{
  "ang": 178,
  "shabads": [
    {
      "shabad_id": 527,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7387,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਅੰਮ੍ਰਿਤ ਰਸੁ ਚਾਖੁ ॥",
          "roman": "gur kā sabad aṃmrit ras chākh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦਾ ਆਨੰਦ ਮਾਣ (ਗੁਰੂ ਦਾ ਸ਼ਬਦ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਰਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Вкуси наслаждение Шабда Гуру; Шабд Гуру — это нектарный вкус, дающий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7388,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰਿ ਜਤਨ ਕਹਹੁ ਕਉਨ ਕਾਜ ॥",
          "roman": "avar jatan kahh kaun kāj ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਦੱਸ (ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾ ਕੇ) ਹੋਰ ਹੋਰ ਉੱਦਮ ਕਿਸ ਕੰਮ ਆ ਸਕਦੇ ਹਨ?"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Скажи, какая польза может быть от иных усилий, если забыть Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7389,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਰਾਖੈ ਆਪਿ ਲਾਜ ॥੨॥",
          "roman": "kar kirpā rākhē āp lāj ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਉ, ਉਹ ਪ੍ਰਭੂ) ਮਿਹਰ ਕਰ ਕੇ (ਜੀਵ ਦੀ) ਇੱਜ਼ਤ ਆਪ ਰੱਖਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "(Припади к защите Бога; Он) по милости Сам хранит честь существа. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7390,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਮਾਨੁਖ ਕਹਹੁ ਕਿਆ ਜੋਰੁ ॥",
          "roman": "kiā mānukh kahh kiā jor ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ, ਇਹ ਬੰਦੇ ਕੀਹ ਕਰਨ ਜੋਗੇ ਹਨ? ਇਹਨਾਂ ਦੀ ਆਕੜ (ਦੀ) ਕੀਹ (ਪਾਂਇਆਂ) ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Скажите, на что вообще способны люди? Чего стоит их спесь?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7391,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠਾ ਮਾਇਆ ਕਾ ਸਭੁ ਸੋਰੁ ॥",
          "roman": "jhūṭhā māiā kā sabh sor ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮਾਇਆ ਦੀ ਸਾਰੀ ਫੂੰ-ਫਾਂ ਝੂਠੀ ਹੈ (ਚਾਰ ਦਿਨਾਂ ਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Вся шумиха майи ложна, она на несколько дней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7392,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਰਾਵਨਹਾਰ ਸੁਆਮੀ ॥",
          "roman": "karaṇ karāvanhār suāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਲਕ-ਪ੍ਰਭੂ (ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ ਆਪ ਹੀ) ਸਭ ਕੁਝ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈ, ਆਪ ਹੀ ਜੀਵਾਂ ਪਾਸੋਂ ਸਭ ਕੁਝ ਕਰਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господин-Бог Сам, пребывая во всех существах, способен всё совершать и Сам же побуждает существ всё делать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7393,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥੩॥",
          "roman": "sagal ghaṭā ke antarjāmī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь знает сердца всех существ. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7394,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਸੁਖੁ ਸਾਚਾ ਏਹੁ ॥",
          "roman": "sarab sukhā sukh sāchā eh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਤਿਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਆਪਣੇ ਮਨ ਵਿਚ ਟਿਕਾ ਕੇ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Утверди в своём уме наставление Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7395,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਉਪਦੇਸੁ ਮਨੈ ਮਹਿ ਲੇਹੁ ॥",
          "roman": "gur updes manē mah leh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੀ ਹੈ ਸਾਰੇ ਸੁਖਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਸੁਖ, ਤੇ, ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਸੁਖ।"
            },
            "sahib_singh_ru": {
              "main": "ибо именно это — высшее из всех блаженств и вечное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7396,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਰਾਮ ਨਾਮ ਲਿਵ ਲਾਗੀ ॥",
          "roman": "jā kau rām nām liv lāgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਲਗਨ ਲੱਗ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человеку, к которому прилепляется любовь к Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7397,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸੋ ਧੰਨੁ ਵਡਭਾਗੀ ॥੪॥੭॥੭੬॥",
          "roman": "kah nānak so dhaṇ vaḍbhāgī ॥4॥7॥76॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-  ਉਹ ਧੰਨ ਹੈ ਉਹ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਹੈ ॥੪॥੭॥੭੬॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: он благословен, он велико-счастлив. ॥4॥7॥76॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 528,
      "rahao_verse_id": 7404,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7398,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahlas 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7399,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਹਰਿ ਕਥਾ ਉਤਾਰੀ ਮੈਲੁ ॥",
          "roman": "suṇ har kathā utārī mēl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣ ਕੇ (ਆਪਣੇ ਮਨ ਤੋਂ ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਲਾਹ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые, припав к защите Гуру, слушая хвалу Богу, сняли с ума грязь пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7400,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਪੁਨੀਤ ਭਏ ਸੁਖ ਸੈਲੁ ॥",
          "roman": "mahā punīt bhaē sukh sēl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੜੇ ਹੀ ਪਵਿਤ੍ਰ (ਜੀਵਨ ਵਾਲੇ) ਹੋ ਗਏ, ਉਹਨਾਂ ਅਨੇਕਾਂ ਹੀ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰ ਲਏ।"
            },
            "sahib_singh_ru": {
              "main": "они стали очень чистыми по жизни, они обрели множество радостей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7401,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਪਾਇਆ ਸਾਧਸੰਗੁ ॥",
          "roman": "vaḍē bhāg pāiā sādhsaṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੇ ਵੱਡੀ ਕਿਸਮਤਿ ਨਾਲ ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਹਾਸਲ ਕਰ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "по великой удаче они обрели встречу с Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7402,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਸਿਉ ਲਾਗੋ ਰੰਗੁ ॥੧॥",
          "roman": "pārbrahm siu lāgo raṅg ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦਾ ਪਰਮਾਤਮਾ ਨਾਲ ਪ੍ਰੇਮ ਬਣ ਗਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "у них возникла любовь к Всевышнему ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7403,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਤ ਜਨੁ ਤਾਰਿਓ ॥",
          "roman": "har har nām japat jan tāriō ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਸਿਮਰਦੇ ਸੇਵਕ ਨੂੰ (ਗੁਰੂ ਨੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служителя, поминающего Имя Хари, Гуру переправил через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7404,
          "is_rahao": true,
          "gurmukhi": "ਅਗਨਿ ਸਾਗਰੁ ਗੁਰਿ ਪਾਰਿ ਉਤਾਰਿਓ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "agan sāgar gur pār utāriō ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਸੇਵਕ ਨੂੰ) ਤ੍ਰਿਸ਼ਨਾ-ਅੱਗ ਦੇ ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਲਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру переправил служителя через океан огня жажды ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7405,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕੀਰਤਨੁ ਮਨ ਸੀਤਲ ਭਏ ॥",
          "roman": "kar kīrtan man sītal bhaē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰ ਕੇ ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਠੰਢੇ-ਠਾਰ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Те, чьи умы, совершая хвалу Богу, стали прохладными и мирными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7406,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਵਿਖ ਗਏ ॥",
          "roman": "janam janam kē kilvikh gaē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਜਨਮਾਂ ਜਨਮਾਂਤਰਾਂ ਦੇ ਪਾਪ ਦੂਰ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "у тех ушли грехи многих рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7407,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਪੇਖੇ ਮਨ ਮਾਹਿ ॥",
          "roman": "sarab nidhān pēkhē man māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੇ ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਆਪਣੇ ਮਨ ਵਿਚ ਹੀ ਵੇਖ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Они увидели все сокровища внутри собственного ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7408,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਢੂਢਨ ਕਾਹੇ ਕਉ ਜਾਹਿ ॥੨॥",
          "roman": "ab ḍhūḍhan kāhē kau jāh ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ ਸੁਖ) ਢੂੰਡਣ ਲਈ ਹੁਣ ਉਹ (ਹੋਰ ਕਿਤੇ) ਕਿਉਂ ਜਾਣ? (ਭਾਵ, ਸੁਖ ਦੀ ਭਾਲ ਬਾਹਰ ਜਗਤ ਦੇ ਪਦਾਰਥਾਂ ਵਿਚੋਂ ਕਰਨ ਦੀ ਉਹਨਾਂ ਨੂੰ ਲੋੜ ਨਹੀਂ ਰਹਿੰਦੀ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда зачем им теперь идти куда-то ещё в поисках блаженства? То есть им уже не нужно искать счастье вовне, среди мирских вещей ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7409,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਪੁਨੇ ਜਬ ਭਏ ਦਇਆਲ ॥",
          "roman": "prabh apunē jab bhaē daiāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਜੀ ਆਪਣੇ ਦਾਸਾਂ ਉਤੇ ਦਿਆਲ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь становится милостив к Своим слугам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7410,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਈ ਸੇਵਕ ਘਾਲ ॥",
          "roman": "pūran hōī sēvak ghāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦਾਸਾਂ ਦੀ (ਕੀਤੀ ਹੋਈ ਸੇਵਾ-ਸਿਮਰਨ ਦੀ) ਮਿਹਨਤ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда труд слуг, их служение и памятование, становится плодотворным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7411,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਕੀਏ ਅਪਨੇ ਦਾਸ ॥",
          "roman": "bandhan kāṭ kīē apnē dās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕਾਂ ਦੇ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਬੰਧਨ ਕੱਟ ਕੇ ਪ੍ਰਭੂ ਉਹਨਾਂ ਨੂੰ ਆਪਣੇ ਦਾਸ ਬਣਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Разрубив узлы привязанности к майе, Господь делает их Своими слугами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7412,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਗੁਣਤਾਸ ॥੩॥",
          "roman": "simar simar simar guṇtās ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਸੇਵਕ ਪਰਮਾਤਮਾ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦੇ ਹਨ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Снова и снова поминая Имя Бога, сокровищницы достоинств, слуги сливаются с Ним ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7413,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਮਨਿ ਏਕੋ ਸਭ ਠਾਇ ॥",
          "roman": "ēko man ēko sabh ṭhāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ, ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਹਰੇਕ ਥਾਂ ਵਿਚ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ему видится, что только один Бог обитает в его сердце, и только один Бог видится во всяком месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7414,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹਿਓ ਸਭ ਜਾਇ ॥",
          "roman": "pūran pūr rahiō sabh jāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਵਿਚ ਪਰਮਾਤਮਾ ਹੀ ਪਰਮਾਤਮਾ ਵਿਆਪਕ ਭਰਪੂਰ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ему всюду видится только Бог, всецело и полно пронизывающий всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7415,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਸਭੁ ਭਰਮੁ ਚੁਕਾਇਆ ॥",
          "roman": "gur pūrē sabh bharam chukāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਦੀ ਸਾਰੀ ਭਟਕਣਾ ਦੂਰ ਕਰ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "того человека, чьё внутреннее блуждание полностью устранил совершенный Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7416,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਨਾਨਕ ਸੁਖੁ ਪਾਇਆ ॥੪॥੮॥੭੭॥",
          "roman": "har simrat Nānak sukh pāiā ॥4॥8॥77॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰ ਕੇ ਉਸ ਮਨੁੱਖ ਨੇ ਆਤਮਕ ਆਨੰਦ ਲੱਭ ਲਿਆ ਹੈ ॥੪॥੮॥੭੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! Поминая Бога, этот человек обрёл духовное блаженство ॥4॥8॥77॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 529,
      "rahao_verse_id": 7423,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7417,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahlas 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7418,
          "is_rahao": false,
          "gurmukhi": "ਅਗਲੇ ਮੁਏ ਸਿ ਪਾਛੈ ਪਰੇ ॥",
          "roman": "aglē muē s pāchhē parē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਆਪਣੇ ਵੱਡੇ-ਵਡੇਰੇ ਮਰ ਚੁਕੇ ਹੁੰਦੇ ਹਨ ਉਹ ਭੁੱਲ ਜਾਂਦੇ ਹਨ (ਭਾਵ, ਇਹ ਗੱਲ ਭੁੱਲ ਜਾਂਦੀ ਹੈ ਕਿ ਉਹ ਜੋੜੀ ਹੋਈ ਮਾਇਆ ਇੱਥੇ ਹੀ ਛੱਡ ਗਏ),"
            },
            "sahib_singh_ru": {
              "main": "Те старшие предки, которые уже умерли, забываются; то есть забывается то, что они оставили здесь всю накопленную майю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7419,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਉਬਰੇ ਸੇ ਬੰਧਿ ਲਕੁ ਖਰੇ ॥",
          "roman": "jō ubrē sē bandh lak kharē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਹੁਣ ਜੀਊਂਦੇ ਹਨ ਉਹ (ਮਾਇਆ ਜੋੜਨ ਲਈ) ਲੱਕ ਬੰਨ੍ਹ ਕੇ ਖਲੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "а те, кто ещё живы, стоят с затянутым поясом, чтобы копить майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7420,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਧੰਧੇ ਮਹਿ ਓਇ ਲਪਟਾਏ ॥",
          "roman": "jih dhandhē meh ōe lapaṭāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਧੰਧੇ ਵਿਚ ਉਹ (ਮਰ ਚੁਕੇ ਵੱਡੇ ਵਡੇਰੇ) ਫਸੇ ਹੋਏ ਸਨ,"
            },
            "sahib_singh_ru": {
              "main": "В том деле, в котором были запутаны умершие старшие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7421,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਤੇ ਦੁਗੁਣ ਦਿੜੀ ਉਨ ਮਾਏ ॥੧॥",
          "roman": "un tē duguṇ diṛī un māē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਤੋਂ ਦੂਣੀ ਮਾਇਆ ਦੀ ਪਕੜ ਉਹ ਜੀਊਂਦੇ ਮਨੁੱਖ ਆਪਣੇ ਮਨ ਵਿਚ ਬਣਾ ਲੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "живые люди закрепляют в своём уме вдвое более сильную хватку майи, чем у них ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7422,
          "is_rahao": true,
          "gurmukhi": "ਓਹ ਬੇਲਾ ਕਛੁ ਚੀਤਿ ਨ ਆਵੈ ॥",
          "roman": "ōh bēlā kachh chīt na āvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੂਰਖ ਮਨੁੱਖ ਨੂੰ) ਉਹ ਸਮਾ ਰਤਾ ਭੀ ਚੇਤੇ ਨਹੀਂ ਆਉਂਦਾ (ਜਦੋਂ ਵੱਡੇ-ਵਡੇਰਿਆਂ ਵਾਂਗ ਸਭ ਕੁਝ ਇੱਥੇ ਹੀ ਛੱਡ ਜਾਣਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Глупому человеку совсем не вспоминается то время, когда, как и его предки, придётся оставить здесь всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7423,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨਸਿ ਜਾਇ ਤਾਹੂ ਲਪਟਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "binas jāe tāhū lapaṭāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ (ਮੁੜ ਮੁੜ) ਉਸੇ (ਮਾਇਆ) ਨਾਲ ਚੰਬੜਦਾ ਹੈ ਜਿਸ ਨੇ ਨਾਸ ਹੋ ਜਾਣਾ ਹੈ (ਜਿਸ ਨਾਲ ਸਾਥ ਨਹੀਂ ਨਿਭਣਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Человек снова и снова цепляется именно за ту майю, которая должна исчезнуть и не может сопровождать его ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7424,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਬੰਧੀ ਮੂਰਖ ਦੇਹ ॥",
          "roman": "āsā bandhī mūrakẖ dēh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ ਦਾ ਸਰੀਰ (ਭਾਵ, ਹਰੇਕ ਗਿਆਨ-ਇੰਦ੍ਰਾ ਮਾਇਆ ਦੀਆਂ) ਆਸਾਂ ਨਾਲ ਜਕੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тело глупого человека, то есть все его чувства, остаётся скованным надеждами на майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7425,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਲਪਟਿਓ ਅਸਨੇਹ ॥",
          "roman": "kām krōdh lapaṭiō asnēh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ ਕਾਮ ਕ੍ਰੋਧ ਮੋਹ ਦੇ ਬੰਧਨਾਂ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Глупый человек остаётся запутанным в узах похоти, гнева и привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7426,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰ ਊਪਰਿ ਠਾਢੋ ਧਰਮ ਰਾਇ ॥",
          "roman": "sir ūpar ṭhāḍhō dharam rāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰ ਉੱਤੇ ਧਰਮਰਾਜ ਖਲੋਤਾ ਹੋਇਆ ਹੈ (ਭਾਵ, ਮੌਤ ਦਾ ਸਮਾ ਨੇੜੇ ਆ ਰਿਹਾ ਹੈ, ਪਰ)"
            },
            "sahib_singh_ru": {
              "main": "Над его головой уже стоит Дхармрай, то есть время смерти приближается, но"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7427,
          "is_rahao": false,
          "gurmukhi": "ਮੀਠੀ ਕਰਿ ਕਰਿ ਬਿਖਿਆ ਖਾਇ ॥੨॥",
          "roman": "mīṭhī kar kar bikhiā khāe ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ (ਆਤਮਕ ਮੌਤ ਲਿਆਉਣ ਵਾਲੀ) ਮਾਇਆ (-ਜ਼ਹਰ) ਮਿੱਠੀ ਜਾਣ ਜਾਣ ਕੇ ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "глупый человек продолжает есть сладкий яд майи, приносящий духовную смерть, считая его приятным ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7428,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬੰਧਉ ਹਉ ਸਾਧਉ ਬੈਰੁ ॥ ਹਮਰੀ ਭੂਮਿ ਕਉਣੁ ਘਾਲੈ ਪੈਰੁ ॥",
          "roman": "hau bandhau hau sādhau bēr ॥ hamrī bhūm kauṇ ghālē pēr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ-ਮੱਤਾ ਮੂਰਖ ਮਨੁੱਖ ਇਉਂ ਅਹੰਕਾਰ-ਭਰੀਆਂ ਗੱਲਾਂ ਕਰਦਾ ਹੈ:) ਮੈਂ (ਉਸ ਨੂੰ) ਬੰਨ੍ਹ ਲਵਾਂਗਾ, ਮੈਂ (ਉਸ ਪਾਸੋਂ ਆਪਣਾ) ਵੈਰ (ਦਾ ਬਦਲਾ) ਲਵਾਂਗਾ, ਮੇਰੀ ਭੁਇਂ ਉਤੇ ਕੌਣ ਪੈਰ ਰੱਖਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Опьянённый майей глупец говорит с гордыней так: я его свяжу, я отомщу ему за свою вражду, кто это ставит ногу на мою землю?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7429,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਪੰਡਿਤੁ ਹਉ ਚਤੁਰੁ ਸਿਆਣਾ ॥",
          "roman": "hau paṇḍit hau chatur siāṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਵਿਦਵਾਨ ਹਾਂ, ਮੈਂ ਚਤੁਰ ਹਾਂ ਮੈਂ ਸਿਆਣਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я учёный, я хитёр, я мудр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7430,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੈਹਾਰੁ ਨ ਬੁਝੈ ਬਿਗਾਨਾ ॥੩॥",
          "roman": "karṇēhār na bujhē bigānā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਅਹੰਕਾਰ ਵਿਚ) ਮੂਰਖ ਮਨੁੱਖ ਆਪਣੇ ਪੈਦਾ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੂੰ ਭੀ ਨਹੀਂ ਸਮਝਦਾ (ਚੇਤੇ ਰੱਖਦਾ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В своей гордыне глупый человек даже не понимает и не помнит Творца, который его создал ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7431,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੀ ਗਤਿ ਮਿਤਿ ਆਪੇ ਜਾਨੈ ॥",
          "roman": "apunī gat mit āpē jānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ ਕਿ ਉਹ ਆਪ ਕਿਹੋ ਜਿਹਾ ਹੈ ਤੇ ਕੇਡਾ ਵੱਡਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но что вообще подвластно живому существу? Только Сам Бог знает, каков Он и насколько велик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7432,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਕੋ ਕਹੈ ਕਿਆ ਆਖਿ ਵਖਾਨੈ ॥",
          "roman": "kiā kō kahē kiā ākh vakhānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ (ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਗਤਿ ਮਿਤਿ ਬਾਰੇ) ਕੁਝ ਭੀ ਕਹਿ ਨਹੀਂ ਸਕਦਾ, ਕੁਝ ਭੀ ਆਖ ਕੇ ਬਿਆਨ ਨਹੀਂ ਕਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Живое существо ничего не может сказать о Его состоянии и мере, никак не может это выразить и описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7433,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਜਿਤੁ ਲਾਵਹਿ ਤਿਤੁ ਤਿਤੁ ਲਗਨਾ ॥",
          "roman": "jit jit lāvah tit tit lagnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਜੀਵ ਨੂੰ ਜਿਸ ਜਿਸ ਪਾਸੇ ਲਾਂਦਾ ਹੈਂ, ਉਧਰ ਉਧਰ ਹੀ ਇਹ ਲੱਗ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Куда бы Ты ни направил живое существо, туда оно и может направиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7434,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਭਲਾ ਸਭ ਕਾਹੂ ਮੰਗਨਾ ॥੪॥",
          "roman": "apnā bhalā sabh kāhū maṅgnā ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਜੀਵ ਨੇ ਤੇਰੇ ਪਾਸੋਂ ਹੀ ਆਪਣੇ ਭਲੇ ਦੀ ਮੰਗ ਮੰਗਣੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Каждое существо должно просить своего блага только у Тебя ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7435,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਿਛੁ ਤੇਰਾ ਤੂੰ ਕਰਣੈਹਾਰੁ ॥",
          "roman": "sabh kichh tērā tūṇ karṇēhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਹ ਸਭ ਕੁਝ ਤੇਰਾ ਹੀ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈ, ਤੂੰ ਹੀ ਸਾਰੇ ਜਗਤ ਦਾ ਬਣਾਣ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Всё это создано Тобой, Ты один Создатель всего мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7436,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤੁ ਨਾਹੀ ਕਿਛੁ ਪਾਰਾਵਾਰੁ ॥",
          "roman": "ant nāhī kichh pārāvār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ, ਤੇਰੇ ਸਰੂਪ ਦਾ ਉਰਲਾ ਪਾਰਲਾ ਬੰਨ੍ਹਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Твоим качествам нет конца, не найти ни этого, ни того берега Твоего существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7437,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਅਪਨੇ ਕਉ ਦੀਜੈ ਦਾਨੁ ॥",
          "roman": "dās apnē kau dījē dān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਆਪਣੇ ਦਾਸ ਨੂੰ ਇਹ  ਦਾਤ ਬਖ਼ਸ਼ ਕਿ"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Даруй Своему слуге такой дар, чтобы"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7438,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਨ ਵਿਸਰੈ ਨਾਨਕ ਨਾਮੁ ॥੫॥੯॥੭੮॥",
          "roman": "kabhū na visrē Nānak nām ॥5॥9॥78॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰੇ ਦਾਸ) ਨਾਨਕ ਨੂੰ ਕਦੇ ਤੇਰਾ ਨਾਮ ਨਾਹ ਭੁੱਲੇ ॥੫॥੯॥੭੮॥"
            },
            "sahib_singh_ru": {
              "main": "Твоему слуге Нанаку никогда не забывалось Твоё Имя ॥5॥9॥78॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 530,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7439,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahlas 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7440,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਤਨ ਨਹੀ ਹੋਤ ਛੁਟਾਰਾ ॥",
          "roman": "anik jatan nahī hōt chhuṭārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਅਨੇਕਾਂ ਜਤਨਾਂ ਦੀ ਰਾਹੀਂ ਭੀ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ ਪੈਦਾ ਹੋਏ ਦੁਖ ਕਲੇਸ਼ਾਂ ਤੋਂ) ਖ਼ਲਾਸੀ ਨਹੀਂ ਹੋ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Даже множеством усилий нельзя освободиться от страданий и бедствий, возникающих из-за привязанности к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7441,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਸਿਆਣਪ ਆਗਲ ਭਾਰਾ ॥",
          "roman": "bahut siāṇap āgal bhārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਗੋਂ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਕੀਤੀ ਹੋਈ) ਬਹੁਤੀ ਚਤੁਰਾਈ (ਹੋਰ ਹੋਰ ਦੁੱਖਾਂ ਦਾ) ਬਹੁਤਾ ਭਾਰ (ਸਿਰ ਉਤੇ ਪਾ ਦੇਂਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "напротив, большая хитрость, совершаемая ради майи, кладёт на голову ещё более тяжёлое бремя других страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7442,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਸੇਵਾ ਨਿਰਮਲ ਹੇਤ ॥",
          "roman": "har kī sēvā nirmal hēt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਪਵਿਤ੍ਰ ਪਿਆਰ ਨਾਲ ਹਰੀ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если с чистой любовью совершать служение и бхакти Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7443,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਦਰਗਹ ਸੋਭਾ ਸੇਤ ॥੧॥",
          "roman": "prabh kī dargah sōbhā sēt ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਹਰੀ ਦੀ ਦਰਗਾਹ ਵਿਚ ਆਦਰ-ਵਡਿਆਈ ਨਾਲ ਪਹੁੰਚੀਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "то в Его обитель приходят с почётом и славой ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
