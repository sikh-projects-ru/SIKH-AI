{
  "ang": 182,
  "shabads": [
    {
      "shabad_id": 539,
      "rahao_verse_id": 7616,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7611,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਹਰਖ ਸੋਗ ਬਿਸਥਾਰ ॥",
          "roman": "biāpat harakh sog bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਖ਼ੁਸ਼ੀ ਗ਼ਮੀ ਦਾ ਖਿਲਾਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Где-то разлита радость и печаль,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7612,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਸੁਰਗ ਨਰਕ ਅਵਤਾਰ ॥",
          "roman": "biāpat surag narak avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਜੀਵ ਨਰਕਾਂ ਵਿਚ ਪੈਂਦੇ ਹਨ, ਕਿਤੇ ਸੁਰਗਾਂ ਵਿਚ ਪਹੁੰਚਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "где-то существа попадают в ады, где-то достигают небес,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7613,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਧਨ ਨਿਰਧਨ ਪੇਖਿ ਸੋਭਾ ॥",
          "roman": "biāpat dhan nirdhan pekh sobhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ ਧਨ ਵਾਲੇ ਹਨ, ਕਿਤੇ ਕੰਗਾਲ ਹਨ, ਕਿਤੇ ਕੋਈ ਆਪਣੀ ਸੋਭਾ ਹੁੰਦੀ ਵੇਖ ਕੇ (ਖ਼ੁਸ਼ ਹਨ)-ਇਹਨਾਂ ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ ਮਾਇਆ ਜੀਵਾਂ ਉਤੇ ਪ੍ਰਭਾਵ ਪਾ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "где-то кто-то богат, где-то беден, где-то кто-то радуется, видя свою славу, — всеми этими многими способами майя воздействует на существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7614,
          "is_rahao": false,
          "gurmukhi": "ਮੂਲੁ ਬਿਆਧੀ ਬਿਆਪਸਿ ਲੋਭਾ ॥੧॥",
          "roman": "mūl biādhī biāpas lobhā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਸਾਰੇ ਰੋਗਾਂ ਦਾ ਮੂਲ ਲੋਭ ਬਣ ਕੇ ਮਾਇਆ ਆਪਣਾ ਜ਼ੋਰ ਪਾ ਰਹੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Где-то майя проявляет свою силу как жадность — корень всех болезней. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7615,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਬਿਆਪਤ ਬਹੁ ਪਰਕਾਰੀ ॥",
          "roman": "māiā biāpat bah parkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਤੇਰੀ ਰਚੀ) ਮਾਇਆ ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ (ਜੀਵਾਂ ਉਤੇ) ਪ੍ਰਭਾਵ ਪਾਈ ਰੱਖਦੀ ਹੈ, (ਤੇ ਆਤਮਕ ਮੌਤੇ ਜੀਵਾਂ ਨੂੰ ਮਾਰ ਦੇਂਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О Бог! Сотворённая Тобой майя множеством способов продолжает воздействовать на существ и духовно умерщвляет их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7616,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਜੀਵਹਿ ਪ੍ਰਭ ਓਟ ਤੁਮਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sant jīvahi prabh oṭ tumārī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਸੰਤ ਤੇਰੇ ਆਸਰੇ ਆਤਮਕ ਜੀਵਨ ਮਾਣਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Твои святые, опираясь на Тебя, наслаждаются духовной жизнью. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7617,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਅਹੰਬੁਧਿ ਕਾ ਮਾਤਾ ॥",
          "roman": "biāpat ahaṃbudh kā mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ 'ਹਉ ਹਉ, ਮੈਂ ਮੈਂ' ਦੀ ਅਕਲ ਵਿਚ ਮਸਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где-то кто-то опьянён разумом «хоу хоу, я я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7618,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਸੰਗਿ ਰਾਤਾ ॥",
          "roman": "biāpat putr kalatr saṅg rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ ਪੁੱਤਰ ਇਸਤ੍ਰੀ ਦੇ ਮੋਹ ਵਿਚ ਰੱਤਾ ਪਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где-то кто-то поглощён привязанностью к сыну и жене."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7619,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਹਸਤਿ ਘੋੜੇ ਅਰੁ ਬਸਤਾ ॥",
          "roman": "biāpat hast ghoṛe ar bastā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਹਾਥੀ ਘੋੜਿਆਂ (ਸੁੰਦਰ) ਕੱਪੜਿਆਂ (ਦੀ ਲਗਨ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Где-то есть привязанность к слонам, лошадям и прекрасным одеждам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7620,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਰੂਪ ਜੋਬਨ ਮਦ ਮਸਤਾ ॥੨॥",
          "roman": "biāpat rūp joban mad mastā ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ ਰੂਪ ਤੇ ਜਵਾਨੀ ਦੇ ਨਸ਼ੇ ਵਿਚ ਮਸਤ ਹੈ-ਇਹਨਾਂ ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ ਮਾਇਆ ਆਪਣਾ ਜ਼ੋਰ ਪਾ ਰਹੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "где-то кто-то опьянён красотой и молодостью — такими многими способами майя проявляет свою силу. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7621,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਭੂਮਿ ਰੰਕ ਅਰੁ ਰੰਗਾ ॥",
          "roman": "biāpat bhūm raṅk ar raṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਭੁਇਂ ਦੀ ਮਾਲਕੀ ਹੈ, ਕਿਤੇ ਕੰਗਾਲ ਹਨ, ਕਿਤੇ ਅਮੀਰ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Где-то есть владение землёй, где-то нищета, где-то богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7622,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਗੀਤ ਨਾਦ ਸੁਣਿ ਸੰਗਾ ॥",
          "roman": "biāpat gīt nād suṇ saṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਮੰਡਲੀਆਂ ਵਿਚ ਗੀਤ ਨਾਦ ਸੁਣ ਕੇ (ਖ਼ੁਸ਼ ਹੋ ਰਹੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "где-то радуются, слушая песни и музыку в собраниях,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7623,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਸੇਜ ਮਹਲ ਸੀਗਾਰ ॥",
          "roman": "biāpat sej mahal sīgār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ (ਸੋਹਣੀ) ਸੇਜ, ਹਾਰ-ਸਿੰਗਾਰ ਤੇ ਮਹਲ-ਮਾੜੀਆਂ (ਦੀ ਲਾਲਸਾ ਹੈ), ਇਹਨਾਂ ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ ਮਾਇਆ ਪ੍ਰਭਾਵ ਪਾ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "где-то есть влечение к красивому ложу, украшениям и дворцам — такими многими способами майя воздействует."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7624,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਦੂਤ ਬਿਆਪਤ ਅੰਧਿਆਰ ॥੩॥",
          "roman": "pañch dūt biāpat aṅdhiār ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਮੋਹ ਦੇ ਹਨੇਰੇ ਵਿਚ ਕਾਮਾਦਿਕ ਪੰਜੇ ਦੂਤ ਬਣ ਕੇ ਮਾਇਆ ਜ਼ੋਰ ਪਾ ਰਹੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Где-то во тьме привязанности майя проявляет свою силу через пятерых посланцев — кам и прочее. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7625,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਕਰਮ ਕਰੈ ਹਉ ਫਾਸਾ ॥",
          "roman": "biāpat karam karē hau fāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ ਹਉਮੈ ਵਿਚ ਫਸਿਆ ਹੋਇਆ (ਆਪਣੇ ਵਲੋਂ ਧਾਰਮਿਕ) ਕੰਮ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Где-то кто-то, запутавшись в хоумэ, совершает со своей стороны религиозные дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7626,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤਿ ਗਿਰਸਤ ਬਿਆਪਤ ਉਦਾਸਾ ॥",
          "roman": "biāpat girast biāpat udāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਗ੍ਰਿਹਸਤ ਵਿਚ ਪ੍ਰਵਿਰਤ ਹੈ, ਕੋਈ ਉਦਾਸੀ ਰੂਪ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто-то вовлечён в жизнь домохозяина, кто-то пребывает в облике отречённого,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7627,
          "is_rahao": false,
          "gurmukhi": "ਆਚਾਰ ਬਿਉਹਾਰ ਬਿਆਪਤ ਇਹ ਜਾਤਿ ॥",
          "roman": "āchār biuhār biāpat ih jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਕੋਈ ਧਾਰਮਿਕ ਰਸਮਾਂ ਵਿਚ ਪ੍ਰਵਿਰਤ ਹੈ, ਕੋਈ (ਉੱਚੀ) ਜਾਤਿ ਦੇ ਮਾਣ ਵਿਚ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "где-то кто-то погружён в религиозные обряды, кто-то — в гордость своей высокой кастой;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7628,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਿਛੁ ਬਿਆਪਤ ਬਿਨੁ ਹਰਿ ਰੰਗ ਰਾਤ ॥੪॥",
          "roman": "sabh kichh biāpat bin har raṅg rāt ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ ਵਿਚ ਮਗਨ ਹੋਣ ਤੋਂ ਵਾਂਜੇ ਰਹਿ ਕੇ ਇਹ ਸਭ ਕੁਝ ਮਾਇਆ ਦਾ ਪ੍ਰਭਾਵ ਹੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "всё это — лишь воздействие майи, если человек остаётся лишён погружённости в любовь к Богу. ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7629,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੇ ਬੰਧਨ ਕਾਟੇ ਹਰਿ ਰਾਇ ॥",
          "roman": "santan ke banḍhan kāṭe har rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਸੰਤ ਜਨਾਂ ਦੇ ਮਾਇਆ ਦੇ ਬੰਧਨ ਕੱਟ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог разрывает у святых людей узы майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7630,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਕਹਾ ਬਿਆਪੈ ਮਾਇ ॥",
          "roman": "tā kau kahā biāpē māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਉਤੇ ਮਾਇਆ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "На таких людей майя уже не может оказывать свою силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7631,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਨਿ ਧੂਰਿ ਸੰਤ ਪਾਈ ॥ ਤਾ ਕੈ ਨਿਕਟਿ ਨ ਆਵੈ ਮਾਈ ॥੫॥੧੯॥੮੮॥",
          "roman": "kah Nānak jin dhūr sant pāī || tā kē nikaṭ na āvē māī ||5||19||88||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਨੇ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਪ੍ਰਾਪਤ ਕਰ ਲਈ ਹੈ, ਮਾਇਆ ਉਸ ਮਨੁੱਖ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕ ਸਕਦੀ ॥੪॥੧੯॥੮੮॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: человек, получивший пыль со Стоп святых людей, становится таким, к кому майя не может даже приблизиться. ||4||19||88||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 540,
      "rahao_verse_id": 7638,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7632,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7633,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨਹੁ ਨੀਦ ਪਰ ਦ੍ਰਿਸਟਿ ਵਿਕਾਰ ॥",
          "roman": "nēnah nīd par dṛiṣṭ vikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਾਏ ਰੂਪ ਨੂੰ ਵਿਕਾਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਵੇਖਣਾ-ਇਹ ਅੱਖਾਂ ਵਿਚ ਨੀਂਦ ਆ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Смотреть на чужую красоту взглядом порока — это сон в глазах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7634,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਵਣ ਸੋਏ ਸੁਣਿ ਨਿੰਦ ਵੀਚਾਰ ॥",
          "roman": "sravaṇ soē suṇ nind vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰਨਾਂ ਦੀ ਨਿੰਦਿਆ ਦੀ ਵਿਚਾਰ ਸੁਣ ਸੁਣ ਕੇ ਕੰਨ ਸੁੱਤੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Слушая и слушая разговоры, полные злословия о других, уши остаются спящими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7635,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਸੋਈ ਲੋਭਿ ਮੀਠੈ ਸਾਦਿ ॥",
          "roman": "rasnā soī lobh mīṭhē sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਖਾਣ ਦੇ ਲੋਭ ਵਿਚ ਪਦਾਰਥਾਂ ਦੇ ਮਿੱਠੇ ਸੁਆਦ ਵਿਚ ਸੁੱਤੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Язык спит в жадности к еде, в сладком вкусе веществ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7636,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਸੋਇਆ ਮਾਇਆ ਬਿਸਮਾਦਿ ॥੧॥",
          "roman": "man soiā māiā bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਮਾਇਆ ਦੇ ਅਸਚਰਜ ਤਮਾਸ਼ੇ ਵਿਚ ਸੁੱਤਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ум спит в изумляющем зрелище майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7637,
          "is_rahao": true,
          "gurmukhi": "ਇਸੁ ਗ੍ਰਿਹ ਮਹਿ ਕੋਈ ਜਾਗਤੁ ਰਹੈ ॥",
          "roman": "is grih meh koī jāgat rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਇਸ ਸਰੀਰ-ਘਰ ਵਿਚ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В этом доме-теле лишь какой-нибудь редкий человек остаётся бодрствующим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7638,
          "is_rahao": true,
          "gurmukhi": "ਸਾਬਤੁ ਵਸਤੁ ਓਹੁ ਅਪਨੀ ਲਹੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sābat vastu oh apnī lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ) ਉਹ ਆਪਣੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸਾਰੀ ਦੀ ਸਾਰੀ ਰਾਸਿ-ਪੂੰਜੀ ਸਾਂਭ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он сберегает всё своё достояние духовной жизни в целости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7639,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਹੇਲੀ ਅਪਨੈ ਰਸ ਮਾਤੀ ॥",
          "roman": "sagal sahēlī apnē ras mātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਗਿਆਨ-ਇੰਦ੍ਰੇ ਆਪੋ ਆਪਣੇ ਚਸਕੇ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ."
            },
            "sahib_singh_ru": {
              "main": "Все познавательные чувства упоены каждое своим собственным вкусом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7640,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹ ਅਪੁਨੇ ਕੀ ਖਬਰਿ ਨ ਜਾਤੀ ॥",
          "roman": "grih apunē kī khabar na jātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸਰੀਰ-ਘਰ ਵਿਚ ਇਹ ਸੂਝ ਨਹੀਂ ਰੱਖਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Они не сохраняют осознания своего собственного дома-тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7641,
          "is_rahao": false,
          "gurmukhi": "ਮੁਸਨਹਾਰ ਪੰਚ ਬਟਵਾਰੇ ॥",
          "roman": "musanahār pañch baṭvāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਠੱਗਣ ਵਾਲੇ ਪੰਜੇ ਡਾਕੂ-"
            },
            "sahib_singh_ru": {
              "main": "Пять грабителей-разбойников —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7642,
          "is_rahao": false,
          "gurmukhi": "ਸੂਨੇ ਨਗਰਿ ਪਰੇ ਠਗਹਾਰੇ ॥੨॥",
          "roman": "sūnē nagar parē ṭhagahāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁੰਞੇ (ਸਰੀਰ-) ਘਰ ਵਿਚ ਆ ਹੱਲਾ ਬੋਲਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "врываются в пустой дом-тело и совершают налёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7643,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਤੇ ਰਾਖੈ ਬਾਪੁ ਨ ਮਾਈ ॥",
          "roman": "un te rākhē bāp na māī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ (ਪੰਜਾਂ ਡਾਕੂਆਂ ਤੋਂ) ਨਾਹ ਪਿਉ ਬਚਾ ਸਕਦਾ ਹੈ, ਨਾਹ ਮਾਂ ਬਚਾ ਸਕਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "От них не может уберечь ни отец, ни мать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7644,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਤੇ ਰਾਖੈ ਮੀਤੁ ਨ ਭਾਈ ॥",
          "roman": "un te rākhē mīt na bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਤੋਂ ਨਾਂਹ ਕੋਈ ਮਿੱਤਰ ਬਚਾ ਸਕਦਾ ਹੈ, ਨਾਂਹ ਕੋਈ ਭਰਾ ਬਚਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "От них не может уберечь ни друг, ни брат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7645,
          "is_rahao": false,
          "gurmukhi": "ਦਰਬਿ ਸਿਆਣਪ ਨਾ ਓਇ ਰਹਤੇ ॥",
          "roman": "darab siāṇap nā oi rahte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੰਜੇ ਡਾਕੂ ਨਾਹ ਧਨ ਨਾਲ ਵਰਜੇ ਜਾ ਸਕਦੇ ਹਨ, ਨਾਹ ਚਤੁਰਾਈ ਨਾਲ ਵਰਜੇ ਜਾ ਸਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Этих пятерых разбойников нельзя удержать ни богатством, ни хитростью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7646,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਓਇ ਦੁਸਟ ਵਸਿ ਹੋਤੇ ॥੩॥",
          "roman": "sādhasaṅg oi duṣṭ vas hote",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੰਜੇ ਦੁਸ਼ਟ ਸਿਰਫ਼ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਹੀ ਕਾਬੂ ਵਿਚ ਆਉਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Эти пятеро злодеев приходят под контроль только в садх-сангате."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7647,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਸਾਰਿੰਗਪਾਣਿ ॥",
          "roman": "kar kirpā moh sāriṅgpāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਧਨੁਖ-ਧਾਰੀ ਪ੍ਰਭੂ! ਮੇਰੇ ਉਤੇ ਕਿਰਪਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, держащий лук, окажи мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7648,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਧੂਰਿ ਸਰਬ ਨਿਧਾਨ ॥",
          "roman": "santan dhūr sarab nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਸੰਤਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਦੇਹ, ਏਹੀ ਮੇਰੇ ਵਾਸਤੇ ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Дай мне пыль от стоп святых — для меня это все сокровища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7649,
          "is_rahao": false,
          "gurmukhi": "ਸਾਬਤੁ ਪੂੰਜੀ ਸਤਿਗੁਰ ਸੰਗਿ ॥",
          "roman": "sābat pūñjī satigur saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਆਤਮਕ ਜੀਵਨ ਦਾ ਸਰਮਾਇਆ ਸਾਰੇ ਦਾ ਸਾਰਾ ਬਚਿਆ ਰਹਿ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в общении с Сатгуру, можно полностью сохранить капитал духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7650,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਾਗੈ ਪਾਰਬ੍ਰਹਮ ਕੈ ਰੰਗਿ ॥੪॥",
          "roman": "nānak jāgē pārbrahm kē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦਾ ਸੇਵਕ) ਨਾਨਕ ਪਰਮਾਤਮਾ ਦੇ ਪਰੇਮ-ਰੰਗ ਵਿਚ ਰਹਿ ਕੇ ਹੀ ਸੁਚੇਤ ਰਹਿ ਸਕਦਾ ਹੈ (ਤੇ ਪੰਜਾਂ ਦੇ ਹੱਲਿਆਂ ਤੋਂ ਬਚ ਸਕਦਾ ਹੈ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак бодрствует только пребывая в любви Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7651,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਜਾਗੈ ਜਿਸੁ ਪ੍ਰਭੁ ਕਿਰਪਾਲੁ ॥",
          "roman": "so jāgē jis prabh kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਡਾਕੂਆਂ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਓਹੀ ਮਨੁੱਖ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ, ਜਿਸ ਤੇ ਪਰਮਾਤਮਾ ਆਪ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бодрствует только тот человек, к кому Сам Бог милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7652,
          "is_rahao": true,
          "gurmukhi": "ਇਹ ਪੂੰਜੀ ਸਾਬਤੁ ਧਨੁ ਮਾਲੁ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥੨੦॥੮੯॥",
          "roman": "ih pūñjī sābat dhan māl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸਦੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਇਹ ਰਾਸਿ-ਪੂੰਜੀ ਸਾਰੀ ਦੀ ਸਾਰੀ ਬਚੀ ਰਹਿੰਦੀ ਹੈ, ਉਸਦੇ ਪਾਸ ਪ੍ਰਭੂ ਦਾ ਨਾਮ-ਧਨ ਸਰਮਾਇਆ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥੨੦॥੮੯॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда этот капитал его духовной жизни целиком сохраняется, и у него остаётся богатство Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 541,
      "rahao_verse_id": 7659,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7653,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7654,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਵਸਿ ਖਾਨ ਸੁਲਤਾਨ ॥",
          "roman": "jā kē vas khān sultān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਦੁਨੀਆ ਦੇ) ਖ਼ਾਨ ਤੇ ਸੁਲਤਾਨ (ਭੀ) ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਅਧੀਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Ханы и султаны мира тоже подвластны Тому Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7655,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਵਸਿ ਹੈ ਸਗਲ ਜਹਾਨ ॥",
          "roman": "jā kē vas hē sagal jahān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰਾ ਜਗਤ ਹੀ ਜਿਸਦੇ ਹੁਕਮ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в Чьём повелении находится весь мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7656,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਕੀਆ ਸਭੁ ਕਿਛੁ ਹੋਇ ॥",
          "roman": "jā kā kīā sabh kichh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਕੀਤਾ ਹੋਇਆ ਹੀ (ਜਗਤ ਵਿਚ) ਸਭ ਕੁਝ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "по воле Которого в мире происходит всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7657,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਤੇ ਬਾਹਰਿ ਨਾਹੀ ਕੋਇ ॥੧॥",
          "roman": "tis te bāhar nāhī koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਤੋਂ ਕੋਈ ਭੀ ਜੀਵ ਆਕੀ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и никто из существ не может быть вне Его власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7658,
          "is_rahao": true,
          "gurmukhi": "ਕਹੁ ਬੇਨੰਤੀ ਅਪੁਨੇ ਸਤਿਗੁਰ ਪਾਹਿ ॥",
          "roman": "kah benantī apune satigur pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਣੇ ਗੁਰੂ ਪਾਸ ਬੇਨਤੀ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Обрати свою мольбу к своему Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7659,
          "is_rahao": true,
          "gurmukhi": "ਕਾਜ ਤੁਮਾਰੇ ਦੇਇ ਨਿਬਾਹਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kāj tumāre dei nibāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਤੇਰੇ ਕਾਰਜ (ਜਨਮ-ਮਨੋਰਥ) ਪੂਰੇ ਕਰ ਦੇਵੇਗਾ, ਭਾਵ (ਤੈਨੂੰ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ  ਦਾਤ ਬਖ਼ਸ਼ੇਗਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру исполнит твои дела, то есть дарует тебе дар Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7660,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਜਾ ਕਾ ਦਰਬਾਰੁ ॥",
          "roman": "sabh te ūch jā kā darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ (ਦੁਨੀਆ ਦੇ) ਸਾਰੇ ਸ਼ਾਹਾਂ-ਬਾਦਸ਼ਾਹਾਂ ਦੇ ਦਰਬਾਰਾਂ ਨਾਲੋਂ ਉੱਚਾ (ਸ਼ਾਨਦਾਰ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чей двор выше и величественнее всех дворов царей и императоров мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7661,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਭਗਤ ਜਾ ਕਾ ਨਾਮੁ ਅਧਾਰੁ ॥",
          "roman": "sagal bhagat jā kā nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਭਗਤਾਂ ਦੀ (ਜ਼ਿੰਦਗੀ) ਵਾਸਤੇ ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя является опорой жизни для всех преданных,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7662,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਬਿਆਪਿਤ ਪੂਰਨ ਧਨੀ ॥",
          "roman": "sarab biāpit pūran dhanī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਤੇ ਆਪਣਾ ਪ੍ਰਭਾਵ ਰੱਖਦਾ ਹੈ ਅਤੇ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Который, Владыка-Господь, распространяет Своё влияние на всех существ и пребывает во всём,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7663,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਸੋਭਾ ਘਟਿ ਘਟਿ ਬਨੀ ॥੨॥",
          "roman": "jā kī sobhā ghaṭ ghaṭ banī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਸੁੰਦਰਤਾ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਫਬਣ ਵਿਖਾ ਰਹੀ ਹੈ, (ਉਸਦਾ ਨਾਮ ਸਦਾ ਸਿਮਰ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Чья красота сияет в каждом теле, — Его Имя помни всегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7664,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਦੁਖ ਡੇਰਾ ਢਹੈ ॥",
          "roman": "jis simrat dukh ḍērā ḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਸਾਰੇ ਹੀ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят этого Бога, все страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7665,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਜਮੁ ਕਿਛੂ ਨ ਕਹੈ ॥",
          "roman": "jis simrat jam kichhū na kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਮੌਤ ਦਾ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Его Имя, страх смерти не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7666,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਹੋਤ ਸੂਕੇ ਹਰੇ ॥",
          "roman": "jis simrat hot sūke hare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਨਿਰਦਈ ਮਨੁੱਖ ਨਰਮ-ਦਿਲ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят этого Бога, жестокие люди становятся мягкосердечными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
