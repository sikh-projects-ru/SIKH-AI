{
  "ang": 183,
  "shabads": [
    {
      "shabad_id": 541,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7667,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਡੂਬਤ ਪਾਹਨ ਤਰੇ ॥੩॥",
          "roman": "jis simrat ḍūbat pāhan tare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਪੱਥਰ-ਦਿਲ ਮਨੁੱਖ (ਕਠੋਰਤਾ ਦੇ ਸਮੁੰਦਰ ਵਿਚ) ਡੁੱਬਣੋਂ ਬਚ ਜਾਂਦੇ ਹਨ, (ਤੂੰ ਭੀ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਉਸਦਾ ਨਾਮ ਸਿਮਰ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Его Имя, даже люди с каменным сердцем спасаются от погружения в океан жестокости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7668,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਭਾ ਕਉ ਸਦਾ ਜੈਕਾਰੁ ॥",
          "roman": "sant sabhā kau sadā jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਾਧ ਸੰਗਤਿ ਅੱਗੇ ਸਦਾ ਸਿਰ ਨਿਵਾਉ,"
            },
            "sahib_singh_ru": {
              "main": "Всегда преклоняй голову перед садх-сангатом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7669,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਨ ਪ੍ਰਾਨ ਅਧਾਰੁ ॥",
          "roman": "har har nām jan prān adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਾਧ ਜਨਾਂ (ਗੁਰਮੁਖਾਂ) ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਹੁੰਦਾ ਹੈ, (ਉਨ੍ਹਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਤੈਨੂੰ ਭੀ ਹਰਿ-ਨਾਮ ਦੀ ਪ੍ਰਾਪਤੀ ਹੋਵੇਗੀ)।"
            },
            "sahib_singh_ru": {
              "main": "Потому что Имя Бога — опора жизни святых людей; в их обществе и ты обретёшь Хари-Нам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7670,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਮੇਰੀ ਸੁਣੀ ਅਰਦਾਸਿ ॥",
          "roman": "kah nānak merī suṇī ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਕਰਤਾਰ ਨੇ) ਮੇਰੀ ਬੇਨਤੀ ਸੁਣ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: Творец услышал мою молитву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7671,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਮੋ ਕਉ ਨਾਮ ਨਿਵਾਸਿ ॥੪॥੨੧॥੯੦॥",
          "roman": "sant prasād mo kau nām nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸਨੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਨੂੰ ਆਪਣੇ ਨਾਮ ਦੇ ਘਰ ਵਿਚ (ਟਿਕਾ ਦਿੱਤਾ ਹੈ) ॥੪॥੨੧॥੯੦॥"
            },
            "sahib_singh_ru": {
              "main": "и по милости Гуру Он утвердил меня в доме Своего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 542,
      "rahao_verse_id": 7678,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7672,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7673,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਦਰਸਨਿ ਅਗਨਿ ਨਿਵਾਰੀ ॥",
          "roman": "satigur darsan agan nivārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੇ ਦੀਦਾਰ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ) ਬੁਝਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) благословением созерцания Гуру человек гасит внутри себя огонь жажды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7674,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਭੇਟਤ ਹਉਮੈ ਮਾਰੀ ॥",
          "roman": "satigur bheṭat haumē mārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਆਪਣੇ ਮਨ ਵਿਚੋਂ) ਹਉਮੈ ਮਾਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "встретив Гуру, он убивает в своём уме Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7675,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਸੰਗਿ ਨਾਹੀ ਮਨੁ ਡੋਲੈ ॥",
          "roman": "satigur saṅg nāhī man ḍolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ (ਮਨੁੱਖ ਦਾ) ਮਨ (ਵਿਕਾਰਾਂ ਵਾਲੇ ਪਾਸੇ) ਡੋਲਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "пребывая в обществе Гуру, ум человека не колеблется в сторону пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7676,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਾਣੀ ਗੁਰਮੁਖਿ ਬੋਲੈ ॥੧॥",
          "roman": "amrit bāṇī gurmukh bolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਗੁਰਬਾਣੀ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(потому что) припав к защите Гуру, человек произносит Гурбани, дающую духовную жизнь. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7677,
          "is_rahao": true,
          "gurmukhi": "ਸਭੁ ਜਗੁ ਸਾਚਾ ਜਾ ਸਚ ਮਹਿ ਰਾਤੇ ॥",
          "roman": "sabh jag sācā jā sach mah rāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਦੋਂ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਪ੍ਰਭੂ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲਈਦੀ ਹੈ, ਜਦੋਂ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗੇ ਜਾਈਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) когда через Гуру обретается глубокая связь с Богом, когда человек окрашивается в любовь к вечно-неизменному Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7678,
          "is_rahao": true,
          "gurmukhi": "ਸੀਤਲ ਸਾਤਿ ਗੁਰ ਤੇ ਪ੍ਰਭ ਜਾਤੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sītal sāṅt gur te prabh jāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹਿਰਦਾ ਠੰਡਾ-ਠਾਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਤਦੋਂ (ਮਨ ਵਿਚ) ਸ਼ਾਂਤੀ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ, ਤਦੋਂ ਸਾਰਾ ਜਗਤ ਸਦਾ-ਥਿਰ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਦਿੱਸਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тогда сердце становится прохладным и умиротворённым, тогда в уме воцаряется покой, тогда весь мир видится образом вечно-неизменного Параматмы. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7679,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਜਪੈ ਹਰਿ ਨਾਉ ॥",
          "roman": "saṅt prasād japē har nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) по милости Гуру человек повторяет Имя Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7680,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਹਰਿ ਕੀਰਤਨੁ ਗਾਉ ॥",
          "roman": "saṅt prasād har kīrtan gāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹਰਿ ਕੀਰਤਨ ਦਾ ਗਾਇਨ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру он поёт киртан Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7681,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਸਗਲ ਦੁਖ ਮਿਟੇ ॥",
          "roman": "saṅt prasād sagal dukh miṭe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸਦਾ ਨਤੀਜਾ ਇਹ ਨਿਕਲਦਾ ਹੈ ਕਿ) ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਨੁੱਖ ਦੇ ਸਾਰੇ ਦੁੱਖ-ਕਲੇਸ਼ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(в результате этого) по милости Сатгуру у человека исчезают все страдания и беды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7682,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਬੰਧਨ ਤੇ ਛੁਟੇ ॥੨॥",
          "roman": "saṅt prasād bandhan te chhuṭe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਬੰਧਨਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਪਾ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "(потому что) по милости Гуру человек освобождается от уз привязанности к майе. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7683,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕ੍ਰਿਪਾ ਤੇ ਮਿਟੇ ਮੋਹ ਭਰਮ ॥",
          "roman": "saṅt kirpā te miṭe moh bharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਾਇਆ ਦਾ ਮੋਹ ਤੇ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਭਟਕਣ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) по милости Гуру исчезают привязанность к майе и блуждание ради майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7684,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਰੇਣ ਮਜਨ ਸਭਿ ਧਰਮ ॥",
          "roman": "sādh reṇ majan sabh dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜੀ ਦਾ ਇਸ਼ਨਾਨ ਹੀ ਸਾਰੇ ਧਰਮਾਂ ਦਾ (ਸਾਰ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Омовение пылью стоп Гуру и есть суть всех дхарм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7685,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕ੍ਰਿਪਾਲ ਦਇਆਲ ਗੋਵਿੰਦੁ ॥",
          "roman": "sādh kirpāl daiyāl govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲੇ) ਗੁਰਮੁਖ ਦਇਆਵਾਨ ਹੁੰਦੇ ਹਨ, ਉਸ ਤੇ ਪਰਮਾਤਮਾ ਭੀ ਦਇਆਵਾਨ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "На того человека, к кому милостивы гурмухи, пребывающие лицом к Гуру, милостивым становится и Параматма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7686,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਾ ਮਹਿ ਇਹ ਹਮਰੀ ਜਿੰਦੁ ॥੩॥",
          "roman": "sādhā mahi ih hamrī jind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੇਰੀ ਜਿੰਦ ਭੀ ਗੁਰਮੁਖਾਂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਹੀ ਵਾਰਨੇ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) и моя жизнь готова отдаться у стоп гурмухов. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7687,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਾ ਨਿਧਿ ਕਿਰਪਾਲ ਧਿਆਵਉ ॥ ਸਾਧਸੰਗਿ ਤਾ ਬੈਠਣੁ ਪਾਵਉ ॥",
          "roman": "kirpā nidh kirpāl dhiāvau, sādhsaṅg tā bēṭhaṇ pāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਜਦੋਂ ਮੈਂ ਕਿਰਪਾ ਦੇ ਖ਼ਜ਼ਾਨੇ, ਕਿਰਪਾ ਦੇ ਘਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹਾਂ, ਸਾਧ-ਸੰਗਤਿ ਵਿਚ ਮੇਰਾ ਜੀਅ ਪਰਚਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда по милости Гуру я памятую Имя Параматмы — сокровищницы милости, обители милости, — тогда моя душа находит удовлетворение в Садх Сангате."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7688,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਨਿਰਗੁਣ ਕਉ ਪ੍ਰਭਿ ਕੀਨੀ ਦਇਆ ॥",
          "roman": "moh nirguṇ kau prabh kīnī daiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਗੁਣ-ਹੀਨ ਉਤੇ ਪ੍ਰਭੂ ਨੇ ਦਇਆ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Надо мной, лишённым достоинств, Бог сжалился,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7689,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਨਾਨਕ ਨਾਮੁ ਲਇਆ ॥੪॥੨੨॥੯੧॥",
          "roman": "sādhsaṅg nānak nām laiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ = ਹੇ ਭਾਈ!) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮੈਂ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਣ ਲੱਗ ਪਿਆ ॥੪॥੨੨॥੯੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! В Садх Сангате я стал повторять Имя Бога. ॥4॥22॥91॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 543,
      "rahao_verse_id": 7696,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7690,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7691,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਪਿਓ ਭਗਵੰਤੁ ॥",
          "roman": "sādhsaṅg japiyo bhagvaṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਭਗਵਾਨ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(По милости Гуру те люди,) которые в Садх Сангате памятовали Бхагванта,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7692,
          "is_rahao": false,
          "gurmukhi": "ਕੇਵਲ ਨਾਮੁ ਦੀਓ ਗੁਰਿ ਮੰਤੁ ॥",
          "roman": "kēval nām dīo gur mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੂੰ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਮੰਤਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "которым Гуру дал мантру — одно лишь Имя Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7693,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਅਭਿਮਾਨ ਭਏ ਨਿਰਵੈਰ ॥",
          "roman": "taj abhimān bhae nirvēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮੰਤਰ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਉਹ ਅਹੰਕਾਰ ਛੱਡ ਕੇ ਨਿਰਵੈਰ ਹੋ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(благодаря силе этой мантры) отбросили гордыню и стали Нирвэр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7694,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪੂਜਹੁ ਗੁਰ ਪੈਰ ॥੧॥",
          "roman": "āṭh pahar pūjah gur pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਗੁਰੂ ਦੇ ਪੈਰ ਪੂਜੋ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) все восемь страж дня и ночи поклоняйся стопам Гуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7695,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਮਤਿ ਬਿਨਸੀ ਦੁਸਟ ਬਿਗਾਨੀ ॥",
          "roman": "ab mat binsī dusṭ bigānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਤਦੋਂ ਤੋਂ ਮੇਰੀ ਭੈੜੀ ਤੇ ਬੇ-ਸਮਝੀ ਵਾਲੀ ਮਤਿ ਦੂਰ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! С тех пор мой дурной и неразумный ум исчез,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7696,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਤੇ ਸੁਣਿਆ ਹਰਿ ਜਸੁ ਕਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jab te suṇiā har jas kānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੋਂ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਮੈਂ ਕੰਨੀਂ ਸੁਣੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "как только я услышал своими ушами хвалу Параматме. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7697,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸੂਖ ਆਨੰਦ ਨਿਧਾਨ ॥",
          "roman": "sahaj sūkh ānand nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਹਰਿ-ਜਸ ਕੰਨੀਂ ਸੁਣਿਆ ਹੈ) ਆਤਮਕ ਅਡੋਲਤਾ, ਸੁਖ ਅਨੰਦ ਦੇ ਖ਼ਜ਼ਾਨੇ-"
            },
            "sahib_singh_ru": {
              "main": "(О брат! У тех людей, которые услышали ушами хвалу Хари,) духовная устойчивость, покой и сокровища блаженства —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7698,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਰਖਿ ਲੇਇ ਨਿਦਾਨ ॥",
          "roman": "rākhanhār rakh lei nidān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਖਣਹਾਰ ਪਰਮਾਤਮਾ ਨੇ ਆਖ਼ਰ ਉਹਨਾਂ ਦੀ (ਸਦਾ) ਰੱਖਿਆ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "их в конце концов всегда хранит и защищает Хранитель-Параматма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7699,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਦਰਦ ਬਿਨਸੇ ਭੈ ਭਰਮ ॥",
          "roman": "dūkh darad binse bhē bharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਦੁੱਖ, ਦਰਦ, ਡਰ, ਵਹਿਮ ਸਾਰੇ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Их страдания, боли, страхи и сомнения — всё это исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7700,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣ ਜਾਣ ਰਖੇ ਕਰਿ ਕਰਮ ॥੨॥",
          "roman": "āvaṇ jāṇ rakhe kar karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਮਿਹਰ ਕਰ ਕੇ ਉਨ੍ਹਾਂ ਦੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ (ਭੀ) ਮੁਕਾ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Параматма, явив милость, прекращает и круг их рождений и смертей. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7701,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖੈ ਬੋਲੈ ਸੁਣੈ ਸਭੁ ਆਪਿ ॥",
          "roman": "pekẖē bolē suṇē sabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਜਿਹੜਾ ਪਰਮਾਤਮਾ ਹਰ ਥਾਂ (ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ) ਆਪ ਵੇਖਦਾ ਹੈ ਆਪ ਹੀ ਬੋਲਦਾ ਹੈ, ਆਪ ਹੀ ਸੁਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Тот Параматма, который повсюду, распространившись во всех существах, Сам видит, Сам говорит и Сам слушает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7702,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸੰਗਿ ਤਾ ਕਉ ਮਨ ਜਾਪਿ ॥",
          "roman": "sadā saṅg tā kau man jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਹਰ ਵੇਲੇ ਤੇਰੇ ਅੰਗ-ਸੰਗ ਹੈ, ਉਸਦਾ ਭਜਨ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "который всегда рядом с тобой, — памятуй Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7703,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਭਇਓ ਪਰਗਾਸੁ ॥",
          "roman": "saṅt prasād bhaio pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਵਾਲਾ ਚਾਨਣ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У человека, в котором по милости Гуру рождается свет духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7704,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਿ ਰਹੇ ਏਕੈ ਗੁਣਤਾਸੁ ॥੩॥",
          "roman": "pūr rahe ekē guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸਨੂੰ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਹਰ ਥਾਂ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тому единый Параматма, сокровищница достоинств, видится пронизывающим всё. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7705,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਪਵਿਤ੍ਰ ਸੁਣਤ ਪੁਨੀਤ ॥ ਗੁਣ ਗੋਵਿੰਦ ਗਾਵਹਿ ਨਿਤ ਨੀਤ ॥",
          "roman": "kahat pavitr suṇat punīt, guṇ govind gāvah nit nīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਹ ਮਨੁੱਖ) ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨ ਵਾਲੇ ਤੇ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਨ ਵਾਲੇ ਸਭੇ ਪਵਿੱਤ੍ਰ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ, ਜੇਹੜੇ ਸਦਾ ਹੀ ਗੋਬਿੰਦ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Те люди) становятся чистыми в жизни — и произносящие хвалу, и слушающие хвалу, — которые постоянно поют достоинства Говинда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7706,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕਉ ਹੋਹੁ ਕ੍ਰਿਪਾਲ ॥",
          "roman": "kah nānak jā kau hoh kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਪ੍ਰਭੂ!) ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਤੂੰ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о Бог! тот человек, к кому Ты милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7707,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਕੀ ਸਭ ਪੂਰਨ ਘਾਲ ॥੪॥੨੩॥੯੨॥",
          "roman": "tis jan kī sabh pūran ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ) ਉਸਦੀ ਸਾਰੀ ਇਹ ਮਿਹਨਤ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ ॥੪॥੨੩॥੯੨॥"
            },
            "sahib_singh_ru": {
              "main": "(тот совершает Твою хвалу), и весь этот его труд становится успешным. ॥4॥23॥92॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 544,
      "rahao_verse_id": 7713,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7708,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7709,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਤੋੜਿ ਬੋਲਾਵੈ ਰਾਮੁ ॥",
          "roman": "bandhan toṛ bolāvē rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ (ਮਨੁੱਖ ਦੇ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਬੰਧਨ ਤੋੜ ਕੇ (ਉਸ ਪਾਸੋਂ) ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Гуру, разрушив узы привязанности к майе, побуждает человека поминать Параматму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7710,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਲਾਗੈ ਸਾਚੁ ਧਿਆਨੁ ॥ ਮਿਟਹਿ ਕਲੇਸ ਸੁਖੀ ਹੋਇ ਰਹੀਐ ॥",
          "roman": "man mah lāgē sāch dhiān, miṭah kalēs sukhī hoi rahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ ਮਿਹਰ ਕਰਦਾ ਹੈ ਉਸ ਦੇ) ਮਨ ਵਿਚ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਦੀ) ਅਟੱਲ ਸੁਰਤ ਬੱਝ ਜਾਂਦੀ ਹੈ। (ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਮਨ ਦੇ ਸਾਰੇ) ਕਲੇਸ਼ ਮਿਟ ਜਾਂਦੇ ਹਨ, ਸੁਖੀ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(У человека, к которому Гуру милостив,) в уме утверждается непоколебимая сосредоточенность на стопах Бога. (О брат! Войдя в защиту Гуру, все) душевные муки исчезают, и жизнь становится счастливой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7711,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਦਾਤਾ ਸਤਿਗੁਰੁ ਕਹੀਐ ॥੧॥",
          "roman": "aisā dātā satigur kahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਗੁਰੂ ਇਹੋ ਜਿਹਾ ਉੱਚੀ  ਦਾਤ ਬਖ਼ਸ਼ਣ ਵਾਲਾ ਕਿਹਾ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Итак, таким подателем столь высокой дары и называют Гуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7712,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਸੁਖਦਾਤਾ ਜਿ ਨਾਮੁ ਜਪਾਵੈ ॥",
          "roman": "so sukhdātā j nām japāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਸਤਿਗੁਰੂ ਆਤਮਕ ਆਨੰਦ ਦੀ  ਦਾਤ ਬਖ਼ਸ਼ਣ ਵਾਲਾ ਹੈ ਕਿਉਂਕਿ ਉਹ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) тот Сатгуру является дарующим духовное блаженство, потому что он побуждает повторять Имя Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7713,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਤਿਸੁ ਸੰਗਿ ਮਿਲਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā tis saṅg milāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮਿਹਰ ਕਰ ਕੇ ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਨਾਲ ਜੋੜਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и, явив милость, соединяет с этим Параматмой. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7714,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਹੋਇ ਦਇਆਲੁ ਤਿਸੁ ਆਪਿ ਮਿਲਾਵੈ ॥",
          "roman": "jis hoi dēāl tis āp milāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਦਇਆਵਾਨ ਹੋਵੇ ਉਸ ਨੂੰ ਆਪ (ਹੀ) ਗੁਰੂ ਮਿਲਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(Но) того человека, к кому Параматма милостив, Он Сам и приводит к Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7715,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਗੁਰੂ ਤੇ ਪਾਵੈ ॥",
          "roman": "sarab nidhān gurū te pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਫਿਰ) ਗੁਰੂ ਪਾਸੋਂ (ਆਤਮਕ ਜੀਵਨ ਦੇ) ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и тогда этот человек через Гуру получает все сокровища духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7716,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਤਿਆਗਿ ਮਿਟੈ ਆਵਣ ਜਾਣਾ ॥",
          "roman": "āp tiāg miṭē āvaṇ jāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਆਪਾ-ਭਾਵ ਤਿਆਗ ਦੇਂਦਾ ਹੈ, ਤੇ ਉਸ ਦਾ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਮੁੱਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он, войдя в защиту Гуру, отбрасывает самоутверждение, и его круг рождений и смертей прекращается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7717,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਪਾਰਬ੍ਰਹਮੁ ਪਛਾਣਾ ॥੨॥",
          "roman": "sādh kē saṅg pārbrahm pachhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ) ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру этот человек обретает глубокую связь с Парабрахмом. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7718,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਊਪਰਿ ਪ੍ਰਭ ਭਏ ਦਇਆਲ ॥",
          "roman": "jan ūpar prabh bhae daiyāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰ-ਸਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਪ੍ਰਭੂ ਜੀ ਸੇਵਕ ਉੱਤੇ ਦਇਆਵਾਨ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Благословением прибежища у Гуру) Бог становится милостив к слуге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
