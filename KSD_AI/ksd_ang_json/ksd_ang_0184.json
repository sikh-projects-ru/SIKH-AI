{
  "ang": 184,
  "shabads": [
    {
      "shabad_id": 544,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7719,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੀ ਟੇਕ ਏਕ ਗੋਪਾਲ ॥",
          "roman": "jan kī ṭek ek gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਗੋਪਾਲ-ਪ੍ਰਭੂ ਹੀ ਸੇਵਕ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и единственный Гопал-Бог становится опорой жизни слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7720,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਲਿਵ ਏਕੋ ਮਨਿ ਭਾਉ ॥",
          "roman": "ekā liv eko man bhāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਆਏ ਮਨੁੱਖ ਨੂੰ) ਇਕ ਪਰਮਾਤਮਾ ਦੀ ਹੀ ਲਗਨ ਲੱਗ ਜਾਂਦੀ ਹੈ, ਉਸ ਦੇ ਮਨ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਪਿਆਰ (ਟਿਕ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "(У человека, пришедшего под защиту Гуру,) возникает устремлённость только к одному Параматме, и в его уме утверждается любовь только к одному Параматме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7721,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਜਨ ਕੈ ਹਰਿ ਨਾਉ ॥੩॥",
          "roman": "sarab nidhān jan kē har nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ (ਦੁਨੀਆ ਦੇ) ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਬਣ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В сердце слуги Имя Параматмы становится всеми сокровищами мира. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7722,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "pārbrahm siu lāgī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਪ੍ਰੀਤਿ ਪਰਮਾਤਮਾ ਨਾਲ ਪੱਕੀ ਬਣ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его любовь становится прочной с Параматмой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7723,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਕਰਣੀ ਸਾਚੀ ਰੀਤਿ ॥",
          "roman": "nirmal karṇī sācī rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਜੀਵਨ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਸ ਦੀ ਜੀਵਨ-ਮਰਯਾਦਾ (ਵਿਕਾਰਾਂ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਅਡੋਲ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "его жизнь становится чистой, его жизненный путь становится непоколебимым перед натиском пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7724,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਮੇਟਿਆ ਅੰਧਿਆਰਾ ॥",
          "roman": "gur pūrē meṭiā andhiārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੀ ਮਿਹਰ ਨਾਲ) ਪੂਰੇ ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ) ਹਨੇਰਾ ਦੂਰ ਕਰ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(по милости Параматмы) совершенный Гуру устранил изнутри этого человека тьму привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7725,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਾ ਪ੍ਰਭੁ ਅਪਰ ਅਪਾਰਾ ॥੪॥੨੪॥੯੩॥",
          "roman": "nānak kā prabh apar apārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹ ਸਾਰੀ ਮਿਹਰ ਪਰਮਾਤਮਾ ਦੀ ਹੀ ਹੈ) ਨਾਨਕ ਦਾ ਪ੍ਰਭੂ ਪਰੇ ਤੋਂ ਪਰੇ ਹੈ ਤੇ ਬੇਅੰਤ ਹੈ ॥੪॥੨੪॥੯੩॥"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Вся эта милость исходит только от Параматмы.) Бог Нанака — запредельный и беспредельный. ॥4॥24॥93॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 545,
      "rahao_verse_id": 7732,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7726,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7727,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਵਸੈ ਤਰੈ ਜਨੁ ਸੋਇ ॥",
          "roman": "jis man vasē tarē jan soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਵੱਸ ਪੈਂਦਾ ਹੈ ਉਹ (ਦੁੱਖਾਂ ਰੋਗਾਂ ਵਿਕਾਰਾਂ ਦੇ ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём уме поселяется Параматма, переправляется через океан страданий, болезней и пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7728,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਕਰਮਿ ਪਰਾਪਤਿ ਹੋਇ ॥",
          "roman": "jā kē karam parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪਰਮਾਤਮਾ) ਦੀ ਬਖ਼ਸ਼ਸ਼ ਨਾਲ (ਜਦੋਂ ਉਸ ਦੇ ਨਾਮ ਦੀ) ਪ੍ਰਾਪਤੀ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда по милости этого Параматмы обретается Его Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7729,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਰੋਗੁ ਕਛੁ ਭਉ ਨ ਬਿਆਪੈ ॥",
          "roman": "dūkh rog kachh bhau na biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਸੰਸਾਰ ਦਾ) ਕੋਈ ਦੁੱਖ ਕੋਈ ਰੋਗ ਕੋਈ ਡਰ ਮਨੁੱਖ ਉੱਤੇ ਆਪਣਾ ਪ੍ਰਭਾਵ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "тогда никакое страдание, никакая болезнь, никакой страх не могут воздействовать на человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7730,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਰਿਦੈ ਹਰਿ ਜਾਪੈ ॥੧॥",
          "roman": "amrit nām ridē har jāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਜਪਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "потому что он повторяет в своём сердце Имя Хари, дарующее духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7731,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਪਰਮੇਸੁਰੁ ਧਿਆਈਐ ॥",
          "roman": "pārbrahm parmēsar dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਅਕਾਲ ਪੁਰਖ ਪਰਮੇਸ਼ਰ ਦਾ ਸਿਮਰਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нужно помнить об Аkal Purakh, о Пармешаре."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7732,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਇਹ ਮਤਿ ਪਾਈਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrē te ih mat pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ) ਇਹ ਸੂਝ ਪੂਰੇ ਗੁਰੂ ਪਾਸੋਂ ਮਿਲਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Это понимание симрана приходит от Совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7733,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਰਾਵਨਹਾਰ ਦਇਆਲ ॥",
          "roman": "karan karāvanhār daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਰੱਖਦਾ ਹੈ, ਜੋ ਜੀਵਾਂ ਪਾਸੋਂ ਸਭ ਕੁਝ ਕਰਾਣ ਦੀ ਤਾਕਤ ਰੱਖਦਾ ਹੈ, ਜੋ ਦਇਆ ਦਾ ਘਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он способен всё совершать, способен всё совершать через существ и является обителью сострадания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7734,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਗਲੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "jīa jant saglē pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਾਰੇ ਜੀਵ ਜੰਤਾਂ ਦੀ ਪਾਲਣਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он поддерживает всех живых существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7735,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰ ਸਦਾ ਬੇਅੰਤਾ ॥",
          "roman": "agam agochar sadā bēantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਅਪਹੁੰਚ ਹੈ, ਜਿਸ ਤਕ ਮਨੁੱਖ ਦੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, ਜਿਸ ਦੇ ਗੁਣਾਂ ਦਾ ਕਦੇ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Он недостижим, недоступен чувствам человеческого познания, и Его качествам никогда не найти конца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7736,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਮਨਾ ਪੂਰੇ ਗੁਰ ਮੰਤਾ ॥੨॥",
          "roman": "simar manā pūrē gur mantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਪੂਰੇ ਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਉੱਤੇ ਤੁਰ ਕੇ ਉਸ (ਪਰਮਾਤਮਾ) ਨੂੰ ਸਿਮਰ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Следуя наставлению Совершенного Гуру, помни Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7737,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਸੇਵਾ ਸਰਬ ਨਿਧਾਨੁ ॥",
          "roman": "jā kī sēvā sarab nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਹੀ (ਜਗਤ ਦੇ) ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В служении и преданности Ему содержатся все сокровища мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7738,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਪੂਜਾ ਪਾਈਐ ਮਾਨੁ ॥",
          "roman": "prabh kī pūjā pāīai mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਹਰੀ ਦੀ ਪੂਜਾ ਕੀਤਿਆਂ (ਹਰ ਥਾਂ) ਆਦਰ-ਮਾਣ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "поклоняясь этому Хари, обретают почёт и уважение повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7739,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਟਹਲ ਨ ਬਿਰਥੀ ਜਾਇ ॥",
          "roman": "jā kī ṭahal na birthī jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦੀ ਕੀਤੀ ਹੋਈ ਸੇਵਾ ਨਿਸਫਲ ਨਹੀਂ ਜਾਂਦੀ"
            },
            "sahib_singh_ru": {
              "main": "и служение Ему не бывает напрасным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7740,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਹਰਿ ਕੇ ਗੁਣ ਗਾਇ ॥੩॥",
          "roman": "sadā sadā har kē guṇ gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਦਾ ਹੀ ਸਦਾ ਉਸ ਹਰੀ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹੁ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому всегда, всегда пой Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7741,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "kar kirpā prabh antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਤਰਜਾਮੀ ਪ੍ਰਭੂ! ਮਿਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О всеведущий Господь, знающий внутреннее! Окажи милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7742,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਨਿਧਾਨ ਹਰਿ ਅਲਖ ਸੁਆਮੀ ॥",
          "roman": "sukh nidhān har alakh suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੁਖਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! ਹੇ ਅਦ੍ਰਿਸ਼ਟ ਸੁਆਮੀ!"
            },
            "sahib_singh_ru": {
              "main": "о Господь, сокровище счастья! О незримый Владыка!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7743,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਤੇਰੀ ਸਰਣਾਈ ॥",
          "roman": "jīa jant tērī sarṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਅ ਜੰਤ ਤੇਰੀ ਸਰਣ ਹਨ (ਤੇਰੇ ਹੀ ਆਸਰੇ ਹਨ, ਮੈਂ ਭੀ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ) ਮਿਹਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Все живые существа находятся в Твоём прибежище, опираются на Тебя; и я тоже пришёл в Твоё прибежище, окажи милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7744,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਮਿਲੈ ਵਡਿਆਈ ॥੪॥੨੫॥੯੪॥",
          "roman": "nānak nām milē vadiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ-ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) ਮੈਨੂੰ ਤੇਰਾ ਨਾਮ ਮਿਲ ਜਾਏ (ਤੇਰਾ ਨਾਮ ਹੀ ਮੇਰਾ ਵਾਸਤੇ) ਵਡਿਆਈ ਹੈ ॥੪॥੨੫॥੯੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись у двери Господа и скажи: пусть мне будет даровано Твоё Имя, ибо Твоё Имя и есть для меня величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 546,
      "rahao_verse_id": 7751,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7745,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7746,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੁਗਤਿ ਜਾ ਕੈ ਹੈ ਹਾਥ ॥",
          "roman": "jīa jugat jā kē hē hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਦੇ ਹੱਥਾਂ ਵਿਚ ਸਭ ਜੀਵਾਂ ਦੀ ਜੀਵਨ-ਮਰਯਾਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В чьих руках находится жизненный уклад всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7747,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਮਰਹੁ ਅਨਾਥ ਕੋ ਨਾਥੁ ॥",
          "roman": "so simarh anāth ko nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਅਨਾਥਾਂ ਦੇ ਨਾਥ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "того Параматму, Господа бесприютных, помни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7748,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਚਿਤਿ ਆਏ ਸਭੁ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "prabh chit āe sabh dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇ ਪਰਮਾਤਮਾ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਵੱਸ ਪਏ ਤਾਂ (ਉਸ ਦਾ) ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если Параматма поселяется в уме человека, тогда всякое его страдание исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7749,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਸਭ ਬਿਨਸਹਿ ਹਰਿ ਕੈ ਨਾਇ ॥੧॥",
          "roman": "bhē sabh binsahi har kē nāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਸਾਰੇ ਡਰ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря Имени Хари исчезают все страхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7750,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਭਉ ਕਾਹੇ ਕਾ ਮਾਨਹਿ ॥",
          "roman": "bin har bhau kāhē kā māneh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੂੰ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕਿਸੇ ਦਾ ਡਰ ਕਿਉਂ ਮੰਨਦਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Почему ты признаёшь страх перед кем-либо, кроме Параматмы?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7751,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਬਿਸਰਤ ਕਾਹੇ ਸੁਖੁ ਜਾਨਹਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har bisrat kāhē sukh jāneh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾ ਕੇ ਹੋਰ ਕੇਹੜਾ ਸੁਖ ਸਮਝਦਾ ਹੈਂ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Забыв Параматму, какое ещё счастье ты считаешь счастьем?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7752,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਧਾਰੇ ਬਹੁ ਧਰਣਿ ਅਗਾਸ ॥",
          "roman": "jin dhārē bah dharaṇ agās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰ, ਜਿਸ ਨੇ ਅਨੇਕਾਂ ਧਰਤੀਆਂ ਅਕਾਸ਼ਾਂ ਨੂੰ ਸਹਾਰਾ ਦਿੱਤਾ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда помни того Господа, который поддерживает бесчисленные земли и небеса,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7753,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਜੋਤਿ ਜੀਅ ਪਰਗਾਸ ॥",
          "roman": "jā kī jot jīa pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਜੋਤਿ ਸਾਰੇ ਜੀਵਾਂ ਵਿਚ ਚਾਨਣ ਕਰ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чей свет сияет во всех живых существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7754,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਬਖਸ ਨ ਮੇਟੈ ਕੋਇ ॥",
          "roman": "jā kī bakhas na mēṭē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦੀ (ਕੀਤੀ ਹੋਈ ਬਖ਼ਸ਼ਸ਼ ਨੂੰ ਕੋਈ ਮਿਟਾ ਨਹੀਂ ਸਕਦਾ) (ਕੋਈ ਰੋਕ ਨਹੀਂ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "И Его дарованную милость никто не может ни стереть, ни остановить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7755,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਪ੍ਰਭੁ ਨਿਰਭਉ ਹੋਇ ॥੨॥",
          "roman": "simar simar prabh nirbhau hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਹੈ ਉਹ ਦੁਨੀਆ ਦੇ ਡਰਾਂ ਵਲੋਂ) ਨਿਡਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Человек, который помнит этого Господа, становится бесстрашным перед страхами мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7756,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਸਿਮਰਹੁ ਪ੍ਰਭ ਨਾਮੁ ॥",
          "roman": "āṭh pahar simarh prabh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਅੱਠੇ ਪਹਰ (ਹਰ ਵੇਲੇ) ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Во все восемь страж дня и ночи, то есть всегда, помни Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7757,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਤੀਰਥ ਮਜਨੁ ਇਸਨਾਨੁ ॥",
          "roman": "anik tīrath majan isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸਿਮਰਨ ਹੀ) ਅਨੇਕਾਂ ਤੀਰਥਾਂ ਦਾ ਇਸ਼ਨਾਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это памятование и есть омовение во множестве тиртх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7758,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਸਰਣੀ ਪਾਹਿ ॥",
          "roman": "pārbrahm kī sarṇī pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਸ਼ਰਨ ਪੈ ਜਾਏਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если ты придёшь в прибежище Парабрахма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7759,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕਲੰਕ ਖਿਨ ਮਹਿ ਮਿਟਿ ਜਾਹਿ ॥੩॥",
          "roman": "koṭ kalank khin meh miṭ jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਤੇਰੇ ਕ੍ਰੋੜਾਂ ਪਾਪ ਇਕ ਪਲ ਵਿਚ ਹੀ ਨਾਸ ਹੋ ਜਾਣ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то твои миллионы грехов исчезнут в одно мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7760,
          "is_rahao": false,
          "gurmukhi": "ਬੇਮੁਹਤਾਜੁ ਪੂਰਾ ਪਾਤਿਸਾਹੁ ॥",
          "roman": "bēmuhatāj pūrā pātisāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੂੰ ਕਿਸੇ ਦੀ ਮੁਥਾਜੀ ਨਹੀਂ, ਉਹ ਸਭ ਗੁਣਾਂ ਦਾ ਮਾਲਕ ਹੈ, ਉਸ ਸਭ ਗੁਣਾਂ ਦਾ ਪਾਤਿਸ਼ਾਹ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Параматма ни в ком не нуждается; Он владыка всех качеств, царь всех качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7761,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸੇਵਕ ਸਾਚਾ ਵੇਸਾਹੁ ॥",
          "roman": "prabh sēvak sāchā vēsāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸੇਵਕਾਂ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਅਟੱਲ ਭਰੋਸਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У слуг Господа есть твёрдое доверие к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7762,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਰਾਖੇ ਦੇ ਹਾਥ ॥",
          "roman": "gur pūrē rākhē dē hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਪੂਰੇ ਗੁਰੂ ਦੀ ਰਾਹੀਂ (ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ ਸਭ ਕਲੰਕਾਂ ਤੋਂ) ਹੱਥ ਦੇ ਕੇ ਬਚਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через Совершенного Гуру Параматма, подавая руку, спасает Своих слуг от всех пятен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7763,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਰਬ੍ਰਹਮ ਸਮਰਾਥ ॥੪॥੨੬॥੯੫॥",
          "roman": "nānak pārbrahm samrāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ ॥੪॥੨੬॥੯੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Параматма — владыка всех сил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 547,
      "rahao_verse_id": 7770,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7764,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī guārērī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7765,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਨਾਮਿ ਮਨੁ ਲਾਗਾ ॥",
          "roman": "gur parsād nām man lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей ум по милости Гуру соединяется с Именем Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7766,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗਾ ॥",
          "roman": "janam janam kā soiā jāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਨਮਾਂ ਜਨਮਾਂਤਰਾਂ ਦਾ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ) ਸੁੱਤਾ ਹੋਇਆ (ਭੀ) ਜਾਗ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "пробуждается, хотя спал из рождения в рождение в сне привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7767,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਗੁਣ ਉਚਰੈ ਪ੍ਰਭ ਬਾਣੀ ॥",
          "roman": "amrit guṇ ucharē prabh bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ) ਪ੍ਰਭੂ ਦੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਗੁਣ ਉਚਾਰਦਾ ਹੈ, ਪ੍ਰਭੂ ਦੀ (ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ) ਬਾਣੀ ਉਚਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он произносит качества Господа, дарующие духовную жизнь, произносит банӣ хвалы Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7768,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕੀ ਸੁਮਤਿ ਪਰਾਣੀ ॥੧॥",
          "roman": "pūrē gur kī sumat parāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਾਣੀ ਨੂੰ ਪੂਰੇ ਗੁਰੂ ਦੀ ਸ੍ਰੇਸ਼ਟ ਮਤਿ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "когда живое существо получает прекрасную мудрость Совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7769,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਸਿਮਰਤ ਕੁਸਲ ਸਭਿ ਪਾਏ ॥",
          "roman": "prabh simrat kusal sabh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਹੈ) ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਦਿਆਂ ਉਸ ਨੇ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, который помнит Господа, помня Господа, обретает все блага,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7770,
          "is_rahao": true,
          "gurmukhi": "ਘਰਿ ਬਾਹਰਿ ਸੁਖ ਸਹਜ ਸਬਾਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ghar bāhar sukh sahaj sabāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਭੀ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸਾਰੇ ਅਨੰਦ, ਜਗਤ ਨਾਲ ਵਰਤਦਿਆਂ ਭੀ ਉਸ ਨੂੰ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸਾਰੇ ਆਨੰਦ (ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ।) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в его сердце присутствуют все радости духовной устойчивости, и даже живя среди мира, он получает все радости этой духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7771,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਪਛਾਤਾ ਜਿਨਹਿ ਉਪਾਇਆ ॥",
          "roman": "soī pachhātā jineh upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ ਉਸੇ ਪ੍ਰਭੂ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲਈ, ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਉਸ ਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот человек обрёл глубокую связь именно с тем Господом, который его создал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7772,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਆਪਿ ਮਿਲਾਇਆ ॥",
          "roman": "kar kirpā prabh āp milāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਮਿਹਰ ਕਰ ਕੇ ਉਸ ਮਨੁੱਖ ਨੂੰ ਆਪ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਜੋੜ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Господь по милости Сам соединил этого человека с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7773,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹ ਪਕਰਿ ਲੀਨੋ ਕਰਿ ਅਪਨਾ ॥",
          "roman": "bāh pakar līno kar apnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਬਾਂਹ ਫੜ ਕੇ ਆਪਣਾ ਬਣਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, которого Господь, взяв за руку, сделал Своим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7774,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਥਾ ਸਦਾ ਜਪੁ ਜਪਨਾ ॥੨॥",
          "roman": "har har kathā sadā jap japnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਪ੍ਰਭੂ ਦੀਆਂ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀਆਂ ਗੱਲਾਂ ਕਰਦਾ ਹੈ। ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਜਾਪ ਜਪਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек всегда говорит о славе Господа и повторяет джап Имени Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7775,
          "is_rahao": false,
          "gurmukhi": "ਮੰਤ੍ਰੁ ਤੰਤ੍ਰੁ ਅਉਖਧੁ ਪੁਨਹਚਾਰੁ ॥",
          "roman": "mantr tantr aukhadh punehchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੋਹ ਦੀ ਨੀਂਦ ਦੂਰ ਕਰਨ ਲਈ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਉਸ ਦੇ ਵਾਸਤੇ) ਮੰਤਰ ਹੈ ਨਾਮ ਹੀ ਜਾਦੂ ਹੈ ਨਾਮ ਹੀ ਦਵਾਈ ਹੈ ਤੇ ਨਾਮ ਹੀ ਪ੍ਰਾਸ਼ਚਿਤ ਕਰਮ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чтобы прогнать сон привязанности, Имя Параматмы для него и мантра, и чудесная сила, и лекарство, и искупительное действие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
