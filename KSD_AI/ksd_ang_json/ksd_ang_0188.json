          }
        },
        {
          "verse_id": 7989,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਧੂਰਿ ਮਿਟੇ ਅਘ ਕੋਟ ॥",
          "roman": "sant kī dhūr miṭe agh koṭ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਸੰਤ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ (ਮੱਥੇ ਤੇ ਲਾਣ) ਨਾਲ (ਮਨੁੱਖ ਦੇ) ਕ੍ਰੋੜਾਂ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Пыль со стоп Гуру-святого удаляет у человека миллионы грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
