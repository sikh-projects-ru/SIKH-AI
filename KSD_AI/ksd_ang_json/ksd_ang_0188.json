{
  "ang": 188,
  "shabads": [
    {
      "shabad_id": 560,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7934,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੁ ਮਹਤੁ ਨਾਨਕ ਪ੍ਰਭੁ ਤੇਰੇ ॥੪॥੪੦॥੧੦੯॥",
          "roman": "mān mahat Nānak prabh tērē ॥4॥40॥109॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਤੇਰਾ ਸੇਵਕ ਬਣਿਆਂ ਹੀ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਆਦਰ ਮਿਲਦਾ ਹੈ ਵਡਿਆਈ ਮਿਲਦੀ ਹੈ ॥੪॥੪੦॥੧੦੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: только став Твоим слугой, обретают почёт и величие в этом и в ином мире ॥4॥40॥109॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 561,
      "rahao_verse_id": 7939,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7935,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7936,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਤੁਮ ਭਏ ਸਮਰਥ ਅੰਗਾ ॥",
          "roman": "jā kau tum bhae samrath aṅgā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤਾਕਤਾਂ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਤੂੰ ਸਹਾਈ ਬਣਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Владыка всех сил! Человеку, помощником которого Ты становишься,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7937,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਕਛੁ ਨਾਹੀ ਕਾਲੰਗਾ ॥੧॥",
          "roman": "tā kau kachh nāhī kālaṅgā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕੋਈ (ਵਿਕਾਰ ਆਦਿਕਾਂ ਦਾ) ਦਾਗ਼ ਨਹੀਂ ਛੁਹ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "к нему не может прикоснуться никакое пятно (пороков и т. п.) ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7938,
          "is_rahao": true,
          "gurmukhi": "ਮਾਧਉ ਜਾ ਕਉ ਹੈ ਆਸ ਤੁਮਾਰੀ ॥",
          "roman": "mādhau jā kau hē ās tumārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਇਆ ਦੇ ਪਤੀ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਸਿਰਫ਼) ਤੇਰੀ (ਸਹਾਇਤਾ ਦੀ) ਆਸ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, супруг майи! У человека, у которого есть надежда (лишь) на Тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7939,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕਉ ਕਛੁ ਨਾਹੀ ਸੰਸਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā kau kachh nāhī saṅsārī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਦੁਨੀਆ (ਦੇ ਲੋਕਾਂ ਦੀ ਸਹਾਇਤਾ) ਦੀ ਆਸ (ਬਣਾਣ ਦੀ ਲੋੜ) ਨਹੀਂ (ਰਹਿੰਦੀ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "у того не остаётся нужды возлагать надежду на мир (на помощь людей мира) ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7940,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹਿਰਦੈ ਠਾਕੁਰੁ ਹੋਇ ॥",
          "roman": "jā kē hirdē ṭhākur hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਮਾਲਕ-ਪ੍ਰਭੂ ਚੇਤੇ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) В сердце того человека, у которого помнится Владыка-Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7941,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਸਹਸਾ ਨਾਹੀ ਕੋਇ ॥੨॥",
          "roman": "tā kau sahsā nāhī koi ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ (ਦੁਨੀਆ ਦਾ) ਕੋਈ ਸਹਮ-ਫ਼ਿਕਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "того не может коснуться никакой страх и тревога мира ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7942,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਤੁਮ ਦੀਨੀ ਪ੍ਰਭ ਧੀਰ ॥",
          "roman": "jā kau tum dīnī prabh dhīr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਤੂੰ ਧੀਰਜ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Человеку, которому Ты дал стойкость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7943,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਨਿਕਟਿ ਨ ਆਵੈ ਪੀਰ ॥੩॥",
          "roman": "tā kē nikaṭ na āvē pīr ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਦੁੱਖ ਕਲੇਸ਼ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "никакое страдание и мучение не могут приблизиться к нему ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7944,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਮੈ ਸੋ ਗੁਰੁ ਪਾਇਆ ॥",
          "roman": "kaho nānak mē so gur pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਮੈਂ ਉਹ ਗੁਰੂ ਲੱਭ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: я нашёл того Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7945,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਦੇਖਾਇਆ ॥੪॥੪੧॥੧੧੦॥",
          "roman": "pārbrahm pūran dekhāiā ॥4॥41॥110॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਮੈਨੂੰ (ਇਹੋ ਜਿਹੀਆਂ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ) ਸਰਬ-ਵਿਆਪਕ ਬੇਅੰਤ ਪ੍ਰਭੂ ਵਿਖਾ ਦਿੱਤਾ ਹੈ ॥੪॥੪੧॥੧੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "который показал мне всепронизывающего бесконечного Господа ॥4॥੪੧॥੧੧੦॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 562,
      "rahao_verse_id": 7950,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7946,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7947,
          "is_rahao": false,
          "gurmukhi": "ਦੁਲਭ ਦੇਹ ਪਾਈ ਵਡਭਾਗੀ ॥",
          "roman": "dulabh deh pāī vaḍbhāgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਦੁਰਲੱਭ ਮਨੁੱਖਾ ਸਰੀਰ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это редкое человеческое тело обретается по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7948,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਨ ਜਪਹਿ ਤੇ ਆਤਮ ਘਾਤੀ ॥੧॥",
          "roman": "nām na japahi te ātam ghātī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜੇਹੜੇ ਮਨੁੱਖ (ਇਹ ਸਰੀਰ ਪ੍ਰਾਪਤ ਕਰ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਜਪਦੇ, ਉਹ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਲੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(Но) те люди, которые, получив это тело, не повторяют Имя Бога, навлекают на себя духовную смерть ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7949,
          "is_rahao": true,
          "gurmukhi": "ਮਰਿ ਨ ਜਾਹੀ ਜਿਨਾ ਬਿਸਰਤ ਰਾਮ ॥",
          "roman": "mar na jāhī jinā bisrat rām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਭੁੱਲ ਜਾਂਦਾ ਹੈ, ਉਹ ਜ਼ਰੂਰ ਆਤਮਕ ਮੌਤੇ ਮਰ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Те люди, которым забывается Бог (Его Имя), непременно умирают духовной смертью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7950,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਨ ਜੀਵਨ ਕਉਨ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām bihūn jīvan kaun kām ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਵਾਂਜੇ ਰਿਹਾਂ ਮਨੁੱਖਾ ਜੀਵਨ ਕਿਸੇ ਭੀ ਕੰਮ ਨਹੀਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(ибо) человеческая жизнь, лишённая Божьего Имени, ни на что не годна ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7951,
          "is_rahao": false,
          "gurmukhi": "ਖਾਤ ਪੀਤ ਖੇਲਤ ਹਸਤ ਬਿਸਥਾਰ ॥",
          "roman": "khāt pīt khelat hast bisthār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਖੁੰਝੇ ਹੋਏ ਮਨੁੱਖ) ਖਾਣ ਪੀਣ ਖੇਡਣ ਹੱਸਣ ਦੇ ਖਿਲਾਰੇ ਖਿਲਾਰਦੇ ਹਨ (ਪਰ ਇਹ ਇਉਂ ਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(Люди, оторванные от Божьего Имени) предаются еде, питью, играм, смеху и развлечениям (но это всё равно что"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7952,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਅਰਥ ਮਿਰਤਕ ਸੀਗਾਰ ॥੨॥",
          "roman": "kavan arath mirtak sīgār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕਿਸੇ ਮੁਰਦੇ ਨੂੰ ਹਾਰ ਸ਼ਿੰਗਾਰ ਲਾਉਣੇ, ਤੇ) ਮੁਰਦੇ ਨੂੰ ਸ਼ਿੰਗਾਰਨ ਦਾ ਕੋਈ ਭੀ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "украшать мертвеца, а от украшения мертвеца нет никакой пользы ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7953,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਨ ਸੁਨਹਿ ਜਸੁ ਪਰਮਾਨੰਦਾ ॥",
          "roman": "jo na sunah jas parmānandā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਆਨੰਦ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨਹੀਂ ਸੁਣਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые не слушают хвалу Господа — Владыки высшего блаженства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7954,
          "is_rahao": false,
          "gurmukhi": "ਪਸੁ ਪੰਖੀ ਤ੍ਰਿਗਦ ਜੋਨਿ ਤੇ ਮੰਦਾ ॥੩॥",
          "roman": "pas pankhī trigad jon te maṅdā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਸ਼ੂ ਪੰਛੀ ਤੇ ਟੇਢੇ ਹੋ ਕੇ ਤੁਰਨ ਵਾਲੇ ਜੀਵਾਂ ਦੀਆਂ ਜੂਨਾਂ ਨਾਲੋਂ ਭੀ ਭੈੜੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "хуже даже животных, птиц и существ, ходящих согнувшись ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7955,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰਿ ਮੰਤ੍ਰੁ ਦ੍ਰਿੜਾਇਆ ॥",
          "roman": "kaho nānak gur mantar driṛāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਗੁਰੂ ਨੇ ਆਪਣਾ ਉਪਦੇਸ਼ ਪੱਕਾ ਕਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: в сердце того человека, кому Гуру утвердил своё наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7956,
          "is_rahao": false,
          "gurmukhi": "ਕੇਵਲ ਨਾਮੁ ਰਿਦ ਮਾਹਿ ਸਮਾਇਆ ॥੪॥੪੨॥੧੧੧॥",
          "roman": "kēval nām rid māhi samāiā ॥4॥42॥111॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਦਾ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੪੨॥੧੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "в сердце всегда пребывает только Божье Имя ॥4॥੪੨॥੧੧੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 563,
      "rahao_verse_id": 7961,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7957,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7958,
          "is_rahao": false,
          "gurmukhi": "ਕਾ ਕੀ ਮਾਈ ਕਾ ਕੋ ਬਾਪ ॥",
          "roman": "kā kī māī kā ko bāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ ਵਿਚ ਸਦਾ ਲਈ) ਨਾਹ ਕੋਈ ਕਿਸੇ ਦੀ ਮਾਂ ਹੈ, ਨਾਹ ਕੋਈ ਕਿਸੇ ਦਾ ਪਿਉ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(В действительности навсегда) никто никому не мать и никто никому не отец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7959,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਧਾਰੀਕ ਝੂਠੇ ਸਭਿ ਸਾਕ ॥੧॥",
          "roman": "nām dhārīk jhūṭhe sabh sāk ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਂ, ਪਿਉ, ਪੁਤ੍ਰ, ਇਸਤ੍ਰੀ ਆਦਿਕ ਇਹ) ਸਾਰੇ ਸਾਕ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਨਹੀਂ ਹਨ, ਕਹਿਣ-ਮਾਤ੍ਰ ਹੀ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(Мать, отец, сын, жена и т. п.) — все эти связи не вечны, они лишь по имени таковы ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7960,
          "is_rahao": true,
          "gurmukhi": "ਕਾਹੇ ਕਉ ਮੂਰਖ ਭਖਲਾਇਆ ॥",
          "roman": "kāhe kau mūrakh bhakhlāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ! ਤੂੰ ਕਿਉਂ (ਵਿਲਕ ਰਿਹਾ ਹੈਂ, ਜਿਵੇਂ) ਸੁਪਨੇ ਦੇ ਅਸਰ ਹੇਠ ਬੋਲ ਰਿਹਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О глупец! Почему ты, словно находясь под воздействием сна, говоришь так жалобно?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7961,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲਿ ਸੰਜੋਗਿ ਹੁਕਮਿ ਤੂੰ ਆਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mil sanjog hukam tūṅ āiā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੈਨੂੰ ਇਹ ਸੂਝ ਨਹੀਂ ਕਿ) ਤੂੰ ਪਰਮਾਤਮਾ ਦੇ ਹੁਕਮ ਵਿਚ (ਪਿਛਲੇ) ਸੰਜੋਗ ਅਨੁਸਾਰ (ਇਹਨਾਂ ਮਾਂ ਪਿਉ ਆਦਿਕ ਸੰਬੰਧੀਆਂ ਨਾਲ) ਮਿਲ ਕੇ (ਜਗਤ ਵਿਚ) ਆਇਆ ਹੈਂ (ਜਿਤਨਾ ਚਿਰ ਇਹ ਸੰਜੋਗ ਕਾਇਮ ਹੈ ਉਤਨਾ ਚਿਰ ਹੀ ਇਹਨਾਂ ਸੰਬੰਧੀਆਂ ਨਾਲ ਮੇਲ ਰਹਿ ਸਕਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(Ты не понимаешь, что) по Божьему повелению, в соответствии с прежним соединением, ты пришёл в мир, встретившись с этими родственниками (матерью, отцом и т. д.); пока сохраняется это соединение, только до тех пор и может длиться встреча с ними) ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7962,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਮਾਟੀ ਏਕਾ ਜੋਤਿ ॥",
          "roman": "ekā māṭī ekā jot ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੀ ਇਕੋ ਹੀ ਮਿੱਟੀ ਹੈ, ਸਭ ਵਿਚ (ਕਰਤਾਰ ਦੀ) ਇਕੋ ਹੀ ਜੋਤਿ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У всех существ одна и та же глина, во всех присутствует один и тот же свет Творца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7963,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਪਵਨੁ ਕਹਾ ਕਉਨੁ ਰੋਤਿ ॥੨॥",
          "roman": "eko pavan kahā kaun rot ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਵਿਚ ਇਕੋ ਹੀ ਪ੍ਰਾਣ ਹਨ (ਜਿਤਨਾ ਚਿਰ ਸੰਜੋਗ ਕਾਇਮ ਹੈ ਉਤਨਾ ਚਿਰ ਇਹ ਤੱਤ ਇਕੱਠੇ ਹਨ। ਸੰਜੋਗ ਮੁੱਕ ਜਾਣ ਤੇ ਤੱਤ ਵੱਖ ਵੱਖ ਹੋ ਜਾਂਦੇ ਹਨ। ਕਿਸੇ ਨੂੰ ਕਿਸੇ ਵਾਸਤੇ) ਰੋਣ ਦੀ ਲੋੜ ਨਹੀਂ ਪੈਂਦੀ (ਰੋਣ ਦਾ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "во всех одно и то же дыхание. Кому и о ком плакать? Пока соединение держится, эти элементы вместе; когда оно кончается, элементы расходятся. Плакать о ком-то нет нужды, от плача нет пользы ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7964,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਮੇਰਾ ਕਰਿ ਬਿਲਲਾਹੀ ॥",
          "roman": "merā merā kar billāhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਸੇ ਸੰਬੰਧੀ ਦੇ ਵਿਛੋੜੇ ਤੇ ਲੋਕ) 'ਮੇਰਾ, ਮੇਰਾ' ਆਖ ਕੇ ਵਿਲਕਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(При разлуке с родственником люди) рыдают, повторяя: «моё, моё»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7965,
          "is_rahao": false,
          "gurmukhi": "ਮਰਣਹਾਰੁ ਇਹੁ ਜੀਅਰਾ ਨਾਹੀ ॥੩॥",
          "roman": "marṇhār ihu jīarā nāhī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਨਹੀਂ ਸਮਝਦੇ ਕਿ ਸਦਾ ਲਈ ਕੋਈ ਕਿਸੇ ਦਾ 'ਮੇਰਾ' ਨਹੀਂ ਤੇ) ਇਹ ਜੀਵਾਤਮਾ ਮਰਨ ਵਾਲਾ ਨਹੀਂ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "(но не понимают, что навсегда никто никому не «мой», и) эта душа не умирает ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7966,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰਿ ਖੋਲੇ ਕਪਾਟ ॥",
          "roman": "kaho nānak gur khole kapāṭ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਨਾਲ ਜਕੜੇ ਹੋਏ) ਕਵਾੜ ਗੁਰੂ ਨੇ ਖੋਲ੍ਹ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тем людям, у которых Гуру открыл затворы, запертые привязанностью к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7967,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤੁ ਭਏ ਬਿਨਸੇ ਭ੍ਰਮ ਥਾਟ ॥੪॥੪੩॥੧੧੨॥",
          "roman": "mukat bhae binse bhram thāṭ ॥4॥43॥112॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮੋਹ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਸੁਤੰਤਰ ਹੋ ਗਏ, ਉਹਨਾਂ ਦੇ ਮੋਹ ਦੀ ਭਟਕਣਾ ਵਾਲੇ ਸਾਰੇ ਪਸਾਰੇ ਮੁੱਕ ਗਏ ॥੪॥੪੩॥੧੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "дарована свобода от уз привязанности; все их разросшиеся заблуждения исчезли ॥4॥੪੩॥੧੧੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 564,
      "rahao_verse_id": 7972,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7968,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7969,
          "is_rahao": false,
          "gurmukhi": "ਵਡੇ ਵਡੇ ਜੋ ਦੀਸਹਿ ਲੋਗ ॥",
          "roman": "vaḍe vaḍe jo dīsah log ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਦੁਨੀਆ ਵਿਚ ਧਨ ਪ੍ਰਭੁਤਾ ਆਦਿਕ ਨਾਲ) ਜੇਹੜੇ ਬੰਦੇ ਵੱਡੇ ਵੱਡੇ ਦਿੱਸਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! В мире) те люди, которые кажутся очень великими из-за богатства, власти и прочего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7970,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕਉ ਬਿਆਪੈ ਚਿੰਤਾ ਰੋਗ ॥੧॥",
          "roman": "tin kau biāpē chintā rog ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਚਿੰਤਾ ਦਾ ਰੋਗ (ਸਦਾ) ਦਬਾਈ ਰੱਖਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "всегда подавлены болезнью заботы ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7971,
          "is_rahao": true,
          "gurmukhi": "ਕਉਨ ਵਡਾ ਮਾਇਆ ਵਡਿਆਈ ॥",
          "roman": "kaun vaḍā māiā vaḍiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮਾਇਆ ਦੇ ਕਾਰਨ (ਜਗਤ ਵਿਚ) ਮਿਲੀ ਵਡਿਆਈ ਨਾਲ ਕੋਈ ਭੀ ਮਨੁੱਖ (ਅਸਲ ਵਿਚ) ਵੱਡਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Никто на самом деле не велик из-за величия, полученного от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7972,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਵਡਾ ਜਿਨਿ ਰਾਮ ਲਿਵ ਲਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "so vaḍā jin rām liv lāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਹੀ ਵੱਡਾ ਹੈ, ਜਿਸ ਨੇ ਪਰਮਾਤਮਾ ਨਾਲ ਲਗਨ ਲਾਈ ਹੋਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Велик только тот человек, кто устремил любовь к Богу ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7973,
          "is_rahao": false,
          "gurmukhi": "ਭੂਮੀਆ ਭੂਮਿ ਊਪਰਿ ਨਿਤ ਲੁਝੈ ॥",
          "roman": "bhūmīā bhūm ūpar nit lujhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜ਼ਮੀਨ ਦਾ ਮਾਲਕ ਮਨੁੱਖ ਜ਼ਮੀਨ ਦੀ (ਮਾਲਕੀ ਦੀ) ਖ਼ਾਤਰ (ਹੋਰਨਾਂ ਨਾਲ) ਸਦਾ ਲੜਦਾ-ਝਗੜਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Владелец земли постоянно ссорится и борется с другими из-за земли (из-за права владения ею)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7974,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਚਲੈ ਤ੍ਰਿਸਨਾ ਨਹੀ ਬੁਝੈ ॥੨॥",
          "roman": "chhoḍ chalē trisnā nahī bujhē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਜ਼ਮੀਨ ਇਥੇ ਹੀ) ਛੱਡ ਕੇ (ਆਖ਼ਰ ਇਥੋਂ) ਤੁਰ ਪੈਂਦਾ ਹੈ, (ਪਰ ਸਾਰੀ ਉਮਰ ਉਸ ਦੀ ਮਾਲਕੀ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਨਹੀਂ ਮਿਟਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "В конце он уходит, оставив эту землю здесь, но жажда владения ею не угасает всю жизнь ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7975,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਇਹੁ ਤਤੁ ਬੀਚਾਰਾ ॥",
          "roman": "kaho nānak ihu tat bīchārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਅਸਾਂ ਵਿਚਾਰ ਕੇ ਕੰਮ ਦੀ ਇਹ ਗੱਲ ਲੱਭੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: обдумав, мы нашли эту сущностную истину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7976,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਭਜਨ ਨਾਹੀ ਛੁਟਕਾਰਾ ॥੩॥੪੪॥੧੧੩॥",
          "roman": "bin har bhajan nāhī chhuṭkārā ॥3॥44॥113॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪਰਮਾਤਮਾ ਦੇ ਭਜਨ ਤੋਂ ਬਿਨਾ ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਖ਼ਲਾਸੀ ਨਹੀ ਹੁੰਦੀ (ਤੇ ਜਦ ਤਕ ਮਾਇਆ ਦਾ ਮੋਹ ਕਾਇਮ ਹੈ ਤਦ ਤਕ ਮਨੁੱਖ ਦਾ ਵਿੱਤ ਨਿੱਕਾ ਜਿਹਾ ਹੀ ਰਹਿੰਦਾ ਹੈ ॥੩॥੪੪॥੧੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "что без преданности Богу нет освобождения от привязанности к майе (а пока привязанность к майе сохраняется, до тех пор человеческое достоинство остаётся совсем ничтожным) ॥3॥੪੪॥੧੧੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 565,
      "rahao_verse_id": 7981,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7977,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7978,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਮਾਰਗੁ ਪੂਰਾ ਇਸਨਾਨੁ ॥",
          "roman": "pūrā mārag pūrā isnān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ (ਜੀਵਨ ਦਾ) ਸਹੀ ਰਸਤਾ ਹੈ, ਨਾਮ ਹੀ ਅਸਲ (ਤੀਰਥ-) ਇਸ਼ਨਾਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Божье Имя и есть верный путь жизни, Имя и есть истинное омовение в тиртхах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7979,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਪੂਰਾ ਹਿਰਦੈ ਨਾਮੁ ॥੧॥",
          "roman": "sabh kichh pūrā hirdē nām ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ, ਉਸ ਦਾ ਹਰੇਕ ਉੱਦਮ ਉਕਾਈ-ਹੀਣ ਹੁੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(По милости Гуру) у того человека, в чьём сердце пребывает Божье Имя, всякое начинание бывает безупречным ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7980,
          "is_rahao": true,
          "gurmukhi": "ਪੂਰੀ ਰਹੀ ਜਾ ਪੂਰੈ ਰਾਖੀ ॥",
          "roman": "pūrī rahī jā pūrē rākhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪੂਰੇ ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ) ਉਹਨਾਂ ਦੀ ਇੱਜ਼ਤ ਸਦਾ ਬਣੀ ਰਹੀ ਕਿਉਂਕਿ ਅਭੁੱਲ ਗੁਰੂ ਨੇ ਉਹਨਾਂ ਦੀ ਇੱਜ਼ਤ ਰੱਖੀ,"
            },
            "sahib_singh_ru": {
              "main": "(По милости совершенного Гуру) их честь всегда сохранялась, потому что безошибочный Гуру сберёг их честь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7981,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਸਰਣਿ ਜਨ ਤਾਕੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pārbrahm kī saraṇ jan tākī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ (ਆਪਣੇ ਸਭ ਕਾਰ-ਵਿਹਾਰਾਂ ਵਿਚ) ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲਈ ਰੱਖਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тех людей, которые во всех своих делах держались опоры на Бога ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7982,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਸੁਖੁ ਪੂਰਾ ਸੰਤੋਖੁ ॥",
          "roman": "pūrā sukh pūrā santokh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਵਿਚ ਰਹਿੰਦਾ ਹੈ ਉਹ) ਸਦਾ ਲਈ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ ਤੇ ਸੰਤੋਖ ਵਾਲਾ ਜੀਵਨ ਬਿਤਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(По милости Гуру тот человек, который пребывает в Божьем прибежище,) всегда вкушает духовное блаженство и проводит жизнь в довольстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7983,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਤਪੁ ਪੂਰਨ ਰਾਜੁ ਜੋਗੁ ॥੨॥",
          "roman": "pūrā tap pūran rāj jog ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਹੀ ਉਸ ਦੇ ਵਾਸਤੇ) ਅਭੁੱਲ ਤਪ ਹੈ, ਉਹ ਪੂਰਨ ਰਾਜ ਭੀ ਮਾਣਦਾ ਹੈ ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਨਾਲ ਜੁੜਿਆ ਭੀ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "(Божье прибежище для него) — совершенная аскеза; он обретает полное царское достоинство и остаётся соединённым со стопами Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7984,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੈ ਮਾਰਗਿ ਪਤਿਤ ਪੁਨੀਤ ॥",
          "roman": "har kē mārag patit punīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਜਿਹੜੇ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੇ ਰਾਹ ਉਤੇ ਤੁਰਦੇ ਹਨ ਉਹ (ਪਹਿਲਾਂ) ਵਿਕਾਰਾਂ ਵਿਚ ਡਿੱਗੇ ਹੋਏ ਭੀ (ਹੁਣ) ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "(По милости Гуру те люди, что идут путём Бога,) даже если прежде были павшими в пороках, теперь становятся чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7985,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੀ ਸੋਭਾ ਪੂਰਾ ਲੋਕੀਕ ॥੩॥",
          "roman": "pūrī sobhā pūrā lokīk ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਨੂੰ ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਸਦਾ ਲਈ ਸੋਭਾ ਮਿਲਦੀ ਹੈ, ਲੋਕਾਂ ਨਾਲ ਉਹਨਾਂ ਦਾ ਵਰਤਣ-ਵਿਹਾਰ ਭੀ ਸੁਚੱਜਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "(Им) навсегда достаётся слава в этом и ином мире, и их обращение с людьми тоже остаётся благородным ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7986,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰੁ ਸਦ ਵਸੈ ਹਦੂਰਾ ॥",
          "roman": "karaṇhār sad vasē hadūrā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਸਿਰਜਣਹਾਰ ਸਦਾ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Творец-Создатель всегда пребывает рядом с тем человеком,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7987,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਮੇਰਾ ਸਤਿਗੁਰੁ ਪੂਰਾ ॥੪॥੪੫॥੧੧੪॥",
          "roman": "kaho nānak merā satgur pūrā ॥4॥45॥114॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਮੇਰਾ ਅਭੁੱਲ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੪॥੪੫॥੧੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: которому встречается мой совершенный Гуру ॥4॥੪੫॥੧੧੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
