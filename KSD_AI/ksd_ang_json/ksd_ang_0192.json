{
  "ang": 192,
  "shabads": [
    {
      "shabad_id": 581,
      "rahao_verse_id": 8157,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8153,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8154,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਾਖੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "gur kā sabad rākh man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇ ਉਸ ਭਗਵਾਨ ਦਾ ਆਸਰਾ ਮਨ ਵਿਚ ਪੱਕਾ ਕਰਨਾ ਹੈ, ਤਾਂ) ਗੁਰੂ ਦਾ ਸ਼ਬਦ (ਆਪਣੇ) ਮਨ ਵਿਚ ਟਿਕਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Если хочешь прочно утвердить в уме опору на того Бога,) удерживай в своём уме Слово Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8155,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਸਿਮਰਿ ਚਿੰਤਾ ਸਭ ਜਾਹਿ ॥੧॥",
          "roman": "nām simar chintā sabh jāhi ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰ-ਸ਼ਬਦ ਦੀ ਸਹਾਇਤਾ ਨਾਲ ਭਗਵਾਨ ਦਾ) ਨਾਮ ਸਿਮਰ, ਤੇਰੇ ਸਾਰੇ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਦੂਰ ਹੋ ਜਾਣਗੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(С помощью Гур-Шабада) помни Имя Бога, и все твои тревоги и заботы уйдут. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8156,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਭਗਵੰਤ ਨਾਹੀ ਅਨ ਕੋਇ ॥",
          "roman": "bin bhagvant nāhī an koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਭਗਵਾਨ ਤੋਂ ਬਿਨਾ (ਜੀਵਾਂ ਦਾ) ਹੋਰ ਕੋਈ ਆਸਰਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) кроме Бога нет никакой иной опоры для живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8157,
          "is_rahao": true,
          "gurmukhi": "ਮਾਰੈ ਰਾਖੈ ਏਕੋ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mārē rākhē eko soi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਭਗਵਾਨ ਹੀ (ਜੀਵਾਂ ਨੂੰ) ਮਾਰਦਾ ਹੈ, ਉਹ ਭਗਵਾਨ ਹੀ (ਜੀਵਾਂ ਨੂੰ) ਪਾਲਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только этот Бог убивает живых существ, только этот Бог их и взращивает. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8158,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਣ ਰਿਦੈ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "gur ke charan ridē ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇ ਭਗਵਾਨ ਦਾ ਆਸਰਾ ਲੈਣਾ ਹੈ, ਤਾਂ) ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਦਿਲ ਵਿਚ ਗੁਰੂ ਦੇ ਚਰਨ ਵਸਾ (ਭਾਵ, ਨਿਮਤ੍ਰਾ ਨਾਲ ਗੁਰੂ ਦੀ ਸਰਨ ਪਉ)।"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Если хочешь принять опору Бога,) посели в своём сердце, в своей душе стопы Гуру (то есть смиренно приди в прибежище Гуру)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8159,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਸਾਗਰੁ ਜਪਿ ਉਤਰਹਿ ਪਾਰਿ ॥੨॥",
          "roman": "agan sāgar jap utarahi pār ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੇ ਦੱਸੇ ਰਾਹ ਉਤੇ ਤੁਰ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਜਪ ਕੇ ਤੂੰ (ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਦੇ ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਏਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "(Идя путём, который показал Гуру, и повторяя Имя Бога,) ты переправишься через океан огня жажды. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8160,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮੂਰਤਿ ਸਿਉ ਲਾਇ ਧਿਆਨੁ ॥",
          "roman": "gur mūrat siu lāe dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਹੀ ਗੁਰੂ ਦੀ ਮੂਰਤਿ ਹੈ, ਗੁਰੂ ਦਾ ਸਰੂਪ ਹੈ) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨਾਲ ਆਪਣੀ ਸੁਰਤ ਜੋੜ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Шабад Гуру и есть образ Гуру, сущность Гуру.) Соедини своё внимание с Шабадом Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8161,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਪਾਵਹਿ ਮਾਨੁ ॥੩॥",
          "roman": "īhā ūhā pāvahi mān ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਇਸ ਲੋਕ ਵਿਚ ਤੇ ਪਰਲੋਕ ਵਿਚ ਆਦਰ ਹਾਸਲ ਕਰੇਂਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и ты обретёшь почёт в этом мире и в мире ином. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8162,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਿਆਗਿ ਗੁਰ ਸਰਣੀ ਆਇਆ ॥",
          "roman": "sagal tiāg gur saraṇī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੇਹੜਾ ਮਨੁੱਖ ਹੋਰ ਸਾਰੇ ਆਸਰੇ ਛੱਡ ਕੇ ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Человек, который, оставив все прочие опоры, приходит в прибежище Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8163,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਅੰਦੇਸੇ ਨਾਨਕ ਸੁਖੁ ਪਾਇਆ ॥੪॥੬੧॥੧੩੦॥",
          "roman": "miṭe andese nānak sukh pāiā ||4||61||130||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਮੁੱਕ ਜਾਂਦੇ ਹਨ, ਉਹ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ ॥੪॥੬੧॥੧੩੦॥"
            },
            "sahib_singh_ru": {
              "main": "у него исчезают все тревоги и заботы, и он обретает духовную радость. ॥4॥੬੧॥੧੩੦॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 582,
      "rahao_verse_id": 8168,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8164,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8165,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਦੂਖੁ ਸਭੁ ਜਾਇ ॥",
          "roman": "jis simrat dūkh sabh jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਸ ਗੋਬਿੰਦ ਦੀ ਬਾਣੀ ਜਪ) ਜਿਸ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Повторяй Бани того Гобинда,) памятование о Котором устраняет всякий вид страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8166,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਰਤਨੁ ਵਸੈ ਮਨਿ ਆਇ ॥੧॥",
          "roman": "nām ratan vasē man āe ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਪਰਮਾਤਮਾ ਦਾ ਅਮੋਲਕ ਨਾਮ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(и по милости Бани) в уме поселяется драгоценное Имя Бога. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8167,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਮਨ ਮੇਰੇ ਗੋਵਿੰਦ ਕੀ ਬਾਣੀ ॥",
          "roman": "jap man mere govind kī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਦਾ ਉੱਚਾਰਨ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Произноси Бани хвалы Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8168,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧੂ ਜਨ ਰਾਮੁ ਰਸਨ ਵਖਾਣੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhū jan rām rasan vakhāṇī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਬਾਣੀ ਦੀ ਰਾਹੀਂ ਹੀ) ਸੰਤ ਜਨ ਆਪਣੀ ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(Именно через эту Бани) святые люди своим языком поют качества Бога. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8169,
          "is_rahao": false,
          "gurmukhi": "ਇਕਸੁ ਬਿਨੁ ਨਾਹੀ ਦੂਜਾ ਕੋਇ ॥",
          "roman": "ikas bin nāhī dūjā koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਦੇ ਬਰਾਬਰ ਦਾ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ, (ਉਸ ਗੋਬਿੰਦ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ),"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) нет никого другого, равного Ему; продолжай восхвалять того Гобинда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8170,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਦ੍ਰਿਸਟਿ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੨॥",
          "roman": "jā kī dṛiṣṭ sadā sukh hoi ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਿਲਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "чьим милостивым взором всегда обретается духовная радость. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8171,
          "is_rahao": false,
          "gurmukhi": "ਸਾਜਨੁ ਮੀਤੁ ਸਖਾ ਕਰਿ ਏਕੁ ॥",
          "roman": "sājan mīt sakhā kar ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਸ) ਇੱਕ ਗੋਬਿੰਦ ਨੂੰ ਆਪਣਾ ਸੱਜਣ ਮਿੱਤਰ ਸਾਥੀ ਬਣਾ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) сделай того единого Гобинда своим близким, другом и спутником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8172,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਅਖਰ ਮਨ ਮਹਿ ਲੇਖੁ ॥੩॥",
          "roman": "har har akhar man mahi lekh ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਹਰੀ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਅੱਖਰ (ਸੰਸਕਾਰ) ਆਪਣੇ ਮਨ ਵਿਚ ਉੱਕਰ ਲੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и запечатлей в своём уме буквы, то есть впечатления, хвалы Хари. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8173,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿ ਰਹਿਆ ਸਰਬਤ ਸੁਆਮੀ ॥",
          "roman": "rav rahiā sarbat suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਾਰੇ ਜਗਤ ਦਾ ਉਹ) ਮਾਲਕ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Тот Владыка всего мира) повсюду пронизывает всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8174,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵੈ ਨਾਨਕੁ ਅੰਤਰਜਾਮੀ ॥੪॥੬੨॥੧੩੧॥",
          "roman": "guṇ gāvē nānak antarjāmī ||4||62||131||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਹਰੇਕ ਦੇ ਦਿਲ ਦੀ ਜਾਣਦਾ ਹੈ, ਨਾਨਕ (ਭੀ) ਉਸ ਅੰਤਰਜਾਮੀ ਸੁਆਮੀ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੪॥੬੨॥੧੩੧॥"
            },
            "sahib_singh_ru": {
              "main": "и знает сердце каждого; Нанак тоже поёт качества того Владыки, Знающего всё внутри. ॥4॥੬੨॥੧੩੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 583,
      "rahao_verse_id": 8179,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8175,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8176,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਮਹਿ ਰਚਿਓ ਸਭੁ ਸੰਸਾਰਾ ॥",
          "roman": "bhē mah rachiō sabh sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਾਰਾ ਸੰਸਾਰ (ਕਿਸੇ ਨ ਕਿਸੇ) ਡਰ-ਸਹਮ ਦੇ ਹੇਠ ਦਬਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) весь мир остаётся придавленным тем или иным страхом и тревогой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8177,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਭਉ ਨਾਹੀ ਜਿਸੁ ਨਾਮੁ ਅਧਾਰਾ ॥੧॥",
          "roman": "tis bhao nāhī jis nām adhārā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਉਸ ਮਨੁੱਖ ਉਤੇ (ਕੋਈ) ਡਰ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ ਜਿਸ ਨੂੰ (ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ (ਜੀਵਨ ਵਾਸਤੇ) ਸਹਾਰਾ ਮਿਲਿਆ ਹੋਇਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Только на того человека не может подействовать никакой страх, у которого Имя Бога стало опорой жизни. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8178,
          "is_rahao": true,
          "gurmukhi": "ਭਉ ਨ ਵਿਆਪੈ ਤੇਰੀ ਸਰਣਾ ॥",
          "roman": "bhao na viāpē terī saraṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਸਰਣ ਪਿਆਂ (ਤੇਰਾ ਪੱਲਾ ਫੜਿਆਂ) ਕੋਈ ਡਰ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Если прийти в Твоё прибежище, ухватиться за Твой край, никакой страх не может подействовать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8179,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਵੈ ਸੋਈ ਕਰਣਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo tudh bhāvē soī karṇā ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਫਿਰ ਇਹ ਨਿਸ਼ਚਾ ਬਣ ਜਾਂਦਾ ਹੈ ਕਿ) ਉਹੀ ਕੰਮ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ ਜੋ (ਹੇ ਪ੍ਰਭੂ!) ਤੈਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(Потому что тогда устанавливается такая уверенность:) можно сделать только то, что угодно Тебе, о Господь. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8180,
          "is_rahao": false,
          "gurmukhi": "ਸੋਗ ਹਰਖ ਮਹਿ ਆਵਣ ਜਾਣਾ ॥",
          "roman": "sog harakh mah āvaṇ jāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਖ ਮੰਨਣ ਵਿਚ ਜਾਂ ਖ਼ੁਸ਼ੀ ਮਨਾਣ ਵਿਚ (ਸੰਸਾਰੀ ਜੀਵ ਵਾਸਤੇ ਡਰ-ਸਹਮ ਦਾ) ਆਉਣਾ ਜਾਣਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В печали или в радости для мирского существа постоянно продолжается приход и уход страха и тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8181,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸੁਖੁ ਪਾਇਆ ਜੋ ਪ੍ਰਭ ਭਾਣਾ ॥੨॥",
          "roman": "tin sukh pāiā jo prabh bhāṇā ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਉਸ ਮਨੁੱਖ ਨੇ (ਟਿਕਵਾਂ) ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਕੀਤਾ ਹੈ ਜੇਹੜਾ ਪ੍ਰਭੂ ਨੂੰ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ (ਜੋ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек обрёл устойчивую духовную радость, кто дорог Богу, кто идёт в Божьей воле. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8182,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਸਾਗਰੁ ਮਹਾ ਵਿਆਪੈ ਮਾਇਆ ॥",
          "roman": "agan sāgar mahā viāpē māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹ ਸੰਸਾਰ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਦਾ ਸਮੁੰਦਰ ਹੈ (ਇਸ ਵਿਚ ਜੀਵਾਂ ਉਤੇ) ਮਾਇਆ ਆਪਣਾ ਬਹੁਤ ਜ਼ੋਰ ਪਾਈ ਰੱਖਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Этот мир — океан огня жажды; в нём майя) очень сильно властвует над существами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8183,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਸੀਤਲ ਜਿਨ ਸਤਿਗੁਰੁ ਪਾਇਆ ॥੩॥",
          "roman": "se sītal jin satigur pāiā ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ (ਵਡ-ਭਾਗੀਆਂ) ਨੂੰ ਸਤਿਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਹ (ਇਸ ਅਗਨਿ-ਸਾਗਰ ਵਿਚ ਵਿਚਰਦੇ ਹੋਏ ਭੀ ਅੰਤਰ-ਆਤਮੇ) ਠੰਡੇ-ਠਾਰ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Те, кому встречается Сатгуру, даже среди этого океана огня остаются внутренне прохладными и умиротворёнными. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8184,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੇਇ ਪ੍ਰਭੁ ਰਾਖਨਹਾਰਾ ॥",
          "roman": "rākh lei prabh rākhanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਚਾਣ ਦੀ ਤਾਕਤ ਰੱਖਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਬਚਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог, обладающий силой спасать, и спасает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8185,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਕਿਆ ਜੰਤ ਵਿਚਾਰਾ ॥੪॥੬੩॥੧੩੨॥",
          "roman": "kaho nānak kiā jant vichārā ||4||63||132||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਹੇ ਨਾਨਕ! (ਡਰ-ਸਹਮ ਤੋਂ ਬਚਣ ਲਈ, ਅਗਨਿ-ਸਾਗਰ ਦੇ ਵਿਕਾਰਾਂ ਦੇ ਸੇਕ ਤੋਂ ਬਚਣ ਲਈ) ਜੀਵਾਂ ਵਿਚਾਰਿਆਂ ਦੀ ਕੀਹ ਪਾਂਇਆਂ ਹੈ? (ਇਸ ਵਾਸਤੇ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਪੱਲਾ ਫੜੀ ਰੱਖ) ॥੪॥੬੩॥੧੩੨॥"
            },
            "sahib_singh_ru": {
              "main": "(Но,) о Нанак! Что могут бедные существа сделать сами, чтобы спастись от страха и от жара пороков океана огня? Поэтому держись за край того Бога. ॥4॥੬੩॥੧੩੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 584,
      "rahao_verse_id": 8190,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8186,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8187,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਤੇ ਜਪੀਐ ਨਾਉ ॥",
          "roman": "tumrī kirpā te japīai nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ!) ਤੇਰੀ ਮਿਹਰ ਨਾਲ ਹੀ (ਤੇਰਾ) ਨਾਮ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О Парабрахман, Господь!) Только по Твоей милости можно повторять Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8188,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਤੇ ਦਰਗਹ ਥਾਉ ॥੧॥",
          "roman": "tumrī kirpā te dargah thāu ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਕਿਰਪਾ ਨਾਲ ਹੀ ਤੇਰੀ ਦਰਗਾਹ ਵਿਚ (ਜੀਵ ਨੂੰ) ਇੱਜ਼ਤ ਮਿਲ ਸਕਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Только по Твоей милости живое существо может обрести честь в Твоём дворе. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8189,
          "is_rahao": true,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਪਾਰਬ੍ਰਹਮ ਨਹੀ ਕੋਇ ॥",
          "roman": "tujh bin pārbrahm nahī koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਬਿਨਾ (ਜੀਵਾਂ ਦਾ ਹੋਰ) ਕੋਈ (ਆਸਰਾ) ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман, Господь! Кроме Тебя у живых существ нет никакой иной опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8190,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਤੇ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tumrī kirpā te sadā sukh hoi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਕਿਰਪਾ ਨਾਲ ਹੀ (ਜੀਵ ਨੂੰ) ਸਦਾ ਲਈ ਆਤਮਕ ਆਨੰਦ ਮਿਲ ਸਕਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только по Твоей милости живое существо может обрести вечную духовную радость. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8191,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਮਨਿ ਵਸੇ ਤਉ ਦੂਖੁ ਨ ਲਾਗੈ ॥",
          "roman": "tum man vase tau dūkh na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ!) ਜੇ ਤੂੰ (ਜੀਵ ਦੇ) ਮਨ ਵਿਚ ਆ ਵੱਸੇਂ ਤਾਂ (ਜੀਵ ਨੂੰ ਕੋਈ) ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "(О Парабрахман, Господь!) Если Ты поселишься в уме живого существа, его не сможет коснуться никакое страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8192,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਤੇ ਭ੍ਰਮੁ ਭਉ ਭਾਗੈ ॥੨॥",
          "roman": "tumrī kirpā te bhram bhao bhāgē ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮਿਹਰ ਨਾਲ ਜੀਵ ਦੀ ਭਟਕਣਾ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ, ਜੀਵ ਦਾ ਡਰ-ਸਹਮ ਭੱਜ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По Твоей милости исчезает блуждание существа, и его страх и тревога убегают. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8193,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਅਪਰੰਪਰ ਸੁਆਮੀ ॥",
          "roman": "pārbrahm aparanpar suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਹੇ ਬੇਅੰਤ ਪ੍ਰਭੂ! ਹੇ ਜਗਤ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман, Господь! О Беспредельный Господь! О Владыка мира!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8194,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥੩॥",
          "roman": "sagal ghaṭā ke antarjāmī ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲੇ ਪ੍ਰਭੂ! ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, знающий сердца всех существ! ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8195,
          "is_rahao": false,
          "gurmukhi": "ਕਰਉ ਅਰਦਾਸਿ ਅਪਨੇ ਸਤਿਗੁਰ ਪਾਸਿ ॥",
          "roman": "karaū ardās apne satigur pās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਤੇਰੀ ਮਿਹਰ ਹੋਵੇ ਤਾਂ ਹੀ) ਮੈਂ ਆਪਣੇ ਗੁਰੂ ਅੱਗੇ (ਇਹ) ਅਰਦਾਸ ਕਰ ਸਕਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "(Лишь если будет Твоя милость,) я могу вознести перед своим Гуру такую ардас,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8196,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਮਿਲੈ ਸਚੁ ਰਾਸਿ ॥੪॥੬੪॥੧੩੩॥",
          "roman": "nānak nām milē sach rās ||4||64||133||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਮੈਨੂੰ ਨਾਨਕ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਮਿਲੇ (ਨਾਨਕ ਵਾਸਤੇ ਨਾਮ ਹੀ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਸਰਮਾਇਆ ਹੈ ॥੪॥੬੪॥੧੩੩॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы мне, Нанаку, было даровано Имя Бога; для Нанака Имя и есть вечный капитал. ॥4॥੬੪॥੧੩੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 585,
      "rahao_verse_id": 8201,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8197,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8198,
          "is_rahao": false,
          "gurmukhi": "ਕਣ ਬਿਨਾ ਜੈਸੇ ਥੋਥਰ ਤੁਖਾ ॥",
          "roman": "kaṇ binā jēse thothar tukhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਵੇਂ ਦਾਣਿਆਂ ਤੋਂ ਬਿਨਾ ਖ਼ਾਲੀ ਤੋਹ (ਕਿਸੇ ਕੰਮ ਨਹੀਂ ਆਉਂਦੇ।)"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) подобно тому как пустая шелуха без зёрен ни на что не годится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8199,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਨ ਸੂਨੇ ਸੇ ਮੁਖਾ ॥੧॥",
          "roman": "nām bihūn sūne se mukhā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸੇ ਤਰ੍ਹਾਂ) ਉਹ ਮੂੰਹ ਸੁੰਞੇ ਹਨ ਜੋ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਤੋਂ ਬਿਨਾ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(так и) пусты те уста, в которых нет повторения Имени Бога. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8200,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਹੁ ਨਿਤ ਪ੍ਰਾਣੀ ॥",
          "roman": "har har nām japah nit prāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਰਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "О существо! Постоянно помни Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8201,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਨ ਧ੍ਰਿਗੁ ਦੇਹ ਬਿਗਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām bihūn dhṛig deh bigānī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਇਹ ਸਰੀਰ ਜੋ ਆਖ਼ਿਰ ਪਰਾਇਆ ਹੋ ਜਾਂਦਾ ਹੈ (ਜੋ ਮੌਤ ਆਉਣ ਤੇ ਛੱਡਣਾ ਪੈਂਦਾ ਹੈ) ਫਿਟਕਾਰ-ਜੋਗ (ਕਿਹਾ ਜਾਂਦਾ) ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога это тело, которое в конце концов становится чужим и которое приходится оставить со смертью, достойно лишь порицания. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8202,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਨਾਹੀ ਮੁਖਿ ਭਾਗੁ ॥",
          "roman": "nām binā nāhī mukh bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਮੱਥੇ ਉਤੇ ਭਾਗ ਨਹੀਂ ਖੁਲ੍ਹਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) без повторения Имени Бога ни у кого на челе не раскрывается удача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8203,
          "is_rahao": false,
          "gurmukhi": "ਭਰਤ ਬਿਹੂਨ ਕਹਾ ਸੋਹਾਗੁ ॥੨॥",
          "roman": "bharat bihūn kahā sohāg ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਖਸਮ ਤੋਂ ਬਿਨਾ (ਇਸਤ੍ਰੀ ਦਾ) ਸੁਹਾਗ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Без мужа не может быть супружеского счастья у женщины. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8204,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਬਿਸਾਰਿ ਲਗੈ ਅਨ ਸੁਆਇ ॥",
          "roman": "nām bisār lagē an suāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਭੁਲਾ ਕੇ ਹੋਰ ਹੋਰ ਸੁਆਦ ਵਿਚ ਰੁੱਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) человек, забыв Имя Бога, погружается в другие и другие вкусы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8205,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਆਸ ਨ ਪੂਜੈ ਕਾਇ ॥੩॥",
          "roman": "tā kī ās na pūjē kāi ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਕੋਈ ਆਸ ਸਿਰੇ ਨਹੀਂ ਚੜ੍ਹਦੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ни одна его надежда не исполняется. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8206,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਅਪਨੀ ਦਾਤਿ ॥",
          "roman": "kar kirpā prabh apnī dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮਿਹਰ ਕਰ ਕੇ ਤੂੰ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਬਖ਼ਸ਼ਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Тому человеку, которому по милости Ты даруешь дар Своего Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8207,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਜਪੈ ਦਿਨ ਰਾਤਿ ॥੪॥੬੫॥੧੩੪॥",
          "roman": "nānak nām japē din rāt ||4||65||134||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਹੀ ਦਿਨ ਰਾਤ ਤੇਰਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੪॥੬੫॥੧੩੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только тот и повторяет Твоё Имя день и ночь. ॥4॥੬੫॥੧੩੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
