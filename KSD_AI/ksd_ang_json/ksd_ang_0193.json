{
  "ang": 193,
  "shabads": [
    {
      "shabad_id": 586,
      "rahao_verse_id": 8212,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8208,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8209,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਸਮਰਥੁ ਤੂੰਹੈ ਮੇਰਾ ਸੁਆਮੀ ॥",
          "roman": "tūṃ samarath tūṃhē merā suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪਾਰਬ੍ਰਹਮ!) ਤੂੰ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਹੀ ਮੇਰਾ ਮਾਲਕ ਹੈਂ (ਮੈਨੂੰ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "(О Парбрахм!) Ты владыка всех сил, Ты один мой Владыка, и мне опора только в Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8210,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤੁਮ ਤੇ ਤੂੰ ਅੰਤਰਜਾਮੀ ॥੧॥",
          "roman": "sabh kichh tum te tūṃ antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈਂ। ਜੋ ਕੁਝ ਜਗਤ ਵਿਚ ਹੋ ਰਿਹਾ ਹੈ ਤੇਰੀ ਪ੍ਰੇਰਨਾ ਨਾਲ ਹੀ ਹੋ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты знающий сердца всех. Всё, что происходит в мире, происходит только по Твоему побуждению. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8211,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਜਨ ਓਟ ॥",
          "roman": "pārabraham pūran jan oṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਰਬ-ਵਿਆਪਕ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਤੇਰੇ ਸੇਵਕਾਂ ਨੂੰ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О всепронизывающий Парбрахм! У Твоих слуг опора только на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8212,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੀ ਸਰਣਿ ਉਧਰਹਿ ਜਨ ਕੋਟਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "terī saraṇ udharahi jan koṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਮਨੁੱਖ ਤੇਰੀ ਸਰਨ ਪੈ ਕੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਬਚ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Миллионы людей, придя в Твоё прибежище, спасаются от мирского океана. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8213,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਜੀਅ ਤੇਤੇ ਸਭਿ ਤੇਰੇ ॥",
          "roman": "jete jīa tete sabh tere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪਾਰਬ੍ਰਹਮ! ਜਗਤ ਵਿਚ) ਜਿਤਨੇ ਭੀ ਜੀਵ ਹਨ, ਸਾਰੇ ਤੇਰੇ ਹੀ ਪੈਦਾ ਕੀਤੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "(О Парбрахм!) Сколько ни есть существ в мире, все они созданы Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8214,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਤੇ ਸੂਖ ਘਨੇਰੇ ॥੨॥",
          "roman": "tumrī kirpā te sūkh ghanere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮਿਹਰ ਨਾਲ ਹੀ (ਜੀਵਾਂ ਨੂੰ) ਅਨੇਕਾਂ ਸੁਖ ਮਿਲ ਰਹੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Только по Твоей милости существа получают бесчисленные радости. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8215,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਵਰਤੈ ਸਭ ਤੇਰਾ ਭਾਣਾ ॥",
          "roman": "jo kichh vartē sabh terā bhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪਾਰਬ੍ਰਹਮ! ਸੰਸਾਰ ਵਿਚ) ਜੋ ਕੁਝ ਵਾਪਰ ਰਿਹਾ ਹੈ, ਉਹੀ ਵਾਪਰਦਾ ਹੈ ਜੋ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О Парбрахм!) Всё, что происходит в мире, происходит только так, как угодно Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8216,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਬੂਝੈ ਸੋ ਸਚਿ ਸਮਾਣਾ ॥੩॥",
          "roman": "hukam būjhē so sach samāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਤੇਰੀ ਰਜ਼ਾ ਨੂੰ ਸਮਝ ਲੈਂਦਾ ਹੈ, ਉਹ ਤੇਰੇ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਨਾਮ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который постигает Твою волю, остаётся погружённым в Твоё вечно-пребывающее Имя. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8217,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਦੀਜੈ ਪ੍ਰਭ ਦਾਨੁ ॥",
          "roman": "kar kirpā dījē prabh dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮਿਹਰ ਕਰ ਕੇ ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਬਖ਼ਸ਼,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! По милости даруй дар Своего Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8218,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਿਮਰੈ ਨਾਮੁ ਨਿਧਾਨੁ ॥੪॥੬੬॥੧੩੫॥",
          "roman": "Nānak simrē nām nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾ ਕਿ ਤੇਰਾ ਦਾਸ ਨਾਨਕ ਤੇਰਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹੇ (ਤੇਰਾ ਨਾਮ ਹੀ ਤੇਰੇ ਦਾਸ ਵਾਸਤੇ ਸਭ ਸੁਖਾਂ ਦਾ) ਖ਼ਜ਼ਾਨਾ ਹੈ ॥੪॥੬੬॥੧੩੫॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Твой слуга Нанак продолжал помнить Твоё Имя, ибо Твоё Имя для Твоего слуги — сокровищница всех благ. ॥4॥66॥135॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 587,
      "rahao_verse_id": 8223,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8219,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8220,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਦਰਸੁ ਪਾਈਐ ਵਡਭਾਗੀ ॥",
          "roman": "tā kā daras pāīai vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਨੁੱਖ ਦਾ ਦਰਸਨ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Лишь по великой удаче можно получить даршан такого человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8221,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਰਾਮ ਨਾਮਿ ਲਿਵ ਲਾਗੀ ॥੧॥",
          "roman": "jā kī rām nām liv lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਲਗਨ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чья привязанность постоянно обращена к Имени Бога. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8222,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੈ ਹਰਿ ਵਸਿਆ ਮਨ ਮਾਹੀ ॥",
          "roman": "jā kē har vasiyā man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ (ਸਦਾ) ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਵੱਸਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) В чьём сердце постоянно пребывает Бог и Его Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8223,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕਉ ਦੁਖੁ ਸੁਪਨੈ ਭੀ ਨਾਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā kau dukh supnē bhī nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਕਦੇ ਸੁਪਨੇ ਵਿਚ ਭੀ (ਕੋਈ) ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "того человека даже во сне не может коснуться никакое страдание. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8224,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਰਾਖੇ ਜਨ ਮਾਹਿ ॥",
          "roman": "sarab nidhān rākhe jan māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਨਾਮ ਦੀ ਲਗਨ ਵਾਲੇ) ਸੇਵਕ (ਦੇ ਹਿਰਦੇ) ਵਿਚ (ਪਰਮਾਤਮਾ) ਸਾਰੇ (ਆਤਮਕ ਗੁਣਾਂ ਦੇ) ਖ਼ਜ਼ਾਨੇ ਪਾ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) В сердце такого слуги, привязанного к Имени, Бог поместил все сокровища духовных качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8225,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਸੰਗਿ ਕਿਲਵਿਖ ਦੁਖ ਜਾਹਿ ॥੨॥",
          "roman": "tā kē saṅg kilvikh dukh jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜੇਹੇ ਸੇਵਕ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਪਾਪ ਤੇ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "В общении с таким слугой грехи и страдания уходят прочь. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8226,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੀ ਮਹਿਮਾ ਕਥੀ ਨ ਜਾਇ ॥",
          "roman": "jan kī mahimā kathī na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹੋ ਜਿਹੇ) ਸੇਵਕ ਦੀ ਆਤਮਕ ਉੱਚਤਾ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Духовное величие такого слуги невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8227,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਨੁ ਰਹਿਆ ਸਮਾਇ ॥੩॥",
          "roman": "pārabraham jan rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੇਵਕ ਉਸ ਪਾਰਬ੍ਰਹਮ ਦਾ ਰੂਪ ਬਣ ਜਾਂਦਾ ਹੈ ਜੋ ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Такой слуга становится образом того Парбрахма, Который пронизывает всех существ. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8228,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਬਿਨਉ ਸੁਨੀਜੈ ॥",
          "roman": "kar kirpā prabh binau sunījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੇਰੀ ਬੇਨਤੀ ਸੁਣ, ਮਿਹਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Услышь мою молитву и окажи милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8229,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਕੀ ਧੂਰਿ ਨਾਨਕ ਕਉ ਦੀਜੈ ॥੪॥੬੭॥੧੩੬॥",
          "roman": "dās kī dhūr Nānak kau dījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਨਾਨਕ ਨੂੰ ਆਪਣੇ ਅਜੇਹੇ ਸੇਵਕ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਦੇਹ ॥੪॥੬੭॥੧੩੬॥"
            },
            "sahib_singh_ru": {
              "main": "Дай мне, Нанаку, пыль стоп такого Твоего слуги. ॥4॥67॥136॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 588,
      "rahao_verse_id": 8234,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8230,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8231,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਤੇਰੀ ਜਾਇ ਬਲਾਇ ॥",
          "roman": "har simrat terī jāi balāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਸਿਰਮਨ ਕਰਦਿਆਂ ਤੇਰੀ ਵੈਰਨ (ਮਾਇਆ ਡਾਇਣ) ਤੈਥੋਂ ਪਰੇ ਹਟ ਜਾਏਗੀ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Когда ты помнишь Бога, твоя враждебная ведьма-майя отступает от тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8232,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਵਸੈ ਮਨਿ ਆਇ ॥੧॥",
          "roman": "sarab kalyāṇ vasē man āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਤੇਰੇ) ਮਨ ਵਿਚ ਆ ਵੱਸੇ ਤਾਂ (ਤੇਰੇ ਅੰਦਰ) ਸਾਰੇ ਸੁਖ (ਆ ਵੱਸਣਗੇ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Если Имя Бога войдёт и поселится в твоём уме, тогда в тебе поселятся все блага. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8233,
          "is_rahao": true,
          "gurmukhi": "ਭਜੁ ਮਨ ਮੇਰੇ ਏਕੋ ਨਾਮ ॥",
          "roman": "bhaj man mere eko nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਨਾਮ ਸਿਮਰਦਾ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Помни только Имя Единого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8234,
          "is_rahao": true,
          "gurmukhi": "ਜੀਅ ਤੇਰੇ ਕੈ ਆਵੈ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jīa tere kē āvē kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਾਮ ਹੀ ਤੇਰੀ ਜਿੰਦ ਦੇ ਕੰਮ ਆਵੇਗਾ (ਜਿੰਦ ਦੇ ਨਾਲ ਸਦਾ ਨਿਭੇਗਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только это Имя пригодится твоей душе и всегда будет с нею. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8235,
          "is_rahao": false,
          "gurmukhi": "ਰੈਣਿ ਦਿਨਸੁ ਗੁਣ ਗਾਉ ਅਨੰਤਾ ॥",
          "roman": "rēṇ dinas guṇ gāu anantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਦਿਨ ਰਾਤ ਬੇਅੰਤ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) День и ночь пой качества Бесконечного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8236,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕਾ ਨਿਰਮਲ ਮੰਤਾ ॥੨॥",
          "roman": "gur pūre kā nirmal maṃtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪੂਰੇ ਗੁਰੂ ਦਾ ਪਵਿੱਤਰ ਉਪਦੇਸ਼ ਲੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и прими чистое наставление Совершенного Гуру. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8237,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਉਪਾਵ ਏਕ ਟੇਕ ਰਾਖੁ ॥",
          "roman": "chhoḍ upāv ek ṭek rākh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣ ਲਈ) ਹੋਰ ਸਾਰੇ ਹੀਲੇ ਛੱਡ, ਤੇ ਇਕ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦਾ ਆਸਰਾ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Чтобы переправиться через мирской океан,) оставь все прочие уловки и держись опоры только на Единого Бога и Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8238,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਪਦਾਰਥੁ ਅੰਮ੍ਰਿਤ ਰਸੁ ਚਾਖੁ ॥੩॥",
          "roman": "mahā padārath aṃmrit ras chākhu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਰਸ ਚੱਖ-ਇਹੀ ਹੈ ਸਭ ਪਦਾਰਥਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਪਦਾਰਥ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Вкуси нектар Имени, дающего духовную жизнь: это и есть высшее из всех сокровищ. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8239,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਮ ਸਾਗਰੁ ਤੇਈ ਜਨ ਤਰੇ ॥",
          "roman": "bikham sāgar teī jan tare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹੀ ਮਨੁੱਖ ਔਖੇ (ਸੰਸਾਰ) ਸਮੁੰਦਰ ਤੋਂ (ਆਤਮਕ ਪੂੰਜੀ ਸਮੇਤ) ਪਾਰ ਲੰਘਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Только те люди переправляются через трудный мирской океан, сохранив своё духовное богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8240,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾ ਕਉ ਨਦਰਿ ਕਰੇ ॥੪॥੬੮॥੧੩੭॥",
          "roman": "Nānak jā kau nadar kare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਤੇ (ਪਰਮਾਤਮਾ ਆਪ ਮਿਹਰ ਦੀ) ਨਜ਼ਰ ਕਰਦਾ ਹੈ ॥੪॥੬੮॥੧੩੭॥"
            },
            "sahib_singh_ru": {
              "main": "на кого Сам Бог бросает милостивый взгляд. ॥4॥68॥137॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 589,
      "rahao_verse_id": 8245,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8241,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8242,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਚਰਨ ਕਮਲ ਪ੍ਰਭ ਧਾਰੇ ॥",
          "roman": "hirdē charan kamal prabh dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ!) ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਸੁੰਦਰ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) Те люди, которые помещают в своём сердце прекрасные стопы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8243,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਸਤਿਗੁਰ ਮਿਲਿ ਨਿਸਤਾਰੇ ॥੧॥",
          "roman": "pūre satgur mil nisatāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਸਤਿਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਉਹ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "встретив Совершенного Сатгуру, переправляются через мирской океан. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8244,
          "is_rahao": true,
          "gurmukhi": "ਗੋਵਿੰਦ ਗੁਣ ਗਾਵਹੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "govind guṇ gāvah mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਭਾਈ! ਗੋਬਿੰਦ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦੇ ਰਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Продолжайте петь песни хвалы Говинду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8245,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਹਰਿ ਨਾਮੁ ਧਿਆਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mil sādhū har nām dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, медитируйте на Имя Бога. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8246,
          "is_rahao": false,
          "gurmukhi": "ਦੁਲਭ ਦੇਹ ਹੋਈ ਪਰਵਾਨੁ ॥",
          "roman": "dulabh deh hoī parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ!) ਉਹਨਾਂ ਦਾ ਮਨੁੱਖਾ ਸਰੀਰ-ਬੜੀ ਕਠਨਤਾ ਨਾਲ ਮਿਲਿਆ ਹੋਇਆ ਮਨੁੱਖਾ ਸਰੀਰ-(ਪਰਮਾਤਮਾ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) Их человеческое тело, полученное с великим трудом, становится принятым в очах Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8247,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਤੇ ਪਾਇਆ ਨਾਮ ਨੀਸਾਨੁ ॥੨॥",
          "roman": "satgur te pāiā nām nīsān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਇਸ ਜੀਵਨ-ਸਫ਼ਰ ਵਿਚ) ਸਤਿਗੁਰੂ ਪਾਸੋਂ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਰਾਹਦਾਰੀ ਹਾਸਲ ਕਰ ਲਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "если в этом жизненном пути они получили у Сатгуру пропуск Имени Бога. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8248,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਪੂਰਨ ਪਦੁ ਪਾਇਆ ॥",
          "roman": "har simrat pūran pad pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਮਨੁੱਖ ਉਹ ਆਤਮਕ ਅਵਸਥਾ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ, ਜਿਥੇ ਕਿਸੇ ਉਕਾਈ ਦੀ ਸੰਭਾਵਨਾ ਨਹੀਂ ਰਹਿ ਜਾਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) Помня Имя Бога, человек достигает такого духовного состояния, где уже не остаётся возможности для какого-либо изъяна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8249,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭੈ ਭਰਮ ਮਿਟਾਇਆ ॥੩॥",
          "roman": "sādhasaṅg bhē bharam miṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਮਨੁੱਖ ਸਾਰੇ ਡਰ ਸਾਰੀਆਂ ਭਟਕਣਾ ਮਿਟਾ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в Садхсанге, человек устраняет все страхи и все блуждания. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8250,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਦੇਖਉ ਤਤ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "jat kat dekhau tat rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੈਂ ਜਿਧਰ ਭੀ ਵੇਖਦਾ ਹਾਂ, ਉਧਰ ਹੀ ਪਰਮਾਤਮਾ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат! По милости прибежища Гуру) куда бы я ни посмотрел, всюду вижу пронизывающего всё Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8251,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਹਰਿ ਕੀ ਸਰਣਾਇ ॥੪॥੬੯॥੧੩੮॥",
          "roman": "Nānak dās har kī saraṇāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸੇਵਕ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਵਿਚ ਹੀ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੬੯॥੧੩੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Слуги остаются утверждёнными только в прибежище Бога. ॥4॥69॥138॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 590,
      "rahao_verse_id": 8256,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8252,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8253,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਜੀ ਕੇ ਦਰਸਨ ਕਉ ਬਲਿ ਜਾਉ ॥",
          "roman": "gur jī ke darsan kau bal jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ ਸਤਿਗੁਰੂ ਜੀ ਦੇ ਦਰਸਨ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Я жертвую собой ради даршана Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8254,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਜੀਵਾ ਸਤਿਗੁਰ ਨਾਉ ॥੧॥",
          "roman": "jap jap jīvā satgur nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦਾ ਨਾਮ ਚੇਤੇ ਕਰ ਕੇ ਮੇਰੇ ਅੰਦਰ ਉੱਚਾ ਆਤਮਕ ਜੀਵਨ ਪੈਦਾ ਹੁੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Когда я снова и снова вспоминаю имя Сатгуру, во мне возникает высокая духовная жизнь. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8255,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਗੁਰਦੇਵ ॥",
          "roman": "pārabraham pūran gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੂਰਨ ਪਾਰਬ੍ਰਹਮ! ਹੇ ਗੁਰਦੇਵ!"
            },
            "sahib_singh_ru": {
              "main": "О совершенный Парбрахм! О Гурдев!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8256,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਲਾਗਉ ਤੇਰੀ ਸੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā lāgau terī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਕਰ, ਮੈਂ ਤੇਰੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਲੱਗਾ ਰਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Окажи милость, чтобы я оставался занятым Твоим служением и преданностью. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8257,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਉਰ ਧਾਰੀ ॥",
          "roman": "charan kamal hirdē ur dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ, ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ) ਸੋਹਣੇ ਚਰਨ ਮੈਂ ਆਪਣੇ ਮਨ ਵਿਚ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "(Поэтому, о брат!) Я помещаю прекрасные стопы Гуру в свой ум, в своё сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8258,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਧਨ ਗੁਰ ਪ੍ਰਾਨ ਅਧਾਰੀ ॥੨॥",
          "roman": "man tan dhan gur prān adhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨ ਮੇਰੇ ਮਨ ਦਾ ਮੇਰੇ ਤਨ ਦਾ ਮੇਰੇ ਧਨ ਦਾ ਮੇਰੀ ਜਿੰਦ ਦਾ ਆਸਰਾ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Стопы Гуру — опора моему уму, моему телу, моему имуществу и моей жизни. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8259,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਜਨਮੁ ਹੋਵੈ ਪਰਵਾਣੁ ॥",
          "roman": "saphal janam hovē parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) (ਇਸ ਤਰ੍ਹਾਂ ਤੇਰਾ ਮਨੁੱਖਾ) ਜਨਮ ਕਾਮਯਾਬ ਹੋ ਜਾਇਗਾ ਤੂੰ (ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਇਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Тогда твоё человеческое рождение станет успешным, и ты будешь принят в присутствии Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8260,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਾਰਬ੍ਰਹਮੁ ਨਿਕਟਿ ਕਰਿ ਜਾਣੁ ॥੩॥",
          "roman": "gur pārabraham nikaṭ kar jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਨੂੰ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਨੂੰ (ਸਦਾ ਆਪਣੇ) ਨੇੜੇ ਵੱਸਦਾ ਸਮਝੇਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если будешь считать Гуру, Парбрахма-Господа, всегда пребывающим рядом с тобой. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8261,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਧੂਰਿ ਪਾਈਐ ਵਡਭਾਗੀ ॥",
          "roman": "saṅt dhūr pāīai vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ-ਸੰਤ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Пыль стоп Гуру-Санта обретается по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8262,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਭੇਟਤ ਹਰਿ ਸਿਉ ਲਿਵ ਲਾਗੀ ॥੪॥੭੦॥੧੩੯॥",
          "roman": "Nānak gur bheṭat har siu liv lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ ਪਰਮਾਤਮਾ (ਦੇ ਚਰਨਾਂ) ਨਾਲ ਲਗਨ ਲੱਗ ਜਾਂਦੀ ਹੈ ॥੪॥੭੦॥੧੩੯॥"
            },
            "sahib_singh_ru": {
              "main": "При встрече с Гуру возникает любовь-сосредоточение к стопам Бога. ॥4॥70॥139॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
