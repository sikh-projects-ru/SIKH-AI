{
  "ang": 195,
  "shabads": [
    {
      "shabad_id": 596,
      "rahao_verse_id": 8321,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8317,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8318,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਦੀਆ ਪੈਨੈ ਖਾਇ ॥",
          "roman": "jis kā dīā pēnē khāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਂ! ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਦਿੱਤਾ ਹੋਇਆ (ਅੰਨ) ਮਨੁੱਖ ਖਾਂਦਾ ਹੈ, (ਦਿੱਤਾ ਹੋਇਆ ਕੱਪੜਾ ਮਨੁੱਖ) ਪਹਿਨਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мать! Человек ест то, что дано Тем, и носит одежду, данную Им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8319,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸਿਉ ਆਲਸੁ ਕਿਉ ਬਨੈ ਮਾਇ ॥੧॥",
          "roman": "tis siu ālas kiu banē māi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਯਾਦ ਵਲੋਂ ਆਲਸ ਕਰਨਾ ਕਿਸੇ ਤਰ੍ਹਾਂ ਭੀ ਫਬਦਾ ਨਹੀਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Как же может хоть сколько-нибудь подобать лениться в памятовании о Нём? ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8320,
          "is_rahao": true,
          "gurmukhi": "ਖਸਮੁ ਬਿਸਾਰਿ ਆਨ ਕੰਮਿ ਲਾਗਹਿ ॥",
          "roman": "khasam bisār ān kamm lāgah ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜੇ ਮਨੁੱਖ) ਮਾਲਕ-ਪ੍ਰਭੂ (ਦੀ ਯਾਦ) ਭੁਲਾ ਕੇ ਹੋਰ ਹੋਰ ਕੰਮ ਵਿਚ ਰੁੱਝੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые, забыв Владыку-Господа, заняты разными другими делами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8321,
          "is_rahao": true,
          "gurmukhi": "ਕਉਡੀ ਬਦਲੇ ਰਤਨੁ ਤਿਆਗਹਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kauṛī badlē ratan tiāgahi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਨਕਾਰੀ ਮਾਇਆ ਦੇ ਵੱਟੇ ਵਿਚ ਆਪਣਾ ਕੀਮਤੀ ਮਨੁੱਖਾ ਜਨਮ ਗਵਾ ਲੈਂਦੇ ਹਨ। (ਉਹ ਰਤਨ ਤਾਂ ਸੁੱਟ ਦੇਂਦੇ ਹਨ, ਪਰ ਕਉਡੀ ਨੂੰ ਸਾਂਭਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в обмен на ничтожную майю теряют свой драгоценный человеческий рождённый удел. Они отбрасывают драгоценность, а берегут каури. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8322,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੂ ਤਿਆਗਿ ਲਾਗਤ ਅਨ ਲੋਭਾ ॥",
          "roman": "prabhū tiāg lāgat an lobhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਨੂੰ ਛੱਡ ਕੇ ਹੋਰ (ਪਦਾਰਥਾਂ ਦੇ) ਲੋਭ ਵਿਚ ਲੱਗਿਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Оставляя Бога и впадая в жадность к другим вещам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8323,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸਿ ਸਲਾਮੁ ਕਰਤ ਕਤ ਸੋਭਾ ॥੨॥",
          "roman": "dās salām karat kat sobhā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਪਰਮਾਤਮਾ ਦੀ) ਦਾਸੀ ਮਾਇਆ ਨੂੰ ਸਲਾਮ ਕੀਤਿਆਂ ਕਿਤੇ ਭੀ ਸੋਭਾ ਨਹੀਂ ਮਿਲ ਸਕਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и кланяясь майе, служанке Бога, нигде не обрести чести. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8324,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਰਸੁ ਖਾਵਹਿ ਖਾਨ ਪਾਨ ॥",
          "roman": "amrit ras khāvah khān pān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕੂਕਰ ਬ੍ਰਿਤੀ ਦੇ ਮਨੁੱਖ) ਸੁਆਦਲੇ ਭੋਜਨ ਖਾਂਦੇ ਹਨ, ਚੰਗੇ ਚੰਗੇ ਖਾਣੇ ਖਾਂਦੇ ਹਨ, ਪੀਣ ਵਾਲੀਆਂ ਚੀਜ਼ਾਂ ਪੀਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Люди с собачьей природой едят вкусные блюда, хорошую пищу, пьют напитки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8325,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਏ ਤਿਸਹਿ ਨ ਜਾਨਹਿ ਸੁਆਨ ॥੩॥",
          "roman": "jin dīē tisahi na jānahi suān ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ (ਇਹ ਸਾਰੇ ਪਦਾਰਥ) ਦਿੱਤੇ ਹੋਏ ਹਨ ਕੁੱਤੇ (ਦੇ ਸੁਭਾਅ ਵਾਲੇ ਮਨੁੱਖ) ਉਸ ਨੂੰ ਜਾਣਦੇ-ਪਛਾਣਦੇ ਭੀ ਨਹੀਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но того Бога, который всё это дал, они, подобные собакам, даже не знают и не узнают. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8326,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਹਮ ਲੂਣ ਹਰਾਮੀ ॥",
          "roman": "kah Nānak ham lūṇ harāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਪ੍ਰਭੂ! ਅਸੀਂ ਜੀਵ ਨਾ-ਸ਼ੁਕਰੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: О Господь! Мы, существа, неблагодарны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8327,
          "is_rahao": false,
          "gurmukhi": "ਬਖਸਿ ਲੇਹੁ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥੪॥੭੬॥੧੪੫॥",
          "roman": "bakhas lēhu prabh antarjāmī ॥4॥76॥145॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੀਵਾਂ ਦੇ ਦਿਲ ਜਾਣਨ ਵਾਲੇ ਪ੍ਰਭੂ! ਸਾਨੂੰ ਬਖ਼ਸ਼ ਲੈ ॥੪॥੭੬॥੧੪੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, знающий сердца всех существ! Прости нас. ॥4॥76॥145॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 597,
      "rahao_verse_id": 8332,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8328,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8329,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਚਰਨ ਮਨ ਮਾਹਿ ਧਿਆਨੁ ॥",
          "roman": "prabh kē charan man māh dhiān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਵੀਰ!) ਆਪਣੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Утверди в своём уме созерцание стоп Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8330,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤੀਰਥ ਮਜਨ ਇਸਨਾਨੁ ॥੧॥",
          "roman": "sagal tīrath majan isnān ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ-ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਹੀ) ਸਾਰੇ ਤੀਰਥਾਂ ਦਾ ਇਸ਼ਨਾਨ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Созерцание стоп Господа и есть омовение во всех местах паломничества. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8331,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਦਿਨੁ ਹਰਿ ਸਿਮਰਨੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "har din har simran mērē bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਸਾਰਾ ਦਿਨ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Весь день, всегда пребывай в памятовании о Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8332,
          "is_rahao": true,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਕੀ ਮਲੁ ਲਹਿ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "koṭ janam kī mal lahi jāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਹੈ ਉਸ ਦੇ) ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਦੀ (ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਲਹਿ ਜਾਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "У того человека, который помнит Бога, смывается грязь пороков многих миллионов рождений. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8333,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਕਥਾ ਰਿਦ ਮਾਹਿ ਬਸਾਈ ॥",
          "roman": "har kī kathā rid māh basāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат мой! Тот человек, который поселяет в своём сердце хвалу Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8334,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਬਾਂਛਤ ਸਗਲੇ ਫਲ ਪਾਈ ॥੨॥",
          "roman": "man bānchhat saglē phal pāī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੇ ਮਨ-ਲੋੜੀਂਦੇ ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "получает все желанные плоды ума. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8335,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਮਰਣੁ ਜਨਮੁ ਪਰਵਾਨੁ ॥",
          "roman": "jīvan maraṇ janam parvān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਨਮ ਤੋਂ ਲੈ ਕੇ ਮੌਤ ਤਕ ਉਸ ਮਨੁੱਖ ਦਾ ਸਾਰਾ ਜੀਵਨ (ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! От рождения до самой смерти вся жизнь того человека становится принятой в присутствии Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8336,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਵਸੈ ਭਗਵਾਨੁ ॥੩॥",
          "roman": "jā kē ridē vasē bhagvān ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਭਗਵਾਨ ਆ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце поселяется Бог. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8337,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸੇਈ ਜਨ ਪੂਰੇ ॥",
          "roman": "kah Nānak sēī jan pūrē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹੀ ਮਨੁੱਖ ਸੁੱਧੇ ਜੀਵਨ ਵਾਲੇ ਬਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Только те люди становятся совершенными в своей жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8338,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਾ ਪਰਾਪਤਿ ਸਾਧੂ ਧੂਰੇ ॥੪॥੭੭॥੧੪੬॥",
          "roman": "jinā parāpat sādhū dhūṛē ॥4॥77॥146॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੂੰ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮਿਲ ਜਾਂਦੀ ਹੈ ॥੪॥੭੭॥੧੪੬॥"
            },
            "sahib_singh_ru": {
              "main": "кому достаётся пыль стоп Гуру. ॥4॥77॥146॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 598,
      "rahao_verse_id": 8343,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8339,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8340,
          "is_rahao": false,
          "gurmukhi": "ਖਾਦਾ ਪੈਨਦਾ ਮੂਕਰਿ ਪਾਇ ॥",
          "roman": "khādā pēndā mūkar pāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀਆਂ ਬਖ਼ਸ਼ੀਆਂ ਦਾਤਾਂ) ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ਪਹਿਨਦਾ ਰਹਿੰਦਾ ਹੈ ਤੇ ਇਸ ਗੱਲੋਂ ਮੁਕਰਿਆ ਰਹਿੰਦਾ ਹੈ ਕਿ ਇਹ ਪਰਮਾਤਮਾ ਨੇ ਦਿੱਤੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, который продолжает есть и носить дары, дарованные Богом, и при этом отрицает, что всё это дано Им,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8341,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਨੋ ਜੋਹਹਿ ਦੂਤ ਧਰਮਰਾਇ ॥੧॥",
          "roman": "tis no johahi dūt dharmrāi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਧਰਮ-ਰਾਜ ਦੇ ਦੂਤ ਆਪਣੀ ਤੱਕ ਵਿਚ ਰੱਖਦੇ ਹਨ (ਭਾਵ, ਉਹ ਮਨੁੱਖ ਸਦਾ ਆਤਮਕ ਮੌਤੇ ਮਰਿਆ ਰਹਿੰਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "того человека держат на примете посланники Дхарм-рая, то есть он постоянно пребывает в духовной смерти. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8342,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸੁ ਸਿਉ ਬੇਮੁਖੁ ਜਿਨਿ ਜੀਉ ਪਿੰਡੁ ਦੀਨਾ ॥",
          "roman": "tis siu bēmukh jin jīu piṇḍ dīnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ) ਉਸ ਪਰਮਾਤਮਾ (ਦੀ ਯਾਦ) ਵਲੋਂ ਮੂੰਹ ਮੋੜੀ ਬੈਠਾ ਹੈਂ, ਜਿਸ ਨੇ (ਤੈਨੂੰ) ਜਿੰਦ ਦਿੱਤੀ, ਜਿਸ ਨੇ (ਤੈਨੂੰ) ਸਰੀਰ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Ты отвернулся от того Бога, который дал тебе жизнь и дал тебе тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8343,
          "is_rahao": true,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਭਰਮਹਿ ਬਹੁ ਜੂਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "koṭ janam bharmahi bah jūnā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਯਾਦ ਰੱਖ, ਇਥੋਂ ਖੁੰਝ ਕੇ) ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਵਿਚ ਅਨੇਕਾਂ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਫਿਰੇਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Помни: сбившись отсюда, ты будешь блуждать через миллионы рождений во множестве форм жизни. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8344,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਕੀ ਐਸੀ ਹੈ ਰੀਤਿ ॥",
          "roman": "sākat kī ēsī hē rīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮਾਇਆ-ਵੇੜ੍ਹੇ ਮਨੁੱਖ ਦੀ ਜੀਵਨ-ਮਰਯਾਦਾ ਹੀ ਐਸੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Таков уклад жизни человека, окружённого майей:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8345,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੈ ਸਗਲ ਬਿਪਰੀਤਿ ॥੨॥",
          "roman": "jo kichh karē sagal biprīt ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਹ ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ ਸਾਰਾ ਬੇ-ਮੁਖਤਾ ਦਾ ਕੰਮ ਹੀ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "что бы он ни делал, всё оказывается делом отвращения от Бога. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8346,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪ੍ਰਾਣ ਜਿਨਿ ਮਨੁ ਤਨੁ ਧਾਰਿਆ ॥ ਸੋਈ ਠਾਕੁਰੁ ਮਨਹੁ ਬਿਸਾਰਿਆ ॥੩॥",
          "roman": "jīu prāṇ jin man tan dhāriā ॥ soī ṭhākur manah bisāriā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਜੀਵ ਦੀ ਜਿੰਦ ਨੂੰ ਮਨ ਨੂੰ ਸਰੀਰ ਨੂੰ (ਆਪਣੀ ਜੋਤਿ ਦਾ) ਸਹਾਰਾ ਦਿੱਤਾ ਹੋਇਆ ਹੈ, ਉਸ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਨੂੰ ਸਾਕਤ ਮਨੁੱਖ ਆਪਣੇ ਮਨ ਤੋਂ ਭੁਲਾਈ ਰੱਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Того Бога, который поддерживает жизнь, ум и тело существа Своим светом, такого Питателя человек, привязанный к майе, держит забытым в своём уме. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8347,
          "is_rahao": false,
          "gurmukhi": "ਬਧੇ ਬਿਕਾਰ ਲਿਖੇ ਬਹੁ ਕਾਗਰ ॥",
          "roman": "badhē bikār likhē bah kāgar ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ, ਹੇ ਭਾਈ! ਉਸ ਸਾਕਤ ਦੇ ਇਤਨੇ) ਵਿਕਾਰ ਵਧ ਜਾਂਦੇ ਹਨ ਕਿ ਉਹਨਾਂ ਦੇ ਅਨੇਕਾਂ ਦਫ਼ਤਰ ਹੀ ਲਿਖੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Так, о брат, его пороки настолько умножаются, что на них записываются целые бесчисленные ведомости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8348,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੁ ਕ੍ਰਿਪਾ ਸੁਖ ਸਾਗਰ ॥੪॥",
          "roman": "Nānak udhar kirpā sukh sāgar ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ-ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) ਹੇ ਦਇਆ ਦੇ ਸਮੁੰਦਰ! ਹੇ ਸੁਖਾਂ ਦੇ ਸਮੁੰਦਰ! (ਤੂੰ ਆਪ ਸਾਨੂੰ ਜੀਵਾਂ ਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਰੱਖ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Вознеси молитву у врат Господа и скажи: О Океан милости! О Океан блаженства! Сам храни нас, существа, от пороков. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8349,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਤੇਰੀ ਸਰਣਾਇ ॥",
          "roman": "pārbrahm tērī saraṇāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਜੇਹੜੇ ਮਨੁੱਖ (ਤੇਰੀ ਮਿਹਰ ਨਾਲ) ਤੇਰੀ ਸਰਨ ਆਉਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Парбрахм, Господь! Те люди, которые по Твоей милости приходят под Твою защиту,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8350,
          "is_rahao": true,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਤਰੈ ਹਰਿ ਨਾਇ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥੭੮॥੧੪੭॥",
          "roman": "bandhan kāṭ tarē har nāi ॥1॥ rahāu dūjā ॥78॥147॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਤੇਰੇ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਆਪਣੇ ਮਾਇਆ ਦੇ) ਬੰਧਨ ਕੱਟ ਕੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥੭੮॥੧੪੭॥"
            },
            "sahib_singh_ru": {
              "main": "силой Твоего Имени разрывают свои узы майи и переправляются через мирской океан. ॥1॥ Вторая пауза ॥78॥147॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 599,
      "rahao_verse_id": 8355,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8351,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8352,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਲੋਭ ਕਉ ਕੀਨੋ ਮੀਤੁ ॥",
          "roman": "apnē lobh kau kīno mīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਵੇਖੋ ਗੋਬਿੰਦ ਦੀ ਉਦਾਰਤਾ) ਭਾਵੇਂ ਕੋਈ ਮਨੁੱਖ ਆਪਣੇ ਕਿਸੇ ਲਾਲਚ ਦੀ ਖ਼ਾਤਰ ਉਸ ਨੂੰ ਮਿੱਤਰ ਬਣਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Посмотри на щедрость Гобинда: даже если человек делает Его своим другом ради какой-то собственной выгоды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8353,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਮੁਕਤਿ ਪਦੁ ਦੀਤੁ ॥੧॥",
          "roman": "sagal manorath mukat pad dīt ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ ਭੀ ਉਹ ਉਸ ਦੇ) ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਕਰ ਦੇਂਦਾ ਹੈ (ਤੇ ਉਸ ਨੂੰ) ਉਹ ਆਤਮਕ ਅਵਸਥਾ ਭੀ ਦੇ ਦੇਂਦਾ ਹੈ ਜਿੱਥੇ ਕੋਈ ਵਾਸਨਾ ਪੋਹ ਨਹੀਂ ਸਕਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он всё равно исполняет все его желания и даёт ему то духовное состояние, куда не может проникнуть никакое вожделение. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8354,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਮੀਤੁ ਕਰਹੁ ਸਭੁ ਕੋਇ ॥",
          "roman": "aisā mīt karah sabh koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੇਕ ਮਨੁੱਖ ਇਹੋ ਜਿਹਾ (ਇਹੋ ਜਿਹੇ ਪ੍ਰਭੂ ਨੂੰ) ਮਿੱਤਰ ਬਣਾਓ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть каждый человек делает себе такого друга, такого Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8355,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਤੇ ਬਿਰਥਾ ਕੋਇ ਨ ਹੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā tē birthā koi na hoi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਦੇ ਦਰ) ਤੋਂ ਕੋਈ ਖ਼ਾਲੀ ਨਹੀਂ ਰਹਿੰਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "от чьих дверей никто не уходит с пустыми руками. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8356,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੈ ਸੁਆਇ ਰਿਦੈ ਲੈ ਧਾਰਿਆ ॥",
          "roman": "apunē suāi ridē lē dhāriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ (ਉਸ ਗੋਬਿੰਦ ਨੂੰ) ਆਪਣੀ ਗ਼ਰਜ਼ ਵਾਸਤੇ ਭੀ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਲਿਆ ਟਿਕਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который даже ради своей собственной нужды удержал Гобинда в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8357,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਦਰਦ ਰੋਗ ਸਗਲ ਬਿਦਾਰਿਆ ॥੨॥",
          "roman": "dūkh darad rog sagal bidāriā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੋਬਿੰਦ ਨੇ ਉਸ ਦੇ) ਸਾਰੇ ਦੁੱਖ ਦਰਦ ਸਾਰੇ ਰੋਗ ਦੂਰ ਕਰ ਦਿੱਤੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "у того Гобинд устранил все страдания, боли и болезни. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8358,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਗੀਧੀ ਬੋਲਤ ਰਾਮ ॥",
          "roman": "rasnā gīdhī bolat rām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਦੀ ਜੀਭ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਉੱਚਾਰਨ ਲਈ ਤਾਂਘ ਕਰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! У того человека, чей язык жаждет произносить Имя Гобинда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8359,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਏ ਸਗਲੇ ਕਾਮ ॥੩॥",
          "roman": "pūran hoē saglē kām ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "исполняются все его желания. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8360,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਾਰ ਨਾਨਕ ਬਲਿਹਾਰਾ ॥",
          "roman": "anik bār Nānak balihārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਆਪਣੇ ਗੋਬਿੰਦ ਤੋਂ ਅਨੇਕਾਂ ਵਾਰੀ ਕੁਰਬਾਨ ਜਾਂਦੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Мы бесчисленное множество раз отдаём себя в жертву нашему Гобинду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8361,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਦਰਸਨੁ ਗੋਬਿੰਦੁ ਹਮਾਰਾ ॥੪॥੭੯॥੧੪੮॥",
          "roman": "saphal darsan gobind hamārā ॥4॥79॥148॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਸਾਡਾ ਗੋਬਿੰਦ ਐਸਾ ਹੈ ਕਿ ਉਸ ਦਾ ਦਰਸਨ ਸਾਰੇ ਫਲ ਦੇਂਦਾ ਹੈ ॥੪॥੭੯॥੧੪੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: наш Гобинд таков, что Его даршан приносит все плоды. ॥4॥79॥148॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 600,
      "rahao_verse_id": 8366,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8362,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8363,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਬਿਘਨ ਹਿਰੇ ਖਿਨ ਮਾਹਿ ॥",
          "roman": "koṭ bighan hirē khin māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹਨਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਦੇ ਰਾਹ ਵਿਚ ਆਉਣ ਵਾਲੀਆਂ ਕ੍ਰੋੜਾਂ ਰੁਕਾਵਟਾਂ ਇਕ ਖਿਨ ਵਿਚ ਨਾਸ ਹੋ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! У тех людей миллионы препятствий на жизненном пути уничтожаются в одно мгновение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8364,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਥਾ ਸਾਧਸੰਗਿ ਸੁਨਾਹਿ ॥੧॥",
          "roman": "har har kathā sādhsang sunāhi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਟਿਕ ਕੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "которые, пребывая в святом собрании, слушают хвалу Бога. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8365,
          "is_rahao": true,
          "gurmukhi": "ਪੀਵਤ ਰਾਮ ਰਸੁ ਅੰਮ੍ਰਿਤ ਗੁਣ ਜਾਸੁ ॥",
          "roman": "pīvat rām ras amrit guṇ jās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਰਸ ਪੀਂਦਿਆਂ, ਪਰਮਾਤਮਾ ਦੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਗੁਣਾਂ ਦਾ ਜਸ ਗਾਂਦਿਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пьющие нектар Имени Бога и воспевающие Его животворящие качества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8366,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਹਰਿ ਚਰਣ ਮਿਟੀ ਖੁਧਿ ਤਾਸੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jap har charaṇ miṭī khudh tās ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਜਪ ਕੇ (ਮਾਇਆ ਦੀ) ਭੁੱਖ ਮਿਟ ਜਾਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "памятуя стопы Бога, избавляются от голода майи. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8367,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਸੁਖ ਸਹਜ ਨਿਧਾਨ ॥",
          "roman": "sarab kalliāṇ sukh sahaj nidhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਾਰੇ ਸੁਖਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਤੇ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਆਨੰਦ ਮਿਲ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Он обретает сокровища всех радостей и блаженство духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8368,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਵਸਹਿ ਭਗਵਾਨ ॥੨॥",
          "roman": "jā kē ridē vasahi bhagvān ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਗਵਾਨ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਤੂੰ ਵੱਸ ਪੈਂਦਾ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Бог, если Ты поселяешься в сердце человека. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
