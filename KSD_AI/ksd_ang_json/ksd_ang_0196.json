{
  "ang": 196,
  "shabads": [
    {
      "shabad_id": 600,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8369,
          "is_rahao": false,
          "gurmukhi": "ਅਉਖਧ ਮੰਤ੍ਰ ਤੰਤ ਸਭਿ ਛਾਰੁ ॥",
          "roman": "aukhadh mantar tant sabh chhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਨਾਮ ਦੇ ਟਾਕਰੇ ਤੇ ਹੋਰ) ਸਾਰੇ ਦਾਰੂ ਸਾਰੇ ਮੰਤਰ ਤੇ ਟੂਣੇ ਤੁੱਛ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Перед Именем все прочие лекарства, мантры и чары — ничтожны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8370,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੈਹਾਰੁ ਰਿਦੇ ਮਹਿ ਧਾਰੁ ॥੩॥",
          "roman": "karṇēhār ridē mahi dhār ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਜਣਹਾਰ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਈ ਰੱਖ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Удерживай в своём сердце Творца. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8371,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਸਭਿ ਭਰਮ ਭਜਿਓ ਪਾਰਬ੍ਰਹਮੁ ॥",
          "roman": "taj sabh bharam bhajio pārbrahm ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਸਾਰੇ ਭਰਮ ਤਿਆਗ ਕੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਦਾ ਭਜਨ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, оставив все сомнения, предался Парбрахму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8372,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਅਟਲ ਇਹੁ ਧਰਮੁ ॥੪॥੮੦॥੧੪੯॥",
          "roman": "kah Nānak aṭal ihu dharam ॥4॥80॥149॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਉਸ ਨੇ ਵੇਖ ਲਿਆ ਹੈ ਕਿ ਭਜਨ-ਸਿਮਰਨ ਵਾਲਾ) ਧਰਮ ਐਸਾ ਹੈ ਜੋ ਕਦੇ ਫਲ ਦੇਣੋਂ ਉਕਾਈ ਨਹੀਂ ਖਾਂਦਾ ॥੪॥੮੦॥੧੪੯॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: он увидел, что такой путь бхаджана и симрана — непреложен и никогда не перестаёт приносить плод. ॥4॥80॥149॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 601,
      "rahao_verse_id": 8377,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8373,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gaurī mehlā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8374,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਭੇਟੇ ਗੁਰ ਸੋਈ ॥",
          "roman": "kar kirpā bheṭe gur soī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਹੇ ਭਾਈ!) ਉਹੀ ਮਨੁੱਖ ਗੁਰੂ ਨੂੰ ਮਿਲਦਾ ਹੈ, ਜਿਸ ਉਤੇ ਪਰਮਾਤਮਾ ਕਿਰਪਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но, о брат! Только тот человек встречает Гуру, на кого Бог являет милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8375,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਬਲਿ ਰੋਗੁ ਨ ਬਿਆਪੈ ਕੋਈ ॥੧॥",
          "roman": "tit bal rog na biāpē koī ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੇ ਮਿਲਾਪ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਆਤਮਕ ਬਲ ਪੈਦਾ ਹੁੰਦਾ ਹੈ) ਉਸ ਬਲ ਦੇ ਕਾਰਨ ਕੋਈ ਰੋਗ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря встрече с Гуру внутри человека возникает духовная сила, и из-за этой силы никакая болезнь уже не может взять верх над ним. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8376,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਰਮਣ ਤਰਣ ਭੈ ਸਾਗਰ ॥",
          "roman": "rām ramaṇ taraṇ bhē sāgar ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Поминанием Бога переплывают мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8377,
          "is_rahao": true,
          "gurmukhi": "ਸਰਣਿ ਸੂਰ ਫਾਰੇ ਜਮ ਕਾਗਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "saraṇ sūr phāre jam kāgar ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੂਰਮੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਜਮਾਂ ਦੇ ਲੇਖੇ ਪਾੜੇ ਜਾਂਦੇ ਹਨ, (ਆਤਮਕ ਮੌਤ ਲਿਆਉਣ ਵਾਲੇ ਸਾਰੇ ਸੰਸਕਾਰ ਮਿਟ ਜਾਂਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда приходят в прибежище к отважному Гуру, записи ямов разрываются, и все впечатления, приносящие духовную смерть, стираются. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8378,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮੰਤ੍ਰੁ ਦੀਓ ਹਰਿ ਨਾਮ ॥",
          "roman": "satgur mantr dīo har nām ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਸਤਿਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਮੰਤ੍ਰ ਦੇ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому человеку, которому Сатгуру дал мантру Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8379,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਆਸਰ ਪੂਰਨ ਭਏ ਕਾਮ ॥੨॥",
          "roman": "ih āsar pūran bhae kām ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਨਾਮ-ਮੰਤ੍ਰ ਦੇ ਆਸਰੇ ਉਸ ਦੇ ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਹੋ ਗਏ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "с опорой на эту мантру Имени исполнились все его желания. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8380,
          "is_rahao": false,
          "gurmukhi": "ਜਪ ਤਪ ਸੰਜਮ ਪੂਰੀ ਵਡਿਆਈ ॥ ਗੁਰ ਕਿਰਪਾਲ ਹਰਿ ਭਏ ਸਹਾਈ ॥੩॥",
          "roman": "jap tap sanjam pūrī vaḍiāī || gur kirpāl har bhae sahāī ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ) ਸਤਿਗੁਰੂ ਜੀ ਕਿਰਪਾਲ ਹੋਏ, ਜਿਸ ਦੇ ਮਦਦਗਾਰ ਪ੍ਰਭੂ ਜੀ ਬਣ ਗਏ, ਉਸ ਨੂੰ ਸਾਰੇ ਜਪਾਂ ਦੀ, ਸਾਰੇ ਤਪਾਂ ਦੀ, ਸਾਰੇ ਸੰਜਮਾਂ ਦੀ ਵਡਿਆਈ ਪ੍ਰਾਪਤ ਹੋ ਗਈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, к кому Сатгуру был милостив и кому Сам Господь стал помощником, получил всё величие всех джапов, всех тапов и всех воздержаний. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8381,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨ ਮੋਹ ਖੋਏ ਗੁਰਿ ਭਰਮ ॥",
          "roman": "mān moh khoe gur bharam ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਜੀ ਹਰ ਥਾਂ ਵਿਆਪਕ ਦਿੱਸ ਪਏ,"
            },
            "sahib_singh_ru": {
              "main": "Ему стал виден Парбрахм, пронизывающий всё и повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8382,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖੁ ਨਾਨਕ ਪਸਰੇ ਪਾਰਬ੍ਰਹਮ ॥੪॥੮੧॥੧੫੦॥",
          "roman": "pekh nānak pasre pārbrahm ||4||81||150||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਵੇਖ, ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਅਹੰਕਾਰ ਮੋਹ ਆਦਿਕ ਭਰਮ ਨਾਸ ਕਰ ਦਿੱਤੇ ॥੪॥੮੧॥੧੫੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Посмотри: это тот человек, у которого Гуру уничтожил заблуждения — эго, привязанность и прочее. ||4||81||150||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 602,
      "rahao_verse_id": 8387,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8383,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gaurī mehlā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8384,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੈ ਰਾਜ ਤੇ ਅੰਧੁਲਾ ਭਾਰੀ ॥",
          "roman": "bikhē rāj te andhulā bhārī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਵਿਸ਼ਿਆਂ ਦੇ ਪ੍ਰਭਾਵ ਨਾਲ (ਮਨੁੱਖ ਵਿਕਾਰਾਂ ਵਿਚ) ਬਹੁਤ ਅੰਨ੍ਹਾ ਹੋ ਜਾਂਦਾ ਹੈ (ਤਦੋਂ ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਕਦੇ ਭੀ ਨਹੀਂ ਸੁੱਝਦਾ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Под воздействием чувственных объектов человек становится очень слепым в пороках, и тогда Имя Бога ему совсем не приходит на ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8385,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖਿ ਲਾਗੈ ਰਾਮ ਨਾਮੁ ਚਿਤਾਰੀ ॥੧॥",
          "roman": "dukh lāgē rām nām chitārī ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਵਿਕਾਰਾਂ ਦੇ ਕਾਰਨ ਜਦੋਂ ਉਹ) ਦੁੱਖ ਵਿਚ ਫਸਦਾ ਹੈ, ਤਦੋਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਚੇਤੇ ਕਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но когда из-за пороков он попадает в страдание, тогда вспоминает Имя Бога. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8386,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੇ ਦਾਸ ਕਉ ਤੁਹੀ ਵਡਿਆਈ ॥",
          "roman": "tere dās kau tuhī vaḍiāī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੇ ਦਾਸ ਦੇ ਵਾਸਤੇ ਤੇਰਾ ਨਾਮ ਹੀ (ਲੋਕ-ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Для Твоего слуги именно Твоё Имя является честью и в этом мире, и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8387,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਮਗਨੁ ਨਰਕਿ ਲੈ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "māiā magan narak lē jāī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਦਾਸ ਜਾਣਦਾ ਹੈ ਕਿ) ਮਾਇਆ ਵਿਚ ਮਸਤ ਮਨੁੱਖ ਨੂੰ (ਮਾਇਆ) ਨਰਕ ਵਿਚ ਲੈ ਜਾਂਦੀ ਹੈ (ਸਦਾ ਦੁਖੀ ਰੱਖਦੀ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Твой слуга знает, что человека, опьянённого майей, она уводит в ад и держит в постоянном страдании. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8388,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗ ਗਿਰਸਤ ਚਿਤਾਰੇ ਨਾਉ ॥",
          "roman": "rog girast chitāre nāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਰੋਗਾਂ ਨਾਲ ਘਿਰਿਆ ਹੋਇਆ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਚੇਤੇ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Человек, окружённый болезнями, вспоминает Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8389,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੁ ਮਾਤੇ ਕਾ ਠਉਰ ਨ ਠਾਉ ॥੨॥",
          "roman": "bikh māte kā ṭhaur na ṭhāu ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਵਿਕਾਰਾਂ ਦੀ ਜ਼ਹਿਰ ਵਿਚ ਮਸਤ ਹੋਏ ਮਨੁੱਖ ਦੇ ਆਤਮਕ ਜੀਵਨ ਦਾ ਕਿਤੇ ਨਾਮ-ਨਿਸ਼ਾਨ ਨਹੀਂ ਲੱਭਦਾ, (ਵਿਕਾਰਾਂ ਦੀ ਜ਼ਹਿਰ ਉਸ ਦੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਮਾਰ-ਮੁਕਾਂਦੀ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но у человека, опьянённого ядом пороков, нигде не находится и следа духовной жизни: яд пороков уничтожает его духовную жизнь. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8390,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "charaṇ kamal siu lāgī prīt ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ) ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ (ਜਿਸ ਮਨੁੱਖ ਦੀ) ਪ੍ਰੀਤਿ ਬਣ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если у человека возникает любовь к прекрасным стопам Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8391,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਸੁਖਾ ਨਹੀ ਆਵਹਿ ਚੀਤਿ ॥੩॥",
          "roman": "ān sukhā nahī āvahi chīt ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਦੁਨੀਆ ਵਾਲੇ ਹੋਰ ਹੋਰ ਸੁਖ ਚੇਤੇ ਨਹੀਂ ਆਉਂਦੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то другие мирские удовольствия уже не приходят ему на ум. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8392,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਸਿਮਰਉ ਪ੍ਰਭ ਸੁਆਮੀ ॥",
          "roman": "sadā sadā simrau prabh suāmī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਆਮੀ! ਮੈਂ ਸਦਾ ਹੀ ਤੈਨੂੰ ਸਿਮਰਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Пусть я всегда помню Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8393,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੁ ਨਾਨਕ ਹਰਿ ਅੰਤਰਜਾਮੀ ॥੪॥੮੨॥੧੫੧॥",
          "roman": "mil nānak har antarjāmī ||4||82||151||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ)-ਹੇ ਪ੍ਰਭੂ! ਹੇ ਹੇ ਅੰਤਰਜਾਮੀ ਹਰੀ! (ਮੈਨੂੰ) ਮਿਲ ॥੪॥੮੨॥੧੫੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Помолись и скажи: о Господь, о всеведущий Хари, откройся мне. ||4||82||151||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 603,
      "rahao_verse_id": 8398,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8394,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gaurī mehlā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8395,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਸੰਗੀ ਬਟਵਾਰੇ ॥",
          "roman": "āṭh pahar sangī baṭvāre ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਾਮਾਦਿਕ ਪੰਜੇ) ਡਾਕੂ ਅੱਠੇ ਪਹਰ (ਮਨੁੱਖ ਦੇ ਨਾਲ) ਸਾਥੀ ਬਣੇ ਰਹਿੰਦੇ ਹਨ (ਤੇ ਇਸ ਦੇ ਆਤਮਕ ਜੀਵਨ ਉਤੇ ਡਾਕਾ ਮਾਰਦੇ ਰਹਿੰਦੇ ਹਨ।)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пять разбойников — кам и прочие — все восемь страж остаются спутниками человека и продолжают грабить его духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8396,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਲਏ ਨਿਵਾਰੇ ॥੧॥",
          "roman": "kar kirpā prabh lae nivāre ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੂੰ ਬਚਾਇਆ ਹੈ) ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਕਿਰਪਾ ਕਰ ਕੇ ਬਚਾ ਲਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тех, кого Бог спас, Он Сам по милости и уберёг. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8397,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਹਰਿ ਰਸੁ ਰਮਹੁ ਸਭੁ ਕੋਇ ॥",
          "roman": "aisā har ras ramah sabh koī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੇਕ ਜੀਵ ਅਜੇਹੀ ਸਮਰੱਥਾ ਵਾਲੇ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਰਸ ਮਾਣੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть всякое существо вкушает нектар Имени такого Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8398,
          "is_rahao": true,
          "gurmukhi": "ਸਰਬ ਕਲਾ ਪੂਰਨ ਪ੍ਰਭੁ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarab kalā pūran prabh soī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਸਾਰੀਆਂ ਮੁਕੰਮਲ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ (ਜੇਹੜਾ ਮਨੁੱਖ ਉਸ ਦਾ ਪੱਲਾ ਫੜਦਾ ਹੈ, ਉਹ ਕਿਸੇ ਵਿਕਾਰ ਨੂੰ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕਣ ਦੇਂਦਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Который обладает всеми совершенными силами; если человек держится за Него, он не позволяет никакому пороку даже приблизиться к себе. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8399,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਤਪਤਿ ਸਾਗਰ ਸੰਸਾਰ ॥",
          "roman": "mahā tapat sāgar sansār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਾਮਾਦਿਕ ਵਿਕਾਰਾਂ ਦੀ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਬੜੀ ਤਪਸ਼ ਪੈ ਰਹੀ ਹੈ। (ਇਸ ਤਪਸ਼ ਤੋਂ ਬਚਣ ਲਈ ਪ੍ਰਭੂ ਦਾ ਹੀ ਆਸਰਾ ਲਵੋ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В мировом океане бушует великий жар пороков — кама и прочих. Чтобы спастись от этого жара, ищи опору только в Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8400,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਖਿਨ ਮਹਿ ਪਾਰਿ ਉਤਾਰਣਹਾਰ ॥੨॥",
          "roman": "prabh khin mahi pār utāraṇhār ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਇਕ ਖਿਨ ਵਿਚ ਇਸ ਸੜਨ ਵਿਚੋਂ ਪਾਰ ਲੰਘਾਣ ਦੀ ਤਾਕਤ ਰੱਖਣ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Бог способен в одно мгновение переправить через это пламя. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8401,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬੰਧਨ ਤੋਰੇ ਨਹੀ ਜਾਹਿ ॥",
          "roman": "anik bandhan tore nahī jāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਇਹ ਵਿਕਾਰ ਆਦਿਕ) ਅਨੇਕਾਂ ਫਾਹੀਆਂ ਹਨ (ਮਨੁੱਖਾਂ ਪਾਸੋਂ ਆਪਣੇ ਜਤਨ ਨਾਲ ਇਹ ਫਾਹੀਆਂ) ਤੋੜੀਆਂ ਨਹੀਂ ਜਾ ਸਕਦੀਆਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Эти пороки и привязанность к майе — бесчисленные петли, и человек своими усилиями не может их разорвать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8402,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮ ਮੁਕਤਿ ਫਲ ਪਾਹਿ ॥੩॥",
          "roman": "simrat nām mukat phal pāhi ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਇਹਨਾਂ ਫਾਹੀਆਂ ਤੋਂ ਖ਼ਲਾਸੀ-ਰੂਪ ਫਲ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но, помня Имя Бога, человек получает плод освобождения от этих петель. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8403,
          "is_rahao": false,
          "gurmukhi": "ਉਕਤਿ ਸਿਆਨਪ ਇਸ ਤੇ ਕਛੁ ਨਾਹਿ ॥",
          "roman": "ukat siānap is te kachh nāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ-ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-ਹੇ ਪ੍ਰਭੂ!) ਇਸ ਜੀਵ ਪਾਸੋਂ ਕੋਈ ਅਜੇਹੀ ਸਿਆਣਪ ਕੋਈ ਅਜੇਹੀ ਦਲੀਲ ਨਹੀ ਚੱਲ ਸਕਦੀ (ਜਿਸ ਕਰਕੇ ਇਹ ਇਹਨਾਂ ਡਾਕੂਆਂ ਦੇ ਪੰਜੇ ਤੋਂ ਬਚ ਸਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Помолись и скажи: о Господь! У этого существа нет такой хитрости и такого довода, которыми оно могло бы спастись из лап этих разбойников."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8404,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਨਾਨਕ ਗੁਣ ਗਾਹਿ ॥੪॥੮੩॥੧੫੨॥",
          "roman": "kar kirpā nānak guṇ gāhi ||4||83||152||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਆਪ) ਕਿਰਪਾ ਕਰ, ਜੀਵ ਤੇਰੇ ਗੁਣ ਗਾਵਣ (ਤੇ ਇਹਨਾਂ ਤੋਂ ਬਚ ਸਕਣ) ॥੪॥੮੩॥੧੫੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Сам яви милость, чтобы существа пели Твои качества и могли от них спастись. ||4||83||152||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 604,
      "rahao_verse_id": 8409,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8405,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gaurī mehlā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8406,
          "is_rahao": false,
          "gurmukhi": "ਥਾਤੀ ਪਾਈ ਹਰਿ ਕੋ ਨਾਮ ॥",
          "roman": "thātī pāī har ko nām ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇ ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਧਨ ਦੀ ਥੈਲੀ ਹਾਸਲ ਕਰ ਲਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если по милости Бога ты получил суму с богатством Его Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8407,
          "is_rahao": false,
          "gurmukhi": "ਬਿਚਰੁ ਸੰਸਾਰ ਪੂਰਨ ਸਭਿ ਕਾਮ ॥੧॥",
          "roman": "bichar sansār pūran sabh kām ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਤੂੰ ਸੰਸਾਰ ਦੇ ਕਾਰ-ਵਿਹਾਰਾਂ ਵਿਚ ਭੀ (ਨਿਸੰਗ ਹੋ ਕੇ) ਤੁਰ ਫਿਰ। ਤੇਰੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਣਗੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда и среди мирских дел ходи свободно и без привязанности — все твои дела завершатся успешно. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8408,
          "is_rahao": true,
          "gurmukhi": "ਵਡਭਾਗੀ ਹਰਿ ਕੀਰਤਨੁ ਗਾਈਐ ॥",
          "roman": "vaḍbhāgī har kīrtan gāīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਗਾਇਆ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Песнь хвалы Богу можно петь только по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8409,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਤੂੰ ਦੇਹਿ ਤ ਪਾਈਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pārbrahm tū deh ta pāīai ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਜੇ ਤੂੰ ਆਪ ਸਾਨੂੰ ਜੀਵਾਂ ਨੂੰ ਆਪਣੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ  ਦਾਤ ਦੇਵੇਂ ਤਾਂ ਹੀ ਸਾਨੂੰ ਮਿਲ ਸਕਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Парбрахм, Господь! Только если Ты Сам дашь нам, существам, дар Своей хвалы, мы сможем его получить. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8410,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਚਰਣ ਹਿਰਦੈ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "har ke charaṇ hirdē ur dhār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਦਿਲ ਵਿਚ ਟਿਕਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Удерживай стопы Бога в своём сердце, в своей душе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8411,
          "is_rahao": false,
          "gurmukhi": "ਭਵ ਸਾਗਰੁ ਚੜਿ ਉਤਰਹਿ ਪਾਰਿ ॥੨॥",
          "roman": "bhav sāgar chaṛ utarahi pār ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ-ਚਰਨ-ਰੂਪ ਜਹਾਜ਼ ਉਤੇ) ਚੜ੍ਹ ਕੇ ਤੂੰ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਏਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поднявшись на корабль стоп Бога, ты переплывёшь мировой океан. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8412,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗੁ ਕਰਹੁ ਸਭੁ ਕੋਇ ॥",
          "roman": "sādhū sang karah sabh koī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੇਕ ਪ੍ਰਾਣੀ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть каждый человек пребывает в обществе Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8413,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਕਲਿਆਣ ਫਿਰਿ ਦੂਖੁ ਨ ਹੋਇ ॥੩॥",
          "roman": "sadā kaliāṇ phir dūkh na hoī ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ) ਸਦਾ ਸੁਖ ਹੀ ਸੁਖ ਹੋਣਗੇ, ਮੁੜ ਕੋਈ ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕੇਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в обществе Гуру, человек всегда будет иметь только благо и счастье, и больше никакое страдание не сможет его коснуться. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8414,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਭਜੁ ਗੁਣੀ ਨਿਧਾਨੁ ॥",
          "roman": "prem bhagat bhaj guṇī nidhān ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰੇਮ-ਭਰੀ ਭਗਤੀ ਨਾਲ ਸਾਰੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜਾਨੇ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "С любовной преданностью поклоняйся Богу, сокровищнице всех достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8415,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਗਹ ਪਾਈਐ ਮਾਨੁ ॥੪॥੮੪॥੧੫੩॥",
          "roman": "nānak dargah pāīai mān ||4||84||153||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਤਰ੍ਹਾਂ) ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ-ਮਾਣ ਮਿਲਦਾ ਹੈ ॥੪॥੮੪॥੧੫੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Так в присутствии Бога обретают честь и почёт. ||4||84||153||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 605,
      "rahao_verse_id": 8420,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8416,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gaurī mehlā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8417,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਪੂਰਨ ਹਰਿ ਮੀਤ ॥",
          "roman": "jal thal mahīal pūran har mīt ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਪ੍ਰਭੂ-ਮਿੱਤਰ ਜਲ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь-друг присутствует в воде, на земле и в небе, повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8418,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮ ਬਿਨਸੇ ਗਾਏ ਗੁਣ ਨੀਤ ॥੧॥",
          "roman": "bharam binse gāe guṇ nīt ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਗੁਣ ਸਦਾ ਗਾਵਿਆਂ ਸਭ ਕਿਸਮ ਦੇ ਭਟਕਣ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и если постоянно петь Его качества, исчезают все виды заблуждений. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8419,
          "is_rahao": true,
          "gurmukhi": "ਊਠਤ ਸੋਵਤ ਹਰਿ ਸੰਗਿ ਪਹਰੂਆ ॥",
          "roman": "ūṭhat sovat har sang paharūā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਪਰਮਾਤਮਾ ਜਾਗਦਿਆਂ ਸੁੱਤਿਆਂ ਹਰ ਵੇਲੇ ਜੀਵ ਦੇ ਨਾਲ ਰਾਖਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Этот Бог и при бодрствовании, и во сне всегда рядом с существом как хранитель,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8420,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਣਿ ਜਮ ਨਹੀ ਡਰੂਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā kē simraṇ jam nahī ḍarūā ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ (ਆਤਮਕ ਮੌਤ ਨੇੜੇ ਨਹੀਂ ਢੁਕ ਸਕਦੀ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и по милости памятования этого Бога страх смерти исчезает, духовная смерть уже не может приблизиться. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8421,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਪ੍ਰਭ ਰਿਦੈ ਨਿਵਾਸੁ ॥",
          "roman": "charaṇ kamal prabh ridē nivās ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਨਿਵਾਸ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если в сердце человека поселяются прекрасные стопы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
