{
  "ang": 198,
  "shabads": [
    {
      "shabad_id": 610,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8476,
          "is_rahao": false,
          "gurmukhi": "ਰੂਪਵੰਤੁ ਸੋ ਚਤੁਰੁ ਸਿਆਣਾ ॥",
          "roman": "Rūpvant so chatur siāṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹੀ ਮਨੁੱਖ ਰੂਪ ਵਾਲਾ ਹੈ ਉਹੀ ਤੀਖਣ ਬੁੱਧਿ ਵਾਲਾ ਹੈ ਉਹੀ ਸਿਆਣਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По-настоящему красив, по-настоящему остроумен и по-настоящему мудр лишь тот человек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8477,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਨਿ ਮਾਨਿਆ ਪ੍ਰਭ ਕਾ ਭਾਣਾ ॥੨॥",
          "roman": "Jin jan māniā prabh kā bhāṇā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ (ਸਦਾ ਸਿਰ ਮੱਥੇ ਉਤੇ) ਮੰਨਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "который всегда принимает волю Параматмы как высшую. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8478,
          "is_rahao": false,
          "gurmukhi": "ਜਗ ਮਹਿ ਆਇਆ ਸੋ ਪਰਵਾਣੁ ॥",
          "roman": "Jag meh āiā so parvāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਪਛਾਣ ਲਿਆ ਹੈ) ਉਹੀ ਮਨੁੱਖ ਜਗਤ ਵਿਚ ਆਇਆ ਸਫਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Лишь тот человек пришёл в мир не напрасно и успешно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8479,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਅਪਣਾ ਸੁਆਮੀ ਜਾਣੁ ॥੩॥",
          "roman": "Ghaṭ ghaṭ apṇā suāmī jāṇ ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਪਛਾਣ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "кто узнал своего Господа-Владыку как пребывающего в каждом теле. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8480,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕੇ ਪੂਰਨ ਭਾਗ ॥",
          "roman": "Kah Nānak jā ke pūran bhāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦੇ ਪੂਰੇ ਭਾਗ ਜਾਗ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: когда у человека полностью пробуждается удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8481,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਣੀ ਤਾ ਕਾ ਮਨੁ ਲਾਗ ॥੪॥੯੦॥੧੫੯॥",
          "roman": "Har charaṇī tā kā man lāg ॥4॥90॥159॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਲੱਗਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੯੦॥੧੫੯॥"
            },
            "sahib_singh_ru": {
              "main": "его ум пребывает прилеплённым к стопам Параматмы. ॥4॥90॥159॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 611,
      "rahao_verse_id": 8484,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8482,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Mahallā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8483,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੇ ਦਾਸ ਸਿਉ ਸਾਕਤ ਨਹੀ ਸੰਗੁ ॥",
          "roman": "Har ke dās siu sākat nahī saṅg.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਨਾਲ ਮਾਇਆ-ਵੇੜ੍ਹੇ ਮਨੁੱਖ ਦਾ ਜੋੜ ਨਹੀਂ ਬਣ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! У почитателя Бога и человека, опутанного майей, не может сложиться связь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8484,
          "is_rahao": true,
          "gurmukhi": "ਓਹੁ ਬਿਖਈ ਓਸੁ ਰਾਮ ਕੋ ਰੰਗੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Oh bikhai os rām ko raṅg. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਸਾਕਤ ਵਿਸ਼ਿਆਂ ਦਾ ਪਿਆਰਾ ਹੁੰਦਾ ਹੈ ਤੇ ਉਸ ਭਗਤ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਪ੍ਰੇਮ-ਰੰਗ ਚੜ੍ਹਿਆ ਹੁੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "ибо тот сакат любит чувственные предметы, а тот бхагат окрашен в цвет любви к Богу. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8485,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਅਸਵਾਰ ਜੈਸੇ ਤੁਰੀ ਸੀਗਾਰੀ ॥",
          "roman": "Man asvār jēse turī sīgārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰੀ ਦੇ ਦਾਸ ਅਤੇ ਸਾਕਤ ਦਾ ਸੰਗ ਇਉਂ ਹੀ ਹੈ) ਜਿਵੇਂ ਕਿਸੇ ਅਨਾੜੀ ਅਸਵਾਰ ਵਾਸਤੇ ਇਕ ਸਜਾਈ ਹੋਈ ਘੋੜੀ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Союз слуги Хари и саката таков же, как если бы для неопытного всадника была наряженная кобылица,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8486,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਕਾਪੁਰਖੁ ਪੁਚਾਰੈ ਨਾਰੀ ॥੧॥",
          "roman": "Jiu kāpurakh puchārey nārī. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਖੁਸਰਾ ਇਸਤ੍ਰੀ ਨੂੰ ਪਿਆਰ ਕਰਦਾ ਹੋਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "как если бы евнух любил женщину. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8487,
          "is_rahao": false,
          "gurmukhi": "ਬੈਲ ਕਉ ਨੇਤ੍ਰਾ ਪਾਇ ਦੁਹਾਵੈ ॥",
          "roman": "Bēl kau netrā pāi duhāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੀ ਦੇ ਦਾਸ ਅਤੇ ਸਾਕਤ ਦਾ ਮੇਲ ਇਉਂ ਹੀ ਹੈ, ਜਿਵੇਂ ਕੋਈ ਮਨੁੱਖ ਨਿਆਣਾ ਪਾ ਕੇ ਬਲਦ ਨੂੰ ਚੋਣ ਲੱਗ ਪਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Союз слуги Хари и саката таков же, как если бы человек, надев упряжь, принялся доить быка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8488,
          "is_rahao": false,
          "gurmukhi": "ਗਊ ਚਰਿ ਸਿੰਘ ਪਾਛੈ ਪਾਵੈ ॥੨॥",
          "roman": "Gaū chari siṅgh pāchhē pāvē. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਮਨੁੱਖ ਗਾਂ ਉਤੇ ਚੜ੍ਹ ਕੇ ਉਸ ਨੂੰ ਸ਼ੇਰ ਦੇ ਪਿੱਛੇ ਦੁੜਾਣ ਲੱਗ ਪਏ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "как если бы кто-то, взобравшись на корову, погнал её за львом. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8489,
          "is_rahao": false,
          "gurmukhi": "ਗਾਡਰ ਲੇ ਕਾਮਧੇਨੁ ਕਰਿ ਪੂਜੀ ॥",
          "roman": "Gāḍar le kāmdhen kar pūjī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੀ ਦੇ ਭਗਤ ਤੇ ਸਾਕਤ ਦਾ ਜੋੜ ਇਉਂ ਹੈ, ਜਿਵੇਂ ਕੋਈ ਮਨੁੱਖ ਭੇਡ ਲੈ ਕੇ ਉਸ ਨੂੰ ਕਾਮਧੇਨ ਮਿਥ ਕੇ ਪੂਜਣ ਲੱਗ ਪਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Связь почитателя Хари и саката такова, как если бы человек взял овцу и, приняв её за Камдхену, стал ей поклоняться,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8490,
          "is_rahao": false,
          "gurmukhi": "ਸਉਦੇ ਕਉ ਧਾਵੈ ਬਿਨੁ ਪੂੰਜੀ ॥੩॥",
          "roman": "Saude kau dhāvē bin pūñjī. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਮਨੁੱਖ ਸਰਮਾਏ ਤੋਂ ਬਿਨਾ ਹੀ ਸੌਦਾ ਖ਼ਰੀਦਣ ਉੱਠ ਦੌੜੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "как если бы человек без всякого капитала бросился покупать товар. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8491,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਮ ਨਾਮੁ ਜਪਿ ਚੀਤ ॥",
          "roman": "Nānak rām nām jap chīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਹਰੀ ਦੇ ਦਾਸਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਟਿਕ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਪਣੇ ਚਿੱਤ ਵਿਚ ਸਿਮਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Пребывая в сангате слуг Хари, помни в своём сердце Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8492,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸੁਆਮੀ ਹਰਿ ਸਾ ਮੀਤ ॥੪॥੯੧॥੧੬੦॥",
          "roman": "Simar suāmī har sā mīt. 4.91.160.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਵਰਗੇ ਮਾਲਕ ਤੇ ਮਿੱਤਰ ਦਾ ਸਿਮਰਨ ਕਰਿਆ ਕਰ ॥੪॥੯੧॥੧੬੦॥"
            },
            "sahib_singh_ru": {
              "main": "вспоминай Бога, такого Владыку и друга. 4.91.160."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 612,
      "rahao_verse_id": 8497,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8493,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Mahallā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8494,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਮਤਿ ਨਿਰਮਲ ਕਹੀਅਤ ਧੀਰ ॥",
          "roman": "Sā mat nirmal kahīat dhīr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਅਕਲ ਪਵਿਤ੍ਰ ਆਖੀ ਜਾਂਦੀ ਹੈ ਧੀਰਜ ਵਾਲੀ ਆਖੀ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Чистым и исполненным стойкости называется тот разум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8495,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣੁ ਪੀਵਤ ਬੀਰ ॥੧॥",
          "roman": "Rām rasāiṇ pīvat bīr. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦਾ ਆਸਰਾ ਲੈ ਕੇ ਮਨੁੱਖ) ਸਭ ਰਸਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਪ੍ਰਭੂ-ਨਾਮ ਦਾ ਰਸ ਪੀਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "опираясь на который человек пьёт нектар Имени Господа, превосходящий все прочие вкусы. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8496,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੇ ਚਰਣ ਹਿਰਦੈ ਕਰਿ ਓਟ ॥",
          "roman": "Har ke charaṇ hirdē kar oṭ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦਾ ਆਸਰਾ ਬਣਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Сделай в своём сердце опорой стопы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8497,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਤੇ ਹੋਵਤ ਛੋਟ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Janam maraṇ te hovat chhoṭ. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਉਂ ਕੀਤਿਆਂ) ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਤੋਂ ਖ਼ਲਾਸੀ ਹੋ ਜਾਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и тогда приходит освобождение от круга рождения и смерти. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8498,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਤਨੁ ਨਿਰਮਲੁ ਜਿਤੁ ਉਪਜੈ ਨ ਪਾਪੁ ॥",
          "roman": "So tn nirmal jit upjē na pāp.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਸਰੀਰ ਪਵਿਤ੍ਰ ਹੈ ਜਿਸ ਵਿਚ ਕੋਈ ਪਾਪ ਨਹੀਂ ਪੈਦਾ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Чисто то тело, в котором не возникает никакой грех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8499,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰੰਗਿ ਨਿਰਮਲ ਪਰਤਾਪੁ ॥੨॥",
          "roman": "Rām raṅg nirmal partāp. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਦੀ ਬਰਕਤਿ ਨਾਲ ਪਵਿਤ੍ਰ ਹੋਏ ਮਨੁੱਖ ਦਾ ਤੇਜ-ਪਰਤਾਪ (ਚਮਕਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По благодати окрашенности в любовь к Богу сияет величие и свет человека, ставшего чистым. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8500,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਿਟਿ ਜਾਤ ਬਿਕਾਰ ॥",
          "roman": "Sādhasaṅg miṭ jāt bikār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਾਧ ਸੰਗਤਿ ਕਰਿਆ ਕਰ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ (ਅੰਦਰੋਂ) ਸਾਰੇ ਵਿਕਾਰ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пребывая в святом сангате, человек избавляется внутри от всех пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8501,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਏਹੋ ਉਪਕਾਰ ॥੩॥",
          "roman": "Sabh te ūch eho upkār. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਦਾ) ਸਭ ਤੋਂ ਉੱਚਾ ਇਹੀ ਉਪਕਾਰ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Вот высшее благодеяние святого сангата. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8502,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਰਾਤੇ ਗੋਪਾਲ ॥",
          "roman": "Prem bhagat rāte Gopāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਪ੍ਰੇਮ-ਭਗਤੀ ਦੇ ਰੰਗ ਵਿਚ ਰੰਗੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, что окрашены в цвет любовной бхакти к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8503,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾਚੈ ਸਾਧ ਰਵਾਲ ॥੪॥੯੨॥੧੬੧॥",
          "roman": "Nānak jāchē sādh ravāl. 4.92.161.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਉਹਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹੈ ॥੪॥੯੨॥੧੬੧॥"
            },
            "sahib_singh_ru": {
              "main": "их пыль со стоп просит Нанак. 4.92.161."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 613,
      "rahao_verse_id": 8506,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8504,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Mahallā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8505,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਪ੍ਰੀਤਿ ਗੋਵਿੰਦ ਸਿਉ ਲਾਗੀ ॥",
          "roman": "Aisī prīt Govind siu lāgī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਨਾਲ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੀ ਇਹੋ ਜਿਹੀ ਪ੍ਰੀਤਿ (ਜਿਸ ਦਾ ਜ਼ਿਕਰ ਇਥੇ ਕੀਤਾ ਜਾ ਰਿਹਾ ਹੈ) ਬਣਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Те люди, у которых с Богом возникает такая любовь, о которой здесь говорится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8506,
          "is_rahao": true,
          "gurmukhi": "ਮੇਲਿ ਲਏ ਪੂਰਨ ਵਡਭਾਗੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Mel lae pūran vaḍbhāgī. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਹ ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ ਭਰਪੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਪਰਮਾਤਮਾ ਉਹਨਾਂ ਨੂੰ ਆਪਣੇ ਨਾਲ ਮਿਲਾ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "становятся очень счастливыми по судьбе, наполняются всеми добродетелями, и Бог соединяет их с Собой. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8507,
          "is_rahao": false,
          "gurmukhi": "ਭਰਤਾ ਪੇਖਿ ਬਿਗਸੈ ਜਿਉ ਨਾਰੀ ॥",
          "roman": "Bhartā pekh bigsē jiu nārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਇਸਤ੍ਰੀ ਆਪਣੇ ਪਤੀ ਨੂੰ ਵੇਖ ਕੇ ਖ਼ੁਸ਼ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как женщина радуется, увидев своего мужа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8508,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨੁ ਜੀਵੈ ਨਾਮੁ ਚਿਤਾਰੀ ॥੧॥",
          "roman": "Tiu har jan jīvē nām chitārī. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਹਰੀ ਦਾ ਦਾਸ ਹਰੀ ਦਾ ਨਾਮ ਚੇਤੇ ਕਰ ਕੇ ਅੰਤਰ ਆਤਮੇ ਹੁਲਾਰੇ ਵਿਚ ਆਉਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так и слуга Хари, вспоминая Имя Хари, внутренне приходит в восторг. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8509,
          "is_rahao": false,
          "gurmukhi": "ਪੂਤ ਪੇਖਿ ਜਿਉ ਜੀਵਤ ਮਾਤਾ ॥",
          "roman": "Pūt pekh jiu jīvat mātā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਾਂ ਆਪਣੇ ਪੁੱਤਰਾਂ ਨੂੰ ਵੇਖ ਵੇਖ ਕੇ ਜੀਊਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как мать живёт, снова и снова глядя на своих сыновей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8510,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਜਨੁ ਹਰਿ ਸਿਉ ਰਾਤਾ ॥੨॥",
          "roman": "Ot pot jan har siu rātā. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦਾ ਭਗਤ ਪਰਮਾਤਮਾ ਨਾਲ ਤਾਣੇ ਪੇਟੇ ਦੇ ਸੂਤਰ ਵਾਂਗ ਰੱਤਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так и бхагат Бога пронизан Богом, словно нити основы и утка. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8511,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭੀ ਅਨਦੁ ਕਰੈ ਪੇਖਿ ਧਨਾ ॥",
          "roman": "Lobhī anad karē pekh dhanā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ, ਹੇ ਭਾਈ!) ਲਾਲਚੀ ਮਨੁੱਖ ਧਨ ਵੇਖ ਕੇ ਖ਼ੁਸ਼ੀ ਮਨਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как, о брат, жадный человек радуется, увидев богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8512,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੋ ਮਨਾ ॥੩॥",
          "roman": "Jan charaṇ kamal siu lāgo manā. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ ਲਪਟਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так и ум почитателя Бога прилеплен к прекрасным стопам Бога. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8513,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸਰੁ ਨਹੀ ਇਕੁ ਤਿਲੁ ਦਾਤਾਰ ॥",
          "roman": "Bisar nahī ik til dātār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਤਾਰ! ਇਕ ਰਤਾ ਜਿਤਨਾ ਸਮਾ ਭੀ ਨਾਹ ਭੁੱਲ।"
            },
            "sahib_singh_ru": {
              "main": "О Даятель! Не забывай меня даже на мгновение размером в кунжутное зёрнышко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8514,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੇ ਪ੍ਰਭ ਪ੍ਰਾਨ ਅਧਾਰ ॥੪॥੯੩॥੧੬੨॥",
          "roman": "Nānak ke prabh prān adhār. 4.93.162.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ ਦੇ ਪ੍ਰਾਣਾਂ ਦੇ ਆਸਰੇ ਪ੍ਰਭੂ! (ਤੂੰ ਮੈਨੂੰ ਨਾਹ ਭੁੱਲੇਂ)! ॥੪॥੯੩॥੧੬੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Бог, опора жизни Нанака, не забывай меня. 4.93.162."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 614,
      "rahao_verse_id": 8517,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8515,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Mahallā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8516,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣਿ ਜੋ ਜਨ ਗੀਧੇ ॥",
          "roman": "Rām rasāiṇ jo jan gīdhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜੇ ਮਨੁੱਖ ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਹਰਿ-ਨਾਮ-ਰਸ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Те люди, которые опьянены высшим нектаром Имени Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8517,
          "is_rahao": true,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਪ੍ਰੇਮ ਭਗਤੀ ਬੀਧੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Charaṇ kamal prem bhagtī bīdhē. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਸੁਹਣੇ ਚਰਨਾਂ ਦੀ ਪ੍ਰੇਮ-ਭਗਤੀ ਵਿੱਚ ਵਿੱਝੇ ਰਹਿੰਦੇ ਹਨ (ਜਿਵੇਂ ਭੌਰਾ ਫੁੱਲ ਵਿਚ ਵਿੱਝ ਜਾਂਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "пронзены любовной бхакти к прекрасным стопам Бога, как пчела вонзается в цветок. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8518,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਰਸਾ ਦੀਸਹਿ ਸਭਿ ਛਾਰੁ ॥",
          "roman": "Ān rasā dīsah sabh chhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਦੁਨੀਆ ਦੇ) ਹੋਰ ਸਾਰੇ ਰਸ (ਪ੍ਰਭੂ-ਨਾਮ-ਰਸ ਦੇ ਟਾਕਰੇ ਤੇ) ਸੁਆਹ ਦਿੱਸਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всем таким людям все прочие мирские вкусы по сравнению с нектаром Имени кажутся пеплом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8519,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਨਿਹਫਲ ਸੰਸਾਰ ॥੧॥",
          "roman": "Nām binā nihphal sansār. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਸੰਸਾਰ ਦੇ ਸਾਰੇ ਪਦਾਰਥ ਉਹਨਾਂ ਨੂੰ ਵਿਅਰਥ ਜਾਪਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и без Имени Бога все предметы мира кажутся им напрасными. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8520,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਕੂਪ ਤੇ ਕਾਢੇ ਆਪਿ ॥",
          "roman": "Andh kūp te kāḍhe āp.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹਨਾਂ ਨੂੰ ਪਰਮਾਤਮਾ) ਆਪ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਅੰਨ੍ਹੇ ਖੂਹ ਵਿਚੋਂ ਕੱਢ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Сам Бог выводит их из слепого колодца привязанности к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8521,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗੋਵਿੰਦ ਅਚਰਜ ਪਰਤਾਪ ॥੨॥",
          "roman": "Guṇ Govind acharaj partāp. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ) ਗੋਬਿੰਦ ਦੇ ਗੁਣ ਅਸਚਰਜ ਪਰਤਾਪ ਵਾਲੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ибо качества Говинда исполнены удивительной силы и славы. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8522,
          "is_rahao": false,
          "gurmukhi": "ਵਣਿ ਤ੍ਰਿਣਿ ਤ੍ਰਿਭਵਣਿ ਪੂਰਨ ਗੋਪਾਲ ॥",
          "roman": "Vaṇ triṇ tribhavaṇ pūran Gopāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਹਰਿ-ਨਾਮ-ਰਸ ਵਿਚ ਮਸਤ ਬੰਦਿਆਂ ਨੂੰ) ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਵਣ ਵਿਚ ਤ੍ਰਿਣ ਵਿਚ ਤਿੰਨ-ਭਵਨੀ ਸੰਸਾਰ ਵਿਚ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Людям, опьянённым нектаром Имени, Хранитель мира видится присутствующим в лесу, в травинке и во всём трёхмирии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8523,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਪਸਾਰੁ ਜੀਅ ਸੰਗਿ ਦਇਆਲ ॥੩॥",
          "roman": "Brahm pasār jīa saṅg dayāl. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਇਹ ਸਾਰਾ ਜਗਤ ਪਰਮਾਤਮਾ ਦਾ ਖਿਲਾਰਾ ਦਿੱਸਦਾ ਹੈ, ਪਰਮਾਤਮਾ ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਗ-ਸੰਗ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ, ਤੇ ਦਇਆ ਦਾ ਘਰ ਦਿੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "весь этот мир видится им развертыванием Бога, Бог ощущается рядом со всеми живыми существами и предстает домом милости. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8524,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਾ ਕਥਨੀ ਸਾਰੁ ॥",
          "roman": "Kah Nānak sā kathnī sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਭਾਈ! ਤੂੰ ਭੀ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਉਹ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੰਭਾਲ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о брат! Храни в своём сердце такую хвалу Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8525,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨਿ ਲੇਤੁ ਜਿਸੁ ਸਿਰਜਨਹਾਰੁ ॥੪॥੯੪॥੧੬੩॥",
          "roman": "Mān let jis sirjanhār. 4.94.163.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਸਿਫ਼ਤ-ਸਾਲਾਹ-ਰੂਪ ਕਥਨੀ) ਨੂੰ ਸਿਰਜਣਹਾਰ ਪ੍ਰਭੂ ਆਦਰ-ਸਤਕਾਰ ਦੇਂਦਾ ਹੈ ॥੪॥੯੪॥੧੬੩॥"
            },
            "sahib_singh_ru": {
              "main": "которой Сам Творец оказывает честь и почёт. 4.94.163."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
