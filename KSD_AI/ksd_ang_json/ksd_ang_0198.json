          "verse_id": 8526,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Mahallā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8527,
          "is_rahao": true,
          "gurmukhi": "ਨਿਤਪ੍ਰਤਿ ਨਾਵਣੁ ਰਾਮ ਸਰਿ ਕੀਜੈ ॥",
          "roman": "Nitprat nāvaṇ rām sar kījē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਸਰ ਵਿਚ ਸਦਾ ਹੀ ਇਸ਼ਨਾਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Следует постоянно омываться в озере Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8528,
          "is_rahao": true,
          "gurmukhi": "ਝੋਲਿ ਮਹਾ ਰਸੁ ਹਰਿ ਅੰਮ੍ਰਿਤੁ ਪੀਜੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Jhol mahā ras har amrit pījē. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਰਸ) ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਰਸ ਹੈ, ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਇਸ ਹਰਿ-ਨਾਮ-ਰਸ ਨੂੰ ਬੜੇ ਪ੍ਰੇਮ ਨਾਲ ਪੀਣਾ ਚਾਹੀਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот нектар Имени Бога есть высочайший вкус, и его, дающего духовную жизнь, нужно пить с великой любовью. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8529,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਉਦਕੁ ਗੋਵਿੰਦ ਕਾ ਨਾਮ ॥",
          "roman": "Nirmal udak Govind kā nām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪਵਿਤ੍ਰ ਜਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — это чистая вода,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8530,
          "is_rahao": false,
          "gurmukhi": "ਮਜਨੁ ਕਰਤ ਪੂਰਨ ਸਭਿ ਕਾਮ ॥੧॥",
          "roman": "Majan karat pūran sabh kām. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਜਲ ਵਿਚ) ਇਸ਼ਨਾਨ ਕਰਦਿਆਂ ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਹੋ ਜਾਂਦੇ ਹਨ (ਸਭ ਵਾਸ਼ਨਾਂ ਮੁੱਕ ਜਾਂਦੀਆਂ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и при омовении в этой воде исполняются все желания, все стремления исчезают. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
