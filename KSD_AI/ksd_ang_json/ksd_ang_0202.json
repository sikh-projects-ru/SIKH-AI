{
  "ang": 202,
  "shabads": [
    {
      "shabad_id": 630,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8692,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਪਰਮ ਪਦੁ ਪਾਇਆ ॥੨॥",
          "roman": "sant prasād param pad pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਸੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਮਿਲ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а по милости Гуру-Санта обретается высочайшее духовное состояние ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8693,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੀ ਕੀਨੀ ਆਪਿ ਸਹਾਇ ॥",
          "roman": "jan kī kīnī āp sahāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਜਿਸ ਮਨੁੱਖ ਦੀ ਸਹਾਇਤਾ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, тому человеку, которому Сам Бог оказал помощь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8694,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਪਾਇਆ ਲਗਿ ਦਾਸਹ ਪਾਇ ॥",
          "roman": "sukh pāiā lag dāsah pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਦੀ ਚਰਨੀਂ ਲੱਗ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "удалось вкусить духовную радость, припав к стопам преданных Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8695,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਗਇਆ ਤਾ ਆਪਹਿ ਭਏ ॥",
          "roman": "āp gaiā tā āpah bhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ (ਜਦੋਂ) ਆਪਾ-ਭਾਵ ਦੂਰ ਹੋ ਗਿਆ ਤਦੋਂ ਉਹ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੀ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Когда изнутри у них ушло эго, тогда они сами стали образом Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8696,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਕੀ ਸਰਨੀ ਪਏ ॥੩॥",
          "roman": "kripā nidhān kī sarnī paē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਦਇਆ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਆ ਪਏ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "те люди, которые пришли в прибежище Бога, сокровищницы милости ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8697,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਚਾਹਤ ਸੋਈ ਜਬ ਪਾਇਆ ॥",
          "roman": "jo chāhat soī jab pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਦੋਂ ਕਿਸੇ ਮਨੁੱਖ ਨੂੰ (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਮਿਲ ਪੈਂਦਾ ਹੈ ਜਿਸ ਨੂੰ ਉਹ ਮਿਲਣਾ ਚਾਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, когда человек по милости Гуру обретает того самого Бога, встречу с Которым он желал,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8698,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਢੂੰਢਨ ਕਹਾ ਕੋ ਜਾਇਆ ॥",
          "roman": "tab ḍhūnḍhan kahā kō jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਹ (ਬਾਹਰ ਜੰਗਲਾਂ ਪਹਾੜਾਂ ਆਦਿਕ ਵਿਚ ਉਸ ਨੂੰ) ਲੱਭਣ ਲਈ ਨਹੀਂ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "тогда он уже не идёт искать Его вовне, в лесах, горах и прочих местах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8699,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਰ ਭਏ ਬਸੇ ਸੁਖ ਆਸਨ ॥",
          "roman": "asthir bhaē basē sukh āsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ ਅੰਦਰ ਹੀ ਲੱਭ ਲੈਣ ਵਾਲੇ ਮਨੁੱਖ) ਅਡੋਲ-ਚਿੱਤ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਹ ਸਦਾ ਆਨੰਦ ਅਵਸਥਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто нашли Бога внутри себя, становятся устойчивыми сердцем и всегда пребывают в состоянии блаженства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8700,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਸੁਖ ਬਾਸਨ ॥੪॥੧੧੦॥",
          "roman": "gur prasād Nānak sukh bāsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਹ ਸਦਾ ਸੁਖਾਂ ਵਿਚ ਵੱਸਣ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ ॥੪॥੧੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, по милости Гуру они навсегда становятся живущими в счастье ॥4॥110॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 631,
      "rahao_verse_id": 8706,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8701,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahelā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8702,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮਜਨ ਕੀਨੋ ਇਸਨਾਨ ॥",
          "roman": "koṭ majan kīno isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਨੇ (ਮਾਨੋ) ਕ੍ਰੋੜਾਂ ਤੀਰਥਾਂ ਵਿਚ ਚੁੱਭੀਆਂ ਲਾ ਲਈਆਂ, ਕ੍ਰੋੜਾਂ ਤੀਰਥਾਂ ਦੇ ਇਸ਼ਨਾਨ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Он словно совершил омовения в крорах тиртх, словно искупался в крорах тиртх,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8703,
          "is_rahao": false,
          "gurmukhi": "ਲਾਖ ਅਰਬ ਖਰਬ ਦੀਨੋ ਦਾਨੁ ॥",
          "roman": "lākh arab kharab dīno dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ (ਮਾਨੋ) ਲੱਖਾਂ ਰੁਪਏ ਅਰਬਾਂ ਰੁਪਏ ਖਰਬਾਂ ਰੁਪਏ ਦਾਨ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "он словно раздал в дар сотни тысяч, миллиарды и триллионы рупий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8704,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਮਨਿ ਵਸਿਓ ਹਰਿ ਕੋ ਨਾਮੁ ॥੧॥",
          "roman": "jā man vasio har ko nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если в сердце человека поселяется Имя Всевышнего. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8705,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲ ਪਵਿਤ ਗੁਨ ਗਾਇ ਗੁਪਾਲ ॥",
          "roman": "sagal pavit gun gāi gupāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ਕੇ ਸਾਰੇ ਮਨੁੱਖ ਪਵਿਤ੍ਰ ਹੋ ਸਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Воспевая качества Господа, Питателя мироздания, все люди могут стать чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8706,
          "is_rahao": true,
          "gurmukhi": "ਪਾਪ ਮਿਟਹਿ ਸਾਧੂ ਸਰਨਿ ਦਇਆਲ ॥ ਰਹਾਉ ॥",
          "roman": "pāp miṭeh sādhū saran dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦੇ ਸੋਮੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ (ਸਾਰੇ) ਪਾਪ ਮਿਟ ਜਾਂਦੇ ਹਨ ॥ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда приходят в прибежище Гуру, источника милости, все грехи исчезают. ॥Рахау॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8707,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਉਰਧ ਤਪ ਸਾਧਨ ਸਾਧੇ ॥",
          "roman": "bahut uraḍh tap sādhan sādhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਨੇ (ਮਾਨੋ) ਪੁੱਠੇ ਲਟਕ ਕੇ ਅਨੇਕਾਂ ਤਪਾਂ ਦੇ ਸਾਧਨ ਸਾਧ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Он словно, повиснув вниз головой, совершил многочисленные аскетические подвиги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8708,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਲਾਭ ਮਨੋਰਥ ਲਾਧੇ ॥",
          "roman": "anik lābh manorath lādhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ (ਮਾਨੋ, ਰਿੱਧੀਆਂ ਸਿੱਧੀਆਂ ਦੇ) ਅਨੇਕਾਂ ਲਾਭ ਖੱਟ ਲਏ, ਅਨੇਕਾਂ ਮਨੋਰਥ ਹਾਸਲ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "он словно обрёл многие выгоды, многие желаемые достижения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8709,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮ ਰਸਨ ਆਰਾਧੇ ॥੨॥",
          "roman": "har har nām rasan ārādhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੀ ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "если человек своим языком повторяет Имя Всевышнего. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8710,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਮ੍ਰਿਤਿ ਸਾਸਤ ਬੇਦ ਬਖਾਨੇ ॥",
          "roman": "siṃmrit sāsat bēd bakhāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਨੇ (ਮਾਨੋ) ਸਿਮ੍ਰਿਤੀਆਂ ਸ਼ਾਸਤ੍ਰਾਂ ਵੇਦਾਂ ਦੇ ਉਚਾਰਨ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Он словно произнёс Смрити, шастры и Веды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8711,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗ ਗਿਆਨ ਸਿਧ ਸੁਖ ਜਾਨੇ ॥",
          "roman": "jog giān sidh sukh jāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ (ਮਾਨੋ) ਜੋਗ (ਦੀਆਂ ਗੁੰਝਲਾਂ) ਦੀ ਸੂਝ ਪ੍ਰਾਪਤ ਕਰ ਲਈ, ਉਸ ਨੇ (ਮਾਨੋ) ਸਿੱਧਾਂ ਨੂੰ ਮਿਲੇ ਸੁਖਾਂ ਨਾਲ ਸਾਂਝ ਪਾ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "он словно постиг тонкости йоги, словно приобщился к тем блаженствам, которые обрели сиддхи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8712,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਪ੍ਰਭ ਸਿਉ ਮਨ ਮਾਨੇ ॥੩॥",
          "roman": "nām japat prabh siu man māne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਸਿਮਰਦਿਆਂ ਪਰਮਾਤਮਾ ਨਾਲ ਗਿੱਝ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если ум человека, повторяя Имя Всевышнего, сживается со Всевышним. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8713,
          "is_rahao": false,
          "gurmukhi": "ਅਗਾਧਿ ਬੋਧਿ ਹਰਿ ਅਗਮ ਅਪਾਰੇ ॥",
          "roman": "agādh bodh har agam apāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਕਿਰਪਾ ਕਰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ) ਉਸ ਅਥਾਹ ਹਸਤੀ ਵਾਲੇ ਅਪਹੁੰਚ ਤੇ ਬੇਅੰਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, на кого Господь проливает милость, повторяет Имя того бездонного, непостижимого и беспредельного Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8714,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਨਾਮੁ ਰਿਦੇ ਬੀਚਾਰੇ ॥",
          "roman": "nām japat nām ridē bīchāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и утверждает Его Имя в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8715,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਕਿਰਪਾ ਧਾਰੇ ॥੪॥੧੧੧॥",
          "roman": "nānak kau prabh kirpā dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਨਾਨਕ! ਤੂੰ ਭੀ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਨਾਨਕ ਉਤੇ ਕਿਰਪਾ ਕਰ (ਤਾ ਕਿ ਮੈਂ ਤੇਰਾ ਨਾਮ ਜਪ ਸਕਾਂ) ॥੪॥੧੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, и ты тоже молись и говори: О Господь, пролей милость на меня, Нанака, чтобы я мог повторять Твоё Имя. ॥4॥111॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 632,
      "rahao_verse_id": 8720,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8716,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਃ ੫ ॥",
          "roman": "gauṛī m 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8717,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "simar simar simar sukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੋਬਿੰਦ ਦਾ ਆਰਾਧਨ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਹੀ ਮਿਲਦਾ ਹੈ।) ਉਸ ਨੇ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Почитание Гобинда обретается только через Гуру. Тот, кто снова и снова вспоминал Имя Гобинда, вкусил духовное блаженство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8718,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰ ਰਿਦੈ ਬਸਾਇਆ ॥੧॥",
          "roman": "charan kamal gur ridē basāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੇ) ਗੁਰੂ ਦੇ ਸੋਹਣੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਏ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот, кто поселил в своём сердце прекрасные стопы Гуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8719,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਗੋਬਿੰਦੁ ਪਾਰਬ੍ਰਹਮੁ ਪੂਰਾ ॥",
          "roman": "gur gobind pārbrahm pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੋਬਿੰਦ ਪਾਰਬ੍ਰਹਮ (ਸਭ ਹਸਤੀਆਂ ਨਾਲੋਂ) ਵੱਡਾ ਹੈ, ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਮਾਲਕ ਹੈ (ਉਸ ਵਿਚ ਕੋਈ ਕਿਸੇ ਕਿਸਮ ਦੀ ਘਾਟ ਨਹੀਂ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гобинд, Парабрахм, выше всех существ и является обладателем всех достоинств, в Нём нет никакого недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8720,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸਹਿ ਅਰਾਧਿ ਮੇਰਾ ਮਨੁ ਧੀਰਾ ॥ ਰਹਾਉ ॥",
          "roman": "tiseh arādh merā man dhīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੋਬਿੰਦ ਨੂੰ ਆਰਾਧ ਕੇ ਮੇਰਾ ਮਨ ਹੌਸਲੇ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ (ਤੇ ਅਨੇਕਾਂ ਕਿਲਬਿਖਾਂ ਦਾ ਟਾਕਰਾ ਕਰਨ ਜੋਗਾ ਹੋ ਜਾਂਦਾ ਹੈ)।ਰਹਾਉ।"
            },
            "sahib_singh_ru": {
              "main": "Почитая этого Гобинда, мой ум становится стойким и способным противостоять множеству грехов. ॥Рахау॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8721,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਜਪਉ ਗੁਰੂ ਗੁਰ ਨਾਮ ॥",
          "roman": "an-din japau gurū gur nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ ਤਾਂ ਹਰ ਵੇਲੇ ਗੁਰੂ ਦਾ ਨਾਮ ਚੇਤੇ ਰੱਖਦਾ ਹਾਂ (ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਹੀ ਗੋਬਿੰਦ ਦਾ ਸਿਮਰਨ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ, ਤੇ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я во всякое время держу в памяти Имя Гуру, ведь только по милости Гуру обретается памятование о Гобинде, и"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8722,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇ ਸਿਧਿ ਭਏ ਸਗਲ ਕਾਂਮ ॥੨॥",
          "roman": "tā te sidh bhae sagal kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਸਾਰੇ ਕੰਮਾਂ ਵਿਚ ਸਫਲਤਾ ਹਾਸਲ ਹੁੰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "по благодати этого памятования приходит успех во всех делах. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8723,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨ ਦੇਖਿ ਸੀਤਲ ਮਨ ਭਏ ॥",
          "roman": "darsan dēkh sītal man bhae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਹਰ ਥਾਂ ਪਰਮਾਤਮਾ ਦਾ) ਦਰਸਨ ਕਰ ਕੇ (ਦਰਸਨ ਕਰਨ ਵਾਲੇ) ਠੰਢੇ ਠਾਰ ਮਨ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через Гуру, увидев везде даршан Всевышнего, люди становятся обладателями прохладного, умиротворённого ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8724,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਬਿਖ ਗਏ ॥੩॥",
          "roman": "janam janam kē kilbikh gae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹਨਾਂ ਦੇ ਅਨੇਕਾਂ (ਪਹਿਲੇ) ਜਨਮਾਂ ਦੇ ਕੀਤੇ ਹੋਏ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и совершённые ими грехи многих прежних рождений уничтожаются. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8725,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਕਹਾ ਭੈ ਭਾਈ ॥",
          "roman": "kah nānak kahā bhē bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਦੁਨੀਆ ਵਾਲੇ) ਸਾਰੇ ਡਰ-ਖ਼ਤਰੇ ਮਨ ਤੋਂ ਲਹਿ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: О брат! Когда, придя в прибежище Гуру, вспоминают Имя Гобинда, все страхи и опасности мира уходят из ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8726,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕੀ ਆਪਿ ਪੈਜ ਰਖਾਈ ॥੪॥੧੧੨॥",
          "roman": "apne sēvak kī āp pēj rakhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਇਹ ਯਕੀਨ ਬਣ ਜਾਂਦਾ ਹੈ ਕਿ (ਗੋਬਿੰਦ ਆਪਣੇ ਸੇਵਕ ਦੀ ਆਪ ਲਾਜ ਰੱਖਦਾ ਹੈ ॥੪॥੧੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "потому что по благодати этого памятования приходит уверенность, что Гобинд Сам хранит честь Своего слуги. ॥4॥112॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 633,
      "rahao_verse_id": 8731,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8727,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahelā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8728,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕਉ ਆਪਿ ਸਹਾਈ ॥",
          "roman": "apne sēvak kau āp sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਆਪਣੇ ਸੇਵਕ ਦੇ ਵਾਸਤੇ (ਸਦਾ) ਮਦਦਗਾਰ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всевышний Сам всегда остаётся помощником Своему слуге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8729,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਪ੍ਰਤਿਪਾਰੈ ਬਾਪ ਜੈਸੇ ਮਾਈ ॥੧॥",
          "roman": "nit pratipārē bāp jēsē māī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ (ਆਪਣੇ ਸੇਵਕ ਦੀ) ਸੰਭਾਲ ਕਰਦਾ ਹੈ ਜਿਵੇਂ ਮਾਂ ਤੇ ਪਿਉ (ਆਪਣੇ ਬੱਚੇ ਦੀ ਸੰਭਾਲ ਕਰਦੇ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "всегда заботится о Своём слуге, как мать и отец заботятся о своём ребёнке. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8730,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਸਰਨਿ ਉਬਰੈ ਸਭ ਕੋਇ ॥",
          "roman": "prabh kī saran ubrē sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਰੇਕ ਮਨੁੱਖ (ਜੇਹੜਾ) ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਵਿਚ (ਆਉਂਦਾ ਹੈ, ਸਾਰੇ ਵਿਕਾਰਾਂ ਡਰਾਂ-ਸਹਿਮਾਂ ਤੋਂ) ਬਚ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каждый человек, который приходит в прибежище Всевышнего, спасается от всех пороков, страхов и тревог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8731,
          "is_rahao": true,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਪੂਰਨ ਸਚੁ ਸੋਇ ॥ ਰਹਾਉ ॥",
          "roman": "karan karāvan pūran sach soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਨਿਸਚਾ ਬਣ ਜਾਂਦਾ ਹੈ ਕਿ ਉਹ ਸਰਬ-ਵਿਆਪਕ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਰੱਖਦਾ ਹੈ ਤੇ ਜੀਵਾਂ ਪਾਸੋਂ ਸਭ ਕੁਝ ਕਰਾਣ ਵਾਲਾ ਹੈ।ਰਹਾਉ।"
            },
            "sahib_singh_ru": {
              "main": "и у него утверждается уверенность, что этот всепроникающий, вечно сущий Всевышний способен совершить всё и побуждает живых существ ко всякому действию. ॥Рахау॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8732,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਮਨਿ ਬਸਿਆ ਕਰਨੈਹਾਰਾ ॥",
          "roman": "ab man basiā karṇēhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਰੱਖਣ ਵਾਲਾ ਪਰਮਾਤਮਾ (ਮੇਰੇ) ਮਨ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всевышний, способный совершить всё, теперь поселился в моём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8733,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਬਿਨਸੇ ਆਤਮ ਸੁਖ ਸਾਰਾ ॥੨॥",
          "roman": "bhē binsē ātam sukh sārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਸਾਰੇ ਡਰ-ਖ਼ਤਰੇ ਨਾਸ ਹੋ ਗਏ ਹਨ ਤੇ ਮੈਂ ਆਤਮਕ ਆਨੰਦ ਮਾਣ ਰਿਹਾ ਹਾਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "теперь все мои страхи и опасности исчезли, и я наслаждаюсь духовным блаженством. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8734,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪਨੇ ਜਨ ਰਾਖੇ ॥",
          "roman": "kar kirpā apne jan rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਕਿਰਪਾ ਕਰ ਕੇ ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਆਪ ਰੱਖਿਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всевышний по милости Сам оберегает Своих слуг,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8735,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਬਿਖ ਲਾਥੇ ॥੩॥",
          "roman": "janam janam kē kilbikh lāthē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ (ਪਹਿਲੇ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ (ਕੀਤੇ) ਪਾਪਾਂ ਦੇ ਸੰਸਕਾਰ (ਉਹਨਾਂ ਦੇ ਮਨ ਤੋਂ) ਲਹਿ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и следы грехов, совершённых во многих прежних рождениях, уходят из их ума. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8736,
          "is_rahao": false,
          "gurmukhi": "ਕਹਨੁ ਨ ਜਾਇ ਪ੍ਰਭ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "kahan na jāi prabh kī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਕੇਡੀ ਵੱਡੀ ਸਮਰੱਥਾ ਵਾਲਾ ਹੈ-ਇਹ ਗੱਲ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Невозможно выразить, сколь велика сила Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8737,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਦਾ ਸਰਨਾਈ ॥੪॥੧੧੩॥",
          "roman": "nānak dās sadā saranāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਦੇ ਸੇਵਕ ਸਦਾ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ ॥੪॥੧੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Слуги Всевышнего всегда пребывают в Его прибежище. ॥4॥113॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 634,
      "rahao_verse_id": 8741,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8738,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਗਉੜੀ ਚੇਤੀ ਮਹਲਾ ੫ ਦੁਪਦੇ",
          "roman": "rāg gauṛī chetī mahelā 5 dupadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਗਉੜੀ-ਚੇਤੀ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਦੋ-ਪਦਿਆਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В раге Гаури-Чети — бани Гуру Арджандева Джи, состоящая из двустиший."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8739,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oaṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8740,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਕੋ ਬਲੁ ਪੂਰਨ ਭਾਈ ॥",
          "roman": "rām ko bal pūran bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੀ ਤਾਕਤ ਹਰ ਥਾਂ (ਆਪਣਾ ਪ੍ਰਭਾਵ ਪਾ ਰਹੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Сила Всевышнего действует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8741,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਤੇ ਬ੍ਰਿਥਾ ਨ ਬਿਆਪੈ ਕਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā te brithā na biāpē kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ ਜਿਸ ਸੇਵਕ ਦੇ ਸਿਰ ਉਤੇ ਪਰਮਾਤਮਾ ਆਪਣਾ ਮਿਹਰ ਦਾ ਹੱਥ ਰੱਖਦਾ ਹੈ) ਉਸ ਤਾਕਤ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਉਸ ਸੇਵਕ ਉੱਤੇ) ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому того слугу, над чьей головой Всевышний держит Свою руку милости, по благодати этой силы не может одолеть никакое страдание и бедствие. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8742,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਚਿਤਵੈ ਦਾਸੁ ਹਰਿ ਮਾਈ ॥",
          "roman": "jo jo chitvē dās har māī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੀ) ਮਾਂ! ਪਰਮਾਤਮਾ ਦਾ ਸੇਵਕ ਜੇਹੜੀ ਜੇਹੜੀ ਮੰਗ ਆਪਣੇ ਮਨ ਵਿਚ ਚਿਤਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О моя мать! О чём бы ни помышлял в своём сердце слуга Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8743,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੋ ਕਰਤਾ ਆਪਿ ਕਰਾਈ ॥੧॥",
          "roman": "so so kartā āp karāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਆਪ ਉਸ ਦੀ ਉਹ ਮੰਗ ਪੂਰੀ ਕਰ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Творец Сам исполняет это его желание. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8744,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕੀ ਪ੍ਰਭਿ ਪਤਿ ਗਵਾਈ ॥",
          "roman": "nindak kī prabh pat gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕ ਦੇ) ਦੋਖੀ-ਨਿੰਦਕ ਦੀ ਇੱਜ਼ਤ ਪ੍ਰਭੂ ਨੇ ਲੋਕ-ਪਰਲੋਕ ਵਿਚ ਆਪ ਗਵਾ ਦਿੱਤੀ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Честь порицающего клеветника слуги Господь Сам лишил и в этом мире, и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8745,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਗੁਣ ਨਿਰਭਉ ਗਾਈ ॥੨॥੧੧੪॥",
          "roman": "nānak har gun nirbhau gāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪਰਮਾਤਮਾ ਦਾ ਸੇਵਕ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ (ਤੇ ਦੁਨੀਆ ਦੇ ਡਰਾਂ ਵਲੋਂ) ਨਿਡਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥੧੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Слуга Всевышнего продолжает петь качества Всевышнего и становится бесстрашным перед страхами мира. ॥2॥114॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
