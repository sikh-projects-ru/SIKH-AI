{
  "ang": 268,
  "shabads": [
    {
      "shabad_id": 905,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11823,
          "is_rahao": false,
          "gurmukhi": "ਇਆਹੂ ਜੁਗਤਿ ਬਿਹਾਨੇ ਕਈ ਜਨਮ ॥",
          "roman": "iāhū jugat bihānē kaī janam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸੇ ਰਾਹੇ ਪੈ ਕੇ (ਇਸ ਦੇ) ਕਈ ਜਨਮ ਗੁਜ਼ਾਰ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "идя по этому пути, он провёл уже многие рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11824,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਖਿ ਲੇਹੁ ਆਪਨ ਕਰਿ ਕਰਮ ॥੭॥",
          "roman": "Nānak rākh leh āpan kar karam.7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਵਿਚਾਰੇ ਜੀਵ ਵਾਸਤੇ ਪ੍ਰਭੂ-ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ) ਆਪਣੀ ਮੇਹਰ ਕਰ ਕੇ (ਇਸ ਨੂੰ) ਬਚਾ ਲਵੋ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись за это бедное существо и говори: по Своей милости спаси его.7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 906,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11825,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਠਾਕੁਰੁ ਤੁਮ ਪਹਿ ਅਰਦਾਸਿ ॥",
          "roman": "tū ṭhākur tum peh ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਮਾਲਿਕ ਹੈਂ (ਸਾਡੀ ਜੀਵਾਂ ਦੀ) ਅਰਜ਼ ਤੇਰੇ ਅੱਗੇ ਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Бог, Ты — Владыка, и наше прошение обращено только к Тебе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11826,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਸਭੁ ਤੇਰੀ ਰਾਸਿ ॥",
          "roman": "jīu piṇḍ sabh tērī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਿੰਦ ਤੇ ਸਰੀਰ (ਜੋ ਤੂੰ ਸਾਨੂੰ ਦਿੱਤਾ ਹੈ) ਸਭ ਤੇਰੀ ਹੀ ਬਖ਼ਸ਼ੀਸ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "эта душа и тело, которые Ты нам дал, — всё это Твой дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11827,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਮਾਤ ਪਿਤਾ ਹਮ ਬਾਰਿਕ ਤੇਰੇ ॥",
          "roman": "tum māt pitā ham bārik tēre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਡਾ ਮਾਂ ਪਿਉ ਹੈਂ, ਅਸੀਂ ਤੇਰੇ ਬਾਲ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты — наши мать и отец, а мы — Твои дети,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11828,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਕ੍ਰਿਪਾ ਮਹਿ ਸੂਖ ਘਨੇਰੇ ॥",
          "roman": "tumrī kirpā meh sūkh ghanēre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮੇਹਰ (ਦੀ ਨਜ਼ਰ) ਵਿਚ ਬੇਅੰਤ ਸੁਖ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "в Твоей милости — бесчисленные блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11829,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਜਾਨੈ ਤੁਮਰਾ ਅੰਤੁ ॥",
          "roman": "koi na jānē tumrā ant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਤੇਰਾ ਅੰਤ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Никто не может постичь Твой предел,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11830,
          "is_rahao": false,
          "gurmukhi": "ਊਚੇ ਤੇ ਊਚਾ ਭਗਵੰਤ ॥",
          "roman": "ūche tē ūchā bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਤੂੰ ਸਭ ਤੋਂ ਉੱਚਾ ਭਗਵਾਨ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "потому что Ты — Высочайший из всех, Божественный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11831,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਤੁਮਰੈ ਸੂਤ੍ਰਿ ਧਾਰੀ ॥",
          "roman": "sagal samagrī tumrē sūtr dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੇ) ਸਾਰੇ ਪਦਾਰਥ ਤੇਰੇ ਹੀ ਹੁਕਮ ਵਿਚ ਟਿਕੇ ਹੋਏ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Все предметы и все вещи мира держатся только в Твоём повелении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11832,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਤੇ ਹੋਇ ਸੁ ਆਗਿਆਕਾਰੀ ॥",
          "roman": "tum tē hoi so āgiākārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਰਚੀ ਹੋਈ ਸ੍ਰਿਸ਼ਟੀ ਤੇਰੀ ਹੀ ਆਗਿਆ ਵਿਚ ਤੁਰ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и созданное Тобой творение движется только в Твоей воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11833,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਗਤਿ ਮਿਤਿ ਤੁਮ ਹੀ ਜਾਨੀ ॥",
          "roman": "tumrī gat mit tum hī jānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਕਿਹੋ ਜਿਹਾ ਹੈਂ ਤੇ ਕੇਡਾ ਵੱਡਾ ਹੈਂ-ਇਹ ਤੂੰ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Каков Ты и насколько Ты велик — это знаешь только Ты Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11834,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਦਾ ਕੁਰਬਾਨੀ ॥੮॥੪॥",
          "roman": "Nānak dās sadā kurbānī.8.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ, ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੇ ਸੇਵਕ (ਤੈਥੋਂ) ਸਦਾ ਸਦਕੇ ਜਾਂਦੇ ਹਨ ॥੮॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: Твои слуги всегда жертвуют собой ради Тебя.8.4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 907,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11835,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11836,
          "is_rahao": false,
          "gurmukhi": "ਦੇਨਹਾਰੁ ਪ੍ਰਭ ਛੋਡਿ ਕੈ ਲਾਗਹਿ ਆਨ ਸੁਆਇ ॥",
          "roman": "denhār prabh chhoḍ kē lāgah ān suāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੀਆਂ ਦਾਤਾਂ) ਦੇਣ ਵਾਲੇ ਪ੍ਰਭੂ ਨੂੰ ਛੱਡ ਕੇ (ਜੀਵ) ਹੋਰ ਸੁਆਦ ਵਿਚ ਲੱਗਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Оставив Прабху, дающего все дары, существа привязываются к иным вкусам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11837,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਹੂ ਨ ਸੀਝਈ ਬਿਨੁ ਨਾਵੈ ਪਤਿ ਜਾਇ ॥੧॥",
          "roman": "Nānak kahū na sījhaī bin nāvē pat jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਹੇ ਨਾਨਕ! (ਇਹੋ ਜਿਹਾ) ਕਦੇ (ਕੋਈ ਮਨੁੱਖ ਜੀਵਨ-ਯਾਤ੍ਰਾ ਵਿਚ) ਕਾਮਯਾਬ ਨਹੀਂ ਹੁੰਦਾ (ਕਿਉਂਕਿ ਪ੍ਰਭੂ ਦੇ) ਨਾਮ ਤੋਂ ਬਿਨਾ ਇੱਜ਼ਤ ਨਹੀਂ ਰਹਿੰਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о Нанак, так никто и никогда не преуспевает, ибо без Имени достоинство утрачивается. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 908,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11838,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "aṣṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11839,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਬਸਤੂ ਲੇ ਪਾਛੈ ਪਾਵੈ ॥",
          "roman": "das bastū le pāchhē pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਪ੍ਰਭੂ ਤੋਂ) ਦਸ ਚੀਜ਼ਾਂ ਲੈ ਕੇ ਸਾਂਭ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Получив от Бога десять вещей, человек откладывает их и хранит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11840,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਬਸਤੁ ਕਾਰਨਿ ਬਿਖੋਟਿ ਗਵਾਵੈ ॥",
          "roman": "ek basat kāran bikhoṭ gavāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਇਕ ਚੀਜ਼ ਦੀ ਖ਼ਾਤਰ ਆਪਣਾ ਇਤਬਾਰ ਗਵਾ ਲੈਂਦਾ ਹੈ (ਕਿਉਂਕਿ ਮਿਲੀਆਂ ਚੀਜ਼ਾਂ ਬਦਲੇ ਸ਼ੁਕਰੀਆ ਤਾਂ ਨਹੀਂ ਕਰਦਾ, ਜੇਹੜੀ ਨਹੀਂ ਮਿਲੀ ਉਸ ਦਾ ਗਿਲਾ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Но из-за одной-единственной вещи теряет своё доброе имя, потому что не благодарит за полученное, а всё жалуется на то, чего не получил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11841,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਭੀ ਨ ਦੇਇ ਦਸ ਭੀ ਹਿਰਿ ਲੇਇ ॥",
          "roman": "ek bhī na deī das bhī hir leī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਪ੍ਰਭੂ) ਇਕ ਚੀਜ਼ ਭੀ ਨਾਹ ਦੇਵੇ, ਤੇ, ਦਸ (ਦਿੱਤੀਆਂ ਹੋਈਆਂ) ਭੀ ਖੋਹ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если же Он и одной вещи не даст, да ещё и десять данных отнимет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11842,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਮੂੜਾ ਕਹੁ ਕਹਾ ਕਰੇਇ ॥",
          "roman": "tau mūṛā kaho kahā kareī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ, ਦੱਸੋ, ਇਹ ਮੂਰਖ ਕੀਹ ਕਰ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "то скажите, что сможет сделать этот глупец?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11843,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਠਾਕੁਰ ਸਿਉ ਨਾਹੀ ਚਾਰਾ ॥",
          "roman": "jis ṭhākur siu nāhī chārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਾਲਕ ਦੇ ਨਾਲ ਪੇਸ਼ ਨਹੀਂ ਜਾ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "С Тем Владыкой невозможно спорить или тягаться,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11844,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਕੀਜੈ ਸਦ ਨਮਸਕਾਰਾ ॥",
          "roman": "tā kau kījē sad namaskārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੱਗੇ ਸਦਾ ਸਿਰ ਨਿਵਾਉਣਾ ਹੀ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "потому перед Ним и следует всегда склонять голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11845,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਲਾਗਾ ਪ੍ਰਭੁ ਮੀਠਾ ॥",
          "roman": "jā kē man lāgā prabh mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਪ੍ਰਭੂ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ибо тот человек, кому Прабху сладок и дорог в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11846,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਤਾਹੂ ਮਨਿ ਵੂਠਾ ॥",
          "roman": "sarab sūkh tāhū man vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਸੁਖ ਉਸੇ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆ ਵੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "обретает все блага, которые поселяются в его сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11847,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਜਨ ਅਪਨਾ ਹੁਕਮੁ ਮਨਾਇਆ ॥",
          "roman": "jis jan apnā hukam manāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਤੋਂ ਪ੍ਰਭੂ ਆਪਣਾ ਹੁਕਮ ਮਨਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, от которого Бог добивается принятия Своего Хукама,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11848,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਥੋਕ ਨਾਨਕ ਤਿਨਿ ਪਾਇਆ ॥੧॥",
          "roman": "sarab thok Nānak tin pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਦੁਨੀਆ ਦੇ) ਸਾਰੇ ਪਦਾਰਥ (ਮਾਨੋ) ਉਸ ਨੇ ਲੱਭ ਲਏ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, словно обрёл все сокровища мира. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 909,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11849,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਤ ਸਾਹੁ ਅਪਨੀ ਦੇ ਰਾਸਿ ॥",
          "roman": "aganat sāh apnī de rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ) ਸ਼ਾਹ ਅਣਗਿਣਤ (ਪਦਾਰਥਾਂ ਦੀ) ਪੂੰਜੀ (ਜੀਵ ਵਣਜਾਰੇ ਨੂੰ) ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господин даёт торговцу-душе неисчислимый капитал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11850,
          "is_rahao": false,
          "gurmukhi": "ਖਾਤ ਪੀਤ ਬਰਤੈ ਅਨਦ ਉਲਾਸਿ ॥",
          "roman": "khāt pīt bartē anad ulās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ) ਖਾਂਦਾ ਪੀਂਦਾ ਚਾਉ ਤੇ ਖ਼ੁਸ਼ੀ ਨਾਲ (ਇਹਨਾਂ ਪਦਾਰਥਾਂ ਨੂੰ) ਵਰਤਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И тот ест, пьёт и с радостью пользуется этими дарами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11851,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੀ ਅਮਾਨ ਕਛੁ ਬਹੁਰਿ ਸਾਹੁ ਲੇਇ ॥",
          "roman": "apunī amān kachh bahur sāh leī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ) ਸ਼ਾਹ ਆਪਣੀ ਕੋਈ ਅਮਾਨਤ ਮੋੜ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если же Господин заберёт назад что-то из Своего, отданного на хранение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11852,
          "is_rahao": false,
          "gurmukhi": "ਅਗਿਆਨੀ ਮਨਿ ਰੋਸੁ ਕਰੇਇ ॥",
          "roman": "agiānī man ros kareī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਇਹ) ਅਗਿਆਨੀ ਮਨ ਵਿਚ ਰੋਸਾ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "то невежда начинает внутренне сердиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11853,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਪਰਤੀਤਿ ਆਪ ਹੀ ਖੋਵੈ ॥",
          "roman": "apnī partīt āp hī khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਆਪਣਾ ਇਤਬਾਰ ਆਪ ਹੀ ਗਵਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Так он сам теряет к себе доверие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11854,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਉਸ ਕਾ ਬਿਸ੍ਵਾਸੁ ਨ ਹੋਵੈ ॥",
          "roman": "bahur us kā bisvās na hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੁੜ ਇਸ ਦਾ ਵਿਸਾਹ ਨਹੀਂ ਕੀਤਾ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и впредь ему уже не верят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11855,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੀ ਬਸਤੁ ਤਿਸੁ ਆਗੈ ਰਾਖੈ ॥",
          "roman": "jis kī basat tis āgē rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ) ਜਿਸ ਪ੍ਰਭੂ ਦੀ (ਬਖ਼ਸ਼ੀ ਹੋਈ) ਚੀਜ਼ ਹੈ ਉਸ ਦੇ ਅੱਗੇ (ਆਪ ਹੀ ਖ਼ੁਸ਼ੀ ਨਾਲ) ਰੱਖ ਦਏ,"
            },
            "sahib_singh_ru": {
              "main": "Но если то, что принадлежит Богу, человек сам с радостью возвращает Ему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11856,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਆਗਿਆ ਮਾਨੈ ਮਾਥੈ ॥",
          "roman": "prabh kī āgiā mānē māthē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪ੍ਰਭੂ ਦਾ ਹੁਕਮ (ਕੋਈ ਚੀਜ਼ ਖੁੱਸਣ ਵੇਲੇ) ਸਿਰ ਮੱਥੇ ਤੇ ਮੰਨ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "и принимает волю Прабху с покорностью, когда что-то утрачивает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11857,
          "is_rahao": false,
          "gurmukhi": "ਉਸ ਤੇ ਚਉਗੁਨ ਕਰੈ ਨਿਹਾਲੁ ॥",
          "roman": "us te chaugun karē nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਪ੍ਰਭੂ ਉਸ ਨੂੰ) ਅੱਗੇ ਨਾਲੋਂ ਚਉਗੁਣਾ ਨਿਹਾਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда Бог одаряет его вчетверо больше прежнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11858,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਹਿਬੁ ਸਦਾ ਦਇਆਲੁ ॥੨॥",
          "roman": "Nānak sāhib sadā daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮਾਲਕ ਸਦਾ ਮੇਹਰ ਕਰਨ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Владыка всегда милостив. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 910,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11859,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਭਾਤਿ ਮਾਇਆ ਕੇ ਹੇਤ ॥ ਸਰਪਰ ਹੋਵਤ ਜਾਨੁ ਅਨੇਤ ॥",
          "roman": "anik bhāt māiā ke het, sarpar hovat jān anet",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਪਿਆਰ ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਹਨ (ਭਾਵ, ਮਾਇਆ ਦੇ ਅਨੇਕਾਂ ਸੋਹਣੇ ਸਰੂਪ ਮਨੁੱਖ ਦੇ ਮਨ ਨੂੰ ਮੋਂਹਦੇ ਹਨ), (ਪਰ ਇਹ ਸਾਰੇ) ਅੰਤ ਨੂੰ ਨਾਸ ਹੋ ਜਾਣ ਵਾਲੇ ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "Привязанности к майе бывают самых разных видов, ибо многие её прекрасные формы пленяют ум человека; но знай, что всё это в конце концов исчезнет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11860,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਖ ਕੀ ਛਾਇਆ ਸਿਉ ਰੰਗੁ ਲਾਵੈ ॥",
          "roman": "birakh kī chhāiā siu rang lāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਕੋਈ ਮਨੁੱਖ) ਰੁੱਖ ਦੀ ਛਾਂ ਨਾਲ ਪਿਆਰ ਪਾ ਬੈਠੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек привяжется к тени дерева,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11861,
          "is_rahao": false,
          "gurmukhi": "ਓਹ ਬਿਨਸੈ ਉਹੁ ਮਨਿ ਪਛੁਤਾਵੈ ॥",
          "roman": "oh binsē oh man pachhutāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿੱਟਾ ਕੀਹ ਨਿਕਲੇਗਾ?) ਉਹ ਛਾਂ ਨਾਸ ਹੋ ਜਾਂਦੀ ਹੈ, ਤੇ, ਉਹ ਮਨੁੱਖ ਮਨ ਵਿਚ ਪਛੁਤਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то когда эта тень исчезнет, он станет раскаиваться в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11862,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੀਸੈ ਸੋ ਚਾਲਨਹਾਰੁ ॥",
          "roman": "jo dīsē so chālanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸਾਰਾ ਜਗਤ) ਜੋ ਦਿੱਸ ਰਿਹਾ ਹੈ ਨਾਸਵੰਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Всё, что видимо, преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11863,
          "is_rahao": false,
          "gurmukhi": "ਲਪਟਿ ਰਹਿਓ ਤਹ ਅੰਧ ਅੰਧਾਰੁ ॥",
          "roman": "lapaṭ rahiō tah andh andhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਜਗਤ) ਨਾਲ ਇਹ ਅੰਨ੍ਹਿਆਂ ਦਾ ਅੰਨ੍ਹਾ (ਜੀਵ) ਜੱਫਾ ਪਾਈ ਬੈਠਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "А это совершенно слепое существо вцепилось именно в это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11864,
          "is_rahao": false,
          "gurmukhi": "ਬਟਾਊ ਸਿਉ ਜੋ ਲਾਵੈ ਨੇਹ ॥",
          "roman": "baṭāū siu jo lāvē neh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਭੀ) ਮਨੁੱਖ (ਕਿਸੇ) ਰਾਹੀ ਨਾਲ ਪਿਆਰ ਪਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто привязывается к путнику,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11865,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਹਾਥਿ ਨ ਆਵੈ ਕੇਹ ॥",
          "roman": "tā kau hāth na āvē keh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅੰਤ ਨੂੰ) ਉਸ ਦੇ ਹੱਥ ਪੱਲੇ ਕੁਝ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "тот в конце ничего не получает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11866,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਪ੍ਰੀਤਿ ਸੁਖਦਾਈ ॥",
          "roman": "man har ke nām kī prīt sukhdāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਪਿਆਰ (ਹੀ) ਸੁਖ ਦੇਣ ਵਾਲਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "О ум, лишь любовь к Имени Хари даёт истинное счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11867,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਨਾਨਕ ਆਪਿ ਲਏ ਲਾਈ ॥੩॥",
          "roman": "kar kirpā Nānak āp lae lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਹੇ ਨਾਨਕ! (ਇਹ ਪਿਆਰ ਉਸ ਮਨੁੱਖ ਨੂੰ ਨਸੀਬ ਹੁੰਦਾ ਹੈ, ਜਿਸ ਨੂੰ) ਪ੍ਰਭੂ ਮੇਹਰ ਕਰ ਕੇ ਆਪ ਲਾਉਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о Нанак, эта любовь достаётся только тому, кого Сам Бог по милости к Себе привлекает. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 911,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11868,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਤਨੁ ਧਨੁ ਕੁਟੰਬੁ ਸਬਾਇਆ ॥",
          "roman": "mithiā tan dhan kuṭamb sabāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦ ਇਹ) ਸਰੀਰ, ਧਨ ਤੇ ਸਾਰਾ ਪਰਵਾਰ ਨਾਸਵੰਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Раз тело, богатство и вся семья непрочны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11869,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਹਉਮੈ ਮਮਤਾ ਮਾਇਆ ॥",
          "roman": "mithiā haumē mamtā māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ) ਮਾਇਆ ਦੀ ਮਾਲਕੀ ਤੇ ਹਉਮੈ (ਭਾਵ, ਧਨ ਤੇ ਪਰਵਾਰ ਦੇ ਕਾਰਣ ਵਡੱਪਣ)-ਇਹਨਾਂ ਉਤੇ ਮਾਣ ਭੀ ਝੂਠਾ।"
            },
            "sahib_singh_ru": {
              "main": "то и чувство собственности, и хоумэ, то есть гордыня из-за богатства и семьи, тоже ложны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11870,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਰਾਜ ਜੋਬਨ ਧਨ ਮਾਲ ॥",
          "roman": "mithiā rāj joban dhan māl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜ ਜੁਆਨੀ ਤੇ ਧਨ ਮਾਲ ਸਭ ਨਾਸਵੰਤ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Царство, молодость, богатство и имущество непрочны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11871,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਕਾਮ ਕ੍ਰੋਧ ਬਿਕਰਾਲ ॥",
          "roman": "mithiā kām krodh bikrāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ ਇਹਨਾਂ ਦੇ ਕਾਰਣ) ਕਾਮ (ਦੀ ਲਹਰ) ਤੇ ਭਿਆਨਕ ਕ੍ਰੋਧ ਇਹ ਭੀ ਵਿਅਰਥ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому и похоть, и страшный гнев, возникающие из-за них, тоже напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11872,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਰਥ ਹਸਤੀ ਅਸ੍ਵ ਬਸਤ੍ਰਾ ॥",
          "roman": "mithiā rath hastī asv bastrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਥ, ਹਾਥੀ, ਘੋੜੇ ਤੇ (ਸੁੰਦਰ) ਕੱਪੜੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਨਹੀਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Колесницы, слоны, кони и красивые одежды не вечны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11873,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਰੰਗ ਸੰਗਿ ਮਾਇਆ ਪੇਖਿ ਹਸਤਾ ॥",
          "roman": "mithiā rang sang māiā pekh hastā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਸਾਰੀ) ਮਾਇਆ ਨੂੰ ਪਿਆਰ ਨਾਲ ਵੇਖ ਕੇ (ਜੀਵ) ਹੱਸਦਾ ਹੈ, (ਪਰ ਇਹ ਹਾਸਾ ਤੇ ਮਾਣ ਭੀ) ਵਿਅਰਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Смеяться и радоваться, глядя с любовью на всю эту майю, тоже напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11874,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਧ੍ਰੋਹ ਮੋਹ ਅਭਿਮਾਨੁ ॥",
          "roman": "mithiā dhroh moh abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਗ਼ਾ, ਮੋਹ ਤੇ ਅਹੰਕਾਰ-(ਇਹ ਸਾਰੇ ਹੀ ਮਨ ਦੇ) ਵਿਅਰਥ (ਤਰੰਗ) ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Обман, привязанность и гордость — все эти движения ума тщетны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11875,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਆਪਸ ਊਪਰਿ ਕਰਤ ਗੁਮਾਨੁ ॥",
          "roman": "mithiā āpas ūpar karat gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਉਤੇ ਮਾਣ ਕਰਨਾ ਭੀ ਝੂਠਾ (ਨਸ਼ਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И гордость собой тоже ложное опьянение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11876,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਰੁ ਭਗਤਿ ਸਾਧ ਕੀ ਸਰਨ ॥",
          "roman": "asthir bhagat sādh kī saran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ (ਪ੍ਰਭੂ ਦੀ) ਭਗਤੀ (ਹੀ ਹੈ ਜੋ) ਗੁਰੂ ਦੀ ਸਰਣ ਪੈ ਕੇ (ਕੀਤੀ ਜਾਏ)।"
            },
            "sahib_singh_ru": {
              "main": "Лишь бхагти Бога, совершаемая в прибежище Гуру, пребывает неизменно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11877,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਪਿ ਜਪਿ ਜੀਵੈ ਹਰਿ ਕੇ ਚਰਨ ॥੪॥",
          "roman": "Nānak jap jap jīvē har ke charan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੇ ਚਰਣ (ਹੀ) ਸਦਾ ਜਪ ਕੇ (ਮਨੁੱਖ) ਅਸਲੀ ਜੀਵਨ ਜੀਊਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, человек по-настоящему живёт, когда постоянно созерцает Стопы Хари. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 912,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11878,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਸ੍ਰਵਨ ਪਰ ਨਿੰਦਾ ਸੁਨਹਿ ॥",
          "roman": "mithiā sravan par nindā suneh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਦੇ) ਕੰਨ ਵਿਅਰਥ ਹਨ (ਜੇ ਉਹ) ਪਰਾਈ ਬਖ਼ੀਲੀ ਸੁਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Уши тщетны, если они слушают злословие о других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11879,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਹਸਤ ਪਰ ਦਰਬ ਕਉ ਹਿਰਹਿ ॥",
          "roman": "mithiā hast par darb kau hireh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੱਥ ਵਿਅਰਥ ਹਨ (ਜੇ ਇਹ) ਪਰਾਏ ਧਨ ਨੂੰ ਚੁਰਾਉਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Руки тщетны, если они крадут чужое имущество."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
