{
  "ang": 270,
  "shabads": [
    {
      "shabad_id": 918,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11937,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖਿ ਤਾ ਕੋ ਜਸੁ ਰਸਨ ਬਖਾਨੈ ॥",
          "roman": "mukh tā ko jas rasan bakhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਵਡਿਆਈ (ਆਪਣੇ) ਮੂੰਹੋਂ ਜੀਭ ਨਾਲ (ਸਦਾ) ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "прославляй Его своим ртом и языком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11938,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰੋ ਰਹਤਾ ਧਰਮੁ ॥",
          "roman": "jih prasād tero rahtā dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੇਰਾ ਧਰਮ (ਕਾਇਮ) ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому твоя дхармa сохраняется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11939,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸਦਾ ਧਿਆਇ ਕੇਵਲ ਪਾਰਬ੍ਰਹਮੁ ॥",
          "roman": "man sadā dhiāe keval pārbrahm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੂੰ ਸਦਾ ਉਸ ਪਰਮੇਸ਼ਰ ਨੂੰ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! всегда помни только Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11940,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਜੀ ਜਪਤ ਦਰਗਹ ਮਾਨੁ ਪਾਵਹਿ ॥",
          "roman": "prabh jī japat dargah mān pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕੀਤਿਆਂ (ਉਸ ਦੀ) ਦਰਗਾਹ ਵਿਚ ਮਾਣ ਪਾਵਹਿਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Прабху, ты обретёшь почёт в Его даргах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11941,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਤਿ ਸੇਤੀ ਘਰਿ ਜਾਵਹਿ ॥੨॥",
          "roman": "Nānak pat setī ghar jāvahi.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਹੇ ਨਾਨਕ! (ਇਥੋਂ) ਇੱਜ਼ਤ ਨਾਲ ਆਪਣੇ (ਪਰਲੋਕ ਦੇ) ਘਰ ਵਿਚ ਜਾਵਹਿਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, с честью войдёшь в свой дом в ином мире. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 919,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11942,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਆਰੋਗ ਕੰਚਨ ਦੇਹੀ ॥",
          "roman": "jih prasād ārog kañchan dehī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਸੋਨੇ ਵਰਗਾ ਤੇਰਾ ਨਰੋਆ ਜਿਸਮ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому твоё тело здорово и подобно золоту,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11943,
          "is_rahao": false,
          "gurmukhi": "ਲਿਵ ਲਾਵਹੁ ਤਿਸੁ ਰਾਮ ਸਨੇਹੀ ॥",
          "roman": "liv lāvah tis rām sanehī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਿਆਰੇ ਰਾਮ ਨਾਲ ਲਿਵ ਜੋੜ।"
            },
            "sahib_singh_ru": {
              "main": "соедини свою любовь с тем возлюбленным Рамом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11944,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰਾ ਓਲਾ ਰਹਤ ॥",
          "roman": "jih prasād terā olā rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਤੇਰਾ ਪਰਦਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому твоя честь и покров сохраняются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11945,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸੁਖੁ ਪਾਵਹਿ ਹਰਿ ਹਰਿ ਜਸੁ ਕਹਤ ॥",
          "roman": "man sukh pāvah har har jas kahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਹਰੀ ਦੀ ਸਿਫ਼ਤ-ਸਲਾਹ ਕਰ ਕੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! обрети покой, прославляя того Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11946,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰੇ ਸਗਲ ਛਿਦ੍ਰ ਢਾਕੇ ॥",
          "roman": "jih prasād tere sagal chhidr ḍhāke",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ ਦੀ ਦਇਆ ਨਾਲ ਤੇਰੇ ਸਾਰੇ ਐਬ ਢੱਕੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! По милости Того, благодаря Кому все твои изъяны прикрыты,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11947,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸਰਨੀ ਪਰੁ ਠਾਕੁਰ ਪ੍ਰਭ ਤਾ ਕੈ ॥",
          "roman": "man sarnī par ṭhākur prabh tā kē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਪ੍ਰਭੂ ਠਾਕੁਰ ਦੀ ਸਰਣ ਪਉ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! припади к прибежищу того Прабху, того Тхакура."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11948,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੁਝੁ ਕੋ ਨ ਪਹੂਚੈ ॥",
          "roman": "jih prasād tujh ko na pahūchē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਕੋਈ ਤੇਰੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому никто не может сравниться с тобой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11949,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸਾਸਿ ਸਾਸਿ ਸਿਮਰਹੁ ਪ੍ਰਭ ਊਚੇ ॥",
          "roman": "man sās sās simrah prabh ūche",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਉਚੇ ਪ੍ਰਭੂ ਨੂੰ ਸ੍ਵਾਸ ਸ੍ਵਾਸ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! вспоминай того высокого Прабху с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11950,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਪਾਈ ਦ੍ਰੁਲਭ ਦੇਹ ॥",
          "roman": "jih prasād pāī drulabh deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਤੈਨੂੰ ਇਹ ਮਨੁੱਖਾ-ਸਰੀਰ ਲੱਭਾ ਹੈ ਜੋ ਬੜੀ ਮੁਸ਼ਕਿਲ ਨਾਲ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты получил это человеческое тело, достающееся с великим трудом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11951,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੀ ਭਗਤਿ ਕਰੇਹ ॥੩॥",
          "roman": "Nānak tā kī bhagat kareh.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! предайся бхагти того Прабху. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 920,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11952,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਆਭੂਖਨ ਪਹਿਰੀਜੈ ॥",
          "roman": "jih prasād ābhūkhan pahirījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕਿਰਪਾ ਨਾਲ ਗਹਣੇ ਪਹਿਨੀਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому надеваются украшения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11953,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਿਸੁ ਸਿਮਰਤ ਕਿਉ ਆਲਸੁ ਕੀਜੈ ॥",
          "roman": "man tis simrat kio ālas kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਨੂੰ ਸਿਮਰਦਿਆਂ ਕਿਉਂ ਆਲਸ ਕੀਤਾ ਜਾਏ?"
            },
            "sahib_singh_ru": {
              "main": "о ум! почему же, помня Его, допускают лень?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11954,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਅਸ੍ਵ ਹਸਤਿ ਅਸਵਾਰੀ ॥",
          "roman": "jih prasād asv hast asvārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਘੋੜੇ ਤੇ ਹਾਥੀਆਂ ਦੀ ਸਵਾਰੀ ਕਰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты ездишь на конях и слонах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11955,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਿਸੁ ਪ੍ਰਭ ਕਉ ਕਬਹੂ ਨ ਬਿਸਾਰੀ ॥",
          "roman": "man tis prabh kau kabhū na bisārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਕਦੇ ਨਾਹ ਵਿਸਾਰੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! никогда не забывай того Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11956,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਬਾਗ ਮਿਲਖ ਧਨਾ ॥",
          "roman": "jih prasād bāg milakh dhanā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਦਇਆ ਨਾਲ ਬਾਗ ਜ਼ਮੀਨਾਂ ਤੇ ਧਨ (ਤੈਨੂੰ ਨਸੀਬ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому тебе достались сады, земли и богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11957,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖੁ ਪਰੋਇ ਪ੍ਰਭੁ ਅਪੁਨੇ ਮਨਾ ॥",
          "roman": "rākh paroī prabh apune manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਪ੍ਰੋ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "нанизай и удерживай того Прабху в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11958,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਤੇਰੀ ਮਨ ਬਨਤ ਬਨਾਈ ॥",
          "roman": "jin terī man banat banāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ (ਪ੍ਰਭੂ) ਨੇ ਤੈਨੂੰ ਸਾਜਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Тот Прабху, Который тебя создал,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11959,
          "is_rahao": false,
          "gurmukhi": "ਊਠਤ ਬੈਠਤ ਸਦ ਤਿਸਹਿ ਧਿਆਈ ॥",
          "roman": "ūṭhat bēṭhat sad tiseh dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਠਦੇ ਬੈਠਦੇ (ਭਾਵ, ਹਰ ਵੇਲੇ) ਉਸੇ ਨੂੰ ਸਦਾ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "вставая и садясь, то есть всегда, помни только Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11960,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਧਿਆਇ ਜੋ ਏਕ ਅਲਖੈ ॥",
          "roman": "tiseh dhiāe jo ek alakhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰ, ਜੋ ਇੱਕ ਹੈ, ਤੇ, ਬੇਅੰਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Помни того Прабху, Который Един и непостижим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11961,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਨਾਨਕ ਤੇਰੀ ਰਖੈ ॥੪॥",
          "roman": "īhā ūhā Nānak terī rakhē.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ (ਉਹੀ) ਤੇਰੀ ਲਾਜ ਰੱਖਣ ਵਾਲਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! и в этом мире, и в ином Он хранит твою честь. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 921,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11962,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਕਰਹਿ ਪੁੰਨ ਬਹੁ ਦਾਨ ॥",
          "roman": "jih prasād karah puṇn bah dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਬਹੁਤ ਦਾਨ ਪੁੰਨ ਕਰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты совершаешь много подаяний и благих дел,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11963,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਆਠ ਪਹਰ ਕਰਿ ਤਿਸ ਕਾ ਧਿਆਨ ॥",
          "roman": "man āṭh pahar kar tis kā dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਅੱਠੇ ਪਹਿਰ ਉਸ ਦਾ ਚੇਤਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! все восемь страж держи память о Нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11964,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੂ ਆਚਾਰ ਬਿਉਹਾਰੀ ॥",
          "roman": "jih prasād tū āchār biuhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਤੂੰ ਰੀਤਾਂ ਰਸਮਾਂ ਕਰਨ ਜੋਗਾ ਹੋਇਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты стал способен исполнять обряды и обычаи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11965,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਪ੍ਰਭ ਕਉ ਸਾਸਿ ਸਾਸਿ ਚਿਤਾਰੀ ॥",
          "roman": "tis prabh kau sās sās chitārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸ੍ਵਾਸ ਸ੍ਵਾਸ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "вспоминай того Прабху с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11966,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰਾ ਸੁੰਦਰ ਰੂਪੁ ॥",
          "roman": "jih prasād terā sundar rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਦਇਆ ਨਾਲ ਤੇਰੀ ਸੋਹਣੀ ਸ਼ਕਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому у тебя красивый облик,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11967,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪ੍ਰਭੁ ਸਿਮਰਹੁ ਸਦਾ ਅਨੂਪੁ ॥",
          "roman": "so prabh simrah sadā anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸੋਹਣੇ ਮਾਲਕ ਨੂੰ ਸਦਾ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "всегда помни того прекрасного Владыку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11968,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰੀ ਨੀਕੀ ਜਾਤਿ ॥",
          "roman": "jih prasād terī nīkī jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਤੈਨੂੰ ਚੰਗੀ (ਮਨੁੱਖ) ਜਾਤੀ ਮਿਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того Прабху, благодаря Кому тебе досталась добрая человеческая природа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11969,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪ੍ਰਭੁ ਸਿਮਰਿ ਸਦਾ ਦਿਨ ਰਾਤਿ ॥",
          "roman": "so prabh simar sadā din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਦਾ ਦਿਨ ਰਾਤ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "день и ночь всегда вспоминай Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11970,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰੀ ਪਤਿ ਰਹੈ ॥",
          "roman": "jih prasād terī pat rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਤੇਰੀ ਇੱਜ਼ਤ (ਜਗਤ ਵਿਚ) ਬਣੀ ਹੋਈ ਹੈ (ਉਸ ਦਾ ਨਾਮ ਸਿਮਰ)।"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому твоя честь в мире сохраняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11971,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਜਸੁ ਕਹੈ ॥੫॥",
          "roman": "gur prasād Nānak jas kahē.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੀ ਬਰਕਤਿ ਲੈ ਕੇ (ਵਡਭਾਗੀ ਮਨੁੱਖ) ਉਸ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! по милости Гуру счастливый человек воспевает Его хвалу. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 922,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11972,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੁਨਹਿ ਕਰਨ ਨਾਦ ॥",
          "roman": "jih prasād sunah karan nād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ (ਆਪਣੇ) ਕੰਨਾਂ ਨਾਲ ਆਵਾਜ਼ ਸੁਣਦਾ ਹੈਂ (ਭਾਵ, ਤੈਨੂੰ ਸੁਣਨ ਦੀ ਤਾਕਤ ਮਿਲੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты своими ушами слышишь звук, то есть имеешь силу слышать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11973,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਪੇਖਹਿ ਬਿਸਮਾਦ ॥",
          "roman": "jih prasād pekhah bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਅਚਰਜ ਨਜ਼ਾਰੇ ਵੇਖਦਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "по Его милости ты видишь удивительные зрелища;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11974,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਬੋਲਹਿ ਅੰਮ੍ਰਿਤ ਰਸਨਾ ॥",
          "roman": "jih prasād bolahi aṃmrit rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਬਰਕਤਿ ਪਾ ਕੇ ਜੀਭ ਨਾਲ ਮਿੱਠੇ ਬੋਲ ਬੋਲਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "по Его благодати своим языком ты произносишь сладкие слова,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11975,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੁਖਿ ਸਹਜੇ ਬਸਨਾ ॥",
          "roman": "jih prasād sukh sahje basnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸੁਭਾਵਕ ਹੀ ਸੁਖੀ ਵੱਸ ਰਿਹਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "по Его милости ты естественно живёшь в покое;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11976,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਹਸਤ ਕਰ ਚਲਹਿ ॥",
          "roman": "jih prasād hast kar chaleh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਦਇਆ ਨਾਲ ਤੇਰੇ ਹੱਥ (ਆਦਿਕ ਸਾਰੇ ਅੰਗ) ਕੰਮ ਦੇ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "по Его милости твои руки и прочие члены служат тебе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11977,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੰਪੂਰਨ ਫਲਹਿ ॥",
          "roman": "jih prasād saṃpūran phaleh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਤੂੰ ਹਰੇਕ ਕਾਰ-ਵਿਹਾਰ ਵਿਚ ਕਾਮਯਾਬ ਹੁੰਦਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "по Его милости ты достигаешь успеха во всяком деле;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11978,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਪਰਮ ਗਤਿ ਪਾਵਹਿ ॥",
          "roman": "jih prasād param gat pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਬਖ਼ਸ਼ਸ਼ ਨਾਲ ਤੈਨੂੰ ਉੱਚਾ ਦਰਜਾ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "по Его щедрому дару ты достигаешь высокого состояния,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11979,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੁਖਿ ਸਹਜਿ ਸਮਾਵਹਿ ॥",
          "roman": "jih prasād sukh sahaj samāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਤੂੰ ਸੁਖ ਤੇ ਬੇ-ਫ਼ਿਕਰੀ ਵਿਚ ਮਸਤ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "и пребываешь в покое и беспечности;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11980,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਪ੍ਰਭੁ ਤਿਆਗਿ ਅਵਰ ਕਤ ਲਾਗਹੁ ॥",
          "roman": "aisā prabh tiāg avar kat lāgah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜੇਹਾ ਪ੍ਰਭੂ ਵਿਸਾਰ ਕੇ ਤੂੰ ਹੋਰ ਕਿਸ ਪਾਸੇ ਲੱਗ ਰਿਹਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "забыв такого Прабху, к кому ещё ты прилепляешься?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11981,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਮਨਿ ਜਾਗਹੁ ॥੬॥",
          "roman": "gur prasād Nānak man jāgah.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੀ ਬਰਕਤਿ ਲੈ ਕੇ ਮਨ ਵਿਚ ਹੁਸ਼ੀਆਰ ਹੋਹੁ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! по милости Гуру пробудись в уме. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 923,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11982,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੂੰ ਪ੍ਰਗਟੁ ਸੰਸਾਰਿ ॥",
          "roman": "jih prasād tūṃ pragaṭ saṃsār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਜਗਤ ਵਿਚ ਸੋਭਾ ਵਾਲਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости того Прабху, благодаря Кому ты славен в мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11983,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਪ੍ਰਭ ਕਉ ਮੂਲਿ ਨ ਮਨਹੁ ਬਿਸਾਰਿ ॥",
          "roman": "tis prabh kau mūl na manah bisār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕਦੇ ਭੀ ਮਨੋਂ ਨ ਭੁਲਾ।"
            },
            "sahib_singh_ru": {
              "main": "никогда даже в мыслях не забывай Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11984,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰਾ ਪਰਤਾਪੁ ॥",
          "roman": "jih prasād terā partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਤੈਨੂੰ ਵਡਿਆਈ ਮਿਲੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому у тебя есть величие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11985,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਮੂੜ ਤੂ ਤਾ ਕਉ ਜਾਪੁ ॥",
          "roman": "re man mūṛ tū tā kau jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ ਮਨ! ਤੂੰ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਜਪ।"
            },
            "sahib_singh_ru": {
              "main": "о глупый ум! повторяй Имя того Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11986,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੇਰੇ ਕਾਰਜ ਪੂਰੇ ॥",
          "roman": "jih prasād tere kāraj pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੇਰੇ (ਸਾਰੇ) ਕੰਮ ਸਿਰੇ ਚੜ੍ਹਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому все твои дела завершаются успешно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11987,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਜਾਨੁ ਮਨ ਸਦਾ ਹਜੂਰੇ ॥",
          "roman": "tiseh jān man sadā hajūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੂੰ ਉਸ (ਪ੍ਰਭੂ) ਨੂੰ ਸਦਾ ਅੰਗ ਸੰਗ ਜਾਣ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! знай Его всегда пребывающим рядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11988,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੂੰ ਪਾਵਹਿ ਸਾਚੁ ॥",
          "roman": "jih prasād tūṃ pāvah sāch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਤੈਨੂੰ ਸੱਚ ਪਰਾਪਤ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По Его благодати тебе открывается Истина,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11989,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਮੇਰੇ ਤੂੰ ਤਾ ਸਿਉ ਰਾਚੁ ॥",
          "roman": "re man mere tū tā sio rāch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਤੂੰ ਉਸ (ਪ੍ਰਭੂ) ਨਾਲ ਜੁੜਿਆ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "о мой ум! оставайся соединённым с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11990,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸਭ ਕੀ ਗਤਿ ਹੋਇ ॥",
          "roman": "jih prasād sabh kī gat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪਰਾਮਤਮਾ) ਦੀ ਦਇਆ ਨਾਲ ਹਰੇਕ (ਜੀਵ) ਦੀ (ਉਸ ਤਕ) ਪਹੁੰਚ ਹੋ ਜਾਂਦੀ ਹੈ, (ਉਸ ਨੂੰ ਜਪ)।"
            },
            "sahib_singh_ru": {
              "main": "По милости Того Параматмы каждый живой может достичь Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11991,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾਪੁ ਜਪੈ ਜਪੁ ਸੋਇ ॥੭॥",
          "roman": "Nānak jāp japē jap soi.7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜਿਸ ਨੂੰ ਇਹ  ਦਾਤ ਮਿਲਦੀ ਹੈ) ਉਹ (ਹਰਿ-) ਜਾਪ ਹੀ ਜਪਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! тот и повторяет Джап, кому дарована эта милость. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 924,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11992,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਜਪਾਏ ਜਪੈ ਸੋ ਨਾਉ ॥",
          "roman": "āp japāe japē so nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ਜਿਸ ਪਾਸੋਂ ਆਪ ਜਪਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот человек повторяет Имя Прабху, кого Сам Он побуждает к повторению,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11993,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਗਾਵਾਏ ਸੁ ਹਰਿ ਗੁਨ ਗਾਉ ॥",
          "roman": "āp gavāe su har guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਹਰੀ ਦੇ ਗੁਣ ਗਾਉਂਦਾ ਹੈ ਜਿਸ ਨੂੰ ਗਾਵਣ ਲਈ ਪ੍ਰੇਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и лишь тот человек поёт качества Хари, кого Сам Он побуждает петь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
