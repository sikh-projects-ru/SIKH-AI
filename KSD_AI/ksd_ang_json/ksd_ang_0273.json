{
  "ang": 273,
  "shabads": [
    {
      "shabad_id": 937,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12117,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਦ੍ਰਿਸਟਿ ਅੰਮ੍ਰਿਤੁ ਬਰਸੀ ॥",
          "roman": "brahm giānī kī drisaṭ amrit barsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਨਜ਼ਰ ਤੋਂ (ਸਭ ਉਤੇ) ਅੰਮ੍ਰਿਤ ਦੀ ਵਰਖਾ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и из его взгляда на всех льётся дождь амриты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12118,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਬੰਧਨ ਤੇ ਮੁਕਤਾ ॥",
          "roman": "brahm giānī bandhan te muktā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਮਾਇਆ ਦੇ) ਬੰਧਨਾਂ ਤੋਂ ਆਜ਼ਾਦ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни свободен от уз майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12119,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਨਿਰਮਲ ਜੁਗਤਾ ॥",
          "roman": "brahm giānī kī nirmal jugtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਦੀ ਜੀਵਨ-ਜੁਗਤੀ ਵਿਕਾਰਾਂ ਤੋਂ ਰਹਿਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и его образ жизни чист от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12120,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਭੋਜਨੁ ਗਿਆਨ ॥",
          "roman": "brahm giānī kā bhojan giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰੱਬੀ-) ਗਿਆਨ ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਖ਼ੁਰਾਕ ਹੈ (ਭਾਵ, ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਆਤਮਕ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Божественное знание — пища брахмгьяни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12121,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਬ੍ਰਹਮ ਧਿਆਨੁ ॥੩॥",
          "roman": "Nānak brahm giānī kā brahm dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਸੁਰਤ ਅਕਾਲ ਪੁਰਖ ਨਾਲ ਜੁੜੀ ਰਹਿੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, сознание брахмгьяни связано с Акаал Пуракхом ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 938,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12122,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਏਕ ਊਪਰਿ ਆਸ ॥",
          "roman": "brahm giānī ek ūpar ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਇਕ ਅਕਾਲ ਪੁਰਖ ਉਤੇ ਆਸ ਰੱਖਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни возлагает надежду на одного Акаал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12123,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਨਹੀ ਬਿਨਾਸ ॥",
          "roman": "brahm giānī kā nahī binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਦੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ) ਦਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и его высокое духовное состояние никогда не разрушается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12124,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਗਰੀਬੀ ਸਮਾਹਾ ॥",
          "roman": "brahm giānī kē garībī samāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਹਿਰਦੇ ਵਿਚ ਗਰੀਬੀ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В сердце брахмгьяни пребывает смирение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12125,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਪਰਉਪਕਾਰ ਉਮਾਹਾ ॥",
          "roman": "brahm giānī parupkār umāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਨੂੰ ਦੂਜਿਆਂ ਦੀ ਭਲਾਈ ਕਰਨ ਦਾ (ਸਦਾ) ਚਾਉ (ਚੜ੍ਹਿਆ ਰਹਿੰਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и у него всегда есть горячее стремление творить благо другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12126,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਨਾਹੀ ਧੰਧਾ ॥",
          "roman": "brahm giānī kē nāhī dhanḍhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਮਨ ਵਿਚ (ਮਾਇਆ ਦਾ) ਜੰਜਾਲ ਨਹੀਂ ਵਿਆਪਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "В уме брахмгьяни не разрастается путаница майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12127,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਲੇ ਧਾਵਤੁ ਬੰਧਾ ॥",
          "roman": "brahm giānī le dhāvat bandhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਭਟਕਦੇ ਮਨ ਨੂੰ ਕਾਬੂ ਕਰ ਕੇ (ਮਾਇਆ ਵਲੋਂ) ਰੋਕ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что он умеет обуздать блуждающий ум и удержать его от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12128,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਹੋਇ ਸੁ ਭਲਾ ॥",
          "roman": "brahm giānī kē hoi su bhalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ (ਪ੍ਰਭੂ ਵਲੋਂ) ਹੁੰਦਾ ਹੈ, ਬ੍ਰਹਮਗਿਆਨੀ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਭਲਾ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Что бы ни происходило по воле Господа, брахмгьяни считает это благим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12129,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸੁਫਲ ਫਲਾ ॥",
          "roman": "brahm giānī suphal phalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ) ਉਸ ਦਾ ਮਨੁੱਖਾ ਜਨਮ ਚੰਗੀ ਤਰ੍ਹਾਂ ਕਾਮਯਾਬ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и потому его человеческое рождение по-настоящему оказывается успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12130,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸੰਗਿ ਸਗਲ ਉਧਾਰੁ ॥",
          "roman": "brahm giānī sang sagal udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਸੰਗਤਿ ਵਿਚ ਸਭ ਦਾ ਬੇੜਾ ਪਾਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе брахмгьяни все переправляются через мирской океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12131,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬ੍ਰਹਮ ਗਿਆਨੀ ਜਪੈ ਸਗਲ ਸੰਸਾਰੁ ॥੪॥",
          "roman": "Nānak brahm giānī japē sagal sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਰਾਹੀਂ ਸਾਰਾ ਜਗਤ (ਹੀ) (ਪ੍ਰਭੂ ਦਾ ਨਾਮ) ਜਪਣ ਲੱਗ ਪੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "потому что, о Нанак, через брахмгьяни весь мир начинает повторять Имя Господа ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 939,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12132,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਏਕੈ ਰੰਗ ॥",
          "roman": "brahm giānī kē ekē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਸਦਾ) ਇਕ ਅਕਾਲ ਪੁਰਖ ਦਾ ਪਿਆਰ (ਵੱਸਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "В сердце брахмгьяни живёт любовь только к одному Акаал Пуракху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12133,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਬਸੈ ਪ੍ਰਭੁ ਸੰਗ ॥",
          "roman": "brahm giānī kē basē prabh sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ) ਪ੍ਰਭੂ ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਅੰਗ-ਸੰਗ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и потому Господь пребывает рядом с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12134,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਨਾਮੁ ਆਧਾਰੁ ॥",
          "roman": "brahm giānī kē nām ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਮਨ ਵਿਚ (ਪ੍ਰਭੂ ਦਾ) ਨਾਮ (ਹੀ) ਟੇਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для брахмгьяни Имя — опора,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12135,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਨਾਮੁ ਪਰਵਾਰੁ ॥",
          "roman": "brahm giānī kē nām parvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਨਾਮ ਹੀ ਉਸ ਦਾ ਪਰਵਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и Имя — его семья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12136,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਦਾ ਸਦ ਜਾਗਤ ॥",
          "roman": "brahm giānī sadā sad jāgat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਸਦਾ (ਵਿਕਾਰਾਂ ਦੇ ਹਮਲੇ ਵਲੋਂ) ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни всегда остаётся настороже перед нападением пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12137,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਅਹੰਬੁਧਿ ਤਿਆਗਤ ॥",
          "roman": "brahm giānī ahaṃbudh tiāgat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ 'ਮੈਂ ਮੈਂ' ਕਰਨ ਵਾਲੀ ਮੱਤ ਛੱਡ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и оставляет ум, говорящий «я, я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12138,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਮਨਿ ਪਰਮਾਨੰਦ ॥",
          "roman": "brahm giānī kē man parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਮਨ ਵਿਚ ਉੱਚੇ ਸੁਖ ਦਾ ਮਾਲਕ ਅਕਾਲ ਪੁਰਖ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В уме брахмгьяни пребывает Акаал Пуракх, владыка высшего блаженства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12139,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਘਰਿ ਸਦਾ ਅਨੰਦ ॥",
          "roman": "brahm giānī kē ghar sadā anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ) ਉਸ ਦੇ ਹਿਰਦੇ-ਰੂਪ ਘਰ ਵਿਚ ਸਦਾ ਖ਼ੁਸ਼ੀ ਖਿੜਾਓ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и потому в его доме-сердце всегда цветёт радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12140,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸੁਖ ਸਹਜ ਨਿਵਾਸ ॥",
          "roman": "brahm giānī sukh sahaj nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਮਨੁੱਖ) ਸੁਖ ਤੇ ਸ਼ਾਂਤੀ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни пребывает в покое и мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12141,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਨਹੀ ਬਿਨਾਸ ॥੫॥",
          "roman": "Nānak brahm giānī kā nahī binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ) ਹੇ ਨਾਨਕ! ਬ੍ਰਹਮਗਿਆਨੀ (ਦੀ ਇਸ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ) ਦਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, это его высокое духовное состояние никогда не исчезает ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 940,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12142,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਬ੍ਰਹਮ ਕਾ ਬੇਤਾ ॥",
          "roman": "brahm giānī brahm kā betā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਮਨੁੱਖ) ਅਕਾਲ ਪੁਰਖ ਦਾ ਮਹਰਮ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни становится близким к Акаал Пуракху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12143,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਏਕ ਸੰਗਿ ਹੇਤਾ ॥",
          "roman": "brahm giānī ek sang hetā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਹ ਇਕ ਪ੍ਰਭੂ ਨਾਲ ਹੀ ਪਿਆਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и любит лишь одного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12144,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਹੋਇ ਅਚਿੰਤ ॥",
          "roman": "brahm giānī kē hoi achint",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਮਨ ਵਿਚ (ਸਦਾ) ਬੇਫ਼ਿਕਰੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В уме брахмгьяни всегда есть беспечальность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12145,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਨਿਰਮਲ ਮੰਤ ॥",
          "roman": "brahm giānī kā nirmal mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਉਪਦੇਸ਼ (ਭੀ ਹੋਰਨਾਂ ਨੂੰ) ਪਵਿਤ੍ਰ ਕਰਨ ਵਾਲਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и его наставление тоже очищает других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12146,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਜਿਸੁ ਕਰੈ ਪ੍ਰਭੁ ਆਪਿ ॥",
          "roman": "brahm giānī jis karē prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹੀ ਮਨੁੱਖ ਬ੍ਰਹਮਗਿਆਨੀ ਬਣਦਾ ਹੈ) ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਆਪ ਬਣਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни становится только тот, кого Сам Господь делает таким,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12147,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਬਡ ਪਰਤਾਪ ॥",
          "roman": "brahm giānī kā baḍ partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦਾ ਬੜਾ ਨਾਮਣਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и слава брахмгьяни становится великой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12148,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਦਰਸੁ ਬਡਭਾਗੀ ਪਾਈਐ ॥",
          "roman": "brahm giānī kā daras baḍbhāgī pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦਾ ਦੀਦਾਰ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਪਾਈਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Увидеть брахмгьяни можно лишь по великой удаче,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12149,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਉ ਬਲਿ ਬਲਿ ਜਾਈਐ ॥",
          "roman": "brahm giānī kau bal bal jāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਈਏ।"
            },
            "sahib_singh_ru": {
              "main": "и нужно снова и снова посвящать себя ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12150,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਉ ਖੋਜਹਿ ਮਹੇਸੁਰ ॥",
          "roman": "brahm giānī kau khojah mahesur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ਿਵ (ਆਦਿਕ ਦੇਵਤੇ ਭੀ) ਬ੍ਰਹਮਗਿਆਨੀ ਨੂੰ ਭਾਲਦੇ ਫਿਰਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Даже Шива и другие божества ищут брахмгьяни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12151,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬ੍ਰਹਮ ਗਿਆਨੀ ਆਪਿ ਪਰਮੇਸੁਰ ॥੬॥",
          "roman": "Nānak brahm giānī āp parmesur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਕਾਲ ਪੁਰਖ ਆਪ ਬ੍ਰਹਮਗਿਆਨੀ (ਦਾ ਰੂਪ) ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "ибо, о Нанак, Сам Акаал Пуракх и есть образ брахмгьяни ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 941,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12152,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਕੀਮਤਿ ਨਾਹਿ ॥",
          "roman": "brahm giānī kī kīmat nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਦੇ ਗੁਣਾਂ) ਦਾ ਮੁੱਲ ਨਹੀਂ ਪੈ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Цены качествам брахмгьяни установить невозможно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12153,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਸਗਲ ਮਨ ਮਾਹਿ ॥",
          "roman": "brahm giānī kē sagal man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਹੀ (ਗੁਣ) ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਅੰਦਰ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что все качества пребывают в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12154,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਕਉਨ ਜਾਨੈ ਭੇਦੁ ॥",
          "roman": "brahm giānī kā kaun jānē bhed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੇਹੜਾ ਮਨੁੱਖ ਬ੍ਰਹਮਗਿਆਨੀ (ਦੀ ਉੱਚੀ ਜ਼ਿੰਦਗੀ) ਦਾ ਭੇਤ ਪਾ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Какой человек способен постичь тайну высокой жизни брахмгьяни?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12155,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਉ ਸਦਾ ਅਦੇਸੁ ॥",
          "roman": "brahm giānī kau sadā ades",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਅੱਗੇ ਸਦਾ ਨਿਊਣਾ ਹੀ (ਫੱਬਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Перед брахмгьяни всегда подобает склоняться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12156,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਕਥਿਆ ਨ ਜਾਇ ਅਧਾਖੵਰੁ ॥",
          "roman": "brahm giānī kā kathia na jāi adhākhyar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਦੀ ਮਹਿਮਾ) ਦਾ ਅੱਧਾ ਅੱਖਰ ਭੀ ਨਹੀਂ ਕਿਹਾ ਜਾ ਸਕਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "О славе брахмгьяни нельзя сказать даже половины буквы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12157,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਰਬ ਕਾ ਠਾਕੁਰੁ ॥",
          "roman": "brahm giānī sarab kā ṭhākur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਸਾਰੇ (ਜੀਵਾਂ) ਦਾ ਪੂਜ੍ਯ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "брахмгьяни почитаем всеми живыми существами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12158,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਮਿਤਿ ਕਉਨੁ ਬਖਾਨੈ ॥",
          "roman": "brahm giānī kī mit kaun bakhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਦੀ ਉੱਚੀ ਜ਼ਿੰਦਗੀ) ਦਾ ਅੰਦਾਜ਼ਾ ਕੌਣ ਲਾ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Кто может определить меру высокой жизни брахмгьяни?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12159,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਗਤਿ ਬ੍ਰਹਮ ਗਿਆਨੀ ਜਾਨੈ ॥",
          "roman": "brahm giānī kī gat brahm giānī jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਹਾਲਤ (ਉਸ ਵਰਗਾ) ਬ੍ਰਹਮਗਿਆਨੀ ਹੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его состояние знает только такой же брахмгьяни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12160,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਅੰਤੁ ਨ ਪਾਰੁ ॥",
          "roman": "brahm giānī kā ant na pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਦੇ ਗੁਣਾਂ ਦੇ ਸਮੁੰਦਰ) ਦਾ ਕੋਈ ਹੱਦ ਬੰਨਾ ਨਹੀਂ;"
            },
            "sahib_singh_ru": {
              "main": "У океана качеств брахмгьяни нет ни конца, ни предела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12161,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਉ ਸਦਾ ਨਮਸਕਾਰੁ ॥੭॥",
          "roman": "Nānak brahm giānī kau sadā namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
