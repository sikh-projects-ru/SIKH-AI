{
  "ang": 278,
  "shabads": [
    {
      "shabad_id": 968,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12412,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਰੂਪ ਜਿਉ ਸ੍ਵਾਗੀ ਦਿਖਾਵੈ ॥",
          "roman": "nānā rūp jiu svāgī dikhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁ-ਰੂਪੀਏ ਵਾਂਗ ਕਈ ਤਰ੍ਹਾਂ ਦੇ ਰੂਪ ਵਿਖਾ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "словно многообличный актёр, показывает самые разные образы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12413,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪ੍ਰਭ ਭਾਵੈ ਤਿਵੈ ਨਚਾਵੈ ॥",
          "roman": "jiu prabh bhāvē tivē nachāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਉਂ ਪ੍ਰਭੂ ਨੂੰ ਭਾਉਂਦਾ ਹੈ ਤਿਵੇਂ (ਜੀਵਾਂ ਨੂੰ) ਨਚਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и как угодно Господу, так Он и заставляет живых существ танцевать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12414,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋਈ ਹੋਇ ॥",
          "roman": "jo tis bhāvē soe hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਹੁੰਦਾ ਹੈ ਜੋ ਉਸ (ਮਾਲਕ) ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Происходит только то, что нравится этому Владыке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12415,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੂਜਾ ਅਵਰੁ ਨ ਕੋਇ ॥੭॥",
          "roman": "Nānak dūjā avar na koe ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਸ ਵਰਗਾ) ਕੋਈ ਹੋਰ ਦੂਜਾ ਨਹੀਂ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Другого, подобного Ему, нет. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 969,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12416,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਸਾਧਸੰਗਤਿ ਇਹੁ ਪਾਵੈ ॥",
          "roman": "kabhū sādhsangat ih pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ) ਕਦੇ (ਪ੍ਰਭੂ ਦੀ ਅੰਸ਼) ਇਹ ਜੀਵ ਸਤਸੰਗਿ ਵਿਚ ਅੱਪੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда иногда это живое существо, частица Господа, попадает в са̄дхсангат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12417,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਅਸਥਾਨ ਤੇ ਬਹੁਰਿ ਨ ਆਵੈ ॥",
          "roman": "us asthān te bahur na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਸ ਥਾਂ ਤੋਂ ਮੁੜ ਵਾਪਸ ਨਹੀਂ ਆਉਂਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "то уже не возвращается назад из того состояния;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12418,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਹੋਇ ਗਿਆਨ ਪਰਗਾਸੁ ॥",
          "roman": "antar hoe giān pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਇਸ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦੇ ਗਿਆਨ ਦਾ ਪਰਕਾਸ਼ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "потому что внутри него загорается свет знания о Господе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12419,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਅਸਥਾਨ ਕਾ ਨਹੀ ਬਿਨਾਸੁ ॥",
          "roman": "us asthān kā nahī binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ) ਉਸ (ਗਿਆਨ ਦੇ ਪਰਕਾਸ਼ ਵਾਲੀ) ਹਾਲਤ ਦਾ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "и это состояние просветления уже не разрушается;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12420,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਨਾਮਿ ਰਤੇ ਇਕ ਰੰਗਿ ॥",
          "roman": "man tan nām rate ik raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ) ਤਨ ਮਨ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਤੇ ਪਿਆਰ ਵਿਚ ਰੱਤੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "те люди, чьи тело и ум окрашены в Имя Господа и в любовь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12421,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਬਸਹਿ ਪਾਰਬ੍ਰਹਮ ਕੈ ਸੰਗਿ ॥",
          "roman": "sadā basah Pārbrahm kē saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਵੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "всегда пребывают в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12422,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜਲ ਮਹਿ ਜਲੁ ਆਇ ਖਟਾਨਾ ॥",
          "roman": "jiu jal mah jal āe khaṭānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੋ) ਜਿਵੇਂ ਪਾਣੀ ਵਿਚ ਪਾਣੀ ਆ ਰਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как вода сливается с водой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12423,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਜੋਤੀ ਸੰਗਿ ਜੋਤਿ ਸਮਾਨਾ ॥",
          "roman": "tiu jotī saṅg jot samānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ (ਸਤਸੰਗ ਵਿਚ ਟਿਕੇ ਹੋਏ ਦੀ) ਆਤਮਾ ਪ੍ਰਭੂ ਦੀ ਜੋਤਿ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "так и душа того, кто утвердился в сатсанге, сливается с Божественной Светоносностью;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12424,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਿ ਗਏ ਗਵਨ ਪਾਏ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "miṭ gae gavan pāe bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ (ਜਨਮ ਮਰਨ ਦੇ) ਫੇਰੇ ਮੁੱਕ ਜਾਂਦੇ ਹਨ, (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਉਸ ਨੂੰ ਟਿਕਾਣਾ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "его круги рождения и смерти прекращаются, и в стопах Господа он находит покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12425,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਕੈ ਸਦ ਕੁਰਬਾਨ ॥੮॥੧੧॥",
          "roman": "Nānak prabh kē sad kurbān ॥8॥11॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਤੋਂ ਸਦਕੇ ਜਾਈਏ ॥੮॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Будем всегда жертвовать собой ради Господа. ॥8॥11॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 970,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12426,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12427,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੀ ਬਸੈ ਮਸਕੀਨੀਆ ਆਪੁ ਨਿਵਾਰਿ ਤਲੇ ॥",
          "roman": "sukhī basē maskīnīā āp nivār talē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਰੀਬੀ ਸੁਭਾਉ ਵਾਲਾ ਬੰਦਾ ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰ ਕੇ, ਤੇ ਨੀਵਾਂ ਰਹਿ ਕੇ ਸੁਖੀ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек со смиренным, бедным духом нравом, устранив самоутверждение и оставаясь низким, живёт счастливо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12428,
          "is_rahao": false,
          "gurmukhi": "ਬਡੇ ਬਡੇ ਅਹੰਕਾਰੀਆ ਨਾਨਕ ਗਰਬਿ ਗਲੇ ॥੧॥",
          "roman": "baḍe baḍe ahaṅkārīā nānak garab galē ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਵੱਡੇ ਵੱਡੇ ਅਹੰਕਾਰੀ ਮਨੁੱਖ, ਹੇ ਨਾਨਕ! ਅਹੰਕਾਰ ਵਿਚ ਹੀ ਗਲ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но великие гордецы, о Нанак, погибают в самой своей гордыне ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 971,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12429,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭapadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12430,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਅੰਤਰਿ ਰਾਜ ਅਭਿਮਾਨੁ ॥",
          "roman": "jis kē antar rāj abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਰਾਜ ਦਾ ਮਾਣ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, в чьём уме есть гордость царской властью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12431,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਨਰਕਪਾਤੀ ਹੋਵਤ ਸੁਆਨੁ ॥",
          "roman": "so narakpātī hovat suān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕੁੱਤਾ ਨਰਕ ਵਿਚ ਪੈਣ ਦਾ ਸਜ਼ਾਵਾਰ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "удел — пасть в ад, как псу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12432,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਾਨੈ ਮੈ ਜੋਬਨਵੰਤੁ ॥",
          "roman": "jo jānē mē jobanvaṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ ਬੜਾ ਸੋਹਣਾ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто считает себя очень красивым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12433,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਹੋਵਤ ਬਿਸਟਾ ਕਾ ਜੰਤੁ ॥",
          "roman": "so hovat bisṭā kā jaṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਵਿਸ਼ਟਾ ਦਾ ਹੀ ਕੀੜਾ ਹੁੰਦਾ ਹੈ (ਕਿਉਂਕਿ ਸਦਾ ਵਿਸ਼ੇ-ਵਿਕਾਰਾਂ ਦੇ ਗੰਦ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "тот всего лишь червь в нечистотах, ибо вечно лежит в грязи страстей и пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12434,
          "is_rahao": false,
          "gurmukhi": "ਆਪਸ ਕਉ ਕਰਮਵੰਤੁ ਕਹਾਵੈ ॥",
          "roman": "āpas kau karamvaṅt kahāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਆਪਣੇ ਆਪ ਨੂੰ ਚੰਗੇ ਕੰਮ ਕਰਨ ਵਾਲਾ ਅਖਵਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто хочет, чтобы его называли совершающим добрые дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12435,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਿ ਮਰੈ ਬਹੁ ਜੋਨਿ ਭ੍ਰਮਾਵੈ ॥",
          "roman": "janam marē bah jon bhramāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਜੰਮਦਾ ਮਰਦਾ ਹੈ, ਕਈ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "вечно рождается и умирает, скитается по многим формам существования."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12436,
          "is_rahao": false,
          "gurmukhi": "ਧਨ ਭੂਮਿ ਕਾ ਜੋ ਕਰੈ ਗੁਮਾਨੁ ॥",
          "roman": "dhan bhūm kā jo karē gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਧਨ ਤੇ ਧਰਤੀ (ਦੀ ਮਾਲਕੀ) ਦਾ ਅਹੰਕਾਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто гордится богатством и землёй, своей собственностью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12437,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮੂਰਖੁ ਅੰਧਾ ਅਗਿਆਨੁ ॥",
          "roman": "so mūrakh aṅdhā agiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮੂਰਖ ਹੈ, ਅੰਨ੍ਹਾ ਹੈ, ਬੜਾ ਜਾਹਿਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот глупец, слепец и великий невежда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12438,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸ ਕੈ ਹਿਰਦੈ ਗਰੀਬੀ ਬਸਾਵੈ ॥",
          "roman": "kar kirpā jis kē hirdē garībī basāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਦਿਲ ਵਿਚ ਗਰੀਬੀ (ਸੁਭਾਉ) ਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, в чьё сердце по милости вселяется смирение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12439,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਈਹਾ ਮੁਕਤੁ ਆਗੈ ਸੁਖੁ ਪਾਵੈ ॥੧॥",
          "roman": "nānak īhā mukat āgē sukh pāvē ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਹ ਮਨੁੱਖ) ਇਸ ਜ਼ਿੰਦਗੀ ਵਿਚ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ ਤੇ ਪਰਲੋਕ ਵਿਚ ਸੁਖ ਪਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот и в этой жизни остаётся избавленным от пороков, и в ином мире обретает покой ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 972,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12440,
          "is_rahao": false,
          "gurmukhi": "ਧਨਵੰਤਾ ਹੋਇ ਕਰਿ ਗਰਬਾਵੈ ॥",
          "roman": "dhanvaṅtā hoi kar garbāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਧਨ ਵਾਲਾ ਹੋ ਕੇ ਮਾਣ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, став богатым, начинает гордиться,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12441,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਣ ਸਮਾਨਿ ਕਛੁ ਸੰਗਿ ਨ ਜਾਵੈ ॥",
          "roman": "triṇ samān kachh saṅg na jāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਸ ਦੇ) ਨਾਲ (ਅੰਤ ਵੇਲੇ) ਇਕ ਤੀਲੇ ਜਿਤਨੀ ਭੀ ਕੋਈ ਚੀਜ਼ ਨਹੀਂ ਜਾਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "но с ним в конце не уходит даже вещь величиной с соломинку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12442,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਲਸਕਰ ਮਾਨੁਖ ਊਪਰਿ ਕਰੇ ਆਸ ॥",
          "roman": "bah laskar mānukh ūpar karē ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤੇ ਲਸ਼ਕਰ ਅਤੇ ਮਨੁੱਖਾਂ ਉਤੇ ਬੰਦਾ ਆਸਾਂ ਲਾਈ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек возлагает надежды на множество войск и людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12443,
          "is_rahao": false,
          "gurmukhi": "ਪਲ ਭੀਤਰਿ ਤਾ ਕਾ ਹੋਇ ਬਿਨਾਸ ॥",
          "roman": "pal bhītar tā kā hoi binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪਲਕ ਵਿਚ ਉਸ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ (ਤੇ ਉਹਨਾਂ ਵਿਚੋਂ ਕੋਈ ਭੀ ਸਹਾਈ ਨਹੀਂ ਹੁੰਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "но в одно мгновение всё это гибнет, и никто из них не оказывается помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12444,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਆਪ ਜਾਨੈ ਬਲਵੰਤੁ ॥",
          "roman": "sabh te āp jānē balvaṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ ਸਭ ਨਾਲੋਂ ਬਲੀ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек считает себя сильнее всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12445,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਹੋਇ ਜਾਇ ਭਸਮੰਤੁ ॥",
          "roman": "khin meh hoi jāi bhasmaṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਅੰਤ ਵੇਲੇ) ਇਕ ਖਿਣ ਵਿਚ (ਸੜ ਕੇ) ਸੁਆਹ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но в один миг в конце сгорает и становится пеплом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12446,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੈ ਨ ਬਦੈ ਆਪਿ ਅਹੰਕਾਰੀ ॥",
          "roman": "kisē na badē āp ahaṅkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਬੰਦਾ) ਆਪ (ਇਤਨਾ) ਅਹੰਕਾਰੀ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ ਕਿਸੇ ਦੀ ਭੀ ਪਰਵਾਹ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто сам становится настолько гордым, что ни с кем не считается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12447,
          "is_rahao": false,
          "gurmukhi": "ਧਰਮ ਰਾਇ ਤਿਸੁ ਕਰੇ ਖੁਆਰੀ ॥",
          "roman": "dharam rāi tis karē khuārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਮਰਾਜ (ਅੰਤ ਵੇਲੇ) ਉਸ ਦੀ ਮਿੱਟੀ ਪਲੀਤ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того Дхарам Радж в конце унижает и позорит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12448,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਜਾ ਕਾ ਮਿਟੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "gur prasād jā kā miṭē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦੀ ਦਇਆ ਨਾਲ ਜਿਸ ਦਾ ਅਹੰਕਾਰ ਮਿਟਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, чья гордыня исчезает по милости Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12449,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਨਾਨਕ ਦਰਗਹ ਪਰਵਾਨੁ ॥੨॥",
          "roman": "so jan nānak dargeh parvān ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ, ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਕਬੂਲ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек, о Нанак, принимается в Божьей даргах ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 973,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12450,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕਰਮ ਕਰੈ ਹਉ ਧਾਰੇ ॥",
          "roman": "koṭ karam karē hau dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਮਨੁੱਖ) ਕਰੋੜਾਂ (ਧਾਰਮਿਕ) ਕੰਮ ਕਰੇ (ਤੇ ਉਹਨਾਂ ਦਾ) ਅਹੰਕਾਰ (ਭੀ) ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек совершает миллионы религиозных дел и ещё гордится ими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12451,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਮੁ ਪਾਵੈ ਸਗਲੇ ਬਿਰਥਾਰੇ ॥",
          "roman": "sram pāvē sagle birthāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਹ ਸਾਰੇ ਕੰਮ ਵਿਅਰਥ ਹਨ, (ਉਹਨਾਂ ਕੰਮਾਂ ਦਾ ਫਲ ਉਸ ਨੂੰ ਕੇਵਲ) ਥਕੇਵਾਂ (ਹੀ) ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то все эти дела напрасны, а плод их для него — лишь усталость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12452,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਤਪਸਿਆ ਕਰੇ ਅਹੰਕਾਰ ॥",
          "roman": "anik tapasīā karē ahaṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਤਪ ਦੇ ਸਾਧਨ ਕਰ ਕੇ ਜੇ ਇਹਨਾਂ ਦਾ ਮਾਣ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если, совершив множество аскез, он гордится ими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12453,
          "is_rahao": false,
          "gurmukhi": "ਨਰਕ ਸੁਰਗ ਫਿਰਿ ਫਿਰਿ ਅਵਤਾਰ ॥",
          "roman": "narak surag phir phir avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਉਹ ਭੀ) ਨਰਕਾਂ ਸੁਰਗਾਂ ਵਿਚ ਹੀ ਮੁੜ ਮੁੜ ਜੰਮਦਾ ਹੈ (ਭਾਵ, ਕਦੇ ਸੁਖ ਤੇ ਕਦੇ ਦੁਖ ਭੋਗਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "то и тогда вновь и вновь рождается в адах и небесах, то есть испытывает то счастье, то страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12454,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਤਨ ਕਰਿ ਆਤਮ ਨਹੀ ਦ੍ਰਵੈ ॥",
          "roman": "anik jatan kar ātam nahī dravē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜਤਨ ਕੀਤਿਆਂ ਜੇ ਹਿਰਦਾ ਨਰਮ ਨਹੀਂ ਹੁੰਦਾ ਤਾਂ ਦੱਸੋ,"
            },
            "sahib_singh_ru": {
              "main": "Если после множества усилий сердце не становится мягким, то скажи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12455,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਰਗਹ ਕਹੁ ਕੈਸੇ ਗਵੈ ॥",
          "roman": "har dargeh kaho kēsē gavē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਕਿਵੇਂ ਪਹੁੰਚ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "как такой человек сможет прийти в Божью даргах?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12456,
          "is_rahao": false,
          "gurmukhi": "ਆਪਸ ਕਉ ਜੋ ਭਲਾ ਕਹਾਵੈ ॥",
          "roman": "āpas kau jo bhalā kahāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ ਨੇਕ ਅਖਵਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто хочет, чтобы его называли добродетельным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12457,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਭਲਾਈ ਨਿਕਟਿ ਨ ਆਵੈ ॥",
          "roman": "tiseh bhalāī nikaṭ na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨੇਕੀ ਉਸ ਦੇ ਨੇੜੇ ਭੀ ਨਹੀਂ ਢੁੱਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "к тому и близко не подходит добродетель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12458,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕੀ ਰੇਨ ਜਾ ਕਾ ਮਨੁ ਹੋਇ ॥",
          "roman": "sarab kī ren jā kā man hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਸਭਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, чей ум становится пылью у ног всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12459,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਾ ਕੀ ਨਿਰਮਲ ਸੋਇ ॥੩॥",
          "roman": "kaho nānak tā kī nirmal soi ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਖ, ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਦੀ ਸੋਹਣੀ ਸੋਭਾ ਖਿਲਰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "скажи, о Нанак, — того человека озаряет чистая прекрасная слава ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 974,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12460,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਲਗੁ ਜਾਨੈ ਮੁਝ ਤੇ ਕਛੁ ਹੋਇ ॥",
          "roman": "jab lag jānē mujh te kachh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਜਦ ਤਕ ਇਹ ਸਮਝਦਾ ਹੈ ਕਿ ਮੈਥੋਂ ਕੁਝ ਹੋ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек думает, что от него самого что то может быть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12461,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਇਸ ਕਉ ਸੁਖੁ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "tab is kau sukh nāhī koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਾਈਂ ਇਸ ਨੂੰ ਕੋਈ ਸੁਖ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "до тех пор у него нет никакого покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12462,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਇਹ ਜਾਨੈ ਮੈ ਕਿਛੁ ਕਰਤਾ ॥",
          "roman": "jab ih jānē mē kichh kartā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਇਹ ਸਮਝਦਾ ਹੈ ਕਿ ਮੈਂ (ਆਪਣੇ ਬਲ ਨਾਲ) ਕੁਝ ਕਰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Пока он считает, что я сам своей силой что то делаю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12463,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲਗੁ ਗਰਭ ਜੋਨਿ ਮਹਿ ਫਿਰਤਾ ॥",
          "roman": "tab lag garabh jon meh phirtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ (ਵੱਖਰਾ-ਪਨ ਦੇ ਕਾਰਣ) ਜੂਨਾਂ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "до тех пор из за чувства отдельности он остаётся в круге рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12464,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਧਾਰੈ ਕੋਊ ਬੈਰੀ ਮੀਤੁ ॥",
          "roman": "jab dhārē koū bēry mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਮਨੁੱਖ ਕਿਸੇ ਨੂੰ ਵੈਰੀ ਤੇ ਕਿਸੇ ਨੂੰ ਮਿਤ੍ਰ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек считает одного врагом, а другого другом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12465,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲਗੁ ਨਿਹਚਲੁ ਨਾਹੀ ਚੀਤੁ ॥",
          "roman": "tab lag nihchal nāhī chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ ਇਸ ਦਾ ਮਨ ਟਿਕਾਣੇ ਨਹੀਂ ਆਉਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "до тех пор его ум не приходит в устойчивость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12466,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਲਗੁ ਮੋਹ ਮਗਨ ਸੰਗਿ ਮਾਇ ॥",
          "roman": "jab lag moh magan saṅg māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਬੰਦਾ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਗ਼ਰਕ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек погружён в привязанность к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12467,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲਗੁ ਧਰਮ ਰਾਇ ਦੇਇ ਸਜਾਇ ॥",
          "roman": "tab lag dharam rāi dei sajāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ ਇਸ ਨੂੰ ਧਰਮ-ਰਾਜ ਡੰਡ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "до тех пор Дхарам Радж подвергает его наказанию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12468,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਬੰਧਨ ਤੂਟੈ ॥",
          "roman": "prabh kirpā te bandhan tūṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ) ਬੰਧਨ ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ ਟੁੱਟਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Оковы майи разрываются по милости Прабху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12469,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਹਉ ਛੂਟੈ ॥੪॥",
          "roman": "gur prasād nānak hau chhūṭē ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮਨੁੱਖ ਦੀ ਹਉਮੈ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੁੱਕਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, а хоумэ человека прекращается по милости Гуру ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 975,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12470,
          "is_rahao": false,
          "gurmukhi": "ਸਹਸ ਖਟੇ ਲਖ ਕਉ ਉਠਿ ਧਾਵੈ ॥",
          "roman": "sahas khaṭe lakh kau uṭh dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ) ਹਜ਼ਾਰਾਂ (ਰੁਪਏ) ਕਮਾਉਂਦਾ ਹੈ ਤੇ ਲੱਖਾਂ (ਰੁਪਇਆਂ) ਦੀ ਖ਼ਾਤਰ ਉੱਠ ਦੌੜਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Человек зарабатывает тысячи и вскакивает бежать за сотнями тысяч,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
