{
  "ang": 279,
  "shabads": [
    {
      "shabad_id": 975,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12471,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਪਤਿ ਨ ਆਵੈ ਮਾਇਆ ਪਾਛੈ ਪਾਵੈ ॥",
          "roman": "tripaṭ na āvē māiā pāchhē pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਜਮ੍ਹਾ ਕਰੀ ਜਾਂਦਾ ਹੈ, (ਪਰ) ਰੱਜਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "копит майю, но не насыщается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12472,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਭੋਗ ਬਿਖਿਆ ਕੇ ਕਰੈ ॥",
          "roman": "anik bhog bikhīā ke karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੀਆਂ ਅਨੇਕਾਂ ਮੌਜਾਂ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он наслаждается множеством удовольствий майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12473,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਤ੍ਰਿਪਤਾਵੈ ਖਪਿ ਖਪਿ ਮਰੈ ॥",
          "roman": "nah triptāvē khap khap marē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਸੱਲੀ ਨਹੀਂ ਸੁ ਹੁੰਦੀ, (ਭੋਗਾਂ ਦੇ ਮਗਰ ਹੋਰ ਭੱਜਦਾ ਹੈ ਤੇ) ਬੜਾ ਦੁੱਖੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но удовлетворения не получает, мечется за наслаждениями и сильно мучается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12474,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਾ ਸੰਤੋਖ ਨਹੀ ਕੋਊ ਰਾਜੈ ॥",
          "roman": "binā santoḵh nahī koū rājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਅੰਦਰ ਸੰਤੋਖ ਨਾਹ ਹੋਵੇ, ਤਾਂ ਕੋਈ (ਮਨੁੱਖ) ਰੱਜਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Без внутреннего довольства никто не бывает насыщен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12475,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨ ਮਨੋਰਥ ਬ੍ਰਿਥੇ ਸਭ ਕਾਜੈ ॥",
          "roman": "supan manorath brithē sabh kājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਸੁਫ਼ਨਿਆਂ ਤੋਂ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ, ਤਿਵੇਂ (ਸੰਤੋਖ-ਹੀਣ ਮਨੁੱਖ ਦੇ) ਸਾਰੇ ਕੰਮ ਤੇ ਖ਼ਾਹਸ਼ਾਂ ਵਿਅਰਥ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "как нет пользы от сна, так и все дела и желания человека без довольства напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12476,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਰੰਗਿ ਸਰਬ ਸੁਖੁ ਹੋਇ ॥",
          "roman": "nām raṅg sarab sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਮੌਜ ਵਿਚ (ਹੀ) ਸਾਰਾ ਸੁਖ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В радости Нам заключено всё блаженство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12477,
          "is_rahao": false,
          "gurmukhi": "ਬਡਭਾਗੀ ਕਿਸੈ ਪਰਾਪਤਿ ਹੋਇ ॥",
          "roman": "baḍbhāgī kisē parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ ਇਹ ਸੁਖ) ਕਿਸੇ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਨੂੰ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и это счастье достаётся лишь кому то очень удачливому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12478,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਆਪੇ ਆਪਿ ॥",
          "roman": "karan karāvan āpe āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ) ਪ੍ਰਭੂ ਆਪ ਹੀ ਸਭ ਕੁਝ ਕਰਨ ਦੇ ਤੇ (ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਉਣ ਦੇ ਸਮਰੱਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Прабху Сам способен всё делать и побуждать делать через существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12479,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਨਾਨਕ ਹਰਿ ਜਾਪਿ ॥੫॥",
          "roman": "sadā sadā nānak har jāp ||5||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, всегда помни этого Хари ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 976,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12480,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਕਰਨੈਹਾਰੁ ॥",
          "roman": "karan karāvan karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਸਭ ਕੁਝ ਕਰਨ ਜੋਗਾ ਹੈ ਤੇ (ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਉਣ ਜੋਗਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Прабху Сам способен всё делать и побуждать к действию через существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12481,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਕੈ ਹਾਥਿ ਕਹਾ ਬੀਚਾਰੁ ॥",
          "roman": "is kē hāth kahā bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਚਾਰ ਕੇ ਵੇਖ ਲੈ, ਇਸ ਜੀਵ ਦੇ ਹੱਥ ਕੁਝ ਭੀ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Подумай и посмотри: в руках этого существа нет вообще ничего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12482,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਦ੍ਰਿਸਟਿ ਕਰੇ ਤੈਸਾ ਹੋਇ ॥",
          "roman": "jēsī drisṭ kare tēsā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜਿਹੋ ਜਿਹੀ ਨਜ਼ਰ (ਬੰਦੇ ਵਲ) ਕਰਦਾ ਹੈ (ਬੰਦਾ) ਉਹੋ ਜਿਹਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Какой взгляд Прабху обращает на человека, таким тот и становится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12483,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਆਪਿ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "āpe āp āp prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਆਪ ਹੀ ਆਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот Прабху Сам и есть Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12484,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕੀਨੋ ਸੁ ਅਪਨੈ ਰੰਗਿ ॥",
          "roman": "jo kichh kīno su apnē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਉਸ ਬਣਾਇਆ ਹੈ ਆਪਣੀ ਮੌਜ ਵਿਚ ਬਣਾਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Всё, что Он создал, создано Им в собственной радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12485,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਦੂਰਿ ਸਭਹੂ ਕੈ ਸੰਗਿ ॥",
          "roman": "sabh te dūr sabhhū kē saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਗ-ਸੰਗ ਭੀ ਹੈ ਤੇ ਸਭ ਤੋਂ ਵੱਖਰਾ ਭੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он и вместе со всеми существами, и в то же время отличен от всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12486,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝੈ ਦੇਖੈ ਕਰੈ ਬਿਬੇਕ ॥",
          "roman": "būjhē dekhē karē bibek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਸਭ ਕੁਝ ਸਮਝਦਾ ਹੈ, ਵੇਖਦਾ ਹੈ ਤੇ ਪਛਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Прабху всё понимает, всё видит и всё распознаёт,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12487,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਏਕ ਆਪਹਿ ਅਨੇਕ ॥",
          "roman": "āpeh ek āpeh anek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ ਇੱਕ ਹੈ ਤੇ ਆਪ ਹੀ ਅਨੇਕ (ਰੂਪ) ਧਾਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам один и Сам же принимает множество форм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12488,
          "is_rahao": false,
          "gurmukhi": "ਮਰੈ ਨ ਬਿਨਸੈ ਆਵੈ ਨ ਜਾਇ ॥",
          "roman": "marē na binsē āvē na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਨਾਹ ਕਦੇ ਮਰਦਾ ਹੈ ਨ ਬਿਨਸਦਾ ਹੈ; ਨਾਹ ਜੰਮਦਾ ਹੈ ਨ ਮਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Он никогда не умирает и не исчезает, не рождается и не умирает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12489,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਦ ਹੀ ਰਹਿਆ ਸਮਾਇ ॥੬॥",
          "roman": "nānak sad hī rahiā samāi ||6||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਸਦਾ ਹੀ ਆਪਣੇ ਆਪ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, Прабху вечно пребывает в Самом Себе ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 977,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12490,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਪਦੇਸੈ ਸਮਝੈ ਆਪਿ ॥",
          "roman": "āp updesē samjhē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ ਸਿੱਖਿਆ ਦੇਂਦਾ ਹੈ ਤੇ ਆਪ ਹੀ (ਉਸ ਸਿੱਖਿਆ ਨੂੰ) ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он Сам даёт наставление и Сам же понимает это наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12491,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਰਚਿਆ ਸਭ ਕੈ ਸਾਥਿ ॥",
          "roman": "āpe rachiā sabh kē sāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਪ੍ਰਭੂ ਆਪ ਹੀ ਸਭ ਜੀਵਾਂ ਦੇ ਨਾਲ ਮਿਲਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо Прабху Сам соединён со всеми существами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12492,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਕੀਨੋ ਆਪਨ ਬਿਸਥਾਰੁ ॥",
          "roman": "āp kīno āpan bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣਾ ਖਿਲਾਰਾ ਉਸ ਨੇ ਆਪ ਹੀ ਬਣਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Своё развёртывание Он Сам и сотворил,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12493,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਛੁ ਉਸ ਕਾ ਓਹੁ ਕਰਨੈਹਾਰੁ ॥",
          "roman": "sabh kachh us kā oh karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੀ) ਹਰੇਕ ਸ਼ੈ ਉਸ ਦੀ ਬਣਾਈ ਹੋਈ ਹੈ, ਉਹ ਬਨਾਉਣ ਜੋਗਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "каждая вещь в мире создана Им, Он способен творить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12494,
          "is_rahao": false,
          "gurmukhi": "ਉਸ ਤੇ ਭਿੰਨ ਕਹਹੁ ਕਿਛੁ ਹੋਇ ॥",
          "roman": "us te bhinn kaho kichh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ, ਉਸ ਤੋਂ ਵੱਖਰਾ ਕੁਝ ਹੋ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Скажи, может ли что то существовать отдельно от Него?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12495,
          "is_rahao": false,
          "gurmukhi": "ਥਾਨ ਥਨੰਤਰਿ ਏਕੈ ਸੋਇ ॥",
          "roman": "thān thanaṅtar ekē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਥਾਂ ਉਹ ਪ੍ਰਭੂ ਆਪ ਹੀ (ਮੌਜੂਦ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Во всяком месте присутствует только Сам этот Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12496,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਚਲਿਤ ਆਪਿ ਕਰਣੈਹਾਰ ॥",
          "roman": "apune chalit āp karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਖੇਲ ਆਪ ਹੀ ਕਰਨ ਜੋਗਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Свои игры Он Сам способен совершать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12497,
          "is_rahao": false,
          "gurmukhi": "ਕਉਤਕ ਕਰੈ ਰੰਗ ਆਪਾਰ ॥",
          "roman": "kautak karē raṅg apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇਅੰਤ ਰੰਗਾਂ ਦੇ ਤਮਾਸ਼ੇ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он устраивает зрелища бесконечных красок и игр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12498,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਆਪਿ ਮਨ ਅਪੁਨੇ ਮਾਹਿ ॥",
          "roman": "man meh āp man apune māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੇ) ਮਨ ਵਿਚ ਆਪ ਵੱਸ ਰਿਹਾ ਹੈ, (ਜੀਵਾਂ ਨੂੰ) ਆਪਣੇ ਮਨ ਵਿਚ ਟਿਕਾਈ ਬੈਠਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "В умах существ Он Сам пребывает и самих существ держит в Своём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12499,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀਮਤਿ ਕਹਨੁ ਨ ਜਾਇ ॥੭॥",
          "roman": "nānak kīmat kahan na jāi ||7||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦਾ ਮੁੱਲ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, Его цену невозможно выразить ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 978,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12500,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਸਤਿ ਸਤਿ ਪ੍ਰਭੁ ਸੁਆਮੀ ॥",
          "roman": "sat sat sat prabh suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਦਾ) ਮਾਲਕ ਪ੍ਰਭੂ ਸਦਾ ਹੀ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Владыка Прабху вечно и неизменно пребывающий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12501,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਕਿਨੈ ਵਖਿਆਨੀ ॥",
          "roman": "gur parsād kinē vaḵẖiānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਕਿਸੇ ਵਿਰਲੇ ਨੇ (ਇਹ ਗੱਲ) ਦੱਸੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру это поведал кто то редкий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12502,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸਚੁ ਸਚੁ ਸਭੁ ਕੀਨਾ ॥",
          "roman": "sach sach sach sabh kīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਉਸ ਨੇ ਬਣਾਇਆ ਹੈ ਉਹ ਭੀ ਮੁਕੰਮਲ ਹੈ (ਭਾਵ, ਅਧੂਰਾ ਨਹੀਂ)"
            },
            "sahib_singh_ru": {
              "main": "Всё, что Он создал, тоже совершенно, не неполно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12503,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮਧੇ ਕਿਨੈ ਬਿਰਲੈ ਚੀਨਾ ॥",
          "roman": "koṭ madhē kinē birlē chīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਗੱਲ ਕ੍ਰੋੜਾਂ ਵਿਚੋਂ ਕਿਸੇ ਵਿਰਲੇ ਨੇ ਪਛਾਣੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и это среди миллионов распознал лишь кто то редкий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12504,
          "is_rahao": false,
          "gurmukhi": "ਭਲਾ ਭਲਾ ਭਲਾ ਤੇਰਾ ਰੂਪ ॥",
          "roman": "bhalā bhalā bhalā terā rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਰੂਪ ਕਿਆ ਪਿਆਰਾ ਪਿਆਰਾ ਹੈ!"
            },
            "sahib_singh_ru": {
              "main": "Как же прекрасен, прекрасен, прекрасен Твой образ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12505,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਸੁੰਦਰ ਅਪਾਰ ਅਨੂਪ ॥",
          "roman": "at sundar apār anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੱਤ ਸੋਹਣੇ, ਬੇਅੰਤ ਤੇ ਬੇ-ਮਿਸਾਲ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О предельно прекрасный, беспредельный и несравненный Прабху!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12506,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਨਿਰਮਲ ਨਿਰਮਲ ਤੇਰੀ ਬਾਣੀ ॥",
          "roman": "nirmal nirmal nirmal terī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਬੋਲੀ ਭੀ ਮਿੱਠੀ ਮਿੱਠੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Твоя речь тоже чиста, чиста, чиста и сладка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12507,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸੁਨੀ ਸ੍ਰਵਨ ਬਖੵਾਣੀ ॥",
          "roman": "ghaṭ ghaṭ sunī sravan baḵẖiānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਕੰਨਾਂ ਦੀ ਰਾਹੀਂ ਸੁਣੀ ਜਾ ਰਹੀ ਹੈ, ਤੇ ਜੀਭ ਨਾਲ ਉੱਚਾਰੀ ਜਾ ਰਹੀ ਹੈ (ਭਾਵ, ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਤੂੰ ਆਪ ਹੀ ਬੋਲ ਰਿਹਾ ਹੈਂ)।"
            },
            "sahib_singh_ru": {
              "main": "в каждом теле она слышится через уши и произносится языком, то есть в каждом теле Ты Сам говоришь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12508,
          "is_rahao": false,
          "gurmukhi": "ਪਵਿਤ੍ਰ ਪਵਿਤ੍ਰ ਪਵਿਤ੍ਰ ਪੁਨੀਤ ॥",
          "roman": "pavitr pavitr pavitr punīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਵਿਤ੍ਰ ਹੀ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот становится совершенно чистым и священным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12509,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪੈ ਨਾਨਕ ਮਨਿ ਪ੍ਰੀਤਿ ॥੮॥੧੨॥",
          "roman": "nām japē nānak man prīt ||8||12||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੋ ਅਜੇਹੇ ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਪ੍ਰੀਤ ਨਾਲ ਮਨ ਵਿਚ ਜਪਦਾ ਹੈ ॥੮॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кто с любовью в сердце повторяет Имя такого Прабху ॥8॥12॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 979,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12510,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12511,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਰਨਿ ਜੋ ਜਨੁ ਪਰੈ ਸੋ ਜਨੁ ਉਧਰਨਹਾਰ ॥",
          "roman": "sant saran jo jan parē so jan udharanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਸੰਤਾਂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ, ਉਹ ਮਾਇਆ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਬਚ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который приходит под защиту святых, спасается от уз майи;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12512,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਨਿੰਦਾ ਨਾਨਕਾ ਬਹੁਰਿ ਬਹੁਰਿ ਅਵਤਾਰ ॥੧॥",
          "roman": "sant kī nindā nānkā bahur bahur avtār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਹੇ ਨਾਨਕ! ਸੰਤਾਂ ਦੀ ਨਿੰਦਿਆ ਕਰਨ ਨਾਲ ਮੁੜ ਮੁੜ ਜੰਮੀਦਾ ਹੈ (ਭਾਵ, ਜਨਮ ਮਰਨ ਦੇ ਚੱਕ੍ਰ ਵਿਚ ਪੈ ਜਾਈਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о Нанак, из-за поношения святых человек снова и снова рождается, то есть попадает в круг рождения и смерти ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 980,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12513,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12514,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਆਰਜਾ ਘਟੈ ॥",
          "roman": "sant kē dūkhan ārjā ghaṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਕਰਨ ਨਾਲ (ਮਨੁੱਖ ਦੀ) ਉਮਰ (ਵਿਅਰਥ ਹੀ) ਗੁਜ਼ਰਦੀ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого жизнь человека проходит впустую,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12515,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਜਮ ਤੇ ਨਹੀ ਛੁਟੈ ॥",
          "roman": "sant kē dūkhan jam te nahī chhuṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਕੀਤਿਆਂ ਮਨੁੱਖ ਜਮਾਂ ਤੋਂ ਬਚ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "потому что, понося святого, человек не может спастись от ямов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12516,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਸੁਖੁ ਸਭੁ ਜਾਇ ॥",
          "roman": "sant kē dūkhan sukh sabh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਕੀਤਿਆਂ ਸਾਰਾ (ਹੀ) ਸੁਖ (ਨਾਸ ਹੋ) ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого весь покой исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12517,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਨਰਕ ਮਹਿ ਪਾਇ ॥",
          "roman": "sant kē dūkhan narak meh pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਨੁੱਖ ਨਰਕ ਵਿਚ (ਭਾਵ, ਘੋਰ ਦੁਖਾਂ ਵਿਚ) ਪੈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и человек попадает в ад, то есть в тяжкие страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12518,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਮਤਿ ਹੋਇ ਮਲੀਨ ॥",
          "roman": "sant kē dūkhan mat hoi malīn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਕਰਨ ਨਾਲ (ਮਨੁੱਖ ਦੀ) ਮਤਿ ਮੈਲੀ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого разум человека становится грязным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12519,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਸੋਭਾ ਤੇ ਹੀਨ ॥",
          "roman": "sant kē dūkhan sobhā te hīn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਜਗਤ ਵਿਚ) ਮਨੁੱਖ ਸੋਭਾ ਤੋਂ ਸੱਖਣਾ ਰਹਿ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и человек в мире остаётся лишённым чести."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12520,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੇ ਹਤੇ ਕਉ ਰਖੈ ਨ ਕੋਇ ॥",
          "roman": "sant ke hate kau rakhē na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੇ ਫਿਟਕਾਰੇ ਹੋਏ ਬੰਦੇ ਦੀ ਕੋਈ ਮਨੁੱਖ ਸਹੈਤਾ ਨਹੀਂ ਕਰ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Никто не может помочь тому, кто был проклят святым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12521,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਥਾਨ ਭ੍ਰਸਟੁ ਹੋਇ ॥",
          "roman": "sant kē dūkhan thān bhrasaṭ hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸੰਤ ਦੀ ਨਿੰਦਾ ਕੀਤਿਆਂ (ਨਿੰਦਕ ਦਾ) ਹਿਰਦਾ ਗੰਦਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что из-за поношения святого сердце хулителя становится грязным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12522,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕ੍ਰਿਪਾਲ ਕ੍ਰਿਪਾ ਜੇ ਕਰੈ ॥",
          "roman": "sant kirpāl kirpā je karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜੇ ਕ੍ਰਿਪਾਲ ਸੰਤ ਆਪ ਕਿਰਪਾ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Но если милостивый святой сам проявит милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12523,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੰਤਸੰਗਿ ਨਿੰਦਕੁ ਭੀ ਤਰੈ ॥੧॥",
          "roman": "nānak santsang nindak bhī tarē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਹੇ ਨਾਨਕ! ਸੰਤ ਦੀ ਸੰਗਤਿ ਵਿਚ ਨਿੰਦਕ ਭੀ (ਪਾਪਾਂ ਤੋਂ) ਬਚ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда, о Нанак, даже хулитель в обществе святого спасается от грехов ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 981,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12524,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੇ ਦੂਖਨ ਤੇ ਮੁਖੁ ਭਵੈ ॥",
          "roman": "sant ke dūkhan te mukh bhavē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਾ ਕਰਨ ਨਾਲ (ਨਿੰਦਕ ਦਾ) ਚੇਹਰਾ ਹੀ ਭ੍ਰਸ਼ਟਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого лицо хулителя становится обезображенным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12525,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੈ ਦੂਖਨਿ ਕਾਗ ਜਿਉ ਲਵੈ ॥",
          "roman": "santan kē dūkhan kāg jiu lavē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਨਿੰਦਕ) (ਥਾਂ ਥਾਂ) ਕਾਂ ਵਾਂਗ ਲਉਂ ਲਉਂ ਕਰਦਾ ਹੈ (ਨਿੰਦਾ ਦੇ ਬਚਨ ਬੋਲਦਾ ਫਿਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и хулитель, словно ворона, всюду каркает, то есть ходит и говорит слова поношения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12526,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੈ ਦੂਖਨਿ ਸਰਪ ਜੋਨਿ ਪਾਇ ॥",
          "roman": "santan kē dūkhan sarap jon pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਾ ਕੀਤਿਆਂ (ਖੋਟਾ ਸੁਭਾਉ ਬਣ ਜਾਣ ਤੇ) ਮਨੁੱਖ ਸੱਪ ਦੀ ਜੂਨੇ ਜਾ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Понося святого, человек, сделавшись дурного нрава, попадает в змеиное рождение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12527,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਤ੍ਰਿਗਦ ਜੋਨਿ ਕਿਰਮਾਇ ॥",
          "roman": "sant kē dūkhan trigad jon kirmāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਕਿਰਮ ਆਦਿਕ ਨਿੱਕੀਆਂ ਜੂਨਾਂ ਵਿਚ (ਭਟਕਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и блуждает в мелких рождениях, таких как черви и подобные им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12528,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੈ ਦੂਖਨਿ ਤ੍ਰਿਸਨਾ ਮਹਿ ਜਲੈ ॥",
          "roman": "santan kē dūkhan trisanā meh jalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਦੇ ਕਾਰਨ (ਨਿੰਦਕ) ਤ੍ਰਿਸਨਾ (ਦੀ ਅੱਗ) ਵਿਚ ਸੜਦਾ ਭੁੱਜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого хулитель горит и мучается в огне жажды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12529,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਸਭੁ ਕੋ ਛਲੈ ॥",
          "roman": "sant kē dūkhan sabh ko chhalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਹਰੇਕ ਮਨੁੱਖ ਨੂੰ ਧੋਖਾ ਦੇਂਦਾ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и обманывает каждого человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12530,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਤੇਜੁ ਸਭੁ ਜਾਇ ॥",
          "roman": "sant kē dūkhan tej sabh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਿਆ ਕੀਤਿਆਂ ਮਨੁੱਖ ਦਾ ਸਾਰਾ ਤੇਜ ਪ੍ਰਤਾਪ ਹੀ ਨਸ਼ਟ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за поношения святого всё величие и слава человека исчезают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12531,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਦੂਖਨਿ ਨੀਚੁ ਨੀਚਾਇ ॥",
          "roman": "sant kē dūkhan nīch nīchāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਨਿੰਦਕ) ਮਹਾ ਨੀਚ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и хулитель становится совсем низким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12532,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਦੋਖੀ ਕਾ ਥਾਉ ਕੋ ਨਾਹਿ ॥",
          "roman": "sant dokhī kā thāu ko nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਨਿੰਦਾ ਕਰਨ ਵਾਲਿਆਂ ਦਾ ਕੋਈ ਆਸਰਾ ਨਹੀਂ ਰਹਿੰਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "У тех, кто поносит святых, не остаётся никакой опоры;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
