{
  "ang": 287,
  "shabads": [
    {
      "shabad_id": 1026,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12949,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਕ੍ਰਿਪਾ ਜਿਸੁ ਆਪਿ ਕਰੇਇ ॥",
          "roman": "apnī kirpā jis āp karei ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਤੇ (ਪ੍ਰਭੂ ਆਪਣੀ ਮੇਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, на кого Сам Господь простирает Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12950,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਸੇਵਕੁ ਗੁਰ ਕੀ ਮਤਿ ਲੇਇ ॥੨॥",
          "roman": "Nānak so sevak gur kī mat lei ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸੇਵਕ ਸਤਿਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот слуга принимает наставление Сатгуру. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1027,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12951,
          "is_rahao": false,
          "gurmukhi": "ਬੀਸ ਬਿਸਵੇ ਗੁਰ ਕਾ ਮਨੁ ਮਾਨੈ ॥",
          "roman": "bīs bisve gur kā man mānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸੇਵਕ ਆਪਣੇ ਸਤਿਗੁਰੂ ਨੂੰ ਆਪਣੀ ਸਰਧਾ ਦਾ ਪੂਰੇ ਤੌਰ ਤੇ ਯਕੀਨ ਦਿਵਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот слуга, который полностью убеждает своего Сатгуру в искренности своей преданности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12952,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਪਰਮੇਸੁਰ ਕੀ ਗਤਿ ਜਾਨੈ ॥",
          "roman": "so sevak parmesur kī gat jānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਕਾਲ ਪੁਰਖ ਦੀ ਅਵਸਥਾ ਨੂੰ ਸਮਝ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "понимает состояние Пармешура."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12953,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਤਿਗੁਰੁ ਜਿਸੁ ਰਿਦੈ ਹਰਿ ਨਾਉ ॥",
          "roman": "so satgur jis ridē har nāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ (ਭੀ) ਉਹ ਹੈ ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "И Сатгуру — тот, в чьём сердце обитает Имя Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12954,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਾਰ ਗੁਰ ਕਉ ਬਲਿ ਜਾਉ ॥",
          "roman": "anik bār gur kau bal jāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਐਸੇ) ਗੁਰੂ ਤੋਂ ਕਈ ਵਾਰੀ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "я многократно иду в жертву такому Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12955,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਜੀਅ ਕਾ ਦਾਤਾ ॥",
          "roman": "sarab nidhān jīa kā dātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਤਿਗੁਰੂ) ਸਾਰੇ ਖ਼ਜ਼ਾਨਿਆਂ ਦਾ ਤੇ ਆਤਮਕ ਜ਼ਿੰਦਗੀ ਦਾ ਦੇਣ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру — дающий все сокровища и духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12956,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪਾਰਬ੍ਰਹਮ ਰੰਗਿ ਰਾਤਾ ॥",
          "roman": "āṭh pahar pārbrahm rang rātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਅੱਠੇ ਪਹਰ ਅਕਾਲ ਪੁਰਖ ਦੇ ਪਿਆਰ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо все восемь страж он окрашен любовью к Парабрахму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12957,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਮਹਿ ਜਨੁ ਜਨ ਮਹਿ ਪਾਰਬ੍ਰਹਮੁ ॥",
          "roman": "brahm meh jan jan meh pārbrahm ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ) ਸੇਵਕ-(ਸਤਿਗੁਰੂ) ਪ੍ਰਭੂ ਵਿਚ (ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ) ਤੇ (ਪ੍ਰਭੂ ਦੇ) ਸੇਵਕ-ਸਤਿਗੁਰੂ ਵਿਚ ਪ੍ਰਭੂ (ਸਦਾ ਟਿਕਿਆ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Слуга Божий, Сатгуру, пребывает в Боге, и Бог всегда утверждён в слуге Божьем, Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12958,
          "is_rahao": false,
          "gurmukhi": "ਏਕਹਿ ਆਪਿ ਨਹੀ ਕਛੁ ਭਰਮੁ ॥",
          "roman": "ekah āp nahī kachh bharam ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਤੇ ਪ੍ਰਭੂ ਇਕ-ਰੂਪ ਹਨ, ਇਸ ਵਿਚ ਭੁਲੇਖੇ ਵਾਲੀ ਗੱਲ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру и Бог едины, и в этом нет ничего сомнительного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12959,
          "is_rahao": false,
          "gurmukhi": "ਸਹਸ ਸਿਆਨਪ ਲਇਆ ਨ ਜਾਈਐ ॥",
          "roman": "sahas siāṇap laiā na jāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਜ਼ਾਰਾਂ ਚਤੁਰਾਈਆਂ ਨਾਲ ਅਜੇਹਾ ਗੁਰੂ ਮਿਲਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Тысячами хитростей такого Гуру не получить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12960,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਐਸਾ ਗੁਰੁ ਬਡਭਾਗੀ ਪਾਈਐ ॥੩॥",
          "roman": "Nānak aisā gur baḍbhāgī pāīai ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, такой Гуру встречается только по великой удаче. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1028,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12961,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਦਰਸਨੁ ਪੇਖਤ ਪੁਨੀਤ ॥",
          "roman": "saphal darsan pekhat punīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਦੀਦਾਰ (ਸਾਰੇ) ਫਲ ਦੇਣ ਵਾਲਾ ਹੈ, ਦੀਦਾਰ ਕੀਤਿਆਂ ਪਵਿਤ੍ਰ ਹੋ ਜਾਈਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Даршан Гуру плодотворен; увидев его, человек очищается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12962,
          "is_rahao": false,
          "gurmukhi": "ਪਰਸਤ ਚਰਨ ਗਤਿ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "parasat charan gat nirmal rīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨ ਛੋਹਿਆਂ ਉਚੀ ਅਵਸਥਾ ਤੇ ਸੁੱਚੀ ਰਹੁ-ਰੀਤ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "коснувшись стоп Гуру, достигает высокого состояния и чистого образа жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12963,
          "is_rahao": false,
          "gurmukhi": "ਭੇਟਤ ਸੰਗਿ ਰਾਮ ਗੁਨ ਰਵੇ ॥",
          "roman": "bheṭat sang rām gun rave ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ਸਕੀਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в сангате Гуру, можно воспевать качества Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12964,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਦਰਗਹ ਗਵੇ ॥",
          "roman": "pārbrahm kī dargeh gave ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਅਕਾਲ ਪੁਰਖ ਦੀ ਦਰਗਾਹ ਵਿਚ ਪਹੁੰਚ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и достигается доступ ко двору Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12965,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਕਰਿ ਬਚਨ ਕਰਨ ਆਘਾਨੇ ॥",
          "roman": "sun kar bachan karan āghāne ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਬਚਨ ਸੁਣ ਕੇ ਕੰਨ ਰੱਜ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Слыша слова Гуру, уши насыщаются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12966,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਸੰਤੋਖੁ ਆਤਮ ਪਤੀਆਨੇ ॥",
          "roman": "man santokh ātam patīāne ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਸੰਤੋਖ ਆ ਜਾਂਦਾ ਹੈ ਤੇ ਆਤਮਾ ਪਤੀਜ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в уме приходит довольство, и душа убеждается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12967,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਗੁਰੁ ਅਖੵਓ ਜਾ ਕਾ ਮੰਤ੍ਰ ॥",
          "roman": "pūrā gur akhyo jā kā mantar ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਪੂਰਨ ਪੁਰਖ ਹੈ, ਉਸ ਦਾ ਉਪਦੇਸ਼ ਭੀ ਸਦਾ ਲਈ ਅਟੱਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру — совершенная Личность, и его наставление тоже вечно непреложно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12968,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਦ੍ਰਿਸਟਿ ਪੇਖੈ ਹੋਇ ਸੰਤ ॥",
          "roman": "amrit drisaṭ pekhē hoi sant ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਵਲ) ਅਮਰ ਕਰਨ ਵਾਲੀ ਨਜ਼ਰ ਨਾਲ ਤੱਕਦਾ ਹੈ ਓਹੀ ਸੰਤ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, на кого он смотрит животворящим взглядом, сам становится сантом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12969,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਬਿਅੰਤ ਕੀਮਤਿ ਨਹੀ ਪਾਇ ॥",
          "roman": "gun biaṅt kīmat nahī pāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦੇ ਗੁਣ ਬੇਅੰਤ ਹਨ, ਮੁੱਲ ਨਹੀਂ ਪੈ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Качества Сатгуру безграничны, им нет цены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12970,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਲਏ ਮਿਲਾਇ ॥੪॥",
          "roman": "Nānak jis bhāvē tis lae milāi ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਜੀਵ (ਪ੍ਰਭੂ ਨੂੰ) ਚੰਗਾ ਲੱਗਦਾ ਹੈ, ਉਸ ਨੂੰ ਗੁਰੂ ਨਾਲ ਮਿਲਾਉਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, того существа, которое угодно Богу, Он приводит к Гуру. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1029,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12971,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹਬਾ ਏਕ ਉਸਤਤਿ ਅਨੇਕ ॥",
          "roman": "jihbā ek ustat anek ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਦੀ) ਜੀਭ ਇੱਕ ਹੈ, ਪਰ ਉਸ ਪ੍ਰਭੂ ਦੇ ਅਨੇਕਾਂ ਗੁਣ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "У человека один язык, а достоинств у Бога бесчисленно много,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12972,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਪੁਰਖ ਪੂਰਨ ਬਿਬੇਕ ॥ ਕਾਹੂ ਬੋਲ ਨ ਪਹੁਚਤ ਪ੍ਰਾਨੀ ॥",
          "roman": "sat purakh pūran bibek ॥ kāhū bol na pahuchat prānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪੂਰਨ ਪੁਰਖ ਹੈ, ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਅਤੇ ਵਿਆਪਕ ਹੈ। ਮਨੁੱਖ ਕਿਸੇ ਬੋਲ ਦੁਆਰਾ (ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਤਕ) ਪਹੁੰਚ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Он — совершенный Пурух, вечно-пребывающий и всепронизывающий. Ни одним словом человек не может достигнуть качеств Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12973,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰ ਪ੍ਰਭ ਨਿਰਬਾਨੀ ॥",
          "roman": "agam agochar prabh nirbānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ, ਵਾਸਨਾ-ਰਹਿਤ ਹੈ, ਤੇ ਮਨੁੱਖ ਦੇ ਸਰੀਰਕ ਇੰਦ੍ਰਿਆਂ ਦੀ ਉਸ ਤਕ ਪਹੁੰਚ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Бог недостижим, свободен от желаний, и телесные чувства человека не могут до Него дотянуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12974,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਾਹਾਰ ਨਿਰਵੈਰ ਸੁਖਦਾਈ ॥",
          "roman": "nirāhār nirvēr sukhdāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਕਿਸੇ ਖ਼ੁਰਾਕ ਦੀ ਲੋੜ ਨਹੀਂ, ਪ੍ਰਭੂ ਵੈਰ-ਰਹਿਤ ਹੈ (ਸਗੋਂ ਸਭ ਨੂੰ) ਸੁਖ ਦੇਣ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Акал Пурукх не нуждается ни в какой пище, Он без вражды и дарующий счастье всем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12975,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਿਨੈ ਨ ਪਾਈ ॥",
          "roman": "tā kī kīmat kinē na pāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਜੀਵ ਉਸ (ਦੇ ਗੁਣਾਂ) ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾ ਸਕਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "ни одно существо не смогло определить цену Его достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12976,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਭਗਤ ਬੰਦਨ ਨਿਤ ਕਰਹਿ ॥",
          "roman": "anik bhagat bandan nit kareh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਭਗਤ ਸਦਾ (ਪ੍ਰਭੂ ਨੂੰ) ਨਮਸਕਾਰ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Многие бхагаты постоянно склоняются перед Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12977,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਸਿਮਰਹਿ ॥",
          "roman": "charan kamal hirdē simreh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਦੇ ਕਮਲਾਂ ਵਰਗੇ (ਸੋਹਣੇ) ਚਰਨਾਂ ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਸਿਮਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и вспоминают в сердце Его прекрасные, как лотос, стопы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12978,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਬਲਿਹਾਰੀ ਸਤਿਗੁਰ ਅਪਨੇ ॥",
          "roman": "sad balihārī satgur apne ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੇ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я всегда предан своему Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12979,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਐਸਾ ਪ੍ਰਭੁ ਜਪਨੇ ॥੫॥",
          "roman": "Nānak jis prasād aisā prabh japne ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਜਿਸ ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਐਸੇ ਪ੍ਰਭੂ ਨੂੰ ਜਪ ਸਕੀਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, скажи: по милости того Гуру можно медитировать на такого Бога. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1030,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12980,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਹਰਿ ਰਸੁ ਪਾਵੈ ਜਨੁ ਕੋਇ ॥",
          "roman": "ih har ras pāvē jan koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек вкушает этот нектар Имени Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12981,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਪੀਵੈ ਅਮਰੁ ਸੋ ਹੋਇ ॥",
          "roman": "amrit pīvē amar so hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਜੋ ਮਾਣਦਾ ਹੈ) ਉਹ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਪੀਂਦਾ ਹੈ, ਤੇ ਅਮਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и тот, кто вкушает, пьёт нектар Имени и становится бессмертным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12982,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਪੁਰਖ ਕਾ ਨਾਹੀ ਕਦੇ ਬਿਨਾਸ ॥ ਜਾ ਕੈ ਮਨਿ ਪ੍ਰਗਟੇ ਗੁਨਤਾਸ ॥",
          "roman": "us purakh kā nāhī kade binās ॥ jā kē man pragaṭe guntās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ (ਭਾਵ, ਉਹ ਮੁੜ ਮੁੜ ਮੌਤ ਦਾ ਸ਼ਿਕਾਰ ਨਹੀਂ ਹੁੰਦਾ) ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦਾ ਪ੍ਰਕਾਸ਼ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, в чьём уме является Сокровищница качеств, Бог, никогда не погибает, то есть не становится вновь и вновь жертвой смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12983,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਕਾ ਨਾਮੁ ਲੇਇ ॥",
          "roman": "āṭh pahar har kā nām lei ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਤਿਗੁਰੂ) ਅੱਠੇ ਪਹਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру все восемь страж помнит Имя Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12984,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਉਪਦੇਸੁ ਸੇਵਕ ਕਉ ਦੇਇ ॥",
          "roman": "sach updes sevak kau dei ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਭੀ ਇਹੀ ਸੱਚਾ ਉਪਦੇਸ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и своему слуге даёт именно это истинное наставление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12985,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹ ਮਾਇਆ ਕੈ ਸੰਗਿ ਨ ਲੇਪੁ ॥",
          "roman": "moh māiā kē sang na lep ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਨਾਲ ਉਸ ਦਾ ਕਦੇ ਜੋੜ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "С привязанностью к майе у него нет связи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12986,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਰਾਖੈ ਹਰਿ ਹਰਿ ਏਕੁ ॥",
          "roman": "man meh rākhē har har ek ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਆਪਣੇ ਮਨ ਵਿਚ ਇਕ ਪ੍ਰਭੂ ਨੂੰ ਟਿਕਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "он всегда удерживает в своём уме одного лишь Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12987,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਕਾਰ ਦੀਪਕ ਪਰਗਾਸੇ ॥",
          "roman": "andhkār dīpak pargāse ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੇ ਅੰਦਰੋਂ) (ਨਾਮ-ਰੂਪ) ਦੀਵੇ ਦੇ ਨਾਲ (ਅਗਿਆਨਤਾ ਦਾ) ਹਨੇਰਾ (ਹਟ ਕੇ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда внутри зажигается светильник Имени, тьма неведения отступает и становится светло,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12988,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਰਮ ਮੋਹ ਦੁਖ ਤਹ ਤੇ ਨਾਸੇ ॥੬॥",
          "roman": "Nānak bharam moh dukh teh te nāse ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦੇ ਭੁਲੇਖੇ ਤੇ ਮੋਹ ਦੇ (ਕਾਰਣ ਪੈਦਾ ਹੋਏ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, у такого человека исчезают заблуждение, привязанность и страдания, рождённые ими. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1031,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12989,
          "is_rahao": false,
          "gurmukhi": "ਤਪਤਿ ਮਾਹਿ ਠਾਢਿ ਵਰਤਾਈ ॥",
          "roman": "tapat māh ṭhāḍ varṭāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਪੂਰੇ ਉਪਦੇਸ਼ ਦੁਆਰਾ (ਵਿਕਾਰਾਂ ਦੀ) ਤਪਸ਼ ਵਿਚ (ਵੱਸਦਿਆਂ ਭੀ, ਪ੍ਰਭੂ ਨੇ ਸਾਡੇ ਅੰਦਰ) ਠੰਢ ਵਰਤਾ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, через совершенное наставление Гуру среди жара пороков внутри нас воцарилась прохлада,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12990,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦੁ ਭਇਆ ਦੁਖ ਨਾਠੇ ਭਾਈ ॥",
          "roman": "anad bhaiā dukh nāṭhe bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਖ ਹੀ ਸੁਖ ਹੋ ਗਿਆ ਹੈ, ਦੁੱਖ ਨੱਸ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "стало одно лишь блаженство, страдания ушли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12991,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਨ ਕੇ ਮਿਟੇ ਅੰਦੇਸੇ ॥",
          "roman": "janam maran ke miṭe andese ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਨਮ ਮਰਨ ਦੇ (ਗੇੜ ਵਿਚ ਪੈਣ ਦੇ) ਡਰ ਫ਼ਿਕਰ ਮਿਟ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "исчезли страх и тревога перед кругом рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12992,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੇ ਪੂਰਨ ਉਪਦੇਸੇ ॥",
          "roman": "sādhū ke pūran updesē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਦਾ ਸਦਕਾ ਹੀ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всё это произошло только благодаря наставлению Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12993,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਚੂਕਾ ਨਿਰਭਉ ਹੋਇ ਬਸੇ ॥",
          "roman": "bhau chūkā nirbhau hoi base ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰਾ) ਡਰ ਮੁੱਕ ਗਿਆ ਹੈ, ਹੁਣ ਨਿਡਰ ਵੱਸਦੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Всякий страх прекратился, теперь мы живём бесстрашно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12994,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਬਿਆਧਿ ਮਨ ਤੇ ਖੈ ਨਸੇ ॥",
          "roman": "sagal biādh man te khē nase ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਰੋਗ ਨਾਸ ਹੋ ਕੇ ਮਨੋਂ ਵਿਸਰ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "все болезни исчезли и ушли из ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12995,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਸਾ ਤਿਨਿ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "jis kā sā tin kirpā dhārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਦੇ ਬਣੇ ਸਾਂ, ਉਸ ਨੇ (ਸਾਡੇ ਉਤੇ) ਕਿਰਪਾ ਕੀਤੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Тот Гуру, чьими мы стали, пролил на нас милость;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12996,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਪਿ ਨਾਮੁ ਮੁਰਾਰੀ ॥",
          "roman": "sādhsang jap nām murārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਸੰਗ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ ਕੇ,"
            },
            "sahib_singh_ru": {
              "main": "повторяя в сатсанге Имя Мурари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12997,
          "is_rahao": false,
          "gurmukhi": "ਥਿਤਿ ਪਾਈ ਚੂਕੇ ਭ੍ਰਮ ਗਵਨ ॥",
          "roman": "thit pāī chūke bhram gavan ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਅਸਾਂ) ਸ਼ਾਂਤੀ ਹਾਸਲ ਕਰ ਲਈ ਹੈ ਤੇ (ਸਾਡੇ) ਭੁਲੇਖੇ ਤੇ ਭਟਕਣਾ ਮੁੱਕ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "мы обрели устойчивость, и наши заблуждение и блуждание прекратились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12998,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਨਾਨਕ ਹਰਿ ਹਰਿ ਜਸੁ ਸ੍ਰਵਨ ॥੭॥",
          "roman": "sun Nānak har har jas sravan ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦਾ ਜਸ ਕੰਨੀਂ ਸੁਣ ਕੇ (ਇਹ ਭਰਮੳ ਅਤੇ ਭਟਕਣਾ ਮੁੱਕੀ ਹੈ) ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это заблуждение и блуждание прекратились через слушание ушами хвалы Хари. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1032,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12999,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਗੁਨੁ ਆਪਿ ਸਰਗੁਨੁ ਭੀ ਓਹੀ ॥",
          "roman": "nirgun āp sargun bhī ohī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਮਾਇਆ ਦੇ ਤਿੰਨਾਂ ਗੁਣਾਂ ਤੋਂ ਵੱਖਰਾ ਹੈ, ਤ੍ਰਿਗੁਣੀ ਸੰਸਾਰ ਦਾ ਰੂਪ ਭੀ ਆਪ ਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он Сам вне трёх качеств майи, и Сам же есть форма этого трёхкачественного мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13000,
          "is_rahao": false,
          "gurmukhi": "ਕਲਾ ਧਾਰਿ ਜਿਨਿ ਸਗਲੀ ਮੋਹੀ ॥",
          "roman": "kalā dhār jin saglī mohī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਆਪਣੀ ਤਾਕਤ ਕਾਇਮ ਕਰ ਕੇ ਸਾਰੇ ਜਗਤ ਨੂੰ ਮੋਹਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот Бог, который, утвердив Свою силу, очаровал весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13001,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਚਰਿਤ ਪ੍ਰਭਿ ਆਪਿ ਬਨਾਏ ॥",
          "roman": "apne charit prabh āp banāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਖੇਲ-ਤਮਾਸ਼ੇ ਆਪ ਹੀ ਬਣਾਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам устроил Свои игры и представления,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13002,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੀ ਕੀਮਤਿ ਆਪੇ ਪਾਏ ॥",
          "roman": "apunī kīmat āpe pāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ ਬਜ਼ੁਰਗੀ ਦਾ ਮੁੱਲ ਭੀ ਆਪ ਹੀ ਪਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и цену Своего величия тоже знает Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13003,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਬਿਨੁ ਦੂਜਾ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "har bin dūjā nāhī koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ (ਉਸ ਵਰਗਾ) ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кроме Хари нет никого другого, подобного Ему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13004,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਏਕੋ ਸੋਇ ॥",
          "roman": "sarab nirantar eko soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਆਪ ਹੀ (ਮੌਜੂਦ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "внутри всех присутствует только Он один."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13005,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਰਵਿਆ ਰੂਪ ਰੰਗ ॥",
          "roman": "ot pot raviā rūp rang ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਣੇ ਪੇਟੇ ਵਾਂਗ ਸਾਰੇ ਰੂਪਾਂ ਤੇ ਰੰਗਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Подобно основе и утку, Он пронизывает все формы и краски;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13006,
          "is_rahao": false,
          "gurmukhi": "ਭਏ ਪ੍ਰਗਾਸ ਸਾਧ ਕੈ ਸੰਗ ॥",
          "roman": "bhae pragās sādh kē sang ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਚਾਨਣ (ਭਾਵ, ਸਮਝ) ਸਤਿਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਪ੍ਰਕਾਸ਼ਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "это озарение, то есть понимание, раскрывается в сангате Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
