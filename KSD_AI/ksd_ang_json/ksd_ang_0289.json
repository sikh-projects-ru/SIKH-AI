{
  "ang": 289,
  "shabads": [
    {
      "shabad_id": 1039,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13068,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਬਿਖ ਜਾਹਿ ॥",
          "roman": "janam janam ke kilbikh jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਕਈ ਜਨਮਾਂ ਦੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਣਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "так исчезнут грехи многих рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13069,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਜਪਹੁ ਅਵਰਾ ਨਾਮੁ ਜਪਾਵਹੁ ॥",
          "roman": "āp japah avrā nām japāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ ਨਾਮ) ਤੂੰ ਆਪ ਜਪ, ਤੇ, ਹੋਰਨਾਂ ਨੂੰ ਜਪਣ ਲਈ ਪ੍ਰੇਰ,"
            },
            "sahib_singh_ru": {
              "main": "Сам повторяй Имя Господа и побуждай других повторять,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13070,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਤ ਕਹਤ ਰਹਤ ਗਤਿ ਪਾਵਹੁ ॥",
          "roman": "sunat kahat rahat gat pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ) ਸੁਣਦਿਆਂ, ਉੱਚਾਰਦਿਆਂ ਤੇ ਨਿਰਮਲ ਰਹਿਣੀ ਰਹਿੰਦਿਆਂ ਉੱਚੀ ਅਵਸਥਾ ਬਣ ਜਾਏਗੀ।"
            },
            "sahib_singh_ru": {
              "main": "слушая Имя, произнося его и живя в чистом образе жизни, обретёшь высокое состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13071,
          "is_rahao": false,
          "gurmukhi": "ਸਾਰ ਭੂਤ ਸਤਿ ਹਰਿ ਕੋ ਨਾਉ ॥",
          "roman": "sār bhūt sat har ko nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਸਭ ਪਦਾਰਥਾਂ ਤੋਂ ਉੱਤਮ ਪਦਾਰਥ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Имя Господа и есть наилучшее из всех даров;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13072,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਸੁਭਾਇ ਨਾਨਕ ਗੁਨ ਗਾਉ ॥੬॥",
          "roman": "sahaj subhāi Nānak gun gāu ||6||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੇ ਨਾਨਕ! ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਪ੍ਰੇਮ ਨਾਲ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому, о Нанак, пребывая в духовной устойчивости, с любовью пой качества Господа. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1040,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13073,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਤ ਤੇਰੀ ਉਤਰਸਿ ਮੈਲੁ ॥",
          "roman": "gun gāvat terī utras mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਂਦਿਆਂ ਤੇਰੀ (ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਉਤਰ ਜਾਏਗੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда поёшь качества Господа, с тебя сходит грязь пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13074,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸਿ ਜਾਇ ਹਉਮੈ ਬਿਖੁ ਫੈਲੁ ॥",
          "roman": "binas jāi haumē bikh phēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਹਉਮੈ ਰੂਪੀ ਵਿਹੁ ਦਾ ਖਿਲਾਰਾ ਭੀ ਮਿਟ ਜਾਏਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и распространение яда Хоумэ тоже исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13075,
          "is_rahao": false,
          "gurmukhi": "ਹੋਹਿ ਅਚਿੰਤੁ ਬਸੈ ਸੁਖ ਨਾਲਿ ॥",
          "roman": "hoh achint basē sukh nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਬੇਫ਼ਿਕਰ ਹੋ ਜਾਹਿਂਗਾ ਤੇ ਤੇਰਾ ਜੀਵਨ ਸੁਖ ਨਾਲ ਬਿਤੀਤ ਹੋਵੇਗਾ-"
            },
            "sahib_singh_ru": {
              "main": "Ты станешь беззаботным, и жизнь твоя будет проходить в покое —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13076,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਗ੍ਰਾਸਿ ਹਰਿ ਨਾਮੁ ਸਮਾਲਿ ॥",
          "roman": "sās grās har nām samāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਮ-ਬ-ਦਮ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਨੂੰ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "помни Имя Господа с каждым дыханием и с каждым куском пищи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13077,
          "is_rahao": false,
          "gurmukhi": "ਛਾਡਿ ਸਿਆਨਪ ਸਗਲੀ ਮਨਾ ॥",
          "roman": "chhāḍ siānap saglī manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਸਾਰੀ ਚਤੁਰਾਈ ਛੱਡ ਦੇਹ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Оставь всю свою хитрость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13078,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਪਾਵਹਿ ਸਚੁ ਧਨਾ ॥",
          "roman": "sādhsang pāvah sach dhanā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਨਾਲ ਨਿਭਣ ਵਾਲਾ ਧਨ ਸਤਸੰਗ ਵਿਚ ਮਿਲੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "в сатсанге ты обретёшь истинное богатство, которое остаётся с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13079,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪੂੰਜੀ ਸੰਚਿ ਕਰਹੁ ਬਿਉਹਾਰੁ ॥",
          "roman": "har pūnjī sanch karah ביuhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਰਾਸ ਇਕੱਠੀ ਕਰ, ਇਹੀ ਵਿਹਾਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Собирай капитал Имени Господа — вот этим и занимайся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13080,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਸੁਖੁ ਦਰਗਹ ਜੈਕਾਰੁ ॥",
          "roman": "īhā sukh dargah jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਜੀਵਨ ਵਿਚ ਸੁਖ ਮਿਲੇਗਾ, ਤੇ, ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਆਦਰ ਹੋਵੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "В этой жизни получишь счастье, а в даргахе — почёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13081,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਏਕੋ ਦੇਖੁ ॥",
          "roman": "sarab nirantar eko dekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਇਕ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਹੀ ਵੇਖ।"
            },
            "sahib_singh_ru": {
              "main": "Во всех существах внутри увидь одного Акаал Пуракха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13082,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕੈ ਮਸਤਕਿ ਲੇਖੁ ॥੭॥",
          "roman": "kah Nānak jā kē mastak lekh ||7||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਇਹ ਕੰਮ ਓਹੀ ਮਨੁੱਖ ਕਰਦਾ ਹੈ) ਜਿਸ ਦੇ ਮੱਥੇ ਤੇ ਭਾਗ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Но, говорит Нанак, это делает только тот человек, у кого на лбу написана такая доля. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1041,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13083,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਜਪਿ ਏਕੋ ਸਾਲਾਹਿ ॥",
          "roman": "eko jap eko sālāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਪ੍ਰਭੂ ਨੂੰ ਹੀ ਜਪ, ਤੇ ਇਕ ਪ੍ਰਭੂ ਦੀ ਹੀ ਸਿਫ਼ਤਿ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяй только одного Господа и восхваляй только одного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13084,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਸਿਮਰਿ ਏਕੋ ਮਨ ਆਹਿ ॥",
          "roman": "ek simar eko man āh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਨੂੰ ਸਿਮਰ, ਤੇ, ਹੇ ਮਨ! ਇਕ ਪ੍ਰਭੂ ਦੇ ਮਿਲਣ ਦੀ ਤਾਂਘ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "помни одного и, о ум, жажди встречи только с одним Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13085,
          "is_rahao": false,
          "gurmukhi": "ਏਕਸ ਕੇ ਗੁਨ ਗਾਉ ਅਨੰਤ ॥",
          "roman": "ekas ke gun gāu anant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਪ੍ਰਭੂ ਦੇ ਹੀ ਗੁਣ ਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Пой качества только одного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13086,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਜਾਪਿ ਏਕ ਭਗਵੰਤ ॥",
          "roman": "man tan jāp ek bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਤੇ ਸਰੀਰਕ ਇੰਦ੍ਰਿਆਂ ਦੀ ਰਾਹੀਂ ਇਕ ਭਗਵਾਨ ਨੂੰ ਹੀ ਜਪ।"
            },
            "sahib_singh_ru": {
              "main": "умом и телесными чувствами повторяй только одного Бхагванта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13087,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਏਕੁ ਏਕੁ ਹਰਿ ਆਪਿ ॥",
          "roman": "eko ek ek har āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਥਾਈਂ) ਪ੍ਰਭੂ ਆਪ ਹੀ ਆਪ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Повсюду Господь Сам и только Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13088,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹਿਓ ਪ੍ਰਭੁ ਬਿਆਪਿ ॥",
          "roman": "pūran pūr rahiō prabh biāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਵਿਚ ਪ੍ਰਭੂ ਹੀ ਵੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "во всех живых существах пребывает один лишь Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13089,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਿਸਥਾਰ ਏਕ ਤੇ ਭਏ ॥",
          "roman": "anik bisthār ek te bhae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੇ) ਅਨੇਕਾਂ ਖਿਲਾਰੇ ਇਕ ਪ੍ਰਭੂ ਤੋਂ ਹੀ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Многочисленные развертывания мира произошли только из одного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13090,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਅਰਾਧਿ ਪਰਾਛਤ ਗਏ ॥",
          "roman": "ek arādh parāchhat gae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆਂ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и при пометовании одного Господа грехи исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13091,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਅੰਤਰਿ ਏਕੁ ਪ੍ਰਭੁ ਰਾਤਾ ॥",
          "roman": "man tan antar ek prabh rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਤੇ ਸਰੀਰ ਵਿਚ ਇਕ ਪ੍ਰਭੂ ਹੀ ਪਰੋਤਾ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в уме и теле которого пронизан один Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13092,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਇਕੁ ਜਾਤਾ ॥੮॥੧੯॥",
          "roman": "gur prasād Nānak ik jātā ||8||19||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਇਕ ਪ੍ਰਭੂ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ ॥੮॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! По милости Гуру он познал этого единого Господа. ॥8॥19॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1042,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13093,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13094,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਤ ਫਿਰਤ ਪ੍ਰਭ ਆਇਆ ਪਰਿਆ ਤਉ ਸਰਨਾਇ ॥",
          "roman": "phirat phirat prabh āiā pariā tau sarnāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਭਟਕਦਾ ਭਟਕਦਾ ਮੈਂ ਤੇਰੀ ਸਰਣ ਆ ਪਿਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Скитаясь и скитаясь, я пришёл и пал в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13095,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਪ੍ਰਭ ਬੇਨਤੀ ਅਪਨੀ ਭਗਤੀ ਲਾਇ ॥੧॥",
          "roman": "Nānak kī prabh benatī apnī bhagatī lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਨਾਨਕ ਦੀ ਇਹੀ ਬੇਨਤੀ ਹੈ ਕਿ ਮੈਨੂੰ ਆਪਣੀ ਭਗਤੀ ਵਿਚ ਜੋੜ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Вот просьба Нанака: соедини меня со Своей бхагти. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1043,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13096,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭapadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13097,
          "is_rahao": false,
          "gurmukhi": "ਜਾਚਕ ਜਨੁ ਜਾਚੈ ਪ੍ਰਭ ਦਾਨੁ ॥",
          "roman": "jāchak jan jāchē prabh dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਇਹ) ਮੰਗਤਾ ਦਾਸ (ਤੇਰੇ ਨਾਮ ਦਾ) ਦਾਨ ਮੰਗਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Этот нищий слуга просит подаяние Твоего Имени;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13098,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਦੇਵਹੁ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "kar kirpā devh har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਕਿਰਪਾ ਕਰ ਕੇ (ਆਪਣਾ) ਨਾਮ ਦਿਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О Хари! По милости даруй Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13099,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੀ ਮਾਗਉ ਧੂਰਿ ॥",
          "roman": "sādh janā kī māgau dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਸਾਧੂ ਜਨਾਂ ਦੇ ਪੈਰਾਂ ਦੀ ਖ਼ਾਕ ਮੰਗਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу прах со стоп святых людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13100,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਮੇਰੀ ਸਰਧਾ ਪੂਰਿ ॥",
          "roman": "pārbrahm merī sardhā pūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ! ਮੇਰੀ ਇੱਛਾ ਪੂਰੀ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман! Исполни моё желание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13101,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਪ੍ਰਭ ਕੇ ਗੁਨ ਗਾਵਉ ॥",
          "roman": "sadā sadā prabh ke gun gāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਸਦਾ ਹੀ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਵਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Пусть я всегда и всегда пою качества Пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13102,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਪ੍ਰਭ ਤੁਮਹਿ ਧਿਆਵਉ ॥",
          "roman": "sās sās prabh tumah dhiāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਦਮ-ਬ-ਦਮ ਤੈਨੂੰ ਹੀ ਸਿਮਰਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Пусть с каждым дыханием я помню только Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13103,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੈ ਪ੍ਰੀਤਿ ॥",
          "roman": "charan kamal siu lāgē prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਕਮਲ (ਵਰਗੇ ਸੋਹਣੇ) ਚਰਨਾਂ ਨਾਲ ਮੇਰੀ ਪ੍ਰੀਤਿ ਲੱਗੀ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Пусть моя любовь будет привязана к лотосным стопам Пребывающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13104,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰਉ ਪ੍ਰਭ ਕੀ ਨਿਤ ਨੀਤਿ ॥",
          "roman": "bhagat karau prabh kī nit nīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਦਾ ਹੀ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и пусть я постоянно совершаю бхагти Пребывающему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13105,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਓਟ ਏਕੋ ਆਧਾਰੁ ॥",
          "roman": "ek oṭ eko ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ) ਇਕੋ ਮੇਰੀ ਓਟ ਹੈ ਤੇ ਇਕੋ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Только одно у меня укрытие и только одна опора — Имя Пребывающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13106,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮਾਗੈ ਨਾਮੁ ਪ੍ਰਭ ਸਾਰੁ ॥੧॥",
          "roman": "Nānak māgē nām prabh sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਪ੍ਰਭੂ ਦਾ ਸ੍ਰੇਸ਼ਟ ਨਾਮ ਮੰਗਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак просит высшее Имя Пребывающего. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1044,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13107,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਦ੍ਰਿਸਟਿ ਮਹਾ ਸੁਖੁ ਹੋਇ ॥",
          "roman": "prabh kī drisaṭ mahā sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ (ਮੇਹਰ ਦੀ) ਨਜ਼ਰ ਨਾਲ ਬੜਾ ਸੁਖ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "От милостивого взгляда Пребывающего приходит великое счастье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13108,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸੁ ਪਾਵੈ ਬਿਰਲਾ ਕੋਇ ॥",
          "roman": "har ras pāvē birlā koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਚੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но лишь редкий человек вкушает вкус Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13109,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਚਾਖਿਆ ਸੇ ਜਨ ਤ੍ਰਿਪਤਾਨੇ ॥",
          "roman": "jin chākhiā se jan triptāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੇ (ਨਾਮ-ਰਸ) ਚੱਖਿਆ ਹੈ, ਉਹ ਮਨੁੱਖ (ਮਾਇਆ ਵਲੋਂ) ਰੱਜ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто вкусил этот нектар Имени, насытились и больше не тянутся к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13110,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੁਰਖ ਨਹੀ ਡੋਲਾਨੇ ॥",
          "roman": "pūran purakh nahī ḍolāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੂਰਨ ਮਨੁੱਖ ਬਣ ਗਏ ਹਨ, ਕਦੇ (ਮਾਇਆ ਦੇ ਲਾਹੇ ਘਾਟੇ ਵਿਚ) ਡੋਲਦੇ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "они стали цельными людьми и никогда не колеблются в прибылях и потерях майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13111,
          "is_rahao": false,
          "gurmukhi": "ਸੁਭਰ ਭਰੇ ਪ੍ਰੇਮ ਰਸ ਰੰਗਿ ॥",
          "roman": "subhar bhare prem ras rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਦੇ ਸੁਆਦ ਦੀ ਮੌਜ ਵਿਚ ਉਹ ਨਕਾ-ਨਕ ਭਰੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Они до краёв наполнены восторгом вкуса любви к Пребывающему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13112,
          "is_rahao": false,
          "gurmukhi": "ਉਪਜੈ ਚਾਉ ਸਾਧ ਕੈ ਸੰਗਿ ॥",
          "roman": "upjē chāu sādh kē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ (ਉਹਨਾਂ ਦੇ ਅੰਦਰ) (ਪ੍ਰਭੂ-ਮਿਲਾਪ ਦਾ) ਚਾਉ ਪੈਦਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и в обществе святых в них рождается стремление к встрече с Пребывающим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13113,
          "is_rahao": false,
          "gurmukhi": "ਪਰੇ ਸਰਨਿ ਆਨ ਸਭ ਤਿਆਗਿ ॥",
          "roman": "pare saran ān sabh tiāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੇ (ਆਸਰੇ) ਛੱਡ ਕੇ ਉਹ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Оставив все прочие опоры, они приходят в прибежище Пребывающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13114,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪ੍ਰਗਾਸ ਅਨਦਿਨੁ ਲਿਵ ਲਾਗਿ ॥",
          "roman": "antar pragās andin liv lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ, ਤੇ ਹਰ ਵੇਲੇ ਉਹਨਾਂ ਦੀ ਲਿਵ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "внутри у них загорается свет, и во всякое время их сосредоточенность остаётся привязанной к стопам Пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13115,
          "is_rahao": false,
          "gurmukhi": "ਬਡਭਾਗੀ ਜਪਿਆ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "baḍbhāgī japiā prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਬੰਦਿਆਂ ਨੇ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Люди великой удачи помнили того Пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13116,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਤੇ ਸੁਖੁ ਹੋਇ ॥੨॥",
          "roman": "Nānak nām rate sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਰੱਤਿਆਂ ਸੁਖ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Когда человек пропитан Именем Пребывающего, приходит счастье. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1045,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13117,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਕੀ ਮਨਸਾ ਪੂਰੀ ਭਈ ॥",
          "roman": "sevak kī mansā pūrī bhaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਸੇਵਕ ਦੇ ਮਨ ਦੇ ਫੁਰਨੇ ਪੂਰਨ ਹੋ ਜਾਂਦੇ ਹਨ, ਭਾਵ, ਮਾਇਆ ਵਾਲੀ ਦੌੜ ਮੁੱਕ ਜਾਂਦੀ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Тогда исполняются устремления ума слуги, то есть прекращается погоня за майей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13118,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਤੇ ਨਿਰਮਲ ਮਤਿ ਲਈ ॥",
          "roman": "satgur te nirmal mat laī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਸੇਵਕ) ਆਪਣੇ ਗੁਰੂ ਤੋਂ ਉੱਤਮ ਸਿੱਖਿਆ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "когда он получает от Сатгуру чистое наставление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13119,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਉ ਪ੍ਰਭੁ ਹੋਇਓ ਦਇਆਲੁ ॥",
          "roman": "jan kau prabh hoio daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ (ਅਜੇਹੇ) ਸੇਵਕ ਉਤੇ ਮੇਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пребывающий становится милостив к такому слуге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13120,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕੁ ਕੀਨੋ ਸਦਾ ਨਿਹਾਲੁ ॥",
          "roman": "sevak kīno sadā nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਸੇਵਕ ਨੂੰ ਸਦਾ ਖਿੜੇ-ਮੱਥੇ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всегда держит слугу в радостном состоянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13121,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਮੁਕਤਿ ਜਨੁ ਭਇਆ ॥",
          "roman": "bandhan kāṭ mukt jan bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ (ਮਾਇਆ ਵਾਲੇ) ਜ਼ੰਜੀਰ ਤੋੜ ਕੇ ਖਲਾਸਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга, разорвав оковы майи, становится освобождённым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13122,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਨ ਦੂਖੁ ਭ੍ਰਮੁ ਗਇਆ ॥",
          "roman": "janam maran dūkh bhram gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਜਨਮ ਮਰਨ (ਦੇ ਗੇੜ) ਦਾ ਦੁੱਖ ਤੇ ਸਹਸਾ ਮੁੱਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и у него исчезает страдание кругов рождения и смерти и исчезает сомнение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13123,
          "is_rahao": false,
          "gurmukhi": "ਇਛ ਪੁਨੀ ਸਰਧਾ ਸਭ ਪੂਰੀ ॥",
          "roman": "ichh punī sardhā sabh pūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਦੀ ਇੱਛਾ ਤੇ ਸਰਧਾ ਸਭ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его желание и вера полностью исполняются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13124,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿ ਰਹਿਆ ਸਦ ਸੰਗਿ ਹਜੂਰੀ ॥",
          "roman": "rav rahiā sad sang hajūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਸਭ ਥਾਈਂ ਵਿਆਪਕ ਆਪਣੇ ਨਾਲ ਅੰਗ-ਸੰਗ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ему видится, что Пребывающий присутствует повсюду и пребывает рядом с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13125,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਸਾ ਤਿਨਿ ਲੀਆ ਮਿਲਾਇ ॥",
          "roman": "jis kā sā tin līā milāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਾਲਕ ਦਾ ਉਹ ਸੇਵਕ ਬਣਦਾ ਹੈ, ਉਹ ਆਪਣੇ ਨਾਲ ਮਿਲਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Владыка, чьим слугой он становится, соединяет его с Собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13126,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤੀ ਨਾਮਿ ਸਮਾਇ ॥੩॥",
          "roman": "Nānak bhagatī nām samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸੇਵਕ ਭਗਤੀ ਕਰ ਕੇ ਨਾਮ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, слуга через бхагти остаётся погружённым в Имя. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1046,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13127,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿ ਘਾਲ ਨ ਭਾਨੈ ॥",
          "roman": "so kiu bisrē j ghāl na bhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਨੂੰ) ਉਹ ਪ੍ਰਭੂ ਕਿਉਂ ਵਿਸਰ ਜਾਏ ਜੋ (ਮਨੁੱਖ ਦੀ ਕੀਤੀ) ਮੇਹਨਤ ਨੂੰ ਅਜਾਈਂ ਨਹੀਂ ਜਾਣ ਦੇਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Как может забыться тот Пребывающий, Который не даёт пропасть напрасно труду человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13128,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿ ਕੀਆ ਜਾਨੈ ॥",
          "roman": "so kiu bisrē j kīā jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੀਤੀ ਕਮਾਈ ਨੂੰ ਚੇਤੇ ਰੱਖਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Который помнит сделанное им дело?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
