{
  "ang": 293,
  "shabads": [
    {
      "shabad_id": 1064,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13304,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਪ੍ਰਭਿ ਆਪਹਿ ਮੇਲੇ ॥੪॥",
          "roman": "Nānak har prabh āpeh mele",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਨੇ ਆਪ ਉਹਨਾਂ ਨੂੰ (ਆਪਣੇ ਨਾਲ) ਮਿਲਾ ਲਿਆ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "потому что, о Нанак, Сам Господь соединил их с Собой. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1065,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13305,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਿਲਿ ਕਰਹੁ ਅਨੰਦ ॥",
          "roman": "sādhsang mil karah anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਸੰਗ ਵਿਚ ਮਿਲ ਕੇ ਇਹ (ਆਤਮਕ) ਅਨੰਦ ਮਾਣਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Соединившись в святом обществе, вкушайте эту духовную радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13306,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਹੁ ਪ੍ਰਭ ਪਰਮਾਨੰਦ ॥",
          "roman": "gun gāvah prabh parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮ ਖ਼ੁਸ਼ੀਆਂ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "воспевайте хвалу Господу, Который есть высшее блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13307,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਤਤੁ ਕਰਹੁ ਬੀਚਾਰੁ ॥",
          "roman": "rām nām tat karah bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੇ ਭੇਤ ਨੂੰ ਵਿਚਾਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Размышляйте о тайне Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13308,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰੁਲਭ ਦੇਹ ਕਾ ਕਰਹੁ ਉਧਾਰੁ ॥",
          "roman": "drulabh deh kā karah udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇਸ (ਮਨੁੱਖਾ-) ਸਰੀਰ ਦਾ ਬਚਾਉ ਕਰੋ ਜੋ ਬੜੀ ਮੁਸ਼ਕਿਲ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и спасайте это человеческое тело, которое даётся с великим трудом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13309,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਚਨ ਹਰਿ ਕੇ ਗੁਨ ਗਾਉ ॥",
          "roman": "amrit bachan har ke gun gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਦੇ ਗੁਣ ਗਾਉ ਜੋ ਅਮਰ ਕਰਨ ਵਾਲੇ ਬਚਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Пойте качества Акаал Пуракха, ибо это слова, делающие бессмертным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13310,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਨ ਤਰਨ ਕਾ ਇਹੈ ਸੁਆਉ ॥",
          "roman": "prān taran kā ihē suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜ਼ਿੰਦਗੀ ਨੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾਉਣ ਦਾ ਇਹੀ ਵਸੀਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "это и есть средство спасти жизнь от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13311,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪ੍ਰਭ ਪੇਖਹੁ ਨੇਰਾ ॥",
          "roman": "āṭh pahar prabh pekhah nerā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਠੇ ਪਹਰ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੇਖਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Все восемь пахаров видьте Господа рядом с собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13312,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੈ ਅਗਿਆਨੁ ਬਿਨਸੈ ਅੰਧੇਰਾ ॥",
          "roman": "miṭē agiān binsē andherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਅਗਿਆਨਤਾ ਮਿਟ ਜਾਏਗੀ ਤੇ (ਮਾਇਆ ਵਾਲਾ) ਹਨੇਰਾ ਨਾਸ ਹੋ ਜਾਏਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "тогда неведение исчезнет и тьма Майи рассеется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13313,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਉਪਦੇਸੁ ਹਿਰਦੈ ਬਸਾਵਹੁ ॥",
          "roman": "sun updes hirdē basāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਤਿਗੁਰੂ ਦਾ) ਉਪਦੇਸ਼ ਸੁਣ ਕੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਉ,"
            },
            "sahib_singh_ru": {
              "main": "Услышав наставление Сатгуру, поселите его в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13314,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਇਛੇ ਨਾਨਕ ਫਲ ਪਾਵਹੁ ॥੫॥",
          "roman": "man ichhe Nānak phal pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਤਰ੍ਹਾਂ) ਮਨ-ਮੰਗੀਆਂ ਮੁਰਾਦਾਂ ਮਿਲਣਗੀਆਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, тогда исполнятся желанные сердцем плоды. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1066,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13315,
          "is_rahao": false,
          "gurmukhi": "ਹਲਤੁ ਪਲਤੁ ਦੁਇ ਲੇਹੁ ਸਵਾਰਿ ॥",
          "roman": "halat palat dui leh savār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲੋਕ ਤੇ ਪਰਲੋਕ ਦੋਵੇਂ ਸੁਧਾਰ ਲਵੋ,"
            },
            "sahib_singh_ru": {
              "main": "Устройте и этот мир, и мир будущий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13316,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਅੰਤਰਿ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "rām nām antar ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਅੰਦਰ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਓ।"
            },
            "sahib_singh_ru": {
              "main": "утвердите Имя Господа глубоко в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13317,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕੀ ਪੂਰੀ ਦੀਖਿਆ ॥",
          "roman": "pūre gur kī pūrī dīkhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਸਤਿਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਭੀ ਪੂਰਨ (ਭਾਵ, ਮੁਕੰਮਲ) ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Наставление совершенного Сатгуру тоже совершенно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13318,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਬਸੈ ਤਿਸੁ ਸਾਚੁ ਪਰੀਖਿਆ ॥",
          "roman": "jis man basē tis sāc parīkhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ (ਇਹ ਸਿੱਖਿਆ) ਵੱਸਦੀ ਹੈ ਉਸ ਨੂੰ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਸਮਝ ਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и тот человек, в чьём уме оно поселяется, постигает вечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13319,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਨਾਮੁ ਜਪਹੁ ਲਿਵ ਲਾਇ ॥",
          "roman": "man tan nām japah liv lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਤੇ ਸਰੀਰ ਦੀ ਰਾਹੀਂ ਲਿਵ ਜੋੜ ਕੇ ਨਾਮ ਜਪਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "С любовной сосредоточенностью повторяйте Имя умом и телом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13320,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਮਨ ਤੇ ਭਉ ਜਾਇ ॥",
          "roman": "dūkh dard man te bhau jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਖ ਦਰਦ ਅਤੇ ਮਨ ਤੋਂ ਡਰ ਦੂਰ ਹੋ ਜਾਏਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и боль, страдание и страх уйдут из ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13321,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਵਾਪਾਰੁ ਕਰਹੁ ਵਾਪਾਰੀ ॥",
          "roman": "sach vāpār karah vāpārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਵਣਜਾਰੇ ਜੀਵ! ਸੱਚਾ ਵਣਜ ਕਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О торговец-душа, веди истинную торговлю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13322,
          "is_rahao": false,
          "gurmukhi": "ਦਰਗਹ ਨਿਬਹੈ ਖੇਪ ਤੁਮਾਰੀ ॥",
          "roman": "dargah nibhē khep tumārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਰੂਪ ਸੱਚੇ ਵਣਜ ਨਾਲ) ਤੁਹਾਡਾ ਸੌਦਾ ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਮੁੱਲ ਪਾਏਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и твой товар будет иметь цену при дворе Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13323,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਟੇਕ ਰਖਹੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "ekā ṭek rakhah man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਇਕ ਅਕਾਲ ਪੁਰਖ ਦਾ ਆਸਰਾ ਰੱਖੋ,"
            },
            "sahib_singh_ru": {
              "main": "Держи в уме опору только на одного Акаал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13324,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਹੁਰਿ ਨ ਆਵਹਿ ਜਾਹਿ ॥੬॥",
          "roman": "Nānak bahur na āveh jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮੁੜ ਜੰਮਣ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਹੋਵੇਗਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, больше не будет круга рождений и смертей. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1067,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13325,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਤੇ ਦੂਰਿ ਕਹਾ ਕੋ ਜਾਇ ॥",
          "roman": "tis te dūr kahā ko jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਪਰੇ ਕਿੱਥੇ ਕੋਈ ਜੀਵ ਜਾ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Куда может уйти какое-либо существо от того Господа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13326,
          "is_rahao": false,
          "gurmukhi": "ਉਬਰੈ ਰਾਖਨਹਾਰੁ ਧਿਆਇ ॥",
          "roman": "ubrē rākhanhār dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਬਚਦਾ ਹੀ ਰੱਖਣਹਾਰ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰ ਕੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Существо спасается только памятованием о Господе-Хранителе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13327,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਜਪੈ ਸਗਲ ਭਉ ਮਿਟੈ ॥",
          "roman": "nirbhau japē sagal bhau miṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮੁਨੱਖ ਨਿਰਭਉ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਜਪਦਾ ਹੈ, ਉਸ ਦਾ ਸਾਰਾ ਡਰ ਮਿਟ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто повторяет Нирбхау Акаал Пуракха, избавляется от всякого страха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13328,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਪ੍ਰਾਣੀ ਛੁਟੈ ॥",
          "roman": "prabh kirpā te prāṇī chhuṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ ਹੀ ਬੰਦਾ (ਡਰ ਤੋਂ) ਖ਼ਲਾਸੀ ਪਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что лишь по милости Господа человек освобождается от страха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13329,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਭੁ ਰਾਖੈ ਤਿਸੁ ਨਾਹੀ ਦੂਖ ॥",
          "roman": "jis prabh rākhē tis nāhī dūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਬੰਦੇ ਨੂੰ ਪ੍ਰਭੂ ਰੱਖਦਾ ਹੈ ਉਸ ਨੂੰ ਕੋਈ ਦੁੱਖ ਨਹੀਂ ਪੋਂਹਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, кого хранит Господь, не касается никакое страдание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13330,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਮਨਿ ਹੋਵਤ ਸੂਖ ॥",
          "roman": "nām japat man hovat sūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਿਆਂ ਮਨ ਵਿਚ ਸੁਖ ਪੈਦਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а при повторении Имени в уме рождается покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13331,
          "is_rahao": false,
          "gurmukhi": "ਚਿੰਤਾ ਜਾਇ ਮਿਟੈ ਅਹੰਕਾਰੁ ॥",
          "roman": "chintā jāi miṭē ahankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਸਿਮਰਿਆਂ) ਚਿੰਤਾ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ, ਅਹੰਕਾਰ ਮਿਟ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "При памятовании Имени исчезает забота и стирается эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13332,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਕਉ ਕੋਇ ਨ ਪਹੁਚਨਹਾਰੁ ॥",
          "roman": "tis jan kau koi na pahuchanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਕੋਈ ਬਰਾਬਰੀ ਹੀ ਨਹੀਂ ਕਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и никто не может сравниться с таким человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13333,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰ ਊਪਰਿ ਠਾਢਾ ਗੁਰੁ ਸੂਰਾ ॥",
          "roman": "sir ūpar ṭhāḍhā gur sūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਬੰਦੇ ਦੇ ਸਿਰ ਉਤੇ ਸੂਰਮਾ ਸਤਿਗੁਰੂ (ਰਾਖਾ) ਖਲੋਤਾ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Над тем человеком, над чьей головой стоит как защитник доблестный Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13334,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੇ ਕਾਰਜ ਪੂਰਾ ॥੭॥",
          "roman": "Nānak tā ke kāraj pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਰਾਸ ਆ ਜਾਂਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, все его дела успешно совершаются. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1068,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13335,
          "is_rahao": false,
          "gurmukhi": "ਮਤਿ ਪੂਰੀ ਅੰਮ੍ਰਿਤੁ ਜਾ ਕੀ ਦ੍ਰਿਸਟਿ ॥",
          "roman": "mat pūrī amrit jā kī driṣṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੀ ਸਮਝ ਪੂਰਨ (infallible, ਅਭੁੱਲ) ਹੈ, ਜਿਸ ਦੀ ਨਜ਼ਰ ਵਿਚੋਂ ਅੰਮ੍ਰਿਤ ਵਰਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь, чьё понимание совершенно и безошибочно, из чьего взгляда льётся амрит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13336,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਪੇਖਤ ਉਧਰਤ ਸ੍ਰਿਸਟਿ ॥",
          "roman": "darsan pekhat udhart srisṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਦੀਦਾਰ ਕੀਤਿਆਂ ਜਗਤ ਦਾ ਉੱਧਾਰ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "при созерцании Его даршана спасается мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13337,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਜਾ ਕੇ ਅਨੂਪ ॥",
          "roman": "charan kamal jā ke anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੇ ਕਮਲਾਂ (ਵਰਗੇ) ਅੱਤ ਸੋਹਣੇ ਚਰਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "У того Господа несравненно прекрасные стопы, подобные лотосам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13338,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਦਰਸਨੁ ਸੁੰਦਰ ਹਰਿ ਰੂਪ ॥",
          "roman": "safal darsan sundar har rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਰੂਪ ਸੁੰਦਰ ਹੈ, ਤੇ, ਉਸ ਦਾ ਦੀਦਾਰ ਮੁਰਾਦਾਂ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его образ прекрасен, и Его даршан исполняет желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13339,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੇਵਾ ਸੇਵਕੁ ਪਰਵਾਨੁ ॥",
          "roman": "dhann sevā sevak parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਸੇਵਕ (ਦਰਗਾਹ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ (ਤਾਹੀਏਂ) ਉਸ ਦੀ ਸੇਵਾ ਮੁਬਾਰਿਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Служение Ему благословенно, ведь Его слуга принимается в даргахе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13340,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਪੁਰਖੁ ਪ੍ਰਧਾਨੁ ॥",
          "roman": "antarjāmī purakh pradhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਕਾਲ ਪੁਰਖ ਘਟ ਘਟ ਦੀ ਜਾਣਨ ਵਾਲਾ ਤੇ ਸਭ ਤੋਂ ਵੱਡਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а тот Акаал Пуракх знает каждое сердце и является величайшим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13341,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਬਸੈ ਸੁ ਹੋਤ ਨਿਹਾਲੁ ॥",
          "roman": "jis man basē so hot nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਐਸਾ ਪ੍ਰਭੂ) ਵੱਸਦਾ ਹੈ ਉਹ (ਫੁੱਲ ਵਾਂਗ) ਖਿੜ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём сердце поселяется такой Господь, расцветает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13342,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਨਿਕਟਿ ਨ ਆਵਤ ਕਾਲੁ ॥",
          "roman": "tā kē nikaṭ na āvat kāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਨੇੜੇ ਕਾਲ (ਭੀ) ਨਹੀਂ ਆਉਂਦਾ (ਭਾਵ, ਮੌਤ ਦਾ ਡਰ ਉਸ ਨੂੰ ਪੋਂਹਦਾ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "и к нему не приближается даже Кал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13343,
          "is_rahao": false,
          "gurmukhi": "ਅਮਰ ਭਏ ਅਮਰਾ ਪਦੁ ਪਾਇਆ ॥",
          "roman": "amar bhae amrā pad pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਤੋਂ ਰਹਿਤ ਹੋ ਜਾਂਦੇ ਹਨ, ਤੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਦਰਜਾ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Такие люди становятся свободными от рождения и смерти и обретают вечное состояние,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13344,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਨਾਨਕ ਹਰਿ ਧਿਆਇਆ ॥੮॥੨੨॥",
          "roman": "sādhsang Nānak har dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਨ੍ਹਾਂ ਨੇ ਸਤਸੰਗ ਵਿਚ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, те, кто в святом обществе вспоминал Господа. ॥8॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1069,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13345,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13346,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨ ਅੰਜਨੁ ਗੁਰਿ ਦੀਆ ਅਗਿਆਨ ਅੰਧੇਰ ਬਿਨਾਸੁ ॥",
          "roman": "giān añjan gur dīā agiān andher binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਸਤਿਗੁਰੂ ਨੇ ਗਿਆਨ ਦਾ ਸੁਰਮਾ ਬਖ਼ਸ਼ਿਆ ਹੈ, ਉਸ ਦੇ ਅਗਿਆਨ (ਰੂਪ) ਹਨੇਰੇ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которому Сатгуру даровал сурьму знания, тьма неведения уничтожается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13347,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਿਰਪਾ ਤੇ ਸੰਤ ਭੇਟਿਆ ਨਾਨਕ ਮਨਿ ਪਰਗਾਸੁ ॥੧॥",
          "roman": "har kirpā te sant bheṭiā Nānak man pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੋ ਮਨੁੱਖ) ਅਕਾਲ ਪੁਰਖ ਦੀ ਮੇਹਰ ਨਾਲ ਗੁਰੂ ਨੂੰ ਮਿਲਿਆ ਹੈ, ਉਸ ਦੇ ਮਨ ਵਿਚ (ਗਿਆਨ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот человек, который по милости Акал Пуракха встретил Гуру, обретает в уме свет знания. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1070,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13348,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭapadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13349,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਅੰਤਰਿ ਪ੍ਰਭੁ ਡੀਠਾ ॥",
          "roman": "santsang antar prabh ḍīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੇ) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ) ਆਪਣੇ ਅੰਦਰ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਵੇਖਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который в сангате Гуру увидел Акал Пуракха внутри себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13350,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਪ੍ਰਭੂ ਕਾ ਲਾਗਾ ਮੀਠਾ ॥",
          "roman": "nām prabhū kā lāgā mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "начинает любить Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13351,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਿਗ੍ਰੀ ਏਕਸੁ ਘਟ ਮਾਹਿ ॥",
          "roman": "sagal samigrī ekas ghaṭ māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੇ) ਸਾਰੇ ਪਦਾਰਥ (ਉਸ ਨੂੰ) ਇਕ ਪ੍ਰਭੂ ਵਿਚ ਹੀ (ਲੀਨ ਦਿੱਸਦੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "Все вещества мира он видит слитыми в одном Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13352,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰੰਗ ਨਾਨਾ ਦ੍ਰਿਸਟਾਹਿ ॥",
          "roman": "anik rang nānā driṣṭāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਹੀ) ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਰੰਗ ਤਮਾਸ਼ੇ (ਨਿਕਲੇ ਹੋਏ) ਦਿੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и видит, что из Него исходят бесчисленные виды красок и зрелищ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13353,
          "is_rahao": false,
          "gurmukhi": "ਨਉ ਨਿਧਿ ਅੰਮ੍ਰਿਤੁ ਪ੍ਰਭ ਕਾ ਨਾਮੁ ॥",
          "roman": "nau nidh ammrit prabh kā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜੋ (ਮਾਨੋ, ਜਗਤ ਦੇ) ਨੌ ਹੀ ਖ਼ਜ਼ਾਨਿਆਂ (ਦੇ ਤੁੱਲ) ਹੈ ਤੇ ਅੰਮ੍ਰਿਤ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога подобно всем девяти сокровищам мира и есть амрита;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13354,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹੀ ਮਹਿ ਇਸ ਕਾ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "dehī mah is kā bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਦੇ) ਸਰੀਰ ਵਿਚ ਉਸ ਨਾਮ ਦਾ ਟਿਕਾਣਾ (ਹੋ ਜਾਂਦਾ ਹੈ।)"
            },
            "sahib_singh_ru": {
              "main": "в теле того человека оно находит себе обитель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13355,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਮਾਧਿ ਅਨਹਤ ਤਹ ਨਾਦ ॥",
          "roman": "sunn samādh anhat tah nād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਅਫੁਰ ਸੁਰਤ ਜੁੜੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри такого человека сознание пребывает в неколебимом сосредоточении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13356,
          "is_rahao": false,
          "gurmukhi": "ਕਹਨੁ ਨ ਜਾਈ ਅਚਰਜ ਬਿਸਮਾਦ ॥",
          "roman": "kahan na jāī acharaj bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਅਜੇਹਾ ਅਚਰਜ ਇਕ-ਰਸ ਰਾਗ (-ਰੂਪ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ) ਜਿਸ ਦਾ ਬਿਆਨ ਨਹੀਂ ਹੋ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и там сохраняется такое изумительное, невыразимое, ровное блаженство, что его нельзя описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13357,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਦੇਖਿਆ ਜਿਸੁ ਆਪਿ ਦਿਖਾਏ ॥",
          "roman": "tin dekhiā jis āp dikhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਇਹ (ਆਨੰਦ) ਉਸ ਮਨੁੱਖ ਨੇ ਵੇਖਿਆ ਹੈ ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਆਪ ਵਿਖਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но это блаженство увидел лишь тот, кому Сам Бог его показывает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13358,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਜਨ ਸੋਝੀ ਪਾਏ ॥੧॥",
          "roman": "Nānak tis jan sojhī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਨੂੰ (ਉਸ ਆਨੰਦ ਦੀ) ਸਮਝ ਬਖ਼ਸ਼ਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ибо, о Нанак, именно такому человеку Он дарует понимание этого состояния. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1071,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13359,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਅੰਤਰਿ ਸੋ ਬਾਹਰਿ ਅਨੰਤ ॥",
          "roman": "so antar so bāhar anant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੇਅੰਤ ਭਗਵਾਨ ਅੰਦਰ ਬਾਹਰ (ਸਭ ਥਾਈਂ)"
            },
            "sahib_singh_ru": {
              "main": "Этот Беспредельный Бог внутри и снаружи, повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13360,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਬਿਆਪਿ ਰਹਿਆ ਭਗਵੰਤ ॥",
          "roman": "ghaṭ ghaṭ biāp rahiā bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он присутствует в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13361,
          "is_rahao": false,
          "gurmukhi": "ਧਰਨਿ ਮਾਹਿ ਆਕਾਸ ਪਇਆਲ ॥",
          "roman": "dharan māh ākās paiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਤੀ ਅਕਾਸ਼ ਤੇ ਪਤਾਲ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает в земле, в небе и в подземных мирах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13362,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਲੋਕ ਪੂਰਨ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "sarab lok pūran pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਭਵਨਾਂ ਵਿਚ ਮੌਜੂਦ ਹੈ ਤੇ ਸਭ ਦੀ ਪਾਲਨਾ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "присутствует во всех мирах и всех поддерживает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
