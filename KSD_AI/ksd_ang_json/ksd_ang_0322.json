{
  "ang": 322,
  "shabads": [
    {
      "shabad_id": 1268,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14588,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਪਦੁ ਨਿਰਬਾਣੁ ਇਕੋ ਸਿਮਰੀਐ ॥",
          "roman": "jīvan pad nirbāṇ iko simrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если вспоминать одного лишь свободного от желаний Господа, достигается состояние подлинной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14589,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੀ ਨਾਹੀ ਜਾਇ ਕਿਨਿ ਬਿਧਿ ਧੀਰੀਐ ॥",
          "roman": "dūjī nāhī jāe kin bidh dhīrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет другого места прибежища; никаким иным способом ум не может обрести устойчивость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14590,
          "is_rahao": false,
          "gurmukhi": "ਡਿਠਾ ਸਭੁ ਸੰਸਾਰੁ ਸੁਖੁ ਨ ਨਾਮ ਬਿਨੁ ॥",
          "roman": "ḍiṭhā sabh sansār sukh na nām bin",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Весь мир рассмотрен: без Имени Господа счастья не обретается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14591,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਧਨੁ ਹੋਸੀ ਛਾਰੁ ਜਾਣੈ ਕੋਇ ਜਨੁ ॥",
          "roman": "tan dhan hosī chhār jāṇē koi jan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело и богатство обратятся в прах, но лишь редкий человек понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14592,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗ ਰੂਪ ਰਸ ਬਾਦਿ ਕਿ ਕਰਹਿ ਪਰਾਣੀਆ ॥",
          "roman": "raṅg rūp ras bād k karah parāṇīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О живое существо, что ты делаешь? Цвета, формы и наслаждения этого мира напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14593,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭੁਲਾਏ ਆਪਿ ਤਿਸੁ ਕਲ ਨਹੀ ਜਾਣੀਆ ॥",
          "roman": "jis bhulāe āp tis kal nahī jāṇīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Сам Господь сбивает с пути, тот не понимает сути душевного покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14594,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗਿ ਰਤੇ ਨਿਰਬਾਣੁ ਸਚਾ ਗਾਵਹੀ ॥",
          "roman": "raṅg rate nirbāṇ sachā gāvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто окрашен любовью к Господу, воспевают вечного, свободного от желаний Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14595,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਰਣਿ ਦੁਆਰਿ ਜੇ ਤੁਧੁ ਭਾਵਹੀ ॥੨॥",
          "roman": "Nānak saraṇ duār je tudh bhāvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молится: о Господь, если Тебе угодно, живые существа приходят к Твоим вратам и в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1269,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14596,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14597,
          "is_rahao": false,
          "gurmukhi": "ਜੰਮਣੁ ਮਰਣੁ ਨ ਤਿਨੑ ਕਉ ਜੋ ਹਰਿ ਲੜਿ ਲਾਗੇ ॥",
          "roman": "jammaṇ maraṇ na tinh kau jo har laṛ lāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для тех, кто принимает опору Господа, круг рождения и смерти прекращается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14598,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਸੇ ਪਰਵਾਣੁ ਹੋਏ ਹਰਿ ਕੀਰਤਨਿ ਜਾਗੇ ॥",
          "roman": "jīvat se parvāṇ hoe har kīrtan jāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они уже в этой жизни становятся принятыми у Господа, потому что через восхваление Господа остаются бодрствующими и защищёнными от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14599,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗੁ ਜਿਨ ਪਾਇਆ ਸੇਈ ਵਡਭਾਗੇ ॥",
          "roman": "sādhasaṅg jin pāiā seī vaḍbhāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто обрёл общество таких гурмукхов, поистине великие счастливцы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14600,
          "is_rahao": false,
          "gurmukhi": "ਨਾਇ ਵਿਸਰਿਐ ਧ੍ਰਿਗੁ ਜੀਵਣਾ ਤੂਟੇ ਕਚ ਧਾਗੇ ॥",
          "roman": "nāe visariai dhrig jīvaṇā ṭūṭe kach dhāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если забывается Имя Господа, такая жизнь достойна порицания и бесполезна, словно оборванная непрочная нить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14601,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਧੂੜਿ ਪੁਨੀਤ ਸਾਧ ਲਖ ਕੋਟਿ ਪਿਰਾਗੇ ॥੧੬॥",
          "roman": "Nānak dhūṛ punīt sādh lakh koṭ pirāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, пыль стоп святых чище, чем сотни тысяч и миллионы святых мест, подобных Праягу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1270,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14602,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੫ ॥",
          "roman": "salok mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14603,
          "is_rahao": false,
          "gurmukhi": "ਧਰਣਿ ਸੁਵੰਨੀ ਖੜ ਰਤਨ ਜੜਾਵੀ ਹਰਿ ਪ੍ਰੇਮ ਪੁਰਖੁ ਮਨਿ ਵੁਠਾ ॥",
          "roman": "dharaṇ suvaṅnī khaṛ ratan jaṛāvī har prem purakh man vuṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда в уме поселяется Хари, Акал Пуракх, сущность любви, этот ум становится прекрасным, как земля с травой, украшенной жемчужинами росы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14604,
          "is_rahao": false,
          "gurmukhi": "ਸਭੇ ਕਾਜ ਸੁਹੇਲੜੇ ਥੀਏ ਗੁਰੁ ਨਾਨਕੁ ਸਤਿਗੁਰੁ ਤੁਠਾ ॥੧॥",
          "roman": "sabhe kāj suhelaṛe thīe gur Nānak satgur ṭuṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда Гуру, Сатгуру Нанак, становится милостивым к человеку, все его дела становятся лёгкими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1271,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14605,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14606,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਦੀ ਫਿਰਦੀ ਦਹ ਦਿਸਾ ਜਲ ਪਰਬਤ ਬਨਰਾਇ ॥",
          "roman": "phirdī phirdī dah disā jal parbat banrāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Летая повсюду, во всех десяти направлениях, над водами, горами и лесами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14607,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਡਿਠਾ ਮਿਰਤਕੋ ਇਲ ਬਹਿਠੀ ਆਇ ॥੨॥",
          "roman": "jithē ḍiṭhā mirtako il bahiṭhī āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "коршун, где увидел падаль, там и сел; таков и ум, который, отделившись от Господа, падает к порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1272,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14608,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14609,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਰਬ ਸੁਖਾ ਫਲ ਲੋੜੀਅਹਿ ਸੋ ਸਚੁ ਕਮਾਵਉ ॥",
          "roman": "jis sarab sukhā phal loṛīah so sach kamāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я буду вспоминать того Истинного Господа, у Которого просят все счастья и все плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14610,
          "is_rahao": false,
          "gurmukhi": "ਨੇੜੈ ਦੇਖਉ ਪਾਰਬ੍ਰਹਮੁ ਇਕੁ ਨਾਮੁ ਧਿਆਵਉ ॥",
          "roman": "neṛē dekhau pārbraham ik nām dhiāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я буду видеть Парабрахма рядом с собой и созерцать только Его одно Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14611,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਸਗਲ ਕੀ ਰੇਣੁਕਾ ਹਰਿ ਸੰਗਿ ਸਮਾਵਉ ॥",
          "roman": "hoe sagal kī reṇukā har saṅg samāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Став пылью у стоп всех, я сольюсь с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14612,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਨ ਦੇਈ ਕਿਸੈ ਜੀਅ ਪਤਿ ਸਿਉ ਘਰਿ ਜਾਵਉ ॥",
          "roman": "dūkh na deī kisē jīa pat siu ghar jāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я не буду причинять боли ни одному живому существу и с честью войду в свой истинный дом, в присутствие Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14613,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪੁਨੀਤ ਕਰਤਾ ਪੁਰਖੁ ਨਾਨਕ ਸੁਣਾਵਉ ॥੧੭॥",
          "roman": "patit punīt kartā purakh Nānak suṇāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я буду возвещать и другим, что Карта Пуракх очищает даже падших в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1273,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14614,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਦੋਹਾ ਮਃ ੫ ॥",
          "roman": "salok dohā mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок-доха, Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14615,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਜਿ ਸਾਜਨੁ ਮੈ ਕੀਆ ਸਰਬ ਕਲਾ ਸਮਰਥੁ ॥",
          "roman": "ek je sājan mē kīā sarab kalā samrath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я сделал своим другом только одного Хари, Который обладает всеми силами и всемогуществом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14616,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਹਮਾਰਾ ਖੰਨੀਐ ਹਰਿ ਮਨ ਤਨ ਸੰਦੜੀ ਵਥੁ ॥੧॥",
          "roman": "jīu hamārā khaṅnīai har man tan sandaṛī vath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя жизнь предана Ему: Хари — подлинная сущность, нужная и уму, и телу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1274,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14617,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14618,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕਰੁ ਗਹਹਿ ਪਿਆਰੜੇ ਤੁਧੁ ਨ ਛੋਡਾ ਮੂਲਿ ॥",
          "roman": "je kar gahah piāraṛe tudh na chhoḍā mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О возлюбленный Господь, если Ты возьмёшь меня за руку, я никогда не оставлю Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14619,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਛੋਡਨਿ ਸੇ ਦੁਰਜਨਾ ਪੜਹਿ ਦੋਜਕ ਕੈ ਸੂਲਿ ॥੨॥",
          "roman": "har chhoḍan se durjanā paṛah dojak kē sūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те злодейские люди, которые забывают Господа, попадают в невыносимую муку ада."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1275,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14620,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14621,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਨਿਧਾਨ ਘਰਿ ਜਿਸ ਦੈ ਹਰਿ ਕਰੇ ਸੁ ਹੋਵੈ ॥",
          "roman": "sabh nidhān ghar jis dē har kare so hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Господа, в доме Которого все сокровища, происходит только то, что Он делает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14622,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਜੀਵਹਿ ਸੰਤ ਜਨ ਪਾਪਾ ਮਲੁ ਧੋਵੈ ॥",
          "roman": "jap jap jīvah sant jan pāpā mal dhovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые люди живут, вновь и вновь вспоминая Его, ведь Господь смывает всю грязь их грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14623,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਵਸਹਿ ਸੰਕਟ ਸਭਿ ਖੋਵੈ ॥",
          "roman": "charan kamal hirdē vasah saṅkaṭ sabh khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его лотосные стопы пребывают в их сердце, и Господь уничтожает все их страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14624,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਜਿਸੁ ਭੇਟੀਐ ਮਰਿ ਜਨਮਿ ਨ ਰੋਵੈ ॥",
          "roman": "gur pūrā jis bheṭīē mar janam na rovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кому встречается совершенный Гуру, не попадает в круг рождения и смерти и не страдает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14625,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਰਸ ਪਿਆਸ ਨਾਨਕ ਘਣੀ ਕਿਰਪਾ ਕਰਿ ਦੇਵੈ ॥੧੮॥",
          "roman": "prabh daras piās Nānak ghaṇī kirpā kar devē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Нанака сильная жажда видения Господа, но Господь дарует Своё видение только по Своей милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1276,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14626,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਡਖਣਾ ਮਃ ੫ ॥",
          "roman": "salok ḍakhaṇā mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок Дакхана, Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14627,
          "is_rahao": false,
          "gurmukhi": "ਭੋਰੀ ਭਰਮੁ ਵਞਾਇ ਪਿਰੀ ਮੁਹਬਤਿ ਹਿਕੁ ਤੂ ॥",
          "roman": "bhorī bharam vañāe pirī muhabbat hik tū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, если ты устранишь хотя бы малую долю блуждания ума и будешь любить только возлюбленного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14628,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥਹੁ ਵੰਞੈ ਜਾਇ ਤਿਥਾਊ ਮਉਜੂਦੁ ਸੋਇ ॥੧॥",
          "roman": "jithah vañē jāe tithāū maujūd soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "куда бы ты ни пошёл, там же увидишь присутствующим того Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1277,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14629,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14630,
          "is_rahao": false,
          "gurmukhi": "ਚੜਿ ਕੈ ਘੋੜੜੈ ਕੁੰਦੇ ਪਕੜਹਿ ਖੂੰਡੀ ਦੀ ਖੇਡਾਰੀ ॥",
          "roman": "chaṛ kē ghoṛaṛē kunde pakaṛah khūṅḍī dī kheḍārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто умеет играть лишь с палкой, но садится на красивого коня и берёт в руки приклады ружей, выглядят смешно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14631,
          "is_rahao": false,
          "gurmukhi": "ਹੰਸਾ ਸੇਤੀ ਚਿਤੁ ਉਲਾਸਹਿ ਕੁਕੜ ਦੀ ਓਡਾਰੀ ॥੨॥",
          "roman": "haṅsā setī chit ulāsah kukaṛ dī oḍārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Таковы те, кто умеет летать лишь как петух, но воодушевляет свой ум лететь вместе с лебедями; таково состояние манмукхов, подражающих гурмукхам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1278,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14632,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14633,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਉਚਰੈ ਹਰਿ ਸ੍ਰਵਣੀ ਸੁਣੈ ਸੋ ਉਧਰੈ ਮਿਤਾ ॥",
          "roman": "rasnā ucharē har sravaṇī suṇē so udharē mitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг, тот человек, кто языком произносит Имя Хари и ушами слушает Имя Хари, спасается от мирского океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14634,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਸੁ ਲਿਖਹਿ ਲਾਇ ਭਾਵਨੀ ਸੇ ਹਸਤ ਪਵਿਤਾ ॥",
          "roman": "har jas likhah lāe bhāvnī se hast pavitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святы те руки, которые с верой записывают славу Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14635,
          "is_rahao": false,
          "gurmukhi": "ਅਠਸਠਿ ਤੀਰਥ ਮਜਨਾ ਸਭਿ ਪੁੰਨ ਤਿਨਿ ਕਿਤਾ ॥",
          "roman": "aṭhasaṭh tīrath majnā sabh punn tin kitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек словно совершил омовение во всех шестидесяти восьми святых местах и исполнил все добрые дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14636,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰ ਸਾਗਰ ਤੇ ਉਧਰੇ ਬਿਖਿਆ ਗੜੁ ਜਿਤਾ ॥",
          "roman": "sansār sāgar te udhare bikhiā gaṛ jitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такие люди спасаются от погружения в пороки мирского океана и, можно сказать, завоёвывают крепость майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
