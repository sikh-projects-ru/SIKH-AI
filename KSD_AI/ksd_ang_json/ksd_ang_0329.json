{
  "ang": 329,
  "shabads": [
    {
      "shabad_id": 1312,
      "rahao_verse_id": 14964,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14962,
          "is_rahao": false,
          "gurmukhi": "ਮਨਹਿ ਮਾਰਿ ਕਵਨ ਸਿਧਿ ਥਾਪੀ ॥੧॥",
          "roman": "manahi mār kavan sidh thāpī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Умертвив ум, какую успешность можно обрести? Это не является настоящим достижением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14963,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਮੁਨਿ ਜੋ ਮਨੁ ਮਾਰੈ ॥",
          "roman": "kavan so mun jo man mārey.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какой это муни, который умерщвляет ум?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14964,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਕਉ ਮਾਰਿ ਕਹਹੁ ਕਿਸੁ ਤਾਰੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man kau mār kahhu kis tārey. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажите: умертвив ум, кого он спасает? Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14965,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਅੰਤਰਿ ਬੋਲੈ ਸਭੁ ਕੋਈ ॥",
          "roman": "man antar boley sabh koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый человек говорит под побуждением ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14966,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਾਰੇ ਬਿਨੁ ਭਗਤਿ ਨ ਹੋਈ ॥੨॥",
          "roman": "man mārey bin bhagat na hoī. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без обуздания ума, то есть без удержания его от пороков, не может быть и бхагти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14967,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜੋ ਜਾਨੈ ਭੇਉ ॥",
          "roman": "kaho Kabīr jo jāney bheu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: кто понимает эту тайну,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14968,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮਧੁਸੂਦਨੁ ਤ੍ਰਿਭਵਣ ਦੇਉ ॥੩॥੨੮॥",
          "roman": "man madhusūdan tribhavaṇ deu. ||3||28||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "его ум становится образом Бога-Мадхусудана, светящего трем мирам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1313,
      "rahao_verse_id": 14973,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14969,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gaurī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14970,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਜੁ ਦੀਸਹਿ ਅੰਬਰਿ ਤਾਰੇ ॥",
          "roman": "oī jo dīseh aṃbar tārey.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те звезды, что видны в небе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14971,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਿ ਓਇ ਚੀਤੇ ਚੀਤਨਹਾਰੇ ॥੧॥",
          "roman": "kin oī chītey chītanhārey. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "какой Художник начертал их?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14972,
          "is_rahao": true,
          "gurmukhi": "ਕਹੁ ਰੇ ਪੰਡਿਤ ਅੰਬਰੁ ਕਾ ਸਿਉ ਲਾਗਾ ॥",
          "roman": "kaho re paṇḍit aṃbar kā siu lāgā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, о пандит: на чем держится небо?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14973,
          "is_rahao": true,
          "gurmukhi": "ਬੂਝੈ ਬੂਝਨਹਾਰੁ ਸਭਾਗਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "būjhē būjhanhār sabhāgā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь счастливый мудрец понимает эту тайну. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14974,
          "is_rahao": false,
          "gurmukhi": "ਸੂਰਜ ਚੰਦੁ ਕਰਹਿ ਉਜੀਆਰਾ ॥",
          "roman": "sūraj chand karah ujīārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Солнце и луна дают свет в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14975,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਪਸਰਿਆ ਬ੍ਰਹਮ ਪਸਾਰਾ ॥੨॥",
          "roman": "sabh meh pasriā brahm pasārā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во всем распространено сияние Божественной Джот, проявление Брахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14976,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜਾਨੈਗਾ ਸੋਇ ॥",
          "roman": "kaho Kabīr jānēgā soī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: эту тайну поймет только тот,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14977,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਰਾਮੁ ਮੁਖਿ ਰਾਮੈ ਹੋਇ ॥੩॥੨੯॥",
          "roman": "hirdē rām mukh rāmē hoī. ||3||29||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "в чьем сердце пребывает Рам и чьи уста произносят только Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1314,
      "rahao_verse_id": 14982,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14978,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gaurī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14979,
          "is_rahao": false,
          "gurmukhi": "ਬੇਦ ਕੀ ਪੁਤ੍ਰੀ ਸਿੰਮ੍ਰਿਤਿ ਭਾਈ ॥",
          "roman": "bed kī putrī simrit bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, эта Симрити, дочь Вед, созданная на их основе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14980,
          "is_rahao": false,
          "gurmukhi": "ਸਾਂਕਲ ਜੇਵਰੀ ਲੈ ਹੈ ਆਈ ॥੧॥",
          "roman": "sāṅkal jevrī lē hē āī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "принесла с собой цепи варн-ашрамов и веревки обрядов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14981,
          "is_rahao": true,
          "gurmukhi": "ਆਪਨ ਨਗਰੁ ਆਪ ਤੇ ਬਾਧਿਆ ॥",
          "roman": "āpan nagar āp te bādhiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Она сама связала всех своих последователей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14982,
          "is_rahao": true,
          "gurmukhi": "ਮੋਹ ਕੈ ਫਾਧਿ ਕਾਲ ਸਰੁ ਸਾਂਧਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "moh kē phādh kāl sar sāndhiā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поймав их в петлю привязанности, она натянула над ними стрелу смерти и рождения. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14983,
          "is_rahao": false,
          "gurmukhi": "ਕਟੀ ਨ ਕਟੈ ਤੂਟਿ ਨਹ ਜਾਈ ॥",
          "roman": "kaṭī na kaṭē ṭūṭ nah jāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эта петля не разрубается разрубанием и сама не рвется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14984,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਸਾਪਨਿ ਹੋਇ ਜਗ ਕਉ ਖਾਈ ॥੨॥",
          "roman": "sā sāpan hoi jag kau khāī. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Она стала змеей и пожирает мир, уничтожая собственных последователей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14985,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਦੇਖਤ ਜਿਨਿ ਸਭੁ ਜਗੁ ਲੂਟਿਆ ॥",
          "roman": "ham dekhat jin sabh jag lūṭiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На наших глазах она обманула весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14986,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਮੈ ਰਾਮ ਕਹਿ ਛੂਟਿਆ ॥੩॥੩੦॥",
          "roman": "kaho Kabīr mē rām kahi chhūṭiā. ||3||30||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я спасся от нее, повторяя Рам, вспоминая Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1315,
      "rahao_verse_id": 14991,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14987,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gaurī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14988,
          "is_rahao": false,
          "gurmukhi": "ਦੇਇ ਮੁਹਾਰ ਲਗਾਮੁ ਪਹਿਰਾਵਉ ॥",
          "roman": "dei muhār lagām pahirāvau.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я надеваю на коня-ум намордник воздержания от хвалы и хулы и узду любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14989,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤ ਜੀਨੁ ਗਗਨ ਦਉਰਾਵਉ ॥੧॥",
          "roman": "sagalat jīn gagan daurāvau. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Надев седло знания о всепроникающем Боге, я заставляю ум лететь в страну Нирankar, то есть соединяю его с памятью о Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14990,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੈ ਬੀਚਾਰਿ ਅਸਵਾਰੀ ਕੀਜੈ ॥",
          "roman": "apnē bīchār asvārī kījē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сядем верхом на коня знания своего истинного существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14991,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਕੈ ਪਾਵੜੈ ਪਗੁ ਧਰਿ ਲੀਜੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sahaj kē pāvṛē pag dhar lījē. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поставим ногу-разум в стремя состояния сахадж, чтобы не упасть. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14992,
          "is_rahao": false,
          "gurmukhi": "ਚਲੁ ਰੇ ਬੈਕੁੰਠ ਤੁਝਹਿ ਲੇ ਤਾਰਉ ॥",
          "roman": "chal re bēkunṭh tujheh le tārau.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Иди, о конь-ум, я покажу тебе прогулки по Бэкунтху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14993,
          "is_rahao": false,
          "gurmukhi": "ਹਿਚਹਿ ਤ ਪ੍ਰੇਮ ਕੈ ਚਾਬੁਕ ਮਾਰਉ ॥੨॥",
          "roman": "hicheh ta prem kē chābuk mārau. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если станешь упрямиться, я ударю тебя кнутом любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14994,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਕਬੀਰ ਭਲੇ ਅਸਵਾਰਾ ॥ ਬੇਦ ਕਤੇਬ ਤੇ ਰਹਹਿ ਨਿਰਾਰਾ ॥੩॥੩੧॥",
          "roman": "kahat Kabīr bhaley asvārā. bed kateb te raheh nirārā. ||3||31||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: такие мудрые всадники, владеющие своим умом, остаются в стороне от споров о Ведах и Катебах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1316,
      "rahao_verse_id": 14999,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14995,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gaurī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14996,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਮੁਖਿ ਪਾਂਚਉ ਅੰਮ੍ਰਿਤ ਖਾਏ ॥",
          "roman": "jih mukh pāñchau amrit khāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем самым ртом, которым ели пять лучших сладких веществ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14997,
          "is_rahao": false,
          "gurmukhi": "ਤਿਹ ਮੁਖ ਦੇਖਤ ਲੂਕਟ ਲਾਏ ॥੧॥",
          "roman": "tih mukh dekhat lūkaṭ lāe. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "после смерти перед глазами людей подносят к нему пламя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14998,
          "is_rahao": true,
          "gurmukhi": "ਇਕੁ ਦੁਖੁ ਰਾਮ ਰਾਇ ਕਾਟਹੁ ਮੇਰਾ ॥",
          "roman": "ik dukh rām rāi kāṭah merā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой прекрасный Рам, устрани одну мою боль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14999,
          "is_rahao": true,
          "gurmukhi": "ਅਗਨਿ ਦਹੈ ਅਰੁ ਗਰਭ ਬਸੇਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "agan dahē ar garabh baserā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это огонь жажды, который сжигает, и пребывание в утробе, то есть повторное рождение и смерть. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15000,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਬਿਗੂਤੀ ਬਹੁ ਬਿਧਿ ਭਾਤੀ ॥",
          "roman": "kāiā bigūtī bah bidh bhātī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "После смерти это тело портится многими разными способами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15001,
          "is_rahao": false,
          "gurmukhi": "ਕੋ ਜਾਰੇ ਕੋ ਗਡਿ ਲੇ ਮਾਟੀ ॥੨॥",
          "roman": "ko jārey ko gaḍ le māṭī. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Одни сжигают его, другие закапывают в землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15002,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਰਿ ਚਰਣ ਦਿਖਾਵਹੁ ॥",
          "roman": "kaho Kabīr har charaṇ dikhāvah.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: о Хари, даруй мне видение Твоих стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15003,
          "is_rahao": false,
          "gurmukhi": "ਪਾਛੈ ਤੇ ਜਮੁ ਕਿਉ ਨ ਪਠਾਵਹੁ ॥੩॥੩੨॥",
          "roman": "pāchhē te jam kiu na paṭhāvah. ||3||32||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "После этого, если хочешь, пошли даже Яма забрать мои праны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1317,
      "rahao_verse_id": 15008,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15004,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gaurī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15005,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਪਾਵਕੁ ਆਪੇ ਪਵਨਾ ॥",
          "roman": "āpey pāvak āpey pavnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господин является и огнем, и ветром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15006,
          "is_rahao": false,
          "gurmukhi": "ਜਾਰੈ ਖਸਮੁ ਤ ਰਾਖੈ ਕਵਨਾ ॥੧॥",
          "roman": "jārē khasam ta rākhē kavnā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Сам Господин начнет сжигать живое существо, кто сможет его спасти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15007,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਜਪਤ ਤਨੁ ਜਰਿ ਕੀ ਨ ਜਾਇ ॥",
          "roman": "rām japat tan jar kī na jāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек вспоминает Рама, пусть даже тело сгорит — он не тревожится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15008,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਚਿਤੁ ਰਹਿਆ ਸਮਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām nām chit rahiā samāe. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его сознание остается погруженным в Имя Рама. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15009,
          "is_rahao": false,
          "gurmukhi": "ਕਾ ਕੋ ਜਰੈ ਕਾਹਿ ਹੋਇ ਹਾਨਿ ॥",
          "roman": "kā ko jarē kāh hoi hān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что и у кого сгорает? Кому бывает ущерб?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15010,
          "is_rahao": false,
          "gurmukhi": "ਨਟ ਵਟ ਖੇਲੈ ਸਾਰਿਗਪਾਨਿ ॥੨॥",
          "roman": "naṭ vaṭ khelē sārīg pān. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог, Саригпани, Сам играет в разных обликах, как актеры на сцене."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15011,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਅਖਰ ਦੁਇ ਭਾਖਿ ॥",
          "roman": "kaho Kabīr akhar dui bhākh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: запомни эту малую истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15012,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇਗਾ ਖਸਮੁ ਤ ਲੇਇਗਾ ਰਾਖਿ ॥੩॥੩੩॥",
          "roman": "hoigā khasam ta leigā rākh. ||3||33||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Господину будет угодно, Он Сам спасет, где это потребуется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1318,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15013,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਦੁਪਦੇ ॥",
          "roman": "Gaurī Kabīr jī dupde.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи, двустишия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15014,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਮੈ ਜੋਗ ਧਿਆਨ ਚਿਤੁ ਲਾਇਆ ॥",
          "roman": "nā mē jog dhiān chit lāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я не сосредоточил сознание на медитации йоги, то есть на самадхи, которые она описывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15015,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੈਰਾਗ ਨ ਛੂਟਸਿ ਮਾਇਆ ॥੧॥",
          "roman": "bin bērāg na chhūṭas māiā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без вайрага, отрешенности от привязанности к миру, не будет освобождения от Майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15016,
          "is_rahao": false,
          "gurmukhi": "ਕੈਸੇ ਜੀਵਨੁ ਹੋਇ ਹਮਾਰਾ ॥",
          "roman": "kēse jīvan hoe hamārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как может быть наша истинная жизнь?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
