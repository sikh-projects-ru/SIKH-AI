{
  "ang": 330,
  "shabads": [
    {
      "shabad_id": 1318,
      "rahao_verse_id": 15017,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15017,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਨ ਹੋਇ ਰਾਮ ਨਾਮ ਅਧਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jab na hoē rām nām adhārā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда нет опоры на Имя Рама. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15018,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਖੋਜਉ ਅਸਮਾਨ ॥",
          "roman": "kah kabīr khojau asmān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я ищу даже в небесах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15019,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਸਮਾਨ ਨ ਦੇਖਉ ਆਨ ॥੨॥੩੪॥",
          "roman": "rām samān na dēkhau ān. ||2||34||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но не вижу никого другого, равного Раму. ||2||34||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1319,
      "rahao_verse_id": 15024,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15020,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15021,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਰਿ ਰਚਿ ਰਚਿ ਬਾਧਤ ਪਾਗ ॥",
          "roman": "jih sir rach rach bādhat pāg.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ту голову, на которой человек снова и снова красиво повязывает тюрбан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15022,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਰੁ ਚੁੰਚ ਸਵਾਰਹਿ ਕਾਗ ॥੧॥",
          "roman": "so sir chuñch savārahi kāg. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "после смерти вороны будут «украшать» своими клювами. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15023,
          "is_rahao": true,
          "gurmukhi": "ਇਸੁ ਤਨ ਧਨ ਕੋ ਕਿਆ ਗਰਬਈਆ ॥",
          "roman": "is tan dhan ko kiā garbaīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, чем ты гордишься этим телом и этим богатством?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15024,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਕਾਹੇ ਨ ਦ੍ਰਿੜੑੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām nām kāhē na driṛhīā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Почему ты не утверждаешь в себе Имя Бога, почему не поминаешь Его? ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15025,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਕਬੀਰ ਸੁਨਹੁ ਮਨ ਮੇਰੇ ॥",
          "roman": "kahat kabīr sunah man mērē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: слушай, мой ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15026,
          "is_rahao": false,
          "gurmukhi": "ਇਹੀ ਹਵਾਲ ਹੋਹਿਗੇ ਤੇਰੇ ॥੨॥੩੫॥",
          "roman": "ihī havāl hohigē tērē. ||2||35||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "когда придёт смерть, с тобой будет то же самое. ||2||35||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1320,
      "rahao_verse_id": 15033,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15027,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਕੇ ਪਦੇ ਪੈਤੀਸ ॥",
          "roman": "gauṛī guārērī kē padē pētīs.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тридцать пять падов Гаури Гуарери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15028,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗਉੜੀ ਗੁਆਰੇਰੀ ਅਸਟਪਦੀ ਕਬੀਰ ਜੀ ਕੀ",
          "roman": "rāg gauṛī guārērī asṭapadī kabīr jī kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Гаури Гуарери, аштапади Кабира Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15029,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satigur prasād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар, по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15030,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਮਾਂਗਤ ਦੁਖੁ ਆਗੈ ਆਵੈ ॥",
          "roman": "sukh māṅgat dukh āgē āvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если просить тот мирской सुख, вслед за ним приходит страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15031,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੁ ਹਮਹੁ ਨ ਮਾਂਗਿਆ ਭਾਵੈ ॥੧॥",
          "roman": "so sukh hamah na māṅgiā bhāvē. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мне не нравится просить такой सुख, в нём нет нужды. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15032,
          "is_rahao": true,
          "gurmukhi": "ਬਿਖਿਆ ਅਜਹੁ ਸੁਰਤਿ ਸੁਖ ਆਸਾ ॥",
          "roman": "bikhiā ajah surat sukh āsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже теперь наше внимание привязано к майе, и от неё мы ждём счастья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15033,
          "is_rahao": true,
          "gurmukhi": "ਕੈਸੇ ਹੋਈ ਹੈ ਰਾਜਾ ਰਾਮ ਨਿਵਾਸਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kēsē hoī hē rājā rām nivāsā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как же тогда в этом внимании сможет пребывать светозарный Нирankar, Рам? ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15034,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਸੁਖ ਤੇ ਸਿਵ ਬ੍ਰਹਮ ਡਰਾਨਾ ॥",
          "roman": "is sukh tē siv brahm ḍarānā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От этого майского счастья даже Шива и Брахма отстрашились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15035,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੁ ਹਮਹੁ ਸਾਚੁ ਕਰਿ ਜਾਨਾ ॥੨॥",
          "roman": "so sukh hamah sāch kar jānā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но мы, мирские существа, приняли этот सुख за истинный. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15036,
          "is_rahao": false,
          "gurmukhi": "ਸਨਕਾਦਿਕ ਨਾਰਦ ਮੁਨਿ ਸੇਖਾ ॥",
          "roman": "sanakādik nārad mun sēkhā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Санак и другие сыновья Брахмы, Нарад-муни и Шеш-наг —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15037,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਭੀ ਤਨ ਮਹਿ ਮਨੁ ਨਹੀ ਪੇਖਾ ॥੩॥",
          "roman": "tin bhī tan mahi man nahī pēkhā. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даже они, из-за привязанности к майскому счастью, не увидели ум внутри тела, то есть их ум не удержался во внутренней душе. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15038,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਨ ਕਉ ਕੋਈ ਖੋਜਹੁ ਭਾਈ ॥",
          "roman": "is man kau koī khojah bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, пусть кто-нибудь исследует этот ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15039,
          "is_rahao": false,
          "gurmukhi": "ਤਨ ਛੂਟੇ ਮਨੁ ਕਹਾ ਸਮਾਈ ॥੪॥",
          "roman": "tan chhūṭē man kahā samāī. ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда он отделяется от тела, где тогда этот ум находит опору? ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15040,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਜੈਦੇਉ ਨਾਮਾਂ ॥",
          "roman": "gur parsādī jēdēu nāmāṅ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Сатгуру Джайдева и Намдев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15041,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕੈ ਪ੍ਰੇਮਿ ਇਨ ਹੀ ਹੈ ਜਾਨਾਂ ॥੫॥",
          "roman": "bhagat kē prēm in hī hē jānāṅ. ||5||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "только такие бхагаты, из любви к преданности, поняли эту истину. ||5||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15042,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਨ ਕਉ ਨਹੀ ਆਵਨ ਜਾਨਾ ॥",
          "roman": "is man kau nahī āvan jānā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Душе того человека больше не приходится входить в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15043,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਭਰਮੁ ਗਇਆ ਤਿਨਿ ਸਾਚੁ ਪਛਾਨਾ ॥੬॥",
          "roman": "jis kā bharam gaiā tin sāch pachhānā. ||6||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, чьё блуждание ради सुखов исчезло, распознал вечного Господа и вошёл с Ним в связь. ||6||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15044,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਨ ਕਉ ਰੂਪੁ ਨ ਰੇਖਿਆ ਕਾਈ ॥",
          "roman": "is man kau rūp na rēkhiā kāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У этого живого существа, в действительности, нет отдельной от Бога формы или признака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15045,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਹੋਇਆ ਹੁਕਮੁ ਬੂਝਿ ਸਮਾਈ ॥੭॥",
          "roman": "hukmē hoiā hukam būjh samāī. ||7||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Хукаму оно стало как бы отдельным, а поняв Хукам, снова растворяется в Нём. ||7||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15046,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਮਨ ਕਾ ਕੋਈ ਜਾਨੈ ਭੇਉ ॥",
          "roman": "is man kā koī jānē bhēu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если кто-нибудь познаёт тайну этого ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15047,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਮਨਿ ਲੀਣ ਭਏ ਸੁਖਦੇਉ ॥੮॥",
          "roman": "ih man līṇ bhaē sukhdēu. ||8||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то через этот самый ум, растворившись внутри, он становится образом Бога, сущего как блаженство. ||8||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15048,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਏਕੁ ਅਰੁ ਸਗਲ ਸਰੀਰਾ ॥",
          "roman": "jīu ēk ar sagal sarīrā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один Атман, одна Божественная Свет-сущность присутствует во всех телах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15049,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਨ ਕਉ ਰਵਿ ਰਹੇ ਕਬੀਰਾ ॥੯॥੧॥੩੬॥",
          "roman": "is man kau rav rahē kabīrā. ||9||1||36||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир поминает этот всепроникающий Ум, то есть Параматму, который сам один и пребывает во всех телах. ||9||1||36||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1321,
      "rahao_verse_id": 15052,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15050,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ॥",
          "roman": "gauṛī guārērī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури Гуарери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15051,
          "is_rahao": true,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਏਕ ਨਾਮ ਜੋ ਜਾਗੇ ॥",
          "roman": "ahinis ēk nām jo jāgē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые день и ночь бодрствуют только в Имени Бога, пробудившись от сна майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15052,
          "is_rahao": true,
          "gurmukhi": "ਕੇਤਕ ਸਿਧ ਭਏ ਲਿਵ ਲਾਗੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kētak sidh bhaē liv lāgē. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "многие из них достигли завершения жизненного пути, удерживая внимание в Имени. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15053,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਕ ਸਿਧ ਸਗਲ ਮੁਨਿ ਹਾਰੇ ॥",
          "roman": "sādhak sidh sagal mun hārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Делатели йогических практик, достигшие йоги и все муни устали, ища иные средства переправы через мир-океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15054,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਨਾਮ ਕਲਿਪ ਤਰ ਤਾਰੇ ॥੧॥",
          "roman": "ēk nām kalip tar tārē. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только Имя Бога — как древо исполнения желаний: оно переправляет существ. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15055,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਹਰਿ ਹਰੇ ਸੁ ਹੋਹਿ ਨ ਆਨਾ ॥",
          "roman": "jo har harē so hoh na ānā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто поминают только Хари, не остаются отдельными от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15056,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਰਾਮ ਨਾਮ ਪਛਾਨਾ ॥੨॥੩੭॥",
          "roman": "kahi kabīr rām nām pachhānā. ||2||37||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: они распознали Имя Рама, вошли с Ним в глубокую связь. ||2||37||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1322,
      "rahao_verse_id": 15059,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 15057,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਭੀ ਸੋਰਠਿ ਭੀ ॥",
          "roman": "gauṛī bhī soraṭh bhī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это следует петь и в рагини Гаури, и в рагини Соратх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15058,
          "is_rahao": true,
          "gurmukhi": "ਰੇ ਜੀਅ ਨਿਲਜ ਲਾਜ ਤੋੁਹਿ ਨਾਹੀ ॥",
          "roman": "rē jīa nilaj lāj tuh nāhī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О бесстыдный ум, тебе не стыдно?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15059,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਤਜਿ ਕਤ ਕਾਹੂ ਕੇ ਜਾਂਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har taj kat kāhū kē jāṅhī. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив Бога, куда и к кому ты идёшь, почему ищешь другие опоры? ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15060,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੋ ਠਾਕੁਰੁ ਊਚਾ ਹੋਈ ॥",
          "roman": "jā ko ṭhākur ūchā hoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей Владыка велик,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15061,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਪਰ ਘਰ ਜਾਤ ਨ ਸੋਹੀ ॥੧॥",
          "roman": "so jan par ghar jāt na sohī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "не выглядит достойно, когда ходит по чужим домам. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15062,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਾਹਿਬੁ ਰਹਿਆ ਭਰਪੂਰਿ ॥",
          "roman": "so sāhib rahiā bharpūr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот Владыка-Прабху присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15063,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸੰਗਿ ਨਾਹੀ ਹਰਿ ਦੂਰਿ ॥੨॥",
          "roman": "sadā saṅg nāhī har dūr. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он всегда с тобой, Хари не далёк от тебя. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15064,
          "is_rahao": false,
          "gurmukhi": "ਕਵਲਾ ਚਰਨ ਸਰਨ ਹੈ ਜਾ ਕੇ ॥",
          "roman": "kavalā charan saran hē jā kē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже Лакшми сидит в прибежище стоп того Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15065,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਜਨ ਕਾ ਨਾਹੀ ਘਰ ਤਾ ਕੇ ॥੩॥",
          "roman": "kah jan kā nāhī ghar tā kē. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О человек, скажи: чего может не хватать в Его доме? ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15066,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕੋਊ ਕਹੈ ਜਾਸੁ ਕੀ ਬਾਤਾ ॥",
          "roman": "sabh koū kahē jās kī bātā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О том Прабху, чьи величия всякое существо рассказывает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15067,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੰਮ੍ਰਥੁ ਨਿਜ ਪਤਿ ਹੈ ਦਾਤਾ ॥੪॥",
          "roman": "so samrath nij pat hē dātā. ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он всесилен, Он наш Господин и Податель всех благ. ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15068,
          "is_rahao": false,
          "gurmukhi": "ਕਹੈ ਕਬੀਰੁ ਪੂਰਨ ਜਗ ਸੋਈ ॥",
          "roman": "kahē kabīr pūran jag soī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: в мире только тот человек полон достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 15069,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਹਿਰਦੈ ਅਵਰੁ ਨ ਹੋਈ ॥੫॥੩੮॥",
          "roman": "jā kē hirdē avar na hoī. ||5||38||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце нет никого другого как подателя, кроме Прабху. ||5||38||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
