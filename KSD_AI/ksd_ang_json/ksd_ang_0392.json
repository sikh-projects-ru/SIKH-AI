{
  "ang": 392,
  "shabads": [
    {
      "shabad_id": 1521,
      "rahao_verse_id": 17893,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 17890,
          "is_rahao": false,
          "gurmukhi": "ਸੰਚਤ ਸੰਚਤ ਥੈਲੀ ਕੀਨੑੀ ॥",
          "roman": "sañchat sañchat thēlī kīnhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋੜਦਿਆਂ ਜੋੜਦਿਆਂ (ਜੇ ਉਸ ਨੇ) ਖ਼ਜ਼ਾਨਾ (ਭੀ) ਬਣਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "если, накапливая и накапливая, он создал себе сокровищницу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17891,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਉਸ ਤੇ ਡਾਰਿ ਅਵਰ ਕਉ ਦੀਨੑੀ ॥੧॥",
          "roman": "prabh us te ḍār avar kau dīnhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਭੀ ਕੀਹ ਹੋਇਆ?) ਪਰਮਾਤਮਾ ਨੇ (ਆਖ਼ਰ) ਉਸ ਪਾਸੋਂ ਖੋਹ ਕੇ ਕਿਸੇ ਹੋਰ ਨੂੰ ਦੇ ਦਿੱਤਾ (ਮੌਤ ਵੇਲੇ ਉਹ ਆਪਣੇ ਨਾਲ ਤਾਂ ਨਾਹ ਲੈ ਜਾ ਸਕਿਆ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "то что из этого? В конце концов Бог отнял у него всё это и отдал другому: в час смерти он ведь не смог унести это с собой. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17892,
          "is_rahao": true,
          "gurmukhi": "ਕਾਚ ਗਗਰੀਆ ਅੰਭ ਮਝਰੀਆ ॥",
          "roman": "kāch gagarīā aṃbh majhrīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹ ਮਨੁੱਖਾ ਸਰੀਰ ਪਾਣੀ ਵਿਚ ਪਈ ਹੋਈ) ਕੱਚੀ ਮਿੱਟੀ ਦੀ ਗਾਗਰ (ਵਾਂਗ ਹੈ ਜੋ ਹਵਾ ਨਾਲ ਉਛਲ-ਉਛਲ ਕੇ) ਪਾਣੀ ਵਿਚ ਹੀ (ਗਲ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Это человеческое тело подобно сырому глиняному сосуду, лежащему в воде: подпрыгивая от ветра, он там же в воде и распадается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17893,
          "is_rahao": true,
          "gurmukhi": "ਗਰਬਿ ਗਰਬਿ ਉਆਹੂ ਮਹਿ ਪਰੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "garab garab uāhū meh parīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸੇ ਤਰ੍ਹਾਂ ਮਨੁੱਖ) ਅਹੰਕਾਰ ਕਰ ਕਰ ਕੇ ਉਸੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ) ਵਿਚ ਹੀ ਡੁੱਬ ਜਾਂਦਾ ਹੈ (ਆਪਣਾ ਆਤਮਕ ਜੀਵਨ ਗ਼ਰਕ ਕਰ ਲੈਂਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Так и человек, снова и снова предаваясь гордости, тонет в том же самом океане мира и губит свою духовную жизнь. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17894,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਹੋਇਓ ਭਇਆ ਨਿਹੰਗਾ ॥",
          "roman": "nirbhau hoio bhaiā nihaṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਰਾਜ ਦੇ ਮਾਣ ਵਿਚ ਜੇ ਉਹ ਮੌਤ ਵਲੋਂ) ਨਿਡਰ ਹੋ ਗਿਆ ਨਿਧੜਕ ਹੋ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если из-за царского величия он стал бесстрашным перед смертью и совсем беззаботным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17895,
          "is_rahao": false,
          "gurmukhi": "ਚੀਤਿ ਨ ਆਇਓ ਕਰਤਾ ਸੰਗਾ ॥",
          "roman": "chīt na āio kartā saṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਉਸ ਨੂੰ) ਹਰ ਵੇਲੇ ਨਾਲ-ਵੱਸਦਾ ਕਰਤਾਰ ਕਦੇ ਯਾਦ ਨਾਹ ਆਇਆ,"
            },
            "sahib_singh_ru": {
              "main": "если ему ни разу не пришёл на ум Творец, всегда пребывающий рядом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17896,
          "is_rahao": false,
          "gurmukhi": "ਲਸਕਰ ਜੋੜੇ ਕੀਆ ਸੰਬਾਹਾ ॥",
          "roman": "laskar joṛe kīā saṃbāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਉਸ ਨੇ) ਫ਼ੌਜਾਂ ਜਮ੍ਹਾਂ ਕਰ ਕਰ ਕੇ ਬੜਾ ਲਸ਼ਕਰ ਬਣਾ ਲਿਆ (ਤਾਂ ਭੀ ਕੀਹ ਹੋਇਆ?)"
            },
            "sahib_singh_ru": {
              "main": "если он, собирая войска, создал огромное воинство, то что из этого?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17897,
          "is_rahao": false,
          "gurmukhi": "ਨਿਕਸਿਆ ਫੂਕ ਤ ਹੋਇ ਗਇਓ ਸੁਆਹਾ ॥੨॥",
          "roman": "niksiā phūk ta hoi gaio suāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਅੰਤ ਵੇਲੇ) ਉਸ ਦੇ ਸੁਆਸ ਨਿਕਲ ਗਏ ਤਾਂ (ਉਸ ਦਾ ਸਰੀਰ) ਮਿੱਟੀ ਹੋ ਗਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Когда в конце его дыхание вышло, тело стало прахом. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17898,
          "is_rahao": false,
          "gurmukhi": "ਊਚੇ ਮੰਦਰ ਮਹਲ ਅਰੁ ਰਾਨੀ ॥",
          "roman": "ūche mandar mahal ar rānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇ ਉਸ ਨੂੰ) ਉੱਚੇ ਮਹਲ ਮਾੜੀਆਂ (ਰਹਿਣ ਲਈ ਮਿਲ ਗਏ) ਅਤੇ (ਸੁੰਦਰ) ਰਾਣੀ (ਮਿਲ ਗਈ।)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если ему достались высокие дворцы и палаты, и прекрасная царица,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17899,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤਿ ਘੋੜੇ ਜੋੜੇ ਮਨਿ ਭਾਨੀ ॥",
          "roman": "hast ghoṛe joṛe man bhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਉਸ ਨੇ) ਹਾਥੀ ਘੋੜੇ (ਵਧੀਆ) ਮਨ-ਭਾਉਂਦੇ ਕੱਪੜੇ (ਇਕੱਠੇ ਕਰ ਲਏ।"
            },
            "sahib_singh_ru": {
              "main": "если он собрал слонов, коней и приятные сердцу одежды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17900,
          "is_rahao": false,
          "gurmukhi": "ਵਡ ਪਰਵਾਰੁ ਪੂਤ ਅਰੁ ਧੀਆ ॥",
          "roman": "vaḍ parvār pūt ar dhīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ) ਪੁੱਤਰਾਂ ਧੀਆਂ ਵਾਲਾ ਵੱਡੇ ਪਰਵਾਰ ਵਾਲਾ ਬਣ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "если он стал человеком с большим семейством, с сыновьями и дочерьми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17901,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਪਚੇ ਪਚਿ ਅੰਧਾ ਮੂਆ ॥੩॥",
          "roman": "moh pache pach andhā mūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਤਾਂ (ਮਾਇਆ ਦੇ) ਮੋਹ ਵਿਚ ਖ਼ੁਆਰ ਹੋ ਹੋ ਕੇ (ਉਹ ਮਾਇਆ ਦੇ) ਮੋਹ ਵਿਚ (ਅੰਨ੍ਹਾ ਹੋਇਆ ਹੋਇਆ) ਆਤਮਕ ਮੌਤ ਹੀ ਸਹੇੜ ਬੈਠਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то всё же, истощаясь и изводясь в привязанности к майе, он ослеплённый этой привязанностью обрёл духовную смерть. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17902,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਹਿ ਉਪਾਹਾ ਤਿਨਹਿ ਬਿਨਾਹਾ ॥",
          "roman": "jineh upāhā tineh bināhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ (ਉਸ ਨੂੰ) ਪੈਦਾ ਕੀਤਾ ਸੀ ਉਸੇ ਨੇ ਉਸ ਨੂੰ ਨਾਸ ਭੀ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот самый Бог, который создал его, тот и разрушил его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17903,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗ ਰਸਾ ਜੈਸੇ ਸੁਪਨਾਹਾ ॥",
          "roman": "raṅg rasā jēse supnāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਮਾਣੇ ਹੋਏ ਰੰਗ-ਤਮਾਸ਼ੇ ਤੇ ਮੌਜ ਮੇਲੇ ਸੁਪਨੇ ਵਾਂਗ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "а все его удовольствия, зрелища и наслаждения стали как сон."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17904,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਮੁਕਤਾ ਤਿਸੁ ਰਾਜੁ ਮਾਲੁ ॥",
          "roman": "soī muktā tis rāj māl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ) ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ ਉਸ ਦੇ ਪਾਸ (ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ) ਰਾਜ ਤੇ ਧਨ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот человек остаётся спасённым от привязанности к майе; у него и есть подлинное царство и богатство, пребывающее вечно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17905,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਜਿਸੁ ਖਸਮੁ ਦਇਆਲੁ ॥੪॥੩੫॥੮੬॥",
          "roman": "nānak dās jis khasam daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਜਿਸ ਉੱਤੇ ਖਸਮ ਪ੍ਰਭੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ (ਤੇ ਜਿਸ ਨੂੰ ਆਪਣੇ ਨਾਮ ਦਾ ਖ਼ਜ਼ਾਨਾ ਬਖ਼ਸ਼ਦਾ ਹੈ) ॥੪॥੩੫॥੮੬॥"
            },
            "sahib_singh_ru": {
              "main": "о раб Нанак, — тот, к кому Господь-Муж милостив и кому Он дарует сокровище Своего Имени. ॥4॥35॥86॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1522,
      "rahao_verse_id": 17912,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 17906,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17907,
          "is_rahao": false,
          "gurmukhi": "ਇਨੑ ਸਿਉ ਪ੍ਰੀਤਿ ਕਰੀ ਘਨੇਰੀ ॥",
          "roman": "inh siu prīt karī ghanerī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇ ਇਸ (ਮਾਇਆ) ਨਾਲ ਬਹੁਤੀ ਪ੍ਰੀਤਿ ਕਰੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если с этой майей установить большую любовь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17908,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਮਿਲੀਐ ਤਉ ਵਧੈ ਵਧੇਰੀ ॥",
          "roman": "jau milīē tau vadhē vadherī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਜਿਉਂ ਜਿਉਂ ਇਸ ਨਾਲ ਸਾਥ ਬਣਾਈਦਾ ਹੈ, ਤਿਉਂ ਤਿਉਂ ਇਸ ਨਾਲ ਮੋਹ ਵਧਦਾ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда чем больше с ней сближаешься, тем больше возрастает привязанность к ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17909,
          "is_rahao": false,
          "gurmukhi": "ਗਲਿ ਚਮੜੀ ਜਉ ਛੋਡੈ ਨਾਹੀ ॥",
          "roman": "gal chamṛī jau chhoḍē nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਖ਼ਰ) ਜਦੋਂ ਇਹ ਗਲ ਨਾਲ ਚੰਬੜੀ ਹੋਈ ਛੱਡਦੀ ਹੀ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Когда в конце концов она, прилипнув к шее, уже совсем не отпускает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17910,
          "is_rahao": false,
          "gurmukhi": "ਲਾਗਿ ਛੁਟੋ ਸਤਿਗੁਰ ਕੀ ਪਾਈ ॥੧॥",
          "roman": "lāg chhuṭo satigur kī pāī.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਸਤਿਗੁਰੂ ਦੀ ਚਰਨੀਂ ਲੱਗ ਕੇ ਹੀ ਇਸ ਤੋਂ ਖ਼ਲਾਸੀ ਪਾਈਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда освободиться от неё можно, лишь припав к стопам Сатгуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17911,
          "is_rahao": true,
          "gurmukhi": "ਜਗ ਮੋਹਨੀ ਹਮ ਤਿਆਗਿ ਗਵਾਈ ॥",
          "roman": "jag mohnī ham tiāg gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਦੋਂ ਤੋਂ) ਮੈਂ ਸਾਰੇ ਜਗਤ ਨੂੰ ਮੋਹਣ ਵਾਲੀ ਮਾਇਆ (ਦੇ ਮੋਹ) ਨੂੰ ਤਿਆਗ ਕੇ ਪਰੇ ਸੁੱਟ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! С тех пор как по милости Гуру я отбросил и отринул привязанность к майе, что чарует весь мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17912,
          "is_rahao": true,
          "gurmukhi": "ਨਿਰਗੁਨੁ ਮਿਲਿਓ ਵਜੀ ਵਧਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nirgun miliō vajī vadhāī.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਉਤਾਂਹ ਰਹਿਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਮਿਲਿਆ ਹੈ ਮੇਰੇ ਅੰਦਰ ਉਤਸ਼ਾਹ-ਭਰੀ ਅਵਸਥਾ ਪ੍ਰਬਲ ਹੋ ਗਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "я встретил Параматму, пребывающего выше воздействия трёх качеств майи, и во мне сильно зазвучало состояние внутреннего ликования. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17913,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਸੁੰਦਰਿ ਮਨ ਕਉ ਮੋਹੈ ॥",
          "roman": "ēsī sundar man kau mohē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹ ਮਾਇਆ) ਐਸੀ ਸੋਹਣੀ ਹੈ ਕਿ (ਮਨੁੱਖ ਦੇ) ਮਨ ਨੂੰ (ਤੁਰਤ) ਮੋਹ ਲੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Эта майя так прекрасна, что сразу пленяет человеческий ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17914,
          "is_rahao": false,
          "gurmukhi": "ਬਾਟਿ ਘਾਟਿ ਗ੍ਰਿਹਿ ਬਨਿ ਬਨਿ ਜੋਹੈ ॥",
          "roman": "bāṭ ghāṭ grih ban ban johē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਸਤੇ ਵਿਚ (ਤੁਰਦਿਆਂ) ਪੱਤਣ ਉਤੇ (ਲੰਘਦਿਆਂ) ਘਰ ਵਿਚ (ਬੈਠਿਆਂ) ਜੰਗਲ ਜੰਗਲ ਵਿਚ (ਭੌਂਦਿਆਂ ਇਹ ਮਨ ਨੂੰ ਮੋਹਣ ਵਾਸਤੇ) ਤੱਕ ਲਾਈ ਰੱਖਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "На дороге, на переправе, дома, в лесу за лесом она всё подстерегает, чтобы пленить ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17915,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਲਾਗੈ ਹੋਇ ਕੈ ਮੀਠੀ ॥",
          "roman": "man tan lāgē hoi kē mīṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿੱਠੀ ਬਣ ਕੇ ਇਹ ਮਨ ਵਿਚ ਤਨ ਵਿਚ ਆ ਚੰਬੜਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Став сладкой, она прилипает и к уму, и к телу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17916,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਮੈ ਖੋਟੀ ਡੀਠੀ ॥੨॥",
          "roman": "gur prasād mē khoṭī ḍīṭhī.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਵੇਖ ਲਿਆ ਹੈ ਕਿ ਇਹ ਬੜੀ ਖੋਟੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но по милости Гуру я увидел, что она крайне лжива. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17917,
          "is_rahao": false,
          "gurmukhi": "ਅਗਰਕ ਉਸ ਕੇ ਵਡੇ ਠਗਾਊ ॥",
          "roman": "agrak us ke vaḍe ṭhagāū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਾਮਾਦਿਕ) ਉਸ ਮਾਇਆ ਦੇ ਮੁਸਾਹਬ (ਵੀ) ਵੱਡੇ ਠੱਗ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Её прислужники, такие как вожделение и прочие, тоже великие обманщики,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17918,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਹਿ ਨਾਹੀ ਬਾਪ ਨ ਮਾਊ ॥",
          "roman": "chhoḍah nāhī bāp na māū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਂ ਹੋਵੇ ਪਿਉ ਹੋਵੇ ਕਿਸੇ ਨੂੰ ਠੱਗਣੋਂ ਛੱਡਦੇ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "они не перестают обманывать никого, будь то мать или отец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17919,
          "is_rahao": false,
          "gurmukhi": "ਮੇਲੀ ਅਪਨੇ ਉਨਿ ਲੇ ਬਾਂਧੇ ॥",
          "roman": "melī apne un le bāṅdhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਜਿਨ੍ਹਾਂ ਨੇ ਇਹਨਾਂ ਨਾਲ ਮੇਲ-ਮੁਲਾਕਾਤ ਪਾਈ, ਉਹਨਾਂ ਨੂੰ ਇਹਨਾਂ ਮੁਸਾਹਬਾਂ ਨੇ ਚੰਗੀ ਤਰ੍ਹਾਂ ਬੰਨ੍ਹ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Кого бы ни свела близость с ними, тех эти прислужники крепко связывают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17920,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਮੈ ਸਗਲੇ ਸਾਧੇ ॥੩॥",
          "roman": "gur kirpā te mē sagle sāḍhe.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਇਹਨਾਂ ਸਾਰਿਆਂ ਨੂੰ ਕਾਬੂ ਕਰ ਲਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но я по милости Гуру подчинил их всех. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17921,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਮੋਰੈ ਮਨਿ ਭਇਆ ਅਨੰਦ ॥",
          "roman": "ab morē man bhēā anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਮਨ ਵਿਚ ਆਤਮਕ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь в моём уме постоянно пребывает духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17922,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਚੂਕਾ ਟੂਟੇ ਸਭਿ ਫੰਦ ॥",
          "roman": "bhau chūkā ṭūṭe sabh fand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ ਅੰਦਰੋਂ ਇਹਨਾਂ ਕਾਮਾਦਿਕ ਮੁਸਾਹਬਾਂ ਦਾ) ਡਰ-ਭਉ ਲਹਿ ਗਿਆ ਹੈ ਇਹਨਾਂ ਦੇ ਪਾਏ ਹੋਏ ਸਾਰੇ ਫਾਹੇ ਟੁਟ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Страх перед этими прислужниками, такими как вожделение и прочие, ушёл из меня, и все их петли разорвались."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17923,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਸਤਿਗੁਰੁ ਪਾਇਆ ॥",
          "roman": "kah nānak jā satigur pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਦੋਂ ਦਾ ਮੈਨੂੰ ਸਤਿਗੁਰੂ ਮਿਲ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: с тех пор как я встретил Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17924,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ਸਗਲਾ ਮੈ ਸੁਖੀ ਬਸਾਇਆ ॥੪॥੩੬॥੮੭॥",
          "roman": "ghar saglā mē sukhī basāiā.4.36.87.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਤੋਂ ਮੈਂ ਆਪਣਾ ਸਾਰਾ ਘਰ ਸੁਖੀ ਵਸਾ ਲਿਆ ਹੈ (ਮੇਰੇ ਸਾਰੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਵਾਲਾ ਪਰਵਾਰ ਇਹਨਾਂ ਦੀ ਮਾਰ ਤੋਂ ਬਚ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣ ਰਿਹਾ ਹੈ) ॥੪॥੩੬॥੮੭॥"
            },
            "sahib_singh_ru": {
              "main": "с тех пор весь мой дом я устроил в благополучии: всё семейство моих чувств спаслось от их ударов и наслаждается духовной радостью. ॥4॥36॥87॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1523,
      "rahao_verse_id": 17931,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 17925,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17926,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਨਿਕਟਿ ਕਰਿ ਜਾਨੈ ॥",
          "roman": "āṭh pahar nikaṭ kar jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਭਗਤ ਪਰਮਾਤਮਾ ਨੂੰ ਅੱਠੇ ਪਹਿਰ ਆਪਣੇ ਨੇੜੇ ਵੱਸਦਾ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Преданный Параматмы считает, что Параматма обитает рядом с ним все восемь страж дня и ночи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17927,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਾ ਕੀਆ ਮੀਠਾ ਮਾਨੈ ॥",
          "roman": "prabh kā kīā mīṭhā mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ ਉਸ ਨੂੰ ਮਿੱਠਾ ਕਰ ਕੇ ਮੰਨਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё, что делает Параматма, принимает как сладостное."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17928,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਨਾਮੁ ਸੰਤਨ ਆਧਾਰੁ ॥",
          "roman": "ek nām santan ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਵੀਰ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸੰਤ ਜਨਾਂ (ਦੀ ਜ਼ਿੰਦਗੀ) ਦਾ ਆਸਰਾ (ਬਣਿਆ ਰਹਿੰਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Параматмы и есть опора жизни святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17929,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਰਹੇ ਸਭ ਕੀ ਪਗ ਛਾਰੁ ॥੧॥",
          "roman": "hoi rahe sabh kī pag chhār.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨ ਸਭਨਾਂ ਦੇ ਪੈਰਾਂ ਦੀ ਧੂੜ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Святые остаются пылью у ног всех. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17930,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਰਹਤ ਸੁਨਹੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "sant rahat sunah mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! (ਪਰਮਾਤਮਾ ਦੇ) ਸੰਤ ਦੀ ਜੀਵਨ-ਜੁਗਤੀ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Послушай, каков образ жизни святого Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17931,
          "is_rahao": true,
          "gurmukhi": "ਉਆ ਕੀ ਮਹਿਮਾ ਕਥਨੁ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "uā kī mahimā kathan na jāī.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦਾ ਜੀਵਨ ਇਤਨਾ ਉੱਚਾ ਹੈ ਕਿ) ਉਸ ਦਾ ਵਡੱਪਣ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "его величие невозможно выразить словами. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17932,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤਣਿ ਜਾ ਕੈ ਕੇਵਲ ਨਾਮ ॥",
          "roman": "vartaṇ jā kē keval nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਤ ਉਹ ਹੈ) ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸਿਰਫ਼ ਹਰਿ ਸਿਮਰਨ ਦਾ ਹੀ ਆਹਰ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Свят тот, в чьём сердце устойчиво живёт лишь одно занятие — памятование о Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17933,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਰੂਪ ਕੀਰਤਨੁ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "anad rūp kīrtan bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਆਨੰਦ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ ਸਾਲਾਹ ਹੀ (ਸੰਤ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ) ਸਹਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и опорой его жизни является только восхваление Параматмы, вечно пребывающего в блаженстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17934,
          "is_rahao": false,
          "gurmukhi": "ਮਿਤ੍ਰ ਸਤ੍ਰੁ ਜਾ ਕੈ ਏਕ ਸਮਾਨੈ ॥",
          "roman": "mitr satr jā kē ek samānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਤ ਉਹ ਹੈ) ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਮਿੱਤਰ ਤੇ ਵੈਰੀ ਇਕੋ ਜਿਹੇ (ਮਿੱਤਰ ਹੀ) ਲੱਗਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Свят тот, кому друг и враг кажутся одинаковыми, словно друзья,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17935,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਪੁਨੇ ਬਿਨੁ ਅਵਰੁ ਨ ਜਾਨੈ ॥੨॥",
          "roman": "prabh apne bin avar na jānē.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਸੰਤ ਸਭ ਜੀਵਾਂ ਵਿਚ) ਆਪਣੇ ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਹੋਰ ਨੂੰ (ਵੱਸਦਾ) ਨਹੀਂ ਸਮਝਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "потому что во всех существах он не видит никого, кроме своего Прабху. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17936,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕੋਟਿ ਅਘ ਕਾਟਨਹਾਰਾ ॥",
          "roman": "koṭ koṭ agh kāṭanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਸੰਤ ਹੋਰਨਾਂ ਦੇ) ਕ੍ਰੋੜਾਂ ਹੀ ਪਾਪ ਦੂਰ ਕਰਨ ਦੀ ਤਾਕਤ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Свят Параматмы обладает силой устранять миллионы и миллионы грехов других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17937,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਦੂਰਿ ਕਰਨ ਜੀਅ ਕੇ ਦਾਤਾਰਾ ॥",
          "roman": "dukh dūr karan jīa ke dātārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਸੰਤ (ਦੂਜਿਆਂ ਦੇ) ਦੁੱਖ ਦੂਰ ਕਰਨ ਜੋਗੇ ਹੋ ਜਾਂਦੇ ਹਨ ਉਹ (ਲੋਕਾਂ ਨੂੰ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਦੀ ਸਮਰਥਾ ਰੱਖਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Святые Параматмы становятся способными устранять страдания других и обладают силой даровать людям духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17938,
          "is_rahao": false,
          "gurmukhi": "ਸੂਰਬੀਰ ਬਚਨ ਕੇ ਬਲੀ ॥",
          "roman": "sūrbīr bachan ke balī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ ਸੰਤ ਵਿਕਾਰਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਸੂਰਮੇ ਹੁੰਦੇ ਹਨ, ਕੀਤੇ ਬਚਨਾਂ ਦੀ ਪਾਲਣਾ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Святые Прабху — герои перед лицом пороков и соблюдают данные ими слова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17939,
          "is_rahao": false,
          "gurmukhi": "ਕਉਲਾ ਬਪੁਰੀ ਸੰਤੀ ਛਲੀ ॥੩॥",
          "roman": "kaulā bapurī santī chhalī.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਤਾਂ ਦੀ ਨਿਗਾਹ ਵਿਚ ਇਹ ਮਾਇਆ ਭੀ ਨਿਮਾਣੀ ਜਿਹੀ ਜਾਪਦੀ ਹੈ) ਇਸ ਨਿਮਾਣੀ ਮਾਇਆ ਨੂੰ ਸੰਤਾਂ ਨੇ ਆਪਣੇ ਵੱਸ ਵਿਚ ਕਰ ਲਿਆ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В глазах святых даже эта майя кажется жалкой, и святые держат эту жалкую майю под своим контролем. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17940,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਸੰਗੁ ਬਾਛਹਿ ਸੁਰਦੇਵ ॥",
          "roman": "tā kā sang bāchhah surdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਸੰਤ ਦਾ ਮਿਲਾਪ ਆਕਾਸ਼ੀ ਦੇਵਤੇ ਭੀ ਲੋੜਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Даже небесные божества жаждут общения со святым Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17941,
          "is_rahao": false,
          "gurmukhi": "ਅਮੋਘ ਦਰਸੁ ਸਫਲ ਜਾ ਕੀ ਸੇਵ ॥",
          "roman": "amogh daras safal jā kī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦਾ ਦਰਸ਼ਨ ਵਿਅਰਥ ਨਹੀਂ ਜਾਂਦਾ, ਸੰਤ ਦੀ ਸੇਵਾ ਜ਼ਰੂਰ ਫਲ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Даршан святого не бывает напрасным, и служение святому непременно приносит плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17942,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਜੋੜਿ ਨਾਨਕੁ ਕਰੇ ਅਰਦਾਸਿ ॥",
          "roman": "kar joṛ nānak kre ardas",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਨਾਨਕ (ਦੋਵੇਂ) ਹੱਥ ਜੋੜ ਕੇ ਅਰਜ਼ੋਈ ਕਰਦਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "О брат! Нанак, сложив обе руки, возносит мольбу:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17943,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਸੰਤਹ ਟਹਲ ਦੀਜੈ ਗੁਣਤਾਸਿ ॥੪॥੩੭॥੮੮॥",
          "roman": "mohi santah ṭahal dījē guṇtās.4.37.88.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਸੰਤ ਜਨਾਂ ਦੀ ਸੇਵਾ ਦੀ ਦਾਤਿ ਬਖ਼ਸ਼ ॥੪॥੩੭॥੮੮॥"
            },
            "sahib_singh_ru": {
              "main": "О сокровищница достоинств, Прабху! Даруй мне благословение служить святым. ॥4॥37॥88॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1524,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 17944,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17945,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸੂਖ ਜਪਿ ਏਕੈ ਨਾਮ ॥",
          "roman": "sagal sūkh jap ekē nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆਂ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в сангати Гуру, через повторение Имени Параматмы обретаются все блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17946,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਧਰਮ ਹਰਿ ਕੇ ਗੁਣ ਗਾਮ ॥",
          "roman": "sagal dharam har ke guṇ gām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਨ ਵਿਚ ਹੀ ਹੋਰ ਸਾਰੇ ਧਰਮ ਆ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В восхвалении Параматмы содержатся все прочие дхармы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 17947,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਪਵਿਤ੍ਰ ਸਾਧ ਕਾ ਸੰਗੁ ॥",
          "roman": "mahā pavitr sādh kā sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਬਹੁਤ ਪਵਿਤ੍ਰ ਕਰਨ ਵਾਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сангат Гуру обладает великой очищающей святостью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
