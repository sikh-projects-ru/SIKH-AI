  "shabads": [
    {
      "shabad_id": 1527,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18002,
          "is_rahao": false,
          "gurmukhi": "ਲਾਲ ਜਵੇਹਰ ਭਰੇ ਭੰਡਾਰ ॥",
          "roman": "lāl javehar bhare bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉੱਚੇ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ ਗੁਣ, ਮਾਨੋ) ਹੀਰੇ ਜਵਾਹਰ ਹਨ, ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਇਹਨਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਭਰ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Добродетели высокого духовного состояния подобны драгоценным камням и жемчугам; внутри человека наполняются сокровищницы ими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18003,
          "is_rahao": false,
          "gurmukhi": "ਤੋਟਿ ਨ ਆਵੈ ਜਪਿ ਨਿਰੰਕਾਰ ॥",
          "roman": "toṭ na āvē jap nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਕਦੇ ਇਹਨਾਂ ਦੀ ਥੁੜ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Если повторять Имя Ниранкара, в них никогда не бывает недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18004,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਸਬਦੁ ਪੀਵੈ ਜਨੁ ਕੋਇ ॥",
          "roman": "amrit sabad pīvē jan koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਜਲ ਹੈ, ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਇਹ ਨਾਮ-ਜਲ ਪੀਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Шабд Гуру — это вода, дарующая духовную жизнь; кто бы ни пил эту воду Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18005,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੀ ਪਰਮ ਗਤਿ ਹੋਇ ॥੨॥੪੧॥੯੨॥",
          "roman": "nānak tā kī param gat hoi.2.41.92.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦੀ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ ॥੨॥੪੧॥੯੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот достигает высочайшего духовного состояния.2.41.92."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1528,
      "rahao_verse_id": 18010,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18006,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਘਰੁ ੭ ਮਹਲਾ ੫ ॥",
          "roman": "āsā ghar 7 mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18007,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਰਿਦੈ ਨਿਤ ਧਿਆਈ ॥",
          "roman": "har kā nām ridē nit dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਅੰਗ-ਸੰਗ ਵੱਸਦੇ ਗੁਰੂ ਦੀ ਹੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਦਾ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਧਿਆਉਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Только по милости Гуру, пребывающего рядом, я всегда созерцаю Имя Вахегуру в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18008,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗੀ ਸਾਥੀ ਸਗਲ ਤਰਾਂਈ ॥੧॥",
          "roman": "sangī sāthī sagal tarāṅī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ ਮੈਂ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣ ਜੋਗਾ ਹੋ ਰਿਹਾ ਹਾਂ) ਆਪਣੇ ਸੰਗੀਆਂ ਸਾਥੀਆਂ (ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ) ਨੂੰ ਪਾਰ ਲੰਘਾਣ ਜੋਗਾ ਬਣ ਰਿਹਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Так я становлюсь способным переплыть мирской океан и делаю способными переплыть его и своих спутников и товарищей, то есть органы познания. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18009,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਮੇਰੈ ਸੰਗਿ ਸਦਾ ਹੈ ਨਾਲੇ ॥",
          "roman": "gur merē sang sadā hē nālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮੇਰਾ) ਗੁਰੂ ਸਦਾ ਮੇਰੇ ਨਾਲ ਵੱਸਦਾ ਹੈ ਮੇਰੇ ਅੰਗ-ਸੰਗ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Гуру всегда пребывает со мной, всегда рядом со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18010,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਤਿਸੁ ਸਦਾ ਸਮੑਾਲੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simar simar tis sadā sam'hāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਹੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਉਸ (ਪਰਮਾਤਮਾ) ਨੂੰ ਸਦਾ ਸਿਮਰ ਕੇ ਸਦਾ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਈ ਰੱਖਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только по милости Гуру я, постоянно помня Его, всегда сохраняю Его в своём сердце. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18011,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਕੀਆ ਮੀਠਾ ਲਾਗੈ ॥",
          "roman": "terā kīā mīṭhā lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਇਹ ਤੇਰੇ ਮਿਲਾਏ ਹੋਏ ਗੁਰੂ ਦੀ ਮੇਹਰ ਹੈ ਕਿ) ਮੈਨੂੰ ਤੇਰਾ ਕੀਤਾ ਹੋਇਆ ਹਰੇਕ ਕੰਮ ਚੰਗਾ ਲੱਗ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру! По милости Гуру, Которого Ты послал мне, всякое совершённое Тобой теперь кажется мне сладостным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18012,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਪਦਾਰਥੁ ਨਾਨਕੁ ਮਾਂਗੈ ॥੨॥੪੨॥੯੩॥",
          "roman": "har nām padārath nānak māṅgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਤੇਰਾ ਦਾਸ) ਨਾਨਕ ਤੇਰੇ ਪਾਸੋਂ ਸਭ ਤੋਂ ਕੀਮਤੀ ਵਸਤ ਤੇਰਾ ਨਾਮ ਮੰਗ ਰਿਹਾ ਹੈ ॥੨॥੪੨॥੯੩॥"
            },
            "sahib_singh_ru": {
              "main": "И Твой слуга Нанак просит у Тебя самое драгоценное сокровище — Твоё Имя. ॥2॥42॥93॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1529,
      "rahao_verse_id": 18017,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18013,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18014,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਤਿ ਤਰਿਆ ਸੰਸਾਰੁ ॥",
          "roman": "sādhū sangat tariā sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਨਿਮ੍ਰਤਾ ਧਾਰ ਕੇ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਕਰਦਾ ਹੈ) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто со смирением пребывает в сангате Гуру, по благодати этой сангати переплывает мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18015,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਮਨਹਿ ਆਧਾਰੁ ॥੧॥",
          "roman": "har kā nām maneh ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਸ ਦੇ ਮਨ ਦਾ ਆਸਰਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Потому что Имя Вахегуру становится опорой его ума. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18016,
          "is_rahao": true,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰਦੇਵ ਪਿਆਰੇ ॥",
          "roman": "charan kamal gurdev piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਿਆਰੇ ਗੁਰਦੇਵ ਦੇ ਸੋਹਣੇ ਕੋਮਲ ਚਰਨ-"
            },
            "sahib_singh_ru": {
              "main": "Прекрасные, нежные лотосные стопы любимого Гурдева —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18017,
          "is_rahao": true,
          "gurmukhi": "ਪੂਜਹਿ ਸੰਤ ਹਰਿ ਪ੍ਰੀਤਿ ਪਿਆਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pūjeh sant har prīt piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੀ ਦੇ ਸੰਤ ਜਨ ਪ੍ਰੀਤਿ ਨਾਲ, ਪਿਆਰ ਨਾਲ ਪੂਜਦੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "святые Хари с любовью и привязанностью постоянно почитают их. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18018,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਸਤਕਿ ਲਿਖਿਆ ਭਾਗੁ ॥",
          "roman": "jā kē mastak likhiā bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਤੇ (ਪੂਰਬਲੇ ਜਨਮਾਂ ਦੇ ਕਰਮਾਂ ਦਾ) ਲਿਖਿਆ ਲੇਖ ਜਾਗ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, на челе которого пробуждается написанная судьба прежних деяний,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18019,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਾ ਕਾ ਥਿਰੁ ਸੋਹਾਗੁ ॥੨॥੪੩॥੯੪॥",
          "roman": "kaho nānak tā kā thir sohāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੂੰ ਮਿਲੀ ਇਹ ਸੁਭਾਗਤਾ (ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸਦਾ ਲਈ ਕਾਇਮ ਰਹਿੰਦੀ ਹੈ ॥੨॥੪੩॥੯੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, это счастье, доставшееся ему, по благодати сангати Гуру остаётся вечным. ॥2॥43॥94॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1530,
      "rahao_verse_id": 18026,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18020,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18021,
          "is_rahao": false,
          "gurmukhi": "ਮੀਠੀ ਆਗਿਆ ਪਿਰ ਕੀ ਲਾਗੀ ॥",
          "roman": "mīṭhī āgiā pir kī lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਦੋਂ ਤੋਂ) ਮੈਨੂੰ ਪ੍ਰਭੂ-ਪਤੀ ਦੀ ਰਜ਼ਾ ਮਿੱਠੀ ਲੱਗ ਰਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! С тех пор как по милости Гуру мне стала сладостна воля Господа-Супруга,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18022,
          "is_rahao": false,
          "gurmukhi": "ਸਉਕਨਿ ਘਰ ਕੀ ਕੰਤਿ ਤਿਆਗੀ ॥",
          "roman": "saukan ghar kī kant tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਤੋਂ) ਪ੍ਰਭੂ-ਪਤੀ ਨੇ ਮੇਰਾ ਹਿਰਦਾ-ਘਰ ਮੱਲ ਕੇ ਬੈਠੀ ਮੇਰੀ ਸੌਂਕਣ (ਮਾਇਆ) ਤੋਂ ਖ਼ਲਾਸੀ ਕਰਾ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "с тех пор Господь-Супруг освободил меня от моей соперницы, майи, которая захватила дом моего сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18023,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਿਅ ਸੋਹਾਗਨਿ ਸੀਗਾਰਿ ਕਰੀ ॥",
          "roman": "priā sohāgan sīgār karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰੇ ਨੇ ਸੁਹਾਗਣ ਬਣਾ ਕੇ ਮੈਨੂੰ (ਮੇਰੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ) ਸੁੰਦਰ ਬਣਾ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный сделал меня счастливой супругой и украсил меня, то есть сделал прекрасной мою духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18024,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮੇਰੇ ਕੀ ਤਪਤਿ ਹਰੀ ॥੧॥",
          "roman": "man mere kī tapat harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੇਰੇ ਮਨ ਦੀ (ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਤਪਸ਼ ਦੂਰ ਕਰ ਦਿੱਤੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и устранил жгучую муку жажды в моём уме. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18025,
          "is_rahao": true,
          "gurmukhi": "ਭਲੋ ਭਇਓ ਪ੍ਰਿਅ ਕਹਿਆ ਮਾਨਿਆ ॥",
          "roman": "bhalo bhaio priā kahiā māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ!) ਮੇਰੇ ਭਾਗ ਜਾਗ ਪਏ ਹਨ (ਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਪਿਆਰੇ (ਪ੍ਰਭੂ-ਪਤੀ) ਦੀ ਰਜ਼ਾ (ਮਿੱਠੀ ਕਰ ਕੇ) ਮੰਨਣੀ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Моё счастье пробудилось, ибо по милости Гуру я начала принимать волю Возлюбленного Господа-Супруга как сладостную."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18026,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖੁ ਸਹਜੁ ਇਸੁ ਘਰ ਕਾ ਜਾਨਿਆ ॥ ਰਹਾਉ ॥",
          "roman": "sūkh sahaj is ghar kā jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਇਸ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਵੱਸਦੇ ਸੁਖ ਤੇ ਆਤਮਕ ਅਡੋਲਤਾ ਨਾਲ ਮੇਰੀ ਡੂੰਘੀ ਸਾਂਝ ਬਣ ਗਈ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь у меня возникла глубокая близость с покоем и духовной устойчивостью, обитающими в этом доме моего сердца. Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18027,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬੰਦੀ ਪ੍ਰਿਅ ਖਿਜਮਤਦਾਰ ॥",
          "roman": "hau bandī priā khizmatdār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਹੁਣ) ਮੈਂ ਪਿਆਰੇ ਪ੍ਰਭੂ-ਪਤੀ ਦੀ ਦਾਸੀ ਬਣ ਗਈ ਹਾਂ ਸੇਵਾਦਾਰਨੀ ਬਣ ਗਈ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Теперь я стала служанкой любимого Господа-Супруга, стала Его прислужницей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18028,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਅਬਿਨਾਸੀ ਅਗਮ ਅਪਾਰ ॥",
          "roman": "ohu abināsī agam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਮੇਰਾ) ਉਹ (ਪਤੀ) ਕਦੇ ਮਰਨ ਵਾਲਾ ਨਹੀਂ, ਅਪਹੁੰਚ ਤੇ ਬੇਅੰਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот мой Супруг не подвержен смерти, непостижим и беспределен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18029,
          "is_rahao": false,
          "gurmukhi": "ਲੇ ਪਖਾ ਪ੍ਰਿਅ ਝਲਉ ਪਾਏ ॥",
          "roman": "le pakhā priā jhalau pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਦੋਂ ਤੋਂ) ਪੱਖਾ (ਹੱਥ ਵਿਚ) ਫੜ ਕੇ ਉਸ ਦੇ ਪੈਰਾਂ ਵਿਚ ਖਲੋ ਕੇ ਮੈਂ ਉਸ ਪਿਆਰੇ ਨੂੰ ਝੱਲਦੀ ਰਹਿੰਦੀ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! С тех пор как по милости Гуру я, взяв в руку веер, стою у Его стоп и вею Ему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18030,
          "is_rahao": false,
          "gurmukhi": "ਭਾਗਿ ਗਏ ਪੰਚ ਦੂਤ ਲਾਵੇ ॥੨॥",
          "roman": "bhāg gae panch dūt lāve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਤੋਂ ਮੇਰੇ ਆਤਮਕ ਜੀਵਨ ਦੀਆਂ ਜੜ੍ਹਾਂ) ਕੱਟਣ ਵਾਲੇ ਕਾਮਾਦਿਕ ਪੰਜੇ ਵੈਰੀ ਭੱਜ ਗਏ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "с тех пор убежали пять врагов, কাম и прочие, которые подрубали корни моей духовной жизни. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18031,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਮੈ ਕੁਲੁ ਨਾ ਸੋਭਾਵੰਤ ॥",
          "roman": "nā mē kul nā sobhāvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ!) ਨਾਹ ਮੇਰਾ ਕੋਈ ਉੱਚਾ ਖ਼ਾਨਦਾਨ ਹੈ, ਨਾਹ (ਕਿਸੇ ਗੁਣਾਂ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੈਂ ਸੋਭਾ ਦੀ ਮਾਲਕ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! У меня нет ни высокого рода, ни красоты, обретённой силой каких-либо достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18032,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਜਾਨਾ ਕਿਉ ਭਾਨੀ ਕੰਤ ॥",
          "roman": "kiā jānā kiu bhānī kant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਪਤਾ ਨਹੀਂ ਮੈਂ ਕਿਵੇਂ ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਚੰਗੀ ਲੱਗ ਰਹੀ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "я не знаю, почему я стала угодна Господу-Супругу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18033,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਅਨਾਥ ਗਰੀਬ ਨਿਮਾਨੀ ॥",
          "roman": "moh anāth garīb nimānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਇਹ ਗੁਰੂ ਪਾਤਿਸ਼ਾਹ ਦੀ ਹੀ ਮੇਹਰ ਹੈ ਕਿ) ਮੈਨੂੰ ਅਨਾਥ ਨੂੰ ਗ਼ਰੀਬਣੀ ਨੂੰ ਨਿਮਾਣੀ ਨੂੰ-"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Только по милости Гуру-Патишаха меня, сирую, бедную и незнатную,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18034,
          "is_rahao": false,
          "gurmukhi": "ਕੰਤ ਪਕਰਿ ਹਮ ਕੀਨੀ ਰਾਨੀ ॥੩॥",
          "roman": "kant pakar ham kīnī rānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੰਤ-ਪ੍ਰਭੂ ਨੇ (ਬਾਹੋਂ) ਫੜ ਕੇ ਆਪਣੀ ਰਾਣੀ ਬਣਾ ਲਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Господь-Супруг, взяв за руку, сделал Своей царицей. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18035,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਮੁਖਿ ਪ੍ਰੀਤਮੁ ਸਾਜਨੁ ਲਾਗਾ ॥",
          "roman": "jab mukh prītam sājan lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਹੇਲੀਏ! ਜਦੋਂ ਤੋਂ) ਮੈਨੂੰ ਮੇਰਾ ਸੱਜਣ ਪ੍ਰੀਤਮ ਮਿਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! С тех пор как я встретила своего Друга-Возлюбленного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18036,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਮੇਰਾ ਧਨੁ ਸੋਹਾਗਾ ॥",
          "roman": "sūkh sahaj merā dhan sohāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਅੰਦਰ ਆਨੰਦ ਬਣ ਰਿਹਾ ਹੈ ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਹੋ ਗਈ ਹੈ, ਮੇਰੇ ਭਾਗ ਜਾਗ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "внутри меня пребывает блаженство, возникла духовная устойчивость, и моё счастье пробудилось."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18037,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਮੋਰੀ ਪੂਰਨ ਆਸਾ ॥",
          "roman": "kaho nānak morī pūran āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਸਹੇਲੀਏ! ਪ੍ਰਭੂ-ਪਤੀ ਦੇ ਮਿਲਾਪ ਦੀ) ਮੇਰੀ ਆਸ ਪੂਰੀ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: О подруга! Моё чаяние о встрече с Господом-Супругом исполнилось,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18038,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਮੇਲੀ ਪ੍ਰਭ ਗੁਣਤਾਸਾ ॥੪॥੧॥੯੫॥",
          "roman": "satgur melī prabh guṇtāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਨੇ ਹੀ ਮੈਨੂੰ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਮਿਲਾਇਆ ਹੈ ॥੪॥੧॥੯੫॥"
            },
            "sahib_singh_ru": {
              "main": "именно Сатгуру соединил меня с Вахегуру — сокровищницей достоинств. ॥4॥1॥95॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1531,
      "rahao_verse_id": 18044,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18039,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18040,
          "is_rahao": false,
          "gurmukhi": "ਮਾਥੈ ਤ੍ਰਿਕੁਟੀ ਦ੍ਰਿਸਟਿ ਕਰੂਰਿ ॥",
          "roman": "māthē trikuṭī drisaṭ karūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਸ ਮਾਇਆ-ਇਸਤ੍ਰੀ ਦੇ) ਮੱਥੇ ਉਤੇ ਤ੍ਰਿਊੜੀ (ਪਈ ਰਹਿੰਦੀ) ਹੈ ਉਸ ਦੀ ਨਿਗਾਹ ਗੁੱਸੇ ਨਾਲ ਭਰੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! На челе у той женщины-майи всегда лежит хмурость, а её взгляд полон гнева,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18041,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਕਉੜਾ ਜਿਹਬਾ ਕੀ ਫੂੜਿ ॥",
          "roman": "bolē kauṛā jihbā kī phūṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਸਦਾ) ਕੌੜਾ ਬੋਲਦੀ ਹੈ, ਜੀਭ ਦੀ ਖਰ੍ਹਵੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "она всегда говорит горько, её язык резок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18042,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਭੂਖੀ ਪਿਰੁ ਜਾਨੈ ਦੂਰਿ ॥੧॥",
          "roman": "sadā bhūkhī pir jānē dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੇ ਜਗਤ ਦੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਹੜੱਪ ਕਰ ਕੇ ਭੀ) ਉਹ ਭੁੱਖੀ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ (ਜਗਤ ਵਿਚ ਆ ਰਹੇ ਸਭ ਜੀਵਾਂ ਨੂੰ ਹੜੱਪ ਕਰਨ ਲਈ ਤਿਆਰ ਰਹਿੰਦੀ ਹੈ) ਉਹ (ਮਾਇਆ-ਇਸਤ੍ਰੀ) ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਕਿਤੇ ਦੂਰ-ਵੱਸਦਾ ਸਮਝਦੀ ਹੈ (ਪ੍ਰਭੂ-ਪਤੀ ਦੀ ਪਰਵਾਹ ਨਹੀਂ ਕਰਦੀ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Даже поглотив духовную жизнь всего мира, она всё равно остаётся голодной и готовой поглотить всех существ, приходящих в мир. Эта женщина-майя считает Господа-Супруга где-то далёким и не заботится о Нём. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18043,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਇਸਤ੍ਰੀ ਇਕ ਰਾਮਿ ਉਪਾਈ ॥",
          "roman": "aisī istrī ik rām upāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਪਰਮਾਤਮਾ ਨੇ (ਮਾਇਆ) ਇਕ ਅਜੇਹੀ ਇਸਤ੍ਰੀ ਪੈਦਾ ਕੀਤੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Вахегуру породил такую женщину — майю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18044,
          "is_rahao": true,
          "gurmukhi": "ਉਨਿ ਸਭੁ ਜਗੁ ਖਾਇਆ ਹਮ ਗੁਰਿ ਰਾਖੇ ਮੇਰੇ ਭਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "un sabh jag khāiā ham gur rākhē mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਨੇ ਸਾਰੇ ਜਗਤ ਨੂੰ ਖਾ ਲਿਆ ਹੈ (ਆਪਣੇ ਕਾਬੂ ਵਿਚ ਕੀਤਾ ਹੋਇਆ ਹੈ), ਮੈਨੂੰ ਤਾਂ ਗੁਰੂ ਨੇ (ਉਸ ਮਾਇਆ-ਇਸਤ੍ਰੀ ਤੋਂ) ਬਚਾ ਰੱਖਿਆ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "она пожрала весь мир, то есть подчинила его себе, а меня Гуру уберёг от этой женщины-майи, о мой брат. Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18045,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇ ਠਗਉਲੀ ਸਭੁ ਜਗੁ ਜੋਹਿਆ ॥",
          "roman": "pāe ṭhagaulī sabh jag johiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮਾਇਆ-ਇਸਤ੍ਰੀ ਨੇ) ਠਗਬੂਟੀ ਖਵਾ ਕੇ ਸਾਰੇ ਜਗਤ ਨੂੰ ਆਪਣੀ ਤੱਕ ਵਿਚ ਰੱਖਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Женщина-майя, напоив весь мир одурманивающим зельем обмана, держит его под своим надзором."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18046,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮਾ ਬਿਸਨੁ ਮਹਾਦੇਉ ਮੋਹਿਆ ॥",
          "roman": "brahmā bisan mahādeu mohiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੀ ਕੀਹ ਪਾਇਆਂ ਹੈ? ਉਸ ਨੇ ਤਾਂ) ਬ੍ਰਹਮਾ ਨੂੰ ਵਿਸ਼ਨੂੰ ਨੂੰ ਸ਼ਿਵ ਨੂੰ ਆਪਣੇ ਮੋਹ ਵਿਚ ਫਸਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что говорить о прочих существах? Она даже Брахму, Вишну и Шиву удерживает в своём обольщении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18047,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮਿ ਲਗੇ ਸੇ ਸੋਹਿਆ ॥੨॥",
          "roman": "gurmukh nām lage se sohiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜੇ ਰਹਿੰਦੇ ਹਨ ਉਹ (ਉਸ ਤੋਂ ਬਚ ਕੇ) ਸੋਹਣੇ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "А те люди, которые, войдя в прибежище Гуру, соединены с Именем Вахегуру, избегая её, сохраняют прекрасную духовную жизнь. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18048,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤ ਨੇਮ ਕਰਿ ਥਾਕੇ ਪੁਨਹਚਰਨਾ ॥",
          "roman": "varat nem kar thāke punahcharṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਅਨੇਕਾਂ ਲੋਕ) ਵਰਤ ਰੱਖ ਰੱਖ ਕੇ ਧਾਰਮਿਕ ਨੇਮ ਨਿਬਾਹ ਨਿਬਾਹ ਕੇ ਤੇ (ਕੀਤੇ ਪਾਪਾਂ ਦਾ ਪ੍ਰਭਾਵ ਮਿਟਾਣ ਲਈ) ਪਛੁਤਾਵੇ ਵਜੋਂ ਧਾਰਮਿਕ ਰਸਮਾਂ ਕਰ ਕਰ ਕੇ ਥੱਕ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Многие люди устали соблюдать посты, исполнять религиозные правила и совершать обрядовые действия покаяния, чтобы изгладить последствия совершённых грехов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18049,
          "is_rahao": false,
          "gurmukhi": "ਤਟ ਤੀਰਥ ਭਵੇ ਸਭ ਧਰਨਾ ॥",
          "roman": "ṭaṭ tīrath bhave sabh dharnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਤੀਰਥਾਂ ਉਤੇ ਸਾਰੀ ਧਰਤੀ ਉਤੇ ਭਉਂ ਚੁਕੇ (ਪਰ ਇਸ ਮਾਇਆ-ਇਸਤ੍ਰੀ ਤੋਂ ਨਾਹ ਬਚ ਸਕੇ)।"
            },
            "sahib_singh_ru": {
              "main": "они обошли множество мест паломничества по всей земле, но и так не смогли спастись от этой женщины-майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18050,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਉਬਰੇ ਜਿ ਸਤਿਗੁਰ ਕੀ ਸਰਨਾ ॥੩॥",
          "roman": "se ubre ji satgur kī sarnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਿਰਫ਼ ਉਹੀ ਬੰਦੇ ਬਚਦੇ ਹਨ ਜੇਹੜੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Спасаются только те, кто приходит в прибежище Гуру. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18051,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿ ਸਭੋ ਜਗੁ ਬਾਧਾ ॥",
          "roman": "māiā moh sabho jag bādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਾਰਾ ਜਗਤ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਬੱਝਾ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Весь мир связан привязанностью к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18052,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਪਚੈ ਮਨਮੁਖ ਮੂਰਾਖਾ ॥",
          "roman": "haumē pachē manmukh mūrākhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮੂਰਖ ਮਨੁੱਖ ਹਉਮੈ ਵਿਚ ਖ਼ੁਆਰ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а глупый человек, идущий за своим умом, истлевает в Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18053,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਨਾਨਕ ਬਾਹ ਪਕਰਿ ਹਮ ਰਾਖਾ ॥੪॥੨॥੯੬॥",
          "roman": "gur nānak bāh pakar ham rākhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਗੁਰੂ! ਮੈਨੂੰ ਤੂੰ ਹੀ ਮੇਰੀ ਬਾਂਹ ਫੜ ਕੇ (ਇਸ ਦੇ ਪੰਜੇ ਤੋਂ) ਬਚਾਇਆ ਹੈ ॥੪॥੨॥੯੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: О Гуру! Только Ты, взяв меня за руку, спас меня от её когтей. ॥4॥2॥96॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1532,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18054,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18055,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਦੂਖ ਜਬ ਬਿਸਰਹਿ ਸੁਆਮੀ ॥",
          "roman": "sarab dūkh jab bisreh suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਲਕ-ਪ੍ਰਭੂ! ਜਦੋਂ (ਕਿਸੇ ਜੀਵ ਦੇ ਮਨ ਵਿਚੋਂ) ਤੂੰ ਵਿਸਰ ਜਾਂਦਾ ਹੈਂ ਤਾਂ ਉਸ ਨੂੰ ਸਾਰੇ ਦੁੱਖ ਆ ਘੇਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь-Владыка! Когда Ты исчезаешь из ума живого существа, его со всех сторон окружают страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18056,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਕਾਮਿ ਨ ਪ੍ਰਾਨੀ ॥੧॥",
          "roman": "īhā ūhā kām na prānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੀਵ ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਕਿਸੇ ਕੰਮ ਨਹੀਂ ਆਉਂਦਾ (ਉਸ ਦਾ ਜੀਵਨ ਵਿਅਰਥ ਹੋ ਜਾਂਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и такое существо не приносит пользы ни здесь, ни в ином мире, его жизнь становится напрасной. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18057,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਤ੍ਰਿਪਤਾਸੇ ਹਰਿ ਹਰਿ ਧੵਾਇ ॥",
          "roman": "sant triptāse har har dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਿਆਂ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру! Следуя Твоей воле, обретаются все радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
