{
  "ang": 395,
  "shabads": [
    {
      "shabad_id": 1532,
      "rahao_verse_id": 18058,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18058,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪੁਨੈ ਨਾਇ ਲਾਏ ਸਰਬ ਸੂਖ ਪ੍ਰਭ ਤੁਮਰੀ ਰਜਾਇ ॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā apunē nāe lāe sarab sūkh prabh tumrī rajāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਤੂੰ ਮੇਹਰ ਕਰ ਕੇ ਆਪਣੇ ਨਾਮ ਵਿਚ ਜੋੜੀ ਰੱਖਦਾ ਹੈਂ ਉਹ (ਤੇਰੇ) ਸੰਤ ਜਨ ਤੇਰਾ ਹਰਿ-ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਵੱਲੋਂ) ਰੱਜੇ ਰਹਿੰਦੇ ਹਨ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру! Тех людей, которых Ты по милости соединяешь со Своим Именем, эти святые, памятуя Твоё Имя, остаются насыщенными и довольными, не обращаясь к жажде майи. Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18059,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਹੋਵਤ ਕਉ ਜਾਨਤ ਦੂਰਿ ॥ ਸੋ ਜਨੁ ਮਰਤਾ ਨਿਤ ਨਿਤ ਝੂਰਿ ॥੨॥",
          "roman": "sang hovat kau jānat dūr so jan martā nit nit jhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦੇ ਪਰਮਾਤਮਾ ਨੂੰ ਕਿਤੇ ਦੂਰ ਵੱਸਦਾ ਸਮਝਦਾ ਹੈ, ਉਹ ਸਦਾ (ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦੇ ਅਧੀਨ) ਖਿੱਝ ਖਿੱਝ ਕੇ ਆਤਮਕ ਮੌਤ ਸਹੇੜੀ ਰੱਖਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто считает далёким Вахегуру, пребывающего рядом с ним, постоянно, день за днём, терзается и несёт в себе духовную смерть, находясь во власти жажды майи. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18060,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਸਭੁ ਕਿਛੁ ਦੀਆ ਤਿਸੁ ਚਿਤਵਤ ਨਾਹਿ ॥",
          "roman": "jin sabh kichh dīā tis chitvat nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਹਰੇਕ ਚੀਜ਼ ਦਿੱਤੀ ਹੈ ਜੇਹੜਾ ਮਨੁੱਖ ਉਸ ਨੂੰ ਚੇਤੇ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, который не вспоминает Вахегуру, давшего всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18061,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਬਿਖਿਆ ਮਹਿ ਦਿਨੁ ਰੈਨਿ ਜਾਹਿ ॥੩॥",
          "roman": "mahā bikhiā meh din rēn jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ (ਜ਼ਿੰਦਗੀ ਦੇ) ਸਾਰੇ ਰਾਤ ਦਿਨ ਡਾਢੀ ਮਾਇਆ (ਦੇ ਮੋਹ) ਵਿਚ (ਫਸਿਆਂ ਹੀ) ਗੁਜ਼ਰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "проводит все свои дни и ночи в тяжёлой майе, в её обольщении. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18062,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭੁ ਸਿਮਰਹੁ ਏਕ ॥",
          "roman": "kaho nānak prabh simarah ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਭਾਈ!) ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਇਕ ਪਰਮਾਤਮਾ ਨੂੰ ਯਾਦ ਕਰਦੇ ਰਿਹਾ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: О брат! Приходя в прибежище совершенного Гуру, помните одного Вахегуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18063,
          "is_rahao": false,
          "gurmukhi": "ਗਤਿ ਪਾਈਐ ਗੁਰ ਪੂਰੇ ਟੇਕ ॥੪॥੩॥੯੭॥",
          "roman": "gat pāīai gur pūre ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ (ਤੇ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਵਿਚ ਨਹੀਂ ਫਸੀਦਾ) ॥੪॥੩॥੯੭॥"
            },
            "sahib_singh_ru": {
              "main": "Так обретается высокая духовная ступень, и человек уже не попадает в жажду майи. ॥4॥3॥97॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1533,
      "rahao_verse_id": 18068,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18064,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18065,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਮਨੁ ਤਨੁ ਸਭੁ ਹਰਿਆ ॥",
          "roman": "nām japat man tan sabh hariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਵੇਂ ਪਾਣੀ ਮਿਲਣ ਨਾਲ ਰੁੱਖ ਹਰਾ ਹੋ ਜਾਂਦਾ ਹੈ, ਰੁੱਖ ਵਿਚ, ਮਾਨੋ, ਜਿੰਦ ਰੁਮਕ ਪੈਂਦੀ ਹੈ ਤਿਵੇਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਨਾਲ (ਨਾਮ-ਜਲ ਨਾਲ) ਮਨੁੱਖ ਦਾ ਮਨ ਮਨੁੱਖ ਦਾ ਹਿਰਦਾ ਆਤਮਕ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя, человек оживляет и ум, и тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18066,
          "is_rahao": false,
          "gurmukhi": "ਕਲਮਲ ਦੋਖ ਸਗਲ ਪਰਹਰਿਆ ॥੧॥",
          "roman": "kalamal dokh sagal parhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਸਾਰੇ ਪਾਪ ਐਬ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Все грехи и пороки уходят прочь. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18067,
          "is_rahao": true,
          "gurmukhi": "ਸੋਈ ਦਿਵਸੁ ਭਲਾ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "soī divas bhalā mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਸਿਰਫ਼ ਉਹੀ ਦਿਨ (ਮਨੁੱਖ ਵਾਸਤੇ) ਸੁਲੱਖਣਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат, по-настоящему благ только тот день,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18068,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਗੁਨ ਗਾਇ ਪਰਮ ਗਤਿ ਪਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "har gun gāy param gat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਹ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਕੇ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਹਾਸਲ ਕਰਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "когда, воспевая качества Хари, человек достигает высшего духовного состояния. ਰਹਾਉ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18069,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੇ ਪੂਜੇ ਪੈਰ ॥",
          "roman": "sādh janā ke pūje pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰਮੁਖਾਂ ਦੇ ਪੈਰ ਪੂਜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который почитает стопы святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18070,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਉਪਦ੍ਰਹ ਮਨ ਤੇ ਬੈਰ ॥੨॥",
          "roman": "miṭe upadrah man te bēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਮਨ ਵਿਚੋਂ ਸਾਰੀਆਂ ਛੇੜ-ਖ਼ਾਨੀਆਂ ਸਾਰੇ ਵੈਰ-ਵਿਰੋਧ ਮਿੱਟ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "избавляется в своём уме от всех распрей и вражды. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18071,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਮਿਲਿ ਝਗਰੁ ਚੁਕਾਇਆ ॥",
          "roman": "gur pūre mil jhagar chukāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ ਵਿਕਾਰਾਂ ਦਾ) ਰੌਲਾ ਮੁਕਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, тот, кто, встретив Совершенного Гуру, прекратил в себе смуту пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18072,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਦੂਤ ਸਭਿ ਵਸਗਤਿ ਆਇਆ ॥੩॥",
          "roman": "panch dūt sabh vasgat āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮਾਦਿਕ ਪੰਜੇ ਵੈਰੀ ਸਾਰੇ ਉਸ ਦੇ ਕਾਬੂ ਵਿਚ ਆ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "держит в подчинении всех пятерых врагов, таких как похоть и прочие. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18073,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਵਸਿਆ ਹਰਿ ਕਾ ਨਾਮੁ ॥",
          "roman": "jis man vasiā har kā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём уме поселилось Имя Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18074,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਊਪਰਿ ਕੁਰਬਾਨ ॥੪॥੪॥੯੮॥",
          "roman": "nānak tis ūpar kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਸ ਤੋਂ ਸਦਾ ਸਦਕੇ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ ॥੪॥੪॥੯੮॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, достоин того, чтобы всегда приносить себя ему в жертву. ॥4॥4॥98॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1534,
      "rahao_verse_id": 18081,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18075,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18076,
          "is_rahao": false,
          "gurmukhi": "ਗਾਵਿ ਲੇਹਿ ਤੂ ਗਾਵਨਹਾਰੇ ॥",
          "roman": "gāv leh tū gāvanhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਦ ਤਕ ਗਾਵਣ ਦੀ ਸਮਰਥਾ ਹੈ ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, пока есть способность петь, продолжай воспевать качества того Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18077,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪਿੰਡ ਕੇ ਪ੍ਰਾਨ ਅਧਾਰੇ ॥",
          "roman": "jīa piṇḍ ke prān adhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਤੇਰੀ ਜਿੰਦ ਦਾ ਆਸਰਾ ਹੈ ਜੋ ਤੇਰੇ ਸਰੀਰ ਦਾ ਆਸਰਾ ਹੈ ਜੋ ਤੇਰੇ ਪ੍ਰਾਣਾਂ ਦਾ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "который есть опора твоей жизни, опора твоего тела, опора твоего дыхания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18078,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਸੇਵਾ ਸਰਬ ਸੁਖ ਪਾਵਹਿ ॥",
          "roman": "jā kī sevā sarab sukh pāveh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰ ਕੇ ਤੂੰ ਸਾਰੇ ਸੁਖ ਹਾਸਲ ਕਰ ਲਏਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "служа и поклоняясь которому, ты обретёшь все блага,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18079,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਕਾਹੂ ਪਹਿ ਬਹੁੜਿ ਨ ਜਾਵਹਿ ॥੧॥",
          "roman": "avar kāhū peh bahuṛ na jāveh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਸੁਖਾਂ ਦੀ ਭਾਲ ਵਿਚ) ਕਿਸੇ ਹੋਰ ਪਾਸ ਮੁੜ ਜਾਣ ਦੀ ਲੋੜ ਨਹੀਂ ਪਏਗੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и тебе не придётся снова обращаться к кому-либо другому в поисках счастья. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18080,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਅਨੰਦ ਅਨੰਦੀ ਸਾਹਿਬੁ ਗੁਨ ਨਿਧਾਨ ਨਿਤ ਨਿਤ ਜਾਪੀਐ ॥",
          "roman": "sadā anand anandī sāhib gun nidhān nit nit jāpīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਾਲਕ-ਪ੍ਰਭੂ (ਦੇ ਨਾਮ) ਨੂੰ ਸਦਾ ਹੀ ਜਪਣਾ ਚਾਹੀਦਾ ਹੈ ਜੋ ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ ਜੋ ਸਦਾ ਆਨੰਦ ਦਾ ਸੋਮਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, всегда следует повторять Имя того Владыки, который есть сокровищница всех достоинств и вечный источник блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18081,
          "is_rahao": true,
          "gurmukhi": "ਬਲਿਹਾਰੀ ਤਿਸੁ ਸੰਤ ਪਿਆਰੇ ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਪ੍ਰਭੁ ਮਨਿ ਵਾਸੀਐ ॥ ਰਹਾਉ ॥",
          "roman": "balihārī tis sant piāre jis prasād prabh man vāsīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਪਿਆਰੇ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਨੂੰ ਮਨ ਵਿਚ ਵਸਾ ਸਕੀਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Нужно идти в жертву тому любимому святому, по чьей милости Бога можно поселить в своём уме. ਰਹਾਉ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18082,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਦਾਨੁ ਨਿਖੂਟੈ ਨਾਹੀ ॥",
          "roman": "jā kā dān nikhūṭē nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਦੀ ਦਿੱਤੀ ਹੋਈ ਦਾਤਿ ਕਦੇ ਮੁੱਕਦੀ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, чьё дарованное никогда не иссякает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18083,
          "is_rahao": false,
          "gurmukhi": "ਭਲੀ ਭਾਤਿ ਸਭ ਸਹਜਿ ਸਮਾਹੀ ॥",
          "roman": "bhalī bhāt sabh sahaj samāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਜੋ ਜੋ ਉਸ ਨੂੰ ਮਨ ਵਿਚ ਵਸਾਂਦੇ ਹਨ ਉਹ) ਸਾਰੇ ਚੰਗੀ ਤਰ੍ਹਾਂ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "и все, кто поселяют Его в своём уме, прочно пребывают в духовной уравновешенности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18084,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਬਖਸ ਨ ਮੇਟੈ ਕੋਈ ॥",
          "roman": "jā kī bakhas na meṭē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕੀਤੀ ਬਖ਼ਸ਼ਸ਼ ਦੇ ਰਾਹ ਵਿਚ ਕੋਈ ਰੋਕ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "чьё дарованное прощение никто не может отменить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18085,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਵਾਸਾਈਐ ਸਾਚਾ ਸੋਈ ॥੨॥",
          "roman": "man vāsāīai sāchā soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੂੰ ਹੀ ਸਦਾ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "именно этого вечного Бога и следует всегда помещать в своё сердце. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18086,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਗ੍ਰਿਹ ਜਾ ਕੈ ਪੂਰਨ ॥",
          "roman": "sagal samagrī grih jā kē pūran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ (ਪ੍ਰਭੂ) ਦੇ ਘਰ ਵਿਚ (ਜੀਵਾਂ ਵਾਸਤੇ) ਸਾਰੇ ਪਦਾਰਥ ਭਰੇ ਪਏ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, в доме того Господа для существ в изобилии имеются все блага,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18087,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਦੂਖ ਨ ਝੂਰਨ ॥",
          "roman": "prabh ke sevak dūkh na jhūran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਸੇਵਕਾਂ ਨੂੰ ਕੋਈ ਦੁੱਖ ਕੋਈ ਝੋਰੇ ਪੋਹ ਨਹੀਂ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "и Его слуг не могут одолеть ни страдания, ни тревоги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18088,
          "is_rahao": false,
          "gurmukhi": "ਓਟਿ ਗਹੀ ਨਿਰਭਉ ਪਦੁ ਪਾਈਐ ॥",
          "roman": "oṭ gahī nirbhau pad pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਆਸਰਾ ਲਿਆਂ ਉਹ ਆਤਮਕ ਦਰਜਾ ਮਿਲ ਜਾਂਦਾ ਹੈ ਜਿਥੇ ਕੋਈ ਡਰ ਦਬਾ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "а если принять Его покровительство, достигается то духовное состояние, где не может подавить никакой страх,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18089,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਸੋ ਗੁਨ ਨਿਧਿ ਗਾਈਐ ॥੩॥",
          "roman": "sās sās so gun nidh gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਉਸ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому с каждым дыханием следует воспевать качества того Господа, сокровищницы достоинств. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18090,
          "is_rahao": false,
          "gurmukhi": "ਦੂਰਿ ਨ ਹੋਈ ਕਤਹੂ ਜਾਈਐ ॥",
          "roman": "dūr na hoī katahū jāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਪਰਮਾਤਮਾ ਸਾਥੋਂ ਦੂਰ ਨਹੀਂ ਵੱਸਦਾ, ਕਿਤੇ (ਦੂਰ) ਲੱਭਣ ਜਾਣ ਦੀ ਲੋੜ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, этот Бог не обитает далеко от нас, нет нужды идти куда-то далеко на поиски,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18091,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਤਾ ਹਰਿ ਹਰਿ ਪਾਈਐ ॥",
          "roman": "nadar kre tā har har pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਪ੍ਰਾਪਤੀ ਤਦੋਂ ਹੀ ਹੋ ਸਕਦੀ ਹੈ ਜਦੋਂ ਉਹ ਆਪ ਮੇਹਰ ਦੀ ਨਜ਼ਰ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "Его можно обрести только тогда, когда Он Сам бросит милостивый взгляд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18092,
          "is_rahao": false,
          "gurmukhi": "ਅਰਦਾਸਿ ਕਰੀ ਪੂਰੇ ਗੁਰ ਪਾਸਿ ॥",
          "roman": "ardās karī pūre gur pās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ ਤਾਂ ਪੂਰੇ ਗੁਰੂ ਕੋਲ ਹੀ ਅਰਦਾਸ ਕਰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, я обращаю молитву только к Совершенному Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18093,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮੰਗੈ ਹਰਿ ਧਨੁ ਰਾਸਿ ॥੪॥੫॥੯੯॥",
          "roman": "nānak mangē har dhan rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਆਖਦਾ ਹਾਂ-ਹੇ ਗੁਰੂ! ਤੇਰੇ ਪਾਸੋਂ) ਨਾਨਕ ਹਰਿ-ਨਾਮ-ਧਨ ਮੰਗਦਾ ਹੈ ਹਰਿ-ਨਾਮ ਦਾ ਸਰਮਾਇਆ ਮੰਗਦਾ ਹੈ ॥੪॥੫॥੯੯॥"
            },
            "sahib_singh_ru": {
              "main": "и говорю: Нанак просит богатство Имени Хари, просит запас этого богатства. ॥4॥5॥99॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1535,
      "rahao_verse_id": 18100,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18094,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18095,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਥਮੇ ਮਿਟਿਆ ਤਨ ਕਾ ਦੂਖ ॥",
          "roman": "prathame miṭiā tan kā dūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ ਸਭ ਤੋਂ) ਪਹਿਲਾਂ ਮੇਰੇ ਸਰੀਰ ਦਾ ਹਰੇਕ ਦੁੱਖ ਮਿਟ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, встретив Гуру, прежде всего я избавился от всякой телесной боли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18096,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸਗਲ ਕਉ ਹੋਆ ਸੂਖੁ ॥",
          "roman": "man sagal kau hoā sūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ ਮੇਰੇ ਮਨ ਨੂੰ ਪੂਰਨ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੋਇਆ।"
            },
            "sahib_singh_ru": {
              "main": "а затем мой ум обрёл совершенное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18097,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਗੁਰ ਦੀਨੋ ਨਾਉ ॥",
          "roman": "kar kirpā gur dīno nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਕਿਰਪਾ ਕਰ ਕੇ ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру по милости дал мне Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18098,
          "is_rahao": false,
          "gurmukhi": "ਬਲਿ ਬਲਿ ਤਿਸੁ ਸਤਿਗੁਰ ਕਉ ਜਾਉ ॥੧॥",
          "roman": "bal bal tis satgur kau jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ ਉਸ ਗੁਰੂ ਤੋਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О брат, я снова и снова иду в жертву тому Сатгуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18099,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪਾਇਓ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "gur pūrā pāio mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਜਦੋਂ ਦਾ ਮੈਨੂੰ ਪੂਰਾ ਗੁਰੂ ਮਿਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат, с тех пор как я встретил Совершенного Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18100,
          "is_rahao": true,
          "gurmukhi": "ਰੋਗ ਸੋਗ ਸਭ ਦੂਖ ਬਿਨਾਸੇ ਸਤਿਗੁਰ ਕੀ ਸਰਣਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "rog sog sabh dūkh bināse satgur kī saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਮੇਰੇ ਸਾਰੇ ਰੋਗ ਸਾਰੇ ਚਿੰਤਾ ਫ਼ਿਕਰ ਸਾਰੇ ਦੁੱਖ ਨਾਸ ਹੋ ਗਏ ਹਨ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "в прибежище Гуру исчезли все мои болезни, все тревоги и все страдания. ਰਹਾਉ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18101,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਨ ਹਿਰਦੈ ਵਸਾਏ ॥",
          "roman": "gur ke charan hirdē vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਦੋਂ ਤੋਂ) ਮੈਂ ਗੁਰੂ ਦੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, с тех пор как я поселил стопы Гуру в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18102,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਚਿੰਤਤ ਸਗਲੇ ਫਲ ਪਾਏ ॥",
          "roman": "man chintat sagle phal pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਸਾਰੇ ਮਨ-ਇੱਛਤ ਫਲ ਮਿਲ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "я получаю все плоды, которых желает мой ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18103,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਬੁਝੀ ਸਭ ਹੋਈ ਸਾਂਤਿ ॥",
          "roman": "agan bujhī sabh hoī sānt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ ਅੰਦਰੋਂ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਬੁੱਝ ਗਈ ਹੈ (ਮੇਰੇ ਅੰਦਰ) ਪੂਰੀ ਠੰਢ ਪੈ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Огонь жажды во мне угас, и внутри воцарился полный покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18104,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਗੁਰਿ ਕੀਨੀ ਦਾਤਿ ॥੨॥",
          "roman": "kar kirpā gur kīnī dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰੀ ਦਾਤਿ ਗੁਰੂ ਨੇ ਹੀ ਮੇਹਰ ਕਰ ਕੇ ਦਿੱਤੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Весь этот дар Гуру дал мне по своей милости. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18105,
          "is_rahao": false,
          "gurmukhi": "ਨਿਥਾਵੇ ਕਉ ਗੁਰਿ ਦੀਨੋ ਥਾਨੁ ॥",
          "roman": "nithāve kau gur dīno thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਪਹਿਲਾਂ ਕਿਤੇ ਢੋਈ ਨਹੀਂ ਸੀ ਮਿਲਦੀ ਗੁਰੂ ਨੇ ਮੈਨੂੰ (ਆਪਣੇ ਚਰਨਾਂ ਵਿੱਚ) ਥਾਂ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Прежде у меня нигде не было пристанища, но Гуру дал мне место у своих стоп,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18106,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਾਨੇ ਕਉ ਗੁਰਿ ਕੀਨੋ ਮਾਨੁ ॥",
          "roman": "nimāne kau gur kīno mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਨਿਮਾਣੇ ਨੂੰ ਗੁਰੂ ਨੇ ਆਦਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "мне, лишённому достоинства, Гуру даровал честь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18107,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਸੇਵਕ ਕਰਿ ਰਾਖੇ ॥",
          "roman": "bandhan kāṭ sevak kar rākhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਬੰਧਨ ਕੱਟ ਕੇ ਮੈਨੂੰ ਗੁਰੂ ਨੇ ਆਪਣਾ ਸੇਵਕ ਬਣਾ ਕੇ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "разрубив мои узы привязанности к майе, Гуру сделал меня своим слугой и утвердил у своих стоп,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18108,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਾਨੀ ਰਸਨਾ ਚਾਖੇ ॥੩॥",
          "roman": "amrit bānī rasnā chākhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੀ ਜੀਭ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ (ਦਾ ਰਸ) ਚੱਖਦੀ ਰਹਿੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и теперь мой язык вкушает нектар речи хвалы, дарующей духовную жизнь. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18109,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਪੂਜ ਗੁਰ ਚਰਨਾ ॥",
          "roman": "vaḍē bhāg pūj gur charnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਵੱਡੀ ਕਿਸਮਤਿ ਨਾਲ ਮੈਨੂੰ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਪੂਜਾ (ਦਾ ਅਵਸਰ ਮਿਲਿਆ)"
            },
            "sahib_singh_ru": {
              "main": "О брат, по великой удаче мне выпала возможность почитать стопы Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18110,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਿਆਗਿ ਪਾਈ ਪ੍ਰਭ ਸਰਨਾ ॥",
          "roman": "sagal tiāg pāī prabh sarnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੈਂ ਹੋਰ ਸਾਰੇ ਆਸਰੇ ਛੱਡ ਕੇ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਆ ਪਿਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и по этой благодати я, оставив все прочие опоры, пришёл в прибежище Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
