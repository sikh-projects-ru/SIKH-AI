{
  "ang": 398,
  "shabads": [
    {
      "shabad_id": 1543,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18203,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਮੰਨੇ ਆਪਿ ਸੋਈ ਮਾਨੀਐ ॥",
          "roman": "jis no manne āp soī mānīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Он Сам признаёт, того и следует считать почтенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18204,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟ ਪੁਰਖੁ ਪਰਵਾਣੁ ਸਭ ਠਾਈ ਜਾਨੀਐ ॥੩॥",
          "roman": "pragaṭ purakh parvāṇ sabh ṭhāī jāṇīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой явленный человек принят Богом и известен повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18205,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨਸੁ ਰੈਣਿ ਆਰਾਧਿ ਸਮੑਾਲੇ ਸਾਹ ਸਾਹ ॥",
          "roman": "dinas rēṇ ārādh samāle sāh sāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Днём и ночью поклоняйся Ему и помни Его с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18206,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਲੋਚਾ ਪੂਰਿ ਸਚੇ ਪਾਤਿਸਾਹ ॥੪॥੬॥੧੦੮॥",
          "roman": "Nānak kī lochā pūr sache pātisāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Истинный Патишах, исполни стремление Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1544,
      "rahao_verse_id": 18211,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18207,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "Āsā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Аса, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18208,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਿ ਰਹਿਆ ਸ੍ਰਬ ਠਾਇ ਹਮਾਰਾ ਖਸਮੁ ਸੋਇ ॥",
          "roman": "pūr rahiyā srab ṭhāe hamārā khasam soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наш Господин-Хозяин пребывает и пронизывает каждое место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18209,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਸਾਹਿਬੁ ਸਿਰਿ ਛਤੁ ਦੂਜਾ ਨਾਹਿ ਕੋਇ ॥੧॥",
          "roman": "ek sāhib sir chhat dūjā nāh koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Есть один Владыка; над Его головой царский зонт, и равного Ему нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18210,
          "is_rahao": true,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਾਖੁ ਰਾਖਣਹਾਰਿਆ ॥",
          "roman": "jiu bhāvē tiu rākh rākhaṇhāriyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Способный защищать всех живых, храни меня так, как Тебе угодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18211,
          "is_rahao": true,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਇ ਨਦਰਿ ਨਿਹਾਰਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tujh bin avar na koe nadar nihāriyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя, я не видел своими глазами никого другого, кто был бы подобен Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18212,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਤਿਪਾਲੇ ਪ੍ਰਭੁ ਆਪਿ ਘਟਿ ਘਟਿ ਸਾਰੀਐ ॥",
          "roman": "pratipāle prabh āp ghaṭ ghaṭ sārīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господь заботится о каждом теле и питает каждого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18213,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਵੁਠਾ ਆਪਿ ਤਿਸੁ ਨ ਵਿਸਾਰੀਐ ॥੨॥",
          "roman": "jis man vuṭhā āp tis na visārīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В чьём уме Сам Господь поселился, того Он уже никогда не заставляет забыть Себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18214,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੇ ਸੁ ਆਪਿ ਆਪਣ ਭਾਣਿਆ ॥",
          "roman": "jo kichh kare so āp āpaṇ bhāṇiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё, что происходит в мире, Сам Бог совершает по Своей воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18215,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਾ ਕਾ ਸਹਾਈ ਜੁਗਿ ਜੁਗਿ ਜਾਣਿਆ ॥੩॥",
          "roman": "bhagtā kā sahāī jug jug jāṇiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Известно, что во всякую эпоху Бог помогает Своим бхагатам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18216,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਹਰਿ ਕਾ ਨਾਮੁ ਕਦੇ ਨ ਝੂਰੀਐ ॥",
          "roman": "jap jap har kā nām kade na jhūrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Хари снова и снова, уже не приходится тревожиться никакой заботой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18217,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਸ ਪਿਆਸ ਲੋਚਾ ਪੂਰੀਐ ॥੪॥੭॥੧੦੯॥",
          "roman": "Nānak daras piyās lochā pūrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Нанака жажда Твоего Даршана; исполни это его стремление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1545,
      "rahao_verse_id": 18222,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18218,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "Āsā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Аса, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18219,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਸੋਵਹਿ ਨਾਮੁ ਵਿਸਾਰਿ ਗਾਫਲ ਗਹਿਲਿਆ ॥",
          "roman": "kiyā soveh nām visār gāfal gahiliyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О беспечный ум, почему ты спишь в забытьи привязанности, забыв Имя Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18220,
          "is_rahao": false,
          "gurmukhi": "ਕਿਤਂੀ ਇਤੁ ਦਰੀਆਇ ਵੰਞਨਿੑ ਵਹਦਿਆ ॥੧॥",
          "roman": "kitnī it darīāe vaññan vahdiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Смотри, забыв Имя, бесчисленные существа уносятся течением этой реки мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18221,
          "is_rahao": true,
          "gurmukhi": "ਬੋਹਿਥੜਾ ਹਰਿ ਚਰਣ ਮਨ ਚੜਿ ਲੰਘੀਐ ॥",
          "roman": "bohithṛā har charaṇ man chaṛ laṅghīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, стопы Хари — прекрасный корабль; взойдя на него, переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18222,
          "is_rahao": true,
          "gurmukhi": "ਆਠ ਪਹਰ ਗੁਣ ਗਾਇ ਸਾਧੂ ਸੰਗੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āṭh pahar guṇ gāe sādhū saṅgīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому оставайся в обществе Гуру и все восемь страж дня воспевай достоинства Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18223,
          "is_rahao": false,
          "gurmukhi": "ਭੋਗਹਿ ਭੋਗ ਅਨੇਕ ਵਿਣੁ ਨਾਵੈ ਸੁੰਞਿਆ ॥",
          "roman": "bhogeh bhog anek viṇ nāvē suññiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Существа наслаждаются множеством удовольствий, но без Имени остаются пустыми от духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18224,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਬਿਨਾ ਮਰਿ ਮਰਿ ਰੁੰਨਿਆ ॥੨॥",
          "roman": "har kī bhagat binā mar mar runniyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без бхагати Хари они снова и снова переживают духовную смерть и страдают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18225,
          "is_rahao": false,
          "gurmukhi": "ਕਪੜ ਭੋਗ ਸੁਗੰਧ ਤਨਿ ਮਰਦਨ ਮਾਲਣਾ ॥",
          "roman": "kapaṛ bhog sugaṅdh tan mardan mālaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди носят красивые одежды, вкушают приятные яства и натирают тело благоуханными мазями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18226,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਿਮਰਨ ਤਨੁ ਛਾਰੁ ਸਰਪਰ ਚਾਲਣਾ ॥੩॥",
          "roman": "bin simran tan chhār sarpar chālaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но без симрана это тело подобно праху, ведь ему непременно предстоит исчезнуть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18227,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਬਿਖਮੁ ਸੰਸਾਰੁ ਵਿਰਲੈ ਪੇਖਿਆ ॥",
          "roman": "mahā bikham sansār virlē pekhiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий счастливец увидел, что этот океан мира чрезвычайно труден и страшен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18228,
          "is_rahao": false,
          "gurmukhi": "ਛੂਟਨੁ ਹਰਿ ਕੀ ਸਰਣਿ ਲੇਖੁ ਨਾਨਕ ਲੇਖਿਆ ॥੪॥੮॥੧੧੦॥",
          "roman": "chhūṭan har kī saraṇ lekh Nānak lekhiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, спасение из него бывает только в прибежище Хари, у того, на чьём лбу записан такой удел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1546,
      "rahao_verse_id": 18233,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18229,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "Āsā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Аса, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18230,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਕਿਸ ਹੀ ਸੰਗਿ ਕਾਹੇ ਗਰਬੀਐ ॥",
          "roman": "koe na kis hī saṅg kāhe garbīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ни один человек не остаётся навсегда ни с кем; зачем же гордиться родными и связями?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18231,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਨਾਮੁ ਆਧਾਰੁ ਭਉਜਲੁ ਤਰਬੀਐ ॥੧॥",
          "roman": "ek nām ādhār bhaujal tarbīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только одно Имя является истинной опорой; с опорой на Имя переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18232,
          "is_rahao": true,
          "gurmukhi": "ਮੈ ਗਰੀਬ ਸਚੁ ਟੇਕ ਤੂੰ ਮੇਰੇ ਸਤਿਗੁਰ ਪੂਰੇ ॥",
          "roman": "mē garīb sach ṭek tū mere satigur pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой совершенный Сатгуру, Ты вечен; Ты — опора меня, бедного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18233,
          "is_rahao": true,
          "gurmukhi": "ਦੇਖਿ ਤੁਮੑਾਰਾ ਦਰਸਨੋ ਮੇਰਾ ਮਨੁ ਧੀਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dekh tumhārā darsano merā man dhīre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Созерцая Твой Даршан, мой ум обретает терпение и уверенность для переправы через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18234,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜੁ ਮਾਲੁ ਜੰਜਾਲੁ ਕਾਜਿ ਨ ਕਿਤੈ ਗਨੋੁ ॥",
          "roman": "rāj māl jañjāl kāj na kitē gano",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Царство и богатство запутывают ум в привязанности; не считай, что в конце они пригодятся хоть для какого-то дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18235,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਨੁ ਆਧਾਰੁ ਨਿਹਚਲੁ ਏਹੁ ਧਨੋੁ ॥੨॥",
          "roman": "har kīrtan ādhār nihchal eh dhano",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевание Хари — настоящая опора души; это и есть неизменное богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18236,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਮਾਇਆ ਰੰਗ ਤੇਤ ਪਛਾਵਿਆ ॥",
          "roman": "jete māiā raṅg tet pachhāviyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все игры и краски майи исчезают, как тени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18237,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਕਾ ਨਾਮੁ ਨਿਧਾਨੁ ਗੁਰਮੁਖਿ ਗਾਵਿਆ ॥੩॥",
          "roman": "sukh kā nām nidhān gurmukh gāviyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — сокровищница всех радостей; его можно воспевать, лишь придя к прибежищу Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18238,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਗੁਣੀ ਨਿਧਾਨੁ ਤੂੰ ਪ੍ਰਭ ਗਹਿਰ ਗੰਭੀਰੇ ॥",
          "roman": "sachā guṇī nidhān tū prabh gahir gambhīre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты глубок, великодушен, вечен и являешься сокровищницей всех добродетелей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18239,
          "is_rahao": false,
          "gurmukhi": "ਆਸ ਭਰੋਸਾ ਖਸਮ ਕਾ ਨਾਨਕ ਕੇ ਜੀਅਰੇ ॥੪॥੯॥੧੧੧॥",
          "roman": "ās bharosā khasam kā Nānak ke jīare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О душа Нанака, полагай надежду только на Господа-Хозяина и доверяй только Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1547,
      "rahao_verse_id": 18244,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18240,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "Āsā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Аса, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18241,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਦੁਖੁ ਜਾਇ ਸਹਜ ਸੁਖੁ ਪਾਈਐ ॥",
          "roman": "jis simrat dukh jāe sahaj sukh pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При памятовании о Том Боге всякое страдание уходит и обретается радость духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18242,
          "is_rahao": false,
          "gurmukhi": "ਰੈਣਿ ਦਿਨਸੁ ਕਰ ਜੋੜਿ ਹਰਿ ਹਰਿ ਧਿਆਈਐ ॥੧॥",
          "roman": "rēṇ dinas kar joṛ har har dhyāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сложив обе руки, днём и ночью следует держать внимание на Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18243,
          "is_rahao": true,
          "gurmukhi": "ਨਾਨਕ ਕਾ ਪ੍ਰਭੁ ਸੋਇ ਜਿਸ ਕਾ ਸਭੁ ਕੋਇ ॥",
          "roman": "Nānak kā prabh soe jis kā sabh koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Нанака — Тот, Кем сотворено каждое существо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18244,
          "is_rahao": true,
          "gurmukhi": "ਸਰਬ ਰਹਿਆ ਭਰਪੂਰਿ ਸਚਾ ਸਚੁ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarab rahiyā bharpūr sachā sach soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он полностью пребывает во всех; Он вечен, и только Он поистине вечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18245,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਸੰਗਿ ਸਹਾਈ ਗਿਆਨ ਜੋਗੁ ॥",
          "roman": "antar bāhar saṅg sahāī giān jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он пребывает внутри и вовне, остаётся рядом, помогает всем, и глубокое познание Его крайне необходимо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18246,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਅਰਾਧਿ ਮਨਾ ਬਿਨਾਸੈ ਸਗਲ ਰੋਗੁ ॥੨॥",
          "roman": "tiseh arādh manā bināsē sagal rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум, поклоняйся Ему: через Его симран уничтожаются все болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18247,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰੁ ਅਪਾਰੁ ਰਾਖੈ ਅਗਨਿ ਮਾਹਿ ॥",
          "roman": "rākhaṇhār apār rākhē agan māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бесконечный Защитник, способный оберегать всех, хранит каждое существо даже в огне материнского чрева."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
