{
  "ang": 410,
  "shabads": [
    {
      "shabad_id": 1593,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18686,
          "is_rahao": false,
          "gurmukhi": "ਅਲਖ ਅਭੇਵੀਐ ਹਾਂ ॥",
          "roman": "alakh abhevīai hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਸਹੀ-ਸਰੂਪ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ਤੇ ਜਿਸ ਦਾ ਭੇਤ ਪਾਇਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Чей истинный облик нельзя описать и Чью тайну нельзя постичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18687,
          "is_rahao": false,
          "gurmukhi": "ਤਾਂ ਸਿਉ ਪ੍ਰੀਤਿ ਕਰਿ ਹਾਂ ॥",
          "roman": "tāṅ siu prīt kar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ!) ਉਸ ਪਰਮਾਤਮਾ ਨਾਲ ਪਿਆਰ ਪਾ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Возлюби этого Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18688,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸਿ ਨ ਜਾਇ ਮਰਿ ਹਾਂ ॥",
          "roman": "binas na jāi mar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ ਜੋ ਨਾਹ ਜੰਮਦਾ ਹੈ ਤੇ ਨਾਹ ਮਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Который никогда не уничтожается, не рождается и не умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18689,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਤੇ ਜਾਨਿਆ ਹਾਂ ॥",
          "roman": "gur te jāniā hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਉਸ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который через Гуру обрёл глубокую связь с этим Параматмой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18690,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਨੁ ਮਾਨਿਆ ਮੇਰੇ ਮਨਾ ॥੨॥੩॥੧੫੯॥",
          "roman": "nānak man māniā mere manā.2.3.159.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਮੇਰੇ ਮਨ! ਉਸ ਦਾ ਮਨ ਸਦਾ (ਉਸ ਦੀ ਯਾਦ ਵਿਚ) ਗਿੱਝ ਜਾਂਦਾ ਹੈ ॥੨॥੩॥੧੫੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: о мой ум, его ум навсегда проникается этой памятью. ॥2॥3॥159॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1594,
      "rahao_verse_id": 18696,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18691,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾਵਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "āsāvarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18692,
          "is_rahao": true,
          "gurmukhi": "ਏਕਾ ਓਟ ਗਹੁ ਹਾਂ ॥",
          "roman": "ekā oṭ gah̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਪੱਲਾ ਫੜ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Держись только за одного Параматму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18693,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਕਹੁ ਹਾਂ ॥",
          "roman": "gur kā sabad kah̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਗੁਰੂ ਦੀ ਬਾਣੀ ਉਚਾਰਦਾ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно произноси Бани Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18694,
          "is_rahao": true,
          "gurmukhi": "ਆਗਿਆ ਸਤਿ ਸਹੁ ਹਾਂ ॥",
          "roman": "āgiā sat sah̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ ਮਿੱਠੀ ਕਰ ਕੇ ਮੰਨ।"
            },
            "sahib_singh_ru": {
              "main": "Сладостно прими и признай волю Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18695,
          "is_rahao": true,
          "gurmukhi": "ਮਨਹਿ ਨਿਧਾਨੁ ਲਹੁ ਹਾਂ ॥",
          "roman": "manah nidhān lah̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਵਿਚ ਵੱਸਦੇ ਸਾਰੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਨੂੰ ਲੱਭ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "Найди в своём уме Господа, в Котором пребывает сокровищница всех добродетелей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18696,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖਹਿ ਸਮਾਈਐ ਮੇਰੇ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukhhī samāīai mere manā ǁ1ǁ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! (ਇਸ ਤਰ੍ਹਾਂ ਸਦਾ) ਆਤਮਕ ਆਨੰਦ ਵਿਚ ਲੀਨ ਰਹੀਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Так всегда и пребывают погружёнными в духовное блаженство. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18697,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਜੋ ਮਰੈ ਹਾਂ ॥",
          "roman": "jīvat jo marē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਕਿਰਤ-ਕਾਰ ਕਰਦਾ ਹੋਇਆ ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ ਅਛੋਹ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, занимаясь делами, остаётся незатронутым привязанностью к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18698,
          "is_rahao": false,
          "gurmukhi": "ਦੁਤਰੁ ਸੋ ਤਰੈ ਹਾਂ ॥",
          "roman": "dutar so tarē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ, ਜਿਸ ਵਿਚੋਂ ਪਾਰ ਲੰਘਣਾ ਬਹੁਤ ਔਖਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "переплывает этот мирской океан, который очень трудно переплыть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18699,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕੀ ਰੇਨੁ ਹੋਇ ਹਾਂ ॥",
          "roman": "sabh kī ren hoi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਮਨੁੱਖ ਸਭਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если он остаётся пылью у стоп всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18700,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਕਹਉ ਸੋਇ ਹਾਂ ॥",
          "roman": "nirbhau kahau soi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮੈਂ ਭੀ ਉਸ ਨਿਰਭਉ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если и я буду постоянно воспевать того Нирбхау Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18701,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਅੰਦੇਸਿਆ ਹਾਂ ॥",
          "roman": "miṭe andesiā hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਮੇਰੇ ਸਾਰੇ ਚਿੰਤਾ ਫ਼ਿਕਰ ਮਿਟ ਜਾਣਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "тогда исчезнут все мои тревоги и заботы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18702,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਉਪਦੇਸਿਆ ਮੇਰੇ ਮਨਾ ॥੧॥",
          "roman": "sant updesiā mere manā ǁ1ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! (ਆਖ!) ਤੈਨੂੰ ਸਤਿਗੁਰੂ ਦੀ ਇਹ ਸਿੱਖਿਆ ਪ੍ਰਾਪਤ ਹੋ ਜਾਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Скажи: пусть тебе будет даровано это наставление Сатгуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18703,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਜਨ ਨਾਮ ਸੁਖੁ ਹਾਂ ॥",
          "roman": "jis jan nām sukh hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, получивший радость Имени Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18704,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਨਿਕਟਿ ਨ ਕਦੇ ਦੁਖੁ ਹਾਂ ॥",
          "roman": "tis nikaṭ na kade dukh hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਕੋਈ ਦੁੱਖ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "никогда не подпускает к себе никакое страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18705,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਹਰਿ ਹਰਿ ਜਸੁ ਸੁਨੇ ਹਾਂ ॥",
          "roman": "jo har har jas sune hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸਦਾ ਸੁਣਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который постоянно слушает хвалу Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18706,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕੋ ਤਿਸੁ ਮੰਨੇ ਹਾਂ ॥",
          "roman": "sabh ko tis manne hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਵਿਚ) ਹਰੇਕ ਮਨੁੱਖ ਉਸ ਦਾ ਆਦਰ-ਸਤਕਾਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "почитается каждым человеком в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18707,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲੁ ਸੁ ਆਇਆ ਹਾਂ ॥",
          "roman": "safal su āiā hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਵਿਚ ਜੰਮਿਆ ਹੋਇਆ ਉਹੀ ਮਨੁੱਖ ਕਾਮਯਾਬ ਜੀਵਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По-настоящему успешную жизнь прожил только тот,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18708,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਭਾਇਆ ਮੇਰੇ ਮਨਾ ॥੨॥੪॥੧੬੦॥",
          "roman": "nānak prabh bhāiā mere manā ǁ2ǁ4ǁ160ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਮੇਰੇ ਮਨ! ਜੇਹੜਾ ਪਰਮਾਤਮਾ ਨੂੰ ਪਿਆਰਾ ਲੱਗ ਗਿਆ ਹੈ ॥੨॥੪॥੧੬੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Скажи: о мой ум! тот, кто стал дорог Параматме. ॥2॥4॥160॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1595,
      "rahao_verse_id": 18715,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18709,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾਵਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "āsāvarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18710,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲਿ ਹਰਿ ਜਸੁ ਗਾਈਐ ਹਾਂ ॥",
          "roman": "mil har jas gāīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਵਿਚ) ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Собравшись вместе в Садх Сангат, следует петь песнь хвалы Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18711,
          "is_rahao": true,
          "gurmukhi": "ਪਰਮ ਪਦੁ ਪਾਈਐ ਹਾਂ ॥",
          "roman": "param pad pāīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਆਤਮਕ ਜੀਵਨ ਦਾ ਸਭ ਤੋਂ ਉੱਚਾ ਦਰਜਾ ਹਾਸਲ ਕਰ ਲਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так достигается высшее состояние духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18712,
          "is_rahao": true,
          "gurmukhi": "ਉਆ ਰਸ ਜੋ ਬਿਧੇ ਹਾਂ ॥",
          "roman": "uā ras jo bidhe hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ (ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ) ਉਸ ਸੁਆਦ ਵਿਚ ਵਿੱਝ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который пронзён тем вкусом хвалы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18713,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕਉ ਸਗਲ ਸਿਧੇ ਹਾਂ ॥",
          "roman": "tā kau sagal sidhe hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ (ਮਾਨੋ) ਸਾਰੀਆਂ ਸਿੱਧੀਆਂ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "словно получает все сиддхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18714,
          "is_rahao": true,
          "gurmukhi": "ਅਨਦਿਨੁ ਜਾਗਿਆ ਹਾਂ ॥",
          "roman": "andin jāgiā hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਹਰ ਵੇਲੇ (ਵਿਕਾਰਾਂ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ (ਜਿਹੜਾ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Кто всегда остаётся бодрствующим по отношению к натиску пороков, то есть воспевает Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18715,
          "is_rahao": true,
          "gurmukhi": "ਨਾਨਕ ਬਡਭਾਗਿਆ ਮੇਰੇ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nānak baḍbhāgiā mere manā ǁ1ǁ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਮੇਰੇ ਮਨ! ਉਹ ਮਨੁੱਖ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Скажи: о мой ум! такой человек становится очень удачливым. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18716,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪਗ ਧੋਈਐ ਹਾਂ ॥",
          "roman": "sant pag dhoīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨ ਧੋਣੇ ਚਾਹੀਦੇ ਹਨ (ਆਪਾ-ਭਾਵ ਛੱਡ ਕੇ ਸੰਤਾਂ ਦੀ ਸਰਨ ਪੈਣਾ ਚਾਹੀਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Следует омывать стопы святых, то есть, отбросив чувство своего я, искать прибежища у святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18717,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਖੋਈਐ ਹਾਂ ॥",
          "roman": "durmat khoīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ ਮਨ ਦੀ) ਖੋਟੀ ਮਤਿ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так дурной ум исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18718,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸਹ ਰੇਨੁ ਹੋਇ ਹਾਂ ॥",
          "roman": "dāsah ren hoi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸੇਵਕਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਬਣਿਆ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Оставайся пылью у стоп слуг Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18719,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪੈ ਦੁਖੁ ਨ ਕੋਇ ਹਾਂ ॥",
          "roman": "biāpē dukh na koi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਕੋਈ ਦੁੱਖ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и тогда никакое страдание не сможет навязать свою силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18720,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਾਂ ਸਰਨਿ ਪਰੁ ਹਾਂ ॥",
          "roman": "bhagtā̃ saran par hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤ-ਜਨਾਂ ਦੀ ਸਰਨੀਂ ਪਿਆ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Оставайся в прибежище бхагатов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18721,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਿ ਨ ਕਦੇ ਮਰੁ ਹਾਂ ॥",
          "roman": "janam na kade mar hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਰਹੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и круг рождения и смерти прекратится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18722,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਰੁ ਸੇ ਭਏ ਹਾਂ ॥",
          "roman": "asthir se bhae hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਡੋਲ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Они становятся обладателями устойчивой духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18723,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਜਿਨੑ ਜਪਿ ਲਏ ਮੇਰੇ ਮਨਾ ॥੧॥",
          "roman": "har har jinh japi lae mere manā ǁ1ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਜੇਹੜੇ ਮਨੁੱਖ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! те люди, которые постоянно повторяют Имя Параматмы. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18724,
          "is_rahao": false,
          "gurmukhi": "ਸਾਜਨੁ ਮੀਤੁ ਤੂੰ ਹਾਂ ॥",
          "roman": "sājan mīt tū̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ!) ਤੂੰ ਹੀ (ਮੇਰਾ) ਸੱਜਣ ਹੈਂ, ਤੂੰ ਹੀ (ਮੇਰਾ) ਮਿੱਤਰ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Ты один мой близкий, Ты один мой друг,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18725,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਦ੍ਰਿੜਾਇ ਮੂੰ ਹਾਂ ॥",
          "roman": "nām driṛāi mū̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ (ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਆਪਣਾ) ਨਾਮ ਪੱਕਾ ਕਰ ਕੇ ਟਿਕਾ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "утверди во мне, в моём сердце, Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18726,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਨਾਹਿ ਕੋਇ ਹਾਂ ॥",
          "roman": "tis bin nāh koi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ (ਅਸਲ ਸੱਜਣ ਮਿੱਤਰ) ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кроме того Параматмы нет никого иного, кто был бы истинным близким другом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18727,
          "is_rahao": false,
          "gurmukhi": "ਮਨਹਿ ਅਰਾਧਿ ਸੋਇ ਹਾਂ ॥",
          "roman": "manah arādh soi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਉਸ (ਪ੍ਰਭੂ) ਨੂੰ ਹੀ ਮਨ ਵਿੱਚ ਸਿਮਰਦਾ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помни в уме только Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18728,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨ ਵੀਸਰੈ ਹਾਂ ॥",
          "roman": "nimakh na vīsrē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਪਰਮਾਤਮਾ ਨੂੰ) ਅੱਖ ਝਮਕਣ ਜਿਤਨੇ ਸਮੇ ਲਈ ਭੀ ਭੁੱਲਣਾ ਨਹੀਂ ਚਾਹੀਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Его не следует забывать даже на мгновение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18729,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਕਿਉ ਸਰੈ ਹਾਂ ॥",
          "roman": "tis bin kiu sarē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਸ (ਦੀ ਯਾਦ) ਤੋਂ ਬਿਨਾ ਜੀਵਨ ਸੁਖੀ ਨਹੀਂ ਗੁਜ਼ਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "потому что без памяти о Нём жизнь не проходит счастливо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18730,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਉ ਕੁਰਬਾਨੁ ਜਾਉ ਹਾਂ ॥",
          "roman": "gur kau kurbān jāu hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ (ਕਿਉਂਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ),"
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой ради Гуру, потому что только по милости Гуру"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18731,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਪੇ ਨਾਉ ਮੇਰੇ ਮਨਾ ॥੨॥੫॥੧੬੧॥",
          "roman": "nānak jape nāu mere manā ǁ2ǁ5ǁ161ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮੇਰਾ ਮਨ (ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਜਪਦਾ ਹੈ ॥੨॥੫॥੧੬੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! мой ум повторяет Имя Параматмы. ॥2॥5॥161॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1596,
      "rahao_verse_id": 18738,
      "rahao_theme": "",
