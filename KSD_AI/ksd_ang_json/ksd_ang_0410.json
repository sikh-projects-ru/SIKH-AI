      "lines": [
        {
          "verse_id": 18732,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾਵਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "āsāvarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18733,
          "is_rahao": true,
          "gurmukhi": "ਕਾਰਨ ਕਰਨ ਤੂੰ ਹਾਂ ॥",
          "roman": "kāran karan tū̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭ!) ਤੂੰ ਸਾਰੇ ਜਗਤ ਦਾ ਰਚਨਹਾਰ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты Творец всего мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18734,
          "is_rahao": true,
          "gurmukhi": "ਅਵਰੁ ਨਾ ਸੁਝੈ ਮੂੰ ਹਾਂ ॥",
          "roman": "avar nā sujhē mū̃ hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਥੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ ਨਹੀਂ ਸੁੱਝਦਾ (ਜੋ ਇਹ ਤਾਕਤ ਰੱਖਦਾ ਹੋਵੇ),"
            },
            "sahib_singh_ru": {
              "main": "кроме Тебя я не вижу никого другого, кто обладал бы такой силой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18735,
          "is_rahao": true,
          "gurmukhi": "ਕਰਹਿ ਸੁ ਹੋਈਐ ਹਾਂ ॥",
          "roman": "karah su hoīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜੋ ਕੁਝ ਤੂੰ ਕਰਦਾ ਹੈਂ ਉਹੀ (ਜਗਤ ਵਿਚ) ਵਰਤਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Всё, что Ты делаешь, то и совершается в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18736,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜਿ ਸੁਖਿ ਸੋਈਐ ਹਾਂ ॥",
          "roman": "sahaj sukh soīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਆਨੰਦ ਵਿਚ ਲੀਨ ਰਹਿ ਸਕੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек может пребывать, погружённый в радость духовного равновесия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18737,
          "is_rahao": true,
          "gurmukhi": "ਧੀਰਜ ਮਨਿ ਭਏ ਹਾਂ ॥",
          "roman": "dhīraj man bhae hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਦਾ ਹੀ ਮਨ ਵਿਚ ਹੌਸਲਾ ਬੱਝ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и только у него в уме утверждается стойкость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18738,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਦਰਿ ਪਏ ਮੇਰੇ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "prabh kē dar pae mere manā ǁ1ǁ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! (ਚਤੁਰਾਈਆਂ ਛੱਡ ਕੇ) ਜੋ ਮਨੁਖ ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਡਿੱਗ ਪਵੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! который, оставив хитрости, падает к дверям Параматмы. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18739,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਮੇ ਹਾਂ ॥",
          "roman": "sādhū sangme hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! пребывая в обществе Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18740,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਸੰਜਮੇ ਹਾਂ ॥",
          "roman": "pūran sanjme hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੁਗਤਿ ਪੂਰਨ ਤੌਰ ਤੇ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "человек полностью овладевает этим способом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18741,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਤੇ ਛੁਟੇ ਆਪ ਹਾਂ ॥",
          "roman": "jab te chhuṭe āp hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਜਿਸ ਵੇਲੇ (ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਅਹੰਕਾਰ ਮੁੱਕ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! когда внутри человека исчезает хоумэ, эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18742,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਤੇ ਮਿਟੇ ਤਾਪ ਹਾਂ ॥",
          "roman": "tab te miṭe tāp hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਗੁਰੂ ਦੀ ਓਟ ਠੀਕ ਜਾਪਦੀ ਹੈ) ਉਸੇ ਵੇਲੇ ਤੋਂ (ਮਨ ਦੇ) ਸਾਰੇ ਦੁੱਖ-ਕਲੇਸ਼ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "с того самого момента, когда опора Гуру становится по-настоящему правильной, уходят все страдания и муки ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18743,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਾ ਧਾਰੀਆ ਹਾਂ ॥",
          "roman": "kirpā dhārīā hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਗਤ ਦੇ ਮਾਲਕ-ਪ੍ਰਭੂ! ਮੇਰੇ ਉੱਤੇ ਮੇਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Владыка мира! Яви мне милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18744,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿ ਰਖੁ ਬਨਵਾਰੀਆ ਮੇਰੇ ਮਨਾ ॥੧॥",
          "roman": "pat rakh banvārīā mere manā ǁ1ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੇਰੀ (ਸਰਨ ਪਏ ਦੀ) ਇੱਜ਼ਤ ਰੱਖ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и сохрани мою честь, раз я пришёл в Твоё прибежище. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18745,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਸੁਖੁ ਜਾਨੀਐ ਹਾਂ ॥",
          "roman": "ih sukh jānīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ!) ਇਸੇ ਨੂੰ ਹੀ ਸੁਖ (ਦਾ ਮੂਲ) ਸਮਝਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Именно это и следует считать подлинным счастьем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18746,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਰੇ ਸੁ ਮਾਨੀਐ ਹਾਂ ॥",
          "roman": "har kre su mānīai hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ ਉਸ ਨੂੰ (ਮਿੱਠਾ ਕਰ ਕੇ) ਮੰਨਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "следует принимать как сладостное всё, что делает Параматма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18747,
          "is_rahao": false,
          "gurmukhi": "ਮੰਦਾ ਨਾਹਿ ਕੋਇ ਹਾਂ ॥",
          "roman": "mandā nāh koi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜੇਹੜਾ ਮਨੁੱਖ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! тот человек, который становится пылью у стоп святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18748,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਰੇਨ ਹੋਇ ਹਾਂ ॥",
          "roman": "sant kī ren hoi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ (ਜਗਤ ਵਿਚ) ਕੋਈ ਭੈੜਾ ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "не видит в мире никого дурным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18749,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਜਿਸੁ ਰਖੈ ਹਾਂ ॥",
          "roman": "āpe jis rakhē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ) ਆਪ ਹੀ ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਵਿਕਾਰਾਂ ਵਲੋਂ) ਬਚਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, которого Сам Параматма хранит от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18750,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਅੰਮ੍ਰਿਤੁ ਸੋ ਚਖੈ ਮੇਰੇ ਮਨਾ ॥੨॥",
          "roman": "har amrit so chakhē mere manā ǁ2ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ-ਜਲ ਪੀਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот пьёт нектар воды Хари-Имени, дающей духовную жизнь. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18751,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਨਾਹਿ ਕੋਇ ਹਾਂ ॥",
          "roman": "jis kā nāh koi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ!) ਜਿਸ ਮਨੁੱਖ ਦਾ ਕੋਈ ਭੀ ਸਹਾਈ ਨਹੀਂ ਬਣਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Тот человек, у которого нет никакого помощника,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18752,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਪ੍ਰਭੂ ਸੋਇ ਹਾਂ ॥",
          "roman": "tis kā prabhū soi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਉਹ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਆ ਪਏ, ਤਾਂ) ਉਹ ਪ੍ਰਭੂ ਉਸ ਦਾ ਰਾਖਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если приходит в прибежище Господа, то этот Господь становится его защитником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18753,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਗਤਿ ਬੁਝੈ ਹਾਂ ॥",
          "roman": "antargat bujhē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਹਰੇਕ ਦੇ ਦਿਲ ਦੀ ਗੱਲ ਜਾਣ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот Параматма знает, что в сердце каждого,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18754,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤਿਸੁ ਸੁਝੈ ਹਾਂ ॥",
          "roman": "sabh kichh tis sujhē hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰੇਕ ਜੀਵ ਦੀ ਹਰੇਕ ਮਨੋ-ਕਾਮਨਾ ਦੀ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ему понятно всякое желание каждого существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18755,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਉਧਾਰਿ ਲੇਹੁ ਹਾਂ ॥",
          "roman": "patit udhār leh hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਨੂੰ ਵਿਕਾਰਾਂ ਵਿਚ) ਡਿੱਗੇ ਜੀਵਾਂ ਨੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲੈ!"
            },
            "sahib_singh_ru": {
              "main": "Спаси нас, падших в пороках, от пороков!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18756,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਰਦਾਸਿ ਏਹੁ ਮੇਰੇ ਮਨਾ ॥੩॥੬॥੧੬੨॥",
          "roman": "nānak ardās eh mere manā ǁ3ǁ6ǁ162ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮੇਰਾ ਮਨ, (ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ) ਇਉਂ ਅਰਜ਼ੋਈ ਕਰਦਾ ਹੈ ॥੩॥੬॥੧੬੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Мой ум именно так и возносит мольбу у дверей Параматмы. ॥3॥6॥162॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
