{
  "ang": 412,
  "shabads": [
    {
      "shabad_id": 1599,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18811,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਫੁਨਿ ਹੋਇ ॥",
          "roman": "jo tis bhāvē so phun hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਵਿਚ ਉਹੀ ਕੁਝ ਹੋ ਰਿਹਾ ਹੈ ਜੋ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "происходит только то, что Ему угодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18812,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਭਰਥਰਿ ਨਾਨਕੁ ਕਹੈ ਬੀਚਾਰੁ ॥",
          "roman": "suṇ bharathar nānak kahē bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਰਥਰੀ ਜੋਗੀ! ਸੁਣ, ਨਾਨਕ ਤੈਨੂੰ ਇਹ ਵਿਚਾਰ ਦੀ ਗੱਲ ਦੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слушай, о Бхартхари, Нанак говорит тебе эту истину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18813,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਨਾਮੁ ਮੇਰਾ ਆਧਾਰੁ ॥੮॥੧॥",
          "roman": "nirmal nām merā ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਸਰਬ-ਵਿਆਪਕ) ਪਰਮਾਤਮਾ ਦਾ ਪਵਿਤ੍ਰ ਨਾਮ ਮੇਰੀ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਹੈ ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чистое Имя Бога — моя опора жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1600,
      "rahao_verse_id": 18820,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18814,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Нанака Дев Джи в раге Аса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18815,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜਪ ਸਭਿ ਤਪ ਸਭ ਚਤੁਰਾਈ ॥",
          "roman": "sabh jap sabh tap sabh chaturāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਸਾਰੇ ਜਪ ਕਰਦਾ ਹੈ ਸਾਰੇ ਤਪ ਸਾਧਦਾ ਹੈ (ਸ਼ਾਸਤ੍ਰ ਆਦਿਕ ਸਮਝਣ ਬਾਰੇ) ਹਰੇਕ ਕਿਸਮ ਦੀ ਸਿਆਣਪ-ਅਕਲ ਭੀ ਵਿਖਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек совершает все джапы, выполняет все аскезы и проявляет всякую мудрость и разум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18816,
          "is_rahao": false,
          "gurmukhi": "ਊਝੜਿ ਭਰਮੈ ਰਾਹਿ ਨ ਪਾਈ ॥",
          "roman": "ūjhaṛ bharmē rāh na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਉਹ (ਪਰਮਾਤਮਾ ਦਾ ਦਾਸ ਬਣਨ ਦੀ ਜੁਗਤਿ) ਨਹੀਂ ਸਮਝਦਾ, ਤਾਂ ਉਸ ਦਾ (ਜਪ ਤਪ ਆਦਿਕ ਦਾ) ਕੋਈ ਭੀ ਉੱਦਮ (ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਪਰਵਾਨ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "но если он не понимает, как стать слугой Бога, то все его усилия не принимаются в Его присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18817,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਕੋ ਥਾਇ ਨ ਪਾਈ ॥",
          "roman": "bin būjhe ko thāe na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗ਼ਲਤ ਰਸਤੇ ਤੇ ਭਟਕ ਰਿਹਾ ਹੈ, ਉਹ ਸਹੀ ਰਸਤੇ ਉੱਤੇ ਨਹੀਂ ਜਾ ਰਿਹਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он блуждает по неверному пути и не идёт по истинной дороге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18818,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਣੈ ਮਾਥੇ ਛਾਈ ॥੧॥",
          "roman": "nām bihūṇe māthe chhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਸੱਖਣੇ ਮਨੁੱਖ ਦੇ ਸਿਰ ਸੁਆਹ ਹੀ ਪੈਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Человек, лишённый Имени Бога, получает лишь прах на свою голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18819,
          "is_rahao": true,
          "gurmukhi": "ਸਾਚ ਧਣੀ ਜਗੁ ਆਇ ਬਿਨਾਸਾ ॥",
          "roman": "sāch dhaṇī jag āe bināsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਜੰਮਦਾ ਮਰਦਾ ਰਹਿੰਦਾ ਹੈ, (ਪਰ) ਜਗਤ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир рождается и умирает, но его Владыка остаётся вечным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18820,
          "is_rahao": true,
          "gurmukhi": "ਛੂਟਸਿ ਪ੍ਰਾਣੀ ਗੁਰਮੁਖਿ ਦਾਸਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "chhūṭas prāṇī gurmukh dāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਪ੍ਰਾਣੀ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਦਾਸ (ਭਗਤ) ਬਣ ਜਾਂਦਾ ਹੈ ਉਹ (ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਤੋਂ) ਬਚ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто становится слугой Бога через Гуру, освобождается от круга рождений и смертей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18821,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਮੋਹਿ ਬਾਧਾ ਬਹੁਤੀ ਆਸਾ ॥",
          "roman": "jag moh bādhā bahutī āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਬੱਝਾ ਹੋਇਆ ਬਹੁਤੀਆਂ ਆਸਾਂ ਵਿਚ ਬੱਝਾ ਹੋਇਆ (ਜੰਮਦਾ ਮਰਦਾ ਰਹਿੰਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир связан привязанностью к майе и множеством желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18822,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤੀ ਇਕਿ ਭਏ ਉਦਾਸਾ ॥",
          "roman": "gurmati ik bhaye udāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਈ (ਵਡ-ਭਾਗੀ ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਤੇ ਤੁਰ ਕੇ ਮੋਹ ਤੋਂ ਨਿਰਲੇਪ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Но некоторые, следуя учению Гуру, становятся непривязанными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18823,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਨਾਮੁ ਕਮਲੁ ਪਰਗਾਸਾ ॥",
          "roman": "antar nām kamal pargāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ (ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹਨਾਂ ਦਾ ਹਿਰਦਾ-) ਕਮਲ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри них пребывает Имя Бога, и их сердце расцветает, как лотос."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18824,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨੑ ਕਉ ਨਾਹੀ ਜਮ ਕੀ ਤ੍ਰਾਸਾ ॥੨॥",
          "roman": "tinh kau nāhī jam kī trāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜੇਹੇ ਬੰਦਿਆਂ ਨੂੰ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦਾ ਡਰ ਨਹੀਂ ਰਹਿੰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Такие люди не боятся круга рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18825,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਤ੍ਰਿਅ ਜਿਤੁ ਕਾਮਣਿ ਹਿਤਕਾਰੀ ॥",
          "roman": "jag triā jit kāmaṇ hitkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਖੁੰਝ ਕੇ) ਜਗਤ ਕਾਮਾਤੁਰ ਹੋ ਰਿਹਾ ਹੈ, ਇਸਤ੍ਰੀ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਹੋਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Мир, отдалившись от Гуру, становится одержим страстью и привязан к женщине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18826,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਲਗਿ ਨਾਮੁ ਵਿਸਾਰੀ ॥",
          "roman": "putr kalatr lag nām visārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੁੱਤਰ ਵਹੁਟੀ ਦੇ ਮੋਹ ਵਿਚ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨੂੰ ਭੁਲਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Из-за привязанности к сыну и жене он забывает Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18827,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥਾ ਜਨਮੁ ਗਵਾਇਆ ਬਾਜੀ ਹਾਰੀ ॥",
          "roman": "birthā janam gavāiā bājī hārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਆਪਣਾ ਜੀਵਨ ਵਿਅਰਥ ਗਵਾਂਦਾ ਹੈ ਤੇ ਮਨੁੱਖਾ ਜਨਮ ਦੀ ਖੇਡ ਹਾਰ ਕੇ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Так он напрасно теряет свою жизнь и проигрывает игру человеческого рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18828,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵੇ ਕਰਣੀ ਸਾਰੀ ॥੩॥",
          "roman": "satgur sevē karaṇī sārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ (ਦੱਸੀ) ਸੇਵਾ ਕਰਦਾ ਹੈ ਉਸ ਦਾ ਨਿੱਤ-ਕਰਮ ਸ੍ਰੇਸ਼ਟ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но тот, кто служит Гуру, обретает возвышенные деяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18829,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਹੁ ਹਉਮੈ ਕਹੈ ਕਹਾਏ ॥",
          "roman": "bāhr haumē kahē kahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਵਿੱਚ ਨਹੀਂ ਪੈਂਦਾ, ਉਂਞ ਦੁਨੀਆ ਦੀ ਕਿਰਤ ਕਾਰ ਕਰਦਾ ਉਹ ਵੇਖਣ ਨੂੰ ਆਪਾ ਜਤਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он внешне проявляет эго, занимаясь делами мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18830,
          "is_rahao": false,
          "gurmukhi": "ਅੰਦਰਹੁ ਮੁਕਤੁ ਲੇਪੁ ਕਦੇ ਨ ਲਾਏ ॥",
          "roman": "andr mukat lep kadē na lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਅੰਤਰ ਆਤਮੇ ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਆਜ਼ਾਦ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но внутренне остаётся свободным от привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18831,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹੁ ਗੁਰ ਸਬਦਿ ਜਲਾਏ ॥",
          "roman": "māiā moh gur shabad jalāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ (ਜੁੜ ਕੇ ਆਪਣੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦਾ ਮੋਹ ਸਾੜ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он сжигает привязанность к майе через Слово Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18832,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਨਾਮੁ ਸਦ ਹਿਰਦੈ ਧਿਆਏ ॥੪॥",
          "roman": "nirmal nām sad hirdē dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਪਵਿਤ੍ਰ ਨਾਮ ਨੂੰ ਸਦਾ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਯਾਦ ਰੱਖਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и всегда держит чистое Имя Бога в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18833,
          "is_rahao": false,
          "gurmukhi": "ਧਾਵਤੁ ਰਾਖੈ ਠਾਕਿ ਰਹਾਏ ॥",
          "roman": "dhāvat rākhe ṭhāk rahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣੇ ਭਟਕਦੇ ਮਨ ਦੀ ਰਾਖੀ ਕਰਦਾ ਹੈ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਰੋਕ ਕੇ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он удерживает свой блуждающий ум и останавливает его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18834,
          "is_rahao": false,
          "gurmukhi": "ਸਿਖ ਸੰਗਤਿ ਕਰਮਿ ਮਿਲਾਏ ॥",
          "roman": "sikh sangat karam milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੇ) ਜਿਸ ਸਿੱਖ ਨੂੰ (ਪਰਮਾਤਮਾ ਆਪਣੀ) ਮੇਹਰ ਨਾਲ, ਸੰਗਤਿ ਵਿਚ ਮਿਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и тот ученик, которого Бог по милости соединяет с сангатом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18835,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਬਿਨੁ ਭੂਲੋ ਆਵੈ ਜਾਏ ॥",
          "roman": "gur bin bhūlo āvē jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਣ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ (ਜ਼ਿੰਦਗੀ ਦੇ ਸਹੀ ਰਸਤੇ ਤੋਂ) ਖੁੰਝ ਜਾਂਦਾ ਹੈ, ਤੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪੈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "без Гуру человек сбивается с пути и попадает в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18836,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਸੰਜੋਗਿ ਮਿਲਾਏ ॥੫॥",
          "roman": "nadar karē sanjog milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਤੇ ਪ੍ਰਭੂ ਮੇਹਰ ਦੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ, ਉਸ ਨੂੰ ਸੰਗਤਿ ਵਿਚ ਰਲਾ ਕੇ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਲੈਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Кого Бог благословляет Своим взглядом милости, того соединяет с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18837,
          "is_rahao": false,
          "gurmukhi": "ਰੂੜੋ ਕਹਉ ਨ ਕਹਿਆ ਜਾਈ ॥",
          "roman": "rūṛo kahau na kahiā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਸੁੰਦਰ ਹੈਂ, ਪਰ ਜੇ ਮੈਂ ਦੱਸਣ ਦਾ ਜਤਨ ਕਰਾਂ ਕਿ ਤੂੰ ਕਿਹੋ ਜਿਹਾ ਸੁੰਦਰ ਹੈਂ ਤਾਂ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты прекрасен, но невозможно описать Твою красоту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18838,
          "is_rahao": false,
          "gurmukhi": "ਅਕਥ ਕਥਉ ਨਹ ਕੀਮਤਿ ਪਾਈ ॥",
          "roman": "akath kathau nah kīmat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਗੁਣ ਬਿਆਨ ਨਹੀਂ ਹੋ ਸਕਦੇ, ਜੇ ਮੈਂ ਬਿਆਨ ਕਰਨ ਦਾ ਜਤਨ ਕਰਾਂ, ਤਾਂ ਭੀ ਤੇਰੇ ਗੁਣਾਂ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Твои качества невозможно выразить словами, и их ценность не может быть постигнута."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18839,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਦੁਖ ਤੇਰੇ ਸੂਖ ਰਜਾਈ ॥",
          "roman": "sabh dukh terē sūkh rajāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੈਥੋਂ ਵਿਛੁੜਿਆਂ ਦੁੱਖ ਵਾਪਰਦੇ ਹਨ, ਪਰ) ਤੇਰੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਿਆਂ ਸਾਰੇ ਦੁੱਖ ਸੁਖ ਬਣ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все страдания превращаются в радость, если жить по Твоей воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18840,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਦੁਖ ਮੇਟੇ ਸਾਚੈ ਨਾਈ ॥੬॥",
          "roman": "sabh dukh meṭe sāchē nāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕੀਤਿਆਂ ਸਾਰੇ ਹੀ ਦੁੱਖ ਮਿਟ ਜਾਂਦੇ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Все страдания исчезают при восхвалении Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18841,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਬਿਨੁ ਵਾਜਾ ਪਗ ਬਿਨੁ ਤਾਲਾ ॥",
          "roman": "kar bin vājā pag bin tālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਅਜੇਹੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ ਕਿ, ਮਾਨੋ, ਬਿਨਾ ਹੱਥੀਂ ਵਜਾਏ ਵਾਜਾ ਵੱਜਦਾ ਹੈ ਤੇ ਬਿਨਾ ਪੈਰੀਂ ਨੱਚਿਆਂ ਤਾਲ ਪੂਰੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри возникает состояние, будто инструмент играет без рук и танец идёт без ног,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18842,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਬਦੁ ਬੁਝੈ ਤਾ ਸਚੁ ਨਿਹਾਲਾ ॥",
          "roman": "je shabad bujhē tā sach nihālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਹ (ਗੁਰੂ ਦੇ) ਸ਼ਬਦ ਨੂੰ ਸਮਝ ਕੇ ਉਹ ਆਪਣੇ ਅੰਦਰ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਦੀਦਾਰ ਵੀ ਕਰ ਲਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "когда человек понимает Слово Гуру и созерцает Истинного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18843,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਸਾਚੁ ਸਭੇ ਸੁਖ ਨਾਲਾ ॥",
          "roman": "antar sāch sabhe sukh nālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਫਿਰ ਆਪਣੇ ਅੰਤਰ ਆਤਮੇ ਸੁਖ ਹੀ ਸੁਖ ਪ੍ਰਤੀਤ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда внутри он ощущает лишь счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18844,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਰਾਖੈ ਰਖਵਾਲਾ ॥੭॥",
          "roman": "nadar karē rākhe rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਪਰਗਟ ਹੋ ਜਾਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Господь проявляется внутри него и защищает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18845,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਭਵਣ ਸੂਝੈ ਆਪੁ ਗਵਾਵੈ ॥",
          "roman": "tribhavan sūjhē āp gavāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪ੍ਰਭੂ ਦਾ ਦਾਸ ਬਣ ਕੇ) ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰਦਾ ਹੈ, ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਤਿੰਨਾਂ ਭਵਨਾਂ ਵਿਚ ਵੱਸਦਾ ਦਿੱਸ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто уничтожает своё эго, видит Бога во всех трёх мирах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18846,
          "is_rahao": false,
          "gurmukhi": "ਬਾਣੀ ਬੂਝੈ ਸਚਿ ਸਮਾਵੈ ॥",
          "roman": "bāṇī būjhē sach samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਗੁਰੂ ਦੀ ਬਾਣੀ ਦੀ ਰਾਹੀਂ ਸਹੀ ਗਿਆਨ ਹੋ ਜਾਂਦਾ ਹੈ ਤੇ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он понимает Бани и сливается с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18847,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਵੀਚਾਰੇ ਏਕ ਲਿਵ ਤਾਰਾ ॥",
          "roman": "shabad vīchāre ek liv tārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਆਪਣੇ ਸੋਚ-ਮੰਡਲ ਵਿਚ ਟਿਕਾਈ ਰੱਖਦਾ ਹੈ, ਇਕ-ਰਸ ਸੁਰਤਿ ਪ੍ਰਭੂ ਵਿਚ ਜੋੜਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он размышляет о Слове Гуру и соединяет своё сознание с Единственным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18848,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਧੰਨੁ ਸਵਾਰਣਹਾਰਾ ॥੮॥੨॥",
          "roman": "nānak dhan savāraṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਦਾ ਮਨੁੱਖਾ ਜਨਮ ਮੁਬਾਰਿਕ ਹੈ ਉਹ ਹੋਰਨਾਂ ਦਾ ਜੀਵਨ ਭੀ ਸੋਹਣਾ ਬਣਾ ਦੇਂਦਾ ਹੈ ॥੮॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, благословен тот, кто украшает и свою, и чужую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1601,
      "rahao_verse_id": 18855,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18849,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Нанака Дев Джи в раге Аса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18850,
          "is_rahao": false,
          "gurmukhi": "ਲੇਖ ਅਸੰਖ ਲਿਖਿ ਲਿਖਿ ਮਾਨੁ ॥",
          "roman": "lekh asaṅkh likh likh mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੇ ਸਰੂਪ ਬਾਰੇ) ਅਣਗਿਣਤ (ਵਿਚਾਰ-ਭਰੇ) ਲੇਖ ਲਿਖ ਲਿਖ ਕੇ (ਲਿਖਣ ਵਾਲਿਆਂ ਦੇ ਮਨ ਵਿਚ ਆਪਣੀ ਵਿਦਿਆ ਤੇ ਵਿਚਾਰ-ਸ਼ਕਤੀ ਦਾ) ਮਾਣ ਹੀ (ਪੈਦਾ ਹੁੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Пишутся бесчисленные трактаты, но это лишь рождает гордость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18851,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਮਾਨਿਐ ਸਚੁ ਸੁਰਤਿ ਵਖਾਨੁ ॥",
          "roman": "man māniē sach surat vakhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇਸ਼ੱਕ ਅਣਗਿਣਤ ਲੇਖ ਲਿਖੇ ਜਾਣ, ਪਰਮਾਤਮਾ ਦਾ ਸਰੂਪ ਬਿਆਨ ਤੋਂ, ਲੇਖ ਤੋਂ ਪਰੇ ਹੈ, ਉਸ ਦੇ ਗੁਣਾਂ ਦਾ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Однако сущность Бога не может быть описана словами или текстами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18852,
          "is_rahao": false,
          "gurmukhi": "ਕਥਨੀ ਬਦਨੀ ਪੜਿ ਪੜਿ ਭਾਰੁ ॥",
          "roman": "kathanī badanī paṛ paṛ bhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਗੁਣ ਕਹਣ ਨਾਲ ਬੋਲਣ ਨਾਲ ਤੇ ਮੁੜ ਮੁੜ ਪੜ੍ਹ ਕੇ ਭੀ (ਮਨ ਉਤੇ ਹਉਮੈ ਦਾ) ਭਾਰ (ਹੀ ਵਧਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Говоря и читая, человек лишь увеличивает бремя эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18853,
          "is_rahao": false,
          "gurmukhi": "ਲੇਖ ਅਸੰਖ ਅਲੇਖੁ ਅਪਾਰੁ ॥੧॥",
          "roman": "lekh asaṅkh alekh apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਹਾਂ) ਜੇ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦੀ ਯਾਦ ਵਿਚ ਗਿੱਝ ਜਾਏ, ਜੇ (ਮਨੁੱਖ ਦੀ) ਸੁਰਤਿ ਵਿਚ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਟਿਕ ਜਾਏ) ਤਾਂ ਬੱਸ! ਇਹੀ ਹੈ ਅਸਲ ਲੇਖ (ਜੋ ਉਸ ਨੂੰ ਪਰਵਾਨ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но если ум погружается в память о Боге, это и есть истинное знание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18854,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਸਾਚਾ ਤੂੰ ਏਕੋ ਜਾਣੁ ॥",
          "roman": "aisā sāchā tū eko jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੋ ਜਿਹਾ (ਅਲੇਖ) ਤੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਤੂੰ ਸਿਰਫ਼ ਇਕ ਪ੍ਰਭੂ ਨੂੰ ਹੀ ਜਾਣ (ਬਾਕੀ ਸਾਰਾ ਜਗਤ ਜੰਮਣ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਹੈ, ਤੇ ਇਹ),"
            },
            "sahib_singh_ru": {
              "main": "Знай только Единого Истинного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18855,
          "is_rahao": true,
          "gurmukhi": "ਜੰਮਣੁ ਮਰਣਾ ਹੁਕਮੁ ਪਛਾਣੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jamṇā marṇā hukam pachhāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੰਮਣਾ ਮਰਨਾ ਭੀ ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਹੁਕਮ ਹੀ ਸਮਝ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и пойми, что рождение и смерть происходят по Его воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18856,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿ ਜਗੁ ਬਾਧਾ ਜਮਕਾਲਿ ॥",
          "roman": "māiā moh jag bādhā jamkāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨੂੰ ਵਿਸਾਰ ਕੇ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ ਜਗਤ ਮੌਤ ਦੇ ਸਹਮ ਵਿਚ ਬੱਝਾ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мир связан страхом смерти из-за привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18857,
          "is_rahao": false,
          "gurmukhi": "ਬਾਂਧਾ ਛੂਟੈ ਨਾਮੁ ਸਮੑਾਲਿ ॥",
          "roman": "bāndhā chhūṭē nām samhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨੂੰ ਹੀ ਸੰਭਾਲ ਕੇ ਬੱਝਾ ਛੁਟ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Освобождение приходит через сохранение Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18858,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਸੁਖਦਾਤਾ ਅਵਰੁ ਨ ਭਾਲਿ ॥",
          "roman": "gur sukhdātā avar na bhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਹੀ (ਨਾਮ ਦੀ ਦਾਤ ਦੇ ਕੇ) ਆਤਮਕ ਸੁਖ ਦੇਣ ਵਾਲਾ ਹੈ, (ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਇਹ ਦਾਤ ਦੇਣ ਵਾਲਾ) ਕੋਈ ਹੋਰ ਨਹੀਂ ਲੱਭਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — дарующий духовное счастье, и другого такого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18859,
          "is_rahao": false,
          "gurmukhi": "ਹਲਤਿ ਪਲਤਿ ਨਿਬਹੀ ਤੁਧੁ ਨਾਲਿ ॥੨॥",
          "roman": "halat palat nibhahī tudh nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਾਮ ਹੀ ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਤੇਰੇ ਨਾਲ ਨਿਭ ਸਕਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Имя сопровождает тебя в этом мире и в следующем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18860,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਮਰੈ ਤਾਂ ਏਕ ਲਿਵ ਲਾਏ ॥",
          "roman": "shabad marē tā ek liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਤਦੋਂ ਹੀ ਇਕ ਪਰਮਾਤਮਾ ਵਿਚ ਸੁਰਤਿ ਜੋੜ ਸਕਦਾ ਹੈ ਜਦੋਂ ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਮੋਹ ਵਲੋਂ) ਮਰ ਜਾਏ (ਮੋਹ ਦਾ ਪ੍ਰਭਾਵ ਆਪਣੇ ਉਤੇ ਪੈਣ ਨ ਦੇਵੇ)।"
            },
            "sahib_singh_ru": {
              "main": "Через Слово Гуру человек умирает для привязанности и соединяется с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18861,
          "is_rahao": false,
          "gurmukhi": "ਅਚਰੁ ਚਰੈ ਤਾਂ ਭਰਮੁ ਚੁਕਾਏ ॥",
          "roman": "achar charē tā bharam chukāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਜੀਵ ਮਾਇਆ ਵਲ ਮਨ ਦੀ ਭਟਕਣਾ ਦੂਰ ਕਰ ਸਕਦਾ ਹੈ, ਜੇ (ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਦੇ) ਨਾਹ ਮੁਕਾਏ ਜਾ ਸਕਣ ਵਾਲੇ ਟੋਲੇ (ਦੇ ਪ੍ਰਭਾਵ ਨੂੰ) ਮੁਕਾ ਦੇਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "Так он избавляется от заблуждений ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18862,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਮੁਕਤੁ ਮਨਿ ਨਾਮੁ ਵਸਾਏ ॥",
          "roman": "jīvan mukat man nām vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵਸਾ ਲੈਂਦਾ ਹੈ ਉਹ ਇਸੇ ਜ਼ਿੰਦਗੀ ਦੇ ਵਿਚ ਹੀ (ਇਹਨਾਂ ਪੰਜਾਂ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ) ਆਜ਼ਾਦ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто помещает Имя в своё сердце, становится освобождённым ещё при жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18863,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਇ ਤ ਸਚਿ ਸਮਾਏ ॥੩॥",
          "roman": "gurmukh hoi tā sach samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦੇ ਨਾਮ) ਵਿਚ ਲੀਨ ਹੁੰਦਾ ਹੈ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਕੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Став гурмукхом, он сливается с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18864,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਧਰ ਸਾਜੀ ਗਗਨੁ ਅਕਾਸੁ ॥",
          "roman": "jin dhar sājī gagan akāś",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ) ਜਿਸ ਨੇ ਇਹ ਧਰਤੀ ਤੇ ਅਕਾਸ਼ ਆਦਿਕ ਰਚੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто создал землю и небо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18865,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਸਭ ਥਾਪੀ ਥਾਪਿ ਉਥਾਪਿ ॥",
          "roman": "jin sabh thāpī thāp uthāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਰਚੀ ਹੈ ਤੇ ਜੋ ਰਚ ਕੇ ਨਾਸ ਕਰਨ ਦੇ ਭੀ ਸਮਰੱਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "создал весь мир и может его разрушить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18866,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਆਪੇ ਆਪਿ ॥",
          "roman": "sarab nirantar āpe āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ ਉਹ ਆਪ ਹੀ ਆਪ ਸਭ ਦੇ ਅੰਦਰ ਇਕ-ਰਸ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "пребывает во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18867,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੈ ਨ ਪੂਛੇ ਬਖਸੇ ਆਪਿ ॥੪॥",
          "roman": "kisē na pūchhe bakhse āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ (ਸਭ ਜੀਵਾਂ ਉਤੇ) ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ (ਇਹ ਬਖ਼ਸ਼ਸ਼ ਵਾਸਤੇ) ਤੇ ਇਸ ਲਈ ਉਹ ਕਿਸੇ ਹੋਰ ਦੀ ਸਲਾਹ ਨਹੀਂ ਲੈਂਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Он сам дарует милость и ни у кого не спрашивает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18868,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਪੁਰੁ ਸਾਗਰੁ ਮਾਣਕ ਹੀਰੁ ॥",
          "roman": "tū pur sāgar māṇak hīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਆਪ ਹੀ ਭਰਿਆ ਹੋਇਆ ਇਹ (ਸੰਸਾਰ-) ਸਮੁੰਦਰ ਹੈਂ, ਤੂੰ ਆਪ ਹੀ ਇਸ ਵਿਚ ਮਾਣਕ-ਹੀਰਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты сам — океан и драгоценный камень в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18869,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਨਿਰਮਲੁ ਸਚੁ ਗੁਣੀ ਗਹੀਰੁ ॥",
          "roman": "tū nirmal sach guṇī gahīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਪਵਿਤ੍ਰ-ਸਰੂਪ ਹੈਂ, ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਹੈਂ, ਤੇ ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты чист, вечен и исполнен достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
