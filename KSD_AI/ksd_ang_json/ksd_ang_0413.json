{
  "ang": 413,
  "shabads": [
    {
      "shabad_id": 1601,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18870,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਮਾਨੈ ਭੇਟੈ ਗੁਰ ਪੀਰੁ ॥",
          "roman": "sukh mānē bheṭe gur pīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਤੇਰੀ ਮੇਹਰ ਨਾਲ) ਗੁਰੂ-ਪੀਰ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਹ (ਤੇਰੇ ਮਿਲਾਪ ਦਾ ਆਤਮਕ) ਆਨੰਦ ਮਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто встречает Гуру, испытывает духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18871,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਸਾਹਿਬੁ ਏਕੁ ਵਜੀਰੁ ॥੫॥",
          "roman": "eko sāhib ek vajīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪ ਹੀ ਆਪ ਬਾਦਸ਼ਾਹ ਹੈਂ ਤੇ ਆਪ ਹੀ ਆਪਣਾ (ਸਲਾਹਕਾਰ) ਵਜ਼ੀਰ ਹੈਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — и Царь, и Советник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18872,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਬੰਦੀ ਮੁਕਤੇ ਹਉ ਮਾਰੀ ॥",
          "roman": "jag bandī mukte haumārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਦੀ ਕੈਦ ਵਿਚੋਂ ਆਜ਼ਾਦ ਉਹੀ ਹਨ (ਜਿਨ੍ਹਾਂ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਇਸ) ਹਉਮੈ ਨੂੰ ਮਾਰਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Освобождаются только те, кто уничтожил эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18873,
          "is_rahao": false,
          "gurmukhi": "ਜਗਿ ਗਿਆਨੀ ਵਿਰਲਾ ਆਚਾਰੀ ॥",
          "roman": "jag giānī virlā ācārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਵਿਚ ਗਿਆਨਵਾਨ ਕੋਈ ਵਿਰਲਾ ਉਹੀ ਹੈ, ਜਿਸ ਦਾ ਨਿੱਤ-ਆਚਰਨ ਉਸ ਗਿਆਨ ਦੇ ਅਨੁਸਾਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Редко встретишь истинно знающего и живущего по знанию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18874,
          "is_rahao": false,
          "gurmukhi": "ਜਗਿ ਪੰਡਿਤੁ ਵਿਰਲਾ ਵੀਚਾਰੀ ॥",
          "roman": "jag paṇḍit virlā vīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਵਿਚ ਪੰਡਿਤ ਭੀ ਕੋਈ ਵਿਰਲਾ ਹੀ ਹੈ ਜੇਹੜਾ (ਵਿੱਦਿਆ ਦੇ ਅਨੁਸਾਰ ਹੀ) ਵਿਚਾਰਵਾਨ ਭੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Редко встретишь пандита, который действительно размышляет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18875,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਤਿਗੁਰੁ ਭੇਟੇ ਸਭ ਫਿਰੈ ਅਹੰਕਾਰੀ ॥੬॥",
          "roman": "bin satgur bheṭe sabh phirē ahankārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲਣ ਤੋਂ ਬਿਨਾ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਅਹੰਕਾਰ ਵਿਚ ਭਟਕਦੀ ਫਿਰਦੀ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Без встречи с Гуру все блуждают в эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18876,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਦੁਖੀਆ ਸੁਖੀਆ ਜਨੁ ਕੋਇ ॥",
          "roman": "jag dukhīā sukhīā jan koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਦੁਖੀ ਹੋ ਰਿਹਾ ਹੈ, ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਸੁਖੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир страдает, и лишь немногие счастливы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18877,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਰੋਗੀ ਭੋਗੀ ਗੁਣ ਰੋਇ ॥",
          "roman": "jag rogī bhogī guṇ roi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ (ਵਿਕਾਰਾਂ ਦੇ ਕਾਰਨ ਆਤਮਕ ਤੌਰ ਤੇ) ਰੋਗੀ ਹੋ ਰਿਹਾ ਹੈ, ਭੋਗਾਂ ਵਿਚ ਪਰਵਿਰਤ ਹੈ ਤੇ ਆਤਮਕ ਗੁਣਾਂ ਲਈ ਤਰਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир болен, погружён в удовольствия и тоскует по духовным качествам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18878,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਉਪਜੈ ਬਿਨਸੈ ਪਤਿ ਖੋਇ ॥",
          "roman": "jag upjē binsē pat khoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨੂੰ ਭੁਲਾ ਕੇ) ਜਗਤ ਇੱਜ਼ਤ ਗਵਾ ਕੇ ਜੰਮਦਾ ਹੈ ਮਰਦਾ ਹੈ, ਮਰਦਾ ਹੈ ਜੰਮਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир рождается и умирает, теряя честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18879,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਵੈ ਬੂਝੈ ਸੋਇ ॥੭॥",
          "roman": "gurmukh hovē būjhē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਂਦਾ ਹੈ, ਉਹ ਇਸ ਭੇਦ ਨੂੰ ਸਮਝਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Только гурмукх понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18880,
          "is_rahao": false,
          "gurmukhi": "ਮਹਘੋ ਮੋਲਿ ਭਾਰਿ ਅਫਾਰੁ ॥",
          "roman": "mahgho mol bhār afār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮੁੱਲ ਦੇ ਕੇ ਪਰਮਾਤਮਾ ਨੂੰ ਪ੍ਰਾਪਤ ਕਰਨਾ ਹੋਵੇ ਤਾਂ ਉਹ ਮੁੱਲ ਬਹੁਤ ਹੀ ਵਧੀਕ ਹੈ (ਉਸ ਦਾ ਮੁਲ ਦਿੱਤਾ ਨਹੀਂ ਜਾ ਸਕਦਾ) ਜੇ ਉਸ ਦੇ ਬਰਾਬਰ ਦੀ ਕੋਈ ਚੀਜ਼ ਦੇ ਕੇ ਉਸ ਨੂੰ ਪ੍ਰਾਪਤ ਕਰਨਾ ਹੋਵੇ ਤਾਂ ਕੋਈ ਚੀਜ਼ ਉਸ ਦੇ ਬਰਾਬਰ ਦੀ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Цена обретения Бога бесконечно велика и непостижима."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18881,
          "is_rahao": false,
          "gurmukhi": "ਅਟਲ ਅਛਲੁ ਗੁਰਮਤੀ ਧਾਰੁ ॥",
          "roman": "aṭal achhal gurmatī dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮਤਿ ਲੈ ਕੇ ਉਸ ਨੂੰ (ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਸਾਂਭ ਕੇ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "Удерживай учение Гуру в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18882,
          "is_rahao": false,
          "gurmukhi": "ਭਾਇ ਮਿਲੈ ਭਾਵੈ ਭਇਕਾਰੁ ॥",
          "roman": "bhāe milē bhāvē bhēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਪ੍ਰੇਮ ਦੀ ਰਾਹੀਂ (ਪ੍ਰੇਮ ਦੇ ਮੁੱਲ) ਮਿਲਦਾ ਹੈ ਤੇ ਜੀਵ ਦਾ ਉਸ ਦੇ ਡਰ-ਅਦਬ ਵਿਚ ਰਹਿਣਾ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог достигается через любовь и благоговение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18883,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਨੀਚੁ ਕਹੈ ਬੀਚਾਰੁ ॥੮॥੩॥",
          "roman": "nānak nīch kahē bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਇਹ ਵਿਚਾਰ ਦਸਦਾ ਹੈ ॥੮॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Смиренный Нанак выражает это размышление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1602,
      "rahao_verse_id": 18890,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18884,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В раге Аса — бани Гуру Нанак Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18885,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਮਰੈ ਪੰਚੇ ਮਿਲਿ ਰੋਵਹਿ ॥",
          "roman": "ek marē panche mil rovah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ (ਪ੍ਰਾਣੀ) ਮਰਦਾ ਹੈ ਉਸ ਦੇ ਸਾਕ ਸੰਬੰਧੀ ਮਿਲ ਕੇ ਰੋਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Один человек умирает, и его родственники собираются вместе и плачут,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18886,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਜਾਇ ਸਬਦਿ ਮਲੁ ਧੋਵਹਿ ॥",
          "roman": "haumē jāe sabad mal dhovah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ ਮੋਹ ਦੀ ਮੈਲ ਨੂੰ ਆਪਣੇ ਮਨ ਤੋਂ ਧੋ ਲੈਂਦੇ ਹਨ, ਉਹਨਾਂ ਦੀ ਹਉਮੈ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но те, кто соединяются со Шабдом Гуру и смывают из своего ума грязь привязанности, их эго исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18887,
          "is_rahao": false,
          "gurmukhi": "ਸਮਝਿ ਸੂਝਿ ਸਹਜ ਘਰਿ ਹੋਵਹਿ ॥",
          "roman": "samajh sūjh sahaj ghar hovah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਇਹ ਸਮਝ ਵਿਚ ਕੇ (ਕਿ ਸਭ ਵਿਚ ਪ੍ਰਭੂ ਦੀ ਹੀ ਜੋਤਿ ਹੈ, ਕਿਸੇ ਸੰਬੰਧੀ ਦਾ ਸਰੀਰ ਨਾਸ ਹੋਣ ਤੇ) ਅਡੋਲ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они, поняв это, пребывают в устойчивом духовном состоянии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18888,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਸਗਲੀ ਪਤਿ ਖੋਵਹਿ ॥੧॥",
          "roman": "bin būjhe saglī pat khovah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਬੇਸਮਝੀ ਵਿਚ (ਕਿ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਆਪਣਾ ਹੈ ਹੀ ਨਹੀਂ) (ਰੋਣ ਵਾਲੇ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਨਜ਼ਰ ਵਿਚ ਆਪਣੀ) ਸਾਰੀ ਇੱਜ਼ਤ ਗਵਾ ਲੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "в этом непонимании люди теряют всю свою честь перед Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18889,
          "is_rahao": true,
          "gurmukhi": "ਕਉਣੁ ਮਰੈ ਕਉਣੁ ਰੋਵੈ ਓਹੀ ॥",
          "roman": "kaun marē kaun rovē ohī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੌਣ ਮਰਦਾ ਹੈ, ਤੇ ਕੌਣ (ਮਰੇ ਨੂੰ) 'ਉਹ, ਉਹ' ਆਖ ਕੇ ਰੋਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто умирает и кто плачет, говоря тот, тот,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18890,
          "is_rahao": true,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਸਭਸੈ ਸਿਰਿ ਤੋਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karan kāran sabhsē sir tohī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦਾ ਸਰੀਰ ਬਿਨਸਦਾ ਹੈ ਉਹ ਭੀ ਤੂੰ ਆਪ ਹੀ ਹੈਂ ਤੇ ਰੋਣ ਵਾਲਾ ਭੀ ਤੂੰ ਆਪ ਹੀ ਹੈਂ) ਹੇ ਪ੍ਰਭੂ! ਹੇ ਸਾਰੇ ਜਗਤ ਦੇ ਕਰਤਾਰ! ਹਰੇਕ ਜੀਵ ਦੇ ਸਿਰ ਉਤੇ ਤੂੰ ਆਪ ਹੀ ਹੈਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "о Бог, Творец всего, над каждым существом Ты Сам стоишь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18891,
          "is_rahao": false,
          "gurmukhi": "ਮੂਏ ਕਉ ਰੋਵੈ ਦੁਖੁ ਕੋਇ ॥",
          "roman": "mūe kau rovē dukh koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੋਈ ਮੋਏ ਨੂੰ ਰੋਂਦਾ ਹੈ ਉਹ (ਅਸਲ ਵਿਚ ਆਪਣਾ) ਦੁੱਖ-ਔਖ ਫਰੋਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто плачет по умершему, на самом деле выражает своё собственное страдание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18892,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਰੋਵੈ ਜਿਸੁ ਬੇਦਨ ਹੋਇ ॥",
          "roman": "so rovē jis bedan hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹੀ ਰੋਂਦਾ ਹੈ ਜਿਸ ਨੂੰ (ਕਿਸੇ ਦੇ ਮਰਨ ਤੇ ਕੋਈ) ਬਿਪਤਾ ਆ ਵਾਪਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "плачет лишь тот, кого коснулось бедствие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18893,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਬੀਤੀ ਜਾਣੈ ਪ੍ਰਭ ਸੋਇ ॥",
          "roman": "jis bītī jāṇē prabh soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਿਸ ਜੀਵ ਉਤੇ (ਮੌਤ ਦੀ) ਇਹ ਘਟਨਾ ਵਰਤਦੀ ਹੈ, ਉਹ ਪ੍ਰਭੂ ਦੀ ਇਹ ਰਜ਼ਾ ਸਮਝ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но тот, с кем это происходит, понимает волю Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18894,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਤਾ ਕਰੇ ਸੁ ਹੋਇ ॥੨॥",
          "roman": "āpe kartā kare so hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਹੀ ਕੁਝ ਹੋ ਰਿਹਾ ਹੈ ਜੋ ਕਰਤਾਰ ਆਪ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "что происходит только то, что Сам Творец совершает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18895,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਮਰਣਾ ਤਾਰੇ ਤਰਣਾ ॥",
          "roman": "jīvat marṇā tāre tarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ ਵਿਚ ਜੀਊਣ ਦੀ ਤਾਂਘ ਮਨੁੱਖ ਨੂੰ ਸੰਸਾਰ ਦੇ ਮੋਹ ਵਿਚ ਫਸਾਂਦੀ ਹੈ) ਜੀਊਣ ਦੀ ਲਾਲਸਾ ਤੋਂ ਮਨ ਦਾ ਮਰ ਜਾਣਾ (ਮੋਹ-ਸਾਗਰ ਤੋਂ) ਤਰਨ ਲਈ, ਮਾਨੋ, ਬੇੜੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Угасание стремления жить становится лодкой для переправы через океан привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18896,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜਗਦੀਸ ਪਰਮ ਗਤਿ ਸਰਣਾ ॥",
          "roman": "jē jagdīs param gat sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਜਗਤ ਦੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਿਆਂ ਲੱਭਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "эта высшая духовная ступень достигается через прибежище у Господа мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18897,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬਲਿਹਾਰੀ ਸਤਿਗੁਰ ਚਰਣਾ ॥",
          "roman": "hau balihārī satgur charṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ) ਮੈਂ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਤੋਂ ਸਦਕੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "я жертвую собой у стоп Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18898,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਬੋਹਿਥੁ ਸਬਦਿ ਭੈ ਤਰਣਾ ॥੩॥",
          "roman": "gur bohith sabad bhē tarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਮਾਨੋ, ਜਹਾਜ਼ ਹੈ, ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ ਭਵ-ਸਾਗਰ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру — это корабль, через соединение с Шабдом можно переправиться через океан существования."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18899,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਆਪਿ ਨਿਰੰਤਰਿ ਜੋਤਿ ॥",
          "roman": "nirbhau āp nirantar jot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੂੰ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ, ਉਹ ਆਪ ਇਕ-ਰਸ ਹਰੇਕ ਦੇ ਅੰਦਰ ਆਪਣੀ ਜੋਤਿ ਦਾ ਪਰਕਾਸ਼ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог бесстрашен, Он непрерывно проявляет Свою светящуюся сущность внутри всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18900,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਸੂਤਕੁ ਜਗਿ ਛੋਤਿ ॥",
          "roman": "bin nāvē sūtak jag chhot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦੇ ਨਾਮ ਤੋਂ ਖੁੰਝਣ ਦੇ ਕਾਰਨ ਜਗਤ ਵਿਚ ਕਿਤੇ ਸੂਤਕ (ਦਾ ਭਰਮ) ਹੈ ਕਿਤੇ ਛੂਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но из-за отдаления от Его Имени в мире существуют суеверия о нечистоте и прикосновении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18901,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਬਿਨਸੈ ਕਿਆ ਕਹਿ ਰੋਤਿ ॥",
          "roman": "durmat binsē kiā kah rot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਰਮਤਿ ਦੇ ਕਾਰਨ ਜਗਤ ਆਤਮਕ ਮੌਤੇ ਮਰ ਰਿਹਾ ਹੈ, (ਇਸ ਬਾਰੇ) ਕੀਹ ਆਖ ਕੇ ਕੋਈ ਰੋਵੇ?"
            },
            "sahib_singh_ru": {
              "main": "из-за дурного ума мир духовно умирает, о чём здесь плакать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18902,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਿ ਮੂਏ ਬਿਨੁ ਭਗਤਿ ਸਰੋਤਿ ॥੪॥",
          "roman": "janam mūe bin bhagat sarot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਤੋਂ ਬਿਨਾ, ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਨ ਤੋਂ ਬਿਨਾ, ਜੀਵ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪੈ ਰਹੇ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "без преданности Богу и без слушания Его хвалы существа попадают в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18903,
          "is_rahao": false,
          "gurmukhi": "ਮੂਏ ਕਉ ਸਚੁ ਰੋਵਹਿ ਮੀਤ ॥",
          "roman": "mūe kau sach rovah mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਾ-ਭਾਵ ਤੋਂ ਮਰੇ ਹੋਏ ਨੂੰ ਸਚ ਮੁਚ ਉਸ ਦੇ (ਪਹਿਲੇ) ਮਿੱਤਰ  ਰੋਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По-настоящему по умершему плачут его прежние друзья,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18904,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਗੁਣ ਰੋਵਹਿ ਨੀਤਾ ਨੀਤ ॥",
          "roman": "trē guṇ rovah nītā nīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣ (ਕਿ ਸਾਡਾ ਸਾਥ ਛੱਡ ਗਿਆ ਹੈ) ਵੀ ਨਿੱਤ ਰੋਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "и три качества майи тоже постоянно плачут,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18905,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਸੁਖੁ ਪਰਹਰਿ ਸਹਜਿ ਸੁਚੀਤ ॥",
          "roman": "dukh sukh parhar sahaj suchīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਉਹ ਦੁਖ ਸੁਖ (ਦਾ ਅਹਿਸਾਸ) ਤਿਆਗ ਕੇ ਅਡੋਲ ਅਵਸਥਾ ਵਿਚ ਸੁਚੇਤ ਹੋ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "потому что он, оставив чувство боли и радости, пребывает в устойчивом состоянии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18906,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਸਉਪਉ ਕ੍ਰਿਸਨ ਪਰੀਤਿ ॥੫॥",
          "roman": "tan man saupau krisan parīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਨੇ ਆਪਣਾ ਤਨ ਤੇ ਮਨ ਪਰਮਾਤਮਾ ਦੀ ਪ੍ਰੀਤ ਤੋਂ ਭੇਟਾ ਕਰ ਦਿੱਤਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и он посвятил своё тело и ум любви к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18907,
          "is_rahao": false,
          "gurmukhi": "ਭੀਤਰਿ ਏਕੁ ਅਨੇਕ ਅਸੰਖ ॥",
          "roman": "bhītar ek anek asaṅkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੇ ਅੰਦਰ ਇਕੋ ਪਰਮਾਤਮਾ ਵੱਸ ਰਿਹਾ ਹੈ, ਉਹ ਅਨੇਕਾਂ ਅਸੰਖਾਂ ਰੂਪਾਂ ਵਿਚ ਦਿਖਾਈ ਦੇ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри всех пребывает один Бог, проявляясь во множестве форм,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18908,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਧਰਮ ਬਹੁ ਸੰਖ ਅਸੰਖ ॥",
          "roman": "karam dharam bah saṅkh asaṅkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵਾਂ ਨੇ ਉਸ ਨੂੰ ਵਿਸਾਰ ਕੇ) ਹੋਰ ਹੋਰ ਬੇਅੰਤ ਧਰਮ ਕਰਮ ਰਚ ਲਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "но люди создали бесчисленные религии и обряды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18909,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਭੈ ਭਗਤੀ ਜਨਮੁ ਬਿਰੰਥ ॥",
          "roman": "bin bhē bhagat janam biranth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਡਰ-ਅਦਬ ਵਿਚ ਰਹਿਣ ਤੋਂ ਬਿਨਾ, ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਤੋਂ ਬਿਨਾ, ਜੀਵਾਂ ਦਾ ਮਨੁੱਖਾ ਜਨਮ ਵਿਅਰਥ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "без благоговения перед Богом и без преданности человеческая жизнь проходит напрасно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18910,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵਹਿ ਮਿਲਿ ਪਰਮਾਰੰਥ ॥੬॥",
          "roman": "har guṇ gāvah mil paramārath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਿਲ ਕੇ ਹਰੀ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ, ਉਹ ਮਨੁੱਖਾ ਜਨਮ ਦਾ ਮਨੋਰਥ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "те, кто вместе поют качества Бога, достигают цели человеческой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18911,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਮਰੈ ਮਾਰੇ ਭੀ ਆਪਿ ॥",
          "roman": "āp marē māre bhī āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦਾ ਰਚਨਹਾਰ ਕਰਤਾਰ ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਆਪ ਮੌਜੂਦ ਹੈ, ਸੋ ਜਦੋਂ ਕੋਈ ਜੀਵ ਮਰਦਾ ਹੈ ਤਾਂ) ਪਰਮਾਤਮਾ (ਉਸ ਵਿਚ ਬੈਠਾ ਆਪ ਹੀ, ਮਾਨੋ) ਮਰਦਾ ਹੈ, ਉਸ ਜੀਵ ਨੂੰ ਮਾਰਦਾ ਭੀ ਆਪ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам присутствует во всех существах, поэтому когда кто-то умирает, Он Сам как бы умирает и Сам же умерщвляет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18912,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਪਾਏ ਥਾਪਿ ਉਥਾਪਿ ॥",
          "roman": "āp upāe thāp uthāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਪੈਦਾ ਕਰਦਾ ਹੈ, ਪੈਦਾ ਕਰ ਕੇ ਆਪ ਹੀ ਨਾਸ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам создаёт и Сам уничтожает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18913,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਿਸਟਿ ਉਪਾਈ ਜੋਤੀ ਤੂ ਜਾਤਿ ॥",
          "roman": "srisṭ upāī jotī tū jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਤਿ-ਰੂਪ ਪ੍ਰਭੂ! ਤੂੰ ਆਪ ਹੀ ਸ੍ਰਿਸ਼ਟੀ ਪੈਦਾ ਕੀਤੀ ਹੈ, ਤੂੰ ਆਪ ਹੀ ਅਨੇਕਾਂ ਜਾਤੀਆਂ ਪੈਦਾ ਕਰ ਦਿੱਤੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "о Светлый Господь, Ты Сам создал мир и все виды существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18914,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਵੀਚਾਰਿ ਮਿਲਣੁ ਨਹੀ ਭ੍ਰਾਤਿ ॥੭॥",
          "roman": "sabad vīchār milaṇ nahī bhrāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਨੂੰ ਵਿਸਾਰ ਕੇ (ਮਨ ਵਿਚ ਟਿਕਾ ਕੇ) ਜੀਵ ਦਾ ਉਸ ਨਾਲ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ, ਜੀਵ ਨੂੰ (ਸੂਤਕ ਛੂਤ ਆਦਿਕ ਦੀ ਕੋਈ) ਭਟਕਣਾ ਨਹੀਂ ਰਹਿੰਦੀ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "через размышление над Шабдом происходит соединение с Ним, и исчезают все заблуждения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18915,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤਕੁ ਅਗਨਿ ਭਖੈ ਜਗੁ ਖਾਇ ॥",
          "roman": "sūtak agan bhakhē jag khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ ਜੰਮਦਾ ਮਰਦਾ ਹੈ), ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਤੋਂ ਵਿਛੁੜਿਆਂ ਨੂੰ ਸੂਤਕ ਦਾ ਭਰਮ ਖ਼ੁਆਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "заблуждение о нечистоте мучает тех, кто отдалён от Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18916,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤਕੁ ਜਲਿ ਥਲਿ ਸਭ ਹੀ ਥਾਇ ॥",
          "roman": "sūtak jal thal sabh hī thāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੂਤਕ ਦਾ ਭਰਮ ਕਿਥੇ ਕਿਥੇ ਕੀਤਾ ਜਾਵੇਗਾ?) ਸੂਤਕ ਅੱਗ, ਸਮੁੰਦਰ ਤੇ ਧਰਤੀ ਵਿਚ ਹੈ, ਹਰ ਥਾਂ ਹੈ, ਕਿਉਂਕ,"
            },
            "sahib_singh_ru": {
              "main": "это представление есть в огне, воде и на земле — повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18917,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੂਤਕਿ ਜਨਮਿ ਮਰੀਜੈ ॥",
          "roman": "nānak sūtak janam marījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸੂਤਕ (ਦੇ ਭਰਮ) ਵਿਚ ਪੈ ਕੇ (ਪਰਮਾਤਮਾ ਦੀ ਹੋਂਦ ਤੋਂ ਖੁੰਝ ਕੇ) ਜਗਤ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪੈ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, из-за этого заблуждения мир попадает в круг рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18918,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਰਿ ਰਸੁ ਪੀਜੈ ॥੮॥੪॥",
          "roman": "gur parsādī har ras pījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਹੀ ਰਸਤਾ ਇਹ ਹੈ ਕਿ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਗੁਰੂ ਦੀ ਮੇਹਰ ਪ੍ਰਾਪਤ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਅੰਮ੍ਰਿਤ-ਰਸ ਪੀਣਾ ਚਾਹੀਦਾ ਹੈ ॥੮॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру следует пить нектар Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1603,
      "rahao_verse_id": 18924,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18919,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "rāg āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В раге Аса — бани Гуру Нанак Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18920,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਵੀਚਾਰੈ ਸੁ ਪਰਖੇ ਹੀਰਾ ॥",
          "roman": "āp vīchārē su parkhe hīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ (ਆਪਣੇ ਜੀਵਨ ਨੂੰ) ਵਿਚਾਰਦਾ ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਸ੍ਰੇਸ਼ਟ ਨਾਮ ਦੀ ਕਦਰ ਪਛਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто размышляет о себе, распознаёт драгоценность Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18921,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਦ੍ਰਿਸਟਿ ਤਾਰੇ ਗੁਰ ਪੂਰਾ ॥",
          "roman": "ek driśṭ tāre gur pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪੂਰੇ ਗੁਰੂ ਇਕ (ਮੇਹਰ ਦੀ) ਨਿਗਾਹ ਨਾਲ (ਮੋਹ ਦੇ ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "совершенный Гуру одним взглядом переправляет через океан привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18922,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਮਾਨੈ ਮਨ ਤੇ ਮਨੁ ਧੀਰਾ ॥੧॥",
          "roman": "gur mānē man te man dhīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਐਸਾ ਮਨੁੱਖ ਸੱਚੇ ਦਿਲੋਂ ਗੁਰੂ ਉਤੇ ਸਰਧਾ ਲਿਆਉਂਦਾ ਹੈ, ਉਸ ਦਾ ਮਨ (ਮਾਇਆ-ਮੋਹ ਵਿਚ) ਡੋਲਦਾ ਨਹੀਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "такой человек искренне верит Гуру, и его ум становится устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18923,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਸਾਹੁ ਸਰਾਫੀ ਕਰੈ ॥",
          "roman": "ēsā sāh sarāfī karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਇਹੋ ਜਿਹਾ ਸ਼ਾਹ (ਸਰਾਫ਼) ਹੈ, ਤੇ ਇਹੋ ਜਿਹੀ ਸਰਾਫ਼ੀ ਕਰਦਾ ਹੈ (ਕਿ ਉਹ ਜੀਵਾਂ ਨੂੰ ਤੁਰਤ ਪਰਖ ਲੈਂਦਾ ਹੈ, ਤੇ),"
            },
            "sahib_singh_ru": {
              "main": "Гуру — как опытный ювелир, который сразу распознаёт,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18924,
          "is_rahao": true,
          "gurmukhi": "ਸਾਚੀ ਨਦਰਿ ਏਕ ਲਿਵ ਤਰੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sāchī nadar ek liv tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਕਦੇ ਉਕਾਈ ਨਾਹ ਖਾਣ ਵਾਲੀ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਜੀਵ ਇਕ ਪਰਮਾਤਮਾ ਵਿਚ ਸੁਰਤਿ ਜੋੜ ਕੇ (ਮੋਹ ਦੇ ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "его истинная милость позволяет человеку сосредоточиться на Едином и переправиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18925,
          "is_rahao": false,
          "gurmukhi": "ਪੂੰਜੀ ਨਾਮੁ ਨਿਰੰਜਨ ਸਾਰੁ ॥",
          "roman": "pūnjī nām nirañjan sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਜੇਹੜਾ ਮਨੁੱਖ ਨਿਰੰਜਨ ਪ੍ਰਭੂ ਦੇ ਸ੍ਰੇਸ਼ਟ ਨਾਮ ਨੂੰ (ਆਪਣੇ ਆਤਮਕ ਜੀਵਨ ਦੀ) ਰਾਸਿ-ਪੂੰਜੀ ਬਣਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто делает Имя Бога своей духовной ценностью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18926,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲੁ ਸਾਚਿ ਰਤਾ ਪੈਕਾਰੁ ॥",
          "roman": "nirmal sāch ratā pēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦੇ ਨਾਮ-ਰੰਗ) ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ ਉਹ ਪਵਿਤ੍ਰ (ਜੀਵਨ ਵਾਲਾ) ਹੋ ਜਾਂਦਾ ਹੈ, ਉਹ ਨਿਆਰੀਏ ਵਾਂਗ ਪਾਰਖੂ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "пребывая в любви к Истине, становится чистым и распознающим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18927,
          "is_rahao": false,
          "gurmukhi": "ਸਿਫਤਿ ਸਹਜ ਘਰਿ ਗੁਰੁ ਕਰਤਾਰੁ ॥੨॥",
          "roman": "sifat sahaj ghar gur kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਗੁਰੂ ਕਰਤਾਰ ਨੂੰ ਆਪਣੇ ਅਡੋਲ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਵਸਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "через восхваление он устанавливает Гуру-Творца в своём устойчивом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18928,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਨਸਾ ਸਬਦਿ ਜਲਾਏ ॥",
          "roman": "āsā mansā sabad jalāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਆਪਣੇ ਅੰਦਰੋਂ) ਮਾਇਕ ਆਸਾ ਤੇ ਮਾਇਕ ਫੁਰਨਾ ਸਾੜ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он сжигает мирские желания и мысли через Шабд,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
