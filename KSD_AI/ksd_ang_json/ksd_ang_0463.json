{
  "ang": 463,
  "shabads": [
    {
      "shabad_id": 1686,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20762,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੨ ॥",
          "roman": "mehlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20763,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਉ ਚੰਦਾ ਉਗਵਹਿ ਸੂਰਜ ਚੜਹਿ ਹਜਾਰ ॥",
          "roman": "je sau chandā ugveh sūraj chaṛeh hazār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਇਕ) ਸੌ ਚੰਦ੍ਰਮਾ ਚੜ੍ਹਨ ਅਤੇ ਹਜ਼ਾਰ ਸੂਰਜ ਚੜ੍ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы взошли сто лун и поднялись тысяча солнц,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20764,
          "is_rahao": false,
          "gurmukhi": "ਏਤੇ ਚਾਨਣ ਹੋਦਿਆਂ ਗੁਰ ਬਿਨੁ ਘੋਰ ਅੰਧਾਰ ॥੨॥",
          "roman": "ete chānaṇ hodiāṅ gur bin ghor andhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਇਤਨੇ ਭੀ ਚਾਨਣ ਹੋ ਜਾਣ (ਭਾਵ, ਚਾਨਣ ਕਰਨ ਵਾਲੇ ਜੇ ਇਤਨੇ ਭੀ ਚੰਦ੍ਰਮਾ ਸੂਰਜ ਆਦਿਕ ਗ੍ਰਹਿ ਅਕਾਸ਼ ਵਿਚ ਚੜ੍ਹ ਪੈਣ), ਗੁਰੂ ਤੋਂ ਬਿਨਾ (ਫੇਰ ਭੀ) ਘੁੱਪ ਹਨੇਰਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "даже при таком свете, без Гуру всё равно остаётся полная тьма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1687,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20765,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20766,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰੂ ਨ ਚੇਤਨੀ ਮਨਿ ਆਪਣੈ ਸੁਚੇਤ ॥",
          "roman": "nānak gurū na chetnī man āpṇē sucheṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੋ ਮਨੁੱਖ) ਗੁਰੂ ਨੂੰ ਚੇਤੇ ਨਹੀਂ ਕਰਦੇ ਆਪਣੇ ਆਪ ਵਿਚ ਚਤਰ (ਬਣੇ ਹੋਏ) ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Те, кто не помнят Гуру и считают себя разумными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20767,
          "is_rahao": false,
          "gurmukhi": "ਛੁਟੇ ਤਿਲ ਬੂਆੜ ਜਿਉ ਸੁੰਞੇ ਅੰਦਰਿ ਖੇਤ ॥",
          "roman": "chhuṭe til būāṛ jiū suñje andar khet",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਇਉਂ ਹਨ ਜਿਵੇਂ ਕਿਸੇ ਸੁੰਞੀ ਪੈਲੀ ਵਿਚ ਅੰਦਰੋਂ ਸੜੇ ਤਿਲ ਨਿਖਸਮੇ ਪਏ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "подобны гнилым семенам кунжута, брошенным в пустом поле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20768,
          "is_rahao": false,
          "gurmukhi": "ਖੇਤੈ ਅੰਦਰਿ ਛੁਟਿਆ ਕਹੁ ਨਾਨਕ ਸਉ ਨਾਹ ॥",
          "roman": "khetē andar chhuṭiā kah nānak sau nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਬੇਸ਼ਕ) ਆਖ ਕਿ ਪੈਲੀ ਵਿਚ ਨਿਖਸਮੇ ਪਏ ਹੋਏ ਉਹਨਾਂ ਬੂਆੜ ਤਿਲਾਂ ਦੇ ਸੌ ਖਸਮ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Скажи, о Нанак, пусть у этих брошенных семян в поле будет сто хозяев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20769,
          "is_rahao": false,
          "gurmukhi": "ਫਲੀਅਹਿ ਫੁਲੀਅਹਿ ਬਪੁੜੇ ਭੀ ਤਨ ਵਿਚਿ ਸੁਆਹ ॥੩॥",
          "roman": "phalīah phulīah bapuṛe bhī tan vich suāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਵਿਚਾਰੇ ਫੁੱਲਦੇ ਭੀ ਹਨ (ਭਾਵ, ਉਹਨਾਂ ਨੂੰ ਫੁੱਲ ਭੀ ਲੱਗਦੇ ਹਨ), ਫਲਦੇ ਭੀ ਹਨ, ਫੇਰ ਭੀ ਉਹਨਾਂ ਦੇ ਤਨ ਵਿਚ (ਭਾਵ, ਉਹਨਾਂ ਦੀ ਫਲੀ ਵਿਚ ਤਿਲਾਂ ਦੀ ਥਾਂ) ਸੁਆਹ ਹੀ ਹੁੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "они могут цвести и давать плоды, но внутри у них лишь пепел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1688,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20770,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20771,
          "is_rahao": false,
          "gurmukhi": "ਆਪੀਨੑੈ ਆਪੁ ਸਾਜਿਓ ਆਪੀਨੑੈ ਰਚਿਓ ਨਾਉ ॥",
          "roman": "āpīnhē āp sājio āpīnhē rachio nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਨੇ ਆਪ ਹੀ ਆਪਣੇ ਆਪ ਨੂੰ ਸਾਜਿਆ, ਅਤੇ ਆਪ ਹੀ ਆਪਣਾ ਨਾਮਣਾ ਬਣਾਇਆ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх сам создал себя и сам установил своё имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20772,
          "is_rahao": false,
          "gurmukhi": "ਦੁਯੀ ਕੁਦਰਤਿ ਸਾਜੀਐ ਕਰਿ ਆਸਣੁ ਡਿਠੋ ਚਾਉ ॥",
          "roman": "duī kudrat sājīai kar āsan diṭho chāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ, ਉਸ ਨੇ ਕੁਦਰਤ ਰਚੀ (ਅਤੇ ਉਸ ਵਿਚ) ਆਸਣ ਜਮਾ ਕੇ, (ਭਾਵ, ਕੁਦਰਤ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ, ਇਸ ਜਗਤ ਦਾ) ਆਪ ਤਮਾਸ਼ਾ ਵੇਖਣ ਲੱਗ ਪਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Затем он создал природу и, утвердившись в ней, стал наблюдать это творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20773,
          "is_rahao": false,
          "gurmukhi": "ਦਾਤਾ ਕਰਤਾ ਆਪਿ ਤੂੰ ਤੁਸਿ ਦੇਵਹਿ ਕਰਹਿ ਪਸਾਉ ॥",
          "roman": "dātā kartā āp tū tus devah kareh pasāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਆਪ ਹੀ (ਜੀਵਾਂ ਨੂੰ) ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈਂ ਅਤੇ ਆਪ ਹੀ (ਇਹਨਾਂ ਦੇ) ਸਾਜਣ ਵਾਲਾ ਹੈਂ। (ਤੂੰ ਆਪ ਹੀ ਤ੍ਰੁੱਠ ਕੇ (ਜੀਵਾਂ ਨੂੰ) ਦੇਂਦਾ ਹੈਂ ਅਤੇ ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты сам — дарующий и создатель; по своей милости ты даёшь и распространяешь благодать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20774,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਜਾਣੋਈ ਸਭਸੈ ਦੇ ਲੈਸਹਿ ਜਿੰਦੁ ਕਵਾਉ ॥",
          "roman": "tū jāṇoī sabhsē de lēsah jind kavāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭਨਾਂ ਜੀਆਂ ਦੀ ਜਾਣਨਹਾਰ ਹੈਂ। ਜਿੰਦ ਅਤੇ ਸਰੀਰ ਦੇ ਕੇ (ਤੂੰ ਆਪ ਹੀ) ਲੈ ਲਵੇਂਗਾ (ਭਾਵ, ਤੂੰ ਆਪ ਹੀ ਜਿੰਦ ਤੇ ਸਰੀਰ ਦੇਂਦਾ ਹੈਂ, ਆਪ ਹੀ ਮੁੜ ਲੈ ਲੈਂਦਾ ਹੈਂ)।"
            },
            "sahib_singh_ru": {
              "main": "Ты знаешь всех существ; дав жизнь и тело, ты сам их затем забираешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20775,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਆਸਣੁ ਡਿਠੋ ਚਾਉ ॥੧॥",
          "roman": "kar āsan diṭho chāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਕੁਦਰਤ ਵਿਚ) ਆਸਣ ਜਮਾ ਕੇ ਤਮਾਸ਼ਾ ਵੇਖ ਰਿਹਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты, утвердившись в природе, наблюдаешь это зрелище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1689,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20776,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20777,
          "is_rahao": false,
          "gurmukhi": "ਸਚੇ ਤੇਰੇ ਖੰਡ ਸਚੇ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "sachey tere khaṇḍ sachey brahmaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਚੇ ਪਾਤਸ਼ਾਹ! ਤੇਰੇ (ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਖੰਡ ਤੇ ਬ੍ਰਹਿਮੰਡ ਸੱਚੇ ਹਨ (ਭਾਵ, ਖੰਡ ਤੇ ਬ੍ਰਹਿਮੰਡ ਸਾਜਣ ਵਾਲਾ ਤੇਰਾ ਇਹ ਸਿਲਸਿਲਾ ਸਦਾ ਲਈ ਅਟੱਲ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О Истинный Владыка! Твои созданные миры и вселенные истинны (то есть порядок их создания Тобой вечен и неизменен)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20778,
          "is_rahao": false,
          "gurmukhi": "ਸਚੇ ਤੇਰੇ ਲੋਅ ਸਚੇ ਆਕਾਰ ॥",
          "roman": "sachey tere loe sachey ākār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ (ਸਿਰਜੇ ਹੋਏ ਚੌਂਦਾਂ) ਲੋਕ ਤੇ (ਇਹ ਬੇਅੰਤ) ਆਕਾਰ ਭੀ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Твои миры и бесчисленные формы также пребывают вечно;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20779,
          "is_rahao": false,
          "gurmukhi": "ਸਚੇ ਤੇਰੇ ਕਰਣੇ ਸਰਬ ਬੀਚਾਰ ॥",
          "roman": "sachey tere karṇe sarab bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਕੰਮ ਤੇ ਸਾਰੀਆਂ ਵਿਚਾਰਾਂ ਨਾਸ-ਰਹਿਤ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Твои деяния и все замыслы не подвержены разрушению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20780,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਤੇਰਾ ਅਮਰੁ ਸਚਾ ਦੀਬਾਣੁ ॥",
          "roman": "sachā terā amar sachā dībāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਤਸ਼ਾਹ! ਤੇਰੀ ਪਾਤਸ਼ਾਹੀ ਤੇ ਤੇਰਾ ਦਰਬਾਰ ਅਟੱਲ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Твоё владычество и Твой двор неизменны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20781,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਤੇਰਾ ਹੁਕਮੁ ਸਚਾ ਫੁਰਮਾਣੁ ॥",
          "roman": "sachā terā hukam sachā furmāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਹੁਕਮ ਤੇ ਤੇਰਾ (ਸ਼ਾਹੀ) ਫ਼ੁਰਮਾਨ ਭੀ ਅਟੱਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Твоё повеление и Твой указ также неизменны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20782,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਤੇਰਾ ਕਰਮੁ ਸਚਾ ਨੀਸਾਣੁ ॥",
          "roman": "sachā terā karam sachā nīsāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਬਖ਼ਸ਼ਸ਼ ਸਦਾ ਲਈ ਥਿਰ ਹੈ ਤੇ ਤੇਰੀਆਂ ਬਖ਼ਸ਼ਸ਼ਾਂ ਦਾ ਨਿਸ਼ਾਨ ਭੀ (ਭਾਵ, ਇਹ ਬੇਅੰਤ ਪਦਾਰਥ ਜੋ ਤੂੰ ਜੀਆਂ ਨੂੰ ਦੇ ਰਿਹਾ ਹੈਂ) ਸਦਾ ਵਾਸਤੇ ਕਾਇਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Твоя милость вечна, и знак Твоих даров (то есть все бесчисленные дары, которые Ты даёшь живым) пребывает всегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20783,
          "is_rahao": false,
          "gurmukhi": "ਸਚੇ ਤੁਧੁ ਆਖਹਿ ਲਖ ਕਰੋੜਿ ॥",
          "roman": "sachey tudh ākhah lakh karor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲੱਖਾਂ ਕਰੋੜਾਂ ਜੀਵ, ਜੋ ਤੈਨੂੰ ਸਿਮਰ ਰਹੇ ਹਨ, ਸੱਚੇ ਹਨ (ਭਾਵ, ਬੇਅੰਤ ਜੀਵਾਂ ਦਾ ਤੈਨੂੰ ਸਿਮਰਨਾ-ਇਹ ਭੀ ਤੇਰਾ ਇਕ ਅਜਿਹਾ ਚਲਾਇਆ ਹੋਇਆ ਕੰਮ ਹੈ ਜੋ ਸਦਾ ਲਈ ਥਿਰ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Сотни тысяч и миллионы существ, помнящих Тебя, истинны (то есть их поминание Тебя — это тоже установленный Тобой вечный порядок)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20784,
          "is_rahao": false,
          "gurmukhi": "ਸਚੈ ਸਭਿ ਤਾਣਿ ਸਚੈ ਸਭਿ ਜੋਰਿ ॥",
          "roman": "sachē sabh tāṇ sachē sabh jor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਖੰਡ, ਬ੍ਰਹਿਮੰਡ, ਲੋਕ, ਆਕਾਰ, ਜੀਅ ਜੰਤ ਆਦਿਕ) ਸਾਰੇ ਹੀ ਸੱਚੇ ਹਰੀ ਦੇ ਤਾਣ ਤੇ ਜ਼ੋਰ ਵਿਚ ਹਨ (ਭਾਵ, ਇਹਨਾਂ ਸਭਨਾਂ ਦੀ ਹਸਤੀ, ਸਭਨਾਂ ਦਾ ਆਸਰਾ ਪ੍ਰਭੂ ਆਪ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Все они пребывают в силе и могуществе Истинного (то есть их существование и опора — Сам Господь)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20785,
          "is_rahao": false,
          "gurmukhi": "ਸਚੀ ਤੇਰੀ ਸਿਫਤਿ ਸਚੀ ਸਾਲਾਹ ॥",
          "roman": "sachī terī sifat sachī sālāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਨੀ ਤੇਰਾ ਇਕ ਅਟੱਲ ਸਿਲਸਿਲਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Твоё прославление — это вечный порядок;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20786,
          "is_rahao": false,
          "gurmukhi": "ਸਚੀ ਤੇਰੀ ਕੁਦਰਤਿ ਸਚੇ ਪਾਤਿਸਾਹ ॥",
          "roman": "sachī terī kudrat sachey pātisāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਚੇ ਪਾਤਿਸ਼ਾਹ! ਇਹ ਸਾਰੀ ਰਚਨਾ ਹੀ ਤੇਰਾ ਇਕ ਨਾ ਮੁੱਕਣ ਵਾਲਾ ਪਰਬੰਧ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Истинный Владыка! Всё это творение — Твой непрекращающийся замысел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20787,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਚੁ ਧਿਆਇਨਿ ਸਚੁ ॥",
          "roman": "nānak sach dhiāin sach",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਜੀਵ ਉਸ ਅਬਿਨਾਸ਼ੀ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਭੀ ਉਸ ਦਾ ਰੂਪ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Те, кто размышляет об этом неразрушимом Господе, сами становятся Его образом;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20788,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਮਰਿ ਜੰਮੇ ਸੁ ਕਚੁ ਨਿਕਚੁ ॥੧॥",
          "roman": "jo mar jamme so kach nikach",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੋ ਜੰਮਣ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਏ ਹਨ, ਉਹ (ਅਜੇ) ਬਿਲਕੁਲ ਕੱਚੇ ਹਨ (ਭਾਵ, ਉਸ ਅਸਲ ਜੋਤ ਦਾ ਰੂਪ ਨਹੀਂ ਹੋਏ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а те, кто в круге рождения и смерти, остаются совершенно незрелыми (то есть ещё не стали образом той Истины)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1690,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20789,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20790,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾ ਵਡਾ ਨਾਉ ॥",
          "roman": "vaḍī vaḍiāī jā vaḍā nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ ਕੀਤੀ ਨਹੀਂ ਜਾ ਸਕਦੀ ਜਿਸ ਦਾ ਨਾਮਣਾ ਵੱਡਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Величие Того, Чьё Имя велико, невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20791,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾ ਸਚੁ ਨਿਆਉ ॥",
          "roman": "vaḍī vaḍiāī jā sach niāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਇਹ ਇਕ ਵੱਡਾ ਗੁਣ ਹੈ ਕਿ ਉਸ ਦਾ ਨਾਉਂ (ਸਦਾ) ਅਟੱਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Великая черта Господа — Его Имя вечно неизменно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20792,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾ ਨਿਹਚਲ ਥਾਉ ॥",
          "roman": "vaḍī vaḍiāī jā nihchal thāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਇਹ ਇਕ ਵੱਡੀ ਸਿਫ਼ਤ ਹੈ ਕਿ ਉਸ ਦਾ ਆਸਣ ਅਡੋਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его великая слава в том, что Его обитель неподвижна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20793,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾਣੈ ਆਲਾਉ ॥",
          "roman": "vaḍī vaḍiāī jāṇē ālāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਇਹ ਇਕ ਬੜੀ ਵਡਿਆਈ ਹੈ ਕਿ ਉਹ ਸਾਰੇ ਜੀਵਾਂ ਦੀਆਂ ਅਰਦਾਸਾਂ ਨੂੰ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его великая слава в том, что Он знает молитвы всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20794,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਬੁਝੈ ਸਭਿ ਭਾਉ ॥",
          "roman": "vaḍī vaḍiāī bujhē sabh bhāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਾਰਿਆਂ ਦੇ ਦਿਲਾਂ ਦੇ ਵਲਵਲਿਆਂ ਨੂੰ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и понимает чувства всех сердец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20795,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾ ਪੁਛਿ ਨ ਦਾਤਿ ॥",
          "roman": "vaḍī vaḍiāī jā puchh na dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਬ ਦੀ ਇਹ ਇਕ ਉੱਚੀ ਸਿਫ਼ਤ ਹੈ ਕਿ ਕਿਸੇ ਦੀ ਸਲਾਹ ਲੈ ਕੇ (ਜੀਵਾਂ ਨੂੰ) ਦਾਤਾਂ ਨਹੀਂ ਦੇ ਰਿਹਾ,"
            },
            "sahib_singh_ru": {
              "main": "Его великая слава в том, что Он не спрашивает совета, даруя дары,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20796,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਵਡਿਆਈ ਜਾ ਆਪੇ ਆਪਿ ॥",
          "roman": "vaḍī vaḍiāī jā āpe āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਆਪ ਬੇਅੰਤ ਦਾਤਾਂ ਬਖ਼ਸ਼ਦਾ ਹੈ) (ਕਿਉਂਕਿ) ਉਸ ਵਰਗਾ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам по Себе раздаёт бесчисленные дары, ибо нет никого равного Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20797,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਾਰ ਨ ਕਥਨੀ ਜਾਇ ॥",
          "roman": "nānak kār na kathnī jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਰੱਬ ਦੀ ਕੁਦਰਤਿ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Деяния Господа невозможно описать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20798,
          "is_rahao": false,
          "gurmukhi": "ਕੀਤਾ ਕਰਣਾ ਸਰਬ ਰਜਾਇ ॥੨॥",
          "roman": "kītā karṇā sarab rajāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀ ਰਚਨਾ ਉਸ ਆਪਣੇ ਹੁਕਮ ਵਿਚ ਰਚੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "всё творение создано по Его воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1691,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20799,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੨ ॥",
          "roman": "mahla 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20800,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਜਗੁ ਸਚੈ ਕੀ ਹੈ ਕੋਠੜੀ ਸਚੇ ਕਾ ਵਿਚਿ ਵਾਸੁ ॥",
          "roman": "ihu jag sachē kī hē koṭhṛī sachey kā vich vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਗਤ ਪ੍ਰਭੂ ਦੇ ਰਹਿਣ ਦੀ ਥਾਂ ਹੈ, ਪ੍ਰਭੂ ਇਸ ਵਿਚ ਵੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот мир — обитель Господа, и Сам Господь пребывает в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20801,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨੑਾ ਹੁਕਮਿ ਸਮਾਇ ਲਏ ਇਕਨੑਾ ਹੁਕਮੇ ਕਰੇ ਵਿਣਾਸੁ ॥",
          "roman": "iknhā hukam samāe lae iknhā hukme kare vinās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜੀਵਾਂ ਨੂੰ ਆਪਣੇ ਹੁਕਮ ਅਨੁਸਾਰ (ਇਸ ਸੰਸਾਰ-ਸਾਗਰ ਵਿਚੋਂ ਬਚਾ ਕੇ) ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਲੈਂਦਾ ਹੈ ਅਤੇ ਕਈ ਜੀਵਾਂ ਨੂੰ ਆਪਣੇ ਹੁਕਮ ਅਨੁਸਾਰ ਹੀ ਇਸੇ ਵਿਚ ਡੋਬ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Одних Он по Своей воле соединяет с Собой, а других по Своей воле погружает в этом мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20802,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨੑਾ ਭਾਣੈ ਕਢਿ ਲਏ ਇਕਨੑਾ ਮਾਇਆ ਵਿਚਿ ਨਿਵਾਸੁ ॥",
          "roman": "iknhā bhāṇē kaḍh lae iknhā māiā vich nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜੀਵਾਂ ਨੂੰ ਆਪਣੀ ਰਜ਼ਾ ਅਨੁਸਾਰ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚੋਂ ਕੱਢ ਲੈਂਦਾ ਹੈ, ਕਈਆਂ ਨੂੰ ਇਸੇ ਵਿਚ ਫਸਾਈ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Некоторых Он по Своей воле выводит из привязанности к майе, а других оставляет в ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20803,
          "is_rahao": false,
          "gurmukhi": "ਏਵ ਭਿ ਆਖਿ ਨ ਜਾਪਈ ਜਿ ਕਿਸੈ ਆਣੇ ਰਾਸਿ ॥",
          "roman": "ev bh ākh na jāpē j kisē āṇe rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਗੱਲ ਭੀ ਦੱਸੀ ਨਹੀਂ ਜਾ ਸਕਦੀ ਕਿ ਰੱਬ ਕਿਸ ਦਾ ਬੇੜਾ ਪਾਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Невозможно сказать, кого Господь приведёт к спасению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20804,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਜਾਣੀਐ ਜਾ ਕਉ ਆਪਿ ਕਰੇ ਪਰਗਾਸੁ ॥੩॥",
          "roman": "nānak gurmukh jāṇīai jā kau āp kare pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ (ਵਡਭਾਗੀ) ਮਨੁੱਖ ਨੂੰ ਚਾਨਣ ਬਖ਼ਸ਼ਦਾ ਹੈ, ਉਸ ਨੂੰ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਸਮਝ ਪੈ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кому Он дарует просветление, понимает это через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1692,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20805,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20806,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੀਅ ਉਪਾਇ ਕੈ ਲਿਖਿ ਨਾਵੈ ਧਰਮੁ ਬਹਾਲਿਆ ॥",
          "roman": "nānak jīa upāe kē likh nāvē dharam bahāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੀਵਾਂ ਨੂੰ ਪੈਦਾ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਨੇ ਧਰਮ-ਰਾਜ ਨੂੰ (ਉਹਨਾਂ ਦੇ ਸਿਰ ਤੇ) ਮੁਕੱਰਰ ਕੀਤਾ ਹੋਇਆ ਹੈ ਕਿ ਜੀਵਾਂ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਦਾ ਲੇਖਾ ਲਿਖਦਾ ਰਹੇ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Создав живых существ, Господь установил Дхармараджа, чтобы он записывал их деяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20807,
          "is_rahao": false,
          "gurmukhi": "ਓਥੈ ਸਚੇ ਹੀ ਸਚਿ ਨਿਬੜੈ ਚੁਣਿ ਵਖਿ ਕਢੇ ਜਜਮਾਲਿਆ ॥",
          "roman": "othē sachey hī sach nibaṛē chuṇ vakh kaḍhe jajmāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਮ-ਰਾਜ ਦੀ ਕਚਹਿਰੀ ਵਿਚ ਨਿਰੋਲ ਸੱਚ ਦੁਆਰਾ (ਜੀਵਾਂ ਦੇ ਕਰਮਾਂ ਦਾ) ਨਿਬੇੜਾ ਹੁੰਦਾ ਹੈ (ਭਾਵ, ਓਥੇ ਨਿਬੇੜੇ ਦਾ ਮਾਪ 'ਨਿਰੋਲ ਸਚੁ' ਹੈ, ਜਿਨ੍ਹਾਂ ਦੇ ਪੱਲੇ 'ਸਚੁ' ਹੁੰਦਾ ਹੈ ਉਹਨਾਂ ਨੂੰ ਆਦਰ ਮਿਲਦਾ ਹੈ ਤੇ) ਮੰਦ-ਕਰਮੀ ਜੀਵ ਚੁਣ ਕੇ ਵੱਖਰੇ ਕੀਤੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Там решается всё по чистой истине: праведные получают почёт, а злые отделяются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20808,
          "is_rahao": false,
          "gurmukhi": "ਥਾਉ ਨ ਪਾਇਨਿ ਕੂੜਿਆਰ ਮੁਹ ਕਾਲੑੈ ਦੋਜਕਿ ਚਾਲਿਆ ॥",
          "roman": "thāo na pāin kūṛiār muh kālhē dojak chāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੂੜ ਠੱਗੀ ਕਰਨ ਵਾਲੇ ਜੀਵਾਂ ਨੂੰ ਓਥੇ ਟਿਕਾਣਾ ਨਹੀਂ ਮਿਲਦਾ; ਕਾਲਾ ਮੂੰਹ ਕਰ ਕੇ ਉਹਨਾਂ ਨੂੰ ਦੋਜ਼ਕ ਵਿਚ ਧੱਕਿਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лживые не находят там места; с почерневшим лицом их отправляют в ад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20809,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਨਾਇ ਰਤੇ ਸੇ ਜਿਣਿ ਗਏ ਹਾਰਿ ਗਏ ਸਿ ਠਗਣ ਵਾਲਿਆ ॥",
          "roman": "terē nāi ratey se jiṇ gae hār gae s ṭhagaṇ vāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜੋ ਮਨੁੱਖ ਤੇਰੇ ਨਾਮ ਵਿਚ ਰੰਗੇ ਹੋਏ ਹਨ, ਉਹ (ਏਥੋਂ) ਬਾਜ਼ੀ ਜਿੱਤ ਕੇ ਜਾਂਦੇ ਹਨ ਤੇ ਠੱਗੀ ਕਰਨ ਵਾਲੇ ਬੰਦੇ (ਮਨੁੱਖਾ ਜਨਮ ਦੀ ਬਾਜ਼ੀ) ਹਾਰ ਕੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кто окрашен в Твоё Имя, побеждают, а обманщики проигрывают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20810,
          "is_rahao": false,
          "gurmukhi": "ਲਿਖਿ ਨਾਵੈ ਧਰਮੁ ਬਹਾਲਿਆ ॥੨॥",
          "roman": "likh nāvē dharam bahāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੂੰ, ਹੇ ਪ੍ਰਭੂ!) ਧਰਮ-ਰਾਜ ਨੂੰ (ਜੀਵਾਂ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਦਾ) ਲੇਖਾ ਲਿਖਣ ਵਾਸਤੇ (ਉਹਨਾਂ ਦੇ ਉੱਤੇ) ਮੁਕੱਰਰ ਕੀਤਾ ਹੋਇਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ты назначил Дхармараджа записывать деяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
