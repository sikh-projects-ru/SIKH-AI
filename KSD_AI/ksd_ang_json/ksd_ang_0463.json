        },
        {
          "verse_id": 20812,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਮਾਦੁ ਨਾਦ ਵਿਸਮਾਦੁ ਵੇਦ ॥",
          "roman": "vismād nād vismād ved",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਨਾਦ ਤੇ ਕਈ ਵੇਦ;"
            },
            "sahib_singh_ru": {
              "main": "Много звуков и много вед — всё это вызывает изумление;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20813,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਮਾਦੁ ਜੀਅ ਵਿਸਮਾਦੁ ਭੇਦ ॥",
          "roman": "vismād jīa vismād bhed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇਅੰਤ ਜੀਵ ਤੇ ਜੀਵਾਂ ਦੇ ਕਈ ਭੇਦ;"
            },
            "sahib_singh_ru": {
              "main": "бесчисленные существа и их различия;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20814,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਮਾਦੁ ਰੂਪ ਵਿਸਮਾਦੁ ਰੰਗ ॥",
          "roman": "vismād rūp vismād raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵਾਂ ਦੇ ਤੇ ਹੋਰ ਪਦਾਰਥਾਂ ਦੇ ਕਈ ਰੂਪ ਤੇ ਕਈ ਰੰਗ"
            },
            "sahib_singh_ru": {
              "main": "множество форм и цветов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20815,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਮਾਦੁ ਨਾਗੇ ਫਿਰਹਿ ਜੰਤ ॥",
          "roman": "vismād nāge firah jant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜੰਤ (ਸਦਾ) ਨੰਗੇ ਹੀ ਫਿਰ ਰਹੇ ਹਨ; ਇਹ ਸਭ ਕੁਝ ਵੇਖ ਕੇ ਵਿਸਮਾਦ ਅਵਸਥਾ ਬਣ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "есть существа, которые ходят нагими — всё это вызывает изумление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
