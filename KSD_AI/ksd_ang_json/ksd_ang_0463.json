          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
