{
  "ang": 465,
  "shabads": [
    {
      "shabad_id": 1697,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20867,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨੁ ਨ ਗਲੀਈ ਢੂਢੀਐ ਕਥਨਾ ਕਰੜਾ ਸਾਰੁ ॥",
          "roman": "giān na galīī ḍhūḍhīai kathnā kaṛṛā sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਿਆਨ ਨਿਰੀਆਂ ਗੱਲਾਂ ਨਾਲ ਨਹੀਂ ਭਾਲਿਆ ਜਾ ਸਕਦਾ, (ਗਿਆਨ ਕਿਵੇਂ ਮਿਲ ਸਕਦਾ ਹੈ-ਇਸ ਗੱਲ ਦਾ) ਬਿਆਨ ਕਰਨਾ ਇਉਂ ਕਰੜਾ ਹੈ ਜਿਵੇਂ ਲੋਹਾ (ਭਾਵ, ਬਹੁਤ ਔਖਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Знание не обретается одними разговорами; объяснить путь к нему крайне трудно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20868,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮਿ ਮਿਲੈ ਤਾ ਪਾਈਐ ਹੋਰ ਹਿਕਮਤਿ ਹੁਕਮੁ ਖੁਆਰੁ ॥੨॥",
          "roman": "karam milē tā pāīē hor hikmat hukam khuār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਾਂ) ਰੱਬ ਦੀ ਮੇਹਰ ਨਾਲ ਮਿਲ ਜਾਏ ਤਾਂ ਮਿਲ ਪੈਂਦਾ ਹੈ, (ਮੇਹਰ ਤੋਂ ਬਿਨਾ ਕੋਈ) ਹੋਰ ਚਾਰਾਜੋਈ ਤੇ ਹੁਕਮ (ਵਰਤਣਾ) ਵਿਅਰਥ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Оно достигается по милости Бога; без неё любые усилия и приказы напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1698,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20869,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20870,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰਹਿ ਜੇ ਆਪਣੀ ਤਾ ਨਦਰੀ ਸਤਿਗੁਰੁ ਪਾਇਆ ॥",
          "roman": "nadar kareh je āpṇī tā nadrī satgur pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜੇ ਤੂੰ (ਜੀਵ ਉੱਤੇ) ਮਿਹਰ ਦੀ ਨਜ਼ਰ ਕਰੇਂ, ਤਾਂ ਉਸ ਨੂੰ ਤੇਰੀ ਕਿਰਪਾ-ਦ੍ਰਿਸ਼ਟੀ ਨਾਲ ਸਤਿਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если Ты проявляешь милость, тогда по Твоей благодати человек находит Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20871,
          "is_rahao": false,
          "gurmukhi": "ਏਹੁ ਜੀਉ ਬਹੁਤੇ ਜਨਮ ਭਰੰਮਿਆ ਤਾ ਸਤਿਗੁਰਿ ਸਬਦੁ ਸੁਣਾਇਆ ॥",
          "roman": "eh jīu bahute janam bharamiā tā satgur sabad suṇāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ (ਵਿਚਾਰਾ) ਜੀਵ (ਜਦੋਂ) ਬਹੁਤੇ ਜਨਮਾਂ ਵਿਚ ਭਟਕ ਚੁਕਿਆ (ਤੇ ਤੇਰੀ ਮਿਹਰ ਦੀ ਨਜ਼ਰ ਹੋਈ) ਤਾਂ ਇਸ ਨੂੰ ਸਤਿਗੁਰੂ ਨੇ ਆਪਣਾ ਸ਼ਬਦ ਸੁਣਾਇਆ।"
            },
            "sahib_singh_ru": {
              "main": "Этот бедный джив блуждал во многих рождениях, и тогда Сатгуру дал ему услышать Слово."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20872,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਜੇਵਡੁ ਦਾਤਾ ਕੋ ਨਹੀ ਸਭਿ ਸੁਣਿਅਹੁ ਲੋਕ ਸਬਾਇਆ ॥",
          "roman": "satgur jevaḍ dātā ko nahī sabh suṇīah lok sabāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਲੋਕੋ! ਧਿਆਨ ਦੇ ਕੇ ਸੁਣੋ, ਸਤਿਗੁਰੂ ਦੇ ਬਰਾਬਰ ਦਾ ਹੋਰ ਕੋਈ ਦਾਤਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О люди! Слушайте внимательно: нет дарителя равного Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20873,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮਿਲਿਐ ਸਚੁ ਪਾਇਆ ਜਿਨੑੀ ਵਿਚਹੁ ਆਪੁ ਗਵਾਇਆ ॥",
          "roman": "satgur miliā sach pāiā jinhī vichah āp gavāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ-ਭਾਵ ਗਵਾ ਦਿੱਤਾ ਹੈ, ਉਹਨਾਂ ਨੂੰ ਉਸ ਸਤਿਗੁਰੂ ਦੇ ਮਿਲਣ ਨਾਲ ਸੱਚੇ ਪ੍ਰਭੂ ਦੀ ਪ੍ਰਾਪਤੀ ਹੋ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто устранили своё эго, встретив Сатгуру, обрели Истинного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20874,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਸਚੋ ਸਚੁ ਬੁਝਾਇਆ ॥੪॥",
          "roman": "jin sacho sach bujhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸਤਿਗੁਰੂ ਨੇ ਨਿਰੋਲ ਸੱਚੇ ਪ੍ਰਭੂ ਦੀ ਸੂਝ ਪਾਈ ਹੈ। (ਭਾਵ, ਜੋ ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ-ਭਾਵ ਗਵਾਉਂਦੇ ਹਨ, ਉਹਨਾਂ ਨੂੰ ਉਸ ਸਤਿਗੁਰੂ ਦੇ ਮਿਲਣ ਨਾਲ ਸੱਚੇ ਰੱਬ ਦੀ ਪ੍ਰਾਪਤੀ ਹੋ ਜਾਂਦੀ ਹੈ, ਜੋ ਸਤਿਗੁਰੂ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸੂਝ ਦੇਂਦਾ ਹੈ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Тот Сатгуру, который познал Истинную Истину и даёт это понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1699,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20875,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20876,
          "is_rahao": false,
          "gurmukhi": "ਘੜੀਆ ਸਭੇ ਗੋਪੀਆ ਪਹਰ ਕੰਨੑ ਗੋਪਾਲ ॥",
          "roman": "ghaṛīā sabhe gopīā pahar kanh gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੀਆਂ) ਘੜੀਆਂ (ਮਾਨੋ) ਗੋਪੀਆਂ ਹਨ; (ਦਿਨ ਦੇ ਸਾਰੇ) ਪਹਿਰ, (ਮਾਨੋ) ਕਾਨ੍ਹ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Все часы словно гопи; все стражи дня словно Кришна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20877,
          "is_rahao": false,
          "gurmukhi": "ਗਹਣੇ ਪਉਣੁ ਪਾਣੀ ਬੈਸੰਤਰੁ ਚੰਦੁ ਸੂਰਜੁ ਅਵਤਾਰ ॥",
          "roman": "gahaṇe pauṇ pāṇī bēsantar chand sūraj avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉਣ ਪਾਣੀ ਤੇ ਅੱਗ, (ਮਾਨੋ) ਗਹਿਣੇ ਹਨ (ਜੋ ਉਹਨਾਂ ਗੋਪੀਆਂ ਨੇ ਪਾਏ ਹੋਏ ਹਨ)। (ਰਾਸਾਂ ਵਿਚ ਰਾਸਧਾਰੀਏ ਅਵਤਾਰਾਂ ਦਾ ਸਾਂਗ ਬਣਾ ਬਣਾ ਕੇ ਗਾਉਂਦੇ ਹਨ, ਕੁਦਰਤ ਦੀ ਰਾਸ ਵਿਚ) ਚੰਦ੍ਰਮਾ ਤੇ ਸੂਰਜ, (ਮਾਨੋ) ਦੋ ਅਵਤਾਰ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Воздух, вода и огонь словно украшения; луна и солнце — словно два аватара."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20878,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੀ ਧਰਤੀ ਮਾਲੁ ਧਨੁ ਵਰਤਣਿ ਸਰਬ ਜੰਜਾਲ ॥",
          "roman": "saglī dhartī māl dhan varṭaṇ sarab janjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀ ਧਰਤੀ (ਰਾਸ ਪਾਣ ਲਈ) ਮਾਲ ਧਨ ਹੈ, ਅਤੇ (ਜਗਤ ਦੇ ਧੰਧੇ) ਰਾਸ ਦਾ ਵਰਤਣ-ਵਲੇਵਾ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Вся земля — богатство для игры, а мирские дела — её вращение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20879,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮੁਸੈ ਗਿਆਨ ਵਿਹੂਣੀ ਖਾਇ ਗਇਆ ਜਮਕਾਲੁ ॥੧॥",
          "roman": "nānak musē giān vihūṇī khāi gae jamkāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੀ ਇਸ ਰਾਸ ਵਿਚ) ਗਿਆਨ ਤੋਂ ਸੱਖਣੀ ਦੁਨੀਆ ਠੱਗੀ ਜਾ ਰਹੀ ਹੈ, ਤੇ ਇਸ ਨੂੰ ਜਮਕਾਲ ਖਾਈ ਜਾ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак: лишённый знания мир обманывается, и его пожирает смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1700,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20880,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20881,
          "is_rahao": false,
          "gurmukhi": "ਵਾਇਨਿ ਚੇਲੇ ਨਚਨਿ ਗੁਰ ॥",
          "roman": "vāin chele nachan gur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰਾਸਾਂ ਵਿਚ) ਚੇਲੇ ਸਾਜ ਵਜਾਉਂਦੇ ਹਨ, ਅਤੇ ਉਹਨਾਂ ਚੇਲਿਆਂ ਦੇ ਗੁਰੂ ਨੱਚਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Ученики играют на инструментах, а их учителя танцуют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20882,
          "is_rahao": false,
          "gurmukhi": "ਪੈਰ ਹਲਾਇਨਿ ਫੇਰਨਿੑ ਸਿਰ ॥",
          "roman": "pēr halāin pheran sir",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਚ ਵੇਲੇ ਉਹ ਗੁਰੂ) ਪੈਰਾਂ ਨੂੰ ਹਿਲਾਉਂਦੇ ਹਨ ਅਤੇ ਸਿਰ ਫੇਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они двигают ногами и вращают головой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20883,
          "is_rahao": false,
          "gurmukhi": "ਉਡਿ ਉਡਿ ਰਾਵਾ ਝਾਟੈ ਪਾਇ ॥",
          "roman": "uḍ uḍ rāwā jhāṭē pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਪੈਰਾਂ ਨਾਲ) ਉੱਡ ਉੱਡ ਕੇ ਘੱਟਾ ਉਹਨਾਂ ਦੇ ਸਿਰ ਵਿਚ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пыль поднимается и падает на их головы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20884,
          "is_rahao": false,
          "gurmukhi": "ਵੇਖੈ ਲੋਕੁ ਹਸੈ ਘਰਿ ਜਾਇ ॥",
          "roman": "vekhē lok hasē ghar jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰਾਸ ਵੇਖਣ ਆਏ ਹੋਏ) ਲੋਕ (ਉਹਨਾਂ ਨੂੰ ਨੱਚਦਿਆਂ) ਵੇਖਦੇ ਹਨ ਅਤੇ ਹੱਸਦੇ ਹਨ (ਅੱਖਰੀਂ-ਲੋਕ ਵੇਖਦਾ ਹੈ ਅਤੇ ਹੱਸਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Люди смотрят и смеются, уходя домой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20885,
          "is_rahao": false,
          "gurmukhi": "ਰੋਟੀਆ ਕਾਰਣਿ ਪੂਰਹਿ ਤਾਲ ॥",
          "roman": "roṭīā kāraṇ pūreh tāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਹ ਰਾਸਧਾਰੀਏ) ਰੋਜ਼ੀ ਦੀ ਖ਼ਾਤਰ ਨੱਚਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Они танцуют ради пропитания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20886,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਪਛਾੜਹਿ ਧਰਤੀ ਨਾਲਿ ॥",
          "roman": "āp pachhāṛeh dhartī nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਆਪਣੇ ਆਪ ਨੂੰ ਭੁਇਂ ਤੇ ਮਾਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "И бросают себя на землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20887,
          "is_rahao": false,
          "gurmukhi": "ਗਾਵਨਿ ਗੋਪੀਆ ਗਾਵਨਿ ਕਾਨੑ ॥",
          "roman": "gāvan gopīā gāvan kanh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੋਪੀਆਂ (ਦੇ ਸਾਂਗ ਬਣ ਕੇ) ਗਾਉਂਦੇ ਹਨ, ਕਾਨ੍ਹ (ਦੇ ਸਾਂਗ ਬਣ ਕੇ) ਗਾਉਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Поют, изображая гопи, поют, изображая Кришну."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20888,
          "is_rahao": false,
          "gurmukhi": "ਗਾਵਨਿ ਸੀਤਾ ਰਾਜੇ ਰਾਮ ॥",
          "roman": "gāvan sītā rāje rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੀਤਾ, ਰਾਮ ਜੀ ਤੇ ਹੋਰ ਰਾਜਿਆਂ ਦੇ ਸਾਂਗ ਬਣ ਕੇ ਗਾਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Поют, изображая Ситу, Раму и царей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20889,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਨਿਰੰਕਾਰੁ ਸਚੁ ਨਾਮੁ ॥",
          "roman": "nirbhau nirankār sach nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਪ੍ਰਭੂ ਨਿਡਰ ਹੈ, ਅਕਾਰ-ਰਹਿਤ ਹੈ ਅਤੇ ਜਿਸ ਦਾ ਨਾਮ ਸਦਾ ਅਟੱਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь бесстрашен, бесформен, Его имя вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20890,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਕੀਆ ਸਗਲ ਜਹਾਨੁ ॥",
          "roman": "jā kā kīā sagal jahān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਸਾਰਾ ਜਗਤ ਬਣਾਇਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Им создан весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20891,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਸੇਵਹਿ ਕਰਮਿ ਚੜਾਉ ॥",
          "roman": "sevak sevah karam chaṛāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ (ਕੇਵਲ ਉਹੀ) ਸੇਵਕ ਸਿਮਰਦੇ ਹਨ, ਜਿਨ੍ਹਾਂ ਦੇ ਅੰਦਰ (ਰੱਬ ਦੀ) ਮਿਹਰ ਨਾਲ ਚੜ੍ਹਦੀ ਕਲਾ ਹੈ, ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ (ਸਿਮਰਨ ਕਰਨ ਦਾ) ਉਤਸ਼ਾਹ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ему служат те, в ком по милости есть духовный подъём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20892,
          "is_rahao": false,
          "gurmukhi": "ਭਿੰਨੀ ਰੈਣਿ ਜਿਨੑਾ ਮਨਿ ਚਾਉ ॥",
          "roman": "bhinī rēṇ jinā man chāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਸੇਵਕਾਂ ਦੀ ਜ਼ਿੰਦਗੀ-ਰੂਪ ਰਾਤ ਸੁਆਦਲੀ ਗੁਜ਼ਰਦੀ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Их жизнь проходит в сладости и радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20893,
          "is_rahao": false,
          "gurmukhi": "ਸਿਖੀ ਸਿਖਿਆ ਗੁਰ ਵੀਚਾਰਿ ॥",
          "roman": "sikhī sikhiā gur vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਿੱਖਿਆ ਜਿਨ੍ਹਾਂ ਨੇ ਗੁਰੂ ਦੀ ਮੱਤ ਦੁਆਰਾ ਸਿੱਖ ਲਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Они усвоили учение через размышление над наставлением Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20894,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰੀ ਕਰਮਿ ਲਘਾਏ ਪਾਰਿ ॥",
          "roman": "nadrī karam laghāe pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਦੀ ਨਜ਼ਰ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪਣੀ ਬਖ਼ਸ਼ਸ਼ ਦੁਆਰਾ ਉਹਨਾਂ ਨੂੰ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Господа они переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20895,
          "is_rahao": false,
          "gurmukhi": "ਕੋਲੂ ਚਰਖਾ ਚਕੀ ਚਕੁ ॥",
          "roman": "kolū charkhā chakī chak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨੱਚਣ ਅਤੇ ਫੇਰੀਆਂ ਲੈਣ ਨਾਲ ਜੀਵਨ ਦਾ ਉਧਾਰ ਨਹੀਂ ਹੋ ਸਕਦਾ, ਵੇਖੋ ਬੇਅੰਤ ਪਦਾਰਥ ਤੇ ਜੀਵ ਸਦਾ ਭੌਂਦੇ ਰਹਿੰਦੇ ਹਨ) ਕੋਹਲੂ, ਚਰਖਾ, ਚੱਕੀ, ਚੱਕ,"
            },
            "sahib_singh_ru": {
              "main": "Пресс, прялка, мельница, колесо —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20896,
          "is_rahao": false,
          "gurmukhi": "ਥਲ ਵਾਰੋਲੇ ਬਹੁਤੁ ਅਨੰਤੁ ॥",
          "roman": "thal vārole bahut anant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਥਲਾਂ ਦੇ ਬੇਅੰਤ ਵਰੋਲੇ,"
            },
            "sahib_singh_ru": {
              "main": "бесконечные вихри на земле —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20897,
          "is_rahao": false,
          "gurmukhi": "ਲਾਟੂ ਮਾਧਾਣੀਆ ਅਨਗਾਹ ॥",
          "roman": "lāṭū mādhāṇīā angāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲਾਟੂ, ਮਧਾਣੀਆਂ, ਫਲ੍ਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "юлы, мешалки, доски —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20898,
          "is_rahao": false,
          "gurmukhi": "ਪੰਖੀ ਭਉਦੀਆ ਲੈਨਿ ਨ ਸਾਹ ॥",
          "roman": "pankhī bhaudīā lēn na sāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੰਛੀ, ਭੰਭੀਰੀਆਂ ਜੋ ਇਕ-ਸਾਹੇ ਉਡਦੀਆਂ ਰਹਿੰਦੀਆਂ ਹਨ-ਇਹ ਸਭ ਭੌਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "птицы и насекомые, непрерывно движущиеся — всё вращается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20899,
          "is_rahao": false,
          "gurmukhi": "ਸੂਐ ਚਾੜਿ ਭਵਾਈਅਹਿ ਜੰਤ ॥",
          "roman": "sūe chāṛ bhavāīah jant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੂਲ ਉੱਤੇ ਚਾੜ੍ਹ ਕੇ ਕਈ ਜੰਤ ਭਵਾਈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Существа насаживают на кол и вращают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20900,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਉਦਿਆ ਗਣਤ ਨ ਅੰਤ ॥",
          "roman": "nānak bhaudiā gaṇat na ant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਭੌਣ ਵਾਲੇ ਜੀਵਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Нанак: нет конца этим вращающимся существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20901,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਬੰਧਿ ਭਵਾਏ ਸੋਇ ॥",
          "roman": "bandhan bandh bhavāe soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸੇ ਤਰ੍ਹਾਂ) ਉਹ ਪ੍ਰਭੂ ਜੀਵਾਂ ਨੂੰ (ਮਾਇਆ ਦੇ) ਜ਼ੰਜੀਰਾਂ ਵਿਚ ਜਕੜ ਕੇ ਭਵਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь связывает существ и заставляет их вращаться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20902,
          "is_rahao": false,
          "gurmukhi": "ਪਇਐ ਕਿਰਤਿ ਨਚੈ ਸਭੁ ਕੋਇ ॥",
          "roman": "pae kirat nachē sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਜੀਵ ਆਪਣੇ ਕੀਤੇ ਕਰਮਾਂ ਦੇ ਸੰਸਕਾਰਾਂ ਅਨੁਸਾਰ ਨੱਚ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Каждый танцует по своим кармическим поступкам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20903,
          "is_rahao": false,
          "gurmukhi": "ਨਚਿ ਨਚਿ ਹਸਹਿ ਚਲਹਿ ਸੇ ਰੋਇ ॥",
          "roman": "nach nach hasah chaleh se roi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੀਵ ਨੱਚ ਨੱਚ ਕੇ ਹੱਸਦੇ ਹਨ, ਉਹ (ਅੰਤ ਨੂੰ) ਰੋ ਕੇ (ਏਥੋਂ) ਤੁਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кто танцуют и смеются, в конце уходят, плача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20904,
          "is_rahao": false,
          "gurmukhi": "ਉਡਿ ਨ ਜਾਹੀ ਸਿਧ ਨ ਹੋਹਿ ॥",
          "roman": "uḍ na jāhī sidh na hoh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਂਞ) ਭੀ ਨੱਚਣ ਟੱਪਣ ਨਾਲ ਕਿਸੇ ਉੱਚੀ ਅਵਸਥਾ ਤੇ ਨਹੀਂ ਅੱਪੜ ਜਾਂਦੇ, ਤੇ ਨਾ ਹੀ ਉਹ ਸਿੱਧ ਬਣ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они не достигают высшего состояния и не становятся совершенными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20905,
          "is_rahao": false,
          "gurmukhi": "ਨਚਣੁ ਕੁਦਣੁ ਮਨ ਕਾ ਚਾਉ ॥",
          "roman": "nachṇ kudṇ man kā chāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨੱਚਣਾ ਕੁੱਦਣਾ (ਕੇਵਲ) ਮਨ ਦਾ ਸ਼ੌਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Танцы и прыжки — лишь желание ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20906,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਨੑ ਮਨਿ ਭਉ ਤਿਨੑਾ ਮਨਿ ਭਾਉ ॥੨॥",
          "roman": "nānak jin man bhau tinhā man bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰੇਮ ਕੇਵਲ ਉਹਨਾਂ ਦੇ ਮਨ ਵਿਚ ਹੀ ਹੈ ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ ਰੱਬ ਦਾ ਡਰ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак: любовь есть у тех, в чьём сердце есть страх Божий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1701,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20907,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20908,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਤੇਰਾ ਨਿਰੰਕਾਰੁ ਹੈ ਨਾਇ ਲਇਐ ਨਰਕਿ ਨ ਜਾਈਐ ॥",
          "roman": "nāu terā nirankār hē nāe laeē narak na jāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰਾ ਨਾਮ ਨਿਰੰਕਾਰ ਹੈ, ਜੇ ਤੇਰਾ ਨਾਮ ਸਿਮਰੀਏ ਤਾਂ ਨਰਕ ਵਿਚ ਨਹੀਂ ਪਈਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Твоё имя — Нирнкар; вспоминая его, не попадают в ад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20909,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਸਭੁ ਤਿਸ ਦਾ ਦੇ ਖਾਜੈ ਆਖਿ ਗਵਾਈਐ ॥",
          "roman": "jīu piṇḍ sabh tis dā de khājē ākh gavāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਿੰਦ ਅਤੇ ਸਰੀਰ ਸਭ ਕੁਝ ਪ੍ਰਭੂ ਦਾ ਹੀ ਹੈ, ਉਹੀ (ਜੀਵਾਂ ਨੂੰ) ਖਾਣ ਵਾਸਤੇ (ਭੋਜਨ) ਦੇਂਦਾ ਹੈ, (ਕਿਤਨਾ ਕੁ ਦੇਂਦਾ ਹੈ) ਇਹ ਅੰਦਾਜ਼ਾ ਲਾਉਣਾ ਵਿਅਰਥ ਜਤਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Жизнь и тело принадлежат Ему; Он даёт пищу — невозможно это полностью описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20910,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਲੋੜਹਿ ਚੰਗਾ ਆਪਣਾ ਕਰਿ ਪੁੰਨਹੁ ਨੀਚੁ ਸਦਾਈਐ ॥",
          "roman": "je loṛeh changā āpṇā kar puṇnah nīch sadāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੀਵ! ਜੇ ਤੂੰ ਆਪਣੀ ਭਲਿਆਈ ਲੋੜਦਾ ਹੈਂ, ਤਾਂ ਚੰਗਾ ਕੰਮ ਕਰ ਕੇ ਭੀ ਆਪਣੇ ਆਪ ਨੂੰ ਨੀਵਾਂ ਅਖਵਾ।"
            },
            "sahib_singh_ru": {
              "main": "Если хочешь блага — делай добро и оставайся смиренным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20911,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਜਰਵਾਣਾ ਪਰਹਰੈ ਜਰੁ ਵੇਸ ਕਰੇਦੀ ਆਈਐ ॥",
          "roman": "je jarvāṇā parharē jar ves karedī āīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਕੋਈ ਜੀਵ) ਬੁਢੇਪੇ ਨੂੰ ਪਰੇ ਹਟਾਉਣਾ ਚਾਹੇ (ਭਾਵ, ਬੁਢੇਪੇ ਤੋਂ ਬਚਣਾ ਚਾਹੇ, ਤਾਂ ਇਹ ਜਤਨ ਫ਼ਜ਼ੂਲ ਹੈ) ਬੁਢੇਪਾ ਵੇਸ ਧਾਰ ਕੇ ਆ ਹੀ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если кто хочет избежать старости — это напрасно, она всё равно приходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20912,
          "is_rahao": false,
          "gurmukhi": "ਕੋ ਰਹੈ ਨ ਭਰੀਐ ਪਾਈਐ ॥੫॥",
          "roman": "ko rahē na bharīē pāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਸੁਆਸ ਪੂਰੇ ਹੋ ਜਾਂਦੇ ਹਨ, ਤਾਂ ਕੋਈ ਜੀਵ ਇੱਥੇ ਰਹਿ ਨਹੀਂ ਸਕਦਾ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Когда дыхание исчерпывается, никто не остаётся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1702,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20913,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahla 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20914,
          "is_rahao": false,
          "gurmukhi": "ਮੁਸਲਮਾਨਾ ਸਿਫਤਿ ਸਰੀਅਤਿ ਪੜਿ ਪੜਿ ਕਰਹਿ ਬੀਚਾਰੁ ॥",
          "roman": "musalmānā sifat sarīat paṛ paṛ kareh vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁਸਲਮਾਨਾਂ ਨੂੰ ਸ਼ਰਹ ਦੀ ਵਡਿਆਈ (ਸਭ ਤੋਂ ਵਧੀਕ ਚੰਗੀ ਲੱਗਦੀ ਹੈ), ਉਹ ਸ਼ਰਹ ਨੂੰ ਪੜ੍ਹ ਪੜ੍ਹ ਕੇ (ਇਹ) ਵਿਚਾਰ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Мусульмане восхваляют шариат и размышляют над ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20915,
          "is_rahao": false,
          "gurmukhi": "ਬੰਦੇ ਸੇ ਜਿ ਪਵਹਿ ਵਿਚਿ ਬੰਦੀ ਵੇਖਣ ਕਉ ਦੀਦਾਰੁ ॥",
          "roman": "bande se j paveh vich bandī vekhaṇ kau dīdār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਰੱਬ ਦਾ ਦੀਦਾਰ ਦੇਖਣ ਲਈ ਜੋ ਮਨੁੱਖ (ਸ਼ਰਹ ਦੀ) ਬੰਦਸ਼ ਵਿਚ ਪੈਂਦੇ ਹਨ, ਉਹੀ ਰੱਬ ਦੇ ਬੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они считают, что те, кто подчиняются закону, — слуги Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20916,
          "is_rahao": false,
          "gurmukhi": "ਹਿੰਦੂ ਸਾਲਾਹੀ ਸਾਲਾਹਨਿ ਦਰਸਨਿ ਰੂਪਿ ਅਪਾਰੁ ॥",
          "roman": "hindū sālāhī sālāhan darsan rūp apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਿੰਦੂ ਸ਼ਾਸਤਰ ਦੁਆਰਾ ਹੀ ਸਾਲਾਹੁਣ-ਜੋਗ ਸੁੰਦਰ ਤੇ ਬੇਅੰਤ ਹਰੀ ਨੂੰ ਸਲਾਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Индусы славят бесконечного Бога через писания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20917,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥਿ ਨਾਵਹਿ ਅਰਚਾ ਪੂਜਾ ਅਗਰ ਵਾਸੁ ਬਹਕਾਰੁ ॥",
          "roman": "tīrath nāveh archā pūjā agar vās bahkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਤੀਰਥ ਤੇ ਨ੍ਹਾਉਂਦੇ ਹਨ, ਮੂਰਤੀਆਂ ਅਗੇ ਭੇਟਾ ਧਰਦੇ ਹਨ ਤੇ ਚੰਦਨ ਆਦਿਕ ਦੇ ਸੁਗੰਧੀ ਵਾਲੇ ਪਦਾਰਥ ਵਰਤਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они совершают омовения, поклоняются и используют благовония."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20918,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਸੁੰਨਿ ਧਿਆਵਨਿੑ ਜੇਤੇ ਅਲਖ ਨਾਮੁ ਕਰਤਾਰੁ ॥",
          "roman": "jogī sunn dhiāvan jeṭe alakh nām kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗੀ ਲੋਕ ਸਮਾਧੀ ਲਾ ਕੇ ਕਰਤਾਰ ਨੂੰ ਧਿਆਉਂਦੇ ਹਨ ਅਤੇ 'ਅਲਖ, ਅਲਖ' ਉਸ ਦਾ ਨਾਮ ਉਚਾਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Йоги медитируют на Творца и произносят Его имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
