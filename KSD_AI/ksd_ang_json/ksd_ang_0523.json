{
  "ang": 523,
  "shabads": [
    {
      "shabad_id": 1993,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23263,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਿ ਸਭਨਾ ਸਮਰਥੁ ਨਦਰਿ ਨਿਹਾਲਿਆ ॥੧੭॥",
          "roman": "sir sabhnā samrath nadar nihāliā ॥17॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Над всеми — Всемогущий; своим милостивым взглядом Он дарует блаженство. ॥17॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1994,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23264,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23265,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਮਦ ਲੋਭ ਮੋਹ ਦੁਸਟ ਬਾਸਨਾ ਨਿਵਾਰਿ ॥",
          "roman": "kām krodh mad lobh moh dusṭ bāsnā nivār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Удали похоть, гнев, жадность, привязанность, опьянение гордыней и дурные желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23266,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੇਹੁ ਪ੍ਰਭ ਆਪਣੇ ਨਾਨਕ ਸਦ ਬਲਿਹਾਰਿ ॥੧॥",
          "roman": "rākh leh prabh āpṇe nānak sad balihār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Прабху, защити меня; Нанак всегда приносит себя в жертву Тебе. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1995,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23267,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23268,
          "is_rahao": false,
          "gurmukhi": "ਖਾਂਦਿਆ ਖਾਂਦਿਆ ਮੁਹੁ ਘਠਾ ਪੈਨੰਦਿਆ ਸਭੁ ਅੰਗੁ ॥",
          "roman": "khāndiā khāndiā muh ghaṭhā pēnandiā sabh aṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От постоянной еды истёрся рот, а от постоянного ношения красивой одежды всё тело стало изношенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23269,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਧ੍ਰਿਗੁ ਤਿਨਾ ਦਾ ਜੀਵਿਆ ਜਿਨ ਸਚਿ ਨ ਲਗੋ ਰੰਗੁ ॥੨॥",
          "roman": "nānak dhrig tinā dā jīviā jin sach na lago raṅg ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, проклята жизнь тех, у кого не возникла любовь к вечному Прабху. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1996,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23270,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23271,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜਿਉ ਤੇਰਾ ਹੁਕਮੁ ਤਿਵੈ ਤਿਉ ਹੋਵਣਾ ॥",
          "roman": "jio jio terā hukam tivē tio hovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху, в мире всё происходит именно так, каков Твой Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23272,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜਹ ਰਖਹਿ ਆਪਿ ਤਹ ਜਾਇ ਖੜੋਵਣਾ ॥",
          "roman": "jah jah rakhah āp tah jāi khaṛovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Куда Ты сам помещаешь существ, туда они и становятся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23273,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਤੇਰੈ ਕੈ ਰੰਗਿ ਦੁਰਮਤਿ ਧੋਵਣਾ ॥",
          "roman": "nām terē kē raṅg durmat dhovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто пребывает в любви к Твоему Имени, смывают дурной разум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23274,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਤੁਧੁ ਨਿਰੰਕਾਰ ਭਰਮੁ ਭਉ ਖੋਵਣਾ ॥",
          "roman": "jap jap tudh niraṅkār bharam bhau khovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нираṅкар, снова и снова вспоминая Тебя, они устраняют блуждание и страх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23275,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੇਰੈ ਰੰਗਿ ਰਤੇ ਸੇ ਜੋਨਿ ਨ ਜੋਵਣਾ ॥",
          "roman": "jo terē raṅg rate se jon na jovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто окрашены Твоей любовью, не ввергаются в круг рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23276,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਇਕੁ ਨੈਣ ਅਲੋਵਣਾ ॥",
          "roman": "antar bāhar ik nēṇ alovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри и снаружи, повсюду, они своими глазами видят одного лишь Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23277,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑੀ ਪਛਾਤਾ ਹੁਕਮੁ ਤਿਨੑ ਕਦੇ ਨ ਰੋਵਣਾ ॥",
          "roman": "jinhī pachhātā hukam tinh kade na rovṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто распознал Хукам Прабху, никогда не раскаиваются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23278,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਨਾਨਕ ਬਖਸੀਸ ਮਨ ਮਾਹਿ ਪਰੋਵਣਾ ॥੧੮॥",
          "roman": "nāo nānak bakhsīs man māh parovṇā ॥18॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, они держат в своём уме нанизанным дар Прабху — Его Имя. ॥18॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1997,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23279,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23280,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਦਿਆ ਨ ਚੇਤਿਓ ਮੁਆ ਰਲੰਦੜੋ ਖਾਕ ॥",
          "roman": "jīvadiā na chetio muā ralandṛo khāk ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока жил, он не помнил Бога; умерев, смешался с прахом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23281,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੁਨੀਆ ਸੰਗਿ ਗੁਦਾਰਿਆ ਸਾਕਤ ਮੂੜ ਨਪਾਕ ॥੧॥",
          "roman": "nānak dunīā saṅg gudāriā sākat mūṛ napāk ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой оторванный от Бога, глупый и нечистый человек провёл жизнь только с миром. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1998,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23282,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23283,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵੰਦਿਆ ਹਰਿ ਚੇਤਿਆ ਮਰੰਦਿਆ ਹਰਿ ਰੰਗਿ ॥",
          "roman": "jīvandiā har chetiā marandiā har raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто при жизни помнил Хари и при смерти пребывал в любви к Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23284,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਤਾਰਿਆ ਨਾਨਕ ਸਾਧੂ ਸੰਗਿ ॥੨॥",
          "roman": "janam padārath tāriā nānak sādhū saṅg ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот в обществе святых спас драгоценность человеческого рождения. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1999,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23285,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23286,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਜੁਗਾਦੀ ਆਪਿ ਰਖਣ ਵਾਲਿਆ ॥",
          "roman": "ād jugādī āp rakhaṇ vāliā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С самого начала, во все эпохи, Прабху сам был Защитником всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23287,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਨਾਮੁ ਕਰਤਾਰੁ ਸਚੁ ਪਸਾਰਿਆ ॥",
          "roman": "sach nām kartār sach pasāriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Картáра вечно; Он сам, вечный, присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23288,
          "is_rahao": false,
          "gurmukhi": "ਊਣਾ ਕਹੀ ਨ ਹੋਇ ਘਟੇ ਘਟਿ ਸਾਰਿਆ ॥",
          "roman": "ūṇā kahī na hoi ghaṭe ghaṭ sāriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет ни одного места, пустого от Него; пребывая в каждом сердце, Он заботится обо всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23289,
          "is_rahao": false,
          "gurmukhi": "ਮਿਹਰਵਾਨ ਸਮਰਥ ਆਪੇ ਹੀ ਘਾਲਿਆ ॥",
          "roman": "miharvān samrath āpe hī ghāliā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он милостив ко всем, всемогущ, и сам заставляет существ совершать труд симрана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23290,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑ ਮਨਿ ਵੁਠਾ ਆਪਿ ਸੇ ਸਦਾ ਸੁਖਾਲਿਆ ॥",
          "roman": "jinh man vuṭhā āp se sadā sukhāliā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, в чьём уме Он сам поселился, всегда пребывают в счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23291,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਰਚਨੁ ਰਚਾਇ ਆਪੇ ਹੀ ਪਾਲਿਆ ॥",
          "roman": "āpe rachan rachāi āpe hī pāliā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам создал творение и сам же его поддерживает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23292,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਆਪੇ ਆਪਿ ਬੇਅੰਤ ਅਪਾਰਿਆ ॥",
          "roman": "sabh kichh āpe āp beant apāriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он бесконечен и безмерен; всё есть Он сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23293,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਟੇਕ ਨਾਨਕ ਸੰਮੑਾਲਿਆ ॥੧੯॥",
          "roman": "gur pūre kī ṭek nānak saṃmhāliā ॥19॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто принял опору совершенного Гуру, помнит этого Прабху. ॥19॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2000,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23294,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23295,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਮਧਿ ਅਰੁ ਅੰਤਿ ਪਰਮੇਸਰਿ ਰਖਿਆ ॥",
          "roman": "ād madh ar ant parmesar rakhiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В начале, середине и конце — всегда — Пармешар сам оберегал своего служителя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23296,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਦਿਤਾ ਹਰਿ ਨਾਮੁ ਅੰਮ੍ਰਿਤੁ ਚਖਿਆ ॥",
          "roman": "satigur ditā har nām amrit chakhiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру дал ему Имя Хари, и он вкусил нектар Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23297,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਾ ਸੰਗੁ ਅਪਾਰੁ ਅਨਦਿਨੁ ਹਰਿ ਗੁਣ ਰਵੈ ॥",
          "roman": "sādhā saṅg apār andin har guṇ ravē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он получил бесценное общество святых и день за днём вспоминает достоинства Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23298,
          "is_rahao": false,
          "gurmukhi": "ਪਾਏ ਮਨੋਰਥ ਸਭਿ ਜੋਨੀ ਨਹ ਭਵੈ ॥",
          "roman": "pāe manorath sabh jonī nah bhavē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все его желания исполняются, то есть все вожделения исчезают, и он больше не блуждает в рождениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23299,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਕਰਤੇ ਹਥਿ ਕਾਰਣੁ ਜੋ ਕਰੈ ॥",
          "roman": "sabh kichh karte hath kāraṇ jo karē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё находится в руке Картáра; только Он сам создаёт средство для симрана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23300,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮੰਗੈ ਦਾਨੁ ਸੰਤਾ ਧੂਰਿ ਤਰੈ ॥੧॥",
          "roman": "nānak maṅgē dān santā dhūr tarē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак просит дара: получив пыль стоп святых, то есть пребывая в Садх Сангат, переправиться через этот мир-океан. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2001,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23301,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mėhlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23302,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਨੋ ਮੰਨਿ ਵਸਾਇ ਜਿਨਿ ਉਪਾਇਆ ॥",
          "roman": "tis no mann vasāi jin upāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, посели в своём уме того Прабху, который создал тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23303,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਨਿ ਧਿਆਇਆ ਖਸਮੁ ਤਿਨਿ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "jin jan dhiāiā khasam tin sukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который созерцал Хозяина-Прабху, обрёл покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23304,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲੁ ਜਨਮੁ ਪਰਵਾਨੁ ਗੁਰਮੁਖਿ ਆਇਆ ॥",
          "roman": "safal janam parvān gurmukh āiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Приход такого гурмукха в мир благословен; его жизнь стала успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23305,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੈ ਬੁਝਿ ਨਿਹਾਲੁ ਖਸਮਿ ਫੁਰਮਾਇਆ ॥",
          "roman": "hukmē bujh nihāl khasam furmāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поняв Хукам, данный Хозяином-Прабху, он пребывает в радостном расцвете."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23306,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਹੋਆ ਆਪਿ ਕ੍ਰਿਪਾਲੁ ਸੁ ਨਹ ਭਰਮਾਇਆ ॥",
          "roman": "jis hoā āp kripāl so nah bharamāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, к кому Прабху сам стал милостив, не впадает в блуждание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23307,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਦਿਤਾ ਖਸਮਿ ਸੋਈ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "jo jo ditā khasam soī sukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что бы ни дал ему Хозяин-Прабху, всё это он воспринимает как благо и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23308,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸਹਿ ਦਇਆਲੁ ਬੁਝਾਏ ਹੁਕਮੁ ਮਿਤ ॥",
          "roman": "nānak jisah dayāl bujhāe hukam mit ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, кому Друг-Прабху становится милостив, тому Он дарует понимание своего Хукама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23309,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਭੁਲਾਏ ਆਪਿ ਮਰਿ ਮਰਿ ਜਮਹਿ ਨਿਤ ॥੨॥",
          "roman": "jisah bhulāe āp mar mar jamah nit ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но тех, кого Он сам вводит в заблуждение, снова и снова, постоянно умирая, рождаются. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2002,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23310,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23311,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਮਾਰੇ ਤਤਕਾਲਿ ਖਿਨੁ ਟਿਕਣ ਨ ਦਿਤੇ ॥",
          "roman": "nindak māre tatkāl khin ṭikaṇ na dite ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тех, кто клевещет на гурмукхов, Прабху словно убивает сразу: из-за клеветы Он не даёт их уму ни мгновения покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23312,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਾਸ ਕਾ ਦੁਖੁ ਨ ਖਵਿ ਸਕਹਿ ਫੜਿ ਜੋਨੀ ਜੁਤੇ ॥",
          "roman": "prabh dās kā dukh na khav sakah phaṛ jonī jute ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху не может терпеть страдания своих слуг; его преданных страдание пороков не касается, а клеветников Он хватает и бросает в рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
