{
  "ang": 563,
  "shabads": [
    {
      "shabad_id": 2161,
      "rahao_verse_id": 24713,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24713,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਜੀਵਾ ਪ੍ਰਭ ਚਰਣ ਤੁਮਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jap jīvā prabh charaṇ tumāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਮੈਂ ਤੇਰੇ ਚਰਨ ਹਿਰਦੇ ਵਿਚ ਵਸ ਕੇ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы, удерживая в сердце Твои стопы, я обрёл духовную жизнь ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24714,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਪੁਰਖ ਮੇਰੇ ਪ੍ਰਭ ਦਾਤੇ ॥",
          "roman": "daīāl purakh mere prabh dāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਦਾਤੇ ਪ੍ਰਭੂ! ਹੇ ਦਇਆ ਦੇ ਘਰ ਅਕਾਲ ਪੁਰਖ!"
            },
            "sahib_singh_ru": {
              "main": "О мой дающий Господь! О Акал Пуракх, дом милости!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24715,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਜਨਾਵਹੁ ਤਿਨਹਿ ਤੁਮ ਜਾਤੇ ॥੨॥",
          "roman": "jiseh janāvho tineh tum jāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਤੂੰ ਆਪ ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈਂ, ਉਸੇ ਨੇ ਹੀ ਤੇਰੇ ਨਾਲ ਸਾਂਝ ਪਾਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот человек обрёл с Тобой близость, кому Ты Сам даруешь понимание ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24716,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਾਈ ਬਲਿਹਾਰੀ ॥",
          "roman": "sadā sadā jāī balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ ਸਦਾ ਹੀ ਸਦਾ ਹੀ ਤੈਥੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я всегда, всегда иду Тебе в жертву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24717,
          "is_rahao": false,
          "gurmukhi": "ਇਤ ਉਤ ਦੇਖਉ ਓਟ ਤੁਮਾਰੀ ॥੩॥",
          "roman": "it ut dekhau oṭ tumārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਵਿਚ ਤੇ ਪਰਲੋਕ ਵਿਚ ਮੈਂ ਤੇਰਾ ਹੀ ਆਸਰਾ ਤੱਕਦਾ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В этом мире и в мире ином я ищу опору только в Тебе ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24718,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਨਿਰਗੁਣ ਗੁਣੁ ਕਿਛੂ ਨ ਜਾਤਾ ॥",
          "roman": "moh nirguṇ guṇ kichhū na jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ ਗੁਣ-ਹੀਣ ਹਾਂ, ਮੈਂ ਤੇਰੇ ਗੁਣ (ਉਪਕਾਰ) ਕੁਝ ਭੀ ਨਹੀਂ ਸੀ ਸਮਝ ਸਕਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я лишён достоинств и совсем не мог понять Твои качества и благодеяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24719,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧੂ ਦੇਖਿ ਮਨੁ ਰਾਤਾ ॥੪॥੩॥",
          "roman": "Nānak sādhū dekhi man rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦਾ ਦਰਸਨ ਕਰ ਕੇ ਮੇਰਾ ਮਨ (ਤੇਰੇ ਪ੍ਰੇਮ ਵਿਚ) ਰੰਗਿਆ ਗਿਆ ਹੈ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Увидев Гуру, мой ум окрасился в Твою любовь ॥4॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2162,
      "rahao_verse_id": 24724,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24720,
          "is_rahao": false,
          "gurmukhi": "ਵਡਹੰਸੁ ਮਃ ੫ ॥",
          "roman": "vaḍhans mahla 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24721,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਸੋ ਪ੍ਰਭੁ ਪੂਰਾ ॥",
          "roman": "antarjāmī so prabh pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ, ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ ਭਰਪੂਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь — знающий сердца всех, Он полон всеми качествами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24722,
          "is_rahao": false,
          "gurmukhi": "ਦਾਨੁ ਦੇਇ ਸਾਧੂ ਕੀ ਧੂਰਾ ॥੧॥",
          "roman": "dān deī sādhū kī dhūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਪ੍ਰਭੂ ਮੇਹਰ ਕਰਦਾ ਹੈ ਤਾਂ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਖ਼ਸ਼ੀਸ਼ (ਵਜੋਂ) ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь проявляет милость, Он дарует пыль стоп Гуру как благословение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24723,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "kar kirpā prabh dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉੱਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ! (ਮੇਰੇ ਉੱਤੇ) ਕਿਰਪਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, милостивый к бедным! Прояви ко мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24724,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੀ ਓਟ ਪੂਰਨ ਗੋਪਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "terī oṭ pūran gopālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਰਬ-ਵਿਆਪਕ! ਹੇ ਸ੍ਰਿਸ਼ਟੀ-ਪਾਲਕ! ਮੈਨੂੰ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Всепроникающий, О Хранитель творения! Я ищу только Твоего прибежища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24725,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਰਹਿਆ ਭਰਪੂਰੇ ॥",
          "roman": "jal thal mahīal rahiā bharpūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਪਾਣੀ ਵਿਚ, ਧਰਤੀ ਵਿਚ, ਆਕਾਸ਼ ਵਿਚ, ਹਰ ਥਾਂ ਜ਼ੱਰੇ ਜ਼ੱਰੇ ਵਿਚ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь присутствует в воде, на земле, в небесах, повсюду, в каждом атоме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24726,
          "is_rahao": false,
          "gurmukhi": "ਨਿਕਟਿ ਵਸੈ ਨਾਹੀ ਪ੍ਰਭੁ ਦੂਰੇ ॥੨॥",
          "roman": "nikat vasē nāhī prabh dūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਹਰੇਕ ਜੀਵ ਦੇ) ਨੇੜੇ ਵੱਸਦਾ ਹੈ, ਕਿਸੇ ਤੋਂ ਦੂਰ ਨਹੀਂ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он обитает рядом со всеми, ни от кого не далёк."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24727,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਨਦਰਿ ਕਰੇ ਸੋ ਧਿਆਏ ॥",
          "roman": "jis no nadar kare so dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਮੇਹਰ ਦੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ ਉਹ ਮਨੁੱਖ ਉਸ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на кого Господь обращает милостивый взгляд, постоянно помнит Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24728,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਕੇ ਗੁਣ ਗਾਏ ॥੩॥",
          "roman": "āṭh pahar har ke guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ ਮਨੁੱਖ ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и такой человек восемь страж дня (всегда) воспевает качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24729,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਗਲੇ ਪ੍ਰਤਿਪਾਰੇ ॥",
          "roman": "jīa jant sagle pratipāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਸਾਰੇ ਹੀ ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог заботится обо всех живых существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24730,
          "is_rahao": false,
          "gurmukhi": "ਸਰਨਿ ਪਰਿਓ ਨਾਨਕ ਹਰਿ ਦੁਆਰੇ ॥੪॥੪॥",
          "roman": "saraṇ pariō nānak har duāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਆ ਕੇ ਤੇਰੀ (ਪ੍ਰਭੂ ਦੀ) ਸਰਨ ਪਿਆ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак пришёл к двери Господа и нашёл прибежище у Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2163,
      "rahao_verse_id": 24735,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24731,
          "is_rahao": false,
          "gurmukhi": "ਵਡਹੰਸੁ ਮਹਲਾ ੫ ॥",
          "roman": "vaḍhans mahla 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24732,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਵਡ ਦਾਤਾ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "tū vaḍ dātā antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਸਭ ਤੋਂ ਵੱਡਾ ਦਾਤਾ ਹੈਂ, ਤੂੰ (ਜੀਵਾਂ ਦੇ) ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — величайший дарующий, Ты — знающий сердца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24733,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਰਵਿਆ ਪੂਰਨ ਪ੍ਰਭ ਸੁਆਮੀ ॥੧॥",
          "roman": "sabh meh raviā pūran prabh suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਸੁਆਮੀ! ਹੇ ਸਰਬ-ਵਿਆਪਕ! ਤੂੰ ਸਭ ਦੇ ਅੰਦਰ ਮੌਜੂਦ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О мой Владыка! Ты присутствуешь во всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24734,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਪ੍ਰਭ ਪ੍ਰੀਤਮ ਨਾਮੁ ਅਧਾਰਾ ॥",
          "roman": "mere prabh prītam nām adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰੀਤਮ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ (ਮੇਰੀ ਜ਼ਿੰਦਗੀ ਦਾ) ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный Господь! Твоё Имя — опора моей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24735,
          "is_rahao": true,
          "gurmukhi": "ਹਉ ਸੁਣਿ ਸੁਣਿ ਜੀਵਾ ਨਾਮੁ ਤੁਮਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "hau suṇ suṇ jīvā nām tumārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਨਾਮ ਸੁਣ ਸੁਣ ਕੇ ਮੈਂ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Слушая Твоё Имя снова и снова, я обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24736,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਸਰਣਿ ਸਤਿਗੁਰ ਮੇਰੇ ਪੂਰੇ ॥",
          "roman": "terī saraṇ satgur mere pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪੂਰੇ ਸਤਿਗੁਰੂ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О мой совершенный Сатгуру! Я пришёл в Твоё прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24737,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਨਿਰਮਲੁ ਹੋਇ ਸੰਤਾ ਧੂਰੇ ॥੨॥",
          "roman": "man nirmal hoī santā dhūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂ ਕਿ ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਨਾਲ ਮਨ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ибо пыль стоп святых очищает ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24738,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਉਰਿ ਧਾਰੇ ॥",
          "roman": "charan kamal hirdē ur dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੇ ਸੋਹਣੇ ਕੋਮਲ ਚਰਨ ਮੈਂ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਏ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои прекрасные лотосные стопы я утвердил в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24739,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਦਰਸਨ ਕਉ ਜਾਈ ਬਲਿਹਾਰੇ ॥੩॥",
          "roman": "tere darsan kau jāī balihāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੈਂ ਤੇਰੇ ਦਰਸ਼ਨ ਤੋਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и я жертвую собой ради Твоего даршана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24740,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਤੇਰੇ ਗੁਣ ਗਾਵਾ ॥",
          "roman": "kar kirpā tere guṇ gāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮੇਹਰ ਕਰ, ਮੈਂ ਤੇਰੇ ਗੁਣ ਗਾਂਦਾ ਰਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Прояви милость, чтобы я воспевал Твои качества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24741,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਜਪਤ ਸੁਖੁ ਪਾਵਾ ॥੪॥੫॥",
          "roman": "nānak nām japat sukh pāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਤੇਰਾ ਨਾਮ ਜਪਦਿਆਂ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਰਹਾਂ, ਹੇ ਨਾਨਕ! ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и, повторяя Твоё Имя, наслаждался духовным блаженством, о Нанак."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2164,
      "rahao_verse_id": 24746,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24742,
          "is_rahao": false,
          "gurmukhi": "ਵਡਹੰਸੁ ਮਹਲਾ ੫ ॥",
          "roman": "vaḍhans mahla 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24743,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਅੰਮ੍ਰਿਤੁ ਪੀਜੈ ॥",
          "roman": "sādhsang har amrit pījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ ਹੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਲ ਪੀਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру следует пить нектар Имени, дающего духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24744,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਜੀਉ ਮਰੈ ਨ ਕਬਹੂ ਛੀਜੈ ॥੧॥",
          "roman": "nā jīu marē na kabhū chhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨਾਲ ਜਿੰਦ ਨਾਂ ਆਤਮਕ ਮੌਤੇ ਮਰਦੀ ਹੈ ਤੇ ਨਾਂ ਕਦੇ ਆਤਮਕ ਜੀਵਨ ਵਿੱਚ ਕਮਜ਼ੋਰੀ ਹੁੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда душа не умирает духовной смертью и никогда не ослабевает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24745,
          "is_rahao": true,
          "gurmukhi": "ਵਡਭਾਗੀ ਗੁਰੁ ਪੂਰਾ ਪਾਈਐ ॥",
          "roman": "vaḍbhāgī gur pūrā pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰਾ ਗੁਰੂ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Совершенного Гуру обретают благодаря великой удаче,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24746,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਪ੍ਰਭੂ ਧਿਆਈਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur kirpā te prabhū dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и по милости Гуру можно помнить Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24747,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨ ਜਵਾਹਰ ਹਰਿ ਮਾਣਕ ਲਾਲਾ ॥",
          "roman": "ratan javāhar har māṇak lālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਬਚਨ (ਮਾਨੋ) ਰਤਨ ਹਨ, ਜਵਾਹਰ ਹਨ, ਮੋਤੀ ਹਨ, ਲਾਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Слова хвалы Господу — как драгоценные камни, жемчуг и рубины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24748,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਪ੍ਰਭ ਭਏ ਨਿਹਾਲਾ ॥੨॥",
          "roman": "simar simar prabh bhae nihālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ ਸਦਾ ਖਿੜੇ ਰਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Помня Господа снова и снова, человек всегда пребывает в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24749,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਪੇਖਉ ਸਾਧੂ ਸਰਣਾ ॥",
          "roman": "jat kat pekhau sādhū saraṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਜਿਧਰ ਕਿਧਰ ਵੇਖਦਾ ਹਾਂ, ਕੇਵਲ ਗੁਰੂ ਦੀ ਸਰਨ ਦੀ ਰਾਹੀਂ ਹੀ,"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни смотрел, только через прибежище Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24750,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਇ ਨਿਰਮਲ ਮਨੁ ਕਰਣਾ ॥੩॥",
          "roman": "har guṇ gāe nirmal man karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾ ਗਾ ਕੇ ਮਨ ਨੂੰ ਪਵਿਤ੍ਰ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "воспевая качества Бога, можно очистить ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24751,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਮੇਰਾ ਸੁਆਮੀ ਵੂਠਾ ॥",
          "roman": "ghaṭ ghaṭ antar merā suāmī vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Господь пребывает в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24752,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਪਾਇਆ ਪ੍ਰਭੁ ਤੂਠਾ ॥੪॥੬॥",
          "roman": "nānak nām pāiā prabh tūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਪ੍ਰਭੂ ਪ੍ਰਸੰਨ ਹੁੰਦਾ ਹੈ ਤਾਂ ਉਸ ਦਾ ਨਾਮ (-ਸਿਮਰਨ) ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ, ਹੇ ਨਾਨਕ! ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь доволен, Его Имя обретается, о Нанак."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2165,
      "rahao_verse_id": 24755,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24753,
          "is_rahao": true,
          "gurmukhi": "ਵਡਹੰਸੁ ਮਹਲਾ ੫ ॥",
          "roman": "vaḍhans mahla 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24754,
          "is_rahao": true,
          "gurmukhi": "ਵਿਸਰੁ ਨਾਹੀ ਪ੍ਰਭ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "visar nāhī prabh dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ! ਮੇਰੇ ਤੋਂ ਕਦੇ ਨਾ ਭੁਲ!"
            },
            "sahib_singh_ru": {
              "main": "О милосердный к бедным Господь! Не дай мне забыть Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24755,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੀ ਸਰਣਿ ਪੂਰਨ ਕਿਰਪਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "terī saraṇ pūran kirpālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ, ਹੇ ਸਰਬ-ਵਿਆਪਕ! ਹੇ ਕਿਰਪਾ ਦੇ ਘਰ! ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Я пришёл в Твоё прибежище, о всепроникающий, источник милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24756,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਚਿਤਿ ਆਵਹਿ ਸੋ ਥਾਨੁ ਸੁਹਾਵਾ ॥",
          "roman": "jah chit āvah so thān suhāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਹਿਰਦੇ ਵਿਚ ਤੂੰ ਆ ਵੱਸਦਾ ਹੈਂ ਉਹ ਹਿਰਦਾ-ਥਾਂ ਸੋਹਣਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "То сердце, куда Ты приходишь, становится прекрасным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24757,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਵੇਲਾ ਵਿਸਰਹਿ ਤਾ ਲਾਗੈ ਹਾਵਾ ॥੧॥",
          "roman": "jit velā visrah tā lāgē hāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਵੇਲੇ ਤੂੰ (ਮੈਨੂੰ) ਭੁੱਲ ਜਾਂਦਾ ਹੈ ਤਦੋਂ (ਮੈਨੂੰ) ਹਉਕਾ ਲੱਗਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Ты забываешься, возникает страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24758,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਜੀਅ ਤੂ ਸਦ ਹੀ ਸਾਥੀ ॥",
          "roman": "tere jīa tū sad hī sāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜੀਵ ਤੇਰੇ (ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਹਨ, ਤੂੰ ਸਦਾ ਹੀ ਇਨ੍ਹਾਂ ਦਾ ਮਦਦਗਾਰ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Живые существа — Твои, и Ты всегда их помощник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24759,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰ ਸਾਗਰ ਤੇ ਕਢੁ ਦੇ ਹਾਥੀ ॥੨॥",
          "roman": "sansār sāgar te kaḍh de hāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਆਪਣਾ) ਹੱਥ ਦੇ ਕੇ (ਜੀਵਾਂ ਨੂੰ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ ਕੱਢ ਲੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Протяни руку и выведи их из океана мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24760,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣੁ ਜਾਣਾ ਤੁਮ ਹੀ ਕੀਆ ॥",
          "roman": "āvaṇ jāṇā tum hī kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਤੂੰ ਹੀ ਬਣਾਇਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты сам установил круг рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24761,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂ ਰਾਖਹਿ ਤਿਸੁ ਦੂਖੁ ਨ ਥੀਆ ॥੩॥",
          "roman": "jis tū rākhe tis dūkh na thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਨੂੰ ਤੂੰ (ਇਸ ਗੇੜ ਵਿਚੋਂ) ਬਚਾ ਲੈਂਦਾ ਹੈਂ, ਉਸ ਨੂੰ ਕੋਈ ਦੁਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и тот, кого Ты спасаешь, не испытывает страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24762,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਏਕੋ ਸਾਹਿਬੁ ਅਵਰੁ ਨ ਹੋਰਿ ॥",
          "roman": "tū eko sāhib avar na hor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਹੀ ਇਕ ਮਾਲਕ ਹੈਂ ਐਸਾ ਕੋਈ ਹੋਰ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты один Владыка, другого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24763,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਉ ਕਰੈ ਨਾਨਕੁ ਕਰ ਜੋਰਿ ॥੪॥੭॥",
          "roman": "binau karē nānak kar jor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ (ਤੇਰੇ ਅੱਗੇ) ਹੱਥ ਜੋੜ ਕੇ ਬੇਨਤੀ ਕਰਦਾ ਹੈ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак складывает руки и обращается с просьбой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2166,
      "rahao_verse_id": 24767,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 24764,
          "is_rahao": false,
          "gurmukhi": "ਵਡਹੰਸੁ ਮਃ ੫ ॥",
          "roman": "vaḍhans mahla 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24765,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਜਾਣਾਇਹਿ ਤਾ ਕੋਈ ਜਾਣੈ ॥",
          "roman": "tū jāṇāih tā koī jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜਦੋਂ ਕਿਸੇ ਮਨੁੱਖ ਨੂੰ ਤੂੰ ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈਂ, ਤਦੋਂ ਹੀ ਕੋਈ ਤੇਰੇ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Когда Ты даруешь понимание, тогда человек обретает глубокую связь с Тобой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24766,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਦੀਆ ਨਾਮੁ ਵਖਾਣੈ ॥੧॥",
          "roman": "terā dīā nām vakhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਤੇਰਾ ਬਖ਼ਸ਼ਿਆ ਹੋਇਆ ਤੇਰਾ ਨਾਮ ਉਚਾਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и произносит Твоё дарованное Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 24767,
          "is_rahao": true,
          "gurmukhi": "ਤੂ ਅਚਰਜੁ ਕੁਦਰਤਿ ਤੇਰੀ ਬਿਸਮਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tū acharaj kudrat terī bisamā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਹੈਰਾਨ ਕਰ ਦੇਣ ਵਾਲੀ ਹਸਤੀ ਵਾਲਾ ਹੈਂ ਤੇ ਤੇਰੀ ਰਚੀ ਰਚਨਾ ਭੀ ਹੈਰਾਨਗੀ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — удивительная сущность, и Твоё творение также вызывает изумление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
