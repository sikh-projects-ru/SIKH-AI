{
  "ang": 621,
  "shabads": [
    {
      "shabad_id": 2348,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26829,
          "is_rahao": false,
          "gurmukhi": "ਅਟਲ ਬਚਨੁ ਨਾਨਕ ਗੁਰ ਤੇਰਾ ਸਫਲ ਕਰੁ ਮਸਤਕਿ ਧਾਰਿਆ ॥੨॥੨੧॥੪੯॥",
          "roman": "aṭal bachan nānak gur terā safal kar mastak dhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਗੁਰੂ! ਤੇਰਾ (ਇਹ) ਬਚਨ ਕਦੇ ਟਲਣ ਵਾਲਾ ਨਹੀਂ (ਕਿ ਪਰਮਾਤਮਾ ਹੀ ਜੀਵ ਦਾ ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਰਾਖਾ ਹੈ)। ਹੇ ਗੁਰੂ! ਤੂੰ ਆਪਣਾ ਬਰਕਤਿ ਵਾਲਾ ਹੱਥ (ਅਸਾਂ ਜੀਵਾਂ ਦੇ) ਮੱਥੇ ਉੱਤੇ ਰੱਖਦਾ ਹੈਂ ॥੨॥੨੧॥੪੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Слово Гуру неизменно, и Он благословляет, возлагая руку на голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2349,
      "rahao_verse_id": 26834,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26830,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "sorath mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26831,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ੍ਰ ਸਭਿ ਤਿਸ ਕੇ ਕੀਏ ਸੋਈ ਸੰਤ ਸਹਾਈ ॥",
          "roman": "jīa jantr sabh tis ke kīe soī sant sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਰੇ ਜੀਵ ਉਸ (ਪਰਮਾਤਮਾ) ਦੇ ਹੀ ਪੈਦਾ ਕੀਤੇ ਹੋਏ ਹਨ; ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਸੰਤ ਜਨਾਂ ਦਾ ਮਦਦਗਾਰ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Все живые существа созданы тем Параматмой; именно Он является помощником святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26832,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਸੇਵਕ ਕੀ ਆਪੇ ਰਾਖੈ ਪੂਰਨ ਭਈ ਬਡਾਈ ॥੧॥",
          "roman": "apne sevak kī āpe rākhē pūran bhaī baḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸੇਵਕ ਦੀ (ਇੱਜ਼ਤ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਰੱਖਦਾ ਹੈ (ਉਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ ਸੇਵਕ ਦੀ) ਇੱਜ਼ਤ ਪੂਰੇ ਤੌਰ ਤੇ ਬਣੀ ਰਹਿੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Параматма Сам хранит честь Своего слуги; по Его милости честь слуги полностью сохраняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26833,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਪੂਰਾ ਮੇਰੈ ਨਾਲਿ ॥",
          "roman": "pārbrahm pūrā merē nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰਨ ਪਰਮਾਤਮਾ (ਸਦਾ) ਮੇਰੇ ਅੰਗ-ਸੰਗ (ਸਹਾਈ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Совершенный Параматма всегда со мной рядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26834,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਪੂਰੀ ਸਭ ਰਾਖੀ ਹੋਏ ਸਰਬ ਦਇਆਲ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrē pūrī sabh rākhī hoe sarab dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਚੰਗੀ ਤਰ੍ਹਾਂ ਮੇਰੀ (ਇੱਜ਼ਤ) ਰੱਖ ਲਈ ਹੈ। ਗੁਰੂ ਸਾਰੇ ਜੀਵਾਂ ਉੱਤੇ ਹੀ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру полностью сохранил мою честь; Гуру милостив ко всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26835,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਨਾਨਕੁ ਨਾਮੁ ਧਿਆਏ ਜੀਅ ਪ੍ਰਾਨ ਕਾ ਦਾਤਾ ॥",
          "roman": "anadin nānak nām dhiāe jīa prān kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਨਕ (ਤਾਂ ਉਸ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਹਰ ਵੇਲੇ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ਜੋ ਜਿੰਦ ਦੇਣ ਵਾਲਾ ਹੈ ਜੋ ਸੁਆਸ ਦੇਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Нанак постоянно помнит Имя Параматмы, дающего жизнь и дыхание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26836,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਦਾਸ ਕਉ ਕੰਠਿ ਲਾਇ ਰਾਖੈ ਜਿਉ ਬਾਰਿਕ ਪਿਤ ਮਾਤਾ ॥੨॥੨੨॥੫੦॥",
          "roman": "apne dās kau kanth lāe rākhē jiu bārik pit mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਵੇਂ ਮਾਪੇ ਆਪਣੇ ਬੱਚਿਆਂ ਦਾ ਧਿਆਨ ਰੱਖਦੇ ਹਨ, ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਆਪਣੇ ਸੇਵਕ ਨੂੰ (ਆਪਣੇ) ਗਲ ਨਾਲ ਲਾ ਕੇ ਰੱਖਦਾ ਹੈ ॥੨॥੨੨॥੫੦॥"
            },
            "sahib_singh_ru": {
              "main": "Как родители заботятся о ребёнке, так Параматма обнимает и хранит Своего слугу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2350,
      "rahao_verse_id": 26844,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26837,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ਘਰੁ ੩ ਚਉਪਦੇ",
          "roman": "sorath mehlā 5 ghar 3 chaupade",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੋਰਠਿ, ਘਰ ੩ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਚਾਰ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Рааг Сораṭх, дом 3, банī Гуру Арджан Дев Джи из четырёх строф."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26838,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуракх один и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26839,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਪੰਚਹੁ ਨਹੀ ਸਹਸਾ ਚੁਕਾਇਆ ॥",
          "roman": "mil panchah nahī sahsā chukāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਗਰ ਦੇ ਪੈਂਚਾਂ ਨੂੰ ਮਿਲ ਕੇ (ਕਾਮਾਦਿਕ ਵੈਰੀਆਂ ਤੋਂ ਪੈ ਰਿਹਾ) ਸਹਿਮ ਦੂਰ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Встретившись с пятью советниками, нельзя избавиться от страха перед внутренними врагами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26840,
          "is_rahao": false,
          "gurmukhi": "ਸਿਕਦਾਰਹੁ ਨਹ ਪਤੀਆਇਆ ॥",
          "roman": "sikdārh nah patīāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰਦਾਰਾਂ ਲੋਕਾਂ ਤੋਂ ਭੀ ਤਸੱਲੀ ਨਹੀਂ ਮਿਲ ਸਕਦੀ (ਕਿ ਇਹ ਵੈਰੀ ਤੰਗ ਨਹੀਂ ਕਰਨਗੇ।)"
            },
            "sahib_singh_ru": {
              "main": "Даже у правителей нельзя получить уверенность, что враги не будут тревожить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26841,
          "is_rahao": false,
          "gurmukhi": "ਉਮਰਾਵਹੁ ਆਗੈ ਝੇਰਾ ॥",
          "roman": "umrāvah āgē jherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰਕਾਰੀ ਹਾਕਮਾਂ ਅੱਗੇ ਭੀ ਇਹ ਝਗੜਾ (ਪੇਸ਼ ਕੀਤਿਆਂ ਕੁਝ ਨਹੀਂ ਬਣਦਾ।)"
            },
            "sahib_singh_ru": {
              "main": "И перед государственными властями этот спор не решается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26842,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਰਾਜਨ ਰਾਮ ਨਿਬੇਰਾ ॥੧॥",
          "roman": "mil rājan rām nibērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਪਾਤਿਸ਼ਾਹ ਨੂੰ ਮਿਲ ਕੇ ਫ਼ੈਸਲਾ ਹੋ ਜਾਂਦਾ ਹੈ (ਤੇ, ਕਾਮਾਦਿਕ ਵੈਰੀਆਂ ਦਾ ਡਰ ਮੁੱਕ ਜਾਂਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Встретившись с Господом-Царём, приходит решение и страх исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26843,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਢੂਢਨ ਕਤਹੁ ਨ ਜਾਈ ॥",
          "roman": "ab ḍhūḍhan katah na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ (ਕਾਮਾਦਿਕ ਵੈਰੀਆਂ ਤੋਂ ਪੈ ਰਹੇ ਸਹਿਮ ਤੋਂ ਬਚਣ ਲਈ) ਕਿਸੇ ਹੋਰ ਥਾਂ (ਆਸਰਾ) ਭਾਲਣ ਦੀ ਲੋੜ ਨਾਹ ਰਹਿ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь нет нужды искать убежище где-либо ещё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26844,
          "is_rahao": true,
          "gurmukhi": "ਗੋਬਿਦ ਭੇਟੇ ਗੁਰ ਗੋਸਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "gobind bheṭe gur gosāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੋਬਿੰਦ ਨੂੰ, ਗੁਰੂ ਨੂੰ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਖਸਮ ਨੂੰ ਮਿਲ ਪਏ। ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда встречаешь Гобинда, Гуру, Господа мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26845,
          "is_rahao": false,
          "gurmukhi": "ਆਇਆ ਪ੍ਰਭ ਦਰਬਾਰਾ ॥",
          "roman": "āiā prabh darbārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਦੋਂ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਪਹੁੰਚਦਾ ਹੈ (ਚਿੱਤ ਜੋੜਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда человек приходит в присутствие Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26846,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਸਗਲੀ ਮਿਟੀ ਪੂਕਾਰਾ ॥",
          "roman": "tā saglī miṭī pūkārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਇਸ ਦੀ (ਕਾਮਾਦਿਕ ਵੈਰੀਆਂ ਦੇ ਵਿਰੁੱਧ) ਸਾਰੀ ਸ਼ਿਕੈਤ ਮੁੱਕ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда исчезают все его жалобы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26847,
          "is_rahao": false,
          "gurmukhi": "ਲਬਧਿ ਆਪਣੀ ਪਾਈ ॥",
          "roman": "labdh āpṇī pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਮਨੁੱਖ ਉਹ ਵਸਤ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда человек получает истинное сокровище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26848,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਤ ਆਵੈ ਕਤ ਜਾਈ ॥੨॥",
          "roman": "tā kat āvē kat jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਦਾ ਇਸ ਦੀ ਆਪਣੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ, ਤਦੋਂ ਵਿਕਾਰਾਂ ਦੇ ਢਹੇ ਚੜ੍ਹ ਕੇ ਭਟਕਣੋਂ ਬਚ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "которое остаётся с ним навсегда, и он больше не блуждает во пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26849,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਸਾਚ ਨਿਆਇ ਨਿਬੇਰਾ ॥",
          "roman": "tah sāch niāi nibērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਨਿਆਂ ਅਨੁਸਾਰ (ਕਾਮਾਦਿਕਾਂ ਨਾਲ ਹੋ ਰਹੀ ਟੱਕਰ ਦਾ) ਫ਼ੈਸਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В присутствии Господа решение принимается по вечной истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26850,
          "is_rahao": false,
          "gurmukhi": "ਊਹਾ ਸਮ ਠਾਕੁਰੁ ਸਮ ਚੇਰਾ ॥",
          "roman": "ūhā sam ṭhākur sam cherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਰਗਾਹ ਵਿਚ (ਜਾਬਰਾਂ ਦਾ ਕੋਈ ਲਿਹਾਜ਼ ਨਹੀਂ ਕੀਤਾ ਜਾਂਦਾ) ਮਾਲਕ ਤੇ ਨੌਕਰ ਇਕੋ ਜਿਹਾ ਸਮਝਿਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Там хозяин и слуга считаются равными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26851,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਜਾਨੈ ॥",
          "roman": "antarjāmī jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਪ੍ਰਭੂ (ਹਜ਼ੂਰੀ ਵਿਚ ਪਹੁੰਚੇ ਹੋਏ ਸਵਾਲੀਏ ਦੇ ਦਿਲ ਦੀ) ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Знающий сердца Господь понимает внутреннее состояние каждого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26852,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੋਲਤ ਆਪਿ ਪਛਾਨੈ ॥੩॥",
          "roman": "bin bolat āp pachhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ) ਬੋਲਣ ਤੋਂ ਬਿਨਾਂ ਉਹ ਪ੍ਰਭੂ ਆਪ (ਉਸ ਦੇ ਦਿਲ ਦੀ ਪੀੜਾ ਨੂੰ) ਸਮਝ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Без слов Он Сам понимает боль сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26853,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਥਾਨ ਕੋ ਰਾਜਾ ॥",
          "roman": "sarab thān ko rājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਸਾਰੇ ਥਾਵਾਂ ਦਾ ਮਾਲਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь — владыка всех мест."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26854,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਅਨਹਦ ਸਬਦ ਅਗਾਜਾ ॥",
          "roman": "tah anhad sabad agājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨਾਲ ਮਿਲਾਪ-ਅਵਸਥਾ ਵਿਚ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਇਕ-ਰਸ ਪੂਰਾ ਪ੍ਰਭਾਵ ਪਾ ਲੈਂਦੀ ਹੈ (ਤੇ, ਮਨੁੱਖ ਉੱਤੇ ਕਾਮਾਦਿਕ ਵੈਰੀ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੇ)।"
            },
            "sahib_singh_ru": {
              "main": "В единении с Ним внутри звучит бесконечная хвала и полностью наполняет человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26855,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਪਹਿ ਕਿਆ ਚਤੁਰਾਈ ॥",
          "roman": "tis peh kiā chaturāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਭਾਈ! ਉਸ ਨੂੰ ਮਿਲਣ ਵਾਸਤੇ) ਉਸ ਨਾਲ ਕੋਈ ਚਲਾਕੀ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "К Нему невозможно приблизиться хитростью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26856,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੁ ਨਾਨਕ ਆਪੁ ਗਵਾਈ ॥੪॥੧॥੫੧॥",
          "roman": "mil nānak āp gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ! ਜੇ ਉਸ ਨੂੰ ਮਿਲਣਾ ਹੈ, ਤਾਂ) ਆਪਾ-ਭਾਵ ਗਵਾ ਕੇ (ਉਸ ਨੂੰ) ਮਿਲ ॥੪॥੧॥੫੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Встреть Его, отбросив эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2351,
      "rahao_verse_id": 26863,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26857,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "sorath mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26858,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਨਾਮੁ ਵਸਾਇਹੁ ॥",
          "roman": "hirdē nām vasāih",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵਸਾਈ ਰੱਖੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Удерживайте Имя Господа в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26859,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਬੈਠੇ ਗੁਰੂ ਧਿਆਇਹੁ ॥",
          "roman": "ghar bēṭhe gur dhiāih",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਤਰ-ਆਤਮੇ ਟਿਕ ਕੇ ਗੁਰੂ ਦਾ ਧਿਆਨ ਧਰਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Пребывая внутри, медитируйте на Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26860,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਸਚੁ ਕਹਿਆ ॥",
          "roman": "gur pūrē sach kahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪੂਰੇ ਗੁਰੂ ਨੇ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ (ਦੇ ਸਿਮਰਨ) ਦਾ ਉਪਦੇਸ਼ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому совершенный Гуру дал наставление помнить Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26861,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੁ ਸਾਚਾ ਲਹਿਆ ॥੧॥",
          "roman": "so sukh sāchā lahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਉਹ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਜੋ ਸਦਾ ਕਾਇਮ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "он обретает истинное вечное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26862,
          "is_rahao": true,
          "gurmukhi": "ਅਪੁਨਾ ਹੋਇਓ ਗੁਰੁ ਮਿਹਰਵਾਨਾ ॥",
          "roman": "apnā hoio gur mihravānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਉਤੇ ਪਿਆਰਾ ਗੁਰੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! На кого милостив Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26863,
          "is_rahao": true,
          "gurmukhi": "ਅਨਦ ਸੂਖ ਕਲਿਆਣ ਮੰਗਲ ਸਿਉ ਘਰਿ ਆਏ ਕਰਿ ਇਸਨਾਨਾ ॥ ਰਹਾਉ ॥",
          "roman": "anad sūkh kalyāṇ maṅgal siu ghar āe kar isnānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਨਾਮ-ਜਲ ਨਾਲ ਮਨ ਨੂੰ ਪਵਿਤ੍ਰ ਕਰ ਕੇ ਆਤਮਕ ਆਨੰਦ ਸੁਖ ਖ਼ੁਸ਼ੀਆਂ ਨਾਲ ਭਰਪੂਰ ਹੋ ਕੇ ਅੰਤਰ-ਆਤਮੇ ਟਿਕ ਜਾਂਦੇ ਹਨ (ਵਿਕਾਰਾਂ ਆਦਿਕਾਂ ਵਲ ਭਟਕਣੋਂ ਹਟ ਜਾਂਦੇ ਹਨ) ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "те, очистив ум Имением, пребывают внутри в радости и счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26864,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਗੁਰ ਵਡਿਆਈ ॥",
          "roman": "sāchī gur vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਆਤਮਕ ਉੱਚਤਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Величие Гуру вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26865,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈ ॥",
          "roman": "tā kī kīmat kahan na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਕਦਰ-ਕੀਮਤ ਨਹੀਂ ਦੱਸੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Его ценность невозможно выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26866,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਿ ਸਾਹਾ ਪਾਤਿਸਾਹਾ ॥",
          "roman": "sir sāhā pātisāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ (ਦੁਨੀਆ ਦੇ) ਸ਼ਾਹ ਦੇ ਸਿਰ ਉੱਤੇ ਪਾਤਿਸ਼ਾਹ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — царь над царями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26867,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਭੇਟਤ ਮਨਿ ਓਮਾਹਾ ॥੨॥",
          "roman": "gur bheṭat man omāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ ਮਨ ਵਿਚ (ਹਰੀ-ਨਾਮ ਸਿਮਰਨ ਦਾ) ਚਾਉ ਪੈਦਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "При встрече с Гуру в сердце возникает радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26868,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਪਰਾਛਤ ਲਾਥੇ ॥",
          "roman": "sagal parāchhat lāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਰੇ ਪਾਪ ਲਹਿ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Все грехи исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26869,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਾਧਸੰਗਤਿ ਕੈ ਸਾਥੇ ॥",
          "roman": "mil sādhsaṅgat kē sāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ। (ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ)"
            },
            "sahib_singh_ru": {
              "main": "В общении со святыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26870,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਨਿਧਾਨ ਹਰਿ ਨਾਮਾ ॥",
          "roman": "guṇ nidhān har nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਹਰਿ ਨਾਮ ਨੂੰ-"
            },
            "sahib_singh_ru": {
              "main": "Имя Господа — сокровище всех качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26871,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਪੂਰਨ ਹੋਏ ਕਾਮਾ ॥੩॥",
          "roman": "jap pūran hoe kāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਪ ਜਪ ਕੇ (ਜ਼ਿੰਦਗੀ ਦੇ) ਸਾਰੇ ਮਨੋਰਥ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя его, исполняются все цели жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26872,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਕੀਨੋ ਮੁਕਤਿ ਦੁਆਰਾ ॥",
          "roman": "gur kīno mukt duārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਨੇ (ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਦਾ ਇਕ ਐਸਾ) ਦਰਵਾਜ਼ਾ ਤਿਆਰ ਕਰ ਦਿੱਤਾ ਹੈ (ਜੋ ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ (ਕਰਾ ਦੇਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру открыл дверь освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26873,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਸ੍ਰਿਸਟਿ ਕਰੈ ਜੈਕਾਰਾ ॥",
          "roman": "sabh srisṭ karē jēkārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਇਸ ਦਾਤਿ ਦੇ ਕਾਰਨ) ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ (ਗੁਰੂ ਦੀ) ਸੋਭਾ ਕਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вся вселенная восхваляет его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26874,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭੁ ਮੇਰੈ ਸਾਥੇ ॥",
          "roman": "nānak prabh merē sāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹਰਿ-ਨਾਮ ਹਿਰਦੇ ਵਿਚ ਵਸਾਇਆਂ) ਪਰਮਾਤਮਾ ਮੇਰੇ ਅੰਗ-ਸੰਗ (ਵੱਸਦਾ ਪ੍ਰਤੀਤ ਹੋ ਰਿਹਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Господь со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26875,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਭੈ ਲਾਥੇ ॥੪॥੨॥੫੨॥",
          "roman": "janam maraṇ bhē lāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਜਨਮ ਮਰਨ ਦੇ ਸਾਰੇ ਡਰ ਲਹਿ ਗਏ ਹਨ ॥੪॥੨॥੫੨॥"
            },
            "sahib_singh_ru": {
              "main": "Страх рождения и смерти исчез."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2352,
      "rahao_verse_id": 26882,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26876,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "sorath mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26877,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "gur pūrē kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਜਦੋਂ ਤੋਂ) ਪੂਰੇ ਗੁਰੂ ਨੇ ਮੇਹਰ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда совершенный Гуру проявил милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26878,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਪੂਰੀ ਲੋਚ ਹਮਾਰੀ ॥",
          "roman": "prabh pūrī loch hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਸਾਡੀ (ਨਾਮ ਸਿਮਰਨ ਦੀ) ਤਾਂਘ ਪੂਰੀ ਕਰ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь исполнил наше желание помнить Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26879,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਇਸਨਾਨੁ ਗ੍ਰਿਹਿ ਆਏ ॥",
          "roman": "kar isnān grih āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਆਤਮਕ ਇਸ਼ਨਾਨ ਕਰ ਕੇ ਅਸੀਂ ਅੰਤਰ-ਆਤਮੇ ਟਿਕੇ ਰਹਿੰਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Омывшись духовно, мы пребываем внутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26880,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਮੰਗਲ ਸੁਖ ਪਾਏ ॥੧॥",
          "roman": "anad maṅgal sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਆਨੰਦ ਆਤਮਕ ਖ਼ੁਸ਼ੀਆਂ ਆਤਮਕ ਸੁਖ ਮਾਣ ਰਹੇ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Испытываем духовную радость и счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26881,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਰਾਮ ਨਾਮਿ ਨਿਸਤਰੀਐ ॥",
          "roman": "santah rām nām nistarīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ (ਜੁੜਿਆਂ ਹੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! Только через Имя Господа можно переплыть мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26882,
          "is_rahao": true,
          "gurmukhi": "ਊਠਤ ਬੈਠਤ ਹਰਿ ਹਰਿ ਧਿਆਈਐ ਅਨਦਿਨੁ ਸੁਕ੍ਰਿਤੁ ਕਰੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ūṭhat bēṭhat har har dhiāīē anadin sukrīt karīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਉਠਦਿਆਂ ਬੈਠਦਿਆਂ ਹਰ ਵੇਲੇ ਹਰਿ-ਨਾਮ ਸਿਮਰਨਾ ਚਾਹੀਦਾ ਹੈ, (ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਦੀ ਇਹ) ਨੇਕ ਕਮਾਈ ਹਰ ਵੇਲੇ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому всегда, вставая и сидя, нужно помнить Имя и совершать это доброе дело постоянно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
