{
  "ang": 622,
  "shabads": [
    {
      "shabad_id": 2352,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26883,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਾ ਮਾਰਗੁ ਧਰਮ ਕੀ ਪਉੜੀ ਕੋ ਵਡਭਾਗੀ ਪਾਏ ॥",
          "roman": "sant kā mārag dharam kī pauṛī ko vaḍbhāgī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਸਿਮਰਨ ਕਰਨਾ ਹੀ ਇਨਸਾਨ ਵਾਸਤੇ) ਗੁਰੂ ਦਾ (ਦੱਸਿਆ ਹੋਇਆ ਸਹੀ) ਰਸਤਾ ਹੈ, (ਸਿਮਰਨ ਹੀ) ਧਰਮ ਦੀ ਪਉੜੀ ਹੈ (ਜਿਸ ਦੀ ਰਾਹੀਂ ਮਨੁੱਖ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਪਹੁੰਚ ਸਕਦਾ ਹੈ, ਪਰ) ਕੋਈ ਵਿਰਲਾ ਭਾਗਾਂ ਵਾਲਾ (ਇਹ ਪਉੜੀ) ਲੱਭਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Путь Гуру — это истинный путь, лестница дхармы, которую находит лишь редкий счастливый."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26884,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਕੇ ਕਿਲਬਿਖ ਨਾਸੇ ਹਰਿ ਚਰਣੀ ਚਿਤੁ ਲਾਏ ॥੨॥",
          "roman": "koṭ janam ke kilbikh nāse har charṇī chit lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ (ਸਿਮਰਨ ਦੀ ਰਾਹੀਂ) ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਚਿੱਤ ਜੋੜਦਾ ਹੈ, ਉਸ ਦੇ ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਦੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто соединяет ум с ногами Господа, уничтожает грехи многих жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26885,
          "is_rahao": false,
          "gurmukhi": "ਉਸਤਤਿ ਕਰਹੁ ਸਦਾ ਪ੍ਰਭ ਅਪਨੇ ਜਿਨਿ ਪੂਰੀ ਕਲ ਰਾਖੀ ॥",
          "roman": "ustat karah sadā prabh apne jin pūrī kal rākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ (ਸਾਰੇ ਸੰਸਾਰ ਵਿਚ ਆਪਣੀ) ਪੂਰੀ ਸੱਤਿਆ ਟਿਕਾ ਰੱਖੀ ਹੈ, ਉਸ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸਦਾ ਕਰਦੇ ਰਿਹਾ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда восхваляйте Господа, который утвердил Свою силу во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26886,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਭਿ ਭਏ ਪਵਿਤ੍ਰਾ ਸਤਿਗੁਰ ਕੀ ਸਚੁ ਸਾਖੀ ॥੩॥",
          "roman": "jīa jant sabh bhae pavitrā satgur kī sach sākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਸਾਰੇ ਹੀ ਪ੍ਰਾਣੀ ਸੁੱਚੇ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ, ਜੇਹੜੇ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਵਾਲੀ ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਨੂੰ ਗ੍ਰਹਿਣ ਕਰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Все существа становятся чистыми, принимая истинное учение Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26887,
          "is_rahao": false,
          "gurmukhi": "ਬਿਘਨ ਬਿਨਾਸਨ ਸਭਿ ਦੁਖ ਨਾਸਨ ਸਤਿਗੁਰਿ ਨਾਮੁ ਦ੍ਰਿੜਾਇਆ ॥",
          "roman": "bighan bināsan sabh dukh nāsan satgur nām driṛāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਨ ਦੇ ਰਸਤੇ ਵਿਚੋਂ ਸਾਰੀਆਂ) ਰੁਕਾਵਟਾਂ ਦੂਰ ਕਰਨ ਵਾਲਾ, ਸਾਰੇ ਦੁੱਖ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਗੁਰੂ ਨੇ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪੱਕਾ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тем, кому Гуру утвердил Имя, оно устраняет препятствия и уничтожает страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26888,
          "is_rahao": false,
          "gurmukhi": "ਖੋਏ ਪਾਪ ਭਏ ਸਭਿ ਪਾਵਨ ਜਨ ਨਾਨਕ ਸੁਖਿ ਘਰਿ ਆਇਆ ॥੪॥੩॥੫੩॥",
          "roman": "khoe pāp bhae sabh pāvan jan nānak sukh ghar āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਹਨਾਂ ਦੇ ਸਾਰੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਹ ਸਾਰੇ ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ, ਉਹ ਆਤਮਕ ਆਨੰਦ ਨਾਲ ਅੰਤਰ-ਆਤਮੇ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੩॥੫੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Их грехи исчезают, они становятся чистыми и пребывают в блаженстве внутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2353,
      "rahao_verse_id": 26895,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26889,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26890,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬੁ ਗੁਨੀ ਗਹੇਰਾ ॥",
          "roman": "sāhib guṇī gaherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭ ਦਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਗੁਣਾਂ ਦਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਡੂੰਘੇ ਜਿਗਰੇ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — владыка всех, Ты — владыка качеств, Ты — обладаешь глубокой сущностью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26891,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ਲਸਕਰੁ ਸਭੁ ਤੇਰਾ ॥",
          "roman": "ghar laskār sabh terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਨੂੰ) ਸਾਰਾ ਘਰ-ਘਾਟ ਤੇਰਾ ਹੀ ਦਿੱਤਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё жилище и всё имущество дано Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26892,
          "is_rahao": false,
          "gurmukhi": "ਰਖਵਾਲੇ ਗੁਰ ਗੋਪਾਲਾ ॥",
          "roman": "rakhvāle gur gopālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤੋਂ ਵੱਡੇ! ਹੇ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਣਹਾਰ! ਹੇ ਸਭ ਜੀਵਾਂ ਦੇ ਰਾਖੇ!"
            },
            "sahib_singh_ru": {
              "main": "О Высший! О Хранитель мира! О Защитник всех существ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26893,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜੀਅ ਭਏ ਦਇਆਲਾ ॥੧॥",
          "roman": "sabh jīa bhae dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਰੇ ਜੀਵਾਂ ਉੱਤੇ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты милостив ко всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26894,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਅਨਦਿ ਰਹਉ ਗੁਰ ਚਰਣਾ ॥",
          "roman": "jap anad rahau gur charnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਨੂੰ ਹਿਰਦੇ ਵਿਚ ਵਸਾ ਕੇ ਮੈਂ ਆਤਮਕ ਆਨੰਦ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Удерживая стопы Гуру в сердце, я пребываю в духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26895,
          "is_rahao": true,
          "gurmukhi": "ਭਉ ਕਤਹਿ ਨਹੀ ਪ੍ਰਭ ਸਰਣਾ ॥ ਰਹਾਉ ॥",
          "roman": "bhau kateh nahī prabh sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੀ ਸ਼ਰਨ ਪਿਆਂ ਕਿਤੇ ਭੀ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! В прибежище Бога никакой страх не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26896,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਿਆ ਦਾਸਾ ਰਿਦੈ ਮੁਰਾਰੀ ॥",
          "roman": "teriā dāsā ridē murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਸੇਵਕਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਹੀ ਨਾਮ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! В сердцах Твоих слуг пребывает Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26897,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਅਬਿਚਲ ਨੀਵ ਉਸਾਰੀ ॥",
          "roman": "prabh abichal nīv usārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ (ਆਪਣੇ ਦਾਸਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਭਗਤੀ ਦੀ) ਕਦੇ ਨਾਹ ਹਿੱਲਣ ਵਾਲੀ ਨੀਂਹ ਰੱਖ ਦਿੱਤੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты утвердил в их сердцах неколебимое основание преданности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26898,
          "is_rahao": false,
          "gurmukhi": "ਬਲੁ ਧਨੁ ਤਕੀਆ ਤੇਰਾ ॥",
          "roman": "bal dhan takīā terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਹੀ ਮੇਰਾ ਬਲ ਹੈਂ, ਤੂੰ ਹੀ ਮੇਰਾ ਧਨ ਹੈ, ਤੇਰਾ ਹੀ ਮੈਨੂੰ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — моя сила, Ты — моё богатство, Ты — моя опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26899,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਭਾਰੋ ਠਾਕੁਰੁ ਮੇਰਾ ॥੨॥",
          "roman": "tū bhāro ṭhākur merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੇਰਾ ਸਭ ਤੋਂ ਵੱਡਾ ਮਾਲਕ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — мой величайший Господин."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26900,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਿਨਿ ਸਾਧਸੰਗੁ ਪਾਇਆ ॥",
          "roman": "jin jin sādhsaṅg pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਪ੍ਰਾਪਤ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каждый, кто обрёл общество святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26901,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪ੍ਰਭਿ ਆਪਿ ਤਰਾਇਆ ॥",
          "roman": "so prabh āp tarāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਆਪ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того Сам Господь переправил через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26902,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਨਾਮ ਰਸੁ ਦੀਆ ॥",
          "roman": "kar kirpā nām ras dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਮੇਹਰ ਕਰ ਕੇ ਆਪਣੇ ਨਾਮ ਦਾ ਸੁਆਦ ਬਖ਼ਸ਼ਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кому Господь по милости дал вкус Своего Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26903,
          "is_rahao": false,
          "gurmukhi": "ਕੁਸਲ ਖੇਮ ਸਭ ਥੀਆ ॥੩॥",
          "roman": "kusal khem sabh thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в том всегда пребывает духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26904,
          "is_rahao": false,
          "gurmukhi": "ਹੋਏ ਪ੍ਰਭੂ ਸਹਾਈ ॥",
          "roman": "hoe prabhū sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਦਦਗਾਰ ਬਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому, кому Бог становится помощником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26905,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਉਠਿ ਲਾਗੀ ਪਾਈ ॥",
          "roman": "sabh uṭh lāgī pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀ ਲੁਕਾਈ ਉਸ ਦੇ ਪੈਰੀਂ ਉੱਠ ਕੇ ਆ ਲੱਗਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "все люди склоняются к его стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26906,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਪ੍ਰਭੁ ਧਿਆਈਐ ॥",
          "roman": "sās sās prabh dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "С каждым дыханием следует медитировать на Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26907,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮੰਗਲੁ ਨਾਨਕ ਗਾਈਐ ॥੪॥੪॥੫੪॥",
          "roman": "har maṅgal nānak gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਦਾ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ ॥੪॥੪॥੫੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Нужно всегда воспевать славу Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2354,
      "rahao_verse_id": 26914,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26908,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26909,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦਾ ॥",
          "roman": "sūkh sahaj ānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੇਰੇ ਅੰਦਰ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਆਨੰਦ ਬਣੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Во мне пребывает радость духовного равновесия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26910,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਮਿਲਿਓ ਮਨਿ ਭਾਵੰਦਾ ॥",
          "roman": "prabh miliō man bhāvaṅdā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ) ਮਨ ਵਿਚ ਪਿਆਰਾ ਲੱਗਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਮਿਲ ਪਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я встретил в сердце любимого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26911,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਗੁਰਿ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "pūrē gur kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੋਂ) ਪੂਰੇ ਗੁਰੂ ਨੇ (ਮੇਰੇ ਉੱਤੇ) ਮੇਹਰ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "С тех пор как совершенный Гуру оказал милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26912,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਗਤਿ ਭਈ ਹਮਾਰੀ ॥੧॥",
          "roman": "tā gat bhaī hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੀ ਮੇਰੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਗਈ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "моё духовное состояние стало возвышенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26913,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੀ ਪ੍ਰੇਮ ਭਗਤਿ ਮਨੁ ਲੀਨਾ ॥",
          "roman": "har kī prem bhagat man līnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੀ ਪਿਆਰ-ਭਰੀ ਭਗਤੀ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Чей ум погружён в любовное поклонение Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26914,
          "is_rahao": true,
          "gurmukhi": "ਨਿਤ ਬਾਜੇ ਅਨਹਤ ਬੀਨਾ ॥ ਰਹਾਉ ॥",
          "roman": "nit bāje anhat bīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਸਦਾ ਇਕ-ਰਸ (ਆਤਮਕ ਆਨੰਦ ਦੀ, ਮਾਨੋ,) ਬੀਣਾ ਵੱਜਦੀ ਰਹਿੰਦੀ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "внутри него постоянно звучит беззвучная мелодия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26915,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਣ ਕੀ ਓਟ ਸਤਾਣੀ ॥",
          "roman": "har charaṇ kī oṭ satāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਦਾ ਬਲਵਾਨ ਆਸਰਾ ਲੈ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто принял сильное прибежище стоп Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26916,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਚੂਕੀ ਕਾਣਿ ਲੋਕਾਣੀ ॥",
          "roman": "sabh chūkī kāṇ lokāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ ਦੇ ਲੋਕਾਂ ਵਾਲੀ ਉਸ ਦੀ ਸਾਰੀ ਮੁਥਾਜੀ ਮੁੱਕ ਗਈ।"
            },
            "sahib_singh_ru": {
              "main": "освободился от зависимости от людей мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26917,
          "is_rahao": false,
          "gurmukhi": "ਜਗਜੀਵਨੁ ਦਾਤਾ ਪਾਇਆ ॥",
          "roman": "jagjīvan dātā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਜਗਤ ਦਾ ਸਹਾਰਾ ਦਾਤਾਰ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он обретает дающего поддержку всему миру Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26918,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸਕਿ ਰਸਕਿ ਗੁਣ ਗਾਇਆ ॥੨॥",
          "roman": "har rasak rasak guṇ gāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਬੜੇ ਪ੍ਰੇਮ ਨਾਲ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он с любовью воспевает качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26919,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਾਟਿਆ ਜਮ ਕਾ ਫਾਸਾ ॥",
          "roman": "prabh kāṭiā jam kā fāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰੀ ਭੀ ਪ੍ਰਭੂ ਨੇ ਜਮ ਦੀ ਫਾਹੀ ਕੱਟ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь разорвал петлю смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26920,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਪੂਰਨ ਹੋਈ ਆਸਾ ॥",
          "roman": "man pūran hoī āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਮਨ ਦੀ (ਇਹ ਚਿਰਾਂ ਦੀ) ਆਸ ਪੂਰੀ ਹੋ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Желание моего сердца исполнилось."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26921,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਪੇਖਾ ਤਹ ਸੋਈ ॥",
          "roman": "jah pekhā tah soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਜਿਧਰ ਵੇਖਦਾ ਹਾਂ, ਉੱਧਰ ਮੈਨੂੰ ਇੱਕ ਪਰਮਾਤਮਾ ਹੀ ਦਿਖਾਈ ਦਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни смотрел, вижу лишь одного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26922,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪ੍ਰਭ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ॥੩॥",
          "roman": "har prabh bin avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਦਿਖਾਈ ਨਹੀਂ ਦੇਂਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Кроме Бога нет никого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26923,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਰਾਖੇ ॥",
          "roman": "kar kirpā prabh rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਕਿਰਪਾ ਕਰ ਕੇ ਜਿਨ੍ਹਾਂ ਦੀ ਰੱਖਿਆ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Кого Господь по милости защитил,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26924,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜਨਮ ਜਨਮ ਦੁਖ ਲਾਥੇ ॥",
          "roman": "sabh janam janam dukh lāthē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਸਾਰੇ ਦੁੱਖ ਦੂਰ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "у того исчезли страдания многих жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26925,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "nirbhau nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੇ ਨਿਰਭਉ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Кто медитировал на Имя бесстрашного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26926,
          "is_rahao": false,
          "gurmukhi": "ਅਟਲ ਸੁਖੁ ਨਾਨਕ ਪਾਇਆ ॥੪॥੫॥੫੫॥",
          "roman": "aṭal sukh nānak pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਨੇ ਉਹ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਜੋ ਕਦੇ ਦੂਰ ਨਹੀਂ ਹੁੰਦਾ ॥੪॥੫॥੫੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! тот обрёл неизменное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2355,
      "rahao_verse_id": 26933,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26927,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26928,
          "is_rahao": false,
          "gurmukhi": "ਠਾਢਿ ਪਾਈ ਕਰਤਾਰੇ ॥",
          "roman": "ṭhāḍ pāī kartāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਕਰਤਾਰ ਨੇ ਠੰਡ ਵਰਤਾ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кому Творец даровал прохладу внутри,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26929,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪੁ ਛੋਡਿ ਗਇਆ ਪਰਵਾਰੇ ॥",
          "roman": "tāp choḍ giā parvāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਪਰਵਾਰ ਨੂੰ (ਉਸ ਦੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਨੂੰ ਵਿਕਾਰਾਂ ਦਾ) ਤਾਪ ਛੱਡ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того покидает жар пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26930,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਹੈ ਰਾਖੀ ॥",
          "roman": "gur pūrē hē rākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰੇ ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਦੀ ਮਦਦ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кому помог совершенный Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26931,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਸਚੇ ਕੀ ਤਾਕੀ ॥੧॥",
          "roman": "saraṇ sache kī tākī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਤੱਕ ਲਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот обратился к прибежищу вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26932,
          "is_rahao": true,
          "gurmukhi": "ਪਰਮੇਸਰੁ ਆਪਿ ਹੋਆ ਰਖਵਾਲਾ ॥",
          "roman": "parmesar āp hoā rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਰਾਖਾ ਪਰਮਾਤਮਾ ਆਪ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Чьим защитником становится Сам Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26933,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਸਹਜ ਸੁਖ ਖਿਨ ਮਹਿ ਉਪਜੇ ਮਨੁ ਹੋਆ ਸਦਾ ਸੁਖਾਲਾ ॥ ਰਹਾਉ ॥",
          "roman": "sānt sahaj sukh khin meh upje man hoā sadā sukhālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਸਦਾ ਵਾਸਤੇ ਸੁਖੀ ਹੋ ਜਾਂਦਾ ਹੈ (ਕਿਉਂਕਿ ਉਸ ਦੇ ਅੰਦਰ) ਇਕ ਛਿਨ ਵਿਚ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਤੇ ਸ਼ਾਂਤੀ ਪੈਦਾ ਹੋ ਜਾਂਦੇ ਹਨ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "его ум становится навсегда счастливым, ибо в нём мгновенно рождаются покой и духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26934,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਦੀਓ ਦਾਰੂ ॥",
          "roman": "har har nām dīo dārū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਵਿਕਾਰ-ਰੋਗਾਂ ਦਾ ਇਲਾਜ ਕਰਨ ਵਾਸਤੇ ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਦਵਾਈ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кому Гуру дал Имя как лекарство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26935,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਗਲਾ ਰੋਗੁ ਬਿਦਾਰੂ ॥",
          "roman": "tin saglā rog bidārū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਨਾਮ-ਦਾਰੂ) ਨੇ ਉਸ ਮਨੁੱਖ ਦਾ ਸਾਰਾ ਹੀ (ਵਿਕਾਰ-) ਰੋਗ ਕੱਟ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "то лекарство уничтожило все болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26936,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੀ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "apṇī kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਨੇ ਉਸ ਮਨੁੱਖ ਉਤੇ ਆਪਣੀ ਮੇਹਰ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь проявил милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26937,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਗਲੀ ਬਾਤ ਸਵਾਰੀ ॥੨॥",
          "roman": "tin saglī bāt savārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਸ ਨੇ ਆਪਣੀ ਸਾਰੀ ਜੀਵਨ-ਕਹਾਣੀ ਹੀ ਸੋਹਣੀ ਬਣਾ ਲਈ (ਆਪਣਾ ਸਾਰਾ ਜੀਵਨ ਸੰਵਾਰ ਲਿਆ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот устроил всю свою жизнь прекрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26938,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਅਪਨਾ ਬਿਰਦੁ ਸਮਾਰਿਆ ॥",
          "roman": "prabh apnā birad samāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਨੇ (ਸਦਾ ਹੀ) ਆਪਣੇ ਮੁੱਢ-ਕਦੀਮਾਂ ਦੇ (ਪਿਆਰ ਵਾਲੇ) ਸੁਭਾਵ ਨੂੰ ਚੇਤੇ ਰੱਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь хранит Свою древнюю природу любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26939,
          "is_rahao": false,
          "gurmukhi": "ਹਮਰਾ ਗੁਣੁ ਅਵਗੁਣੁ ਨ ਬੀਚਾਰਿਆ ॥",
          "roman": "hamrā guṇ avguṇ na bīchāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਡਾ ਜੀਵਾਂ ਦਾ ਕੋਈ ਗੁਣ ਜਾਂ ਔਗੁਣ ਦਿਲ ਤੇ ਲਾ ਨਹੀਂ ਰੱਖਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он не учитывает наши достоинства и недостатки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26940,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਭਇਓ ਸਾਖੀ ॥",
          "roman": "gur kā sabad bhaiō sākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੇ ਆਪਣਾ ਪ੍ਰਭਾਵ ਪਾਇਆ,"
            },
            "sahib_singh_ru": {
              "main": "В ком Слово Гуру проявило свою силу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
