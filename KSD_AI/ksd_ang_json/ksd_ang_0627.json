{
  "ang": 627,
  "shabads": [
    {
      "shabad_id": 2370,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27154,
          "is_rahao": false,
          "gurmukhi": "ਜਿ ਕਰਾਵੈ ਸੋ ਕਰਣਾ ॥",
          "roman": "j karāvē so karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਜੀਵ ਉਹੀ ਕੁਝ ਕਰ ਸਕਦੇ ਹਾਂ ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਸਾਥੋਂ ਕਰਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мы можем делать только то, что Бог заставляет нас делать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27155,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤੇਰੀ ਸਰਣਾ ॥੨॥੭॥੭੧॥",
          "roman": "nānak dās terī sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੇ ਦਾਸ ਤੇਰੀ ਹੀ ਸ਼ਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ ॥੨॥੭॥੭੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Твои слуги всегда пребывают в Твоём прибежище ॥2॥7॥71॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2371,
      "rahao_verse_id": 27162,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27156,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27157,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਰਿਦੈ ਪਰੋਇਆ ॥",
          "roman": "har nām ridē paro-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਦੋਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹਿਰਦੇ ਵਿਚ ਚੰਗੀ ਤਰ੍ਹਾਂ ਵਸਾ ਲਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! когда имя Бога хорошо утверждается в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27158,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਾਜੁ ਹਮਾਰਾ ਹੋਇਆ ॥",
          "roman": "sabh kāj hamārā ho-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਅਸਾਂ ਜੀਵਾਂ ਦਾ ਸਾਰਾ ਜੀਵਨ-ਮਨੋਰਥ ਸਫਲ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда вся цель нашей жизни достигается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27159,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਚਰਣੀ ਮਨੁ ਲਾਗਾ ॥",
          "roman": "prabh charṇī man lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! ум такого человека пребывает в стопах Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27160,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਜਾ ਕੇ ਭਾਗਾ ॥੧॥",
          "roman": "pūraṇ jā ke bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਭਾਗ ਚੰਗੀ ਤਰ੍ਹਾਂ ਜਾਗ ਪੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чьи судьбы полностью пробуждены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27161,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲਿ ਸਾਧਸੰਗਿ ਹਰਿ ਧਿਆਇਆ ॥",
          "roman": "mil sādhsaṅg har dhiā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਭੀ ਮਨੁੱਖ ਨੇ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! тот, кто в святом собрании медитировал на Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27162,
          "is_rahao": true,
          "gurmukhi": "ਆਠ ਪਹਰ ਅਰਾਧਿਓ ਹਰਿ ਹਰਿ ਮਨ ਚਿੰਦਿਆ ਫਲੁ ਪਾਇਆ ॥ ਰਹਾਉ ॥",
          "roman": "āṭh pahar arādhio har har man chindiā phal pā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਯਾਦ ਕੀਤਾ, ਉਸ ਨੇ ਹਰੇਕ ਮਨ-ਮੰਗੀ ਮੁਰਾਦ ਪਾ ਲਈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "кто восемь прахаров помнил Бога, тот получил все желания сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27163,
          "is_rahao": false,
          "gurmukhi": "ਪਰਾ ਪੂਰਬਲਾ ਅੰਕੁਰੁ ਜਾਗਿਆ ॥",
          "roman": "parā pūrablā aṅkur jāgiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਜਦੋਂ ਕਿਸੇ ਮਨੁੱਖ ਦੇ) ਅਨੇਕਾਂ ਪੂਰਬਲੇ ਜਨਮਾਂ ਦੇ ਸੰਸਕਾਰਾਂ ਦਾ ਬੀਜ ਉੱਗ ਪੈਂਦਾ ਹੈ (ਪੂਰਬਲੇ ਸੰਸਕਾਰ ਜਾਗ ਪੈਂਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "когда в святом собрании пробуждаются семена прежних жизней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27164,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮਿ ਮਨੁ ਲਾਗਿਆ ॥",
          "roman": "rām nām man lāgiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਉਸ ਦਾ) ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда ум начинает пребывать в имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27165,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਹਰਿ ਦਰਸਿ ਸਮਾਵੈ ॥",
          "roman": "man tan har dars samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮਨੋਂ ਤਨੋਂ ਪਰਮਾਤਮਾ ਦੇ ਦੀਦਾਰ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "такой человек умом и телом погружается в созерцание Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27166,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਚੇ ਗੁਣ ਗਾਵੈ ॥੨॥੮॥੭੨॥",
          "roman": "nānak dās sache guṇ gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥੮॥੭੨॥"
            },
            "sahib_singh_ru": {
              "main": "о слуга Нанак говорит: он поёт качества вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2372,
      "rahao_verse_id": 27173,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27167,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27168,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਪ੍ਰਭੂ ਚਿਤਾਰਿਆ ॥",
          "roman": "gur mil prabhū chitāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਜਿਸ ਮਨੁੱਖ ਨੇ) ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਨੂੰ ਯਾਦ ਕਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! тот, кто, встретив Гуру, начал помнить Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27169,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜ ਸਭਿ ਸਵਾਰਿਆ ॥",
          "roman": "kāraj sabh savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਆਪਣੇ ਸਾਰੇ ਕੰਮ ਸਵਾਰ ਲਏ।"
            },
            "sahib_singh_ru": {
              "main": "он устроил все свои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27170,
          "is_rahao": false,
          "gurmukhi": "ਮੰਦਾ ਕੋ ਨ ਅਲਾਏ ॥",
          "roman": "mandā ko na alā-e",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਕਿਸੇ ਨੂੰ) ਕੋਈ ਭੈੜੇ ਬੋਲ ਨਹੀਂ ਬੋਲਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "он никому не говорит дурных слов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27171,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਜੈ ਜੈ ਕਾਰੁ ਸੁਣਾਏ ॥੧॥",
          "roman": "sabh jē jē kār suṇā-e",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੀ ਲੁਕਾਈ ਨੂੰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਹੀ ਸੁਣਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "он всем возвещает лишь хвалу Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27172,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਸਾਚੀ ਸਰਣਿ ਸੁਆਮੀ ॥",
          "roman": "santah sāchī saraṇ suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਮਾਲਕ-ਪ੍ਰਭੂ ਦਾ ਆਸਰਾ ਪੱਕਾ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! прибежище Господа — истинное прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27173,
          "is_rahao": true,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਭਿ ਹਾਥਿ ਤਿਸੈ ਕੈ ਸੋ ਪ੍ਰਭੁ ਅੰਤਰਜਾਮੀ ॥ ਰਹਾਉ ॥",
          "roman": "jīa jant sabh hāth tisē kē so prabh antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਰੇ ਜੀਵ ਉਸ ਪ੍ਰਭੂ ਦੇ ਹੱਥ ਵਿਚ ਹਨ, ਅਤੇ, ਉਹ ਪ੍ਰਭੂ ਹਰੇਕ ਜੀਵ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "ибо все существа в Его руках, и Он знает сердца всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27174,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤਬ ਸਭਿ ਸਵਾਰੇ ॥",
          "roman": "kartab sabh savāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਜਿਸ ਮਨੁੱਖ ਨੇ ਪ੍ਰਭੂ ਦਾ ਪੱਕਾ ਆਸਰਾ ਲਿਆ, ਪ੍ਰਭੂ ਨੇ ਉਸ ਦੇ) ਸਾਰੇ ਕੰਮ ਸਵਾਰ ਦਿੱਤੇ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! Господь устроил все дела того,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27175,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਅਪੁਨਾ ਬਿਰਦੁ ਸਮਾਰੇ ॥",
          "roman": "prabh apunā birad samāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਆਪਣਾ ਇਹ ਮੁੱਢ-ਕਦੀਮਾਂ ਦਾ (ਪਿਆਰ ਵਾਲਾ) ਸੁਭਾਉ ਸਦਾ ਹੀ ਚੇਤੇ ਰੱਖਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда помнит свой древний любящий обычай."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27176,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨ ਪ੍ਰਭ ਨਾਮਾ ॥",
          "roman": "patit pāvan prabh nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵਿਕਾਰੀਆਂ ਨੂੰ ਪਵਿਤ੍ਰ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога очищает грешных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27177,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸਦ ਕੁਰਬਾਨਾ ॥੨॥੯॥੭੩॥",
          "roman": "jan nānak sad kurbānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-ਮੈਂ ਉਸ ਤੋਂ) ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੨॥੯॥੭੩॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак говорит: я всегда посвящаю себя Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2373,
      "rahao_verse_id": 27184,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27178,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27179,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮਿ ਸਾਜਿ ਸਵਾਰਿਆ ॥",
          "roman": "pārbrahm sāj savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਨੇ ਇਸ ਛੋਟੇ ਬੱਚੇ (ਹਰਗੋਬਿੰਦ) ਨੂੰ ਸਾਜਿਆ ਤੇ ਸਵਾਰਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог создал и украсил этого ребёнка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27180,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਲਹੁੜਾ ਗੁਰੂ ਉਬਾਰਿਆ ॥",
          "roman": "ih lahurā gur ūbāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਦੀ ਅਰਦਾਸ ਸੁਣ ਕੇ) ਗੁਰੂ ਨੇ ਇਸ ਨੂੰ ਬਚਾ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру спас этого малыша."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27181,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਕਰਹੁ ਪਿਤ ਮਾਤਾ ॥",
          "roman": "anad karah pit mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਪਰਮਾਤਮਾ ਦੀ ਮੇਹਰ ਦਾ ਸਦਕਾ ਇਸ ਦੇ) ਮਾਪੇ ਬੇਸ਼ਕ ਖ਼ੁਸ਼ੀ ਮਨਾਣ,"
            },
            "sahib_singh_ru": {
              "main": "пусть его родители радуются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27182,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮੇਸਰੁ ਜੀਅ ਕਾ ਦਾਤਾ ॥੧॥",
          "roman": "parmesar jīa kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਹੀ ਜਿੰਦ ਦਾ ਦਾਤਾ ਹੈ (ਰਾਖਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ведь Бог — даритель жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27183,
          "is_rahao": true,
          "gurmukhi": "ਸੁਭ ਚਿਤਵਨਿ ਦਾਸ ਤੁਮਾਰੇ ॥",
          "roman": "subh chitvan dās tumāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਸੇਵਕ ਸਭ ਦਾ ਭਲਾ ਮੰਗਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои слуги желают всем блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27184,
          "is_rahao": true,
          "gurmukhi": "ਰਾਖਹਿ ਪੈਜ ਦਾਸ ਅਪੁਨੇ ਕੀ ਕਾਰਜ ਆਪਿ ਸਵਾਰੇ ॥ ਰਹਾਉ ॥",
          "roman": "rākheh pēj dās apune kī kāraj āp savāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਮੰਗ ਅਨੁਸਾਰ) ਤੂੰ ਕੰਮ ਸਵਾਰ ਕੇ ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਇੱਜ਼ਤ ਰੱਖ ਲੈਂਦਾ ਹੈਂ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Ты сохраняешь честь своих слуг и сам устраиваешь их дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27185,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਪਰਉਪਕਾਰੀ ॥",
          "roman": "merā prabh paropkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਪ੍ਰਭੂ ਸਭ ਦੀ ਭਲਾਈ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! мой Господь делает добро всем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27186,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਕਲ ਜਿਨਿ ਧਾਰੀ ॥",
          "roman": "pūraṇ kal jin dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਸਾਰੇ ਜਗਤ ਵਿਚ ਆਪਣੀ ਸ਼ਕਤੀ ਟਿਕਾਈ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он установил свою силу во всём мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27187,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਰਣੀ ਆਇਆ ॥",
          "roman": "nānak saraṇī ā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ (ਉਸ ਪ੍ਰਭੂ ਦੀ) ਸਰਨ ਆ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак говорит: тот, кто приходит в Его прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27188,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਚਿੰਦਿਆ ਫਲੁ ਪਾਇਆ ॥੨॥੧੦॥੭੪॥",
          "roman": "man chindiā phal pā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨ-ਮੰਗੀ ਮੁਰਾਦ ਪਾ ਲੈਂਦਾ ਹੈ ॥੨॥੧੦॥੭੪॥"
            },
            "sahib_singh_ru": {
              "main": "получает желаемое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2374,
      "rahao_verse_id": 27195,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27189,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27190,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਹਰਿ ਜਾਪੇ ॥",
          "roman": "sadā sadā har jāpe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਹੀ (ਸਿਰਫ਼) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! всегда повторяйте имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27191,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਬਾਲਕ ਰਾਖੇ ਆਪੇ ॥",
          "roman": "prabh bālak rākhe āpe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਆਪ ਹੀ ਬਾਲਕਾਂ ਦੇ ਰਾਖੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Господь сам защищает детей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27192,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਲਾ ਠਾਕਿ ਰਹਾਈ ॥",
          "roman": "sītlā ṭhāk rahā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬਾਲਕ ਹਰਗੋਬਿੰਦ ਤੋਂ ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ) ਸੀਤਲਾ (ਚੇਚਕ) ਰੋਕ ਲਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он остановил болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27193,
          "is_rahao": false,
          "gurmukhi": "ਬਿਘਨ ਗਏ ਹਰਿ ਨਾਈ ॥੧॥",
          "roman": "bighan gae har nā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ ਖ਼ਤਰੇ ਦੂਰ ਹੋ ਗਏ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "по милости хвалы Бога опасности исчезли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27194,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਹੋਆ ਸਦਾ ਦਇਆਲਾ ॥",
          "roman": "merā prabh hoā sadā da-iālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਪ੍ਰਭੂ ਸਦਾ ਹੀ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! мой Господь всегда милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27195,
          "is_rahao": true,
          "gurmukhi": "ਅਰਦਾਸਿ ਸੁਣੀ ਭਗਤ ਅਪੁਨੇ ਕੀ ਸਭ ਜੀਅ ਭਇਆ ਕਿਰਪਾਲਾ ॥ ਰਹਾਉ ॥",
          "roman": "ardās suṇī bhagat apune kī sabh jīa bha-iā kirpālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਹੀ ਜੀਵਾਂ ਉੱਤੇ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ। ਉਹ ਆਪਣੇ ਭਗਤ ਦੀ ਅਰਜ਼ੋਈ (ਸਦਾ) ਸੁਣਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Он слышит молитву своего преданного и милостив ко всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27196,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਰਣ ਕਾਰਣ ਸਮਰਾਥਾ ॥",
          "roman": "prabh karaṇ kāraṇ samrāthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਜਗਤ ਦਾ ਮੂਲ ਹੈ, ਤੇ, ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог — источник всего и владыка сил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27197,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਸਭੁ ਦੁਖੁ ਲਾਥਾ ॥",
          "roman": "har simrat sabh dukh lāthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "вспоминая Его, все страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27198,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੇ ਦਾਸ ਕੀ ਸੁਣੀ ਬੇਨੰਤੀ ॥",
          "roman": "apṇe dās kī suṇī benantī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ (ਸਦਾ ਹੀ) ਆਪਣੇ ਸੇਵਕ ਦੀ ਬੇਨਤੀ ਸੁਣ ਲਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он услышал просьбу своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27199,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਨਾਨਕ ਸੁਖਿ ਸਵੰਤੀ ॥੨॥੧੧॥੭੫॥",
          "roman": "sabh nānak sukh savantī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ ਹੀ) ਸਾਰੀ ਲੁਕਾਈ ਸੁਖੀ ਵੱਸਦੀ ਹੈ ॥੨॥੧੧॥੭੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак говорит: все живут в счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2375,
      "rahao_verse_id": 27206,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27200,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27201,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਗੁਰੂ ਧਿਆਏ ॥",
          "roman": "apnā gurū dhiā-e",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਗੁਰੂ ਦਾ ਧਿਆਨ ਧਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! тот, кто медитирует на своего Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27202,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਕੁਸਲ ਸੇਤੀ ਘਰਿ ਆਏ ॥",
          "roman": "mil kusal setī ghar ā-e",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਗੁਰੂ-ਚਰਨਾਂ ਵਿਚ) ਜੁੜ ਕੇ ਆਤਮਕ ਆਨੰਦ ਨਾਲ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਟਿਕ ਜਾਂਦਾ ਹੈ (ਬਾਹਰ ਭਟਕਣੋਂ ਬਚ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "соединяясь с Ним, обретает внутренний покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27203,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੈ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "nāmē kī vaḍiā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਾਮ ਦੀ ਹੀ ਬਰਕਤਿ ਹੈ (ਕਿ ਮਨੁੱਖ ਹੋਰ ਹੋਰ ਆਸਰਿਆਂ ਦੀ ਭਾਲ ਛੱਡ ਦੇਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "это величие имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27204,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈ ॥੧॥",
          "roman": "tis kīmat kahaṇ na jā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਇਸ (ਹਰਿ-ਨਾਮ) ਦਾ ਮੁੱਲ ਨਹੀਂ ਦੱਸਿਆ ਜਾ ਸਕਦਾ (ਕਿਸੇ ਦੁਨੀਆਵੀ ਪਦਾਰਥ ਦੇ ਵੱਟੇ ਨਹੀਂ ਮਿਲਦਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "его цену невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27205,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਹਰਿ ਹਰਿ ਹਰਿ ਆਰਾਧਹੁ ॥",
          "roman": "santah har har har ārādhah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਸਦਾ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਿਮਰਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! всегда помните Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27206,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਆਰਾਧਿ ਸਭੋ ਕਿਛੁ ਪਾਈਐ ਕਾਰਜ ਸਗਲੇ ਸਾਧਹੁ ॥ ਰਹਾਉ ॥",
          "roman": "har ārādh sabho kichh pā-ī-ai kāraj sagle sādhah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਕੇ ਹਰੇਕ ਚੀਜ਼ ਪ੍ਰਾਪਤ ਕਰ ਲਈਦੀ ਹੈ। (ਤੁਸੀ ਭੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਕੇ ਆਪਣੇ) ਸਾਰੇ ਕੰਮ ਸਵਾਰੋ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "помня Бога, можно получить всё и устроить все дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27207,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਪ੍ਰਭ ਲਾਗੀ ॥",
          "roman": "prem bhagat prabh lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦਾ ਧਿਆਨ ਧਰਦਾ ਹੈ) ਪ੍ਰਭੂ ਦੀ ਪਿਆਰ-ਭਰੀ ਭਗਤੀ ਵਿਚ ਉਸ ਦਾ ਮਨ ਲੱਗ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ум соединяется с любовной преданностью Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27208,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਾਏ ਜਿਸੁ ਵਡਭਾਗੀ ॥",
          "roman": "so pā-e jis vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਦਾਤਿ ਉਹੀ ਮਨੁੱਖ ਹਾਸਲ ਕਰਦਾ ਹੈ ਜਿਸ ਦੇ ਵੱਡੇ ਭਾਗ ਹੋਣ।"
            },
            "sahib_singh_ru": {
              "main": "это получает только тот, у кого великая судьба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27209,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "jan nānak nām dhiā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак говорит: тот, кто помнил имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27210,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਰਬ ਸੁਖਾ ਫਲ ਪਾਇਆ ॥੨॥੧੨॥੭੬॥",
          "roman": "tin sarab sukhā phal pā-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਸਾਰੇ ਸੁਖ ਦੇਣ ਵਾਲੇ (ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲਏ ਹਨ ॥੨॥੧੨॥੭੬॥"
            },
            "sahib_singh_ru": {
              "main": "получил все плоды счастья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2376,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27211,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27212,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮੇਸਰਿ ਦਿਤਾ ਬੰਨਾ ॥",
          "roman": "parmesar ditā bannā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਜਿਸ ਮਨੁੱਖ ਦੇ ਆਤਮਕ ਜੀਵਨ ਵਾਸਤੇ) ਪਰਮੇਸਰ ਨੇ (ਵਿਕਾਰਾਂ ਦੇ ਰਾਹ ਵਿਚ) ਡੱਕਾ ਮਾਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! тому, кому Бог поставил преграду на пути пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27213,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਰੋਗ ਕਾ ਡੇਰਾ ਭੰਨਾ ॥",
          "roman": "dukh rog kā ḍerā bhannā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਪਰਮੇਸਰ ਨੇ ਦੁੱਖਾਂ ਤੇ ਰੋਗਾਂ ਦਾ ਡੇਰਾ ਹੀ ਮੁਕਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он разрушил обитель страданий и болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27214,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਕਰਹਿ ਨਰ ਨਾਰੀ ॥",
          "roman": "anad karah nar nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੇ ਜੀਵ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "все люди наслаждаются духовной радостью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27215,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਪ੍ਰਭਿ ਕਿਰਪਾ ਧਾਰੀ ॥੧॥",
          "roman": "har har prabh kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਉੱਤੇ ਪ੍ਰਭੂ ਨੇ (ਇਹ) ਕਿਰਪਾ ਕਰ ਦਿੱਤੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "на которых Господь пролил милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
