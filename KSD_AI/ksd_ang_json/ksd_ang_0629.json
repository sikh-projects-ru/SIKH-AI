{
  "ang": 629,
  "shabads": [
    {
      "shabad_id": 2381,
      "rahao_verse_id": 27274,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27269,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਆਰਾਧੇ ॥",
          "roman": "gur pūrā ārādhe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые созерцали совершенного Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27270,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜ ਸਗਲੇ ਸਾਧੇ ॥",
          "roman": "kāraj saglē sādhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "они устроили все свои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27271,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰੇ ॥",
          "roman": "sagal manorath pūrē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все их сердечные желания исполнились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27272,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜੇ ਅਨਹਦ ਤੂਰੇ ॥੧॥",
          "roman": "bājē anhad tūre ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри них непрерывно звучат трубы хвалы Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27273,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਰਾਮੁ ਜਪਤ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "santah rām japat sukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, повторяя Имя Бога, они наслаждаются духовным покоем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27274,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਅਸਥਾਨਿ ਬਸੇ ਸੁਖ ਸਹਜੇ ਸਗਲੇ ਦੂਖ ਮਿਟਾਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sant asthān basē sukh sahjē saglē dūkh miṭāiā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто обосновался в месте святых, в Садх Сангат, пребывая в духовной устойчивости, обрели духовную радость и устранили все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27275,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਬਾਣੀ ॥",
          "roman": "gur pūrē kī bāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бани совершенного Гуру"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27276,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਮਨਿ ਭਾਣੀ ॥",
          "roman": "pārbrahm man bhāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "любима в уме Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27277,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸਿ ਵਖਾਣੀ ॥",
          "roman": "nānak dās vakhāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, лишь редкий слуга произнёс её, пребывая в духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27278,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਅਕਥ ਕਹਾਣੀ ॥੨॥੧੮॥੮੨॥",
          "roman": "nirmal akath kahāṇī ॥2॥18॥82॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это чистая, очищающая жизнь хвала Тому Господу, чей образ невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2382,
      "rahao_verse_id": 27283,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27279,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27280,
          "is_rahao": false,
          "gurmukhi": "ਭੂਖੇ ਖਾਵਤ ਲਾਜ ਨ ਆਵੈ ॥",
          "roman": "bhūkhē khāvat lāj na āvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как голодный человек, получив еду, не чувствует стыда, когда ест,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27281,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨੁ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥੧॥",
          "roman": "tiu har jan har guṇ gāvē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так слуга Господа с большим желанием поёт песни хвалы Господу, чтобы утолить свою духовную жажду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27282,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਕਾਜ ਕਉ ਕਿਉ ਅਲਕਾਈਐ ॥",
          "roman": "apnē kāj kau kiu alkāīē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Почему же лениться ради своего истинного дела?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27283,
          "is_rahao": true,
          "gurmukhi": "ਜਿਤੁ ਸਿਮਰਨਿ ਦਰਗਹ ਮੁਖੁ ਊਜਲ ਸਦਾ ਸਦਾ ਸੁਖੁ ਪਾਈਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jit simran dargah mukh ūjal sadā sadā sukh pāīē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря этому симрану человек становится светлоликим в присутствии Бога и всегда наслаждается духовным блаженством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27284,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਕਾਮੀ ਕਾਮਿ ਲੁਭਾਵੈ ॥",
          "roman": "jiu kāmī kām lubhāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как чувственный человек остаётся поглощённым страстью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27285,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਦਾਸ ਹਰਿ ਜਸੁ ਭਾਵੈ ॥੨॥",
          "roman": "tiu har dās har jas bhāvē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так слуге Господа нравится только хвала Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27286,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮਾਤਾ ਬਾਲਿ ਲਪਟਾਵੈ ॥",
          "roman": "jiu mātā bāl laṭpāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как мать привязана любовью к своему ребёнку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27287,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਗਿਆਨੀ ਨਾਮੁ ਕਮਾਵੈ ॥੩॥",
          "roman": "tiu giānī nām kamāvē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так человек духовного понимания совершает труд практики Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27288,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਪਾਵੈ ॥",
          "roman": "gur pūrē tē pāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но получает этот дар только тот, кто получает его от совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27289,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਧਿਆਵੈ ॥੪॥੧੯॥੮੩॥",
          "roman": "jan nānak nām dhiāvē ॥4॥19॥83॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак, такой человек созерцает Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2383,
      "rahao_verse_id": 27296,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27290,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27291,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਸਾਂਦਿ ਘਰਿ ਆਇਆ ॥",
          "roman": "sukh sānd ghar āiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он в полном духовном здоровье вернулся и утвердился в доме своего сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27292,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕੈ ਮੁਖਿ ਛਾਇਆ ॥",
          "roman": "nindak kē mukh chhāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На лицо клеветника легла зола: клеветник слуги Господа обрёл лишь пятно бесчестья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27293,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਗੁਰਿ ਪਹਿਰਾਇਆ ॥",
          "roman": "pūrē gur pahirāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру даровал ему почёт и уважение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27294,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੇ ਦੁਖ ਸਬਾਇਆ ॥੧॥",
          "roman": "binsē dukh sabāiā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все его страдания исчезли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27295,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਸਾਚੇ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "santah sāchē kī vaḍiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, велика слава и сила Вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27296,
          "is_rahao": true,
          "gurmukhi": "ਜਿਨਿ ਅਚਰਜ ਸੋਭ ਬਣਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jin acharaj sobh baṇāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он создал удивительную славу для своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27297,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੇ ਸਾਹਿਬ ਕੈ ਭਾਣੈ ॥",
          "roman": "bolē sāhib kē bhāṇē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга, которому Гуру даровал честь, всегда говорит в воле Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27298,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸੁ ਬਾਣੀ ਬ੍ਰਹਮੁ ਵਖਾਣੈ ॥",
          "roman": "dās bāṇī brahm vakhāṇē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот слуга всегда произносит Бани хвалы Богу и произносит Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27299,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸੁਖਦਾਈ ॥",
          "roman": "nānak prabh sukhdāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Господь всегда даёт покой своему слуге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27300,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਪੂਰੀ ਬਣਤ ਬਣਾਈ ॥੨॥੨੦॥੮੪॥",
          "roman": "jin pūrī baṇat baṇāī ॥2॥20॥84॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно Он устроил безошибочный порядок: через прибежище Гуру обретается симран Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2384,
      "rahao_verse_id": 27307,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27301,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27302,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਪੁਨਾ ਰਿਦੈ ਧਿਆਏ ॥",
          "roman": "prabh apunā ridē dhiāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто держит Имя Бога в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27303,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਸਹੀ ਸਲਾਮਤਿ ਆਏ ॥",
          "roman": "ghar sahī salāmat āē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "сохраняет капитал духовной жизни от пороков и пребывает в доме сердца, у стоп Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27304,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤੋਖੁ ਭਇਆ ਸੰਸਾਰੇ ॥",
          "roman": "santokh bhaiā sansārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже живя в мире и занимаясь мирскими делами, он сохраняет в уме удовлетворённость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27305,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਲੈ ਤਾਰੇ ॥੧॥",
          "roman": "gur pūrē lē tārē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру, взяв его за руку, переправляет его через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27306,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਪ੍ਰਭੁ ਮੇਰਾ ਸਦਾ ਦਇਆਲਾ ॥",
          "roman": "santah prabh merā sadā daiālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, мой Господь всегда милостив к своим слугам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27307,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਭਗਤ ਕੀ ਗਣਤ ਨ ਗਣਈ ਰਾਖੈ ਬਾਲ ਗੁਪਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "apnē bhagat kī gaṇat na gaṇaī rākhē bāl gupālā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь не рассматривает счёт поступков своих преданных, потому что, как детей, Он сохраняет их от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27308,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਰਿਦੈ ਉਰਿ ਧਾਰੇ ॥",
          "roman": "har nām ridē ur dhārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто удерживает Имя Господа в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27309,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਭੇ ਥੋਕ ਸਵਾਰੇ ॥",
          "roman": "tin sabhē thok savārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тот украсил и привёл в порядок все свои духовные качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27310,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਤੁਸਿ ਦੀਆ ॥",
          "roman": "gur pūrē tus dīā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру, будучи доволен, даровал ему дар Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27311,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਨਾਨਕ ਦੂਖੁ ਨ ਥੀਆ ॥੨॥੨੧॥੮੫॥",
          "roman": "phir nānak dūkh na thīā ॥2॥21॥85॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, после этого никакое страдание уже не смогло коснуться его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2385,
      "rahao_verse_id": 27318,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27312,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27313,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮਨਿ ਤਨਿ ਵਸਿਆ ਸੋਈ ॥",
          "roman": "har man tan vasiā soī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того человека, в чьём уме и теле пребывает один Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27314,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਕਰੇ ਸਭੁ ਕੋਈ ॥",
          "roman": "jē jē kār karē sabh koī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "каждое живое существо прославляет его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27315,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "gur pūrē kī vaḍiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это благословение совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27316,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਹੀ ਨ ਜਾਈ ॥੧॥",
          "roman": "tā kī kīmat kahī na jāī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Цену этому благословению невозможно назвать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27317,
          "is_rahao": true,
          "gurmukhi": "ਹਉ ਕੁਰਬਾਨੁ ਜਾਈ ਤੇਰੇ ਨਾਵੈ ॥",
          "roman": "hau kurbān jāī terē nāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой любимый Господь, я жертвую собой ради Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27318,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸ ਨੋ ਬਖਸਿ ਲੈਹਿ ਮੇਰੇ ਪਿਆਰੇ ਸੋ ਜਸੁ ਤੇਰਾ ਗਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jis no bakhas lēh merē piārē so jas terā gāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, на кого Ты изливаешь милость, о мой любимый, всегда поёт песнь Твоей хвалы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27319,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਭਾਰੋ ਸੁਆਮੀ ਮੇਰਾ ॥",
          "roman": "tūṅ bhāro suāmī merā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты мой великий Владыка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27320,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਾਂ ਭਰਵਾਸਾ ਤੇਰਾ ॥",
          "roman": "santāṅ bharvāsā terā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твоим святым также остаётся только Твоя опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27321,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਈ ॥",
          "roman": "nānak prabh sarṇāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто остаётся в прибежище Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27322,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖਿ ਨਿੰਦਕ ਕੈ ਛਾਈ ॥੨॥੨੨॥੮੬॥",
          "roman": "mukh nindak kē chhāī ॥2॥22॥86॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "на лицо его клеветника падает зола: никто не может повредить человеку, нашедшему прибежище у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2386,
      "rahao_verse_id": 27329,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27323,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27324,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਸੁਖੁ ਮੇਰੇ ਮੀਤਾ ॥",
          "roman": "āgē sukh merē mītā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Впереди — покой, о мой друг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27325,
          "is_rahao": false,
          "gurmukhi": "ਪਾਛੇ ਆਨਦੁ ਪ੍ਰਭਿ ਕੀਤਾ ॥",
          "roman": "pāchhē ānad prabh kītā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Позади Господь тоже сотворил радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27326,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮੇਸੁਰਿ ਬਣਤ ਬਣਾਈ ॥",
          "roman": "parmesur baṇat baṇāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Верховный Господь устроил весь порядок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27327,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਡੋਲਤ ਕਤਹੂ ਨਾਹੀ ॥੧॥",
          "roman": "phir ḍolat katahū nāhī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому теперь нигде больше нет колебания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27328,
          "is_rahao": true,
          "gurmukhi": "ਸਾਚੇ ਸਾਹਿਬ ਸਿਉ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "sāchē sāhib siu man māniā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ум согласился и соединился с Истинным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27329,
          "is_rahao": true,
