{
  "ang": 645,
  "shabads": [
    {
      "shabad_id": 2432,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27880,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕੀ ਸਾਰ ਨ ਜਾਣਨੀ ਹਉਮੈ ਭਰਮਿ ਭੁਲਾਇ ॥",
          "roman": "man kī sār na jāṇnī haumē bharam bhulāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они не знают ценности собственного ума; Хоумэ и заблуждение сбивают их с пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27881,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਭਉ ਪਇਆ ਵਡਭਾਗਿ ਵਸਿਆ ਮਨਿ ਆਇ ॥",
          "roman": "gur parsādī bhau paiā vaḍbhāg vasiā man āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По великой удаче, через милость Сатгуру, в человеке рождается благоговейный страх перед Хари и поселяется в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27882,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਪਇਐ ਮਨੁ ਵਸਿ ਹੋਆ ਹਉਮੈ ਸਬਦਿ ਜਲਾਇ ॥",
          "roman": "bhē pēā man vas hoā haumē śabad jalāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда возникает этот страх и Хоумэ сжигается Словом Сатгуру, ум становится подвластным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27883,
          "is_rahao": false,
          "gurmukhi": "ਸਚਿ ਰਤੇ ਸੇ ਨਿਰਮਲੇ ਜੋਤੀ ਜੋਤਿ ਮਿਲਾਇ ॥",
          "roman": "sach rate se nirmale jotī jot milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто соединил своё сознание с Светом-Прабху и окрасился Истиной, стали чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27884,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮਿਲਿਐ ਨਾਉ ਪਾਇਆ ਨਾਨਕ ਸੁਖਿ ਸਮਾਇ ॥੨॥",
          "roman": "satgur miliai nāu pāiā nānak sukh samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только встретив Сатгуру, человек получает Имя и погружается в покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2433,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27885,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27886,
          "is_rahao": false,
          "gurmukhi": "ਏਹ ਭੂਪਤਿ ਰਾਣੇ ਰੰਗ ਦਿਨ ਚਾਰਿ ਸੁਹਾਵਣਾ ॥",
          "roman": "eh bhūpat rāṇe raṅg din chār suhāvaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти удовольствия царей и правителей красивы лишь на четыре дня, то есть на короткое время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27887,
          "is_rahao": false,
          "gurmukhi": "ਏਹੁ ਮਾਇਆ ਰੰਗੁ ਕਸੁੰਭ ਖਿਨ ਮਹਿ ਲਹਿ ਜਾਵਣਾ ॥",
          "roman": "eh māiā raṅg kasumbh khin mah lah jāvaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот цвет майи подобен цвету сафлора: он мгновенно сойдёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27888,
          "is_rahao": false,
          "gurmukhi": "ਚਲਦਿਆ ਨਾਲਿ ਨ ਚਲੈ ਸਿਰਿ ਪਾਪ ਲੈ ਜਾਵਣਾ ॥",
          "roman": "chaldiā nāl na chalē sir pāp lē jāvaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При уходе из мира майя не идёт с человеком, но грехи, совершённые ради неё, он несёт на своей голове."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27889,
          "is_rahao": false,
          "gurmukhi": "ਜਾਂ ਪਕੜਿ ਚਲਾਇਆ ਕਾਲਿ ਤਾਂ ਖਰਾ ਡਰਾਵਣਾ ॥",
          "roman": "jāṅ pakaṛ chalāiā kāl tāṅ kharā ḍarāvaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Джам-Кал схватывает и уводит его, живое существо сильно пугается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27890,
          "is_rahao": false,
          "gurmukhi": "ਓਹ ਵੇਲਾ ਹਥਿ ਨ ਆਵੈ ਫਿਰਿ ਪਛੁਤਾਵਣਾ ॥੬॥",
          "roman": "oh velā hath na āvē phir pachhutāvaṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "То время человеческой жизни уже не возвращается, и тогда человек раскаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2434,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27891,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā tījjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27892,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਤੇ ਜੋ ਮੁਹ ਫਿਰੇ ਸੇ ਬਧੇ ਦੁਖ ਸਹਾਹਿ ॥",
          "roman": "satgur te jo muh phire se badhe dukh sahāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто отворачиваются от Сатгуру и становятся манмукхами, в конце связанными терпят страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27893,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਫਿਰਿ ਮਿਲਣੁ ਨ ਪਾਇਨੀ ਜੰਮਹਿ ਤੈ ਮਰਿ ਜਾਹਿ ॥",
          "roman": "phir phir milaṇ na pāinī jammah tē mar jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они не могут встретиться с Прабху; снова и снова рождаются и умирают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27894,
          "is_rahao": false,
          "gurmukhi": "ਸਹਸਾ ਰੋਗੁ ਨ ਛੋਡਈ ਦੁਖ ਹੀ ਮਹਿ ਦੁਖ ਪਾਹਿ ॥",
          "roman": "sahsā rog na chhoḍaī dukh hī mah dukh pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Болезнь тревоги никогда не оставляет их; они пребывают лишь в страдании и получают страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27895,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਦਰੀ ਬਖਸਿ ਲੇਹਿ ਸਬਦੇ ਮੇਲਿ ਮਿਲਾਹਿ ॥੧॥",
          "roman": "nānak nadrī bakhas lehi śabde mel milāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если милостивый Прабху простит их, они через Слово Сатгуру соединяются с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2435,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27896,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahallā tījjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27897,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਸਤਿਗੁਰ ਤੇ ਮੁਹ ਫਿਰੇ ਤਿਨਾ ਠਉਰ ਨ ਠਾਉ ॥",
          "roman": "jo satgur te muh phire tinā ṭhaur na ṭhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех, кто отворачивается от Сатгуру, нет ни места, ни устойчивого пристанища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27898,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਛੁਟੜਿ ਘਰਿ ਘਰਿ ਫਿਰੈ ਦੁਹਚਾਰਣਿ ਬਦਨਾਉ ॥",
          "roman": "jiu chhuṭaṛ ghar ghar phirē duhchāraṇ badanāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они подобны оставленной развратной женщине, которая, ходя от дома к дому, становится опозоренной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27899,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਬਖਸੀਅਹਿ ਸੇ ਸਤਿਗੁਰ ਮੇਲਿ ਮਿਲਾਉ ॥੨॥",
          "roman": "nānak gurmukh bakhasīahi se satgur mel milāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто, обратившись к Гуру, получают прощение, соединяются с обществом Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2436,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27900,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27901,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਸੇਵਹਿ ਸਤਿ ਮੁਰਾਰਿ ਸੇ ਭਵਜਲ ਤਰਿ ਗਇਆ ॥",
          "roman": "jo sevah sat murār se bhavjal tar gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто служат истинному Хари, переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27902,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਬੋਲਹਿ ਹਰਿ ਹਰਿ ਨਾਉ ਤਿਨ ਜਮੁ ਛਡਿ ਗਇਆ ॥",
          "roman": "jo bolah har har nāu tin jam chhaḍ gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тех, кто произносит Имя Хари, Джам оставляет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27903,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਦਰਗਹ ਪੈਧੇ ਜਾਹਿ ਜਿਨਾ ਹਰਿ ਜਪਿ ਲਇਆ ॥",
          "roman": "se dargah pēdhe jāh jinā har jap lēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто джапали Имя Хари, идут в Даргах с почётом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27904,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸੇਵਹਿ ਸੇਈ ਪੁਰਖ ਜਿਨਾ ਹਰਿ ਤੁਧੁ ਮਇਆ ॥",
          "roman": "har sevah seī purakh jinā har tudh maiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Хари, только те люди служат Тебе, на кого есть Твоя милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27905,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵਾ ਪਿਆਰੇ ਨਿਤ ਗੁਰਮੁਖਿ ਭ੍ਰਮ ਭਉ ਗਇਆ ॥੭॥",
          "roman": "guṇ gāvā piāre nit gurmukh bhram bhau gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О возлюбленный, дай мне всегда петь Твои достоинства; став гурмукхом, человек избавляется от заблуждения и страха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2437,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27906,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā tījjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27907,
          "is_rahao": false,
          "gurmukhi": "ਥਾਲੈ ਵਿਚਿ ਤੈ ਵਸਤੂ ਪਈਓ ਹਰਿ ਭੋਜਨੁ ਅੰਮ੍ਰਿਤੁ ਸਾਰੁ ॥",
          "roman": "thālē vich tē vastū paīo har bhojan amrit sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В тот сердечный тхал, где оказались три вещи — истина, довольство и размышление, подаётся превосходная амритная пища Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27908,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਖਾਧੈ ਮਨੁ ਤ੍ਰਿਪਤੀਐ ਪਾਈਐ ਮੋਖ ਦੁਆਰੁ ॥",
          "roman": "jit khādhē man triptīē pāīē mokh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От вкушения этой пищи ум насыщается, и обретается дверь освобождения от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27909,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਭੋਜਨੁ ਅਲਭੁ ਹੈ ਸੰਤਹੁ ਲਭੈ ਗੁਰ ਵੀਚਾਰਿ ॥",
          "roman": "ih bhojan alabh hē santah labhē gur vichār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, эта пища редка; она находится через размышление, указанное Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27910,
          "is_rahao": false,
          "gurmukhi": "ਏਹ ਮੁਦਾਵਣੀ ਕਿਉ ਵਿਚਹੁ ਕਢੀਐ ਸਦਾ ਰਖੀਐ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "eh mudāvaṇī kiu vichah kaḍhīai sadā rakhīai ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эту дарующую духовную радость вещь не следует вынимать изнутри; её нужно всегда хранить в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27911,
          "is_rahao": false,
          "gurmukhi": "ਏਹ ਮੁਦਾਵਣੀ ਸਤਿਗੁਰੂ ਪਾਈ ਗੁਰਸਿਖਾ ਲਧੀ ਭਾਲਿ ॥",
          "roman": "eh mudāvaṇī satgurū pāī gursikhā ladhī bhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру открыл эту пищу духовной радости; гур-сикхи нашли её поиском."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27912,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸੁ ਬੁਝਾਏ ਸੁ ਬੁਝਸੀ ਹਰਿ ਪਾਇਆ ਗੁਰਮੁਖਿ ਘਾਲਿ ॥੧॥",
          "roman": "nānak jis bujhāe su bujhsī har pāiā gurmukh ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кому Хари даёт это понять, понимает; став гурмукхом и совершив труд, он встречает Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2438,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27913,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahallā tījjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27914,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਧੁਰਿ ਮੇਲੇ ਸੇ ਮਿਲਿ ਰਹੇ ਸਤਿਗੁਰ ਸਿਉ ਚਿਤੁ ਲਾਇ ॥",
          "roman": "jo dhur mele se mil rahe satgur siu chit lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кого Хари изначально соединил с Собой, остаются соединёнными, приложив сознание к Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27915,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਵਿਛੋੜੇਨੁ ਸੇ ਵਿਛੁੜੇ ਦੂਜੈ ਭਾਇ ਖੁਆਇ ॥",
          "roman": "āp vichhoṛen se vichhuṛe dūjē bhāe khuāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те же, кого Он Сам отделил, сбившись в любви к майе, остаются отделёнными от Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27916,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵਿਣੁ ਕਰਮਾ ਕਿਆ ਪਾਈਐ ਪੂਰਬਿ ਲਿਖਿਆ ਕਮਾਇ ॥੨॥",
          "roman": "nānak viṇ karmā kiā pāīai pūrab likhiā kamāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, без совершённой кармы ничего не обретается; человек проживает то, что изначально записано согласно прежним делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2439,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27917,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27918,
          "is_rahao": false,
          "gurmukhi": "ਬਹਿ ਸਖੀਆ ਜਸੁ ਗਾਵਹਿ ਗਾਵਣਹਾਰੀਆ ॥",
          "roman": "bah sakhīā jas gāvah gāvaṇhārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Подруги-святые, поющие славу Хари, сидят вместе и сами воспевают Его хвалу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27919,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਸਲਾਹਿਹੁ ਨਿਤ ਹਰਿ ਕਉ ਬਲਿਹਾਰੀਆ ॥",
          "roman": "har nām salāhih nit har kau balihārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они, будучи преданными Хари, учат других всегда славить Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27920,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੀ ਸੁਣਿ ਮੰਨਿਆ ਹਰਿ ਨਾਉ ਤਿਨਾ ਹਉ ਵਾਰੀਆ ॥",
          "roman": "jinī suṇ manniā har nāu tinā hau vārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой ради тех, кто, услышав, принял Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27921,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖੀਆ ਹਰਿ ਮੇਲੁ ਮਿਲਾਵਣਹਾਰੀਆ ॥",
          "roman": "gurmukhīā har mel milāvaṇhārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой ради тех гурмукх-подруг, которые соединяют с Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27922,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬਲਿ ਜਾਵਾ ਦਿਨੁ ਰਾਤਿ ਗੁਰ ਦੇਖਣਹਾਰੀਆ ॥੮॥",
          "roman": "hau bal jāvā din rāt gur dekhaṇhārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я днём и ночью приношу себя в жертву тем, кто созерцает Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2440,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27923,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā tījjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
