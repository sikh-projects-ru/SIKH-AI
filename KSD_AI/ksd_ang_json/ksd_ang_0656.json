{
  "ang": 656,
  "shabads": [
    {
      "shabad_id": 2509,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28358,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਬਸਤੁ ਅਗੋਚਰ ਲਹੀਐ ॥",
          "roman": "ik bast agochar lahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂਕਿ ਅੰਦਰੋਂ) ਉਹ ਹਰਿ-ਨਾਮ ਪਦਾਰਥ ਮਿਲ ਪਏ, ਜਿਸ ਤਕ ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, (ਇਸ ਤਰ੍ਹਾਂ ਧਾਰਮਿਕ ਪੁਸਤਕਾਂ ਪੜ੍ਹਨ ਨਾਲ ਉਹ ਗਿਆਨ ਦਾ ਦੀਵਾ ਮਨ ਵਿਚ ਜਗਣਾ ਚਾਹੀਦਾ ਹੈ ਜਿਸ ਨਾਲ ਅੰਦਰ-ਵੱਸਦਾ ਰੱਬ ਲੱਭ ਪਏ)।"
            },
            "sahib_singh_ru": {
              "main": "чтобы найти то, что недоступно чувствам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28359,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤੁ ਅਗੋਚਰ ਪਾਈ ॥",
          "roman": "bast agochar pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਉਹ ਅਪਹੁੰਚ ਹਰਿ-ਨਾਮ ਪਦਾਰਥ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто находит это,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28360,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਦੀਪਕੁ ਰਹਿਆ ਸਮਾਈ ॥੨॥",
          "roman": "ghaṭ dīpak rahiā samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਉਹ ਦੀਵਾ ਫਿਰ ਸਦਾ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "в его сердце этот светильник остаётся навсегда ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28361,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਅਬ ਜਾਨਿਆ ॥",
          "roman": "kah Kabīr ab jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ-ਉਸ ਅਪਹੁੰਚ ਹਰਿ-ਨਾਮ ਪਦਾਰਥ ਨਾਲ ਮੇਰੀ ਭੀ ਜਾਣ-ਪਛਾਣ ਹੋ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: теперь я узнал это,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28362,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਜਾਨਿਆ ਤਉ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "jab jāniā tau man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੋਂ ਜਾਣ-ਪਛਾਣ ਹੋਈ ਹੈ, ਮੇਰਾ ਮਨ ਉਸੇ ਵਿਚ ਹੀ ਪਰਚ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и с тех пор мой ум утвердился в этом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28363,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਾਨੇ ਲੋਗੁ ਨ ਪਤੀਜੈ ॥",
          "roman": "man māne log na patījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜਗਤ ਲੋੜਦਾ ਹੈ ਧਰਮ-ਪੁਸਤਕਾਂ ਦੇ ਰਿਵਾਜੀ ਪਾਠ ਕਰਨੇ ਕਰਾਉਣੇ ਤੇ ਤੀਰਥ ਆਦਿਕਾਂ ਦੇ ਇਸ਼ਨਾਨ; ਸੋ,) ਪਰਮਾਤਮਾ ਵਿਚ ਮਨ ਜੁੜਨ ਨਾਲ (ਕਰਮ-ਕਾਂਡੀ) ਜਗਤ ਦੀ ਤਸੱਲੀ ਨਹੀਂ ਹੁੰਦੀ;"
            },
            "sahib_singh_ru": {
              "main": "Но мир не удовлетворяется этим внутренним соединением,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28364,
          "is_rahao": false,
          "gurmukhi": "ਨ ਪਤੀਜੈ ਤਉ ਕਿਆ ਕੀਜੈ ॥੩॥੭॥",
          "roman": "na patījē tau kiā kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੂਜੇ ਪਾਸੇ) ਨਾਮ ਸਿਮਰਨ ਵਾਲੇ ਨੂੰ ਭੀ ਇਹ ਮੁਥਾਜੀ ਨਹੀਂ ਹੁੰਦੀ ਕਿ ਜ਼ਰੂਰ ਹੀ ਲੋਕਾਂ ਦੀ ਤਸੱਲੀ ਭੀ ਕਰਾਏ, (ਤਾਹੀਏਂ, ਆਮ ਤੌਰ ਤੇ ਇਹਨਾਂ ਦਾ ਅਜੋੜ ਹੀ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ) ॥੩॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и если он не удовлетворён, что можно сделать ॥3॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2510,
      "rahao_verse_id": 28368,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28365,
          "is_rahao": false,
          "gurmukhi": "ਹ੍ਰਿਦੈ ਕਪਟੁ ਮੁਖ ਗਿਆਨੀ ॥",
          "roman": "hridē kapaṭ mukh giānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਖੰਡੀ ਮਨੁੱਖ! ਤੇਰੇ ਮਨ ਵਿਚ ਤਾਂ ਠੱਗੀ ਹੈ, ਪਰ ਤੂੰ ਮੂੰਹੋਂ (ਬ੍ਰਹਮ) ਗਿਆਨ ਦੀਆਂ ਗੱਲਾਂ ਕਰ ਰਿਹਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Эй лицемерный человек! В твоём сердце обман, но устами ты говоришь о божественном знании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28366,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠੇ ਕਹਾ ਬਿਲੋਵਸਿ ਪਾਨੀ ॥੧॥",
          "roman": "jhūṭhe kahā bilovasi pānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਝੂਠੇ ਮਨੁੱਖ! ਤੈਨੂੰ ਇਸ ਪਾਣੀ ਰਿੜਕਣ ਤੋਂ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Эй лживый человек! Тебе нет никакой пользы от взбалтывания этой воды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28367,
          "is_rahao": true,
          "gurmukhi": "ਕਾਂਇਆ ਮਾਂਜਸਿ ਕਉਨ ਗੁਨਾਂ ॥",
          "roman": "kāñiā māñjas kaun gunā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਝੂਠੇ!) ਤੈਨੂੰ ਇਸ ਗੱਲ ਦਾ ਕੋਈ ਫ਼ਾਇਦਾ ਨਹੀਂ ਕਿ ਤੂੰ ਆਪਣਾ ਸਰੀਰ ਮਾਂਜਦਾ ਫਿਰਦਾ ਹੈਂ (ਭਾਵ, ਬਾਹਰੋਂ ਸੁੱਚਾ ਤੇ ਪਵਿੱਤਰਤਾ ਰੱਖਦਾ ਹੈਂ)"
            },
            "sahib_singh_ru": {
              "main": "Эй лживый! Нет тебе никакой пользы от того, что ты очищаешь своё тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28368,
          "is_rahao": true,
          "gurmukhi": "ਜਉ ਘਟ ਭੀਤਰਿ ਹੈ ਮਲਨਾਂ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jau ghaṭ bhītar hē malnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੇਰੇ ਹਿਰਦੇ ਵਿਚ (ਕਪਟ ਦੀ) ਮੈਲ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если внутри твоего сердца есть грязь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28369,
          "is_rahao": false,
          "gurmukhi": "ਲਉਕੀ ਅਠਸਠਿ ਤੀਰਥ ਨੑਾਈ ॥",
          "roman": "laukī aṭhsaṭh tīrath nhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ!) ਜੇ ਤੂੰਬੀ ਅਠਾਹਠ ਤੀਰਥਾਂ ਉੱਤੇ ਭੀ ਇਸ਼ਨਾਨ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Даже если ты омоешься на всех шестидесяти восьми святых местах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28370,
          "is_rahao": false,
          "gurmukhi": "ਕਉਰਾਪਨੁ ਤਊ ਨ ਜਾਈ ॥੨॥",
          "roman": "kaurāpan tau na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਉਸ ਦੀ (ਅੰਦਰਲੀ) ਕੁੜਿੱਤਣ ਦੂਰ ਨਹੀਂ ਹੁੰਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "всё равно внутренняя горечь не исчезнет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28371,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਬੀਚਾਰੀ ॥",
          "roman": "kah Kabīr bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਅੰਦਰਲੀ ਮੈਲ ਨੂੰ ਦੂਰ ਕਰਨ ਲਈ) ਕਬੀਰ ਤਾਂ ਸੋਚ ਵਿਚਾਰ ਕੇ (ਪ੍ਰਭੂ ਅੱਗੇ ਹੀ ਇਉਂ) ਅਰਦਾਸ ਕਰਦਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Кабир, размышляя, так молится:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28372,
          "is_rahao": false,
          "gurmukhi": "ਭਵ ਸਾਗਰੁ ਤਾਰਿ ਮੁਰਾਰੀ ॥੩॥੮॥",
          "roman": "bhav sāgar tār Murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਮੈਨੂੰ ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਲੈ ॥੩॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Переправь меня через этот океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2511,
      "rahao_verse_id": 28378,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28373,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ",
          "roman": "soraṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੋਰਠਿ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Сораṭх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28374,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Вечный существует и постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28375,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਪਰਪੰਚ ਕਰਿ ਪਰ ਧਨੁ ਲਿਆਵੈ ॥",
          "roman": "bah parpañch kar par dhan liāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਤਰ੍ਹਾਂ ਦੀਆਂ ਠੱਗੀਆਂ ਕਰ ਕੇ ਤੂੰ ਪਰਾਇਆ ਮਾਲ ਲਿਆਉਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Совершая множество обманов, ты присваиваешь чужое богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28376,
          "is_rahao": false,
          "gurmukhi": "ਸੁਤ ਦਾਰਾ ਪਹਿ ਆਨਿ ਲੁਟਾਵੈ ॥੧॥",
          "roman": "sut dārā pahi ān luṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਲਿਆ ਕੇ ਆਪਣੇ ਪੁੱਤਰ ਤੇ ਵਹੁਟੀ ਦੇ ਹਵਾਲੇ ਕਰ ਦੇਂਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и приносишь его, передавая своим детям и жене."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28377,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਮੇਰੇ ਭੂਲੇ ਕਪਟੁ ਨ ਕੀਜੈ ॥",
          "roman": "man mere bhūle kapaṭ na kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਭੁੱਲੇ ਹੋਏ ਮਨ! (ਰੋਜ਼ੀ ਆਦਿਕ ਦੀ ਖ਼ਾਤਰ ਕਿਸੇ ਨਾਲ) ਧੋਖਾ ਫ਼ਰੇਬ ਨਾਹ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой заблуждающийся ум! Не обманывай ради пропитания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28378,
          "is_rahao": true,
          "gurmukhi": "ਅੰਤਿ ਨਿਬੇਰਾ ਤੇਰੇ ਜੀਅ ਪਹਿ ਲੀਜੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ant nibērā tere jīa pahi lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਖ਼ਰ ਨੂੰ (ਇਹਨਾਂ ਮੰਦ ਕਰਮਾਂ ਦਾ) ਲੇਖਾ ਤੇਰੀ ਆਪਣੀ ਜਿੰਦ ਤੋਂ ਹੀ ਲਿਆ ਜਾਣਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "В конце счёт за эти поступки будет взят с твоей собственной души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28379,
          "is_rahao": false,
          "gurmukhi": "ਛਿਨੁ ਛਿਨੁ ਤਨੁ ਛੀਜੈ ਜਰਾ ਜਨਾਵੈ ॥",
          "roman": "chhin chhin tan chhījē jarā janāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ, ਇਹਨਾਂ ਠੱਗੀਆਂ ਵਿਚ ਹੀ) ਸਹਿਜੇ ਸਹਿਜੇ ਤੇਰਾ ਆਪਣਾ ਸਰੀਰ ਕਮਜ਼ੋਰ ਹੁੰਦਾ ਜਾ ਰਿਹਾ ਹੈ, ਬੁਢੇਪੇ ਦੀਆਂ ਨਿਸ਼ਾਨੀਆਂ ਆ ਰਹੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Постепенно твоё тело слабеет, проявляются признаки старости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28380,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਤੇਰੀ ਓਕ ਕੋਈ ਪਾਨੀਓ ਨ ਪਾਵੈ ॥੨॥",
          "roman": "tab terī ok koī pānīo na pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੂੰ ਬੁੱਢਾ ਹੋ ਗਿਆ, ਤੇ ਹਿੱਲਣ-ਜੋਗਾ ਨਾਹ ਰਿਹਾ) ਤਦੋਂ (ਇਹਨਾਂ ਵਿਚੋਂ, ਜਿਨ੍ਹਾਂ ਦੀ ਖ਼ਾਤਰ ਠੱਗੀ ਕਰਦਾ ਹੈਂ) ਕਿਸੇ ਨੇ ਤੇਰੇ ਬੁੱਕ ਵਿਚ ਪਾਣੀ ਵੀ ਨਹੀਂ ਪਾਣਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "И когда ты состаришься и не сможешь двигаться, никто из них даже воды тебе не подаст."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28381,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤੁ ਕਬੀਰੁ ਕੋਈ ਨਹੀ ਤੇਰਾ ॥",
          "roman": "kahat Kabīr koī nahī terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੈਨੂੰ) ਕਬੀਰ ਆਖਦਾ ਹੈ-(ਹੇ ਜਿੰਦੇ!) ਕਿਸੇ ਨੇ ਭੀ ਤੇਰਾ (ਸਾਥੀ) ਨਹੀਂ ਬਣਨਾ।"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: никто не станет твоим спутником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28382,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਰਾਮੁ ਕੀ ਨ ਜਪਹਿ ਸਵੇਰਾ ॥੩॥੯॥",
          "roman": "hridē Rām kī na japahi saverā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇੱਕ ਪ੍ਰਭੂ ਹੀ ਅਸਲ ਸਾਥੀ ਹੈ) ਤੂੰ ਵੇਲੇ ਸਿਰ (ਹੁਣੇ ਹੁਣੇ) ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਕਿਉਂ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਨਹੀਂ ਸਿਮਰਦੀ? ॥੩॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "Почему ты вовремя не поминаешь Господа в своём сердце?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2512,
      "rahao_verse_id": 28384,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28383,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਮਨ ਪਵਨੈ ਸੁਖੁ ਬਨਿਆ ॥",
          "roman": "santah man pavanē sukh baniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਮੇਰੇ) ਪਉਣ (ਵਰਗੇ ਚੰਚਲ) ਮਨ ਨੂੰ (ਹੁਣ) ਸੁਖ ਮਿਲ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! Моему ветреному уму теперь пришёл покой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28384,
          "is_rahao": true,
          "gurmukhi": "ਕਿਛੁ ਜੋਗੁ ਪਰਾਪਤਿ ਗਨਿਆ ॥ ਰਹਾਉ ॥",
          "roman": "kichh jog parāpat ganiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਇਹ ਮਨ ਪ੍ਰਭੂ ਦਾ ਮਿਲਾਪ) ਹਾਸਲ ਕਰਨ ਜੋਗਾ ਥੋੜਾ ਬਹੁਤ ਸਮਝਿਆ ਜਾ ਸਕਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "и он стал в некоторой мере пригоден для соединения с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28385,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਦਿਖਲਾਈ ਮੋਰੀ ॥",
          "roman": "gur dikhlaī morī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਤਿਗੁਰੂ ਨੇ (ਮੈਨੂੰ ਮੇਰੀ ਉਹ) ਕਮਜ਼ੋਰੀ ਵਿਖਾ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Потому что Сатгуру показал мне мою слабость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28386,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਮਿਰਗ ਪੜਤ ਹੈ ਚੋਰੀ ॥",
          "roman": "jit mirag paṛat hē chorī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਕਰਕੇ (ਕਾਮਾਦਿਕ) ਪਸ਼ੂ ਅਡੋਲ ਹੀ (ਮੈਨੂੰ) ਆ ਦਬਾਉਂਦੇ ਸਨ।"
            },
            "sahib_singh_ru": {
              "main": "из-за которой звери страстей внезапно нападали на меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28387,
          "is_rahao": false,
          "gurmukhi": "ਮੂੰਦਿ ਲੀਏ ਦਰਵਾਜੇ ॥",
          "roman": "mūnd līe darvāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੋ, ਮੈਂ ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਸਰੀਰ ਦੇ) ਦਰਵਾਜ਼ੇ (ਗਿਆਨ-ਇੰਦ੍ਰੇ: ਪਰ ਨਿੰਦਾ, ਪਰ ਤਨ, ਪਰ ਧਨ ਆਦਿਕ ਵਲੋਂ) ਬੰਦ ਕਰ ਲਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь я, по милости Гуру, закрыл двери чувств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28388,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜੀਅਲੇ ਅਨਹਦ ਬਾਜੇ ॥੧॥",
          "roman": "bājīale anhad bāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਮੇਰੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ) ਵਾਜੇ ਇੱਕ-ਰਸ ਵੱਜਣ ਲੱਗ ਪਏ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и внутри меня зазвучали непрерывные божественные звуки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28389,
          "is_rahao": false,
          "gurmukhi": "ਕੁੰਭ ਕਮਲੁ ਜਲਿ ਭਰਿਆ ॥",
          "roman": "kuṃbh kamal jal bhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰਾ) ਹਿਰਦਾ-ਕਮਲ ਰੂਪ ਘੜਾ (ਪਹਿਲਾਂ ਵਿਕਾਰਾਂ ਦੇ) ਪਾਣੀ ਨਾਲ ਭਰਿਆ ਹੋਇਆ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Моё сердце-лотос было наполнено водой пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28390,
          "is_rahao": false,
          "gurmukhi": "ਜਲੁ ਮੇਟਿਆ ਊਭਾ ਕਰਿਆ ॥",
          "roman": "jal meṭiā ūbhā kariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਗੁਰੂ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੈਂ ਉਹ) ਪਾਣੀ ਡੋਲ੍ਹ ਦਿੱਤਾ ਹੈ ਤੇ (ਹਿਰਦੇ ਨੂੰ) ਉੱਚਾ ਕਰ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но теперь я вылил эту воду и возвысил сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28391,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜਨ ਜਾਨਿਆ ॥",
          "roman": "kah Kabīr jan jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- (ਹੁਣ) ਮੈਂ ਦਾਸ ਨੇ (ਪ੍ਰਭੂ ਨਾਲ) ਜਾਣ-ਪਛਾਣ ਕਰ ਲਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: теперь я, раб, познал Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28392,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਜਾਨਿਆ ਤਉ ਮਨੁ ਮਾਨਿਆ ॥੨॥੧੦॥",
          "roman": "jau jāniā tau man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਦੋਂ ਤੋਂ ਇਹ ਸਾਂਝ ਪਾਈ ਹੈ, ਮੇਰਾ ਮਨ (ਉਸ ਪ੍ਰਭੂ ਵਿਚ ਹੀ) ਗਿੱਝ ਗਿਆ ਹੈ ॥੨॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "и с тех пор мой ум утвердился в Нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2513,
      "rahao_verse_id": 28399,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28393,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੋਰਠਿ ॥",
          "roman": "rāg soraṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28394,
          "is_rahao": false,
          "gurmukhi": "ਭੂਖੇ ਭਗਤਿ ਨ ਕੀਜੈ ॥",
          "roman": "bhūkhe bhagat na kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮਨੁੱਖ ਦੀ ਰੋਟੀ ਵਲੋਂ ਹੀ ਤ੍ਰਿਸ਼ਨਾ ਨਹੀਂ ਮੁੱਕੀ, ਤਾਂ ਉਹ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਨਹੀਂ ਕਰ ਸਕਦਾ, ਫਿਰ ਉਹ ਭਗਤੀ ਵਿਖਾਵੇ ਦੀ ਹੀ ਰਹਿ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пока человек не избавился от жажды пищи, он не может совершать истинное поклонение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28395,
          "is_rahao": false,
          "gurmukhi": "ਯਹ ਮਾਲਾ ਅਪਨੀ ਲੀਜੈ ॥",
          "roman": "yah mālā apnī lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਹ ਆਪਣੀ ਮਾਲਾ ਮੈਥੋਂ ਲੈ ਲਉ। (ਪ੍ਰਭੂ! ਇੱਕ ਤਾਂ ਮੈਨੂੰ ਰੋਟੀ ਵਲੋਂ ਬੇ-ਫ਼ਿਕਰ ਕਰ, ਦੂਜੇ)"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Возьми у меня эту чётку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28396,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਮਾਂਗਉ ਸੰਤਨ ਰੇਨਾ ॥",
          "roman": "hau māṅgau santan renā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਸੰਤਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਮੰਗਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу пыль стоп святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28397,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਨਾਹੀ ਕਿਸੀ ਕਾ ਦੇਨਾ ॥੧॥",
          "roman": "mē nāhī kisī kā denā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਕਿ ਮੈਂ ਕਿਸੇ ਦਾ ਮੁਥਾਜ ਨਾਹ ਹੋਵਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы ни от кого не зависеть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28398,
          "is_rahao": true,
          "gurmukhi": "ਮਾਧੋ ਕੈਸੀ ਬਨੈ ਤੁਮ ਸੰਗੇ ॥",
          "roman": "Mādho kēsī banē tum saṅge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਸ਼ਰਮ ਕੀਤਿਆਂ ਨਹੀਂ ਨਿਭ ਸਕਣੀ;"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Без искренности с Тобой нельзя пребывать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28399,
          "is_rahao": true,
          "gurmukhi": "ਆਪਿ ਨ ਦੇਹੁ ਤ ਲੇਵਉ ਮੰਗੇ ॥ ਰਹਾਉ ॥",
          "roman": "āp na deh ta levau māṅge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਜੇ ਤੂੰ ਆਪ ਨਾਹ ਦੇਵੇਂਗਾ, ਤਾਂ ਮੈਂ ਹੀ ਮੰਗ ਕੇ ਲੈ ਲਵਾਂਗਾ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Если Ты сам не дашь, я буду просить и возьму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28400,
          "is_rahao": false,
          "gurmukhi": "ਦੁਇ ਸੇਰ ਮਾਂਗਉ ਚੂਨਾ ॥",
          "roman": "dui ser māṅgau chūnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਦੋ ਸੇਰ ਆਟੇ ਦੀ ਲੋੜ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мне нужно два сера муки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28401,
          "is_rahao": false,
          "gurmukhi": "ਪਾਉ ਘੀਉ ਸੰਗਿ ਲੂਨਾ ॥",
          "roman": "pāu ghīu saṅg lūnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਪਾਉ ਘਿਉ ਤੇ ਕੁਝ ਲੂਣ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "четверть сера топлёного масла и немного соли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28402,
          "is_rahao": false,
          "gurmukhi": "ਅਧ ਸੇਰੁ ਮਾਂਗਉ ਦਾਲੇ ॥",
          "roman": "adh ser māṅgau dāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੈਥੋਂ ਅੱਧ ਸੇਰ ਦਾਲ ਮੰਗਦਾ ਹਾਂ-"
            },
            "sahib_singh_ru": {
              "main": "и полсера бобов прошу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28403,
          "is_rahao": false,
          "gurmukhi": "ਮੋ ਕਉ ਦੋਨਉ ਵਖਤ ਜਿਵਾਲੇ ॥੨॥",
          "roman": "mo kau donau vakhat jivāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਚੀਜ਼ਾ ਮੇਰੇ ਦੋਹਾਂ ਵੇਲਿਆਂ ਦੀ ਗੁਜ਼ਰਾਨ ਲਈ ਕਾਫ਼ੀ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "этого достаточно для моего пропитания два раза в день."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28404,
          "is_rahao": false,
          "gurmukhi": "ਖਾਟ ਮਾਂਗਉ ਚਉਪਾਈ ॥",
          "roman": "khāṭ māṅgau chaupaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਬਤ ਮੰਜੀ ਮੰਗਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу прочную кровать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28405,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਹਾਨਾ ਅਵਰ ਤੁਲਾਈ ॥",
          "roman": "sirhānā avar tulāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਾਣਾ ਤੇ ਤੁਲਾਈ ਭੀ।"
            },
            "sahib_singh_ru": {
              "main": "подушку и покрывало,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28406,
          "is_rahao": false,
          "gurmukhi": "ਊਪਰ ਕਉ ਮਾਂਗਉ ਖੀਂਧਾ ॥",
          "roman": "ūpar kau māṅgau khīndhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਪਰ ਲੈਣ ਲਈ ਰਜ਼ਾਈ ਦੀ ਲੋੜ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "и одеяло сверху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28407,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਭਗਤਿ ਕਰੈ ਜਨੁ ਥਂੀਧਾ ॥੩॥",
          "roman": "terī bhagat karē jan thīndhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੱਸ! ਫਿਰ ਤੇਰਾ ਭਗਤ (ਸਰੀਰਕ ਲੋੜਾਂ ਵਲੋਂ ਬੇ-ਫ਼ਿਕਰ ਹੋ ਕੇ) ਤੇਰੇ ਪ੍ਰੇਮ ਵਿਚ ਭਿੱਜ ਕੇ ਤੇਰੀ ਭਗਤੀ ਕਰੇਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тогда Твой слуга, избавившись от нужд, будет погружён в Твою любовь и поклоняться Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28408,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਨਾਹੀ ਕੀਤਾ ਲਬੋ ॥",
          "roman": "mē nāhī kītā labo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ (ਮੰਗਣ ਵਿਚ) ਕੋਈ ਲਾਲਚ ਨਹੀਂ ਕੀਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Я не проявил жадности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28409,
          "is_rahao": false,
          "gurmukhi": "ਇਕੁ ਨਾਉ ਤੇਰਾ ਮੈ ਫਬੋ ॥",
          "roman": "ik nāu terā mē phabo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ (ਉਹ ਚੀਜ਼ਾਂ ਤਾਂ ਸਰੀਰਕ ਨਿਰਬਾਹ-ਮਾਤ੍ਰ ਹਨ) ਅਸਲ ਵਿਚ ਤਾਂ ਮੈਨੂੰ ਤੇਰਾ ਨਾਮ ਹੀ ਪਿਆਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо мне дорого лишь Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28410,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "kah Kabīr man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਮੇਰਾ ਮਨ (ਤੇਰੇ ਨਾਮ ਵਿਚ) ਪਰਚਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: мой ум погрузился в Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28411,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮਾਨਿਆ ਤਉ ਹਰਿ ਜਾਨਿਆ ॥੪॥੧੧॥",
          "roman": "man māniā tau har jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਦੋਂ ਦਾ ਪਰਚਿਆ ਹੈ ਤਦੋਂ ਤੋਂ ਤੇਰੇ ਨਾਲ ਮੇਰੀ (ਡੂੰਘੀ) ਜਾਣ-ਪਛਾਣ ਹੋ ਗਈ ਹੈ ॥੪॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "и с тех пор я глубоко познал Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2514,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28412,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੋਰਠਿ ਬਾਣੀ ਭਗਤ ਨਾਮਦੇ ਜੀ ਕੀ ਘਰੁ ੨",
          "roman": "rāg soraṭh bāṇī bhagat Nāmdev jī kī ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੋਰਠਿ, ਘਰ ੨ ਵਿੱਚ ਭਗਤ ਨਾਮਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Сораṭх, бани Бхагата Намдева, дом 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28413,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Вечный существует и постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28414,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਦੇਖਾ ਤਬ ਗਾਵਾ ॥",
          "roman": "jab dekhā tab gāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਦਾ ਸਦਕਾ) ਜਿਉਂ ਜਿਉਂ ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ (ਹਰ ਥਾਂ) ਦੀਦਾਰ ਕਰਦਾ ਹਾਂ ਮੈਂ (ਆਪ-ਮੁਹਾਰਾ) ਉਸ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Когда я вижу Господа повсюду, я самопроизвольно воспеваю Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28415,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਜਨ ਧੀਰਜੁ ਪਾਵਾ ॥੧॥",
          "roman": "tau jan dhīraj pāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਹੇ ਭਾਈ! ਮੇਰੇ ਅੰਦਰ ਠੰਢ ਪੈਂਦੀ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и в моём сердце наступает покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
