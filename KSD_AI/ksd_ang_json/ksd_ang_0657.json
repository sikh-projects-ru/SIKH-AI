            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28459,
          "is_rahao": false,
          "gurmukhi": "ਅਨਲ ਅਗਮ ਜੈਸੇ ਲਹਰਿ ਮਇ ਓਦਧਿ ਜਲ ਕੇਵਲ ਜਲ ਮਾਂਹੀ ॥੧॥",
          "roman": "anal agam jēse lahar mē odadh jal keval jal māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ 'ਮੈਂ' ਦੇ ਹਟਣ ਨਾਲ ਇਹ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ ਕਿ) ਜਿਵੇਂ ਬੜਾ ਤੂਫ਼ਾਨ ਆਇਆਂ ਸਮੁੰਦਰ ਲਹਿਰਾਂ ਨਾਲ ਨਕਾ-ਨਕ ਭਰ ਜਾਂਦਾ ਹੈ, ਪਰ ਅਸਲ ਵਿਚ ਉਹ (ਲਹਿਰਾਂ ਸਮੁੰਦਰ ਦੇ) ਪਾਣੀ ਵਿਚ ਪਾਣੀ ਹੀ ਹੈ (ਤਿਵੇਂ ਇਹ ਸਾਰੇ ਜੀਆ ਜੰਤ ਤੇਰਾ ਆਪਣਾ ਹੀ ਵਿਕਾਸ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Как волны в океане — это лишь вода в воде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28460,
          "is_rahao": true,
          "gurmukhi": "ਮਾਧਵੇ ਕਿਆ ਕਹੀਐ ਭ੍ਰਮੁ ਐਸਾ ॥",
          "roman": "mādhve kiā kahī-ai bhram aiso",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਧੋ! ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ ਕੁਝ ਅਜਿਹਾ ਭੁਲੇਖਾ ਪਿਆ ਹੋਇਆ ਹੈ ਕਿ ਇਹ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Мадхо, такое заблуждение невозможно описать."
