{
  "ang": 657,
  "shabads": [
    {
      "shabad_id": 2514,
      "rahao_verse_id": 28416,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28416,
          "is_rahao": true,
          "gurmukhi": "ਨਾਦਿ ਸਮਾਇਲੋ ਰੇ ਸਤਿਗੁਰੁ ਭੇਟਿਲੇ ਦੇਵਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nāḍ samāilo re satigur bheṭile devā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਨੂੰ ਪ੍ਰਭੂ-ਦੇਵ ਨੇ ਸਤਿਗੁਰੂ ਮਿਲਾ ਦਿੱਤਾ ਹੈ, (ਉਸ ਦੀ ਬਰਕਤਿ ਨਾਲ, ਮੇਰਾ ਮਨ) ਉਸ ਦੇ ਸ਼ਬਦ ਵਿਚ ਲੀਨ ਹੋ ਗਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Господь дал мне встречу с Сатгуру, и мой ум растворился в Его слове."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28417,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਝਿਲਿ ਮਿਲਿ ਕਾਰੁ ਦਿਸੰਤਾ ॥",
          "roman": "jah jhil mil kār disantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨ ਵਿਚ ਪਹਿਲਾਂ ਚੰਚਲਤਾ ਦਿੱਸ ਰਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Там, где раньше виднелась беспокойная суета,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28418,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਅਨਹਦ ਸਬਦ ਬਜੰਤਾ ॥",
          "roman": "tah anhad sabad bajantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉੱਥੇ ਹੁਣ ਇੱਕ-ਰਸ ਗੁਰ-ਸ਼ਬਦ ਦਾ ਪ੍ਰਭਾਵ ਪੈ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "теперь звучит непрерывный божественный звук."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28419,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤੀ ਜੋਤਿ ਸਮਾਨੀ ॥",
          "roman": "jotī jot samānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੀ ਆਤਮਾ ਪਰਮਾਤਮਾ ਵਿਚ ਮਿਲ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Моя душа слилась с Божественным Светом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28420,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਗੁਰ ਪਰਸਾਦੀ ਜਾਨੀ ॥੨॥",
          "roman": "mē gur parsādī jānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਂ ਉਸ ਜੋਤਿ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру я познал этот Свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28421,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨ ਕਮਲ ਕੋਠਰੀ ॥",
          "roman": "ratan kamal koṭharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਹਿਰਦੇ-ਕਮਲ ਦੀ ਕੋਠੜੀ ਵਿਚ ਰਤਨ ਸਨ (ਪਰ ਲੁਕੇ ਹੋਏ ਸਨ);"
            },
            "sahib_singh_ru": {
              "main": "Внутри моего сердца-лотоса были сокровища,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28422,
          "is_rahao": false,
          "gurmukhi": "ਚਮਕਾਰ ਬੀਜੁਲ ਤਹੀ ॥",
          "roman": "chamkār bījul tahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਉੱਥੇ (ਗੁਰੂ ਦੀ ਮਿਹਰ ਸਦਕਾ, ਮਾਨੋ) ਬਿਜਲੀ ਦੀ ਲਿਸ਼ਕ (ਵਰਗਾ ਚਾਨਣ) ਹੈ (ਤੇ ਉਹ ਰਤਨ ਦਿੱਸ ਪਏ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "и теперь там сияет свет, словно вспышка молнии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28423,
          "is_rahao": false,
          "gurmukhi": "ਨੇਰੈ ਨਾਹੀ ਦੂਰਿ ॥",
          "roman": "nerē nāhī dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਪ੍ਰਭੂ ਕਿਤੇ ਦੂਰ ਨਹੀਂ ਜਾਪਦਾ, ਨੇੜੇ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь Господь не кажется далёким — Он близок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28424,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਆਤਮੈ ਰਹਿਆ ਭਰਪੂਰਿ ॥੩॥",
          "roman": "nij ātmē rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਆਪਣੇ ਅੰਦਰ ਹੀ ਭਰਪੂਰ ਦਿੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он полностью пребывает внутри меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28425,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਅਨਹਤ ਸੂਰ ਉਜੵਾਰਾ ॥",
          "roman": "jah anhat sūr ujiyārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨ ਵਿਚ ਹੁਣ ਇੱਕ-ਰਸ ਸੂਰਜ ਦੇ ਚਾਨਣ ਵਰਗਾ ਚਾਨਣ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В том уме, где теперь сияет свет, подобный солнцу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28426,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਦੀਪਕ ਜਲੈ ਛੰਛਾਰਾ ॥",
          "roman": "tah dīpak jalē chhanchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇੱਥੇ ਪਹਿਲਾਂ (ਮਾਨੋ) ਮੱਧਮ ਜਿਹਾ ਦੀਵਾ ਬਲ ਰਿਹਾ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "раньше лишь тускло горел слабый светильник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28427,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਜਾਨਿਆ ॥",
          "roman": "gur parsādī jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੇਰੀ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру я познал Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28428,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਨਾਮਾ ਸਹਜ ਸਮਾਨਿਆ ॥੪॥੧॥",
          "roman": "jan Nāmā sahaj samāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੈਂ ਦਾਸ ਨਾਮਦੇਵ ਅਡੋਲ ਅਵਸਥਾ ਵਿਚ ਟਿਕ ਗਿਆ ਹਾਂ ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и я, раб Нама, утвердился в состоянии покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2515,
      "rahao_verse_id": 28434,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28429,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ੪ ਸੋਰਠਿ ॥",
          "roman": "ghar 4 soraṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28430,
          "is_rahao": false,
          "gurmukhi": "ਪਾੜ ਪੜੋਸਣਿ ਪੂਛਿ ਲੇ ਨਾਮਾ ਕਾ ਪਹਿ ਛਾਨਿ ਛਵਾਈ ਹੋ ॥",
          "roman": "pāṛ paṛosan pūchh le nāmā kā pah chhān chhavāī ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਲ ਦੀ ਗੁਆਂਢਣ ਨੇ ਪੁੱਛਿਆ-ਹੇ ਨਾਮੇ! ਤੂੰ ਆਪਣੀ ਛੰਨ ਕਿਸ ਪਾਸੋਂ ਬਣਵਾਈ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Соседка спросила: о Нама, у кого ты сделал свою хижину?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28431,
          "is_rahao": false,
          "gurmukhi": "ਤੋ ਪਹਿ ਦੁਗਣੀ ਮਜੂਰੀ ਦੈਹਉ ਮੋ ਕਉ ਬੇਢੀ ਦੇਹੁ ਬਤਾਈ ਹੋ ॥੧॥",
          "roman": "to pah dugṇī majūrī dehau mo kau beṛhī deh batāī ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਉਸ ਤਰਖਾਣ ਦੀ ਦੱਸ ਪਾ, ਮੈਂ ਤੇਰੇ ਨਾਲੋਂ ਦੂਣੀ ਮਜੂਰੀ ਦੇ ਦਿਆਂਗੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Скажи мне про того плотника, я дам ему вдвое больше платы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28432,
          "is_rahao": true,
          "gurmukhi": "ਰੀ ਬਾਈ ਬੇਢੀ ਦੇਨੁ ਨ ਜਾਈ ॥",
          "roman": "rī bāī beṛhī den na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭੈਣ! ਉਸ ਤਰਖਾਣ ਦੀ (ਇਸ ਤਰ੍ਹਾਂ) ਦੱਸ ਨਹੀਂ ਪਾਈ ਜਾ ਸਕਦੀ;"
            },
            "sahib_singh_ru": {
              "main": "О сестра, так рассказать о том плотнике невозможно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28433,
          "is_rahao": true,
          "gurmukhi": "ਦੇਖੁ ਬੇਢੀ ਰਹਿਓ ਸਮਾਈ ॥",
          "roman": "dekh beṛhī rahiō samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਖ, ਉਹ ਤਰਖਾਣ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "смотри — он присутствует повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28434,
          "is_rahao": true,
          "gurmukhi": "ਹਮਾਰੈ ਬੇਢੀ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "hamārē beṛhī prān adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ ਮੇਰੀ ਜਿੰਦ ਦਾ ਆਸਰਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и он — опора моей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28435,
          "is_rahao": false,
          "gurmukhi": "ਬੇਢੀ ਪ੍ਰੀਤਿ ਮਜੂਰੀ ਮਾਂਗੈ ਜਉ ਕੋਊ ਛਾਨਿ ਛਵਾਵੈ ਹੋ ॥",
          "roman": "beṛhī prīt majūrī māṅgē jau koū chhān chhavāvē ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭੈਣ!) ਜੇ ਕੋਈ ਮਨੁੱਖ (ਉਸ ਤਰਖਾਣ ਪਾਸੋਂ) ਛੰਨ ਬਣਵਾਏ ਤਾਂ ਉਹ ਤਰਖਾਣ ਪ੍ਰੀਤ (ਦੀ) ਮਜੂਰੀ ਮੰਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если кто хочет построить хижину у этого плотника, он просит плату в виде любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28436,
          "is_rahao": false,
          "gurmukhi": "ਲੋਗ ਕੁਟੰਬ ਸਭਹੁ ਤੇ ਤੋਰੈ ਤਉ ਆਪਨ ਬੇਢੀ ਆਵੈ ਹੋ ॥੨॥",
          "roman": "log kuṭamb sabhah te torē tau āpan beṛhī āvē ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰੀਤ ਭੀ ਅਜਿਹੀ ਹੋਵੇ ਕਿ ਲੋਕਾਂ ਨਾਲੋਂ, ਪਰਵਾਰ ਨਾਲੋਂ, ਸਭਨਾਂ ਨਾਲੋਂ, ਮੋਹ ਤੋੜ ਲਏ; ਤਾਂ ਉਹ ਤਰਖਾਣ ਆਪਣੇ ਆਪ ਆ ਜਾਂਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Если человек разрывает привязанность к людям и семье, тогда тот плотник сам приходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28437,
          "is_rahao": false,
          "gurmukhi": "ਐਸੋ ਬੇਢੀ ਬਰਨਿ ਨ ਸਾਕਉ ਸਭ ਅੰਤਰ ਸਭ ਠਾਂਈ ਹੋ ॥",
          "roman": "aiso beṛhī baran na sākau sabh antar sabh ṭhāī ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭੈਣ!) ਮੈਂ (ਉਸ) ਐਸੇ ਤਰਖਾਣ ਦਾ ਸਰੂਪ ਬਿਆਨ ਨਹੀਂ ਕਰ ਸਕਦਾ। (ਉਂਞ) ਉਹ ਸਭਨਾਂ ਵਿਚ ਹੈ, ਉਹ ਸਭ ਥਾਈਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я не могу описать такого плотника — он внутри всех и везде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28438,
          "is_rahao": false,
          "gurmukhi": "ਗੂੰਗੈ ਮਹਾ ਅੰਮ੍ਰਿਤ ਰਸੁ ਚਾਖਿਆ ਪੂਛੇ ਕਹਨੁ ਨ ਜਾਈ ਹੋ ॥੩॥",
          "roman": "gūṅgē mahā amrit ras chākhiā pūchhe kahan na jāī ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਜੇ ਕੋਈ ਗੁੰਗਾ ਬੜਾ ਸੁਆਦਲਾ ਪਦਾਰਥ ਖਾਏ ਤਾਂ ਪੁੱਛਿਆਂ (ਉਸ ਪਾਸੋਂ ਉਸ ਦਾ ਸੁਆਦ) ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Как немой, попробовавший сладкий вкус, не может описать его при расспросе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28439,
          "is_rahao": false,
          "gurmukhi": "ਬੇਢੀ ਕੇ ਗੁਣ ਸੁਨਿ ਰੀ ਬਾਈ ਜਲਧਿ ਬਾਂਧਿ ਧ੍ਰੂ ਥਾਪਿਓ ਹੋ ॥",
          "roman": "beṛhī ke guṇ sun rī bāī jaladh bāṅdh dhrū thāpio ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭੈਣ! ਉਸ ਤਰਖਾਣ ਦੇ (ਕੁਝ ਥੋੜੇ ਜਿਹੇ) ਗੁਣ ਸੁਣ ਲੈ-ਉਸ ਨੇ ਧ੍ਰੂ ਨੂੰ ਅਟੱਲ ਪਦਵੀ ਦਿੱਤੀ, ਉਸ ਨੇ ਸਮੁੰਦਰ (ਤੇ ਪੁਲ) ਬੱਧਾ,"
            },
            "sahib_singh_ru": {
              "main": "Послушай о качествах того плотника: он утвердил Дхрува и связал океан мостом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28440,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਕੇ ਸੁਆਮੀ ਸੀਅ ਬਹੋਰੀ ਲੰਕ ਭਭੀਖਣ ਆਪਿਓ ਹੋ ॥੪॥੨॥",
          "roman": "nāme ke suāmī sīā bahorī laṅk bhabhīkhaṇ āpio ho",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਦੇ (ਉਸ ਤਰਖਾਣ) ਨੇ (ਲੰਕਾਂ ਤੋਂ) ਸੀਤਾ ਮੋੜ ਕੇ ਲਿਆਂਦੀ ਤੇ ਭਭੀਖਣ ਨੂੰ ਲੰਕਾ ਦਾ ਮਾਲਕ ਬਣਾ ਦਿੱਤਾ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "он вернул Ситу и дал Бхабхихану царство Ланки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2516,
      "rahao_verse_id": 28447,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28441,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਘਰੁ ੩ ॥",
          "roman": "soraṭh ghar 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28442,
          "is_rahao": false,
          "gurmukhi": "ਅਣਮੜਿਆ ਮੰਦਲੁ ਬਾਜੈ ॥",
          "roman": "aṇmaṛiā mandal bājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਢੋਲ ਵੱਜਣ ਲੱਗ ਪੈਂਦਾ ਹੈ (ਪਰ ਉਹ ਢੋਲ ਖੱਲ ਨਾਲ) ਮੜ੍ਹਿਆ ਹੋਇਆ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри него звучит барабан, но он не покрыт кожей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28443,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਾਵਣ ਘਨਹਰੁ ਗਾਜੈ ॥",
          "roman": "bin sāvaṇ ghanhar gājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਮਨ ਵਿਚ) ਬੱਦਲ ਗੱਜਣ ਲੱਗ ਪੈਂਦਾ ਹੈ, ਪਰ ਉਹ ਬੱਦਲ ਸਾਵਣ ਮਹੀਨੇ ਦੀ ਉਡੀਕ ਨਹੀਂ ਕਰਦਾ (ਭਾਵ, ਹਰ ਵੇਲੇ ਗੱਜਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "в его уме гремят облака без ожидания месяца дождей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28444,
          "is_rahao": false,
          "gurmukhi": "ਬਾਦਲ ਬਿਨੁ ਬਰਖਾ ਹੋਈ ॥",
          "roman": "bādal bin barkhā hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਬੱਦਲਾਂ ਤੋਂ ਬਿਨਾ ਹੀ ਮੀਂਹ ਪੈਣ ਲੱਗ ਜਾਂਦਾ ਹੈ (ਬੱਦਲ ਤਾਂ ਕਦੇ ਆਏ ਤੇ ਕਦੇ ਚਲੇ ਗਏ, ਉੱਥੇ ਹਰ ਵੇਲੇ ਹੀ ਨਾਮ ਦੀ ਵਰਖਾ ਹੁੰਦੀ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "внутри него идёт дождь без облаков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28445,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਤਤੁ ਬਿਚਾਰੈ ਕੋਈ ॥੧॥",
          "roman": "jau tat bichārē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਭੀ ਕੋਈ ਮਨੁੱਖ ਅਸਲੀਅਤ ਨੂੰ ਵਿਚਾਰਦਾ ਹੈ (ਭਾਵ, ਜਿਸ ਦੇ ਭੀ ਅੰਦਰ ਇਹ ਮੇਲ-ਅਵਸਥਾ ਵਾਪਰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "у того, кто размышляет об истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28446,
          "is_rahao": true,
          "gurmukhi": "ਮੋ ਕਉ ਮਿਲਿਓ ਰਾਮੁ ਸਨੇਹੀ ॥",
          "roman": "mo kau miliō rām sanehī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਪਿਆਰਾ ਰਾਮ ਮਿਲ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я встретил любимого Рама,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28447,
          "is_rahao": true,
          "gurmukhi": "ਜਿਹ ਮਿਲਿਐ ਦੇਹ ਸੁਦੇਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jih mili-ai deh sudēhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਿਲਣ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰਾ ਸਰੀਰ ਭੀ ਚਮਕ ਪਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "от встречи с которым даже моё тело стало сияющим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28448,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਪਾਰਸ ਕੰਚਨੁ ਹੋਇਆ ॥",
          "roman": "mil pārās kanchan hoīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਰਸ ਨਾਲ ਛੋਹ ਕੇ (ਲੋਹਾ) ਸੋਨਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как железо становится золотом, коснувшись философского камня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28449,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖ ਮਨਸਾ ਰਤਨੁ ਪਰੋਇਆ ॥",
          "roman": "mukh mansā ratan paroīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਬਚਨਾਂ ਵਿਚ ਤੇ ਖ਼ਿਆਲਾਂ ਵਿਚ ਨਾਮ-ਰਤਨ ਹੀ ਪਰੋਤਾ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так теперь в моих словах и мыслях нанизано драгоценное имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28450,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਭਾਉ ਭਇਆ ਭ੍ਰਮੁ ਭਾਗਾ ॥",
          "roman": "nij bhāu bhaiā bhram bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨਾਲ ਹੁਣ) ਮੇਰਾ ਆਪਣਿਆਂ ਵਾਲਾ ਪਿਆਰ ਪੈ ਗਿਆ ਹੈ, (ਇਹ) ਭੁਲੇਖਾ ਰਹਿ ਹੀ ਨਹੀਂ ਗਿਆ (ਕਿ ਕਿਤੇ ਕੋਈ ਓਪਰਾ ਭੀ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Во мне возникла родственная любовь к Богу, и заблуждение исчезло,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28451,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਛੇ ਮਨੁ ਪਤੀਆਗਾ ॥੨॥",
          "roman": "gur pūchhe man patiāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਲੈ ਕੇ ਮੇਰਾ ਮਨ ਪਤੀਜ ਗਿਆ ਹੈ (ਤੇ ਸੁਅੱਛ ਹੋ ਗਿਆ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "приняв учение Гуру, мой ум успокоился."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28452,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਭੀਤਰਿ ਕੁੰਭ ਸਮਾਨਿਆ ॥",
          "roman": "jal bhītar kumbh samāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਸਮੁੰਦਰ ਦੇ) ਪਾਣੀ ਵਿਚ ਘੜੇ ਦਾ ਪਾਣੀ ਮਿਲ ਜਾਂਦਾ ਹੈ (ਤੇ ਆਪਣੀ ਵੱਖਰੀ ਹਸਤੀ ਮਿਟਾ ਲੈਂਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Как вода сосуда сливается с водой океана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28453,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਰਾਮੁ ਏਕੁ ਕਰਿ ਜਾਨਿਆ ॥",
          "roman": "sabh rām ek kar jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਭੀ ਹੁਣ ਹਰ ਥਾਂ ਰਾਮ ਹੀ ਰਾਮ ਦਿੱਸਦਾ ਹੈ (ਮੇਰੀ ਆਪਣੀ ਅਪਣੱਤ ਰਹੀ ਹੀ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "так теперь я вижу везде только Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28454,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚੇਲੇ ਹੈ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "gur chele hē man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸਤਿਗੁਰੂ ਨਾਲ ਮੇਰਾ ਮਨ ਇਕ-ਮਿਕ ਹੋ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мой ум стал единым с Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28455,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਮੈ ਤਤੁ ਪਛਾਨਿਆ ॥੩॥੩॥",
          "roman": "jan nāmē tat pachhāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੈਂ ਦਾਸ ਨਾਮੇ ਨੇ (ਜਗਤ ਦੇ) ਅਸਲੇ ਪਰਮਾਤਮਾ ਨਾਲ (ਪੱਕੀ) ਸਾਂਝ ਪਾ ਲਈ ਹੈ ॥੩॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и я, слуга Нама, познал сущность Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2517,
      "rahao_verse_id": 28461,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28456,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੋਰਠਿ ਬਾਣੀ ਭਗਤ ਰਵਿਦਾਸ ਜੀ ਕੀ",
          "roman": "rāg soraṭh bāṇī bhagat ravīdās jī kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੋਰਠਿ ਵਿੱਚ ਭਗਤ ਰਵਿਦਾਸ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Бхагата Равидаса в раге Сораṭх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28457,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог, постигаемый по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28458,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਹਮ ਹੋਤੇ ਤਬ ਤੂ ਨਾਹੀ ਅਬ ਤੂਹੀ ਮੈ ਨਾਹੀ ॥",
          "roman": "jab ham hote tab tū nāhī ab tūhī mē nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਾਧੋ!) ਜਿਤਨਾ ਚਿਰ ਅਸਾਂ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਹਉਮੈ ਰਹਿੰਦੀ ਹੈ, ਉਤਨਾ ਚਿਰ ਤੂੰ (ਅਸਾਡੇ ਅੰਦਰ) ਪਰਗਟ ਨਹੀਂ ਹੁੰਦਾ, ਪਰ ਜਦੋਂ ਤੂੰ ਪ੍ਰਤੱਖ ਹੁੰਦਾ ਹੈਂ ਤਦੋਂ ਅਸਾਡੀ 'ਮੈਂ' ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пока во мне было эго, Ты не проявлялся; когда проявляешься Ты, моё я исчезает."
