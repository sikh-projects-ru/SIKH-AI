{
  "ang": 661,
  "shabads": [
    {
      "shabad_id": 2526,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28569,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਲਗੁ ਦੁਨੀਆ ਰਹੀਐ ਨਾਨਕ ਕਿਛੁ ਸੁਣੀਐ ਕਿਛੁ ਕਹੀਐ ॥",
          "roman": "jab lag dunīā rahīai nānak kichh suṇīai kichh kahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਦ ਤਕ ਦੁਨੀਆ ਵਿਚ ਜੀਊਣਾ ਹੈ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਨੀ-ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ (ਇਹੀ ਹੈ ਮਨੁੱਖਾ ਜਨਮ ਦਾ ਲਾਭ, ਤੇ ਇਥੇ ਸਦਾ ਨਹੀਂ ਬੈਠ ਰਹਿਣਾ)।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Пока живём в мире, следует слушать и произносить хвалу Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28570,
          "is_rahao": false,
          "gurmukhi": "ਭਾਲਿ ਰਹੇ ਹਮ ਰਹਣੁ ਨ ਪਾਇਆ ਜੀਵਤਿਆ ਮਰਿ ਰਹੀਐ ॥੫॥੨॥",
          "roman": "bhāl rahe ham rahan na pāiā jīvatiā mar rahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਢੂੰਡ ਚੁਕੇ ਹਾਂ, ਕਿਸੇ ਨੂੰ ਸਦਾ ਦਾ ਟਿਕਾਣਾ ਇਥੇ ਨਹੀਂ ਮਿਲਿਆ, ਇਸ ਵਾਸਤੇ ਜਿਤਨਾ ਚਿਰ ਜੀਵਨ-ਅਵਸਰ ਮਿਲਿਆ ਹੈ ਦੁਨੀਆ ਦੀਆਂ ਵਾਸਨਾਂ ਵਲੋਂ ਮਰ ਕੇ ਜ਼ਿੰਦਗੀ ਦੇ ਦਿਨ ਗੁਜ਼ਾਰੀਏ ॥੫॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Мы искали и убедились — никто не нашёл здесь вечного пребывания, поэтому пока живы, следует умереть для мирских желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2527,
      "rahao_verse_id": 28578,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28571,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ਘਰੁ ਦੂਜਾ",
          "roman": "dhanāsrī mehlā 1 ghar dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਧਨਾਸਰੀ, ਘਰ ੨ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Дханасри, дом 2, бани Гуру Нанак Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28572,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28573,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਸਿਮਰੀ ਸਿਵਰਿਆ ਨਹੀ ਜਾਇ ॥",
          "roman": "kio simrī sivariā nahī jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਚਲਾਕੀ ਜਾਂ ਧੱਕੇ ਨਾਲ) ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ। ਫਿਰ ਮੈਂ ਕਿਵੇਂ ਉਸ ਦਾ ਸਿਮਰਨ ਕਰਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "С помощью хитрости или давления невозможно совершать поминание Бога. Тогда как же мне Его поминать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28574,
          "is_rahao": false,
          "gurmukhi": "ਤਪੈ ਹਿਆਉ ਜੀਅੜਾ ਬਿਲਲਾਇ ॥",
          "roman": "tapē hiāu jīṛā billāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੀਹ ਕੀਤਾ ਜਾਏ? ਉਸ ਦੀ ਯਾਦ ਤੋਂ ਬਿਨਾਂ) ਦਿਲ ਸੜਦਾ ਰਹਿੰਦਾ ਹੈ, ਜਿੰਦ ਦੁਖੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что делать? Без Его памяти сердце горит, душа страдает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28575,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਜਿ ਸਵਾਰੇ ਸਾਚਾ ਸੋਇ ॥",
          "roman": "siraj savāre sāchā soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ ਗੱਲ ਇਹ ਹੈ ਕਿ) ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਜੀਵਾਂ ਨੂੰ ਪੈਦਾ ਕਰ ਕੇ ਆਪ ਹੀ (ਸਿਮਰਨ ਦੀ ਦਾਤਿ ਦੇ ਕੇ) ਚੰਗੇ ਜੀਵਨ ਵਾਲਾ ਬਣਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Истина в том, что вечный Господь создаёт существ и Сам делает их благими, даруя память о Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28576,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਵਿਸਰਿਐ ਚੰਗਾ ਕਿਉ ਹੋਇ ॥੧॥",
          "roman": "tis visarai changā kio hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਭੁਲਾ ਦੇਈਏ, ਤਾਂ ਭੀ ਜੀਵਨ ਚੰਗਾ ਕਦੇ ਨਹੀਂ ਬਣ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Если забыть Его, жизнь никогда не может стать хорошей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28577,
          "is_rahao": true,
          "gurmukhi": "ਹਿਕਮਤਿ ਹੁਕਮਿ ਨ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "hikmat hukam na pāiā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ ਮਾਂ! ਕਿਸੇ ਚਲਾਕੀ ਨਾਲ ਜਾਂ ਕੋਈ ਹੱਕ ਜਤਾਣ ਨਾਲ ਪਰਮਾਤਮਾ ਨਹੀਂ ਮਿਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О мать моя! Ни хитростью, ни утверждением права невозможно достичь Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28578,
          "is_rahao": true,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਸਾਚਿ ਮਿਲਉ ਮੇਰੀ ਮਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kio kar sāch milau merī māe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਕਿਹੜਾ ਤਰੀਕਾ ਹੈ ਜਿਸ ਨਾਲ ਮੈਂ ਉਸ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਵਿਚ ਮਿਲ ਸਕਦਾ ਹਾਂ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Какой же путь есть, чтобы соединиться с этим вечным Господом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28579,
          "is_rahao": false,
          "gurmukhi": "ਵਖਰੁ ਨਾਮੁ ਦੇਖਣ ਕੋਈ ਜਾਇ ॥",
          "roman": "vakhar nām dekhan koe jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਉਸ ਦੀ ਮੇਹਰ ਨ ਹੋਵੇ ਤਾਂ) ਇਸ ਨਾਮ-ਵੱਖਰ ਨੂੰ ਨਾਹ ਕੋਈ ਪਰਖਣ ਲਈ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если нет Его милости, никто не идёт даже узнать этот товар Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28580,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕੋ ਚਾਖੈ ਨਾ ਕੋ ਖਾਇ ॥",
          "roman": "nā ko chākhē nā ko khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਕੋਈ ਇਸ ਨੂੰ ਖਾ ਕੇ ਵੇਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не пробует и не вкушает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28581,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕਿ ਪਤੀਣੈ ਨਾ ਪਤਿ ਹੋਇ ॥",
          "roman": "lok patīṇē nā pat hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਚਲਾਕੀਆਂ ਵਰਤ ਕੇ ਜਗਤ ਦੀ ਤਸੱਲੀ ਕਰਾ ਦਿੱਤੀ ਜਾਂਦੀ ਹੈ ਕਿ ਅਸੀਂ ਨਾਮ-ਵੱਖਰ ਵਿਹਾਝ ਰਹੇ ਹਾਂ) ਪਰ ਨਿਰਾ ਜਗਤ ਦੀ ਤਸੱਲੀ ਕਰਾਇਆਂ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ ਨਹੀਂ ਮਿਲਦਾ (ਲੋਕ-ਵਿਖਾਵੇ ਵਾਲੀ ਭਗਤੀ ਪਰਵਾਨ ਨਹੀਂ ਹੁੰਦੀ)।"
            },
            "sahib_singh_ru": {
              "main": "Можно обмануть мир, но лишь удовлетворяя людей, невозможно получить честь перед Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28582,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਪਤਿ ਰਹੈ ਰਾਖੈ ਜਾ ਸੋਇ ॥੨॥",
          "roman": "tā pat rahē rākhē jā soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇੱਜ਼ਤ ਤਦੋਂ ਹੀ ਮਿਲਦੀ ਹੈ ਜੇ ਪ੍ਰਭੂ (ਆਪ ਮੇਹਰ ਕਰ ਕੇ ਨਾਮ ਦੀ ਦਾਤਿ ਦੇਵੇ ਤੇ) ਇੱਜ਼ਤ ਰੱਖੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Честь сохраняется только тогда, когда Сам Господь сохраняет её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28583,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਦੇਖਾ ਤਹ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "jah dekhā tah rahiā samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜਿੱਧਰ ਮੈਂ ਵੇਖਦਾ ਹਾਂ ਉਧਰ ਹੀ ਤੂੰ ਮੌਜੂਦ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Куда ни посмотрю — везде Ты присутствуешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28584,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਬਿਨੁ ਦੂਜੀ ਨਾਹੀ ਜਾਇ ॥",
          "roman": "tudh bin dūjī nāhī jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੈਨੂੰ ਮਿਲਣ ਵਾਸਤੇ) ਤੈਥੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਆਸਰਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя нет другого прибежища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28585,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਕਰੇ ਕੀਤੈ ਕਿਆ ਹੋਇ ॥",
          "roman": "je ko kare kītē kiā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੋਈ ਜੀਵ (ਪ੍ਰਭੂ ਨੂੰ ਮਿਲਣ ਵਾਸਤੇ ਹਿਕਮਤਿ ਆਦਿਕ ਵਾਲਾ ਕੋਈ ਜਤਨ) ਕਰੇ, ਤਾਂ ਅਜੇਹੇ ਜਤਨ ਨਾਲ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Какие бы усилия ни предпринимал человек, они не приносят пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28586,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਬਖਸੇ ਸਾਚਾ ਸੋਇ ॥੩॥",
          "roman": "jis no bakhse sāchā soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਰਫ਼ ਉਹੀ ਜੀਵ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਸਕਦਾ ਹੈ) ਜਿਸ ਉਤੇ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਆਪ (ਸਿਮਰਨ ਦੀ) ਬਖ਼ਸ਼ਸ਼ ਕਰੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот достигает Бога, кого Сам вечный Господь одарит милостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28587,
          "is_rahao": false,
          "gurmukhi": "ਹੁਣਿ ਉਠਿ ਚਲਣਾ ਮੁਹਤਿ ਕਿ ਤਾਲਿ ॥",
          "roman": "hun uth chalṇā muhat k tāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਥੇ ਸਦਾ ਨਹੀਂ ਬੈਠੇ ਰਹਿਣਾ, ਇਥੋਂ) ਝਬਦੇ ਹੀ (ਹਰੇਕ ਜੀਵ ਨੇ ਆਪੋ ਆਪਣੀ ਵਾਰੀ) ਚਲੇ ਜਾਣਾ ਹੈ, ਇਕ ਪਲ ਵਿਚ ਜਾਂ ਇਕ ਤਾਲ ਵਿਚ (ਕਹਿ ਲਵੋ। ਇਥੇ ਪੱਕੇ ਡੇਰੇ ਨਹੀਂ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Здесь нельзя оставаться вечно, каждому предстоит уйти — в мгновение или в один миг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28588,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਮੁਹੁ ਦੇਸਾ ਗੁਣ ਨਹੀ ਨਾਲਿ ॥",
          "roman": "kiā muh desā guṇ nahī nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ, ਇਸ ਸਮੇ ਵਿਚ ਜੇ ਮੈਂ ਲੋਕ-ਵਿਖਾਵਾ ਹੀ ਕਰਦਾ ਰਿਹਾ, ਤਾਂ) ਮੈਂ ਕੀਹ ਮੂੰਹ ਵਿਖਾਵਾਂਗਾ? ਮੇਰੇ ਪੱਲੇ ਗੁਣ ਨਹੀਂ ਹੋਣਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "Что я покажу тогда, если у меня не будет добродетелей?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28589,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਨਦਰਿ ਕਰੇ ਤੈਸਾ ਹੋਇ ॥",
          "roman": "jēsī nadar kare tēsā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਪਰਮਾਤਮਾ ਜੇਹੋ ਜੇਹੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ ਜੀਵ ਉਹੋ ਜੇਹੇ ਜੀਵਨ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Какой взгляд бросит Господь, таким и становится человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28590,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਨਦਰੀ ਨਾਨਕ ਨਹੀ ਕੋਇ ॥੪॥੧॥੩॥",
          "roman": "viṇ nadrī nānak nahī koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਦੀ ਨਜ਼ਰ ਤੋਂ ਬਿਨਾ ਕੋਈ ਜੀਵ ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਨਹੀਂ ਸਕਦਾ ॥੪॥੧॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Без милостивого взгляда Бога никто не соединяется с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2528,
      "rahao_verse_id": 28597,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28591,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ॥",
          "roman": "dhanāsrī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28592,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਤਾ ਸਿਮਰਿਆ ਜਾਇ ॥",
          "roman": "nadar kare tā simariā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਮੇਹਰ ਦੀ ਨਜ਼ਰ ਕਰੇ ਤਾਂ (ਗੁਰੂ ਦੀ ਰਾਹੀਂ) ਉਸ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если Господь проявит милость, тогда возможно Его поминание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28593,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮਾ ਦ੍ਰਵੈ ਰਹੈ ਲਿਵ ਲਾਇ ॥",
          "roman": "ātmā dravē rahē liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਮਨੁੱਖ ਸਿਮਰਦਾ ਹੈ ਉਸ ਦਾ) ਆਤਮਾ (ਦੂਜਿਆਂ ਦੇ ਦੁੱਖ ਵੇਖ ਕੇ) ਨਰਮ ਹੁੰਦਾ ਹੈ (ਕਠੋਰਤਾ ਮੁੱਕ ਜਾਣ ਕਰਕੇ) ਉਹ ਪ੍ਰਭੂ ਵਿਚ ਸੁਰਤਿ ਜੋੜੀ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Душа такого человека становится мягкой и пребывает в соединении с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28594,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮਾ ਪਰਾਤਮਾ ਏਕੋ ਕਰੈ ॥",
          "roman": "ātmā parātmā eko karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਆਪੇ ਤੇ ਦੂਜਿਆਂ ਦੇ ਆਪੇ ਨੂੰ ਇਕੋ ਜਿਹਾ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он считает своё «я» и «я» других единым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28595,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰ ਕੀ ਦੁਬਿਧਾ ਅੰਤਰਿ ਮਰੈ ॥੧॥",
          "roman": "antar kī dubidhā antar marē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਦੀ ਮੇਰ-ਤੇਰ ਅੰਦਰ ਹੀ ਮਿਟ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Внутреннее разделение в нём исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28596,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "gur parsādī pāiā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹਾਸਲ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Поминание Бога достигается по милости Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28597,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਸਿਉ ਚਿਤੁ ਲਾਗੈ ਫਿਰਿ ਕਾਲੁ ਨ ਖਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har sio chit lāgē fir kāl na khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਜਿਸ ਮਨੁੱਖ ਦਾ ਚਿੱਤ ਪਰਮਾਤਮਾ ਨਾਲ ਪਰਚ ਜਾਂਦਾ ਹੈ ਉਸ ਨੂੰ ਮੁੜ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਪੋਂਹਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Чьё сознание соединяется с Богом, того больше не поражает смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28598,
          "is_rahao": false,
          "gurmukhi": "ਸਚਿ ਸਿਮਰਿਐ ਹੋਵੈ ਪਰਗਾਸੁ ॥",
          "roman": "sach simariā hovē pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਜਾਏ ਤਾਂ ਸਹੀ ਜੀਵਨ ਦੀ ਸੂਝ ਪੈ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "При поминании вечного Господа приходит истинное понимание жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28599,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇ ਬਿਖਿਆ ਮਹਿ ਰਹੈ ਉਦਾਸੁ ॥",
          "roman": "tā te bikhiā meh rahē udās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ 'ਪਰਗਾਸ' ਦੀ ਰਾਹੀਂ ਮਾਇਆ ਵਿਚ ਵਰਤਦਾ ਹੋਇਆ ਭੀ ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря этому человек остаётся отрешённым, даже находясь в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28600,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਕੀ ਐਸੀ ਵਡਿਆਈ ॥",
          "roman": "satgur kī aisī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਵਿਚ ਅਜੇਹੀ ਖ਼ੂਬੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такова слава Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28601,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਵਿਚੇ ਗਤਿ ਪਾਈ ॥੨॥",
          "roman": "putr kalatr viche gat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪੁਤ੍ਰ ਇਸਤ੍ਰੀ (ਆਦਿਕ ਪਰਵਾਰ) ਵਿਚ ਹੀ ਰਹਿੰਦਿਆਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "что, оставаясь среди семьи, человек достигает высокой духовной ступени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28602,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਸੇਵਕੁ ਸੇਵਾ ਕਰੈ ॥",
          "roman": "ēsī sevak sevā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਉਹ ਹੈ ਜੋ (ਮਾਲਕ ਦੀ) ਇਹੋ ਜਿਹੀ ਸੇਵਾ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга тот, кто служит так,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28603,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਜੀਉ ਤਿਸੁ ਆਗੈ ਧਰੈ ॥",
          "roman": "jis kā jīu tis āgē dharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਜਿਸ ਮਾਲਕ ਦੀ ਦਿੱਤੀ ਹੋਈ ਜਿੰਦ ਹੈ ਉਸੇ ਦੇ ਅੱਗੇ ਇਸ ਨੂੰ ਭੇਟਾ ਦੇ ਦੇਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "что предаёт свою жизнь Тому, Кто её дал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28604,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬ ਭਾਵੈ ਸੋ ਪਰਵਾਣੁ ॥",
          "roman": "sāhib bhāvē so parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜੇਹਾ ਸੇਵਕ ਮਾਲਕ ਨੂੰ ਪਸੰਦ ਆ ਜਾਂਦਾ ਹੈ, (ਮਾਲਕ ਦੇ ਘਰ ਵਿਚ) ਕਬੂਲ ਪੈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такой слуга становится угодным Господу и принимается Им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28605,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਦਰਗਹ ਪਾਵੈ ਮਾਣੁ ॥੩॥",
          "roman": "so sevak dargah pāvē māṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੇਵਕ ਉਸ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ-ਸਤਕਾਰ ਪਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он получает честь в Его присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28606,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਕੀ ਮੂਰਤਿ ਹਿਰਦੈ ਵਸਾਏ ॥",
          "roman": "satgur kī mūrat hirdē vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਸੇਵਕ ਆਪਣੇ ਸਤਿਗੁਰੂ ਦੇ ਆਤਮਕ-ਸਰੂਪ (ਸ਼ਬਦ) ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто поселяет в сердце образ Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28607,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਛੈ ਸੋਈ ਫਲੁ ਪਾਏ ॥",
          "roman": "jo ichhē soī phal pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ ਦੇ ਦਰ ਤੋਂ ਮਨ-ਇੱਛਤ ਫਲ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "получает желаемый плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28608,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਾ ਸਾਹਿਬੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "sāchā sāhib kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਉਸ ਉਤੇ (ਇਤਨੀ) ਮੇਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Вечный Господь оказывает ему милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28609,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਜਮ ਤੇ ਕੈਸਾ ਡਰੈ ॥੪॥",
          "roman": "so sevak jam te kēsā ḍarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਨੂੰ ਮੌਤ ਦਾ ਭੀ ਕੋਈ ਡਰ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и такой слуга не боится смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28610,
          "is_rahao": false,
          "gurmukhi": "ਭਨਤਿ ਨਾਨਕੁ ਕਰੇ ਵੀਚਾਰੁ ॥",
          "roman": "bhaṇat nānak kare vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-ਜਦੋਂ ਮਨੁੱਖ (ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ) ਵਿਚਾਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: когда человек размышляет над Словом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28611,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਬਾਣੀ ਸਿਉ ਧਰੇ ਪਿਆਰੁ ॥",
          "roman": "sāchī bāṇī sio dhare piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਾਲੀ ਇਸ ਗੁਰ-ਬਾਣੀ ਨਾਲ ਪਿਆਰ ਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он начинает любить истинную бани Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28612,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੋ ਪਾਵੈ ਮੋਖ ਦੁਆਰੁ ॥",
          "roman": "tā ko pāvē mokh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਹ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ) ਖ਼ਲਾਸੀ ਦਾ ਦਰਵਾਜ਼ਾ ਲੱਭ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда он находит дверь освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28613,
          "is_rahao": false,
          "gurmukhi": "ਜਪੁ ਤਪੁ ਸਭੁ ਇਹੁ ਸਬਦੁ ਹੈ ਸਾਰੁ ॥੫॥੨॥੪॥",
          "roman": "jap tap sabh ih sabad hē sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਾਲਾ ਇਹ) ਸ੍ਰੇਸ਼ਟ ਗੁਰ-ਸ਼ਬਦ ਹੀ ਅਸਲ ਜਪ ਹੈ ਅਸਲ ਤਪ ਹੈ ॥੫॥੨॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Этот высший Шабад — и есть истинное повторение и истинное подвижничество."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2529,
      "rahao_verse_id": 28620,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28614,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ॥",
          "roman": "dhanāsrī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28615,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਤਪਤੁ ਹੈ ਬਾਰੋ ਬਾਰ ॥",
          "roman": "jīu tapat hē bāro bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਵਿਸਾਰਿਆਂ) ਜਿੰਦ ਮੁੜ ਮੁੜ ਦੁਖੀ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Душа снова и снова страдает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28616,
          "is_rahao": false,
          "gurmukhi": "ਤਪਿ ਤਪਿ ਖਪੈ ਬਹੁਤੁ ਬੇਕਾਰ ॥",
          "roman": "tap tap khapē bahut bekār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਖੀ ਹੋ ਹੋ ਕੇ (ਫਿਰ ਭੀ) ਹੋਰ ਹੋਰ ਵਿਕਾਰਾਂ ਵਿਚ ਖ਼ੁਆਰ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, мучаясь, впадает в новые пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28617,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਤਨਿ ਬਾਣੀ ਵਿਸਰਿ ਜਾਇ ॥",
          "roman": "jē tan bāṇī visar jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸਰੀਰ ਵਿਚ (ਭਾਵ, ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਭੁੱਲ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек забывает бани Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28618,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪਕਾ ਰੋਗੀ ਵਿਲਲਾਇ ॥੧॥",
          "roman": "jio pakā rogī villāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਇਉਂ ਵਿਲਕਦਾ ਹੈ ਜਿਵੇਂ ਕੋੜ੍ਹ ਦੇ ਰੋਗ ਵਾਲਾ ਬੰਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "он плачет, как тяжело больной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28619,
          "is_rahao": true,
          "gurmukhi": "ਬਹੁਤਾ ਬੋਲਣੁ ਝਖਣੁ ਹੋਇ ॥",
          "roman": "bahutā bolaṇ jhakhaṇ hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਤੋਂ ਖ਼ਾਲੀ ਰਹਿਣ ਕਰ ਕੇ ਸਹੇੜੇ ਹੋਏ ਦੁੱਖਾਂ ਬਾਰੇ ਹੀ) ਬਹੁਤੇ ਗਿਲੇ ਕਰੀ ਜਾਣੇ ਵਿਅਰਥ ਬੋਲ-ਬੁਲਾਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Много жаловаться — бесполезная болтовня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28620,
          "is_rahao": true,
          "gurmukhi": "ਵਿਣੁ ਬੋਲੇ ਜਾਣੈ ਸਭੁ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "viṇ bole jāṇē sabh soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਉਹ ਪਰਮਾਤਮਾ ਸਾਡੇ ਗਿਲੇ ਕਰਨ ਤੋਂ ਬਿਨਾ ਹੀ (ਸਾਡੇ ਰੋਗਾਂ ਦਾ) ਸਾਰਾ ਕਾਰਣ ਜਾਣਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Ведь Бог знает всё и без слов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28621,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕਨ ਕੀਤੇ ਅਖੀ ਨਾਕੁ ॥",
          "roman": "jin kan kīte akhī nāk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁੱਖਾਂ ਤੋਂ ਬਚਣ ਵਾਸਤੇ ਉਸ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ) ਜਿਸ ਨੇ ਕੰਨ ਦਿੱਤੇ, ਅੱਖਾਂ ਦਿੱਤੀਆਂ, ਨੱਕ ਦਿੱਤਾ;"
            },
            "sahib_singh_ru": {
              "main": "Тот, Кто дал уши, глаза и нос,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28622,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਿਹਵਾ ਦਿਤੀ ਬੋਲੇ ਤਾਤੁ ॥",
          "roman": "jin jihvā ditī bole tāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਜੀਭ ਦਿੱਤੀ ਜੋ ਛੇਤੀ ਛੇਤੀ ਬੋਲਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Кто дал язык, который быстро говорит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
