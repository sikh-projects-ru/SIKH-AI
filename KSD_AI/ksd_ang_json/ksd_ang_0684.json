{
  "ang": 684,
  "shabads": [
    {
      "shabad_id": 2610,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29482,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਜਾ ਕਾ ਮਨੁ ਰਾਪੈ ॥",
          "roman": "charan kamal jā kā man rāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ (ਦੇ ਪ੍ਰੇਮ-ਰੰਗ) ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, чьё сердце окрашено любовью к прекрасным стопам Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29483,
          "is_rahao": false,
          "gurmukhi": "ਸੋਗ ਅਗਨਿ ਤਿਸੁ ਜਨ ਨ ਬਿਆਪੈ ॥੨॥",
          "roman": "sog agan tis jan na biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਉਤੇ ਚਿੰਤਾ ਦੀ ਅੱਗ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "того человека не затрагивает огонь печали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29484,
          "is_rahao": false,
          "gurmukhi": "ਸਾਗਰੁ ਤਰਿਆ ਸਾਧੂ ਸੰਗੇ ॥",
          "roman": "sāgar tariā sādhū saṅge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਨਾਮ ਜਪਣ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В обществе святых переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29485,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਨਾਮੁ ਜਪਹੁ ਹਰਿ ਰੰਗੇ ॥੩॥",
          "roman": "nirbhau nām japah har range",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰੇਮ ਨਾਲ ਨਿਰਭਉ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰੋ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "С любовью повторяйте Имя бесстрашного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29486,
          "is_rahao": false,
          "gurmukhi": "ਪਰ ਧਨ ਦੋਖ ਕਿਛੁ ਪਾਪ ਨ ਫੇੜੇ ॥",
          "roman": "par dhan dokh kichh pāp na pheṛe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਿਮਰਨ ਦਾ ਸਦਕਾ) ਪਰਾਏ ਧਨ (ਆਦਿਕ) ਦੇ ਕੋਈ ਐਬ ਪਾਪ ਮੰਦੇ ਕਰਮ ਨਹੀਂ ਹੁੰਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Благодаря поминанию не совершаются грехи и дурные поступки, связанные с чужим имуществом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29487,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਜੰਦਾਰੁ ਨ ਆਵੈ ਨੇੜੇ ॥੪॥",
          "roman": "jam jandār na āvē neṛe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਿਆਨਕ ਜਮ ਭੀ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦਾ (ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਵਿਆਪਦਾ, ਆਤਮਕ ਮੌਤ ਨੇੜੇ ਨਹੀਂ ਆਉਂਦੀ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Страшный Яма не приближается (нет страха смерти)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29488,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਸਨਾ ਅਗਨਿ ਪ੍ਰਭਿ ਆਪਿ ਬੁਝਾਈ ॥",
          "roman": "trisnā agan prabh āp bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜੇਹੜੇ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ) ਉਹਨਾਂ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਪ੍ਰਭੂ ਨੇ ਆਪ ਬੁਝਾ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! У тех, кто воспевает Бога, Он Сам гасит огонь жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29489,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੇ ਪ੍ਰਭ ਸਰਣਾਈ ॥੫॥੧॥੫੫॥",
          "roman": "nānak udhre prabh sarnāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਅਨੇਕਾਂ ਜੀਵ ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਵਿਚੋਂ) ਬਚ ਨਿਕਲਦੇ ਹਨ ॥੫॥੧॥੫੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Придя в убежище Господа, многие спасаются от огня жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2611,
      "rahao_verse_id": 29494,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29490,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "dhanāsarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29491,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਪਤਿ ਭਈ ਸਚੁ ਭੋਜਨੁ ਖਾਇਆ ॥",
          "roman": "tripat bhaī sach bhojan khāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਨੁੱਖ ਨੇ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ (ਦੀ) ਖ਼ੁਰਾਕ ਖਾਣੀ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤੀ ਉਸ ਨੂੰ (ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਵਲੋਂ) ਸ਼ਾਂਤੀ ਆ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек начал питаться вечной пищей — Именем Бога, и к нему приходит покой от жажды майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29492,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਰਸਨਾ ਨਾਮੁ ਧਿਆਇਆ ॥੧॥",
          "roman": "man tan rasnā nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣੇ ਮਨ ਵਿਚ, ਹਿਰਦੇ ਵਿਚ, ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "который в уме, в сердце и языком начал поминать Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29493,
          "is_rahao": true,
          "gurmukhi": "ਜੀਵਨਾ ਹਰਿ ਜੀਵਨਾ ॥",
          "roman": "jīvnā har jīvnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਹੀ ਹੈ ਅਸਲ ਜੀਵਨ, ਇਹੀ ਹੈ ਅਸਲ ਜ਼ਿੰਦਗ਼ੀ!"
            },
            "sahib_singh_ru": {
              "main": "О брат! Вот это и есть истинная жизнь, вот это и есть настоящая жизнь!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29494,
          "is_rahao": true,
          "gurmukhi": "ਜੀਵਨੁ ਹਰਿ ਜਪਿ ਸਾਧਸੰਗਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jīvan har jap sādhsaṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਬੈਠ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "— пребывая в садх-сангате, повторяйте Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29495,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪ੍ਰਕਾਰੀ ਬਸਤ੍ਰ ਓਢਾਏ ॥",
          "roman": "anik prakārī bastra oḍhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ (ਮਾਨੋ) ਕਈ ਕਿਸਮਾਂ ਦੇ (ਵੰਨ ਸੁਵੰਨੇ) ਕੱਪੜੇ ਪਹਿਨ ਲਏ ਹਨ (ਤੇ ਉਹ ਇਹਨਾਂ ਸੋਹਣੀਆਂ ਪੁਸ਼ਾਕਾਂ ਦਾ ਆਨੰਦ ਮਾਣ ਰਿਹਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Такой человек словно облачился в разные прекрасные одежды и наслаждается ими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29496,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਕੀਰਤਨੁ ਹਰਿ ਗੁਨ ਗਾਏ ॥੨॥",
          "roman": "anadin kīrtan har gun gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਹਰ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ, ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот, кто постоянно прославляет Бога и поёт Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29497,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤੀ ਰਥ ਅਸੁ ਅਸਵਾਰੀ ॥",
          "roman": "hastī rath asu asvārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਮਨੁੱਖ (ਮਾਨੋ) ਹਾਥੀ ਰਥਾਂ ਘੋੜਿਆਂ ਦੀ ਸਵਾਰੀ (ਦਾ ਸੁਖ ਮਾਣ ਰਿਹਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Такой человек словно наслаждается ездой на слонах, колесницах и конях,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29498,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਮਾਰਗੁ ਰਿਦੈ ਨਿਹਾਰੀ ॥੩॥",
          "roman": "har kā mārag ridē nihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਮਿਲਾਪ ਦਾ ਰਾਹ ਤੱਕਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "который в сердце ищет путь к встрече с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29499,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਅੰਤਰਿ ਚਰਨ ਧਿਆਇਆ ॥",
          "roman": "man tan antar charan dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣੇ ਮਨ ਵਿਚ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто в уме и сердце начал созерцать стопы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29500,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸੁਖ ਨਿਧਾਨ ਨਾਨਕ ਦਾਸਿ ਪਾਇਆ ॥੪॥੨॥੫੬॥",
          "roman": "har sukh nidhān nānak dās pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦਾਸ ਨੇ ਸੁਖਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਨੂੰ ਲੱਭ ਲਿਆ ਹੈ ॥੪॥੨॥੫੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот слуга обрел Бога — сокровищницу блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2612,
      "rahao_verse_id": 29503,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29501,
          "is_rahao": true,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "dhanāsarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29502,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਨ ਜੀਅ ਕਾ ਨਿਸਤਾਰਾ ॥",
          "roman": "gur ke charan jīa kā nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਜਿੰਦ ਵਾਸਤੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣ ਲਈ ਵਸੀਲਾ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Созерцание стоп Гуру — средство для спасения души от океана мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29503,
          "is_rahao": true,
          "gurmukhi": "ਸਮੁੰਦੁ ਸਾਗਰੁ ਜਿਨਿ ਖਿਨ ਮਹਿ ਤਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "samund sāgar jin khin meh tārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਨੇ (ਸਰਨ ਆਏ ਮਨੁੱਖ ਨੂੰ ਸਦਾ) ਇਕ ਛਿਨ ਵਿਚ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тот Гуру, который в одно мгновение переправляет через этот океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29504,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਹੋਆ ਕ੍ਰਮ ਰਤੁ ਕੋਈ ਤੀਰਥ ਨਾਇਆ ॥",
          "roman": "koī hoā karam rat koī tīrath nāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਮਨੁੱਖ ਧਾਰਮਿਕ ਰਸਮਾਂ ਦਾ ਪ੍ਰੇਮੀ ਬਣ ਜਾਂਦਾ ਹੈ; ਕੋਈ ਮਨੁੱਖ ਤੀਰਥਾਂ ਉੱਤੇ ਇਸ਼ਨਾਨ ਕਰਦਾ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кто-то становится приверженцем обрядов, кто-то ходит омываться в местах паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29505,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸੰੀ ਹਰਿ ਕਾ ਨਾਮੁ ਧਿਆਇਆ ॥੧॥",
          "roman": "dāsīṁ har kā nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਦਾਸਾਂ ਨੇ (ਸਦਾ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਿਮਰਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но рабы Бога всегда поминали только Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29506,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਨਹਾਰੁ ਸੁਆਮੀ ॥",
          "roman": "bandhan kāṭanhār suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੋ ਪਰਮਾਤਮਾ ਸਭ ਦਾ ਮਾਲਕ ਹੈ, ਜੋ (ਜੀਵਾਂ ਦੇ ਮਾਇਆ ਦੇ) ਬੰਧਨ ਕੱਟਣ ਦੀ ਸਮਰਥਾ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог — Владыка, способный разрубить узы майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29507,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕੁ ਸਿਮਰੈ ਅੰਤਰਜਾਮੀ ॥੨॥੩॥੫੭॥",
          "roman": "jan nānak simrē antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ (ਭੀ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਸਿਮਰਦਾ ਹੈ ਜੋ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ ॥੨॥੩॥੫੭॥"
            },
            "sahib_singh_ru": {
              "main": "слуга Нанак помнит Того, кто знает сердца всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2613,
      "rahao_verse_id": 29509,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29508,
          "is_rahao": true,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "dhanāsarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29509,
          "is_rahao": true,
          "gurmukhi": "ਕਿਤੈ ਪ੍ਰਕਾਰਿ ਨ ਤੂਟਉ ਪ੍ਰੀਤਿ ॥ ਦਾਸ ਤੇਰੇ ਕੀ ਨਿਰਮਲ ਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kitē prakār na tūṭau prīt dās tere kī nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਕਿਸੇ ਤਰ੍ਹਾਂ ਭੀ (ਤੇਰੇ ਦਾਸਾਂ ਦੀ) ਪ੍ਰੀਤਿ (ਕਿਧਰੇ ਤੇਰੇ ਨਾਲੋਂ) ਟੁੱਟ ਨਾਹ ਜਾਏ, (ਇਸ ਲਈ) ਤੇਰੇ ਦਾਸਾਂ ਦੀ ਰਹਿਣੀ-ਬਹਿਣੀ ਪਵਿਤ੍ਰ ਰਹਿੰਦੀ ਹੈ  ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Пусть ни при каких обстоятельствах любовь Твоих слуг к Тебе не прервётся — поэтому их образ жизни остаётся чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29510,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਨ ਮਨ ਧਨ ਤੇ ਪਿਆਰਾ ॥",
          "roman": "jīa prān man dhan te piārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਦਾਸਾਂ ਨੂੰ ਆਪਣੀ ਜਿੰਦ ਨਾਲੋਂ, ਪ੍ਰਾਣਾਂ ਨਾਲੋਂ, ਮਨ ਨਾਲੋਂ, ਧਨ ਨਾਲੋਂ, ਉਹ ਪਰਮਾਤਮਾ ਸਦਾ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Для слуг Бога Он дороже жизни, дыхания, ума и богатства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29511,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਬੰਧੁ ਹਰਿ ਦੇਵਣਹਾਰਾ ॥੧॥",
          "roman": "haumē bandh har devan hārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਹਉਮੈ ਦੇ ਰਾਹ ਵਿਚ ਬੰਨ੍ਹ ਮਾਰਨ ਦੀ ਸਮਰਥਾ ਰੱਖਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто способен разрушить узы эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29512,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗਉ ਨੇਹੁ ॥",
          "roman": "charan kamal siu lāgau neh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ (ਨਾਨਕ ਦਾ) ਪਿਆਰ ਬਣਿਆ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть любовь к Его прекрасным стопам сохраняется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29513,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਬੇਨੰਤੀ ਏਹ ॥੨॥੪॥੫੮॥",
          "roman": "nānak kī benantī eh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਦੀ (ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਸਦਾ) ਇਹੀ ਅਰਦਾਸ ਹੈ ॥੨॥੪॥੫੮॥"
            },
            "sahib_singh_ru": {
              "main": "это постоянная молитва Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2614,
      "rahao_verse_id": 29517,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29514,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог существует и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29515,
          "is_rahao": true,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੯ ॥",
          "roman": "dhanāsarī mehlā 9",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਧਨਾਸਰੀ ਵਿੱਚ ਗੁਰੂ ਤੇਗਬਹਾਦਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Тег Бахадура в раге Дханасари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29516,
          "is_rahao": true,
          "gurmukhi": "ਕਾਹੇ ਰੇ ਬਨ ਖੋਜਨ ਜਾਈ ॥",
          "roman": "kāhe re ban khojan jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਨੂੰ) ਲੱਭਣ ਵਾਸਤੇ ਤੂੰ ਜੰਗਲਾਂ ਵਿਚ ਕਿਉਂ ਜਾਂਦਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Зачем ты идёшь в леса искать Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29517,
          "is_rahao": true,
          "gurmukhi": "ਸਰਬ ਨਿਵਾਸੀ ਸਦਾ ਅਲੇਪਾ ਤੋਹੀ ਸੰਗਿ ਸਮਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarab nivāsī sadā alepā tohī saṅg samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਸਭ ਵਿਚ ਵੱਸਣ ਵਾਲਾ ਹੈ, (ਫਿਰ ਭੀ) ਸਦਾ (ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ) ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ। ਉਹ ਪਰਮਾਤਮਾ ਤੇਰੇ ਨਾਲ ਹੀ ਵੱਸਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Бог пребывает во всём и остаётся непривязанным к майе; Он всегда с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29518,
          "is_rahao": false,
          "gurmukhi": "ਪੁਹਪ ਮਧਿ ਜਿਉ ਬਾਸੁ ਬਸਤੁ ਹੈ ਮੁਕਰ ਮਾਹਿ ਜੈਸੇ ਛਾਈ ॥",
          "roman": "puhap madh jiu bās bast hē mukar māh jēse chhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਵੇਂ ਫੁੱਲ ਵਿਚ ਸੁਗੰਧੀ ਵੱਸਦੀ ਹੈ, ਜਿਵੇਂ ਸ਼ੀਸ਼ੇ ਵਿਚ (ਸ਼ੀਸ਼ਾ ਵੇਖਣ ਵਾਲੇ ਦਾ) ਅਕਸ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Как аромат пребывает в цветке, как отражение находится в зеркале,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29519,
          "is_rahao": false,
          "gurmukhi": "ਤੈਸੇ ਹੀ ਹਰਿ ਬਸੇ ਨਿਰੰਤਰਿ ਘਟ ਹੀ ਖੋਜਹੁ ਭਾਈ ॥੧॥",
          "roman": "tēse hī har base nirantar ghaṭ hī khojah bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਇਕ-ਰਸ ਸਭਨਾਂ ਦੇ ਅੰਦਰ ਵੱਸਦਾ ਹੈ। (ਇਸ ਵਾਸਤੇ, ਉਸ ਨੂੰ) ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਹੀ ਲੱਭ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так и Бог пребывает внутри всех — ищи Его в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29520,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਭੀਤਰਿ ਏਕੋ ਜਾਨਹੁ ਇਹੁ ਗੁਰ ਗਿਆਨੁ ਬਤਾਈ ॥",
          "roman": "bāhar bhītar eko jānh ihu gur giān batāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ (ਆਤਮਕ ਜੀਵਨ ਦਾ) ਉਪਦੇਸ਼ ਇਹ ਦੱਸਦਾ ਹੈ ਕਿ (ਆਪਣੇ ਸਰੀਰ ਦੇ) ਅੰਦਰ (ਅਤੇ ਆਪਣੇ ਸਰੀਰ ਤੋਂ) ਬਾਹਰ (ਹਰ ਥਾਂ) ਇਕ ਪਰਮਾਤਮਾ ਨੂੰ (ਵੱਸਦਾ) ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Учение Гуру говорит: понимай, что внутри и снаружи — везде один Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29521,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਬਿਨੁ ਆਪਾ ਚੀਨੈ ਮਿਟੈ ਨ ਭ੍ਰਮ ਕੀ ਕਾਈ ॥੨॥੧॥",
          "roman": "jan nānak bin āpā chīnē miṭē na bhram kī kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! ਆਪਣਾ ਆਤਮਕ ਜੀਵਨ ਪਰਖਣ ਤੋਂ ਬਿਨਾ (ਮਨ ਉੱਤੋਂ) ਭਟਕਣਾ ਦਾ ਜਾਲਾ ਦੂਰ ਨਹੀਂ ਹੋ ਸਕਦਾ (ਤੇ, ਉਤਨਾ ਚਿਰ ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਦੀ ਸੂਝ ਨਹੀਂ ਆ ਸਕਦੀ) ॥੨॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! Без познания своего внутреннего «я» заблуждение не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
