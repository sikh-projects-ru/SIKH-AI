{
  "ang": 710,
  "shabads": [
    {
      "shabad_id": 2715,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30490,
          "is_rahao": false,
          "gurmukhi": "ਭਾਹਿ ਬਲੰਦੜੀ ਬੁਝਿ ਗਈ ਰਖੰਦੜੋ ਪ੍ਰਭੁ ਆਪਿ ॥",
          "roman": "bhāh balandṛī bujh gaī rakhandṛo prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Высоко разгоревшийся огонь погас: сам Господь стал защитником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30491,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਉਪਾਈ ਮੇਦਨੀ ਨਾਨਕ ਸੋ ਪ੍ਰਭੁ ਜਾਪਿ ॥੨॥",
          "roman": "jin upāī mednī nānak so prabh jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, помни того Господа, который сотворил землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2716,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30492,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30493,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਪ੍ਰਭ ਭਏ ਦਇਆਲ ਨ ਬਿਆਪੈ ਮਾਇਆ ॥",
          "roman": "jā prabh bhaē dēāl na biāpē māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь становится милостивым к живому существу, майя не может взять над ним силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30494,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਅਘਾ ਗਏ ਨਾਸ ਹਰਿ ਇਕੁ ਧਿਆਇਆ ॥",
          "roman": "koṭ aghā gaē nās har ik dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек вспоминает одного Господа, уничтожаются миллионы грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30495,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਭਏ ਸਰੀਰ ਜਨ ਧੂਰੀ ਨਾਇਆ ॥",
          "roman": "nirmal bhaē sarīr jan dhūrī nāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Омывшись в пыли стоп святых людей, тела становятся чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30496,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਭਏ ਸੰਤੋਖ ਪੂਰਨ ਪ੍ਰਭੁ ਪਾਇਆ ॥",
          "roman": "man tan bhaē santokh pūran prabh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе святых обретается совершенный Господь, и ум и тело получают удовлетворённость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30497,
          "is_rahao": false,
          "gurmukhi": "ਤਰੇ ਕੁਟੰਬ ਸੰਗਿ ਲੋਗ ਕੁਲ ਸਬਾਇਆ ॥੧੮॥",
          "roman": "tarē kuṭamb saṅg log kul sabāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе таких людей спасаются их семьи, родные люди и все их роды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2717,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30498,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30499,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਗੋਬਿੰਦ ਗੋਪਾਲ ਗੁਰ ਗੁਰ ਪੂਰਨ ਨਾਰਾਇਣਹ ॥",
          "roman": "gur gobind gopāl gur gur pūran nārāiṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру есть образ Гобинда, образ Гопала, образ всепроникающего Нараяна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30500,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਦਇਆਲ ਸਮਰਥ ਗੁਰ ਗੁਰ ਨਾਨਕ ਪਤਿਤ ਉਧਾਰਣਹ ॥੧॥",
          "roman": "gur daiāl samrath gur gur nānak patit udhāraṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Гуру — дом милости, он обладает силой и спасает даже падших."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30501,
          "is_rahao": false,
          "gurmukhi": "ਭਉਜਲੁ ਬਿਖਮੁ ਅਸਗਾਹੁ ਗੁਰਿ ਬੋਹਿਥੈ ਤਾਰਿਅਮੁ ॥",
          "roman": "bhaujal bikham asgāh gur bohithē tāriam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Океан мира страшен, труден и бездонен, но Гуру-корабль переправил меня через него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30502,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪੂਰ ਕਰੰਮ ਸਤਿਗੁਰ ਚਰਣੀ ਲਗਿਆ ॥੨॥",
          "roman": "nānak pūr karam satigur charṇī lagiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у тех, кто припадает к стопам Сатгуру, добрая и полная судьба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2718,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30503,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30504,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਧੰਨੁ ਗੁਰਦੇਵ ਜਿਸੁ ਸੰਗਿ ਹਰਿ ਜਪੇ ॥",
          "roman": "dhan dhan gurdev jis saṅg har japē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословен, благословен Гуру: в его обществе можно совершать воспоминание Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30505,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕ੍ਰਿਪਾਲ ਜਬ ਭਏ ਤ ਅਵਗੁਣ ਸਭਿ ਛਪੇ ॥",
          "roman": "gur kripāl jab bhaē ta avguṇ sabh chhapē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Сатгуру становится милостивым, все пороки исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30506,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਰਦੇਵ ਨੀਚਹੁ ਉਚ ਥਪੇ ॥",
          "roman": "pārbraham gurdev nīchah uch thapē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру, образ Парабрахмана, поднимает низких и утверждает их высокими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30507,
          "is_rahao": false,
          "gurmukhi": "ਕਾਟਿ ਸਿਲਕ ਦੁਖ ਮਾਇਆ ਕਰਿ ਲੀਨੇ ਅਪ ਦਸੇ ॥",
          "roman": "kāṭ silak dukh māiā kar līnē ap dasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он разрезает петлю страданий майи и делает людей своими слугами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30508,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਏ ਬੇਅੰਤ ਰਸਨਾ ਹਰਿ ਜਸੇ ॥੧੯॥",
          "roman": "guṇ gāē beant rasnā har jasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру языком можно воспевать качества бесконечного Господа и совершать Его хвалу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2719,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30509,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30510,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿਸਟੰਤ ਏਕੋ ਸੁਨੀਅੰਤ ਏਕੋ ਵਰਤੰਤ ਏਕੋ ਨਰਹਰਹ ॥",
          "roman": "drisṭant eko sunīant eko vartant eko narharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем, на кого милостивый Господь изливает благодать, везде видится, слышится и ощущается присутствующим один Владыка творения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30511,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਦਾਨੁ ਜਾਚੰਤਿ ਨਾਨਕ ਦਇਆਲ ਪੁਰਖ ਕ੍ਰਿਪਾ ਕਰਹ ॥੧॥",
          "roman": "nām dān jāchant nānak daiāl purakh kripā karah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такие люди просят у Него дар преданности и Имени, когда милостивый Пурукх являет благодать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30512,
          "is_rahao": false,
          "gurmukhi": "ਹਿਕੁ ਸੇਵੀ ਹਿਕੁ ਸੰਮਲਾ ਹਰਿ ਇਕਸੁ ਪਹਿ ਅਰਦਾਸਿ ॥",
          "roman": "hik sevī hik sammalā har ikas pah ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя мольба только к одному Господу: чтобы я вспоминал Его одного и хранил Его одного в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30513,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਵਖਰੁ ਧਨੁ ਸੰਚਿਆ ਨਾਨਕ ਸਚੀ ਰਾਸਿ ॥੨॥",
          "roman": "nām vakhar dhan sanchiā nānak sachī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто накопил товар Имени и богатство Имени, обладают истинным капиталом, который остаётся навсегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2720,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30514,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30515,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਇਆਲ ਬੇਅੰਤ ਪੂਰਨ ਇਕੁ ਏਹੁ ॥",
          "roman": "prabh daiāl beant pūran ik eh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только этот милостивый и бесконечный Господь присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30516,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਆਪੇ ਆਪਿ ਦੂਜਾ ਕਹਾ ਕੇਹੁ ॥",
          "roman": "sabh kichh āpē āp dūjā kahā keh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам по себе есть всё; кого ещё, второго, можно было бы назвать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30517,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਕਰਹੁ ਪ੍ਰਭ ਦਾਨੁ ਆਪੇ ਆਪਿ ਲੇਹੁ ॥",
          "roman": "āp karah prabh dān āpē āp leh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты сам даёшь дар и сам же принимаешь этот дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30518,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣ ਜਾਣਾ ਹੁਕਮੁ ਸਭੁ ਨਿਹਚਲੁ ਤੁਧੁ ਥੇਹੁ ॥",
          "roman": "āvaṇ jāṇā hukam sabh nihchal tudh theh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рождение и смерть — всё это Твой Хукам, Твоя игра; Твоё собственное место пребывания вечно и неизменно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30519,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮੰਗੈ ਦਾਨੁ ਕਰਿ ਕਿਰਪਾ ਨਾਮੁ ਦੇਹੁ ॥੨੦॥੧॥",
          "roman": "nānak maṅgē dān kar kirpā nām deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак просит у Тебя дар: яви милость и подари Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2721,
      "rahao_verse_id": 30523,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30520,
          "is_rahao": true,
          "gurmukhi": "ਜੈਤਸਰੀ ਬਾਣੀ ਭਗਤਾ ਕੀ",
          "roman": "jētsarī bāṇī bhagtā kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Джайтсари, Бани бхагатов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30521,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30522,
          "is_rahao": true,
          "gurmukhi": "ਨਾਥ ਕਛੂਅ ਨ ਜਾਨਉ ॥",
          "roman": "nāth kachhūa na jānau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, я ничего не знаю, мне ничего не приходит на ум, перед майей у меня нет никакого средства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30523,
          "is_rahao": true,
          "gurmukhi": "ਮਨੁ ਮਾਇਆ ਕੈ ਹਾਥਿ ਬਿਕਾਨਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man māiā kē hāth bikānau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я уже продал свой ум в руки майи; теперь перед ней у меня нет силы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30524,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਕਹੀਅਤ ਹੌ ਜਗਤ ਗੁਰ ਸੁਆਮੀ ॥",
          "roman": "tum kahīat hau jagat gur suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка, Ты называешься Господином мира, его Учителем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30525,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਕਹੀਅਤ ਕਲਿਜੁਗ ਕੇ ਕਾਮੀ ॥੧॥",
          "roman": "ham kahīat kalijug ke kāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А мы — чувственные существа Кали-юги; помоги мне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30526,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਪੰਚਨ ਮੇਰੋ ਮਨੁ ਜੁ ਬਿਗਾਰਿਓ ॥",
          "roman": "in panchan mero man ju bigāriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти пятеро — похоть и другие пороки — настолько испортили мой ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30527,
          "is_rahao": false,
          "gurmukhi": "ਪਲੁ ਪਲੁ ਹਰਿ ਜੀ ਤੇ ਅੰਤਰੁ ਪਾਰਿਓ ॥੨॥",
          "roman": "pal pal har jī te antar pāriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что каждое мгновение они отдаляют меня от возлюбленного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30528,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਦੇਖਉ ਤਤ ਦੁਖ ਕੀ ਰਾਸੀ ॥",
          "roman": "jat dekhau tat dukh kī rāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни посмотрел, всюду накоплена масса страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30529,
          "is_rahao": false,
          "gurmukhi": "ਅਜੌਂ ਨ ਪਤੵਾਇ ਨਿਗਮ ਭਏ ਸਾਖੀ ॥੩॥",
          "roman": "ajauṅ na patyāi nigam bhaē sākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже видя, что страдание — плод пороков, мой ум всё ещё не верит; и Веды с другими священными книгами свидетельствуют о том же."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30530,
          "is_rahao": false,
          "gurmukhi": "ਗੋਤਮ ਨਾਰਿ ਉਮਾਪਤਿ ਸ੍ਵਾਮੀ ॥ ਸੀਸੁ ਧਰਨਿ ਸਹਸ ਭਗ ਗਾਂਮੀ ॥੪॥",
          "roman": "gotam nār umāpat suāmī sīs dharan sahas bhag gāṃmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жена Готама Ахалья, супруг Умы Шива, Брахма и Индра с тысячью знаков — всех их эти пятеро пороков опозорили."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30531,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਦੂਤਨ ਖਲੁ ਬਧੁ ਕਰਿ ਮਾਰਿਓ ॥",
          "roman": "in dūtan khal badh kar māriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти злые посланцы жестоко избили мой глупый ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30532,
          "is_rahao": false,
          "gurmukhi": "ਬਡੋ ਨਿਲਾਜੁ ਅਜਹੂ ਨਹੀ ਹਾਰਿਓ ॥੫॥",
          "roman": "baḍo nilāj ajahū nahī hāriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но этот ум очень бесстыден: даже теперь он не отвратился от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30533,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਰਵਿਦਾਸ ਕਹਾ ਕੈਸੇ ਕੀਜੈ ॥",
          "roman": "kah ravidas kahā kēsē kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Равидас говорит: куда ещё идти и что ещё делать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30534,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਰਘੁਨਾਥ ਸਰਨਿ ਕਾ ਕੀ ਲੀਜੈ ॥੬॥੧॥",
          "roman": "bin raghunāth saran kā kī lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чтобы спастись от этих пороков, кроме Параматмы нельзя принять прибежище ни у кого другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
