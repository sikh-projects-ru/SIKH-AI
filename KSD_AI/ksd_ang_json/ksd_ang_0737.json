{
  "ang": 737,
  "shabads": [
    {
      "shabad_id": 2808,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31454,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਲਾਇ ਲਏ ਸੋ ਲਾਗੈ ॥",
          "roman": "jis no lāi lae so lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹੀ ਮਨੁੱਖ ਪ੍ਰਭੂ (ਦੇ ਚਰਨਾਂ) ਵਿਚ ਲੀਨ ਹੁੰਦਾ ਹੈ, ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਆਪ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਜੋੜਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот соединяется с Богом, кого Он Сам соединяет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31455,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨ ਰਤਨੁ ਅੰਤਰਿ ਤਿਸੁ ਜਾਗੈ ॥",
          "roman": "giān ratan antar tis jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਰਤਨ (ਵਰਗੀ ਕੀਮਤੀ) ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਉੱਘੜ ਪੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри такого человека пробуждается драгоценное знание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31456,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਜਾਇ ਪਰਮ ਪਦੁ ਪਾਏ ॥",
          "roman": "durmat jāi param pad pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਖੋਟੀ ਮਤਿ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ, ਉਹ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его дурной ум исчезает, и он достигает высшего состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31457,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਨਾਮੁ ਧਿਆਏ ॥੩॥",
          "roman": "gur prasādī nām dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਹ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру он размышляет о Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31458,
          "is_rahao": false,
          "gurmukhi": "ਦੁਇ ਕਰ ਜੋੜਿ ਕਰਉ ਅਰਦਾਸਿ ॥",
          "roman": "dui kar joṛ karau ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ (ਆਪਣੇ) ਦੋਵੇਂ ਹੱਥ ਜੋੜ ਕੇ (ਤੇਰੇ ਦਰ ਤੇ) ਅਰਦਾਸ ਕਰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Сложив обе руки, я совершаю молитву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31459,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਤਾ ਆਣਹਿ ਰਾਸਿ ॥",
          "roman": "tudh bhāvē tā āṇeh rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗੇ (ਤੇਰੀ ਰਜ਼ਾ ਹੋਵੇ) ਤਦੋਂ ਹੀ ਤੂੰ ਉਸ ਅਰਦਾਸ ਨੂੰ ਸਫਲ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Если Тебе угодно, Ты делаешь эту молитву успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31460,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪਨੀ ਭਗਤੀ ਲਾਇ ॥",
          "roman": "kar kirpā apnī bhagatī lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕਿਰਪਾ ਕਰ ਕੇ ਪਰਮਾਤਮਾ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਆਪਣੀ ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По Своей милости Бог соединяет человека со Своим поклонением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31461,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਪ੍ਰਭੁ ਸਦਾ ਧਿਆਇ ॥੪॥੨॥",
          "roman": "jan nānak prabh sadā dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਉਹ ਉਸ ਨੂੰ ਸਦਾ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! Такой человек всегда помнит Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2809,
      "rahao_verse_id": 31467,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31462,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31463,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਸੋਹਾਗਨਿ ਜੋ ਪ੍ਰਭੂ ਪਛਾਨੈ ॥",
          "roman": "dhan sohāgan jo prabhū pachhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! ਉਹ ਜੀਵ-ਇਸਤ੍ਰੀ ਸਲਾਹੁਣ-ਜੋਗ ਹੈ, ਸੁਹਾਗ-ਭਾਗ ਵਾਲੀ ਹੈ, ਜੇਹੜੀ ਪ੍ਰਭੂ-ਪਤੀ ਨਾਲ ਸਾਂਝ ਬਣਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Та душа-жена достойна восхваления, наделена супружеским счастьем, которая соединяется с Господом-супругом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31464,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੈ ਹੁਕਮੁ ਤਜੈ ਅਭਿਮਾਨੈ ॥",
          "roman": "mānē hukam tajē abhimānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਅਹੰਕਾਰ ਛੱਡ ਕੇ ਪ੍ਰਭੂ-ਪਤੀ ਦਾ ਹੁਕਮ ਮੰਨਦੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "которая, оставив гордыню, принимает волю Господа-супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31465,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਿਅ ਸਿਉ ਰਾਤੀ ਰਲੀਆ ਮਾਨੈ ॥੧॥",
          "roman": "priā siu rātī raliā mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੀਵ-ਇਸਤ੍ਰੀ ਪਭੂ-ਪਤੀ (ਦੇ ਪਿਆਰ-ਰੰਗ) ਵਿਚ ਰੰਗੀ ਹੋਈ ਉਸ ਦੇ ਮਿਲਾਪ ਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੀ ਰਹਿੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Та душа-жена, окрашенная в любовь Господа-супруга, наслаждается духовной радостью его единения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31466,
          "is_rahao": true,
          "gurmukhi": "ਸੁਨਿ ਸਖੀਏ ਪ੍ਰਭ ਮਿਲਣ ਨੀਸਾਨੀ ॥",
          "roman": "sun sakhīe prabh milan nīsānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! ਪਰਮਾਤਮਾ ਨੂੰ ਮਿਲਣ ਦੀ ਨਿਸ਼ਾਨੀ (ਮੈਥੋਂ) ਸੁਣ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Послушай признак встречи с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31467,
          "is_rahao": true,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਅਰਪਿ ਤਜਿ ਲਾਜ ਲੋਕਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man tan arap taj lāj lokānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਨਿਸ਼ਾਨੀ ਉਹ ਤਰੀਕਾ ਇਹ ਹੈ ਕਿ) ਲੋਕ-ਲਾਜ ਦੀ ਖ਼ਾਤਰ ਕੰਮ ਕਰਨੇ ਛੱਡ ਕੇ ਆਪਣਾ ਮਨ ਆਪਣਾ ਸਰੀਰ ਪਰਮਾਤਮਾ ਦੇ ਹਵਾਲੇ ਕਰ ਦੇਹ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот признак таков: отбросив мирскую стыдливость, предай свой ум и тело Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31468,
          "is_rahao": false,
          "gurmukhi": "ਸਖੀ ਸਹੇਲੀ ਕਉ ਸਮਝਾਵੈ ॥",
          "roman": "sakhī sahelī kau samjhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਕ ਸਤਸੰਗੀ) ਸਹੇਲੀ (ਦੂਜੇ ਸਤਸੰਗੀ) ਸਹੇਲੀ ਨੂੰ (ਪ੍ਰਭੂ-ਪਤੀ ਦੇ ਮਿਲਾਪ ਦੇ ਤਰੀਕੇ ਬਾਰੇ) ਸਮਝਾਂਦੀ ਹੈ (ਤੇ ਆਖਦੀ ਹੈ ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "Одна подруга объясняет другой подруге путь встречи с Господом-супругом и говорит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31469,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਕਮਾਵੈ ਜੋ ਪ੍ਰਭ ਭਾਵੈ ॥",
          "roman": "soī kamāvē jo prabh bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਵ-ਇਸਤ੍ਰੀ ਉਹੀ ਕੁਝ ਕਰਦੀ ਹੈ ਜੋ ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਪਸੰਦ ਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "что та душа-жена делает лишь то, что угодно Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31470,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਸੋਹਾਗਣਿ ਅੰਕਿ ਸਮਾਵੈ ॥੨॥",
          "roman": "sā sohāgan ank samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੁਹਾਗ-ਭਾਗ ਵਾਲੀ ਜੀਵ-ਇਸਤ੍ਰੀ ਉਸ ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਰਹਿੰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и такая счастливая душа-жена пребывает в объятиях Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31471,
          "is_rahao": false,
          "gurmukhi": "ਗਰਬਿ ਗਹੇਲੀ ਮਹਲੁ ਨ ਪਾਵੈ ॥",
          "roman": "garab gahēlī mahal na pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜੇਹੜੀ ਜੀਵ-ਇਸਤ੍ਰੀ ਅਹੰਕਾਰ ਵਿਚ ਫਸੀ ਰਹਿੰਦੀ ਹੈ, ਉਹ ਪ੍ਰਭੂ-ਪਤੀ ਦੇ ਚਰਨਾਂ ਵਿਚ ਥਾਂ ਪ੍ਰਾਪਤ ਨਹੀਂ ਕਰ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Но та душа-жена, погружённая в гордыню, не может обрести место у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31472,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਪਛੁਤਾਵੈ ਜਬ ਰੈਣਿ ਬਿਹਾਵੈ ॥",
          "roman": "phir pachhutāvē jab rēn bihāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਜ਼ਿੰਦਗੀ ਦੀ) ਰਾਤ ਬੀਤ ਜਾਂਦੀ ਹੈ, ਤਦੋਂ ਉਹ ਪਛੁਤਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда ночь жизни проходит, она раскаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31473,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮਹੀਣਿ ਮਨਮੁਖਿ ਦੁਖੁ ਪਾਵੈ ॥੩॥",
          "roman": "karmahīṇ manmukh dukh pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਹੀ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੀ ਉਹ ਮੰਦ-ਭਾਗਣ ਜੀਵ-ਇਸਤ੍ਰੀ ਸਦਾ ਦੁੱਖ ਪਾਂਦੀ ਰਹਿੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Следующая за своим умом несчастная душа-жена всегда испытывает страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31474,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਉ ਕਰੀ ਜੇ ਜਾਣਾ ਦੂਰਿ ॥",
          "roman": "binau karī je jāṇā dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਲੋਕ-ਲਾਜ ਦੀ ਖ਼ਾਤਰ ਮੈਂ ਤਾਂ ਹੀ ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ) ਅਰਦਾਸ ਕਰਾਂ, ਜੇ ਮੈਂ ਉਸ ਨੂੰ ਕਿਤੇ ਦੂਰ ਵੱਸਦਾ ਸਮਝਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я бы молился Господу только если бы считал его далёким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31475,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਬਿਨਾਸੀ ਰਹਿਆ ਭਰਪੂਰਿ ॥",
          "roman": "prabh abināsī rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਨਾਸ-ਰਹਿਤ ਪਰਮਾਤਮਾ ਤਾਂ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но нетленный Господь присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31476,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਨਾਨਕੁ ਗਾਵੈ ਦੇਖਿ ਹਦੂਰਿ ॥੪॥੩॥",
          "roman": "jan nānak gāvē dekh hadūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ (ਤਾਂ ਉਸ ਨੂੰ ਆਪਣੇ) ਅੰਗ-ਸੰਗ (ਵੱਸਦਾ) ਵੇਖ ਕੇ ਉਸ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак, видя его рядом с собой, воспевает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2810,
      "rahao_verse_id": 31483,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31477,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31478,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹੁ ਵਸਿ ਗੁਰਿ ਕੀਨਾ ਹਉ ਘਰ ਕੀ ਨਾਰਿ ॥",
          "roman": "grih vas gur kīnā hau ghar kī nār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ!) ਉਸ ਖਸਮ-ਪ੍ਰਭੂ ਨੇ ਗੁਰੂ ਦੀ ਰਾਹੀਂ (ਮੇਰਾ) ਸਰੀਰ-ਘਰ (ਮੇਰੇ) ਵੱਸ ਵਿਚ ਕਰ ਦਿੱਤਾ ਹੈ (ਹੁਣ) ਮੈਂ (ਉਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਇਸ) ਘਰ ਦੀ ਮਾਲਕਾ ਬਣ ਗਈ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Господь через Гуру подчинил мне дом-тело, и теперь я стала хозяйкой этого дома."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31479,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਦਾਸੀ ਕਰਿ ਦੀਨੀ ਭਤਾਰਿ ॥",
          "roman": "das dāsī kar dīnī bhatār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਖਸਮ ਨੇ ਦਸਾਂ ਹੀ ਇੰਦ੍ਰਿਆਂ ਨੂੰ ਮੇਰੀਆਂ ਦਾਸੀਆਂ ਬਣਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь сделал десять чувств моими служанками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31480,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਮੈ ਘਰ ਕੀ ਜੋੜੀ ॥",
          "roman": "sagal samagrī mē ghar kī jorī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉੱਚੇ ਆਤਮਕ ਗੁਣਾਂ ਦਾ) ਮੈਂ ਆਪਣੇ ਸਰੀਰ-ਘਰ ਦਾ ਸਾਰਾ ਸਾਮਾਨ ਜੋੜ ਕੇ (ਸਜਾ ਕੇ) ਰੱਖ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я собрала и устроила всё духовное богатство в доме своего тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31481,
          "is_rahao": false,
          "gurmukhi": "ਆਸ ਪਿਆਸੀ ਪਿਰ ਕਉ ਲੋੜੀ ॥੧॥",
          "roman": "ās piyāsī pir kau lorī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਪ੍ਰਭੂ-ਪਤੀ ਦੇ ਦਰਸਨ ਦੀ ਆਸ ਤੇ ਤਾਂਘ ਵਿਚ ਉਸ ਦੀ ਉਡੀਕ ਕਰ ਰਹੀ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь я с надеждой и жаждой жду Господа-супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31482,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨ ਕਹਾ ਗੁਨ ਕੰਤ ਪਿਆਰੇ ॥",
          "roman": "kavan kahā gun kant piyāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ!) ਪਿਆਰੇ ਕੰਤ ਪ੍ਰਭੂ ਦੇ ਮੈਂ ਕੇਹੜੇ ਕੇਹੜੇ ਗੁਣ ਦੱਸਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Какие качества возлюбленного Господа мне перечислить?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31483,
          "is_rahao": true,
          "gurmukhi": "ਸੁਘੜ ਸਰੂਪ ਦਇਆਲ ਮੁਰਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sughar sarūp dayāl murāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਚੱਜੇ, ਦਇਆਵਾਨ, ਪ੍ਰਭੂ ਦੇ- ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Прекрасный, милостивый Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31484,
          "is_rahao": false,
          "gurmukhi": "ਸਤੁ ਸੀਗਾਰੁ ਭਉ ਅੰਜਨੁ ਪਾਇਆ ॥",
          "roman": "sat sīgār bhau anjan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਖਸਮ-ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ) ਸੁੱਚੇ ਆਚਰਨ ਨੂੰ ਮੈਂ (ਆਪਣੇ ਜੀਵਨ ਦਾ) ਸਿੰਗਾਰ ਬਣਾ ਲਿਆ ਹੈ, ਉਸ ਦੇ ਡਰ-ਅਦਬ (ਦਾ) ਮੈਂ (ਅੱਖਾਂ ਵਿਚ) ਸੁਰਮਾ ਪਾ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я сделала чистое поведение своим украшением, а страх-почтение — сурьмой для глаз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31485,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਤੰਬੋਲੁ ਮੁਖਿ ਖਾਇਆ ॥",
          "roman": "amrit nām tambol mukh khāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਮੇਹਰ ਨਾਲ ਹੀ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਪਾਨ ਮੈਂ ਮੂੰਹ ਨਾਲ ਖਾਧਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я вкусила нектар Имени, дарующего духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31486,
          "is_rahao": false,
          "gurmukhi": "ਕੰਗਨ ਬਸਤ੍ਰ ਗਹਨੇ ਬਨੇ ਸੁਹਾਵੇ ॥",
          "roman": "kangan bastr gahnē bane suhāve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਉਸ ਦੇ ਕੰਗਣ, ਕੱਪੜੇ, ਗਹਿਣੇ ਸੋਹਣੇ ਲੱਗਣ ਲੱਗ ਪੈਂਦੇ ਹਨ (ਸਾਰੇ ਧਾਰਮਿਕ ਉੱਦਮ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "Тогда браслеты, одежды и украшения становятся прекрасными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31487,
          "is_rahao": false,
          "gurmukhi": "ਧਨ ਸਭ ਸੁਖ ਪਾਵੈ ਜਾਂ ਪਿਰੁ ਘਰਿ ਆਵੈ ॥੨॥",
          "roman": "dhan sabh sukh pāvē jāṅ pir ghar āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ-ਪਤੀ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ, ਤਦੋਂ ਜੀਵ-ਇਸਤ੍ਰੀ ਸਾਰੇ ਸੁਖ ਹਾਸਲ ਕਰ ਲੈਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь входит в сердце, душа обретает все радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31488,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਕਾਮਣ ਕਰਿ ਕੰਤੁ ਰੀਝਾਇਆ ॥",
          "roman": "gun kāman kar kant rījhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਗੁਣਾਂ ਦੇ ਟੂਣੇ ਬਣਾ ਕੇ ਉਸ ਜੀਵ-ਇਸਤ੍ਰੀ ਨੇ ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਖ਼ੁਸ਼ ਕਰ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! С помощью добродетелей душа-жена угодила Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31489,
          "is_rahao": false,
          "gurmukhi": "ਵਸਿ ਕਰਿ ਲੀਨਾ ਗੁਰਿ ਭਰਮੁ ਚੁਕਾਇਆ ॥",
          "roman": "vas kar līnā gur bharam chukāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਜਿਸ ਦੀ) ਭਟਕਣਾ ਦੂਰ ਕਰ ਦਿੱਤੀ। ਉਸ ਨੇ ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਆਪਣੇ ਵੱਸ ਵਿਚ ਕਰ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру устранил заблуждение, и она обрела Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31490,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚਾ ਮੰਦਰੁ ਮੇਰਾ ॥",
          "roman": "sabh te ūchā mandar merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਉਸ ਖਸਮ-ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ) ਮੇਰਾ ਹਿਰਦਾ-ਘਰ ਸਭ (ਵਾਸਨਾਵਾਂ) ਤੋਂ ਉੱਚਾ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Моё сердце стало выше всех желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31491,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਾਮਣਿ ਤਿਆਗੀ ਪ੍ਰਿਉ ਪ੍ਰੀਤਮੁ ਮੇਰਾ ॥੩॥",
          "roman": "sabh kāman tyāgī priu prītam merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੀਆਂ ਇਸਤ੍ਰੀਆਂ ਨੂੰ ਛੱਡ ਕੇ ਉਹ ਪ੍ਰੀਤਮ ਮੇਰਾ ਪਿਆਰਾ ਬਣ ਗਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Оставив всех других, возлюбленный стал только моим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31492,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟਿਆ ਸੂਰੁ ਜੋਤਿ ਉਜੀਆਰਾ ॥",
          "roman": "pragaṭiā sūr jot ujīārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! (ਉਸ ਕੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੇਰੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਦਾ) ਸੂਰਜ ਚੜ੍ਹ ਪਿਆ ਹੈ, (ਆਤਮਕ ਜੀਵਨ ਦੀ) ਜੋਤਿ ਜਗ ਪਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Во мне взошло солнце духовной жизни, зажглась светлая энергия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31493,
          "is_rahao": false,
          "gurmukhi": "ਸੇਜ ਵਿਛਾਈ ਸਰਧ ਅਪਾਰਾ ॥",
          "roman": "sej vichhāī sradha apārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇਅੰਤ ਪ੍ਰਭੂ ਦੀ ਸਰਧਾ ਦੀ ਸੇਜ ਮੈਂ ਵਿਛਾ ਦਿੱਤੀ ਹੈ (ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਵਾਸਤੇ ਪੂਰੀ ਸਰਧਾ ਬਣ ਗਈ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Я постелила ложе безграничной преданности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31494,
          "is_rahao": false,
          "gurmukhi": "ਨਵ ਰੰਗ ਲਾਲੁ ਸੇਜ ਰਾਵਣ ਆਇਆ ॥",
          "roman": "nav rang lāl sej rāvan āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਆਪਣੀ ਮੇਹਰ ਨਾਲ ਹੀ) ਉਹ ਨਿੱਤ ਨਵੇਂ ਪਿਆਰ ਵਾਲਾ ਪ੍ਰੀਤਮ ਮੇਰੇ ਹਿਰਦੇ ਦੀ ਸੇਜ ਉਤੇ ਆ ਬੈਠਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный, полный новой любви, пришёл на ложе моего сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31495,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਪਿਰ ਧਨ ਮਿਲਿ ਸੁਖੁ ਪਾਇਆ ॥੪॥੪॥",
          "roman": "jan nānak pir dhan mil sukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਪ੍ਰਭੂ-ਪਤੀ ਨੂੰ ਮਿਲ ਕੇ ਜੀਵ-ਇਸਤ੍ਰੀ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੀ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Встретив Господа, душа-жена обрела духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2811,
      "rahao_verse_id": 31502,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31496,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31497,
          "is_rahao": false,
          "gurmukhi": "ਉਮਕਿਓ ਹੀਉ ਮਿਲਨ ਪ੍ਰਭ ਤਾਈ ॥",
          "roman": "umakio hīo milan prabh tāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਹਿਰਦਾ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲਣ ਵਾਸਤੇ ਖ਼ੁਸ਼ੀ ਨਾਲ ਨੱਚ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Моё сердце радостно устремилось к встрече с Господом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31498,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਚਰਿਓ ਦੇਖਉ ਪ੍ਰਿਅ ਜਾਈ ॥",
          "roman": "khojat chariō dekhau priā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨੂੰ) ਲੱਭਣ ਚੜ੍ਹ ਪਿਆ (ਕਿ) ਮੈਂ ਪਿਆਰੇ ਦੇ ਰਹਿਣ ਦੀ ਥਾਂ (ਕਿਤੇ) ਵੇਖਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "я отправилась искать место пребывания возлюбленного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31499,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਤ ਸਦੇਸਰੋ ਪ੍ਰਿਅ ਗ੍ਰਿਹਿ ਸੇਜ ਵਿਛਾਈ ॥",
          "roman": "sunat sadesaro priā grih sej vichhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਪਿਆਰੇ ਦਾ ਸਨੇਹਾ ਸੁਣਦਿਆਂ ਮੈਂ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਸੇਜ ਵਿਛਾ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "Услышав весть о возлюбленном, я постелила ложе в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31500,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਆਇਓ ਤਉ ਨਦਰਿ ਨ ਪਾਈ ॥੧॥",
          "roman": "bhram bhram āio tau nadar na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਭਟਕ ਭਟਕ ਕੇ ਮੁੜ ਆਇਆ, ਤਦੋਂ (ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਦੀ) ਨਿਗਾਹ ਹਾਸਲ ਨਾਹ ਹੋਈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но, блуждая, я не получила его милостивого взгляда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31501,
          "is_rahao": true,
          "gurmukhi": "ਕਿਨ ਬਿਧਿ ਹੀਅਰੋ ਧੀਰੈ ਨਿਮਾਨੋ ॥",
          "roman": "kin bidh hīaro dhīrē nimāno",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰੇ ਦਰਸਨ ਤੋਂ ਬਿਨਾ) ਮੇਰਾ ਇਹ ਨਿਮਾਣਾ ਦਿਲ ਕਿਵੇਂ ਧੀਰਜ ਫੜੇ?"
            },
            "sahib_singh_ru": {
              "main": "Как моё смиренное сердце найдёт покой без тебя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31502,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲੁ ਸਾਜਨ ਹਉ ਤੁਝੁ ਕੁਰਬਾਨੋ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mil sājan hau tujh kurbāno",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਜਣ ਪ੍ਰਭੂ! (ਮੈਨੂੰ) ਮਿਲ, ਮੈਂ ਤੈਥੋਂ ਸਦਕੇ ਜਾਂਦੀ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь-друг! Встреться со мной, я жертвую собой ради тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31503,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਸੇਜ ਵਿਛੀ ਧਨ ਕੰਤਾ ॥",
          "roman": "ekā sej vichhī dhan kantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਜੀਵ-ਇਸਤ੍ਰੀ ਅਤੇ ਪ੍ਰਭੂ-ਪਤੀ ਦੀ ਇਕੋ ਹੀ ਸੇਜ (ਜੀਵ-ਇਸਤ੍ਰੀ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਵਿਛੀ ਹੋਈ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "О подруга! У души-жены и Господа одно ложе в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31504,
          "is_rahao": false,
          "gurmukhi": "ਧਨ ਸੂਤੀ ਪਿਰੁ ਸਦ ਜਾਗੰਤਾ ॥",
          "roman": "dhan sūtī pir sad jāgntā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੀਵ-ਇਸਤ੍ਰੀ (ਸਦਾ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ) ਸੁੱਤੀ ਰਹਿੰਦੀ ਹੈ, ਪ੍ਰਭੂ-ਪਤੀ ਸਦਾ ਜਾਗਦਾ ਰਹਿੰਦਾ ਹੈ (ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਉਤਾਂਹ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "но душа спит в иллюзии, а Господь всегда бодрствует."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31505,
          "is_rahao": false,
          "gurmukhi": "ਪੀਓ ਮਦਰੋ ਧਨ ਮਤਵੰਤਾ ॥",
          "roman": "pīo madro dhan matvntā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ-ਇਸਤ੍ਰੀ ਇਉਂ ਮਸਤ ਰਹਿੰਦੀ ਹੈ ਜਿਵੇਂ ਇਸ ਨੇ ਸ਼ਰਾਬ ਪੀਤੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Душа опьянена, словно выпила вино."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31506,
          "is_rahao": false,
          "gurmukhi": "ਧਨ ਜਾਗੈ ਜੇ ਪਿਰੁ ਬੋਲੰਤਾ ॥੨॥",
          "roman": "dhan jāgē je pir bolntā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਾਂ) ਜੀਵ-ਇਸਤ੍ਰੀ ਜਾਗ ਭੀ ਸਕਦੀ ਹੈ, ਜੇ ਪ੍ਰਭੂ-ਪਤੀ (ਆਪ) ਜਗਾਏ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но она может пробудиться, если Господь её разбудит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31507,
          "is_rahao": false,
          "gurmukhi": "ਭਈ ਨਿਰਾਸੀ ਬਹੁਤੁ ਦਿਨ ਲਾਗੇ ॥",
          "roman": "bhaī nirāsī bahut din lāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! (ਉਮਰ ਦੇ) ਬਹੁਤ ਸਾਰੇ ਦਿਨ ਬੀਤ ਗਏ ਹਨ, (ਹੁਣ) ਮੈਂ ਨਿਰਾਸ ਹੋ ਗਈ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Прошло много дней, и я впала в отчаяние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31508,
          "is_rahao": false,
          "gurmukhi": "ਦੇਸ ਦਿਸੰਤਰ ਮੈ ਸਗਲੇ ਝਾਗੇ ॥",
          "roman": "des disntar mē sagle jhāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਬਾਹਰ) ਹੋਰ ਹੋਰ ਸਾਰੇ ਦੇਸ ਭਾਲ ਵੇਖੇ ਹਨ (ਪਰ ਬਾਹਰ ਪ੍ਰਭੂ-ਪਤੀ ਕਿਤੇ ਲੱਭਾ ਨਹੀਂ।)"
            },
            "sahib_singh_ru": {
              "main": "Я искала во всех странах, но не нашла Господа вовне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
