{
  "ang": 740,
  "shabads": [
    {
      "shabad_id": 2820,
      "rahao_verse_id": 31616,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31612,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31613,
          "is_rahao": false,
          "gurmukhi": "ਰਹਣੁ ਨ ਪਾਵਹਿ ਸੁਰਿ ਨਰ ਦੇਵਾ ॥",
          "roman": "rahan na pāveh sur nar devā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਅਨੇਕਾਂ ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ) ਦੈਵੀ ਮਨੁੱਖ, ਦੇਵਤੇ (ਅਖਵਾਉਣ ਵਾਲੇ ਕੋਈ ਭੀ ਇਥੇ) ਸਦਾ ਲਈ ਟਿਕੇ ਨਹੀਂ ਰਹਿ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! многие люди, называющие себя божественными людьми, богами, не могут оставаться здесь навсегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31614,
          "is_rahao": false,
          "gurmukhi": "ਊਠਿ ਸਿਧਾਰੇ ਕਰਿ ਮੁਨਿ ਜਨ ਸੇਵਾ ॥੧॥",
          "roman": "ūṭh sidhāre kar mun jan sevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਨੇਕਾਂ ਆਪਣੇ ਆਪ ਨੂੰ) ਰਿਸ਼ੀ ਮੁਨੀ (ਅਖਵਾ ਗਏ, ਅਨੇਕਾਂ ਹੀ ਉਹਨਾਂ ਦੀ) ਸੇਵਾ ਕਰ ਕੇ (ਜਗਤ ਤੋਂ ਆਖ਼ਰ ਆਪੋ ਆਪਣੀ ਵਾਰੀ) ਚਲੇ ਜਾਂਦੇ ਰਹੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Многие, называвшие себя риши и муни, и многие служившие им — в конце концов уходили из мира в своё время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31615,
          "is_rahao": true,
          "gurmukhi": "ਜੀਵਤ ਪੇਖੇ ਜਿਨੑੀ ਹਰਿ ਹਰਿ ਧਿਆਇਆ ॥",
          "roman": "jīvat pekhe jinhī har har dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ (ਸਫਲ ਜੀਵਨ ਵਾਲੇ ਸਿਰਫ਼ ਉਹੀ) ਵੇਖੇ ਜਾਂਦੇ ਹਨ ਜਿਨ੍ਹਾਂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! живыми (по-настоящему) считаются только те, кто помнил Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31616,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਤਿਨੑੀ ਦਰਸਨੁ ਪਾਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādh saṅg tinhī darsan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੇ ਹੀ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਟਿਕ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਦਰਸਨ ਕੀਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только они, пребывая в обществе святых, обрели видение Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31617,
          "is_rahao": false,
          "gurmukhi": "ਬਾਦਿਸਾਹ ਸਾਹ ਵਾਪਾਰੀ ਮਰਨਾ ॥",
          "roman": "bādshāh sāh vāparī marnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸ਼ਾਹ, ਵਾਪਾਰੀ, ਬਾਦਸ਼ਾਹ (ਸਭਨਾਂ ਨੇ ਆਖ਼ਰ) ਮਰਨਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! шахи, торговцы, цари — все должны умереть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31618,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੀਸੈ ਸੋ ਕਾਲਹਿ ਖਰਨਾ ॥੨॥",
          "roman": "jo dīsē so kāleh kharnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਭੀ ਕੋਈ (ਇਥੇ) ਦਿੱਸਦਾ ਹੈ, ਹਰੇਕ ਨੂੰ ਮੌਤ ਨੇ ਲੈ ਜਾਣਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Кто бы ни был виден здесь — каждого унесёт смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31619,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜੈ ਮੋਹਿ ਲਪਟਿ ਲਪਟਾਨਾ ॥",
          "roman": "kūṛē moh lapaṭ lapaṭānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਨੁੱਖ ਝੂਠੇ ਮੋਹ ਵਿਚ ਸਦਾ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ (ਤੇ, ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾਈ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! человек постоянно запутан в ложной привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31620,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਚਲਿਆ ਤਾ ਫਿਰਿ ਪਛੁਤਾਨਾ ॥੩॥",
          "roman": "chhoḍ chaliā tā fir pachhutānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਦੁਨੀਆ ਦੇ ਪਦਾਰਥ) ਛੱਡ ਕੇ ਤੁਰਦਾ ਹੈ, ਤਾਂ ਤਦੋਂ ਪਛੁਤਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но когда он покидает мирские вещи, тогда раскаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31621,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਨਾਨਕ ਕਉ ਕਰਹੁ ਦਾਤਿ ॥",
          "roman": "kripā nidhān nānak kau karah dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਿਰਪਾ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! (ਮੈਨੂੰ) ਨਾਨਕ ਨੂੰ (ਇਹ) ਦਾਤ ਦੇਹ (ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "О сокровищница милости, Господь! даруй Нанаку этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31622,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਤੇਰਾ ਜਪੀ ਦਿਨੁ ਰਾਤਿ ॥੪॥੮॥੧੪॥",
          "roman": "nām terā japī din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਨਾਨਕ) ਦਿਨ ਰਾਤ ਤੇਰਾ ਨਾਮ ਜਪਦਾ ਰਹਾਂ ॥੪॥੮॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы я день и ночь повторял Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2821,
      "rahao_verse_id": 31627,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31623,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31624,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਤੁਮਹਿ ਬਸਾਰੇ ॥",
          "roman": "ghaṭ ghaṭ antar tumah basāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਤੂੰ ਹੀ ਵੱਸਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты пребываешь в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31625,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਸੂਤਿ ਤੁਮਾਰੇ ॥੧॥",
          "roman": "sagal samagrī sūt tumāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੀਆਂ) ਸਾਰੀਆਂ ਚੀਜ਼ਾਂ ਤੇਰੀ ਹੀ ਮਰਯਾਦਾ ਦੇ ਧਾਗੇ ਵਿਚ (ਪ੍ਰੋਤੀਆਂ ਹੋਈਆਂ) ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Все вещи мира вплетены в нить Твоего закона."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31626,
          "is_rahao": true,
          "gurmukhi": "ਤੂੰ ਪ੍ਰੀਤਮ ਤੂੰ ਪ੍ਰਾਨ ਅਧਾਰੇ ॥",
          "roman": "tū prītam tū prān adhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਾਡਾ ਪ੍ਰੀਤਮ ਹੈਂ, ਤੂੰ ਸਾਡੀ ਜਿੰਦ ਦਾ ਆਸਰਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты наш возлюбленный, Ты опора нашей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31627,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮ ਹੀ ਪੇਖਿ ਪੇਖਿ ਮਨੁ ਬਿਗਸਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tum hī pekh pekh man bigsāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਹੀ ਵੇਖ ਵੇਖ ਕੇ (ਸਾਡਾ) ਮਨ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Видя Тебя снова и снова, наш ум радуется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31628,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੋਨਿ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਹਾਰੇ ॥",
          "roman": "anik jon bhram bhram bhram hāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਤੈਥੋਂ ਵਿਛੁੜ ਕੇ ਜੀਵ) ਅਨੇਕਾਂ ਜੂਨਾਂ ਵਿਚ ਭਟਕ ਭਟਕ ਕੇ ਥੱਕ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! отделившись от Тебя, души, блуждая в многочисленных рождениях, устают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31629,
          "is_rahao": false,
          "gurmukhi": "ਓਟ ਗਹੀ ਅਬ ਸਾਧ ਸੰਗਾਰੇ ॥੨॥",
          "roman": "oṭ gahī ab sādh saṅgāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖਾ ਜਨਮ ਵਿਚ ਆ ਕੇ (ਤੇਰੀ ਮੇਹਰ ਨਾਲ) ਸਾਧ ਸੰਗਤਿ ਦਾ ਆਸਰਾ ਲੈਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Получив человеческое рождение, по Твоей милости, они принимают прибежище в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31630,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰੁ ਅਲਖ ਅਪਾਰੇ ॥",
          "roman": "agam agochar alakh apāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ) ਜੋ ਅਪਹੁੰਚ ਹੈ, ਜਿਸ ਤਕ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, ਜੋ ਮਨੁੱਖ ਦੀ ਸਮਝ ਤੋਂ ਪਰੇ ਹੈ, ਅਤੇ ਜੋ ਬੇਅੰਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог — недостижимый, недоступный чувствам, непостижимый и бесконечный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31631,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਸਿਮਰੈ ਦਿਨੁ ਰੈਨਾਰੇ ॥੩॥੯॥੧੫॥",
          "roman": "nānak simrē din rēnāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਨਾਨਕ ਦਿਨ ਰਾਤ ਉਸ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ ॥੩॥੯॥੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря обществу святых Нанак день и ночь помнит Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2822,
      "rahao_verse_id": 31636,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31632,
