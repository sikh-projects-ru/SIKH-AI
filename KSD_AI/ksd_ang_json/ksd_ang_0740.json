            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31633,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਕਾਜ ਮਾਇਆ ਵਡਿਆਈ ॥",
          "roman": "kavan kāj māiā vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਾਇਆ ਦੇ ਕਾਰਨ ਮਿਲੀ ਵਡਿਆਈ ਭੀ ਕਿਸੇ ਕੰਮ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! величие, полученное через майю, ни к чему не пригодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31634,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਬਿਨਸਤ ਬਾਰ ਨ ਕਾਈ ॥੧॥",
          "roman": "jā kau binsat bār na kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਾਇਆ ਦੇ ਨਾਸ ਹੁੰਦਿਆਂ ਰਤਾ ਚਿਰ ਨਹੀਂ ਲੱਗਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Та майя исчезает мгновенно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31635,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਸੁਪਨਾ ਸੋਵਤ ਨਹੀ ਜਾਨੈ ॥",
          "roman": "ihu supnā sovat nahī jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਹ (ਜਗਤ ਇਉਂ ਹੈ, ਜਿਵੇਂ) ਸੁਪਨਾ (ਹੁੰਦਾ) ਹੈ, (ਸੁਪਨੇ ਵਿਚ) ਸੁੱਤਾ ਹੋਇਆ ਮਨੁੱਖ (ਇਹ) ਨਹੀਂ ਜਾਣਦਾ (ਕਿ ਮੈਂ ਸੁੱਤਾ ਪਿਆ ਹਾਂ, ਤੇ ਸੁਪਨਾ ਵੇਖ ਰਿਹਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! этот мир подобен сну, и спящий не осознаёт, что он спит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31636,
          "is_rahao": true,
          "gurmukhi": "ਅਚੇਤ ਬਿਵਸਥਾ ਮਹਿ ਲਪਟਾਨੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "achet bivasthā meh lapaṭānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸੇ ਤਰ੍ਹਾਂ ਮਨੁੱਖ ਜਗਤ ਦੇ ਮੋਹ ਵਾਲੀ) ਗ਼ਾਫ਼ਲ ਹਾਲਤ ਵਿਚ (ਜਗਤ ਦੇ ਮੋਹ ਨਾਲ) ਚੰਬੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Так же человек остаётся привязанным в состоянии неведения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31637,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਮੋਹਿ ਮੋਹਿਓ ਗਾਵਾਰਾ ॥",
          "roman": "mahā moh mohiō gāvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੂਰਖ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਵੱਡੇ ਮੋਹ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! глупый человек погружён в сильную привязанность майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31638,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਤ ਪੇਖਤ ਊਠਿ ਸਿਧਾਰਾ ॥੨॥",
          "roman": "pekhat pekhat ūṭh sidhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਵੇਂਹਦਿਆਂ ਵੇਂਹਦਿਆਂ ਹੀ (ਇਥੋਂ) ਉਠ ਕੇ ਤੁਰ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но, глядя-гладя, внезапно встаёт и уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31639,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਤੇ ਊਚ ਤਾ ਕਾ ਦਰਬਾਰਾ ॥",
          "roman": "ūch te ūch tā kā darbārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਜਪ) ਉਸ ਦਾ ਦਰਬਾਰ ਉੱਚੇ ਤੋਂ ਉੱਚਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! двор Бога — самый высокий из всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31640,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜੰਤ ਬਿਨਾਹਿ ਉਪਾਰਾ ॥੩॥",
          "roman": "kaī jant bināhi upārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਨੇਕਾਂ ਜੀਵਾਂ ਨੂੰ ਨਾਸ ਭੀ ਕਰਦਾ ਹੈ, ਤੇ, ਪੈਦਾ ਭੀ ਕਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он уничтожает многих существ и также создаёт их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31641,
          "is_rahao": false,
          "gurmukhi": "ਦੂਸਰ ਹੋਆ ਨਾ ਕੋ ਹੋਈ ॥",
          "roman": "dūsar hoā nā ko hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਵਰਗਾ ਹੋਰ ਕੋਈ ਦੂਜਾ ਨਾਹ ਅਜੇ ਤਕ ਕੋਈ ਹੋਇਆ ਹੈ, ਨਾਹ ਹੀ (ਅਗਾਂਹ ਨੂੰ) ਹੋਵੇਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Никто подобный Богу никогда не был и не будет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31642,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਨਾਨਕ ਪ੍ਰਭ ਏਕੋ ਸੋਈ ॥੪॥੧੦॥੧੬॥",
          "roman": "jap nānak prabh eko soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਜਪਿਆ ਕਰ ॥੪॥੧੦॥੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! повторяй Имя только этого Единого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2823,
      "rahao_verse_id": 31647,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31643,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31644,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਤਾ ਕਉ ਹਉ ਜੀਵਾ ॥",
          "roman": "simar simar tā kau hau jīvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਭਗਤ ਜਨਾਂ ਦੇ ਅੰਗ-ਸੰਗ ਰਹਿਣ ਵਾਲੇ) ਉਸ (ਪ੍ਰਭੂ ਦੇ ਨਾਮ) ਨੂੰ ਮੈਂ ਸਦਾ ਸਿਮਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰ ਰਿਹਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! помня Его Имя, я обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31645,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਤੇਰੇ ਧੋਇ ਧੋਇ ਪੀਵਾ ॥੧॥",
          "roman": "charan kamal tere dhoi dhoi pīvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਸੋਹਣੇ ਚਰਨ ਧੋ ਧੋ ਕੇ (ਨਿੱਤ) ਪੀਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! я снова и снова омываю Твои прекрасные стопы и пью их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31646,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਹਰਿ ਮੇਰਾ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "so har merā antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਲਕ-ਪ੍ਰਭੂ ਆਪਣੇ ਭਗਤ ਜਨਾਂ ਦੇ ਨਾਲ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь пребывает с Своими преданными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31647,
          "is_rahao": true,
          "gurmukhi": "ਭਗਤ ਜਨਾ ਕੈ ਸੰਗਿ ਸੁਆਮੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bhagat janā kē saṅg suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਉਹ ਹਰੀ-ਪ੍ਰਭੂ ਹਰੇਕ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот мой Господь знает сердца всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31648,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਣਿ ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਧਿਆਵਾ ॥",
          "roman": "suṇ suṇ amrit nām dhiāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੁੜ ਮੁੜ (ਇਹ) ਸੁਣ ਕੇ (ਕਿ ਤੇਰਾ) ਨਾਮ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ (ਹੈ,) ਮੈਂ (ਤੇਰਾ ਨਾਮ) ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! снова и снова слыша, что Твоё Имя дарует жизнь, я размышляю о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31649,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਤੇਰੇ ਗੁਣ ਗਾਵਾ ॥੨॥",
          "roman": "āṭh pahar tere guṇ gāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਠੇ ਪਹਰ ਮੈਂ ਤੇਰੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹਾਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Все восемь страж дня я пою Твои славословия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31650,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਿ ਪੇਖਿ ਲੀਲਾ ਮਨਿ ਆਨੰਦਾ ॥",
          "roman": "pekh pekh līlā man ānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਕੌਤਕ ਵੇਖ ਵੇਖ ਕੇ ਮੇਰੇ ਮਨ ਵਿਚ ਆਨੰਦ ਪੈਦਾ ਹੁੰਦਾ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "О Господь! видя Твои игры, мой ум наполняется радостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31651,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਅਪਾਰ ਪ੍ਰਭ ਪਰਮਾਨੰਦਾ ॥੩॥",
          "roman": "guṇ apār prabh parmānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤੋਂ ਉੱਚੇ ਆਨੰਦ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ! ਤੇਰੇ ਗੁਣ ਬੇਅੰਤ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, источник высшего блаженства! Твои качества безграничны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31652,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਕਛੁ ਭਉ ਨ ਬਿਆਪੈ ॥",
          "roman": "jā kē simran kachh bhau na biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря памяти о Нём никакой страх не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31653,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਨਾਨਕ ਹਰਿ ਜਾਪੈ ॥੪॥੧੧॥੧੭॥",
          "roman": "sadā sadā nānak har jāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਤੂੰ ਭੀ ਸਦਾ ਹੀ ਉਸ ਹਰੀ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ ॥੪॥੧੧॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! всегда повторяй Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2824,
      "rahao_verse_id": 31658,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31654,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31655,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਬਚਨਿ ਰਿਦੈ ਧਿਆਨੁ ਧਾਰੀ ॥",
          "roman": "gur kē bachan ridē dhiān dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਮੈਂ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! через Слово Гуру я удерживаю Бога в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31656,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਜਾਪੁ ਜਪਉ ਬਨਵਾਰੀ ॥੧॥",
          "roman": "rasnā jāp japau banvārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਆਪਣੀ ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦਾ ਜਾਪ ਜਪਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "И языком повторяю Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31657,
          "is_rahao": true,
          "gurmukhi": "ਸਫਲ ਮੂਰਤਿ ਦਰਸਨ ਬਲਿਹਾਰੀ ॥",
          "roman": "saphal mūrat darsan balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਹਸਤੀ ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ ਫਲ ਦੇਣ ਵਾਲੀ ਹੈ। ਮੈਂ (ਗੁਰੂ ਦੇ) ਦਰਸਨ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! образ Гуру приносит плод человеческой жизни; я жертвую собой ради его видения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31658,
          "is_rahao": true,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਮਨ ਪ੍ਰਾਣ ਅਧਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "charan kamal man prān adhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਕੋਮਲ ਚਰਨਾਂ ਨੂੰ ਮੈਂ ਆਪਣੇ ਮਨ ਦਾ ਜਿੰਦ ਦਾ ਆਸਰਾ ਬਣਾਂਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Я делаю лотосные стопы Гуру опорой своего ума и жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31659,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਨਮ ਮਰਣ ਨਿਵਾਰੀ ॥",
          "roman": "sādh saṅg janam maran nivārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ) ਮੈਂ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਮੁਕਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! пребывая в обществе Гуру, я избавился от цикла рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31660,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਕਥਾ ਸੁਣਿ ਕਰਨ ਅਧਾਰੀ ॥੨॥",
          "roman": "amrit kathā suṇ karan adhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕੰਨਾਂ ਨਾਲ ਸੁਣ ਕੇ (ਇਸ ਨੂੰ ਮੈਂ ਆਪਣੇ ਜੀਵਨ ਦਾ) ਆਸਰਾ ਬਣਾ ਰਿਹਾ ਹਾਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Слушая амритическую хвалу, я делаю её опорой своей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31661,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ ਮੋਹ ਤਜਾਰੀ ॥",
          "roman": "kām krodh lobh moh tajārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੈਂ ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ ਮੋਹ (ਆਦਿਕ) ਨੂੰ ਤਿਆਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! по милости Гуру я оставил страсть, гнев, жадность и привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31662,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿੜੁ ਨਾਮ ਦਾਨੁ ਇਸਨਾਨੁ ਸੁਚਾਰੀ ॥੩॥",
          "roman": "driṛh nām dān isnān suchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ-ਨਾਮ ਨੂੰ ਪੱਕਾ ਕਰ ਕੇ ਟਿਕਾਣਾ, ਦੂਜਿਆਂ ਦੀ ਸੇਵਾ ਕਰਨੀ, ਆਚਰਨ ਨੂੰ ਪਵਿਤ੍ਰ ਰੱਖਣਾ-ਇਹ ਮੈਂ ਚੰਗੀ ਜੀਵਨ-ਮਰਯਾਦਾ ਬਣਾ ਲਈ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Укрепив Имя в сердце, служение другим и чистое поведение — я сделал это своим образом жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31663,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਇਹੁ ਤਤੁ ਬੀਚਾਰੀ ॥",
          "roman": "kah nānak ihu tat bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਭਾਈ! ਤੂੰ ਭੀ) ਇਹ ਅਸਲੀਅਤ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: утверди эту истину в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31664,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਜਪਿ ਪਾਰਿ ਉਤਾਰੀ ॥੪॥੧੨॥੧੮॥",
          "roman": "rām nām jap pār utārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ (ਆਪਣੇ ਆਪ ਨੂੰ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲੈ ॥੪॥੧੨॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "И повторяя Имя Бога, переправь себя через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
