          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31666,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭਿ ਮੋਹਿ ਮਗਨ ਅਪਰਾਧੀ ॥",
          "roman": "lobh moh magan aparādhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਅਸੀਂ ਭੁੱਲਣਹਾਰ ਜੀਵ ਲੋਭ ਵਿਚ ਮੋਹ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! мы, заблуждающиеся, погружены в жадность и привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
