      "lines": [
        {
          "verse_id": 31711,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31712,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਅਪੁਨੇ ਊਪਰਿ ਬਲਿ ਜਾਈਐ ॥",
          "roman": "gur apune ūpar bal jāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਪਣੇ ਗੁਰੂ ਉੱਤੋਂ (ਸਦਾ) ਕੁਰਬਾਨ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ- ਭਾਵ ਮਿਟਾ ਦੇਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Нужно всегда быть преданным своему Гуру и, прибегнув к его защите, уничтожить своё эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31713,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਹਰਿ ਜਸੁ ਗਾਈਐ ॥੧॥",
          "roman": "āṭh pahar har har jas gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ, ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ) ਅੱਠੇ ਪਹਰ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਇਆ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ведь только по милости Гуру можно непрерывно воспевать славу Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31714,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਉ ਸੋ ਪ੍ਰਭੁ ਅਪਨਾ ਸੁਆਮੀ ॥",
          "roman": "simarau so prabh apnā suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਆਪਣਾ ਉਹ ਮਾਲਕ-ਪ੍ਰਭੂ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру я постоянно помню своего Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31715,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕਾ ਅੰਤਰਜਾਮੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sagal ghaṭā kā antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਸਭ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "который знает сердца всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31716,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "charaṇ kamal siu lāgī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ) ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ ਪਿਆਰ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру возникает любовь к прекрасным стопам Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31717,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਪੂਰਨ ਨਿਰਮਲ ਰੀਤਿ ॥੨॥",
          "roman": "sāchī pūran nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰ-ਚਰਨਾਂ ਦੀ ਪ੍ਰੀਤ ਹੀ) ਅਟੱਲ ਮੁਕੰਮਲ ਤੇ ਪਵਿਤ੍ਰ ਜੀਵਨ-ਜੁਗਤਿ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Эта любовь — истинный, совершенный и чистый путь жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31718,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਵਸੈ ਮਨ ਮਾਹੀ ॥",
          "roman": "sant prasād vasē man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру Бог поселяется в сердце человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31719,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਵਿਖ ਜਾਹੀ ॥੩॥",
          "roman": "janam janam ke kilvikh jāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਦੇ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и грехи многих жизней исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31720,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "kar kirpā prabh dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਿਮਾਣਿਆਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ! (ਆਪਣੇ ਦਾਸ ਨਾਨਕ ਉਤੇ) ਕਿਰਪਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О сострадательный Господь, милующий смиренных! Даруй милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31721,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮਾਗੈ ਸੰਤ ਰਵਾਲਾ ॥੪॥੧੭॥੨੩॥",
          "roman": "nānak māgē sant ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਦਾਸ) ਨਾਨਕ (ਤੇਰੇ ਦਰ ਤੋਂ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹੈ ॥੪॥੧੭॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак просит пыль стоп Гуру."
            },
            "ipotseluev_ru": {
