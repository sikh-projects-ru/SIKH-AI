{
  "ang": 741,
  "shabads": [
    {
      "shabad_id": 2825,
      "rahao_verse_id": 31669,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31667,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰ ਕੀ ਸੇਵ ਨ ਸਾਧੀ ॥੧॥",
          "roman": "karaṇhār kī sev na sādhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਨੂੰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ ਹੈਂ, ਅਸੀਂ ਤੇਰੀ ਸੇਵਾ-ਭਗਤੀ ਨਹੀਂ ਕਰਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — наш Творец, но мы не служим Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31668,
          "is_rahao": true,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨ ਪ੍ਰਭ ਨਾਮ ਤੁਮਾਰੇ ॥",
          "roman": "patit pāvan prabh nām tumāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਵਿਕਾਰੀਆਂ ਨੂੰ ਪਵਿਤ੍ਰ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твоё Имя очищает грешников."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31669,
          "is_rahao": true,
          "gurmukhi": "ਰਾਖਿ ਲੇਹੁ ਮੋਹਿ ਨਿਰਗੁਨੀਆਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rākh leh moh nirgunīāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਗੁਣ-ਹੀਨ ਨੂੰ (ਆਪਣਾ ਨਾਮ ਦੇ ਕੇ) ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਾਈ ਰੱਖ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Сохрани меня, лишённого достоинств, от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31670,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਦਾਤਾ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "tū dātā prabh antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਾਨੂੰ ਸਭ ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈਂ, ਸਾਡੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты дарующий всё и знающий сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31671,
          "is_rahao": false,
          "gurmukhi": "ਕਾਚੀ ਦੇਹ ਮਾਨੁਖ ਅਭਿਮਾਨੀ ॥੨॥",
          "roman": "kāchī deh mānukh abhimānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਅਸੀਂ ਜੀਵ ਇਸ ਨਾਸਵੰਤ ਸਰੀਰ ਦਾ ਹੀ ਮਾਣ ਕਰਦੇ ਰਹਿੰਦੇ ਹਾਂ (ਤੇ, ਤੈਨੂੰ ਯਾਦ ਨਹੀਂ ਕਰਦੇ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но мы гордимся этим бренным телом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31672,
          "is_rahao": false,
          "gurmukhi": "ਸੁਆਦ ਬਾਦ ਈਰਖ ਮਦ ਮਾਇਆ ॥",
          "roman": "suād bād īrakh mad māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਦੁਨੀਆ ਦੇ ਪਦਾਰਥਾਂ ਦੇ) ਚਸਕੇ, ਝਗੜੇ, ਸਾੜਾ, ਮਾਇਆ ਦਾ ਮਾਣ-"
            },
            "sahib_singh_ru": {
              "main": "О Господь! вкусы, споры, зависть и гордость майи —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31673,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਸੰਗਿ ਲਾਗਿ ਰਤਨ ਜਨਮੁ ਗਵਾਇਆ ॥੩॥",
          "roman": "in saṅg lāg ratan janam gavāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਜੀਵ ਇਹਨਾਂ ਵਿਚ ਹੀ ਲੱਗ ਕੇ ਕੀਮਤੀ ਮਨੁੱਖਾ ਜਨਮ ਨੂੰ ਗਵਾ ਰਹੇ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "погружаясь в них, мы растрачиваем драгоценную человеческую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31674,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਭੰਜਨ ਜਗਜੀਵਨ ਹਰਿ ਰਾਇਆ ॥",
          "roman": "dukh bhanjan jagjīvan har rāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੁੱਖਾਂ ਦੇ ਨਾਸ ਕਰਨ ਵਾਲੇ! ਹੇ ਜਗਤ ਦੇ ਜੀਵਨ! ਹੇ ਪ੍ਰਭੂ ਪਾਤਿਸ਼ਾਹ!"
            },
            "sahib_singh_ru": {
              "main": "О разрушитель страданий, жизнь мира, Господь!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31675,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਿਆਗਿ ਨਾਨਕੁ ਸਰਣਾਇਆ ॥੪॥੧੩॥੧੯॥",
          "roman": "sagal tiāg nānak saraṇāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੇ (ਆਸਰੇ ਛੱਡ ਕੇ ਨਾਨਕ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹੈ ॥੪॥੧੩॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "Оставив всё, Нанак пришёл к Твоему прибежищу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2826,
      "rahao_verse_id": 31680,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31676,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31677,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਤ ਚਾਖਤ ਕਹੀਅਤ ਅੰਧਾ ਸੁਨੀਅਤ ਸੁਨੀਐ ਨਾਹੀ ॥",
          "roman": "pekhat chākhat kahīat andhā sunīat sunīai nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਹਰ ਵੇਲੇ ਮਨੁੱਖ ਦੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਹੈ, ਪਰ ਮਨੁੱਖ ਉਸ ਨੂੰ ਵੇਖਦਾ ਨਹੀਂ। ਇਸ ਵਾਸਤੇ, ਦੁਨੀਆ ਦੇ ਹੋਰ ਸਾਰੇ ਪਦਾਰਥ) ਵੇਖਦਾ ਚਾਖਦਾ ਹੋਇਆ ਭੀ (ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ) ਅੰਨ੍ਹਾ ਹੀ ਕਿਹਾ ਜਾ ਸਕਦਾ ਹੈ। (ਦੁਨੀਆ ਦੇ ਹੋਰ ਰਾਗ ਨਾਦ) ਸੁਣਦਾ ਹੋਇਆ ਭੀ (ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਨਹੀਂ ਸੁਣ ਰਿਹਾ (ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਬੋਲਾ ਹੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Хотя человек постоянно находится рядом с Богом, он Его не видит. Поэтому, хотя он видит и пробует другие вещи мира, его можно назвать духовно слепым. Хотя он слышит звуки мира, он не слышит восхваления Бога, и потому духовно глух."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31678,
          "is_rahao": false,
          "gurmukhi": "ਨਿਕਟਿ ਵਸਤੁ ਕਉ ਜਾਣੈ ਦੂਰੇ ਪਾਪੀ ਪਾਪ ਕਮਾਹੀ ॥੧॥",
          "roman": "nikat vastu kau jāṇē dūre pāpī pāp kamāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨੇੜੇ ਵੱਸ ਰਹੇ (ਨਾਮ-) ਪਦਾਰਥ ਨੂੰ ਕਿਤੇ ਦੂਰ ਸਮਝਦਾ ਹੈ। ਇਸ ਉਕਾਈ ਦੇ ਕਾਰਨ) ਵਿਕਾਰਾਂ ਵਿਚ ਫਸੇ ਹੋਏ ਮਨੁੱਖ ਵਿਕਾਰ ਹੀ ਕਰਦੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "То, что находится рядом (Имя), он считает далёким. Из-за этого заблуждения люди, погружённые в пороки, продолжают совершать грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31679,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਕਿਛੁ ਕਰਿ ਜਿਤੁ ਛੁਟਹਿ ਪਰਾਨੀ ॥",
          "roman": "so kichh kar jit chhuṭah parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਕੋਈ ਉਹ ਕੰਮ ਕਰ ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਤੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਿਆ ਰਹਿ ਸਕੇਂ।"
            },
            "sahib_singh_ru": {
              "main": "О живое существо! Делай то, благодаря чему ты сможешь освободиться от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31680,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਿ ਅੰਮ੍ਰਿਤ ਬਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har har nām jap amrit bānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ। (ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਿਤ-ਸਾਲਾਹ ਦੀ) ਬਾਣੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Постоянно повторяй Имя Бога; Его хвала — это дающая жизнь амритная речь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31681,
          "is_rahao": false,
          "gurmukhi": "ਘੋਰ ਮਹਲ ਸਦਾ ਰੰਗਿ ਰਾਤਾ ॥",
          "roman": "ghor mahal sadā rang rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਤੂੰ ਸਦਾ ਘੋੜੇ ਮਹਲ-ਮਾੜੀਆਂ ਆਦਿਕ ਦੇ ਪਿਆਰ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О существо! Ты постоянно погружён в любовь к домам, дворцам и богатствам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31682,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਤੁਮੑਾਰੈ ਕਛੂ ਨ ਜਾਤਾ ॥੨॥",
          "roman": "sang tumhārē kachhū na jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹਨਾਂ ਵਿਚੋਂ) ਕੋਈ ਭੀ ਚੀਜ਼ ਤੇਰੇ ਨਾਲ ਨਹੀਂ ਜਾ ਸਕਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но ничего из этого не пойдёт с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31683,
          "is_rahao": false,
          "gurmukhi": "ਰਖਹਿ ਪੋਚਾਰਿ ਮਾਟੀ ਕਾ ਭਾਂਡਾ ॥",
          "roman": "rakhah pochār māṭī kā bhāṇḍā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਤੂੰ ਇਸ ਮਿੱਟੀ ਦੇ ਭਾਂਡੇ (ਸਰੀਰ) ਨੂੰ (ਬਾਹਰੋਂ) ਬਣਾ ਸੰਵਾਰ ਕੇ ਰੱਖਦਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "О существо! Ты заботливо украшаешь это глиняное тело снаружи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31684,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਕੁਚੀਲ ਮਿਲੈ ਜਮ ਡਾਂਡਾ ॥੩॥",
          "roman": "at kuchīl milē jam ḍāṇḍā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਅੰਦਰੋਂ ਵਿਕਾਰਾਂ ਨਾਲ ਇਹ) ਬਹੁਤ ਗੰਦਾ ਹੋਇਆ ਪਿਆ ਹੈ। (ਇਹੋ ਜਿਹੇ ਜੀਵਨ ਵਾਲੇ ਨੂੰ ਤਾਂ) ਜਮਾਂ ਦੀ ਸਜ਼ਾ ਮਿਲਿਆ ਕਰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но внутри оно сильно загрязнено пороками; за такую жизнь приходит наказание Ямы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31685,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧਿ ਲੋਭਿ ਮੋਹਿ ਬਾਧਾ ॥",
          "roman": "kām krodh lobh moh bādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਤੂੰ ਕਾਮ ਕ੍ਰੋਧ ਵਿਚ, ਲੋਭ ਵਿਚ ਮੋਹ ਵਿਚ ਬੱਝਾ ਪਿਆ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О существо! Ты связан страстью, гневом, жадностью и привязанностью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31686,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਗਰਤ ਮਹਿ ਨਿਘਰਤ ਜਾਤਾ ॥੪॥",
          "roman": "mahā garat meh nigharat jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਕਾਰਾਂ ਦੇ ਵੱਡੇ ਹੋਏ ਵਿਚ (ਹੋਰ ਹੋਰ) ਖੁੱਭਦਾ ਜਾ ਰਿਹਾ ਹੈਂ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Ты всё глубже погружаешься в огромную яму пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31687,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਅਰਦਾਸਿ ਸੁਣੀਜੈ ॥",
          "roman": "nānak kī ardās sunījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! (ਆਪਣੇ ਦਾਸ) ਨਾਨਕ ਦੀ ਅਰਜ਼ੋਈ ਸੁਣ।"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Услышь молитву Твоего слуги Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31688,
          "is_rahao": false,
          "gurmukhi": "ਡੂਬਤ ਪਾਹਨ ਪ੍ਰਭ ਮੇਰੇ ਲੀਜੈ ॥੫॥੧੪॥੨੦॥",
          "roman": "ḍūbat pāhan prabh mere lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਾਂ ਡੁੱਬ ਰਹੇ ਪੱਥਰਾਂ ਨੂੰ ਡੁੱਬਣੋਂ ਬਚਾ ਲੈ ॥੫॥੧੪॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "Мы тонущие камни — спаси нас от утопления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2827,
      "rahao_verse_id": 31693,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31689,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31690,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਮਰੈ ਬੁਝੈ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "jīvat marē bujhē prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਦੁਨੀਆ ਦੀ ਕਾਰ ਕਰਦਾ ਹੋਇਆ ਹੀ (ਦੁਨੀਆ ਦਾ) ਮੋਹ ਤਿਆਗ ਦੇਂਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨਾਲ ਸਾਂਝ ਪਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто, живя в мире, отказывается от мирской привязанности, соединяется с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31691,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਕਰਮਿ ਪਰਾਪਤਿ ਹੋਇ ॥੧॥",
          "roman": "tis jan karam parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ (ਪਰਮਾਤਮਾ ਦੀ) ਕਿਰਪਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਦਾ ਮਿਲਾਪ) ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Такой человек по милости Бога достигает Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31692,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਸਾਜਨ ਇਉ ਦੁਤਰੁ ਤਰੀਐ ॥",
          "roman": "sun sājan iou dutar tarīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਜਣ! (ਮੇਰੀ ਬੇਨਤੀ) ਸੁਣ। ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣਾ ਬਹੁਤ ਔਖਾ ਹੈ, ਇਸ ਤੋਂ ਸਿਰਫ਼ ਇਸ ਤਰੀਕੇ ਨਾਲ ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ (ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "О друг! Послушай: океан мира трудно переплыть, и его можно пересечь только так:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31693,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਹਰਿ ਨਾਮੁ ਉਚਰੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mil sādhū har nām ucharīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਜਾਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "встретив Гуру, следует произносить Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31694,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਬਿਨਾ ਦੂਜਾ ਨਹੀ ਜਾਨੈ ॥",
          "roman": "ek binā dūjā nahī jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਇਕ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਹੋਰ ਨਾਲ ਦਿਲੀ ਸਾਂਝ ਨਹੀਂ ਪਾਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто не привязывается ни к кому, кроме Единого Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31695,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਪਾਰਬ੍ਰਹਮੁ ਪਛਾਨੈ ॥੨॥",
          "roman": "ghaṭ ghaṭ antar pārbrahm pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਪਛਾਣ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "распознаёт Бога, пребывающего в каждом существе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31696,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੈ ਸੋਈ ਭਲ ਮਾਨੈ ॥",
          "roman": "jo kichh karē soi bhal mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਭੀ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ ਜੇਹੜਾ ਮਨੁੱਖ ਹਰੇਕ ਉਸ ਕੰਮ ਨੂੰ (ਦੁਨੀਆ ਵਾਸਤੇ) ਭਲਾ ਮੰਨਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто считает всё, что делает Бог, благим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31697,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਅੰਤ ਕੀ ਕੀਮਤਿ ਜਾਨੈ ॥੩॥",
          "roman": "ād ant kī kīmat jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਹੀ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੀ ਕਦਰ ਸਮਝ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "понимает ценность вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31698,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਿਸੁ ਜਨ ਬਲਿਹਾਰੀ ॥",
          "roman": "kaho nānak tis jan balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਪ੍ਰਭੂ! ਉਸ ਮਨੁੱਖ ਤੋਂ (ਮੈਂ) ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: я предан такому человеку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31699,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹਿਰਦੈ ਵਸਹਿ ਮੁਰਾਰੀ ॥੪॥੧੫॥੨੧॥",
          "roman": "jā kē hirdē vasahi murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸਦਾ ਤੂੰ ਵੱਸਦਾ ਹੈਂ (ਜਿਸ ਨੂੰ ਸਦਾ ਤੂੰ ਚੇਤੇ ਰਹਿੰਦਾ ਹੈਂ) ॥੪॥੧੫॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "в сердце которого пребывает Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2828,
      "rahao_verse_id": 31704,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31700,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31701,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਕਰਣੈਹਾਰੁ ॥",
          "roman": "gur parmesar karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਗੁਰੂ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ ਜੇਹੜਾ ਸਭ ਤੋਂ ਵੱਡਾ ਮਾਲਕ ਹੈ ਜੇਹੜਾ ਸਭ ਕੁਝ ਕਰ ਸਕਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Гуру — это образ Бога, великого Владыки, способного на всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31702,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸ੍ਰਿਸਟਿ ਕਉ ਦੇ ਆਧਾਰੁ ॥੧॥",
          "roman": "sagal srisht kau de ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਨੂੰ (ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ) ਆਸਰਾ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру даёт всей вселенной опору — Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31703,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਣ ਕਮਲ ਮਨ ਧਿਆਇ ॥",
          "roman": "gur ke charaṇ kamal man dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਸਦਾ) ਗੁਰੂ ਦੇ ਸੋਹਣੇ ਕੋਮਲ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Сосредоточься на прекрасных, нежных стопах Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31704,
          "is_rahao": true,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਇਸੁ ਤਨ ਤੇ ਜਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dūkh dard is tan te jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਇਹ ਉੱਦਮ ਕਰਦਾ ਹੈ ਉਸ ਦੇ) ਇਸ ਸਰੀਰ ਤੋਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਦੁੱਖ-ਕਲੇਸ਼ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда все страдания и боли покинут это тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31705,
          "is_rahao": false,
          "gurmukhi": "ਭਵਜਲਿ ਡੂਬਤ ਸਤਿਗੁਰੁ ਕਾਢੈ ॥",
          "roman": "bhavjal ḍūbat satgur kāḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ! ਗੁਰੂ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਡੁਬਦਿਆਂ ਨੂੰ ਬਚਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Гуру спасает тех, кто тонет в океане мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31706,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਟੂਟਾ ਗਾਢੈ ॥੨॥",
          "roman": "janam janam kā ṭūṭā gāḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜਨਮਾਂ ਤੋਂ (ਪਰਮਾਤਮਾ ਨਾਲੋਂ) ਟੁੱਟੇ ਹੋਏ ਮਨੁੱਖ ਨੂੰ (ਪਰਮਾਤਮਾ ਨਾਲ) ਜੋੜ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и соединяет человека, разлучённого с Богом на протяжении многих жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31707,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੇਵਾ ਕਰਹੁ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "gur kī sevā karah din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਦਿਨ ਰਾਤ ਗੁਰੂ ਦੀ (ਦੱਸੀ ਹੋਈ) ਸੇਵਾ ਕਰਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Служите Гуру день и ночь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31708,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਮਨਿ ਆਵੈ ਸਾਂਤਿ ॥੩॥",
          "roman": "sūkh sahaj man āvē sānt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਸੇਵਾ ਕਰਦਾ ਹੈ ਉਸ ਦੇ) ਮਨ ਵਿਚ ਸ਼ਾਂਤੀ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ, ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਆਨੰਦ ਪੈਦਾ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда в сердце придёт покой и духовное равновесие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31709,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਕੀ ਰੇਣੁ ਵਡਭਾਗੀ ਪਾਵੈ ॥",
          "roman": "satgur kī reṇ vaḍbhāgī pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਚਰਨ-ਧੂੜ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только очень удачливый человек обретает пыль стоп Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31710,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਕਉ ਸਦ ਬਲਿ ਜਾਵੈ ॥੪॥੧੬॥੨੨॥",
          "roman": "nānak gur kau sad bal jāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਫਿਰ ਉਹ ਮਨੁੱਖ) ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹੈ ॥੪॥੧੬॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такой человек всегда предан Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2829,
