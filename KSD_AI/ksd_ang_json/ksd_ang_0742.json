{
  "ang": 742,
  "shabads": [
    {
      "shabad_id": 2830,
      "rahao_verse_id": 31726,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31722,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31723,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਦੇਖਿ ਜੀਵਾ ਗੁਰ ਤੇਰਾ ॥",
          "roman": "darsan dekh jīvā gur terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਰੂ! ਤੇਰਾ ਦਰਸਨ ਕਰ ਕੇ ਮੈਨੂੰ ਆਤਮਕ ਜੀਵਨ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Гуру! Увидев твой даршан, я обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31724,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਕਰਮੁ ਹੋਇ ਪ੍ਰਭ ਮੇਰਾ ॥੧॥",
          "roman": "pūran karam ho-e prabh merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਪੂਰਨ ਬਖ਼ਸ਼ਸ਼ ਹੋਏ (ਤੇ, ਮੈਨੂੰ ਗੁਰੂ ਮਿਲ ਜਾਵੇ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Когда совершается Твоя полная милость (и я встречаю Гуру)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31725,
          "is_rahao": true,
          "gurmukhi": "ਇਹ ਬੇਨੰਤੀ ਸੁਣਿ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "ih benantī suṇ prabh mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ (ਮੇਰੀ) ਇਹ ਅਰਜ਼ੋਈ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь, услышь эту мою просьбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31726,
          "is_rahao": true,
          "gurmukhi": "ਦੇਹਿ ਨਾਮੁ ਕਰਿ ਅਪਣੇ ਚੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "deh nām kar apṇe chere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਰਾਹੀਂ) ਮੈਨੂੰ ਆਪਣਾ ਸੇਵਕ ਬਣਾ ਕੇ (ਆਪਣਾ) ਨਾਮ ਬਖ਼ਸ਼ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "сделай меня Своим слугой и даруй мне Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31727,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੀ ਸਰਣਿ ਰਾਖੁ ਪ੍ਰਭ ਦਾਤੇ ॥",
          "roman": "apṇī saraṇ rākh prabh dāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦਾਤਾਂ ਦੇਣ ਵਾਲੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਆਪਣੀ ਸਰਨ ਵਿਚ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, дарующий всё, держи меня в Своём прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31728,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਕਿਨੈ ਵਿਰਲੈ ਜਾਤੇ ॥੨॥",
          "roman": "gur prasād kinē virlē jāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਕਿਸੇ ਵਿਰਲੇ ਮਨੁੱਖ ਨੇ ਤੇਰੇ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! По милости Гуру лишь редкий человек познал Тебя глубоко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31729,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਹੁ ਬਿਨਉ ਪ੍ਰਭ ਮੇਰੇ ਮੀਤਾ ॥",
          "roman": "sunah binau prabh mere mītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਿੱਤਰ ਪ੍ਰਭੂ! ਮੇਰੀ ਅਰਜ਼ੋਈ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О мой друг Господь, услышь мою мольбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31730,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਵਸਹਿ ਮੇਰੈ ਚੀਤਾ ॥੩॥",
          "roman": "charan kamal vasahi merē chītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਹਰ ਕਰ! ਤੇਰੇ) ਸੋਹਣੇ ਚਰਨ ਮੇਰੇ ਚਿੱਤ ਵਿਚ ਵੱਸ ਪੈਣ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "пусть Твои прекрасные стопы поселятся в моём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31731,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਏਕ ਕਰੈ ਅਰਦਾਸਿ ॥",
          "roman": "nānak ek karē ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਸੇਵਕ) ਨਾਨਕ (ਤੇਰੇ ਦਰ ਤੇ) ਇਕ ਅਰਜ਼ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак возносит одну просьбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31732,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਰੁ ਨਾਹੀ ਪੂਰਨ ਗੁਣਤਾਸਿ ॥੪॥੧੮॥੨੪॥",
          "roman": "visar nāhī pūran guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੂਰਨ ਪ੍ਰਭੂ! ਸਭ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! (ਕਿਰਪਾ ਕਰ, ਮੈਨੂੰ ਨਾਨਕ ਨੂੰ ਕਦੇ) ਨਾਹ ਭੁੱਲ ॥੪॥੧੮॥੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "о совершенный Господь, сокровищница всех добродетелей, не дай мне забыть Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2831,
      "rahao_verse_id": 31737,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31733,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31734,
          "is_rahao": false,
          "gurmukhi": "ਮੀਤੁ ਸਾਜਨੁ ਸੁਤ ਬੰਧਪ ਭਾਈ ॥",
          "roman": "mīt sājan sut bandhāp bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਹੀ ਮੇਰਾ ਮਿੱਤਰ ਹੈ, ਸੱਜਣ ਹੈ, ਪਰਮਾਤਮਾ ਹੀ (ਮੇਰੇ ਵਾਸਤੇ) ਪੁੱਤਰ ਰਿਸ਼ਤੇਦਾਰ ਭਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Только Господь — мой друг, близкий, Он же для меня сын, родной и брат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31735,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਪੇਖਉ ਹਰਿ ਸੰਗਿ ਸਹਾਈ ॥੧॥",
          "roman": "jat kat pekhau har sang sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਜਿਧਰ ਕਿਧਰ ਵੇਖਦਾ ਹਾਂ, ਪਰਮਾਤਮਾ ਮੇਰੇ ਨਾਲ ਮਦਦਗਾਰ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни посмотрел, Господь рядом со мной как помощник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31736,
          "is_rahao": true,
          "gurmukhi": "ਜਤਿ ਮੇਰੀ ਪਤਿ ਮੇਰੀ ਧਨੁ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "jat merī pat merī dhan har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮੇਰੀ (ਉੱਚੀ) ਜਾਤਿ ਹੈ, ਮੇਰੀ ਇੱਜ਼ਤ ਹੈ, ਮੇਰਾ ਧਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Господа — моя честь, моё достоинство и моё богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31737,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਬਿਸਰਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sūkh sahaj ānand bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰੇ ਅੰਦਰ) ਆਨੰਦ ਹੈ ਸ਼ਾਂਤੀ ਹੈ, ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря ему во мне есть покой, радость и духовное равновесие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31738,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਪਿ ਪਹਿਰਿ ਸਨਾਹ ॥",
          "roman": "pārbrahm jap pahir sanāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਦਾ) ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਜਪਿਆ ਕਰ, (ਹਰਿ-ਨਾਮ ਦੀ) ਸੰਜੋਅ ਪਹਿਨੀ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда повторяй Имя Господа и облачайся в доспех Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31739,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਆਵਧ ਤਿਸੁ ਬੇਧਤ ਨਾਹਿ ॥੨॥",
          "roman": "koṭ āvadh tis bedhat nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਸੰਜੋਅ) ਨੂੰ (ਕਾਮਾਦਿਕ) ਕ੍ਰੋੜਾਂ ਹਥਿਆਰ ਵਿੰਨ੍ਹ ਨਹੀਂ ਸਕਦੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Этот доспех не могут пробить миллионы оружий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31740,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਨ ਸਰਣ ਗੜ ਕੋਟ ਹਮਾਰੈ ॥",
          "roman": "har charan saraṇ gaṛ koṭ hamārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰੇ ਵਾਸਤੇ (ਤਾਂ) ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦੀ ਸਰਨ ਅਨੇਕਾਂ ਕਿਲ੍ਹੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Для меня прибежище у стоп Господа — это крепость из множества цитаделей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31741,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੁ ਕੰਟਕੁ ਜਮੁ ਤਿਸੁ ਨ ਬਿਦਾਰੈ ॥੩॥",
          "roman": "kāl kaṇṭak jam tis na bidārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਕਿਲ੍ਹੇ) ਨੂੰ ਦੁਖਦਾਈ ਮੌਤ (ਦਾ ਡਰ) ਨਾਸ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Эту крепость не может разрушить страх смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31742,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਦਾ ਬਲਿਹਾਰੀ ॥",
          "roman": "nānak dās sadā balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਸੇਵਕਾਂ ਸੰਤਾਂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: я всегда жертвую собой ради Твоих слуг-святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31743,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਸੰਤ ਰਾਜਾ ਰਾਮ ਮੁਰਾਰੀ ॥੪॥੧੯॥੨੫॥",
          "roman": "sevak sant rājā rām murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ! ਹੇ ਮੁਰਾਰੀ! (ਜਿਨ੍ਹਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਤੇਰਾ ਨਾਮ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ) ॥੪॥੧੯॥੨੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Господь-Царь, Мурари, в их обществе обретается Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2832,
      "rahao_verse_id": 31748,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31744,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31745,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗੋਪਾਲ ਪ੍ਰਭ ਕੇ ਨਿਤ ਗਾਹਾ ॥",
          "roman": "guṇ gopāl prabh ke nit gāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! ਗੋਪਾਲ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਸਦਾ ਗਾਂਦੇ ਰਹੀਏ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Давайте всегда воспевать качества Господа Гопала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31746,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਬਿਨੋਦ ਮੰਗਲ ਸੁਖ ਤਾਹਾ ॥੧॥",
          "roman": "anad binod maṅgal sukh tāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਗਾਂਦੇ ਹਨ) ਉਹਨਾਂ ਨੂੰ ਸੁਖ ਆਨੰਦ ਚਾਉ ਖ਼ੁਸ਼ੀਆਂ ਬਣੀਆਂ ਰਹਿੰਦੀਆਂ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Те, кто поют, пребывают в радости, счастье и веселье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31747,
          "is_rahao": true,
          "gurmukhi": "ਚਲੁ ਸਖੀਏ ਪ੍ਰਭੁ ਰਾਵਣ ਜਾਹਾ ॥",
          "roman": "chal sakhīe prabh rāvaṇ jāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! ਉੱਠ, ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਚੱਲੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Встань, пойдём размышлять о Господе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31748,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੀ ਚਰਣੀ ਪਾਹਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādh janā kī charaṇī pāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜਾ ਪਈਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "пойдём и склонимся к стопам святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31749,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਬੇਨਤੀ ਜਨ ਧੂਰਿ ਬਾਛਾਹਾ ॥",
          "roman": "kar benatī jan dhūr bāchhāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! (ਪ੍ਰਭੂ ਅੱਗੇ) ਬੇਨਤੀ ਕਰ ਕੇ (ਉਸ ਪਾਸੋਂ) ਸੰਤ ਜਨਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਮੰਗੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Вознеся просьбу, попросим пыль стоп святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31750,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਵਿਖ ਲਾਹਾਂ ॥੨॥",
          "roman": "janam janam ke kilvikh lāhāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ ਆਪਣੇ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਪਾਪ ਦੂਰ ਕਰ ਲਈਏ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и избавимся от грехов многих жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31751,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਪ੍ਰਾਣ ਜੀਉ ਅਰਪਾਹਾ ॥",
          "roman": "man tan prāṇ jīu arpāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਏ! ਆਪਣਾ ਮਨ ਤਨ ਜਿੰਦ ਜਾਨ ਭੇਟਾ ਕਰ ਦੇਈਏ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Посвятим Ему ум, тело, жизнь и душу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31752,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਮਾਨੁ ਮੋਹੁ ਕਟਾਹਾਂ ॥੩॥",
          "roman": "har simar simar mān moh kaṭāhāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਅਹੰਕਾਰ ਤੇ ਮੋਹ ਦੂਰ ਕਰ ਲਈਏ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помня Господа, избавимся от эго и привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31753,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਕਰਹੁ ਉਤਸਾਹਾ ॥",
          "roman": "dīn dayāl karah utsāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਹਰੀ! (ਮੇਰੇ ਅੰਦਰ) ਚਾਉ ਪੈਦਾ ਕਰ (ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "О милосердный к бедным Господь! Пробуди во мне стремление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31754,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਹਰਿ ਸਰਣਿ ਸਮਾਹਾ ॥੪॥੨੦॥੨੬॥",
          "roman": "nānak dās har saraṇ samāhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਮੈਂ ਤੇਰੇ ਦਾਸਾਂ ਦੀ ਸਰਨ ਪਿਆ ਰਹਾਂ ॥੪॥੨੦॥੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы я пребывал в прибежище Твоих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2833,
      "rahao_verse_id": 31759,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31755,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31756,
          "is_rahao": false,
          "gurmukhi": "ਬੈਕੁੰਠ ਨਗਰੁ ਜਹਾ ਸੰਤ ਵਾਸਾ ॥",
          "roman": "bēkunṭh nagar jahā sant vāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਥਾਂ (ਪਰਮਾਤਮਾ ਦੇ) ਸੰਤ ਜਨ ਵੱਸਦੇ ਹੋਣ, ਉਹੀ ਹੈ (ਅਸਲ) ਬੈਕੁੰਠ ਦਾ ਸ਼ਹਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Там, где живут святые, там и есть истинный город Вайкунтха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31757,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਚਰਣ ਕਮਲ ਰਿਦ ਮਾਹਿ ਨਿਵਾਸਾ ॥੧॥",
          "roman": "prabh charaṇ kamal rid māhi nivāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ) ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨ ਹਿਰਦੇ ਵਿਚ ਆ ਵੱਸਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "В их обществе стопы Господа поселяются в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31758,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਮਨ ਤਨ ਤੁਝੁ ਸੁਖੁ ਦਿਖਲਾਵਉ ॥",
          "roman": "suṇ man tan tujh sukh dikhlāvao",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮੇਰੀ ਗੱਲ) ਸੁਣ, (ਆ,) ਮੈਂ (ਤੇਰੇ) ਮਨ ਨੂੰ (ਤੇਰੇ) ਤਨ ਨੂੰ ਆਤਮਕ ਆਨੰਦ ਵਿਖਾ ਦਿਆਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Слушай, я покажу твоему уму и телу духовное счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31759,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਅਨਿਕ ਬਿੰਜਨ ਤੁਝੁ ਭੋਗ ਭੁੰਚਾਵਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har anik binjan tujh bhog bhuñchāvao",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਮਾਨੋ) ਅਨੇਕਾਂ ਸੁਆਦਲੇ ਭੋਜਨ ਹੈ, (ਆ, ਸਾਧ ਸੰਗਤਿ ਵਿਚ) ਮੈਂ ਤੈਨੂੰ ਉਹ ਸੁਆਦਲੇ ਭੋਜ ਖਵਾਵਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Господа — как множество вкусных блюд, я дам тебе вкусить их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31760,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਭੁੰਚੁ ਮਨ ਮਾਹੀ ॥",
          "roman": "amrit nām bhuñch man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ (-ਭੋਜਨ) ਆਪਣੇ ਮਨ ਵਿਚ ਖਾਇਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Вкушай в своём сердце нектар Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31761,
          "is_rahao": false,
          "gurmukhi": "ਅਚਰਜ ਸਾਦ ਤਾ ਕੇ ਬਰਨੇ ਨ ਜਾਹੀ ॥੨॥",
          "roman": "acharaj sād tā ke barne na jāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਭੋਜਨ ਦੇ ਹੈਰਾਨ ਕਰਨ ਵਾਲੇ ਸੁਆਦ ਹਨ, ਬਿਆਨ ਨਹੀਂ ਕੀਤੇ ਜਾ ਸਕਦੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "его удивительный вкус невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31762,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭੁ ਮੂਆ ਤ੍ਰਿਸਨਾ ਬੁਝਿ ਥਾਕੀ ॥",
          "roman": "lobh mūā trisnā bujh thākī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਲੋਭ ਮੁੱਕ ਜਾਂਦਾ ਹੈ, ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਬੁੱਝ ਕੇ ਖ਼ਤਮ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Жадность умирает, жажда угасает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31763,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਸਰਣਿ ਜਨ ਤਾਕੀ ॥੩॥",
          "roman": "pārbrahm kī saraṇ jan tākī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਸੰਤ ਜਨਾਂ ਨੇ (ਸਾਧ ਸੰਗਤਿ-ਬੈਕੁੰਠ ਵਿਚ ਆ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਤੱਕ ਲਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "у тех, кто ищет прибежища у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31764,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਭੈ ਮੋਹ ਨਿਵਾਰੇ ॥",
          "roman": "janam janam ke bhē moh nivāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਉਹਨਾਂ ਦੇ ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਡਰ ਮੋਹ ਦੂਰ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь устраняет страхи и привязанности многих жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31765,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਪ੍ਰਭ ਕਿਰਪਾ ਧਾਰੇ ॥੪॥੨੧॥੨੭॥",
          "roman": "nānak dās prabh kirpā dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
