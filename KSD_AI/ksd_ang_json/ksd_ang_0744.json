          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31878,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਦੂਜਾ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "tis bin dūjā avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਨਹੀਂ (ਜੋ ਵਿਕਾਰਾਂ ਰੋਗਾਂ ਤੋਂ ਬਚਣ ਲਈ ਸਹਾਰਾ ਦੇ ਸਕੇ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кроме Него нет никого другого, кто мог бы помочь избавиться от пороков и болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31879,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਥੰਮੈ ਸਚਾ ਸੋਈ ॥੧॥",
          "roman": "āpe thammē sachā soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਆਪ ਹੀ (ਹਰੇਕ ਜੀਵ ਨੂੰ) ਸਹਾਰਾ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Этот Вечный Бог Сам поддерживает каждого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31880,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਮੇਰਾ ਆਧਾਰੁ ॥",
          "roman": "har har nām merā ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮੇਰਾ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — моя опора,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31881,
          "is_rahao": true,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਸਮਰਥੁ ਅਪਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karaṇ kāraṇ samrath apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਪਰਮਾਤਮਾ ਸਾਰੇ ਜਗਤ ਦਾ ਮੂਲ ਹੈ, ਜੋ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ, ਜਿਸ ਦੀ ਹਸਤੀ ਦਾ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он — причина всего, Всемогущий и безграничный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31882,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਰੋਗ ਮਿਟਾਵੇ ਨਵਾ ਨਿਰੋਆ ॥",
          "roman": "sabh rog miṭāve navā niroā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਉਹ ਸਾਰੇ ਰੋਗ ਮਿਟਾ ਦੇਂਦਾ ਹੈ, ਉਸ ਨੂੰ ਨਵਾਂ ਨਿਰੋਆ ਕਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он уничтожает все болезни и делает человека вновь здоровым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31883,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਖਾ ਆਪੇ ਹੋਆ ॥੨॥੩੩॥੩੯॥",
          "roman": "nānak rakhā āpe hoā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਦਾ ਰਾਖਾ ਪ੍ਰਭੂ ਆਪ ਬਣ ਜਾਂਦਾ ਹੈ ॥੨॥੩੩॥੩੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! когда Сам Бог становится защитником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
