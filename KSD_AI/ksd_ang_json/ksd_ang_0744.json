{
  "ang": 744,
  "shabads": [
    {
      "shabad_id": 2839,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31829,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜਗਦੀਸ ਕੀ ਗਤਿ ਨਹੀ ਜਾਣੀ ॥੩॥",
          "roman": "jē jagdīs kī gat nahī jāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਆਤਮਕ ਆਨੰਦ ਦੀ ਅਵਸਥਾ ਤੂੰ (ਹੁਣ ਤਕ) ਸਮਝੀ ਹੀ ਨਹੀਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но состояние духовного आनंदа Бога ты так и не понял."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31830,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਸਮਰਥ ਅਗੋਚਰ ਸੁਆਮੀ ॥",
          "roman": "saraṇ samrath agochar suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤਾਕਤਾਂ ਦੇ ਮਾਲਕ! ਗਿਆਨ ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਰਹਿਣ ਵਾਲੇ ਹੇ ਮਾਲਕ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О всемогущий и непостижимый Господь! Я пришёл в твоё прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31831,
          "is_rahao": false,
          "gurmukhi": "ਉਧਰੁ ਨਾਨਕ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥੪॥੨੭॥੩੩॥",
          "roman": "udhar nānak prabh antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਮੈਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲੈ, ਤੂੰ ਮੇਰਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਮੇਰੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈਂ ॥੪॥੨੭॥੩੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Спаси меня от пороков, ты знаешь моё сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2840,
      "rahao_verse_id": 31836,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31832,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31833,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਤਰੈ ਭੈ ਸਾਗਰੁ ॥",
          "roman": "sādhsang tarē bhē sāgar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖ ਡਰਾਂ-ਭਰੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В обществе Гуру человек переправляется через океан страха, наполненный миром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31834,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਸਿਮਰਿ ਰਤਨਾਗਰੁ ॥੧॥",
          "roman": "har har nām simar ratnāgar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਤਨਾਂ ਦੀ ਖਾਣਿ ਹਰਿ-ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਮਨੁੱਖ ਦਾ ਉਧਾਰ ਹੁੰਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Снова и снова поминая Имя Хари, сокровищницу драгоценностей, человек спасается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31835,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਜੀਵਾ ਨਾਰਾਇਣ ॥",
          "roman": "simar simar jīvā nārāyan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰ ਰਿਹਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру, поминая Имя Бога, я обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31836,
          "is_rahao": true,
          "gurmukhi": "ਦੂਖ ਰੋਗ ਸੋਗ ਸਭਿ ਬਿਨਸੇ ਗੁਰ ਪੂਰੇ ਮਿਲਿ ਪਾਪ ਤਜਾਇਣ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dūkh rog sog sabh binse gur pūre mil pāp tajāyan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਸਾਰੇ ਦੁੱਖ ਰੋਗ ਗ਼ਮ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ, ਪਾਪ ਤਿਆਗੇ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Встретив совершенного Гуру, все страдания, болезни и печали исчезают, грехи оставляются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31837,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਪਦਵੀ ਹਰਿ ਕਾ ਨਾਉ ॥",
          "roman": "jīvan padvī har kā nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਹੀ) ਆਤਮਕ ਜ਼ਿੰਦਗੀ ਦਾ ਪਿਆਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — это и есть любовь духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31838,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਨਿਰਮਲੁ ਸਾਚੁ ਸੁਆਉ ॥੨॥",
          "roman": "man tan nirmal sāch suāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਨ ਪਵਿਤਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਸਰੀਰ ਪਵਿਤਰ ਹੋ ਜਾਂਦਾ ਹੈ, (ਨਾਮ ਸਿਮਰਦਿਆਂ) ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦਾ ਮਿਲਾਪ ਹੀ) ਜੀਵਨ ਮਨੋਰਥ ਬਣ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря Имени ум очищается, тело очищается, и целью жизни становится встреча с Вечным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31839,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪਾਰਬ੍ਰਹਮੁ ਧਿਆਈਐ ॥",
          "roman": "āṭh pahar pārbrahm dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਅੱਠੇ ਪਹਰ ਸਿਮਰਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога следует помнить все восемь страж дня и ночи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31840,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਬਿ ਲਿਖਤੁ ਹੋਇ ਤਾ ਪਾਈਐ ॥੩॥",
          "roman": "pūrab likhat hoi tā pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਦਾਤ ਤਦੋਂ ਹੀ ਮਿਲਦੀ ਹੈ ਜੇ ਪੂਰਬਲੇ ਜਨਮ ਵਿਚ (ਮੱਥੇ ਉਤੇ ਨਾਮ ਸਿਮਰਨ ਦਾ) ਲੇਖ ਲਿਖਿਆ ਹੋਵੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но этот дар даётся лишь тогда, когда в прошлых рождениях на челе записано поминание Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31841,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਪਏ ਜਪਿ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "saran pae jap dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਜੇਹੜੇ ਮਨੁੱਖ ਉਸ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Те, кто, повторяя Имя Милосердного к бедным Бога, пребывают в Его прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31842,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਾਚੈ ਸੰਤ ਰਵਾਲਾ ॥੪॥੨੮॥੩੪॥",
          "roman": "nānak jāchē sant ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਉਹਨਾਂ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹੈ ॥੪॥੨੮॥੩੪॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак просит пыли стоп таких святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2841,
      "rahao_verse_id": 31847,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31843,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31844,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਕਾ ਕਾਜੁ ਨ ਜਾਣੀ ਰੂੜਾ ॥",
          "roman": "ghar kā kāj na jāṇī rūṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਮੇਹਰ ਤੋਂ ਬਿਨਾ) ਮਨੁੱਖ ਉਹ ਸੋਹਣਾ ਕੰਮ ਕਰਨਾ ਨਹੀਂ ਜਾਣਦਾ, ਜੇਹੜਾ ਇਸ ਦੇ ਆਪਣੇ ਹਿਰਦੇ-ਘਰ ਦੇ ਕੰਮ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Без Твоей милости человек не знает, как делать то прекрасное дело, которое полезно для его внутреннего дома,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31845,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠੈ ਧੰਧੈ ਰਚਿਓ ਮੂੜਾ ॥੧॥",
          "roman": "jhūṭhē dhandhē rachiō mūṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਗੋਂ) ਇਹ ਮੂਰਖ ਝੂਠੇ ਧੰਧੇ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а глупец погружён в ложные занятия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31846,
          "is_rahao": true,
          "gurmukhi": "ਜਿਤੁ ਤੂੰ ਲਾਵਹਿ ਤਿਤੁ ਤਿਤੁ ਲਗਨਾ ॥",
          "roman": "jit tū lāveh tit tit lagnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਜਿਸ ਕੰਮ ਵਿਚ ਤੂੰ (ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ) ਲਾਂਦਾ ਹੈਂ, ਉਸ ਉਸ ਕੰਮ ਵਿਚ ਅਸੀਂ ਲੱਗਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! В какое дело Ты нас направляешь, в том мы и заняты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31847,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਤੂੰ ਦੇਹਿ ਤੇਰਾ ਨਾਉ ਜਪਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā tū deh terā nāo japnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੂੰ (ਸਾਨੂੰ ਆਪਣਾ ਨਾਮ) ਦੇਂਦਾ ਹੈਂ, ਤਦੋਂ ਤੇਰਾ ਨਾਮ ਜਪਦੇ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Ты даёшь нам Своё Имя, тогда мы его повторяем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31848,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਦਾਸ ਹਰਿ ਸੇਤੀ ਰਾਤੇ ॥",
          "roman": "har ke dās har setī rāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਸੇਵਕ ਪਰਮਾਤਮਾ ਨਾਲ ਹੀ ਰੰਗੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Слуги Бога окрашены только в любовь к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31849,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣਿ ਅਨਦਿਨੁ ਮਾਤੇ ॥੨॥",
          "roman": "rām rasāyan an-din māte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਵੇਲੇ ਸਭ ਰਸਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਹਰਿ-ਨਾਮ ਰਸ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и всегда пребывают в опьянении нектаром Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31850,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹ ਪਕਰਿ ਪ੍ਰਭਿ ਆਪੇ ਕਾਢੇ ॥",
          "roman": "bāh pakar prabh āpe kāḍhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ) ਬਾਂਹ ਫੜ ਕੇ (ਝੂਠੇ ਧੰਧਿਆਂ ਵਿਚੋਂ) ਕੱਢ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тех, кого Сам Бог взял за руку и вывел из ложных занятий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31851,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਟੂਟੇ ਗਾਢੇ ॥੩॥",
          "roman": "janam janam ke ṭūṭe gāḍhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ (ਪ੍ਰਭੂ ਨਾਲੋਂ) ਟੁੱਟਿਆਂ ਹੋਇਆਂ ਨੂੰ (ਉਸ ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਆਪਣੇ ਨਾਲ) ਜੋੜ ਲਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он соединяет с Собой после многих рождений разлуки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31852,
          "is_rahao": false,
          "gurmukhi": "ਉਧਰੁ ਸੁਆਮੀ ਪ੍ਰਭ ਕਿਰਪਾ ਧਾਰੇ ॥",
          "roman": "udhar suāmī prabh kirpā dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਲਕ ਪ੍ਰਭੂ! ਮੇਹਰ ਕਰ। (ਮੈਨੂੰ ਝੂਠੇ ਧੰਧਿਆਂ ਤੋਂ) ਬਚਾ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Владыка Бог! Прояви милость и спаси меня от ложных занятий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31853,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਹਰਿ ਸਰਣਿ ਦੁਆਰੇ ॥੪॥੨੯॥੩੫॥",
          "roman": "nānak dās har saran duāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਆਖ-) ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ, ਮੈਂ ਤੇਰੇ ਦਰ ਤੇ (ਆ ਡਿੱਗਾ ਹਾਂ) ॥੪॥੨੯॥੩੫॥"
            },
            "sahib_singh_ru": {
              "main": "О раб Нанак говорит: я пришёл в Твоё прибежище, к Твоей двери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2842,
      "rahao_verse_id": 31858,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31854,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31855,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਨਿਹਚਲੁ ਘਰੁ ਪਾਇਆ ॥",
          "roman": "sant prasād nihchal ghar pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਸ ਨੇ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਕਦੇ ਨਾਹ ਡੋਲਣ ਵਾਲਾ ਹਿਰਦਾ-ਘਰ ਲੱਭ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто по милости Гуру обрёл неизменный внутренний дом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31856,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਫਿਰਿ ਨਹੀ ਡੋੁਲਾਇਆ ॥੧॥",
          "roman": "sarab sūkh phir nahī ḍolāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਿਰਦੇ ਦੀ ਅਡੋਲਤਾ ਪ੍ਰਾਪਤ ਕਰ ਲਈ) ਉਸ ਨੂੰ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਗਏ, (ਉਹ ਮਨੁੱਖ ਕਦੇ ਵਿਕਾਰਾਂ ਵਿਚ) ਨਹੀਂ ਡੋਲਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "обретает все радости и больше не колеблется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31857,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੂ ਧਿਆਇ ਹਰਿ ਚਰਨ ਮਨਿ ਚੀਨੑੇ ॥",
          "roman": "gurū dhiāi har charan man chīnhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ) ਗੁਰੂ ਦਾ ਧਿਆਨ ਧਰ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਨੂੰ (ਆਪਣੇ) ਮਨ ਵਿਚ (ਵੱਸਦਾ) ਪਛਾਣ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Те, кто, сосредоточившись на Гуру, узнали в сердце стопы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31858,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਤੇ ਕਰਤੈ ਅਸਥਿਰੁ ਕੀਨੑੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā te kartē asthir kīnhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਪਰਖ) ਦੀ ਬਰਕਤਿ ਨਾਲ ਕਰਤਾਰ ਨੇ (ਉਹਨਾਂ ਨੂੰ) ਅਡੋਲ-ਚਿੱਤ ਬਣਾ ਦਿੱਤਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "благодаря этому Господь сделал их ум устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31859,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵਤ ਅਚੁਤ ਅਬਿਨਾਸੀ ॥",
          "roman": "guṇ gāvat achut abināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅਟੱਲ ਅਬਿਨਾਸੀ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ-"
            },
            "sahib_singh_ru": {
              "main": "О брат! Воспевая качества Непоколебимого и Вечного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31860,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇ ਕਾਟੀ ਜਮ ਕੀ ਫਾਸੀ ॥੨॥",
          "roman": "tā te kāṭī jam kī phāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਣ ਗਾਣ ਦੀ ਬਰਕਤਿ ਨਾਲ ਜਮਾਂ ਦੀ ਫਾਹੀ ਕੱਟੀ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "человек освобождается от петли смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31861,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਲੀਨੇ ਲੜਿ ਲਾਏ ॥",
          "roman": "kar kirpā līne laṛ lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਹਰ ਕਰ ਕੇ ਜਿਨ੍ਹਾਂ ਨੂੰ ਪ੍ਰਭੂ ਆਪਣੇ ਲੜ ਲਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тех, кого Бог по милости привлёк к Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31862,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਅਨਦੁ ਨਾਨਕ ਗੁਣ ਗਾਏ ॥੩॥੩੦॥੩੬॥",
          "roman": "sadā anand nānak guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ਕੇ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਹਨ ॥੩॥੩੦॥੩੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! они, воспевая Его качества, пребывают в вечной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2843,
      "rahao_verse_id": 31865,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31863,
          "is_rahao": true,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31864,
          "is_rahao": true,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਚਨ ਸਾਧ ਕੀ ਬਾਣੀ ॥",
          "roman": "amrit bachan sādh kī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਉਚਾਰੀ ਹੋਈ ਬਾਣੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਬਚਨ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Слова, произнесённые Гуру, — это амритные речи, дающие духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31865,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਜੋ ਜਪੈ ਤਿਸ ਕੀ ਗਤਿ ਹੋਵੈ ਹਰਿ ਹਰਿ ਨਾਮੁ ਨਿਤ ਰਸਨ ਬਖਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo jo japē tis kī gat hovē har har nām nit rasan bakhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਜੇਹੜਾ ਮਨੁੱਖ (ਇਸ ਬਾਣੀ ਨੂੰ) ਜਪਦਾ ਹੈ, ਉਸ ਦੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ, ਉਹ ਮਨੁੱਖ ਸਦਾ ਆਪਣੀ ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Кто бы ни повторял эту бани, тот достигает высокого духовного состояния и всегда произносит Имя Бога своим языком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31866,
          "is_rahao": false,
          "gurmukhi": "ਕਲੀ ਕਾਲ ਕੇ ਮਿਟੇ ਕਲੇਸਾ ॥",
          "roman": "kalī kāl ke miṭe kalesā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਕਲੇਸ਼ਾਂ-ਭਰੇ ਜੀਵਨ-ਸਮੇ ਦੇ ਸਾਰੇ ਕਲੇਸ਼ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Благодаря бани все страдания времени Кали исчезают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31867,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਨਾਮੁ ਮਨ ਮਹਿ ਪਰਵੇਸਾ ॥੧॥",
          "roman": "eko nām man meh parvesā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਬਾਣੀ ਦਾ ਸਦਕਾ) ਇਕ ਹਰਿ-ਨਾਮ ਹੀ ਮਨ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "потому что одно Имя Бога укореняется в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31868,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਧੂਰਿ ਮੁਖਿ ਮਸਤਕਿ ਲਾਈ ॥",
          "roman": "sādhū dhūr mukh mastak lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਆਪਣੇ) ਮੂੰਹ ਉਤੇ ਮੱਥੇ ਉਤੇ ਲਾ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто приложили пыль стоп Гуру к своему лицу и лбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31869,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੇ ਹਰਿ ਗੁਰ ਸਰਣਾਈ ॥੨॥੩੧॥੩੭॥",
          "roman": "nānak udhre har gur saranāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਝਗੜਿਆਂ ਕਲੇਸ਼ਾਂ ਤੋਂ) ਬਚ ਗਏ ॥੨॥੩੧॥੩੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! спасаются, прибегнув к прибежищу Гуру и Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2844,
      "rahao_verse_id": 31872,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31870,
          "is_rahao": true,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ਘਰੁ ੩ ॥",
          "roman": "sūhī mehlā 5 ghar 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31871,
          "is_rahao": true,
          "gurmukhi": "ਗੋਬਿੰਦਾ ਗੁਣ ਗਾਉ ਦਇਆਲਾ ॥",
          "roman": "gobindā guṇ gāo dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੋਬਿੰਦ! ਹੇ ਦਇਆਲ! ਮੈਂ (ਸਦਾ ਤੇਰੇ) ਗੁਣ ਗਾਂਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Гобинд, Милостивый! Я буду воспевать Твои качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31872,
          "is_rahao": true,
          "gurmukhi": "ਦਰਸਨੁ ਦੇਹੁ ਪੂਰਨ ਕਿਰਪਾਲਾ ॥ ਰਹਾਉ ॥",
          "roman": "darsan deh pūran kirpālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੂਰਨ ਕਿਰਪਾਲ! (ਮੈਨੂੰ ਆਪਣਾ) ਦਰਸਨ ਦੇਹ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "О Совершенно Милостивый! даруй мне Своё видение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31873,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਤੁਮ ਹੀ ਪ੍ਰਤਿਪਾਲਾ ॥",
          "roman": "kar kirpā tum hī pratipālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੋਬਿੰਦ! ਤੂੰ ਹੀ ਕਿਰਪਾ ਕਰ ਕੇ (ਅਸਾਂ ਜੀਵਾਂ ਦੀ) ਪਾਲਣਾ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Гобинд! Только Ты по милости поддерживаешь нас."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31874,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਸਭੁ ਤੁਮਰਾ ਮਾਲਾ ॥੧॥",
          "roman": "jīo piṇḍ sabh tumrā mālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਿੰਦ ਇਹ ਸਰੀਰ ਸਭ ਕੁਝ ਤੇਰੀ ਹੀ ਦਿੱਤੀ ਹੋਈ ਰਾਸਿ-ਪੂੰਜੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Эта душа и тело — всё это Твоя данная собственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31875,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਚਲੈ ਜਪਿ ਨਾਲਾ ॥",
          "roman": "amrit nām chalē jap nālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ (ਸਦਾ) ਜਪਿਆ ਕਰ (ਇਹੀ ਇਥੋਂ ਜੀਵਾਂ ਦੇ) ਨਾਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Поминай Имя, дающее жизнь — только оно идёт с человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31876,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਾਚੈ ਸੰਤ ਰਵਾਲਾ ॥੨॥੩੨॥੩੮॥",
          "roman": "nānak jāchē sant ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ (ਭੀ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹੈ। (ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹਰਿ-ਨਾਮ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ) ॥੨॥੩੨॥੩੮॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак также просит пыль стоп Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2845,
      "rahao_verse_id": 31881,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
