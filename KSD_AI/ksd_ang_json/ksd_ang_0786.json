{
  "ang": 786,
  "shabads": [
    {
      "shabad_id": 2918,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33355,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33356,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੀ ਸ੍ਰਿਸਟਿ ਸਾਜੀਅਨੁ ਬਹੁ ਭਿਤਿ ਸੰਸਾਰਾ ॥",
          "roman": "hukmī srisaṭ sājīan bah bhit sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Господь по Своему Хукаму создал эту вселенную, этот мир, многими видами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33357,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਹੁਕਮੁ ਨ ਜਾਪੀ ਕੇਤੜਾ ਸਚੇ ਅਲਖ ਅਪਾਰਾ ॥",
          "roman": "terā hukam na jāpī ketṛā sache alakh apārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Истинный, о Непостижимый, о Беспредельный Господь, невозможно понять, насколько велик и могуч Твой Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33358,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨਾ ਨੋ ਤੂ ਮੇਲਿ ਲੈਹਿ ਗੁਰ ਸਬਦਿ ਬੀਚਾਰਾ ॥",
          "roman": "iknā no tū mel lēh gur sabad bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторых существ Ты соединяешь с Собой, направляя их к размышлению над словом Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33359,
          "is_rahao": false,
          "gurmukhi": "ਸਚਿ ਰਤੇ ਸੇ ਨਿਰਮਲੇ ਹਉਮੈ ਤਜਿ ਵਿਕਾਰਾ ॥",
          "roman": "sach rate se nirmale haumē taj vikārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они окрашиваются в Истинного, становятся чистыми, оставив Хоумэ и пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33360,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂ ਮੇਲਹਿ ਸੋ ਤੁਧੁ ਮਿਲੈ ਸੋਈ ਸਚਿਆਰਾ ॥੨॥",
          "roman": "jis tū melah so tudh milē soī sachiārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, тот, кого Ты соединяешь с Собой, соединяется с Тобой; он и есть торговец Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2919,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33361,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Третий Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33362,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹਵੀਏ ਸੂਹਾ ਸਭੁ ਸੰਸਾਰੁ ਹੈ ਜਿਨ ਦੁਰਮਤਿ ਦੂਜਾ ਭਾਉ ॥",
          "roman": "sūhavīe sūhā sabh sansār hē jin durmat dūjā bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О любящая цвет сафлора, тем, у кого внутри дурной разум и любовь к двойственности, весь мир кажется ярко-привлекательным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33363,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਝੂਠੁ ਸਭੁ ਬਿਨਸਿ ਜਾਇ ਜਿਉ ਟਿਕੈ ਨ ਬਿਰਖ ਕੀ ਛਾਉ ॥",
          "roman": "khin mah jhūṭh sabh binas jāe jiu ṭikē na birakh kī chhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но этот ложный цвет исчезает в одно мгновение, как не удерживается тень дерева."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33364,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਲਾਲੋ ਲਾਲੁ ਹੈ ਜਿਉ ਰੰਗਿ ਮਜੀਠ ਸਚੜਾਉ ॥",
          "roman": "gurmukh lālo lāl hē jiu rang majīṭh sachṛāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Женщина-душа, обращённая к Гуру, получает полностью прочный красный цвет Имени, словно окрашена в стойкий цвет марены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33365,
          "is_rahao": false,
          "gurmukhi": "ਉਲਟੀ ਸਕਤਿ ਸਿਵੈ ਘਰਿ ਆਈ ਮਨਿ ਵਸਿਆ ਹਰਿ ਅੰਮ੍ਰਿਤ ਨਾਉ ॥",
          "roman": "ulaṭī sakat sivē ghar āī man vasiā har amrit nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Она отворачивается от майи и утверждается в доме Господа; в её уме поселяется нектарное Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33366,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਲਿਹਾਰੀ ਗੁਰ ਆਪਣੇ ਜਿਤੁ ਮਿਲਿਐ ਹਰਿ ਗੁਣ ਗਾਉ ॥੧॥",
          "roman": "nānak balihārī gur āpṇe jit miliai har guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: я в жертву своему Гуру, встретив которого поют качества Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2920,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33367,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahallā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Третий Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33368,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹਾ ਰੰਗੁ ਵਿਕਾਰੁ ਹੈ ਕੰਤੁ ਨ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "sūhā rang vikār hē kant na pāiā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Яркий цвет сафлора подобен пороку: попав в его притяжение, невозможно обрести Господа-Супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33369,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਲਹਦੇ ਬਿਲਮ ਨ ਹੋਵਈ ਰੰਡ ਬੈਠੀ ਦੂਜੈ ਭਾਇ ॥",
          "roman": "is lahde bilam na hovaī raṇḍ bēṭhī dūjē bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот яркий цвет порока сходит без промедления; душу, сидящую в любви к двойственности, считай овдовевшей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33370,
          "is_rahao": false,
          "gurmukhi": "ਮੁੰਧ ਇਆਣੀ ਦੁੰਮਣੀ ਸੂਹੈ ਵੇਸਿ ਲੋੁਭਾਇ ॥",
          "roman": "mundh iāṇī dummanī sūhē ves lubhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Женщина-душа, прельщённая ярким облачением майи, неразумна, и её ум всё время колеблется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33371,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਸਚੈ ਰੰਗੁ ਲਾਲੁ ਕਰਿ ਭੈ ਭਾਇ ਸੀਗਾਰੁ ਬਣਾਇ ॥",
          "roman": "sabad sachē rang lāl kar bhē bhāe sīgār baṇāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через истинное Слово она принимает прочный красный цвет Имени и украшает себя страхом Божиим и любовью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33372,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਦਾ ਸੋਹਾਗਣੀ ਜਿ ਚਲਨਿ ਸਤਿਗੁਰ ਭਾਇ ॥੨॥",
          "roman": "nānak sadā sohāgaṇī ji chalan satigur bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто идут в любви Сатгуру, навсегда остаются счастливыми супругами Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2921,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33373,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33374,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਉਪਾਇਅਨੁ ਆਪਿ ਕੀਮਤਿ ਪਾਈ ॥",
          "roman": "āpe āp upāian āp kīmat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Сам создал всех существ и Сам знает их цену."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33375,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਦਾ ਅੰਤੁ ਨ ਜਾਪਈ ਗੁਰ ਸਬਦਿ ਬੁਝਾਈ ॥",
          "roman": "tis dā ant na jāpaī gur sabad bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Предел Его не постигается; через слово Гуру Он Сам дарует понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33376,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹੁ ਗੁਬਾਰੁ ਹੈ ਦੂਜੈ ਭਰਮਾਈ ॥",
          "roman": "māiā moh gubār hē dūjē bharamāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Привязанность к майе — словно густая тьма; в этой тьме существо сбивается с истинного пути и блуждает в ином направлении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33377,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਠਉਰ ਨ ਪਾਇਨੑੀ ਫਿਰਿ ਆਵੈ ਜਾਈ ॥",
          "roman": "manmukh ṭhaur na pāinhī phir āvē jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идущие за своим умом не находят истинного места назначения и снова и снова приходят и уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33378,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਥੀਐ ਸਭ ਚਲੈ ਰਜਾਈ ॥੩॥",
          "roman": "jo tis bhāvē so thīē sabh chalē rajāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что угодно тому Господу, то и происходит; вся вселенная движется в Его воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2922,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33379,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Третий Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33380,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੈ ਵੇਸਿ ਕਾਮਣਿ ਕੁਲਖਣੀ ਜੋ ਪ੍ਰਭ ਛੋਡਿ ਪਰ ਪੁਰਖ ਧਰੇ ਪਿਆਰੁ ॥",
          "roman": "sūhē ves kāmaṇ kulakhṇī jo prabh chhoḍ par purakh dhare piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Женщина-душа, опьянённая ярким облачением майи, дурных признаков: забыв Господа-Супруга, она любит чужого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33381,
          "is_rahao": false,
          "gurmukhi": "ਓਸੁ ਸੀਲੁ ਨ ਸੰਜਮੁ ਸਦਾ ਝੂਠੁ ਬੋਲੈ ਮਨਮੁਖਿ ਕਰਮ ਖੁਆਰੁ ॥",
          "roman": "os sīl na sanjam sadā jhūṭh bolē manmukh karam khuār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У неё нет ни доброго поведения, ни сдержанной жизни; она всегда говорит ложь и, следуя самовольным делам, терпит унижение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33382,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪੂਰਬਿ ਹੋਵੈ ਲਿਖਿਆ ਤਿਸੁ ਸਤਿਗੁਰੁ ਮਿਲੈ ਭਤਾਰੁ ॥",
          "roman": "jis pūrab hovē likhiā tis satigur milē bhatār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, у кого с самого начала записана такая судьба, встречает Сатгуру как защитника."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33383,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹਾ ਵੇਸੁ ਸਭੁ ਉਤਾਰਿ ਧਰੇ ਗਲਿ ਪਹਿਰੈ ਖਿਮਾ ਸੀਗਾਰੁ ॥",
          "roman": "sūhā ves sabh utār dhare gal pahirē khimā sīgār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда она снимает всё яркое облачение майи и надевает на шею украшение терпеливого прощения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33384,
          "is_rahao": false,
          "gurmukhi": "ਪੇਈਐ ਸਾਹੁਰੈ ਬਹੁ ਸੋਭਾ ਪਾਏ ਤਿਸੁ ਪੂਜ ਕਰੇ ਸਭੁ ਸੈਸਾਰੁ ॥",
          "roman": "peīē sāhurē bah sobhā pāe tis pūj kare sabh sēsār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И в этом мире, и в мире ином она получает великую славу; весь мир оказывает ей почтение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33385,
          "is_rahao": false,
          "gurmukhi": "ਓਹ ਰਲਾਈ ਕਿਸੈ ਦੀ ਨਾ ਰਲੈ ਜਿਸੁ ਰਾਵੇ ਸਿਰਜਨਹਾਰੁ ॥",
          "roman": "oh ralāī kisē dī nā ralē jis rāve sirjanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та, кого наслаждает Творец-Супруг, не смешивается ни с кем иным; её жизнь становится совершенно особой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33386,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਦਾ ਸੁਹਾਗਣੀ ਜਿਸੁ ਅਵਿਨਾਸੀ ਪੁਰਖੁ ਭਰਤਾਰੁ ॥੧॥",
          "roman": "nānak gurmukh sadā suhāgaṇī jis avināsī purakh bhartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, та гурмукх-женщина-душа, у которой Бессмертный Пурукх — супруг, всегда остаётся счастливой супругой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2923,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33387,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33388,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹਾ ਰੰਗੁ ਸੁਪਨੈ ਨਿਸੀ ਬਿਨੁ ਤਾਗੇ ਗਲਿ ਹਾਰੁ ॥",
          "roman": "sūhā rang supnē nisī bin tāge gal hār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Яркий цвет майи подобен ночному сну, подобен ожерелью на шее без нити."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33389,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਰੰਗੁ ਮਜੀਠ ਕਾ ਗੁਰਮੁਖਿ ਬ੍ਰਹਮ ਬੀਚਾਰੁ ॥",
          "roman": "sachā rang majīṭh kā gurmukh brahm bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Размышление о Брахме, слова хвалы Господу в обращённости к Гуру, подобны истинному, стойкому цвету марены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33390,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰੇਮ ਮਹਾ ਰਸੀ ਸਭਿ ਬੁਰਿਆਈਆ ਛਾਰੁ ॥੨॥",
          "roman": "nānak prem mahā rasī sabh buriāīā chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у женщины-души, пропитанной великим соком любви к Господу, все дурные качества сгорают в пепел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2924,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33391,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33392,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਜਗੁ ਆਪਿ ਉਪਾਇਓਨੁ ਕਰਿ ਚੋਜ ਵਿਡਾਨੁ ॥",
          "roman": "ih jag āp upāion kar choj viḍān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершая удивительные игры, Господь Сам создал этот мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33393,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਧਾਤੁ ਵਿਚਿ ਪਾਈਅਨੁ ਮੋਹੁ ਝੂਠੁ ਗੁਮਾਨੁ ॥",
          "roman": "panch dhāt vich pāīan moh jhūṭh gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В него Он вложил пять элементов, которые стали основой привязанности, лжи и гордыни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33394,
          "is_rahao": false,
          "gurmukhi": "ਆਵੈ ਜਾਇ ਭਵਾਈਐ ਮਨਮੁਖੁ ਅਗਿਆਨੁ ॥",
          "roman": "āvē jāe bhavāīē manmukh agiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Невежественный самовольный человек, запутавшись в них, блуждает и снова приходит и уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33395,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨਾ ਆਪਿ ਬੁਝਾਇਓਨੁ ਗੁਰਮੁਖਿ ਹਰਿ ਗਿਆਨੁ ॥",
          "roman": "iknā āp bujhāion gurmukh har giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторым существам Господь Сам, сделав их гурмукхами, дал понять знание о Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33396,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਖਜਾਨਾ ਬਖਸਿਓਨੁ ਹਰਿ ਨਾਮੁ ਨਿਧਾਨੁ ॥੪॥",
          "roman": "bhagat khajānā bakhsiōn har nām nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он даровал им сокровище бхагати и клад Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2925,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33397,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Третий Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33398,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹਵੀਏ ਸੂਹਾ ਵੇਸੁ ਛਡਿ ਤੂ ਤਾ ਪਿਰ ਲਗੀ ਪਿਆਰੁ ॥",
          "roman": "sūhavīe sūhā ves chhaḍ tū tā pir lagī piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О любящая яркий цвет, оставь это яркое облачение — тогда в тебе возникнет любовь к Возлюбленному-Супругу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
