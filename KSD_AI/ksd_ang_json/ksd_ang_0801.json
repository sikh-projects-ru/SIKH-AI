          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34068,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਨਿਧਾਨ ਪ੍ਰੀਤਮ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "sukh nidhān prītam prabh mērē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੁਖਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! ਹੇ ਮੇਰੇ ਪ੍ਰੀਤਮ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный Господь, сокровище счастья!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
