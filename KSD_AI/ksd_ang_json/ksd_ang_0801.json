{
  "ang": 801,
  "shabads": [
    {
      "shabad_id": 3006,
      "rahao_verse_id": 34016,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34014,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਭਰਿਪੁਰੇ ਰਹਿਆ ॥",
          "roman": "har bharipure rahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਸਾਰੇ ਜਗਤ ਵਿਚ) ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34015,
          "is_rahao": true,
          "gurmukhi": "ਜਲਿ ਥਲੇ ਰਾਮ ਨਾਮੁ ॥",
          "roman": "jal thale rām nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੋ ਪਾਣੀ ਵਿਚ ਹੈ, ਜੋ ਧਰਤੀ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он присутствует и в воде, и на земле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34016,
          "is_rahao": true,
          "gurmukhi": "ਨਿਤ ਗਾਈਐ ਹਰਿ ਦੂਖ ਬਿਸਾਰਨੋ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nit gāīai har dūkh bisārano",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਜੀਵਾਂ ਦੇ) ਸਾਰੇ ਦੁੱਖ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਸ ਹਰੀ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਸਦਾ ਗਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Всегда следует воспевать Его, уничтожающего все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34017,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਆ ਹੈ ਸਫਲ ਜਨਮੁ ਹਮਾਰਾ ॥",
          "roman": "har kīā hē safal janam hamārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਨੇ ਮੇਰੀ ਜ਼ਿੰਦਗੀ ਕਾਮਯਾਬ ਬਣਾ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог сделал мою жизнь успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34018,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਪਿਆ ਹਰਿ ਦੂਖ ਬਿਸਾਰਨਹਾਰਾ ॥",
          "roman": "har japiā har dūkh bisārnahārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਲੱਗ ਪਿਆ ਹਾਂ, ਜੋ ਸਾਰੇ ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я начал повторять Имя Бога, устраняющего все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34019,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਭੇਟਿਆ ਹੈ ਮੁਕਤਿ ਦਾਤਾ ॥",
          "roman": "gur bheṭiā hē mukt dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਦਿਵਾਣ ਵਾਲਾ ਗੁਰੂ ਮੈਨੂੰ ਮਿਲ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Я встретил Гуру — дарующего освобождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34020,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਈ ਹਮਾਰੀ ਸਫਲ ਜਾਤਾ ॥",
          "roman": "har kīī hamārī safal jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਕਰਕੇ) ਪਰਮਾਤਮਾ ਨੇ ਮੇਰੀ ਜੀਵਨ-ਜਾਤ੍ਰਾ ਕਾਮਯਾਬ ਕਰ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому Бог сделал мою жизнь успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34021,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸੰਗਤੀ ਗੁਨ ਗਾਵਨੋ ॥੧॥",
          "roman": "mil sangatī guṇ gāvanō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ) ਮੈਂ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь я, пребывая в святом собрании, пою хвалу Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34022,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਰਾਮ ਨਾਮ ਕਰਿ ਆਸਾ ॥",
          "roman": "man rām nām kar āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਉਤੇ ਹੀ ਡੋਰੀ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Возложи надежду только на Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34023,
          "is_rahao": false,
          "gurmukhi": "ਭਾਉ ਦੂਜਾ ਬਿਨਸਿ ਬਿਨਾਸਾ ॥",
          "roman": "bhāu dūjā binas bināsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮਾਇਆ ਦੇ ਮੋਹ ਨੂੰ ਪੂਰਨ ਤੌਰ ਤੇ (ਅੰਦਰੋਂ) ਮੁਕਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога полностью уничтожает привязанность к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34024,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਿ ਆਸਾ ਹੋਇ ਨਿਰਾਸੀ ॥",
          "roman": "vich āsā hoi nirāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਦੁਨੀਆ ਦੇ ਕੰਮ-ਕਾਰ ਵਿਚ ਰਹਿੰਦਾ ਹੋਇਆ ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто живя в мире, остаётся непривязанным к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34025,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਮਿਲਿਆ ਹਰਿ ਪਾਸੀ ॥",
          "roman": "so jan miliā har pāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਮਿਲਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот пребывает рядом с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34026,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਰਾਮ ਨਾਮ ਗੁਨ ਗਾਵਨੋ ॥",
          "roman": "koī rām nām guṇ gāvanō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто воспевает качества Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34027,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਨਾਨਕੁ ਤਿਸੁ ਪਗਿ ਲਾਵਨੋ ॥੨॥੧॥੭॥੪॥੬॥੭॥੧੭॥",
          "roman": "jan nānak tis pag lāvanō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਉਸ ਦੇ ਪੈਰੀਂ ਲੱਗਦਾ ਹੈ ॥੨॥੧॥੭॥੪॥੬॥੭॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "слуга Нанак склоняется к его стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3007,
      "rahao_verse_id": 34035,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34028,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ਚਉਪਦੇ ਘਰੁ ੧",
          "roman": "rāg bilāval mehlā 5 chaupadē ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਿਲਾਵਲੁ, ਘਰ ੧ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਚਾਰ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Билавал, в доме 1, четырехстишная бани Гуру Арджандева Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34029,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуркх один и постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34030,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰੀ ਆਵੈ ਤਿਸੁ ਸਿਉ ਮੋਹੁ ॥",
          "roman": "nadrī āvē tis siu moh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ! ਜੋ ਕੁਝ ਅੱਖਾਂ ਨਾਲ ਦਿੱਸ ਰਿਹਾ ਹੈ, ਮੇਰਾ ਉਸ ਨਾਲ ਸਦਾ ਮੋਹ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Вечный! всё, что видимо глазами, с тем у меня сохраняется привязанность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34031,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਮਿਲੀਐ ਪ੍ਰਭ ਅਬਿਨਾਸੀ ਤੋਹਿ ॥",
          "roman": "kiu milīai prabh abināsī toh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਤੂੰ ਇਹਨਾਂ ਅੱਖਾਂ ਨਾਲ ਦਿੱਸਦਾ ਨਹੀਂ) ਤੈਨੂੰ ਮੈਂ ਕਿਸ ਤਰ੍ਹਾਂ ਮਿਲਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "но Ты глазами не видим — как же мне встретиться с Тобой?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34032,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਮਾਰਗਿ ਪਾਵਹੁ ॥",
          "roman": "kar kirpā moh mārag pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਕਿਰਪਾ ਕਰ ਕੇ ਮੈਨੂੰ (ਜੀਵਨ ਦੇ ਸਹੀ) ਰਸਤੇ ਉਤੇ ਤੋਰ,"
            },
            "sahib_singh_ru": {
              "main": "Смилуйся и поставь меня на правильный путь жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34033,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕੈ ਅੰਚਲਿ ਲਾਵਹੁ ॥੧॥",
          "roman": "sādhsangat kē añchal lāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਸਾਧ ਸੰਗਤਿ ਦੇ ਲੜ ਨਾਲ ਲਾ ਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "присоедини меня к покрову Садхсангата."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34034,
          "is_rahao": true,
          "gurmukhi": "ਕਿਉ ਤਰੀਐ ਬਿਖਿਆ ਸੰਸਾਰੁ ॥",
          "roman": "kiu tarīai bikhiā sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਇਹ ਸੰਸਾਰ ਮਾਇਆ (ਦੇ ਮੋਹ ਦੀਆਂ ਲਹਿਰਾਂ ਨਾਲ ਭਰਪੂਰ) ਹੈ (ਇਸ ਵਿਚੋਂ) ਕਿਵੇਂ ਪਾਰ ਲੰਘਿਆ ਜਾਏ?"
            },
            "sahib_singh_ru": {
              "main": "Как переплыть этот мир, наполненный волнами майи?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34035,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਬੋਹਿਥੁ ਪਾਵੈ ਪਾਰਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "satigur bohith pāvē pār rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉੱਤਰ-) ਗੁਰੂ ਜਹਾਜ਼ ਹੈ (ਗੁਰੂ ਇਸ ਸਮੁੰਦਰ ਵਿਚੋਂ) ਪਾਰ ਲੰਘਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру — это корабль, он переправляет через океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34036,
          "is_rahao": false,
          "gurmukhi": "ਪਵਨ ਝੁਲਾਰੇ ਮਾਇਆ ਦੇਇ ॥",
          "roman": "pavan jhulārē māiā dēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹਵਾ (ਵਾਂਗ) ਮਾਇਆ (ਜੀਵਾਂ ਨੂੰ) ਹੁਲਾਰੇ ਦੇਂਦੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Майя, словно ветер, всё время раскачивает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34037,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਭਗਤ ਸਦਾ ਥਿਰੁ ਸੇਇ ॥",
          "roman": "har kē bhagat sadā thir sēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਹੁਲਾਰਿਆਂ ਦੇ ਸਾਹਮਣੇ ਸਿਰਫ਼) ਉਹੀ ਬੰਦੇ ਅਡੋਲ ਰਹਿੰਦੇ ਹਨ ਜੇਹੜੇ ਸਦਾ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и только те остаются устойчивыми, кто предан Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34038,
          "is_rahao": false,
          "gurmukhi": "ਹਰਖ ਸੋਗ ਤੇ ਰਹਹਿ ਨਿਰਾਰਾ ॥",
          "roman": "harakh sog tē rahe nirārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਖ਼ੁਸ਼ੀ ਗ਼ਮੀ (ਦੇ ਹੁਲਾਰਿਆਂ) ਤੋਂ ਵੱਖਰੇ (ਨਿਰਲੇਪ) ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Они остаются вне радости и печали,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34039,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰ ਊਪਰਿ ਆਪਿ ਗੁਰੂ ਰਖਵਾਰਾ ॥੨॥",
          "roman": "sir ūpar āp gurū rakhvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਸਿਰ ਉਤੇ ਗੁਰੂ ਆਪ ਰਾਖੀ ਕਰਨ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "над их головой сам Гуру — защитник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34040,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇਆ ਵੇੜੁ ਮਾਇਆ ਸਰਬ ਭੁਇਅੰਗਾ ॥",
          "roman": "pāiā veṛ māiā sarab bhuiaṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸੱਪ (ਵਾਂਗ) ਮਾਇਆ ਨੇ ਸਾਰੇ ਜੀਵਾਂ ਦੇ ਦੁਆਲੇ ਵਲੇਵਾਂ ਪਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Майя, словно змея, обвила всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34041,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਪਚੇ ਦੀਪਕ ਦੇਖਿ ਪਤੰਗਾ ॥",
          "roman": "haumē pachē dīpak dēkh pataṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਹਉਮੈ (ਦੀ ਅੱਗ) ਵਿਚ ਸੜੇ ਪਏ ਹਨ ਜਿਵੇਂ ਦੀਵਿਆਂ ਨੂੰ ਵੇਖ ਕੇ ਪਤੰਗੇ ਸੜਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "живые существа сгорают в эго, как мотыльки в огне лампы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34042,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸੀਗਾਰ ਕਰੇ ਨਹੀ ਪਾਵੈ ॥",
          "roman": "sagal sīgār karē nahī pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ-ਵੇੜ੍ਹਿਆ ਜੀਵ ਭਾਵੇਂ ਬਾਹਰਲੇ ਭੇਖ ਆਦਿਕ ਦੇ) ਸਾਰੇ ਸਿੰਗਾਰ ਕਰਦਾ ਰਹੇ, (ਫਿਰ ਭੀ ਉਹ) ਪਰਮਾਤਮਾ ਨੂੰ ਮਿਲ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Даже совершая все украшения и внешние обряды, не достигают Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34043,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਹੋਇ ਕ੍ਰਿਪਾਲੁ ਤਾ ਗੁਰੂ ਮਿਲਾਵੈ ॥੩॥",
          "roman": "jā hoi kripāl tā gurū milāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪਰਮਾਤਮਾ ਆਪ (ਜੀਵ ਉੱਤੇ) ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ, ਤਾਂ (ਉਸ ਨੂੰ) ਗੁਰੂ ਮਿਲਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "когда же Бог становится милостивым — Он приводит к Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34044,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਫਿਰਉ ਉਦਾਸੀ ਮੈ ਇਕੁ ਰਤਨੁ ਦਸਾਇਆ ॥",
          "roman": "hau phirau udāsī mē ik ratan dasāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ (ਭੀ) ਨਾਮ-ਰਤਨ ਨੂੰ ਭਾਲਦੀ ਭਾਲਦੀ (ਬਾਹਰ) ਉਦਾਸ ਫਿਰ ਰਹੀ ਸਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я скитался в печали, ища драгоценность Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34045,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮੋਲਕੁ ਹੀਰਾ ਮਿਲੈ ਨ ਉਪਾਇਆ ॥",
          "roman": "nirmolak hīrā milē na upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਹ ਨਾਮ-ਹੀਰਾ ਅਮੋਲਕ ਹੈ ਉਹ (ਬਾਹਰਲੇ ਭੇਖ ਆਦਿਕ) ਉਪਾਵਾਂ ਨਾਲ ਨਹੀਂ ਮਿਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "но этот бесценный алмаз не достигается внешними средствами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34046,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਮੰਦਰੁ ਤਿਸੁ ਮਹਿ ਲਾਲੁ ॥",
          "roman": "har kā mandar tis meh lāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸਰੀਰ ਹੀ) ਪਰਮਾਤਮਾ ਦੇ ਰਹਿਣ ਦਾ ਘਰ ਹੈ, ਇਸ (ਸਰੀਰ) ਵਿਚ ਉਹ ਲਾਲ ਵੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это тело — храм Бога, в нём пребывает драгоценный Лал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34047,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਖੋਲਿਆ ਪੜਦਾ ਦੇਖਿ ਭਈ ਨਿਹਾਲੁ ॥੪॥",
          "roman": "gur kholiā paṛdā dēkh bhaī nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰੂ ਨੇ (ਮੇਰੇ ਅੰਦਰੋਂ ਭਰਮ-ਭੁਲੇਖੇ ਦਾ) ਪਰਦਾ ਖੋਲ੍ਹ ਦਿੱਤਾ, ਮੈਂ (ਉਸ ਲਾਲ ਨੂੰ ਆਪਣੇ ਅੰਦਰ ਹੀ) ਵੇਖ ਕੇ ਲੂੰ ਲੂੰ ਖਿੜ ਗਈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Гуру открыл завесу, я увидел Его внутри и возрадовался."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34048,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਚਾਖਿਆ ਤਿਸੁ ਆਇਆ ਸਾਦੁ ॥",
          "roman": "jin chākhiā tis āiā sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੇ (ਨਾਮ-ਰਸ) ਚੱਖਿਆ ਹੈ, ਉਸ ਨੂੰ (ਹੀ) ਸੁਆਦ ਆਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только тот вкусил сладость, кто попробовал Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34049,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਗੂੰਗਾ ਮਨ ਮਹਿ ਬਿਸਮਾਦੁ ॥",
          "roman": "jio gūṅgā man meh bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਹ ਇਹ ਸੁਆਦ ਦੱਸ ਨਹੀਂ ਸਕਦਾ) ਜਿਵੇਂ ਗੁੰਗਾ (ਕੋਈ ਸੁਆਦਲਾ ਪਦਾਰਥ ਖਾ ਕੇ ਹੋਰਨਾਂ ਨੂੰ ਦੱਸ ਨਹੀਂ ਸਕਦਾ ਉਂਞ ਆਪਣੇ) ਮਨ ਵਿਚ ਬਹੁਤ ਗਦ-ਗਦ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "как немой — испытывает внутри восторг, но не может выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34050,
          "is_rahao": false,
          "gurmukhi": "ਆਨਦ ਰੂਪੁ ਸਭੁ ਨਦਰੀ ਆਇਆ ॥",
          "roman": "ānand rūp sabh nadrī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਉਹ ਆਨੰਦ ਦਾ ਸੋਮਾ ਪ੍ਰਭੂ ਹਰ ਥਾਂ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек видит Бога как источник блаженства повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34051,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਹਰਿ ਗੁਣ ਆਖਿ ਸਮਾਇਆ ॥੫॥੧॥",
          "roman": "jan nānak har gun ākh samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! ਜੇਹੜਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ਗਾ ਕੇ (ਪ੍ਰਭੂ ਵਿਚ) ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੫॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! воспевая качества Бога, он сливается с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3008,
      "rahao_verse_id": 34057,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34052,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34053,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਕੀਏ ਗੁਰਦੇਵ ॥",
          "roman": "sarab kalyān kīe gurdēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਉਸ ਨੂੰ ਸਾਰੇ ਸੁਖ ਦੇ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру дарует все блага,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34054,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕੁ ਅਪਨੀ ਲਾਇਓ ਸੇਵ ॥",
          "roman": "sēvak apnī lāio sēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸੇਵਕ ਨੂੰ ਪ੍ਰਭੂ ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тому слуге, которого Бог вовлекает в служение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34055,
          "is_rahao": false,
          "gurmukhi": "ਬਿਘਨੁ ਨ ਲਾਗੈ ਜਪਿ ਅਲਖ ਅਭੇਵ ॥੧॥",
          "roman": "bighan na lāgē jap alakh abhev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਲੱਖ ਅਤੇ ਅਭੇਵ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ (ਉਸ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਦੇ ਰਸਤੇ ਵਿਚ ਵਿਕਾਰਾਂ ਦੀ ਕੋਈ) ਰੁਕਾਵਟ ਨਹੀਂ ਪੈਂਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя непостижимого Бога, препятствия не возникают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34056,
          "is_rahao": true,
          "gurmukhi": "ਧਰਤਿ ਪੁਨੀਤ ਭਈ ਗੁਨ ਗਾਏ ॥",
          "roman": "dharat punīt bhaī gun gāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ, ਉਸ ਦਾ ਹਿਰਦਾ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сердце очищается, когда поют качества Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34057,
          "is_rahao": true,
          "gurmukhi": "ਦੁਰਤੁ ਗਇਆ ਹਰਿ ਨਾਮੁ ਧਿਆਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "durat gaiā har nām dhiāē rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ (ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚੋਂ) ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "грехи уходят при медитации на Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34058,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨੀ ਥਾਂਈ ਰਵਿਆ ਆਪਿ ॥",
          "roman": "sabhni thāī raviā āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈ, ਉਸ ਨੂੰ) ਉਹ ਪ੍ਰਭੂ ਹੀ ਹਰ ਥਾਂ ਮੌਜੂਦ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он видит Бога присутствующим повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34059,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਜੁਗਾਦਿ ਜਾ ਕਾ ਵਡ ਪਰਤਾਪੁ ॥",
          "roman": "ād jugād jā kā vaḍ partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਤੇਜ-ਪਰਤਾਪ ਸ਼ੁਰੂ ਤੋਂ ਜੁਗਾਂ ਦੇ ਸ਼ੁਰੂ ਤੋਂ ਹੀ ਬੜਾ ਚਲਿਆ ਆ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чья слава распространяется с начала времён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34060,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਨ ਹੋਇ ਸੰਤਾਪੁ ॥੨॥",
          "roman": "gur parsād na hoi santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру страдания не касаются его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34061,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਨ ਲਗੇ ਮਨਿ ਮੀਠੇ ॥",
          "roman": "gur kē charan lagē man mīṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੇ (ਸੋਹਣੇ) ਚਰਨ (ਆਪਣੇ) ਮਨ ਵਿਚ ਪਿਆਰੇ ਲੱਗਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кому дороги стопы Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34062,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਬਿਘਨ ਹੋਇ ਸਭ ਥਾਂਈ ਵੂਠੇ ॥",
          "roman": "nirbighan hoi sabh thāī vūṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਿੱਥੇ ਭੀ ਵੱਸਦਾ ਹੈ ਹਰ ਥਾਂ (ਵਿਕਾਰਾਂ ਦੀ) ਰੁਕਾਵਟ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "везде живёт без препятствий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34063,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਸੁਖ ਪਾਏ ਸਤਿਗੁਰ ਤੂਠੇ ॥੩॥",
          "roman": "sabh sukh pāē satigur tūṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ, ਤੇ, ਉਹ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Гуру доволен, он получает все блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34064,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭ ਭਏ ਰਖਵਾਲੇ ॥",
          "roman": "pārbrahm prabh bhaē rakhvālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ-ਪਾਰਬ੍ਰਹਮ ਜੀ ਸਦਾ ਆਪਣੇ ਸੇਵਕਾਂ ਦੇ ਰਾਖੇ ਬਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Парабрахман становится защитником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34065,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਕਿਥੈ ਦੀਸਹਿ ਨਾਲੇ ॥",
          "roman": "jithē kithē dīsah nālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕਾਂ ਨੂੰ ਪ੍ਰਭੂ ਜੀ ਹਰ ਥਾਂ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਦਿੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Он видим рядом повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34066,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਖਸਮਿ ਪ੍ਰਤਿਪਾਲੇ ॥੪॥੨॥",
          "roman": "nānak dās khasam pratipālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਖਸਮ-ਪ੍ਰਭੂ ਨੇ ਸਦਾ ਹੀ ਆਪਣੇ ਦਾਸਾਂ ਦੀ ਰੱਖਿਆ ਕੀਤੀ ਹੈ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Господь всегда защищает Своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
