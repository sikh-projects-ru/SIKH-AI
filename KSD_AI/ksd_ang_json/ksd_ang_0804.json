          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34180,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਵਡਭਾਗੀ ਪਾਈਐ ॥",
          "roman": "gur pūrā vaḍbhāgī pāīai.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Гуру встречается только по великой судьбе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34181,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਹਰਿ ਨਾਮੁ ਧਿਆਈਐ ॥੧॥",
          "roman": "mil sādhū har nām dhiāīai. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, можно медитировать на Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34182,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭ ਤੇਰੀ ਸਰਨਾ ॥",
          "roman": "pārbrahm prabh terī sarnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Парабрахм, о Господь, я пришёл в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34183,
          "is_rahao": true,
          "gurmukhi": "ਕਿਲਬਿਖ ਕਾਟੈ ਭਜੁ ਗੁਰ ਕੇ ਚਰਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kilbikh kāṭē bhaj gur ke charnā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прими в сердце опору у стоп Гуру: Гуру срезает все грехи. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34184,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰਿ ਕਰਮ ਸਭਿ ਲੋਕਾਚਾਰ ॥",
          "roman": "avar karam sabh lokāchār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без прибежища Гуру все прочие дела — лишь внешний обычай мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34185,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਾਧੂ ਸੰਗਿ ਹੋਇ ਉਧਾਰ ॥੨॥",
          "roman": "mil sādhū sang hoe udhār. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь соединившись с сангатом Гуру, можно быть переправленным через мир-океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34186,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਮ੍ਰਿਤਿ ਸਾਸਤ ਬੇਦ ਬੀਚਾਰੇ ॥",
          "roman": "siṃmrit sāstat bed bīchāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я рассмотрел все шастры, смрити и Веды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34187,
          "is_rahao": false,
          "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਜਿਤੁ ਪਾਰਿ ਉਤਾਰੇ ॥੩॥",
          "roman": "japīai nām jit pār utāre. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следует повторять Имя: через это Хар-Нам Гуру переправляет на другой берег."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34188,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਕਿਰਪਾ ਕਰੀਐ ॥",
          "roman": "jan nānak kau prabh kirpā karīai.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, прояви милость к Твоему слуге Нанаку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34189,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਧੂਰਿ ਮਿਲੈ ਨਿਸਤਰੀਐ ॥੪॥੬॥੧੧॥",
          "roman": "sādhū dhūr milē nistarīē. ||4||6||11||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть мне достанется пыль стоп Гуру; только милостью Гуру можно переправиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3018,
      "rahao_verse_id": 34194,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34190,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34191,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਿਦੇ ਮਹਿ ਚੀਨਾ ॥",
          "roman": "gur kā sabad ride meh chīnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те счастливцы, кто распознал и осмыслил Слово Гуру в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34192,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰਨ ਆਸੀਨਾ ॥੧॥",
          "roman": "sagal manorath pūran āsīnā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все их желания исполнились, все их надежды достигли завершения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34193,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਕਾ ਮੁਖੁ ਊਜਲੁ ਕੀਨਾ ॥",
          "roman": "sant janā kā mukh ūjal kīnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сделал лик святых людей сияющим в этом мире и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34194,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪੁਨਾ ਨਾਮੁ ਦੀਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā apunā nām dīnā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Проявив милость, Он даровал им Своё Имя. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34195,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਕੂਪ ਤੇ ਕਰੁ ਗਹਿ ਲੀਨਾ ॥",
          "roman": "andh kūp te kar geh līnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь взял их за руку и вывел из тёмного колодца привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34196,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਜਗਤਿ ਪ੍ਰਗਟੀਨਾ ॥੨॥",
          "roman": "jē jē kār jagat pragṭīnā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Их великая слава распространилась по всему миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34197,
          "is_rahao": false,
          "gurmukhi": "ਨੀਚਾ ਤੇ ਊਚ ਊਨ ਪੂਰੀਨਾ ॥",
          "roman": "nīchā te ūch ūn pūrīnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они из низких стали высокими, а пустые прежде наполнились добродетелями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34198,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਮਹਾ ਰਸੁ ਲੀਨਾ ॥੩॥",
          "roman": "amrit nām mahā ras līnā. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они начали вкушать животворящее и велико-сладостное Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34199,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਨਿਰਮਲ ਪਾਪ ਜਲਿ ਖੀਨਾ ॥",
          "roman": "man tan nirmal pāp jal khīnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Их ум и тело стали чистыми, а все их грехи сгорели и исчезли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34200,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭ ਭਏ ਪ੍ਰਸੀਨਾ ॥੪॥੭॥੧੨॥",
          "roman": "kah nānak prabh bhae prasīnā. ||4||7||12||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: это происходит с теми, на кого Господь стал доволен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3019,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34201,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34202,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪਾਈਅਹਿ ਮੀਤਾ ॥",
          "roman": "sagal manorath pāīah mītā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг, все желания обретаются и исполняются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
