{
  "ang": 804,
  "shabads": [
    {
      "shabad_id": 3014,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34151,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਕ੍ਰੋਧਿ ਲੋਭਿ ਮੋਹਿ ਮਨੁ ਲੀਨਾ ॥",
          "roman": "kām krodh lobh moh man līnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ум был поглощён похотью, гневом, жадностью и привязанностью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34152,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਮੁਕਤਿ ਗੁਰਿ ਕੀਨਾ ॥੨॥",
          "roman": "bandhan kāṭ mukt gur kīnā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру разрубил эти узы и сделал меня освобождённым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34153,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਸੁਖ ਕਰਤ ਜਨਮਿ ਫੁਨਿ ਮੂਆ ॥",
          "roman": "dukh sukh karat janam phun mūā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Переживая страдание и радость, человек снова рождался и умирал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34154,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰਿ ਆਸ੍ਰਮੁ ਦੀਆ ॥੩॥",
          "roman": "charan kamal gur āsram dīā. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру дал мне прибежище у лотосных стоп Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34155,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਸਾਗਰ ਬੂਡਤ ਸੰਸਾਰਾ ॥",
          "roman": "agan sāgar būḍat sansārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мир тонет в огненном океане."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34156,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਾਹ ਪਕਰਿ ਸਤਿਗੁਰਿ ਨਿਸਤਾਰਾ ॥੪॥੩॥੮॥",
          "roman": "nānak bāh pakar satgur nistārā. ||4||3||8||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Сатгуру схватил меня за руку и переправил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3015,
      "rahao_verse_id": 34161,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34157,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34158,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਧਨੁ ਅਰਪਉ ਸਭੁ ਅਪਨਾ ॥",
          "roman": "tan man dhan arpau sabh apnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я готов отдать своё тело, свой ум, своё богатство — всё своё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34159,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਸੁ ਮਤਿ ਜਿਤੁ ਹਰਿ ਹਰਿ ਜਪਨਾ ॥੧॥",
          "roman": "kavan su mat jit har har japnā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какая это добрая мудрость, благодаря которой можно повторять Имя Хар Хар?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34160,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਆਸਾ ਆਇਓ ਪ੍ਰਭ ਮਾਗਨਿ ॥",
          "roman": "kar āsā āio prabh māgan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, с надеждой я пришёл просить у Твоих дверей дар Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34161,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮੑ ਪੇਖਤ ਸੋਭਾ ਮੇਰੈ ਆਗਨਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tumh pekhat sobhā merē āgan. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда я вижу Тебя, в моём сердечном дворе возникает радостное сияние. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34162,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੁਗਤਿ ਕਰਿ ਬਹੁਤੁ ਬੀਚਾਰਉ ॥",
          "roman": "anik jugat kar bahut bīchārau.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я рассматриваю многие способы и долго размышляю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34163,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਇਸੁ ਮਨਹਿ ਉਧਾਰਉ ॥੨॥",
          "roman": "sādhsang is maneh udhārau. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И понимаю, что только в сангате гурмукхов могу спасти этот ум от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34164,
          "is_rahao": false,
          "gurmukhi": "ਮਤਿ ਬੁਧਿ ਸੁਰਤਿ ਨਾਹੀ ਚਤੁਰਾਈ ॥",
          "roman": "mat budh surat nāhī chaturāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ни умением, ни рассудком, ни сосредоточением, ни какой-либо хитростью Господа не обрести."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34165,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਮਿਲੀਐ ਜਾ ਲਏ ਮਿਲਾਈ ॥੩॥",
          "roman": "tā milīai jā lae milāī. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С Ним можно соединиться лишь тогда, когда Он сам соединяет с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34166,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨ ਸੰਤੋਖੇ ਪ੍ਰਭ ਦਰਸਨੁ ਪਾਇਆ ॥",
          "roman": "nēn santokhe prabh darsan pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто получил даршан Господа, чьи глаза насытились и освободились от жажды майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34167,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਫਲੁ ਸੋ ਆਇਆ ॥੪॥੪॥੯॥",
          "roman": "kah nānak safal so āiā. ||4||4||9||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: благословен и плодотворен приход такого человека в мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3016,
      "rahao_verse_id": 34172,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34168,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34169,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਪਿਤਾ ਸੁਤ ਸਾਥਿ ਨ ਮਾਇਆ ॥",
          "roman": "māt pitā sut sāth na māiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мать, отец, сын и майя не могут быть вечными спутниками человека и не помогают в страдании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34170,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸਭੁ ਦੂਖੁ ਮਿਟਾਇਆ ॥੧॥",
          "roman": "sādhsang sabh dūkh miṭāiā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая в сангате Гуру, можно устранить всё страдание и мучение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34171,
          "is_rahao": true,
          "gurmukhi": "ਰਵਿ ਰਹਿਆ ਪ੍ਰਭੁ ਸਭ ਮਹਿ ਆਪੇ ॥",
          "roman": "rav rahiā prabh sabh meh āpe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Сам присутствует во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34172,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਜਪੁ ਰਸਨਾ ਦੁਖੁ ਨ ਵਿਆਪੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har jap rasnā dukh na viāpe. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяй Его Имя языком — тогда никакое страдание не сможет одолеть тебя. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34173,
          "is_rahao": false,
          "gurmukhi": "ਤਿਖਾ ਭੂਖ ਬਹੁ ਤਪਤਿ ਵਿਆਪਿਆ ॥",
          "roman": "tikhā bhūkh bah tapat viāpiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мир охвачен жаждой майи, голодом майи и сильным внутренним жаром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34174,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਲ ਭਏ ਹਰਿ ਹਰਿ ਜਸੁ ਜਾਪਿਆ ॥੨॥",
          "roman": "sītal bhae har har jas jāpiā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто воспевает славу Хар Хар, становятся прохладными и умиротворёнными сердцем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34175,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਤਨ ਸੰਤੋਖੁ ਨ ਪਾਇਆ ॥",
          "roman": "koṭ jatan santokh na pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже миллионами усилий не обрести удовлетворения от жажды майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34176,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤ੍ਰਿਪਤਾਨਾ ਹਰਿ ਗੁਣ ਗਾਇਆ ॥੩॥",
          "roman": "man triptānā har guṇ gāiā. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда поют добродетели Господа, ум насыщается и успокаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34177,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹੁ ਭਗਤਿ ਪ੍ਰਭ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "deh bhagat prabh antarjāmī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, знающий сердца, даруй мне Свою бхагти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34178,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਬੇਨੰਤੀ ਸੁਆਮੀ ॥੪॥੫॥੧੦॥",
          "roman": "nānak kī benantī suāmī. ||4||5||10||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка, такова просьба Нанака у Твоих дверей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3017,
      "rahao_verse_id": 34183,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
