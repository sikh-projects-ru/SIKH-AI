{
  "ang": 805,
  "shabads": [
    {
      "shabad_id": 3019,
      "rahao_verse_id": 34205,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34203,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਈਐ ਚੀਤਾ ॥੧॥",
          "roman": "charan kamal siu lāīai chītā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нужно соединить сознание с лотосными, нежными стопами Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34204,
          "is_rahao": true,
          "gurmukhi": "ਹਉ ਬਲਿਹਾਰੀ ਜੋ ਪ੍ਰਭੂ ਧਿਆਵਤ ॥",
          "roman": "hau balihārī jo prabhū dhiāvat ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой ради тех людей, которые вспоминают имя Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34205,
          "is_rahao": true,
          "gurmukhi": "ਜਲਨਿ ਬੁਝੈ ਹਰਿ ਹਰਿ ਗੁਨ ਗਾਵਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jalan bujhē har har gun gāvat ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Хар, Хар, угасает жжение огня жажды майи. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34206,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਜਨਮੁ ਹੋਵਤ ਵਡਭਾਗੀ ॥",
          "roman": "safal janam hovat vaḍbhāgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жизнь тех великих счастливцев становится успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34207,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਰਾਮਹਿ ਲਿਵ ਲਾਗੀ ॥੨॥",
          "roman": "sādhsaṅg rāmhi liv lāgī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру их внимание соединяется с Рамом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34208,
          "is_rahao": false,
          "gurmukhi": "ਮਤਿ ਪਤਿ ਧਨੁ ਸੁਖ ਸਹਜ ਅਨੰਦਾ ॥ ਇਕ ਨਿਮਖ ਨ ਵਿਸਰਹੁ ਪਰਮਾਨੰਦਾ ॥੩॥",
          "roman": "mat pat dhan sukh sahaj anandā ॥ ik nimakh na visarah parmānandā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Не забывайте имя Параматмы, владыки высшего блаженства, даже на мгновение; через благословение имени разум становится высоким, приходит честь, и обретается богатство покоя, духовной устойчивости и радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34209,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਰਸਨ ਕੀ ਮਨਿ ਪਿਆਸ ਘਨੇਰੀ ॥",
          "roman": "har darsan kī man piās ghanerī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В моём уме великая жажда даршана Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34210,
          "is_rahao": false,
          "gurmukhi": "ਭਨਤਿ ਨਾਨਕ ਸਰਣਿ ਪ੍ਰਭ ਤੇਰੀ ॥੪॥੮॥੧੩॥",
          "roman": "bhanat nānak saraṇ prabh terī ॥4॥8॥13॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молится: о Прабху, я пришёл в твоё прибежище; исполни эту мою жажду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3020,
      "rahao_verse_id": 34215,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34211,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34212,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਨਿਰਗੁਨ ਸਭ ਗੁਣਹ ਬਿਹੂਨਾ ॥",
          "roman": "moh nirgun sabh guṇah bihūnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Меня, лишённого добродетелей и пустого от всех качеств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34213,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਧਾਰਿ ਅਪੁਨਾ ਕਰਿ ਲੀਨਾ ॥੧॥",
          "roman": "daiā dhār apunā kar līnā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху по милости сделал своим слугой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34214,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰਾ ਮਨੁ ਤਨੁ ਹਰਿ ਗੋਪਾਲਿ ਸੁਹਾਇਆ ॥",
          "roman": "merā man tan har gopāl suhāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот Гопал-Прабху сделал мой ум и моё тело прекрасными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34215,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭੁ ਘਰ ਮਹਿ ਆਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā prabh ghar meh āiā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Прабху вошёл в дом моего сердца. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34216,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਵਛਲ ਭੈ ਕਾਟਨਹਾਰੇ ॥",
          "roman": "bhagat vachhal bhē kāṭanhāre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху, любящий преданность, о устраняющий все страхи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34217,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰ ਸਾਗਰ ਅਬ ਉਤਰੇ ਪਾਰੇ ॥੨॥",
          "roman": "sansār sāgar ab utre pāre ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "теперь, когда ты поселился в доме моего сердца, твоей милостью я переправился через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34218,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨ ਪ੍ਰਭ ਬਿਰਦੁ ਬੇਦਿ ਲੇਖਿਆ ॥",
          "roman": "patit pāvan prabh birad bed lekhiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Веды и всякое религиозное писание записали о Прабху, что его древнее свойство — очищать даже падших."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34219,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਸੋ ਨੈਨਹੁ ਪੇਖਿਆ ॥੩॥",
          "roman": "pārbraham so nēnah pekhiā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этого Парбрахма я увидел своими глазами как пребывающего повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34220,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਪ੍ਰਗਟੇ ਨਾਰਾਇਣ ॥",
          "roman": "sādhsaṅg pragṭe nārāiṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда в обществе Гуру Нараян проявляется в сердце человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34221,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਭਿ ਦੂਖ ਪਲਾਇਣ ॥੪॥੯॥੧੪॥",
          "roman": "nānak dās sabh dūkh palāiṇ ॥4॥9॥14॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "о слуга Нанак, все его страдания уходят прочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3021,
      "rahao_verse_id": 34227,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34222,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34223,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਜਾਨੈ ਪ੍ਰਭ ਤੁਮੑਰੀ ਸੇਵਾ ॥",
          "roman": "kavan jānē prabh tumhrī sevā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху, никто своим умом не знает, как совершать твою севу-бхагти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34224,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਵਿਨਾਸੀ ਅਲਖ ਅਭੇਵਾ ॥੧॥",
          "roman": "prabh avināsī alakh abhevā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О неразрушимый Прабху, о невидимый Прабху, о непостижимый Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34225,
          "is_rahao": true,
          "gurmukhi": "ਗੁਣ ਬੇਅੰਤ ਪ੍ਰਭ ਗਹਿਰ ਗੰਭੀਰੇ ॥",
          "roman": "guṇ beant prabh gahir gambhīre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глубокий Прабху, о Прабху великого сердца, ты владыка бесконечных качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34226,
          "is_rahao": true,
          "gurmukhi": "ਊਚ ਮਹਲ ਸੁਆਮੀ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "ūch mahal suāmī prabh mere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой владыка Прабху, духовные обители, в которых ты пребываешь, очень высоки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34227,
          "is_rahao": true,
          "gurmukhi": "ਤੂ ਅਪਰੰਪਰ ਠਾਕੁਰ ਮੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tū aparanpar ṭhākur mere ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Тхакур, ты за пределами всего и ещё дальше. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34228,
          "is_rahao": false,
          "gurmukhi": "ਏਕਸ ਬਿਨੁ ਨਾਹੀ ਕੋ ਦੂਜਾ ॥",
          "roman": "ekas bin nāhī ko dūjā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме тебя одного, о Прабху, нет никого другого, равного тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34229,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮੑ ਹੀ ਜਾਨਹੁ ਅਪਨੀ ਪੂਜਾ ॥੨॥",
          "roman": "tumh hī jānah apnī pūjā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты сам знаешь способ своей бхагти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34230,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹੁ ਕਛੂ ਨ ਹੋਵਤ ਭਾਈ ॥",
          "roman": "āpah kachhū na hovat bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, своими силами живое существо не может совершить даже малой доли бхагти Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34231,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਭੁ ਦੇਵੈ ਸੋ ਨਾਮੁ ਪਾਈ ॥੩॥",
          "roman": "jis prabh devē so nām pāī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот человек получает дар Хар-нама, кому сам Прабху даёт его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34232,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜੋ ਜਨੁ ਪ੍ਰਭ ਭਾਇਆ ॥",
          "roman": "kah nānak jo jan prabh bhāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: тот человек, который становится дорог Параматме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34233,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਨਿਧਾਨ ਪ੍ਰਭੁ ਤਿਨ ਹੀ ਪਾਇਆ ॥੪॥੧੦॥੧੫॥",
          "roman": "guṇ nidhān prabh tin hī pāiā ॥4॥10॥15॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "только он обретает встречу с Прабху, сокровищницей качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3022,
      "rahao_verse_id": 34238,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34234,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34235,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਗਰਭ ਮਹਿ ਹਾਥ ਦੇ ਰਾਖਿਆ ॥",
          "roman": "māt garabh meh hāth de rākhiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Прабху, который, протянув свою руку, защитил тебя в утробе матери,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34236,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸੁ ਛੋਡਿ ਬਿਖਿਆ ਫਲੁ ਚਾਖਿਆ ॥੧॥",
          "roman": "har ras chhoḍ bikhiā phal chākhiā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "наслаждение его именем ты забыл и пробуешь плод майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34237,
          "is_rahao": true,
          "gurmukhi": "ਭਜੁ ਗੋਬਿਦ ਸਭ ਛੋਡਿ ਜੰਜਾਲ ॥",
          "roman": "bhaj gobid sabh chhoḍ janjāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупый человек, оставь все путы привязанности и воспевай имя Гобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34238,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਜਮੁ ਆਇ ਸੰਘਾਰੈ ਮੂੜੇ ਤਬ ਤਨੁ ਬਿਨਸਿ ਜਾਇ ਬੇਹਾਲ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jab jam āe saṅghārē mūṛe tab tan binas jāe behāl ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Джам приходит и наносит смертельный удар, о глупец, тогда тело, претерпев страдание, погибает. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34239,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਧਨੁ ਅਪਨਾ ਕਰਿ ਥਾਪਿਆ ॥",
          "roman": "tan man dhan apnā kar thāpiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупец, ты считаешь это тело, этот ум и это богатство своими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34240,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨਹਾਰੁ ਇਕ ਨਿਮਖ ਨ ਜਾਪਿਆ ॥੨॥",
          "roman": "karanhār ik nimakh na jāpiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но Прабху, который создал их, ты не вспоминал даже на мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34241,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਮੋਹ ਅੰਧ ਕੂਪ ਪਰਿਆ ॥",
          "roman": "mahā moh andh kūp pariā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупец, ты упал в глубокий тёмный колодец великой привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34242,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਮਾਇਆ ਪਟਲਿ ਬਿਸਰਿਆ ॥੩॥",
          "roman": "pārbraham māiā paṭal bisariā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "За завесой привязанности к майе ты забыл Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34243,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਪ੍ਰਭ ਕੀਰਤਨੁ ਗਾਇਆ ॥",
          "roman": "vaḍē bhāg prabh kīrtan gāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто по великой удаче начал петь киртан славы Прабху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34244,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਨਾਨਕ ਪ੍ਰਭੁ ਪਾਇਆ ॥੪॥੧੧॥੧੬॥",
          "roman": "santsang nānak prabh pāiā ॥4॥11॥16॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "о Нанак, в обществе святых обретает встречу с Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3023,
      "rahao_verse_id": 34249,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34245,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34246,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਪਿਤਾ ਸੁਤ ਬੰਧਪ ਭਾਈ ॥",
          "roman": "māt pitā sut bandhap bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как мать, отец, сын, родственники и брат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34247,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹੋਆ ਪਾਰਬ੍ਰਹਮੁ ਸਹਾਈ ॥੧॥",
          "roman": "nānak hoā pārbraham sahāī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Парабрахм стал помощником Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34248,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਘਣੇ ॥",
          "roman": "sūkh sahaj ānand ghaṇe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обретаются многие покои и радости духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34249,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪੂਰੀ ਜਾ ਕੀ ਬਾਣੀ ਅਨਿਕ ਗੁਣਾ ਜਾ ਕੇ ਜਾਹਿ ਨ ਗਣੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrā pūrī jā kī bāṇī anik guṇā jā ke jāh na gaṇe ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру полон всех качеств, его Бани наполнена духовной радостью, и у него множество качеств, которые невозможно исчислить; в его прибежище обретаются многие покои и радости духовной устойчивости. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34250,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਰੰਜਾਮ ਕਰੇ ਪ੍ਰਭੁ ਆਪੇ ॥",
          "roman": "sagal saranjām kare prabh āpe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам устраивает все средства для завершения дел человека, пришедшего в его прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34251,
          "is_rahao": false,
          "gurmukhi": "ਭਏ ਮਨੋਰਥ ਸੋ ਪ੍ਰਭੁ ਜਾਪੇ ॥੨॥",
          "roman": "bhae manorath so prabh jāpe ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя имя этого Прабху, все желания ума исполняются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34252,
          "is_rahao": false,
          "gurmukhi": "ਅਰਥ ਧਰਮ ਕਾਮ ਮੋਖ ਕਾ ਦਾਤਾ ॥",
          "roman": "arath dharam kām mokh kā dātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма сам является дарителем четырёх известных благ мира: дхармы, артхи, камы и мокши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
