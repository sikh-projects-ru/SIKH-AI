{
  "ang": 807,
  "shabads": [
    {
      "shabad_id": 3029,
      "rahao_verse_id": 34299,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34299,
          "is_rahao": true,
          "gurmukhi": "ਵਡੀ ਆਰਜਾ ਹਰਿ ਗੋਬਿੰਦ ਕੀ ਸੂਖ ਮੰਗਲ ਕਲਿਆਣ ਬੀਚਾਰਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "vaḍī ārjā har gobind kī sūkh maṅgal kaliāṇ bīchāriā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я пожелал Хар Гобинду долгой жизни, мира, радости и благополучия. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34300,
          "is_rahao": false,
          "gurmukhi": "ਵਣ ਤ੍ਰਿਣ ਤ੍ਰਿਭਵਣ ਹਰਿਆ ਹੋਏ ਸਗਲੇ ਜੀਅ ਸਾਧਾਰਿਆ ॥",
          "roman": "vaṇ triṇ tribhavaṇ hariā hoē saglē jīa sādhāriā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Леса, травы и три мира стали зелёными и оживлёнными; все существа получили опору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34301,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਇਛੇ ਨਾਨਕ ਫਲ ਪਾਏ ਪੂਰਨ ਇਛ ਪੁਜਾਰਿਆ ॥੨॥੫॥੨੩॥",
          "roman": "man ichhē nānak phal pāē pūran ichh pujāriā. ||2||5||23||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак получил желанные плоды сердца; все желания исполнились. ||2||5||23||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3030,
      "rahao_verse_id": 34304,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34302,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34303,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਊਪਰਿ ਹੋਵਤ ਦਇਆਲੁ ॥",
          "roman": "jis ūpar hovat daiyāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на кого Гуру становится милостивым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34304,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਕਾਟੈ ਸੋ ਕਾਲੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har simrat kāṭē so kāl. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "памятованием о Хар отсекает смерть, страх смерти и путь духовной смерти. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34305,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭਜੀਐ ਗੋਪਾਲੁ ॥",
          "roman": "sādhasaṅg bhajīē gopāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая в обществе Гуру, следует созерцать Гопала, Питателя мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34306,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਤ ਤੂਟੈ ਜਮ ਜਾਲੁ ॥੧॥",
          "roman": "gun gāvat tūṭē jam jāl. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Господа, человек разрывает сеть Джама, петлю духовной смерти. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34307,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਤਿਗੁਰੁ ਆਪੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "āpē satigur āpē pratipāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господь становится Сатгуру и Сам же защищает существ от этой сети."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34308,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਾਚੈ ਸਾਧ ਰਵਾਲ ॥੨॥੬॥੨੪॥",
          "roman": "nānak jāchē sādh ravāl. ||2||6||24||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому Нанак всегда просит пыль стоп Гуру. ||2||6||24||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3031,
      "rahao_verse_id": 34313,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34309,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34310,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਸਿੰਚਹੁ ਹਰਿ ਹਰਿ ਨਾਮ ॥",
          "roman": "man mah siñchah har har nām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, постоянно орошай свой ум нектаром Имени Хар, Хар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34311,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਕੀਰਤਨੁ ਹਰਿ ਗੁਣ ਗਾਮ ॥੧॥",
          "roman": "anadin kīrtan har guṇ gām. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый день совершай киртан и воспевай качества Хар. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34312,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਪ੍ਰੀਤਿ ਕਰਹੁ ਮਨ ਮੇਰੇ ॥",
          "roman": "aisī prīt karah man mērē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум, установи такую любовь к Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34313,
          "is_rahao": true,
          "gurmukhi": "ਆਠ ਪਹਰ ਪ੍ਰਭ ਜਾਨਹੁ ਨੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āṭh pahar prabh jānah nērē. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "чтобы все восемь пэхэров понимать, что Прабху пребывает рядом с тобой. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34314,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕੇ ਨਿਰਮਲ ਭਾਗ ॥",
          "roman": "kah nānak jā kē nirmal bhāg.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, о Нанак: у кого пробуждаются чистые, благие судьбы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34315,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਨੀ ਤਾ ਕਾ ਮਨੁ ਲਾਗ ॥੨॥੭॥੨੫॥",
          "roman": "har charnī tā kā man lāg. ||2||7||25||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "ум того человека привыкает пребывать у стоп Хар. ||2||7||25||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3032,
      "rahao_verse_id": 34318,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34316,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34317,
          "is_rahao": true,
          "gurmukhi": "ਰੋਗੁ ਗਇਆ ਪ੍ਰਭਿ ਆਪਿ ਗਵਾਇਆ ॥",
          "roman": "rog gaiā prabh āp gavāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот недуг ушёл, который Сам Прабху устранил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34318,
          "is_rahao": true,
          "gurmukhi": "ਨੀਦ ਪਈ ਸੁਖ ਸਹਜ ਘਰੁ ਆਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nīd paī sukh sahaj ghar āiā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря Имени человеку приходит духовный покой; он обретает состояние счастья и духовной устойчивости. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34319,
          "is_rahao": false,
          "gurmukhi": "ਰਜਿ ਰਜਿ ਭੋਜਨੁ ਖਾਵਹੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "raj raj bhojan khāvah mērē bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой брат, ешь эту пищу души досыта, снова и снова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34320,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਰਿਦ ਮਾਹਿ ਧਿਆਈ ॥੧॥",
          "roman": "aṅmrit nām rid māh dhiāī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Созерцай в сердце дающее духовную жизнь Имя Хар. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34321,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਪੂਰੇ ਸਰਨਾਈ ॥",
          "roman": "nānak gur pūrē sarnāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, оставайся в прибежище совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34322,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਅਪਨੇ ਨਾਮ ਕੀ ਪੈਜ ਰਖਾਈ ॥੨॥੮॥੨੬॥",
          "roman": "jin apnē nām kī pēj rakhāī. ||2||8||26||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот Гуру всегда сохранял честь своего Имени и поддерживал пришедших к его прибежищу. ||2||8||26||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3033,
      "rahao_verse_id": 34324,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34323,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34324,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰ ਕਰਿ ਦੀਨੇ ਅਸਥਿਰ ਘਰ ਬਾਰ ॥ ਰਹਾਉ ॥",
          "roman": "satigur kar dīnē asthir ghar bār. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма сделал дома Сатгуру, то есть Садх Сангат, вечно устойчивыми местами соединения с Ним. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34325,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਨਿੰਦ ਕਰੈ ਇਨ ਗ੍ਰਿਹਨ ਕੀ ਤਿਸੁ ਆਗੈ ਹੀ ਮਾਰੈ ਕਰਤਾਰ ॥੧॥",
          "roman": "jo jo nind karē in grihan kī tis āgē hī mārē kartār. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто порицает эти дома, Садх Сангат, тому Картар уже заранее дал духовную смерть. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34326,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤਾ ਕੀ ਸਰਨਾਈ ਜਾ ਕੋ ਸਬਦੁ ਅਖੰਡ ਅਪਾਰ ॥੨॥੯॥੨੭॥",
          "roman": "nānak dās tā kī sarnāī jā ko sabad akhaṇḍ apār. ||2||9||27||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, в прибежище того Параматмы, чей Хукам нерушим и бесконечен, можно прийти только благодатью Садх Сангат. ||2||9||27||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3034,
      "rahao_verse_id": 34329,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34327,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34328,
          "is_rahao": true,
          "gurmukhi": "ਤਾਪ ਸੰਤਾਪ ਸਗਲੇ ਗਏ ਬਿਨਸੇ ਤੇ ਰੋਗ ॥",
          "roman": "tāp santāp saglē gaē binsē tē rog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто вкушает духовную радость Naam Simran, исчезают все страдания, все мучения и все болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34329,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮਿ ਤੂ ਬਖਸਿਆ ਸੰਤਨ ਰਸ ਭੋਗ ॥ ਰਹਾਉ ॥",
          "roman": "pārbrahm tū bakhsiā santan ras bhog. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Парбрахм одарил тебя милостью, вкушай духовную радость, свойственную святым. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34330,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਤੇਰੀ ਮੰਡਲੀ ਤੇਰਾ ਮਨੁ ਤਨੁ ਆਰੋਗ ॥",
          "roman": "sarab sukhā tērī maṇḍalī tērā man tan ārog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если будешь принимать лекарство Naam Simran, все радости станут твоими спутниками, и твой ум и тело будут свободны от болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34331,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਹੁ ਨਿਤ ਰਾਮ ਕੇ ਇਹ ਅਵਖਦ ਜੋਗ ॥੧॥",
          "roman": "gun gāvah nit rām kē ih avkadh jog. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Постоянно воспевай качества Рама; это подходящее лекарство от страданий и болезней. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34332,
          "is_rahao": false,
          "gurmukhi": "ਆਇ ਬਸਹੁ ਘਰ ਦੇਸ ਮਹਿ ਇਹ ਭਲੇ ਸੰਜੋਗ ॥",
          "roman": "āi basah ghar dēs mah ih bhalē sanjog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Приди и пребывай в доме-сердце, в стране сердца; дни человеческой жизни дают благие возможности для соединения с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34333,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸੁਪ੍ਰਸੰਨ ਭਏ ਲਹਿ ਗਏ ਬਿਓਗ ॥੨॥੧੦॥੨੮॥",
          "roman": "nānak prabh suprasann bhaē lah gaē biog. ||2||10||28||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у того, на кого Прабху становится полностью милостивым, уходят все разлуки с Ним. ||2||10||28||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3035,
      "rahao_verse_id": 34336,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34334,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34335,
          "is_rahao": true,
          "gurmukhi": "ਕਾਹੂ ਸੰਗਿ ਨ ਚਾਲਹੀ ਮਾਇਆ ਜੰਜਾਲ ॥",
          "roman": "kāhū saṅg na chālahī māiā jañjāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые твёрдо знают, что все путы и разрастания Майи ни с кем не уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34336,
          "is_rahao": true,
          "gurmukhi": "ਊਠਿ ਸਿਧਾਰੇ ਛਤ੍ਰਪਤਿ ਸੰਤਨ ਕੈ ਖਿਆਲ ॥ ਰਹਾਉ ॥",
          "roman": "ūṭh sidhārē chhatrapat santan kē khiāl. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже цари и владыки, когда приходит смерть, поднимаются и уходят, оставив всё это; таков взгляд святых. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34337,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਬੁਧਿ ਕਉ ਬਿਨਸਨਾ ਇਹ ਧੁਰ ਕੀ ਢਾਲ ॥",
          "roman": "ahaṅbudh kau binsnā ih dhur kī ḍhāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кто живёт разумом Хоумэ и желанием стать великим, непременно постигает духовная смерть; таков изначальный порядок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34338,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਜੋਨੀ ਜਨਮਹਿ ਮਰਹਿ ਬਿਖਿਆ ਬਿਕਰਾਲ ॥੧॥",
          "roman": "bah jonī janmah marah bikhiyā bikrāl. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ужасные последствия привязанности к Майе таковы: поглощённые ею люди рождаются и умирают во многих утробах. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34339,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਬਚਨ ਸਾਧੂ ਕਹਹਿ ਨਿਤ ਜਪਹਿ ਗੁਪਾਲ ॥",
          "roman": "sat bachan sādhū kahah nit japah gupāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукхи произносят истинные слова хвалы Господу и постоянно повторяют Имя Гопала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34340,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਨਾਨਕ ਤਰੇ ਹਰਿ ਕੇ ਰੰਗ ਲਾਲ ॥੨॥੧੧॥੨੯॥",
          "roman": "simar simar nānak tarē har kē raṅg lāl. ||2||11||29||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, окрашенные глубоким цветом любви Хар, святые, снова и снова вспоминая Его, переправляются через океан мира и привязанность к Майе. ||2||11||29||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3036,
      "rahao_verse_id": 34343,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34341,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34342,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਸਮਾਧਿ ਅਨੰਦ ਸੂਖ ਪੂਰੇ ਗੁਰਿ ਦੀਨ ॥",
          "roman": "sahaj samādh anand sūkh pūrē gur dīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру дал человеку все радости и счастье однонаправленного пребывания в духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34343,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਸਹਾਈ ਸੰਗਿ ਪ੍ਰਭ ਅੰਮ੍ਰਿਤ ਗੁਣ ਚੀਨ ॥ ਰਹਾਉ ॥",
          "roman": "sadā sahāī saṅg prabh aṅmrit guṇ chīn. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху всегда остаётся его помощником и пребывает с ним; этот человек размышляет в уме о дающих духовную жизнь качествах Прабху. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
