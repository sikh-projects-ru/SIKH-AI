{
  "ang": 819,
  "shabads": [
    {
      "shabad_id": 3080,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34789,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਜਗਤ ਮਹਿ ਸਫਲ ਜਾ ਕੀ ਸੇਵ ॥੧॥",
          "roman": "jē jē kār jagat meh safal jā kī sēv ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мире звучит хвала тому, чьё служение становится плодотворным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34790,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਅਪਾਰ ਅਗਨਤ ਹਰਿ ਸਭਿ ਜੀਅ ਜਿਸੁ ਹਾਥਿ ॥",
          "roman": "ūch apār aganat har sabh jīa jis hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Высокий, беспредельный и неисчислимый Хари — все существа в Его руке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34791,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਗਤੀ ਜਤ ਕਤ ਮੇਰੈ ਸਾਥਿ ॥੨॥੧੦॥੭੪॥",
          "roman": "nānak prabh śaraṇāgatī jat kat merē sāth ||2||10||74||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак пребывает в прибежище Прабху: куда бы ни пойти, Он всюду со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3081,
      "rahao_verse_id": 34796,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34792,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34793,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਆਰਾਧਿਆ ਹੋਏ ਕਿਰਪਾਲ ॥",
          "roman": "gur pūrā ārādhiā hoe kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, который хранит совершенного Гуру в сердце и на которого Гуру становится милостивым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34794,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰਗੁ ਸੰਤਿ ਬਤਾਇਆ ਤੂਟੇ ਜਮ ਜਾਲ ॥੧॥",
          "roman": "mārag sant batāiā ṭūṭē jam jāl ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тому Гуру показывает верный путь жизни, и все петли Джама разрываются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34795,
          "is_rahao": true,
          "gurmukhi": "ਦੂਖ ਭੂਖ ਸੰਸਾ ਮਿਟਿਆ ਗਾਵਤ ਪ੍ਰਭ ਨਾਮ ॥",
          "roman": "dūkh bhūkh sansā miṭiā gāvat prabh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При воспевании имени Прабху исчезают все страдания, все голодные желания и все страхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34796,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਸੂਖ ਆਨੰਦ ਰਸ ਪੂਰਨ ਸਭਿ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sahaj sūkh ānand ras pūran sabh kām ||1|| rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Приходят покой духовной устойчивости, радость и вкус блаженства; все нужды исполняются. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34797,
          "is_rahao": false,
          "gurmukhi": "ਜਲਨਿ ਬੁਝੀ ਸੀਤਲ ਭਏ ਰਾਖੇ ਪ੍ਰਭਿ ਆਪ ॥",
          "roman": "jalan bujhī sītal bhaye rākhē prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам охраняет такого человека; внутренняя жгучесть угасает, и ум становится прохладным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34798,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਗਤੀ ਜਾ ਕਾ ਵਡ ਪਰਤਾਪ ॥੨॥੧੧॥੭੫॥",
          "roman": "nānak prabh śaraṇāgatī jā kā vaḍ partāp ||2||11||75||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак, оставайся в прибежище того Прабху, чья сила столь велика."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3082,
      "rahao_verse_id": 34803,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34799,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34800,
          "is_rahao": false,
          "gurmukhi": "ਧਰਤਿ ਸੁਹਾਵੀ ਸਫਲ ਥਾਨੁ ਪੂਰਨ ਭਏ ਕਾਮ ॥",
          "roman": "dharat suhāvī safal thān pūran bhaye kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело становится прекрасным, сердце — местом, где достигается жизненная цель, и все дела завершаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34801,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਨਾਠਾ ਭ੍ਰਮੁ ਮਿਟਿ ਗਇਆ ਰਵਿਆ ਨਿਤ ਰਾਮ ॥੧॥",
          "roman": "bhau nāṭhā bhram miṭ gaiā raviā nit rām ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек постоянно вспоминает Рама, страх удаляется, а блуждание и сомнение исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34802,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੈ ਸੰਗਿ ਬਸਤ ਸੁਖ ਸਹਜ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "sādh janā kē sang basat sukh sahaj bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе святых людей, обретают радость духовной устойчивости и покой ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34803,
          "is_rahao": true,
          "gurmukhi": "ਸਾਈ ਘੜੀ ਸੁਲਖਣੀ ਸਿਮਰਤ ਹਰਿ ਨਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sāī ghaṛī sulakhaṇī simrat har nām ||1|| rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та минута благословенна, когда человек вспоминает имя Хари. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34804,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟ ਭਏ ਸੰਸਾਰ ਮਹਿ ਫਿਰਤੇ ਪਹਨਾਮ ॥",
          "roman": "pragaṭ bhaye sansār meh phirtē pahnām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто прежде ходили скрытыми и никому не были известны, становятся прославленными в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34805,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਸਰਣਾਗਤੀ ਘਟ ਘਟ ਸਭ ਜਾਨ ॥੨॥੧੨॥੭੬॥",
          "roman": "nānak tis śaraṇāgatī ghaṭ ghaṭ sabh jān ||2||12||76||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак, следует пребывать в прибежище Того, кто знает всё в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3083,
      "rahao_verse_id": 34810,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34806,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34807,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਮਿਟਾਇਆ ਆਪਿ ਪ੍ਰਭਿ ਉਪਜਿਆ ਸੁਖੁ ਸਾਂਤਿ ॥",
          "roman": "rog miṭāiā āp prabh upjiā sukh sānt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам устранил болезнь; по Его милости возникли покой и мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34808,
          "is_rahao": false,
          "gurmukhi": "ਵਡ ਪਰਤਾਪੁ ਅਚਰਜ ਰੂਪੁ ਹਰਿ ਕੀਨੑੀ ਦਾਤਿ ॥੧॥",
          "roman": "vaḍ partāp acharaj rūp har kīnhī dāt ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хари великого могущества и чудесного облика сам даровал эту милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34809,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਗੋਵਿੰਦਿ ਕ੍ਰਿਪਾ ਕਰੀ ਰਾਖਿਆ ਮੇਰਾ ਭਾਈ ॥",
          "roman": "gur govind kirpā karī rākhiā merā bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру, Говинд, проявил милость и спас моего дорогого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34810,
          "is_rahao": true,
          "gurmukhi": "ਹਮ ਤਿਸ ਕੀ ਸਰਣਾਗਤੀ ਜੋ ਸਦਾ ਸਹਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ham tis kī śaraṇāgatī jo sadā sahāī ||1|| rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я принял прибежище у Того, кто всегда помогает. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34811,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥੀ ਕਦੇ ਨ ਹੋਵਈ ਜਨ ਕੀ ਅਰਦਾਸਿ ॥",
          "roman": "birthī kadē na hovaī jan kī ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мольба слуги никогда не бывает напрасной; Прабху обязательно помогает и сам защищает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34812,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੋਰੁ ਗੋਵਿੰਦ ਕਾ ਪੂਰਨ ਗੁਣਤਾਸਿ ॥੨॥੧੩॥੭੭॥",
          "roman": "nānak jor govind kā pūran guṇtās ||2||13||77||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак, моя опора — сила Говинда; Он полный сокровищницей всех качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3084,
      "rahao_verse_id": 34817,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34813,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34814,
          "is_rahao": false,
          "gurmukhi": "ਮਰਿ ਮਰਿ ਜਨਮੇ ਜਿਨ ਬਿਸਰਿਆ ਜੀਵਨ ਕਾ ਦਾਤਾ ॥",
          "roman": "mar mar janmē jin bisriā jīvan kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто забывает Подателя жизни, переживают духовную смерть и снова попадают в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34815,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਨਿ ਸੇਵਿਆ ਅਨਦਿਨੁ ਰੰਗਿ ਰਾਤਾ ॥੧॥",
          "roman": "pārbrahm jan sēviā andin rang rātā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но слуга Прабху вспоминает Парабрахма постоянно и остаётся окрашенным любовью к Нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34816,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਸਹਜੁ ਆਨਦੁ ਘਨਾ ਪੂਰਨ ਭਈ ਆਸ ॥",
          "roman": "sānt sahaj ānad ghanā pūran bhaī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В сердце слуги пребывают мир, духовная устойчивость и большое блаженство; всякая надежда исполняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34817,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖੁ ਪਾਇਆ ਹਰਿ ਸਾਧਸੰਗਿ ਸਿਮਰਤ ਗੁਣਤਾਸ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukh pāiā har sādhsang simrat guṇtās ||1|| rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Садхсангат, вспоминая Хари, сокровищницу качеств, слуга обретает духовную радость. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34818,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਆਮੀ ਅਰਦਾਸਿ ਜਨ ਤੁਮੑ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "suṇ suāmī ardās jan tum antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Суами, Ты знаешь сердца и всегда слышишь молитву своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34819,
          "is_rahao": false,
          "gurmukhi": "ਥਾਨ ਥਨੰਤਰਿ ਰਵਿ ਰਹੇ ਨਾਨਕ ਕੇ ਸੁਆਮੀ ॥੨॥੧੪॥੭੮॥",
          "roman": "thān thanantar rav rahē nānak kē suāmī ||2||14||78||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка Нанака, Ты пребываешь во всяком месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3085,
      "rahao_verse_id": 34824,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34820,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34821,
          "is_rahao": false,
          "gurmukhi": "ਤਾਤੀ ਵਾਉ ਨ ਲਗਈ ਪਾਰਬ੍ਰਹਮ ਸਰਣਾਈ ॥",
          "roman": "tātī vāu na lagaī pārbrahm śaraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В прибежище Парабрахма не касается даже горячий ветер страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34822,
          "is_rahao": false,
          "gurmukhi": "ਚਉਗਿਰਦ ਹਮਾਰੈ ਰਾਮ ਕਾਰ ਦੁਖੁ ਲਗੈ ਨ ਭਾਈ ॥੧॥",
          "roman": "chaugirad hamārē rām kār dukh lagē na bhāī ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, вокруг нас словно проведена линия имени Рама, поэтому никакое страдание не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34823,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਪੂਰਾ ਭੇਟਿਆ ਜਿਨਿ ਬਣਤ ਬਣਾਈ ॥",
          "roman": "satigur pūrā bhēṭiā jin baṇat baṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда встречается совершенный Сатгуру, устроивший средство для удаления болезней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34824,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਅਉਖਧੁ ਦੀਆ ਏਕਾ ਲਿਵ ਲਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām nām aukhad dīā ēkā liv lāī ||1|| rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "он даёт лекарство имени Рама, и человек удерживает внимание в едином Прабху. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34825,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੀਏ ਤਿਨਿ ਰਖਨਹਾਰਿ ਸਭ ਬਿਆਧਿ ਮਿਟਾਈ ॥",
          "roman": "rākh līe tin rakhṇhār sabh biādh miṭāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Хранитель спас его и удалил изнутри всякую болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34826,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਕਿਰਪਾ ਭਈ ਪ੍ਰਭ ਭਏ ਸਹਾਈ ॥੨॥੧੫॥੭੯॥",
          "roman": "kah nānak kirpā bhaī prabh bhaye sahāī ||2||15||79||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: на такого человека сошла милость, и Прабху стал его помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
