{
  "ang": 832,
  "shabads": [
    {
      "shabad_id": 3140,
      "rahao_verse_id": 35275,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35269,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੧ ॥",
          "roman": "bilāval mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35270,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਕਹਿਆ ਮਨਸਾ ਕਰੈ ॥",
          "roman": "man kā kahiā mansā karey",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ-ਨਾਮ ਤੋਂ ਖੁੰਝੇ ਹੋਏ ਮਨੁੱਖ ਦੀ) ਬੁੱਧੀ (ਭੀ) ਮਨ ਦੇ ਕਹੇ ਵਿਚ ਤੁਰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Разум человека (отклонённого от Имени) следует за тем, что говорит ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35271,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਪੁੰਨੁ ਪਾਪੁ ਉਚਰੈ ॥",
          "roman": "ih man punn pāp ucharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਇਹ ਮਨ ਨਿਰੀਆਂ ਇਹੀ ਗੱਲਾਂ ਸੋਚਦਾ ਹੈ ਕਿ (ਸ਼ਾਸਤ੍ਰਾਂ ਦੀ ਮਰਯਾਦਾ ਅਨੁਸਾਰ) ਪੁੰਨ ਕੀਹ ਹੈ ਤੇ ਪਾਪ ਕੀਹ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и этот ум только и размышляет о том, что есть заслуга и что есть грех (по шастрам)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35272,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮਦਿ ਮਾਤੇ ਤ੍ਰਿਪਤਿ ਨ ਆਵੈ ॥",
          "roman": "māiā mad mātē tripat na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਨਸ਼ੇ ਵਿਚ ਮਸਤ ਹੋਏ ਮਨੁੱਖ ਨੂੰ (ਮਾਇਆ ਵਲੋਂ) ਰਜੇਵਾਂ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Опьянённый опьянением майи человек не находит насыщения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35273,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਪਤਿ ਮੁਕਤਿ ਮਨਿ ਸਾਚਾ ਭਾਵੈ ॥੧॥",
          "roman": "tripat mukat man sāchā bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਵਲੋਂ ਰਜੇਵਾਂ ਤੇ ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਖ਼ਲਾਸੀ ਤਦੋਂ ਹੀ ਹੁੰਦੀ ਹੈ ਜਦੋਂ ਮਨੁੱਖ ਨੂੰ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਮਨ ਵਿਚ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Насыщение и освобождение приходят тогда, когда в сердце становится дорогим вечный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35274,
          "is_rahao": true,
          "gurmukhi": "ਤਨੁ ਧਨੁ ਕਲਤੁ ਸਭੁ ਦੇਖੁ ਅਭਿਮਾਨਾ ॥",
          "roman": "tan dhan kalat sabh dekh abhimānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅਭਿਮਾਨੀ ਜੀਵ! ਵੇਖ, ਇਹ ਸਰੀਰ, ਇਹ ਧਨ, ਇਹ ਇਸਤ੍ਰੀ-ਇਹ ਸਭ (ਸਦਾ ਨਾਲ ਨਿਭਣ ਵਾਲੇ ਨਹੀਂ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "О гордый человек! Посмотри: это тело, это богатство, эта жена — всё это не вечно с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35275,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਕਿਛੁ ਸੰਗਿ ਨ ਜਾਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bin nāvē kichh sang na jānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਕੋਈ ਚੀਜ਼ (ਜੀਵ ਦੇ) ਨਾਲ ਨਹੀਂ ਜਾਂਦੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени ничего не уходит вместе с человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35276,
          "is_rahao": false,
          "gurmukhi": "ਕੀਚਹਿ ਰਸ ਭੋਗ ਖੁਸੀਆ ਮਨ ਕੇਰੀ ॥",
          "roman": "kīchah ras bhog khusīā man kerī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਕ ਰਸਾਂ ਦੇ ਭੋਗ ਕਰੀਦੇ ਹਨ, ਮਨ ਦੀਆਂ ਮੌਜਾਂ ਮਾਣੀਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Человек наслаждается мирскими удовольствиями, предаётся радостям ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35277,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਲੋਕਾਂ ਤਨੁ ਭਸਮੈ ਢੇਰੀ ॥",
          "roman": "dhan lokā tan bhasmē dherī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਮੌਤ ਆਉਣ ਤੇ) ਧਨ (ਹੋਰ) ਲੋਕਾਂ ਦਾ ਬਣ ਜਾਂਦਾ ਹੈ ਤੇ ਇਹ ਸਰੀਰ ਮਿੱਟੀ ਦੀ ਢੇਰੀ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но при смерти богатство достаётся другим, а тело превращается в груду пепла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35278,
          "is_rahao": false,
          "gurmukhi": "ਖਾਕੂ ਖਾਕੁ ਰਲੈ ਸਭੁ ਫੈਲੁ ॥",
          "roman": "khākū khāk ralē sabh fēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰਾ ਹੀ ਪਸਾਰਾ (ਅੰਤ) ਖ਼ਾਕ ਵਿਚ ਹੀ ਰਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё это распространение в конце смешивается с прахом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35279,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਨਹੀ ਉਤਰੈ ਮੈਲੁ ॥੨॥",
          "roman": "bin sabdē nahī utarē mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨ ਉਤੇ ਵਿਸ਼ੇ ਵਿਕਾਰਾਂ ਦੀ ਮੈਲ ਇਕੱਠੀ ਹੁੰਦੀ ਜਾਂਦੀ ਹੈ, ਉਹ) ਮੈਲ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਤੋਂ ਬਿਨਾ ਨਹੀਂ ਲਹਿੰਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Эта грязь (пороков) не очищается без Шабда Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35280,
          "is_rahao": false,
          "gurmukhi": "ਗੀਤ ਰਾਗ ਘਨ ਤਾਲ ਸਿ ਕੂਰੇ ॥",
          "roman": "gīt rāg ghan tāl s kūrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ-ਨਾਮ ਤੋਂ ਖੁੰਝ ਕੇ) ਮਨੁੱਖ ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਗੀਤ ਰਾਗ ਤੇ ਤਾਲ ਆਦਿਕਾਂ ਵਿਚ ਮਨ ਪਰਚਾਂਦਾ ਹੈ ਪਰ ਇਹ ਸਭ ਝੂਠੇ ਉੱਦਮ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Без Имени человек увлекается песнями, рагами и ритмами, но всё это ложные занятия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35281,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਹੁ ਗੁਣ ਉਪਜੈ ਬਿਨਸੈ ਦੂਰੇ ॥",
          "roman": "trih guṇ upjē binsē dūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਨਾਮ ਤੋਂ ਬਿਨਾ ਜੀਵ) ਤਿੰਨਾਂ ਗੁਣਾਂ ਦੇ ਅਸਰ ਹੇਠ ਜੰਮਦਾ ਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ਤੇ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਤੋਂ) ਵਿਛੁੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо без Имени он рождается и умирает под властью трёх гун и остаётся отделённым от Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35282,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੀ ਦੁਰਮਤਿ ਦਰਦੁ ਨ ਜਾਇ ॥",
          "roman": "dūjī durmat dard na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਗੀਤਾਂ ਰਾਗਾਂ ਦੀ ਸਹਾਇਤਾ ਨਾਲ ਜੀਵ ਦੀ) ਹੋਰ ਝਾਕ ਤੇ ਭੈੜੀ ਮਤਿ ਦੂਰ ਨਹੀਂ ਹੁੰਦੀ, ਆਤਮਕ ਰੋਗ ਨਹੀਂ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Эти занятия не устраняют дурной склонности и не исцеляют духовную болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35283,
          "is_rahao": false,
          "gurmukhi": "ਛੂਟੈ ਗੁਰਮੁਖਿ ਦਾਰੂ ਗੁਣ ਗਾਇ ॥੩॥",
          "roman": "chhūṭē gurmukh dārū guṇ gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦੂਜੀ ਝਾਕ ਤੋਂ, ਦੁਰਮਤਿ ਤੋਂ, ਆਤਮਕ ਰੋਗ ਤੋਂ ਉਹ ਮਨੁੱਖ) ਖ਼ਲਾਸੀ ਪਾਂਦਾ ਹੈ ਜੋ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ (ਇਹ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਹੀ ਇਹਨਾਂ ਰੋਗਾਂ ਦਾ) ਦਾਰੂ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Освобождается тот, кто, став гурмукхом, воспевает качества Господа — это и есть лекарство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35284,
          "is_rahao": false,
          "gurmukhi": "ਧੋਤੀ ਊਜਲ ਤਿਲਕੁ ਗਲਿ ਮਾਲਾ ॥",
          "roman": "dhotī ūjal tilak gal mālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਚਿੱਟੀ ਧੋਤੀ ਪਹਿਨਦੇ ਹਨ (ਮੱਥੇ ਉਤੇ) ਤਿਲਕ ਲਾਂਦੇ ਹਨ, ਗਲ ਵਿਚ ਮਾਲਾ ਪਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто носят чистую дхоти, ставят тилак и носят четки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35285,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਕ੍ਰੋਧੁ ਪੜਹਿ ਨਾਟ ਸਾਲਾ ॥",
          "roman": "antar krodh paṛah nāṭ sālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਵੇਦ ਆਦਿਕਾਂ ਦੇ ਮੰਤ੍ਰ) ਪੜ੍ਹਦੇ ਹਨ ਪਰ ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਕ੍ਰੋਧ ਪ੍ਰਬਲ ਹੈ ਉਹਨਾਂ ਦਾ ਉੱਦਮ ਇਉਂ ਹੀ ਹੈ ਜਿਵੇਂ ਕਿਸੇ ਨਾਟ-ਘਰ ਵਿਚ (ਨਾਟ-ਵਿੱਦਿਆ ਦੀ ਸਿਖਲਾਈ ਕਰ ਕਰਾ ਰਹੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "но внутри полны гнева и читают мантры — их деятельность подобна обучению актёрскому искусству."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35286,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਵਿਸਾਰਿ ਮਾਇਆ ਮਦੁ ਪੀਆ ॥",
          "roman": "nām visār māiā mad pīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਭੁਲਾ ਕੇ ਮਾਇਆ (ਦੇ ਮੋਹ) ਦੀ ਸ਼ਰਾਬ ਪੀਤੀ ਹੋਈ ਹੋਵੇ, (ਉਹਨਾਂ ਨੂੰ ਸੁਖ ਨਹੀਂ ਹੋ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Забыв Имя, они пьют вино привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35287,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਭਗਤਿ ਨਾਹੀ ਸੁਖੁ ਥੀਆ ॥੪॥",
          "roman": "bin gur bhagat nāhī sukh thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਨਹੀਂ ਹੋ ਸਕਦੀ, ਤੇ ਭਗਤੀ ਤੋਂ ਬਿਨਾ ਆਤਮਕ ਆਨੰਦ ਨਹੀਂ ਮਿਲਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Без Гуру нет преданности, а без преданности нет духовного счастья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35288,
          "is_rahao": false,
          "gurmukhi": "ਸੂਕਰ ਸੁਆਨ ਗਰਧਭ ਮੰਜਾਰਾ ॥",
          "roman": "sūkar suān gardhabh manjārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਸੂਰ, ਕੁੱਤੇ, ਖੋਤੇ, ਬਿੱਲੇ-"
            },
            "sahib_singh_ru": {
              "main": "Такие люди попадают в рождения свиней, собак, ослов и кошек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35289,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਮਲੇਛ ਨੀਚ ਚੰਡਾਲਾ ॥",
          "roman": "pasū malechh nīch chaṇḍālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਸ਼ੂ, ਮਲੇਛ, ਨੀਚ, ਚੰਡਾਲ ਆਦਿਕਾਂ ਦੀਆਂ ਜੂਨਾਂ ਵਿਚ ਭਵਾਇਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в животных, нечистых, низких и чандалов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35290,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਤੇ ਮੁਹੁ ਫੇਰੇ ਤਿਨੑ ਜੋਨਿ ਭਵਾਈਐ ॥",
          "roman": "gur te muh pherē tinh jon bhavāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਬੰਦਿਆਂ ਨੇ ਆਪਣਾ ਮੂੰਹ ਗੁਰੂ ਵਲੋਂ ਮੋੜਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "те, кто отвернулись от Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35291,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨਿ ਬਾਧਿਆ ਆਈਐ ਜਾਈਐ ॥੫॥",
          "roman": "bandhan bādhia āīai jāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਬੰਧਨ ਵਿਚ ਬੱਝਾ ਹੋਇਆ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Связанный узами майи, человек вращается в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35292,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਲਹੈ ਪਦਾਰਥੁ ॥",
          "roman": "gur sevā te lahē padārath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਦੱਸੀ ਸੇਵਾ ਦੀ ਰਾਹੀਂ ਹੀ ਮਨੁੱਖ ਨਾਮ-ਸਰਮਾਇਆ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через служение Гуру человек получает богатство Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35293,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਨਾਮੁ ਸਦਾ ਕਿਰਤਾਰਥੁ ॥",
          "roman": "hirdē nām sadā kiratārath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਦਾ ਵੱਸਦਾ ਹੈ ਉਹ (ਜੀਵਨ-ਜਾਤ੍ਰਾ ਵਿਚ) ਸਫਲ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, в чьём сердце живёт Имя, становится успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35294,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਦਰਗਹ ਪੂਛ ਨ ਹੋਇ ॥",
          "roman": "sāchī dargah pūchh na hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਦਰਗਾਹ ਵਿਚ ਉਸ ਪਾਸੋਂ ਲੇਖਾ ਨਹੀਂ ਮੰਗਿਆ ਜਾਂਦਾ (ਕਿਉਂਕਿ ਉਸ ਦੇ ਜ਼ਿੰਮੇ ਕੋਈ ਬਾਕੀ ਨਹੀਂ ਨਿਕਲਦੀ)।"
            },
            "sahib_singh_ru": {
              "main": "В истинном дворе от него не требуют отчёта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35295,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੇ ਹੁਕਮੁ ਸੀਝੈ ਦਰਿ ਸੋਇ ॥੬॥",
          "roman": "māne hukam sījhē dar soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ (ਸਿਰ ਮੱਥੇ) ਮੰਨਦਾ ਹੈ ਉਹ ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਕਾਮਯਾਬ ਹੋ ਜਾਂਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто принимает Волю, достигает успеха у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35296,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮਿਲੈ ਤ ਤਿਸ ਕਉ ਜਾਣੈ ॥",
          "roman": "satgur milē ta tis kau jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ਤਾਂ ਇਹ ਉਸ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек встречает Гуру, он познаёт Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35297,
          "is_rahao": false,
          "gurmukhi": "ਰਹੈ ਰਜਾਈ ਹੁਕਮੁ ਪਛਾਣੈ ॥",
          "roman": "rahē rajāī hukam pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ ਸਮਝਦਾ ਹੈ ਤੇ ਰਜ਼ਾ ਵਿਚ (ਰਾਜ਼ੀ) ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он понимает Волю и пребывает в ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35298,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਪਛਾਣਿ ਸਚੈ ਦਰਿ ਵਾਸੁ ॥",
          "roman": "hukam pachhāṇ sachē dar vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਨੂੰ ਸਮਝ ਕੇ ਉਸ ਦੇ ਦਰ ਤੇ ਥਾਂ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Поняв Волю, он получает место у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35299,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲ ਬਿਕਾਲ ਸਬਦਿ ਭਏ ਨਾਸੁ ॥੭॥",
          "roman": "kāl bikāl sabad bhae nās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਉਸ ਦੇ ਜਨਮ ਮਰਨ (ਦੇ ਗੇੜ) ਮੁੱਕ ਜਾਂਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Через Шабд прекращаются рождение и смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35300,
          "is_rahao": false,
          "gurmukhi": "ਰਹੈ ਅਤੀਤੁ ਜਾਣੈ ਸਭੁ ਤਿਸ ਕਾ ॥",
          "roman": "rahē atīt jāṇē sabh tis kā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਜੇਹੜਾ ਮਨੁੱਖ (ਅੰਤਰ ਆਤਮੇ ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਉਪਰਾਮ ਰਹਿੰਦਾ ਹੈ ਉਹ ਹਰੇਕ ਚੀਜ਼ ਨੂੰ ਪਰਮਾਤਮਾ ਦੀ (ਦਿੱਤੀ ਹੋਈ) ਹੀ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он остаётся отрешённым и видит всё как принадлежащее Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35301,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਅਰਪੈ ਹੈ ਇਹੁ ਜਿਸ ਕਾ ॥",
          "roman": "tan man arpē hē ih jis kā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਇਹ ਸਰੀਰ ਤੇ ਮਨ ਦਿੱਤਾ ਹੈ ਉਸ ਦੇ ਹਵਾਲੇ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он отдаёт тело и ум Тому, Кто их дал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35302,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਓਹੁ ਆਵੈ ਨਾ ਓਹੁ ਜਾਇ ॥",
          "roman": "nā oh āvē nā oh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚੋਂ ਬਚ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он больше не приходит и не уходит (не рождается и не умирает)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35303,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੇ ਸਾਚਿ ਸਮਾਇ ॥੮॥੨॥",
          "roman": "nānak sāche sāch samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸਦਾ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੮॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Он сливается с Истинным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3141,
      "rahao_verse_id": 35310,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35304,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੩ ਅਸਟਪਦੀ ਘਰੁ ੧੦",
          "roman": "bilāval mehlā 3 asṭpadī ghar 10",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਿਲਾਵਲੁ, ਘਰ ੧੦ ਵਿੱਚ ਗੁਰੂ ਅਮਰਦਾਸ ਜੀ ਦੀ ਅੱਠ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Рааг Билавал, дом 10, бани Гуру Амардаса из восьми строф."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35305,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Один Вечный есть, постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35306,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਕਊਆ ਮੁਖਿ ਚੁੰਚ ਗਿਆਨੁ ॥",
          "roman": "jag kauā mukh chunch giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ-ਵੇੜ੍ਹਿਆ ਮਨੁੱਖ ਕਾਂ (ਵਾਂਗ ਲੌਂ ਲੌਂ ਕਰਨ ਵਾਲਾ) ਹੈ, (ਨਿਰਾ) ਮੂੰਹੋਂ (ਹੀ) ਜ਼ਬਾਨੀ ਜ਼ਬਾਨੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ (ਦੱਸਦਾ ਰਹਿੰਦਾ ਹੈ, ਜਿਵੇਂ ਕਾਂ ਆਪਣੀ ਚੁੰਝ ਨਾਲ 'ਕਾਂ ਕਾਂ' ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Мирской человек подобен вороне — только устно говорит о знании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35307,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਲੋਭੁ ਝੂਠੁ ਅਭਿਮਾਨੁ ॥",
          "roman": "antar lobh jhūṭh abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਸ ਚੁੰਚ-ਗਿਆਨੀ ਦੇ) ਮਨ ਵਿਚ ਲੋਭ (ਟਿਕਿਆ ਰਹਿੰਦਾ) ਹੈ, ਝੂਠ (ਟਿਕਿਆ ਰਹਿੰਦਾ) ਹੈ, ਅਹੰਕਾਰ (ਟਿਕਿਆ ਰਹਿੰਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но внутри у него жадность, ложь и гордыня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35308,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਪਾਜੁ ਲਹਗੁ ਨਿਦਾਨਿ ॥੧॥",
          "roman": "bin nāvē pāj lahag nidān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਮ ਤੋਂ ਵਾਂਜੇ ਰਹਿ ਕੇ ਇਹ ਧਾਰਮਿਕ ਵਿਖਾਵਾ ਆਖ਼ਰ ਉੱਘੜ ਹੀ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени этот внешний показ в конце раскрывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35309,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰ ਸੇਵਿ ਨਾਮੁ ਵਸੈ ਮਨਿ ਚੀਤਿ ॥",
          "roman": "satgur sev nām vasē man chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ (ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਚਿੱਤ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через служение Сатгуру Имя поселяется в уме и сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35310,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਭੇਟੇ ਹਰਿ ਨਾਮੁ ਚੇਤਾਵੈ ਬਿਨੁ ਨਾਵੈ ਹੋਰ ਝੂਠੁ ਪਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur bheṭe har nām chetāvē bin nāvē hor jhūṭh parīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਸ ਨੂੰ (ਗੁਰੂ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਜਪਾਂਦਾ ਹੈ। ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਦੇ) ਨਾਮ (ਦੇ ਪਿਆਰ) ਤੋਂ ਬਿਨਾ ਹੋਰ ਪਿਆਰ ਝੂਠਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда встречается Гуру, он учит повторять Имя; без любви к Имени всякая любовь ложна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35311,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਕਹਿਆ ਸਾ ਕਾਰ ਕਮਾਵਹੁ ॥",
          "roman": "gur kahiā sā kār kamāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਕਾਰ ਕਰਿਆ ਕਰੋ ਜਿਹੜੀ ਗੁਰ ਨੇ ਦੱਸੀ ਹੈ (ਉਹ ਕਾਰ ਹੈ ਨਾਮ ਦਾ ਸਿਮਰਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Совершайте то дело, которое указал Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35312,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਚੀਨਿੑ ਸਹਜ ਘਰਿ ਆਵਹੁ ॥",
          "roman": "sabad chīnh sahaj ghar āvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਕੇ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਘਰ ਵਿਚ ਟਿਕਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Познавая Шабд, обретайте состояние внутреннего покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35313,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੈ ਨਾਇ ਵਡਾਈ ਪਾਵਹੁ ॥੨॥",
          "roman": "sāchē nāi vaḍāī pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜ ਕੇ (ਲੋਕ ਪਰਲੋਕ ਦੀ) ਵਡਿਆਈ ਹਾਸਲ ਕਰੋਗੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Соединяясь с Истинным Именем, обретёте величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35314,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਨ ਬੂਝੈ ਲੋਕ ਬੁਝਾਵੈ ॥",
          "roman": "āp na būjhē lok bujhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਹੜਾ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਬਾਰੇ) ਆਪ (ਤਾਂ ਕੁਝ) ਸਮਝਦਾ ਨਹੀਂ, ਪਰ ਲੋਕਾਂ ਨੂੰ ਸਮਝਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто сам не понимает, но учит других,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35315,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਅੰਧਾ ਅੰਧੁ ਕਮਾਵੈ ॥",
          "roman": "man kā andhā andh kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਆਪਣਾ ਆਪਾ (ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ) ਬਿਲਕੁਲ ਕੋਰਾ ਹੈ (ਅੰਨ੍ਹਾ ਹੈ, ਇਸ ਵਾਸਤੇ ਆਤਮਕ ਜੀਵਨ ਦੇ ਰਸਤੇ ਵਿਚ ਉਹ ਅੰਨ੍ਹਿਆਂ ਵਾਂਗ ਠੇਡੇ ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ) ਅੰਨ੍ਹਿਆਂ ਵਾਲਾ ਕੰਮ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "слеп умом и действует как слепой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35316,
          "is_rahao": false,
          "gurmukhi": "ਦਰੁ ਘਰੁ ਮਹਲੁ ਠਉਰੁ ਕੈਸੇ ਪਾਵੈ ॥੩॥",
          "roman": "dar ghar mahal ṭhauṛ kēse pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅਜਿਹਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਦਰ ਘਰ, ਪਰਮਾਤਮਾ ਦਾ ਮਹਲ, ਪਰਮਾਤਮਾ ਦਾ ਟਿਕਾਣਾ ਬਿਲਕੁਲ ਨਹੀਂ ਲੱਭ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Как он может найти обитель Господа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35317,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਸੇਵੀਐ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "har jīo sevīai antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Следует служить Господу, Знающему сердца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35318,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਜਿਸ ਕੀ ਜੋਤਿ ਸਮਾਨੀ ॥",
          "roman": "ghaṭ ghaṭ antar jis kī jot samānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈ, ਜੋ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чья светлая сущность присутствует в каждом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35319,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਨਾਲਿ ਕਿਆ ਚਲੈ ਪਹਨਾਮੀ ॥੪॥",
          "roman": "tis nāl kiā chalē pahnāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨਾਲ ਕੋਈ ਲੁਕਾ-ਛਿਪਾ ਨਹੀਂ ਚੱਲ ਸਕਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Перед Ним нельзя ничего скрыть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
