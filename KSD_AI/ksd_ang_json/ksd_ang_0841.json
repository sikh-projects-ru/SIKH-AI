{
  "ang": 841,
  "shabads": [
    {
      "shabad_id": 3151,
      "rahao_verse_id": 35676,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35667,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੩ ਵਾਰ ਸਤ ਘਰੁ ੧੦",
          "roman": "bilāval mahla 3 vār sat ghar 10",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਿਲਾਵਲੁ, ਘਰ ੧੦ ਵਿੱਚ ਗੁਰੂ ਅਮਰਦਾਸ ਜੀ ਦੀ ਬਾਣੀ 'ਵਾਰ ਸਤ'।"
            },
            "sahib_singh_ru": {
              "main": "Раг Билавал, дом 10, бани Гуру Амардаса Джи Вār Sat."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35668,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35669,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿਤ ਵਾਰਿ ਆਦਿ ਪੁਰਖੁ ਹੈ ਸੋਈ ॥",
          "roman": "ādit vār ād purakh hē soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਾਰੇ ਜਗਤ ਦਾ) ਮੂਲ ਉਹ ਅਕਾਲ ਪੁਰਖ-"
            },
            "sahib_singh_ru": {
              "main": "О брат, изначальной основой всего мира является тот Акал Пуракх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35670,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵਰਤੈ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "āpe vartē avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ (ਸਭ ਥਾਂ) ਮੌਜੂਦ ਹੈ, (ਉਸ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он сам присутствует повсюду, кроме него никого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35671,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਜਗੁ ਰਹਿਆ ਪਰੋਈ ॥",
          "roman": "ot pot jag rahia paroī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਸਾਰੇ ਜਗਤ ਨੂੰ ਤਾਣੇ ਪੇਟੇ ਵਾਂਗ (ਆਪਣੀ ਰਜ਼ਾ ਵਿਚ) ਪ੍ਰੋ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он пронизывает весь мир, словно нитью вплетает его в свою волю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35672,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਤਾ ਕਰੈ ਸੁ ਹੋਈ ॥",
          "roman": "āpe kartā karē so hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ) ਉਹ ਕੁਝ ਹੁੰਦਾ ਹੈ ਜੋ ਕਰਤਾਰ ਆਪ ਹੀ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Происходит только то, что сам Творец совершает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35673,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਦਾ ਸੁਖੁ ਹੋਈ ॥",
          "roman": "nām rate sadā sukh hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਨਾਮ ਵਿਚ ਰੰਗੇ ਹੋਏ ਮਨੁੱਖ ਨੂੰ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Окрашенный в Его Имя всегда обретает духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35674,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਵਿਰਲਾ ਬੂਝੈ ਕੋਈ ॥੧॥",
          "roman": "gurmukh virlā būjhē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕੋਈ ਵਿਰਲਾ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ (ਇਸ ਗੱਲ ਨੂੰ) ਸਮਝਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но лишь редкий гурмукх понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35675,
          "is_rahao": true,
          "gurmukhi": "ਹਿਰਦੈ ਜਪਨੀ ਜਪਉ ਗੁਣਤਾਸਾ ॥",
          "roman": "hirdē japnī japau guṇtāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ (ਆਪਣੇ) ਹਿਰਦੇ ਵਿਚ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ (ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ) ਨੂੰ ਜਪਦਾ ਹਾਂ (ਇਹੀ ਹੈ ਮੇਰੀ) ਮਾਲਾ।"
            },
            "sahib_singh_ru": {
              "main": "Я в сердце повторяю Имя сокровищницы добродетелей — это моя мала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35676,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਅਗਮ ਅਗੋਚਰੁ ਅਪਰੰਪਰ ਸੁਆਮੀ ਜਨ ਪਗਿ ਲਗਿ ਧਿਆਵਉ ਹੋਇ ਦਾਸਨਿ ਦਾਸਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har agam agochar aparampar suāmī jan pag lag dhiāvau hoi dāsan dāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਅਪਹੁੰਚ ਹੈ, ਪਰੇ ਤੋਂ ਪਰੇ ਹੈ, ਸਭ ਦਾ ਮਾਲਕ ਹੈ, ਉਸ ਤਕ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ। ਮੈਂ ਤਾਂ ਸੰਤ ਜਨਾਂ ਦੀ ਚਰਨੀਂ ਲੱਗ ਕੇ ਸੰਤ ਜਨਾਂ ਦੇ ਦਾਸਾਂ ਦਾ ਦਾਸ ਬਣ ਕੇ ਉਸ ਨੂੰ ਸਿਮਰਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Бог недостижим и непостижим, владыка всего, я, став слугой слуг святых, вспоминаю Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35677,
          "is_rahao": false,
          "gurmukhi": "ਸੋਮਵਾਰਿ ਸਚਿ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "somvār sach rahia samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ) ਸਦਾ-ਥਿਰ ਪਰਮਾਤਮਾ (ਦੀ ਯਾਦ) ਵਿਚ ਲੀਨ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто пребывает в Истине через слово Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35678,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਕੀਮਤਿ ਕਹੀ ਨ ਜਾਇ ॥",
          "roman": "tis kī kīmat kahī na jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦਾ ਆਤਮਕ ਜੀਵਨ ਇਤਨਾ ਉੱਚਾ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ) ਉਸ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "ценность его невозможно выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35679,
          "is_rahao": false,
          "gurmukhi": "ਆਖਿ ਆਖਿ ਰਹੇ ਸਭਿ ਲਿਵ ਲਾਇ ॥",
          "roman": "ākh ākh rahe sabh liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਉੱਦਮ ਨਾਲ ਸੁਰਤਾਂ ਜੋੜਨ ਵਾਲੇ ਅਤੇ ਸਿਫ਼ਤਾਂ ਆਖਣ ਵਾਲੇ ਮਨੁੱਖ) ਸਿਫ਼ਤਾਂ ਆਖ ਆਖ ਕੇ ਅਤੇ ਸੁਰਤ ਜੋੜ ਜੋੜ ਕੇ ਸਾਰੇ ਹੀ ਥੱਕ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все устают, произнося хвалы и стараясь сосредоточиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35680,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਦੇਵੈ ਤਿਸੁ ਪਲੈ ਪਾਇ ॥",
          "roman": "jis devē tis palē pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਸਿਮਰਨ ਤੇ ਯਾਦ ਦੀ ਦਾਤਿ) ਜਿਸ (ਮਨੁੱਖ) ਨੂੰ (ਪਰਮਾਤਮਾ ਆਪ) ਦੇਂਦਾ ਹੈ, ਉਸ ਨੂੰ (ਹੀ) ਮਿਲਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но дар получает лишь тот, кому Он сам даёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35681,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰੁ ਲਖਿਆ ਨ ਜਾਇ ॥",
          "roman": "agam agochar lakhia na jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਅਪਹੁੰਚ ਹੈ, ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ, ਉਸ ਦਾ ਸਹੀ ਸਰੂਪ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Бог непостижим и недосягаем, Его сущность нельзя описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35682,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਹਰਿ ਰਹਿਆ ਸਮਾਇ ॥੨॥",
          "roman": "gur kē sabad har rahia samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਹੀ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਵਿਚ ਲੀਨ ਰਹਿ ਸਕਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Через слово Гуру человек сливается с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35683,
          "is_rahao": false,
          "gurmukhi": "ਮੰਗਲਿ ਮਾਇਆ ਮੋਹੁ ਉਪਾਇਆ ॥",
          "roman": "mangal māiā moh upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਨੇ) ਮਾਇਆ ਦਾ ਮੋਹ (ਆਪ ਹੀ) ਪੈਦਾ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он сам создал привязанность к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35684,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਿਰਿ ਸਿਰਿ ਧੰਧੈ ਲਾਇਆ ॥",
          "roman": "āpe sir sir dhaṅdhē lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ (ਇਸ ਮੋਹ ਨੂੰ) ਹਰੇਕ (ਜੀਵ ਦੇ) ਸਿਰ ਉੱਤੇ (ਥਾਪ ਕੇ ਹਰੇਕ ਨੂੰ ਮਾਇਆ ਦੇ) ਧੰਧੇ ਵਿਚ ਲਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И сам возложил её на головы всех, вовлекая в дела майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35685,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬੁਝਾਏ ਸੋਈ ਬੂਝੈ ॥",
          "roman": "āp bujhāe soī būjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਪਰਮਾਤਮਾ) ਆਪ ਸਮਝ ਬਖ਼ਸ਼ਦਾ ਹੈ, ਉਹੀ (ਇਸ ਮੋਹ ਦੀ ਖੇਡ ਨੂੰ) ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Понимает лишь тот, кому Он даёт понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35686,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਦਰੁ ਘਰੁ ਸੂਝੈ ॥",
          "roman": "gur kē sabad dar ghar sūjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤ ਨਾਲ ਉਸ ਨੂੰ (ਪਰਮਾਤਮਾ ਦਾ) ਦਰ-ਘਰ ਦਿੱਸ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через слово Гуру ему открывается дом Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35687,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਕਰੇ ਲਿਵ ਲਾਇ ॥",
          "roman": "prem bhagat kare liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੁਰਤ ਜੋੜ ਕੇ ਪ੍ਰੇਮ ਨਾਲ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он с любовью совершает бхакти, сосредоточив ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35688,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮਮਤਾ ਸਬਦਿ ਜਲਾਇ ॥੩॥",
          "roman": "haumē mamtā sabad jalāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ, ਇਸ ਤਰ੍ਹਾਂ) ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਆਪਣੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਅਤੇ (ਮਾਇਆ ਦੀ) ਮਮਤਾ ਸਾੜ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И словом Гуру сжигает эго и привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35689,
          "is_rahao": false,
          "gurmukhi": "ਬੁਧਵਾਰਿ ਆਪੇ ਬੁਧਿ ਸਾਰੁ ॥",
          "roman": "budhvār āpe budh sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ) ਆਪ ਹੀ (ਮਨੁੱਖ ਨੂੰ) ਸ੍ਰੇਸ਼ਟ ਬੁੱਧੀ (ਬਖ਼ਸ਼ਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Он сам даёт высшую мудрость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35690,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕਰਣੀ ਸਬਦੁ ਵੀਚਾਰੁ ॥",
          "roman": "gurmukh karaṇī sabad vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਵਿਚ ਰੱਖ ਕੇ ਉੱਚਾ ਆਚਰਨ, ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਅਤੇ (ਆਪਣੇ ਗੁਣਾਂ ਦੀ) ਵਿਚਾਰ (ਬਖ਼ਸ਼ਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "И через Гуру даёт праведные дела и размышление над словом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35691,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਮਨੁ ਨਿਰਮਲੁ ਹੋਇ ॥",
          "roman": "nām rate man nirmal hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ ਉਸ ਪਰਮਾਤਮਾ ਦੇ) ਨਾਮ ਵਿਚ ਰੰਗੇ ਹੋਏ ਮਨੁੱਖ ਦਾ ਮਨ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Окрашенный в Имя очищает ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35692,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵੈ ਹਉਮੈ ਮਲੁ ਖੋਇ ॥",
          "roman": "har guṇ gāvē haumē mal khoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਦੀ ਮੈਲ ਦੂਰ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Поёт добродетели Бога, устраняя грязь эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35693,
          "is_rahao": false,
          "gurmukhi": "ਦਰਿ ਸਚੈ ਸਦ ਸੋਭਾ ਪਾਏ ॥",
          "roman": "dar sachē sad sobhā pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਸਦਾ ਸੋਭਾ ਖੱਟਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В обители Истины обретает вечную славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35694,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਗੁਰ ਸਬਦਿ ਸੁਹਾਏ ॥੪॥",
          "roman": "nām rate gur sabad suhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਰੰਗੇ ਹੋਏ ਮਨੁੱਖ ਸੋਹਣੇ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Окрашенные в Имя через слово Гуру становятся прекрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35695,
          "is_rahao": false,
          "gurmukhi": "ਲਾਹਾ ਨਾਮੁ ਪਾਏ ਗੁਰ ਦੁਆਰਿ ॥",
          "roman": "lāhā nām pāe gur duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਦਰ ਤੇ (ਰਹਿ ਕੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ-ਲਾਭ ਖੱਟ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У дверей Гуру человек получает прибыль Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35696,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਦੇਵੈ ਦੇਵਣਹਾਰੁ ॥",
          "roman": "āpe devē devṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਦਾਤ ਹੈ, ਤੇ ਇਹ ਦਾਤਿ) ਦੇਣ ਦੀ ਸਮਰਥਾ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪ ਹੀ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но даёт это сам Дающий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35697,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੇਵੈ ਤਿਸ ਕਉ ਬਲਿ ਜਾਈਐ ॥",
          "roman": "jo devē tis kau bal jāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਜਿਹੜਾ ਪ੍ਰਭੂ (ਇਹ ਦਾਤਿ) ਦੇਂਦਾ ਹੈ ਉਸ ਤੋਂ (ਸਦਾ) ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тому, кто даёт, следует быть преданным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35698,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਆਪੁ ਗਵਾਈਐ ॥",
          "roman": "gur parsādī āp gavāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਆਪਣੇ ਅੰਦਰੋਂ) ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру нужно избавиться от эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35699,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਰਖਹੁ ਉਰ ਧਾਰਿ ॥",
          "roman": "nānak nām rakho ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਈ ਰੱਖੋ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: удерживайте Имя в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35700,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵਣਹਾਰੇ ਕਉ ਜੈਕਾਰੁ ॥੫॥",
          "roman": "devṇhāre kau jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਉਸ ਸਭ ਕੁਝ ਦੇ ਸਕਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਸਦਾ ਕਰਦੇ ਰਹੋ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "И прославляйте Дающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35701,
          "is_rahao": false,
          "gurmukhi": "ਵੀਰਵਾਰਿ ਵੀਰ ਭਰਮਿ ਭੁਲਾਏ ॥",
          "roman": "vīrvār vīr bharam bhulāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਬਵੰਜਾ) ਬੀਰਾਂ ਨੂੰ (ਭੀ ਪਰਮਾਤਮਾ ਨੇ) ਭਟਕਣਾ ਵਿਚ ਪਾ ਕੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ) ਭੁਲਾਈ ਰੱਖਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Даже сильных Он вводит в заблуждение майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35702,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਤ ਭੂਤ ਸਭਿ ਦੂਜੈ ਲਾਏ ॥",
          "roman": "pret bhūt sabh dūjē lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਭੂਤ ਪ੍ਰੇਤ ਭੀ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਲਾਏ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все духи также вовлечены в двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35703,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਪਾਏ ਕਰਿ ਵੇਖੈ ਵੇਕਾ ॥",
          "roman": "āp upāe kar vekhē vekā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਆਪ (ਹੀ ਇਹ ਸਾਰੇ) ਪੈਦਾ ਕੀਤੇ, (ਇਹਨਾਂ ਨੂੰ) ਵੱਖ ਵੱਖ ਕਿਸਮਾਂ ਦੇ ਬਣਾ ਕੇ (ਸਭ ਦੀ) ਸੰਭਾਲ (ਭੀ) ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он сам создал всех и наблюдает за ними."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35704,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨਾ ਕਰਤੇ ਤੇਰੀ ਟੇਕਾ ॥",
          "roman": "sabhna kartē terī ṭekā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਰਤਾਰ! ਸਭ ਜੀਵਾਂ ਨੂੰ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Все существа опираются только на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35705,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਤੇਰੀ ਸਰਣਾਈ ॥",
          "roman": "jīa jant terī saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵ ਜੰਤ ਤੇਰੀ ਸਰਨ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все живые существа находятся под Твоей защитой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35706,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮਿਲੈ ਜਿਸੁ ਲੈਹਿ ਮਿਲਾਈ ॥੬॥",
          "roman": "so milē jis lēh milāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਹੀ ਤੈਨੂੰ) ਮਿਲਦਾ ਹੈ ਜਿਸ ਨੂੰ ਤੂੰ ਆਪ (ਆਪਣੇ ਨਾਲ) ਮਿਲਾਂਦਾ ਹੈਂ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Тот соединяется с Тобой, кого Ты соединяешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35707,
          "is_rahao": false,
          "gurmukhi": "ਸੁਕ੍ਰਵਾਰਿ ਪ੍ਰਭੁ ਰਹਿਆ ਸਮਾਈ ॥",
          "roman": "sukravār prabh rahia samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ) ਪਰਮਾਤਮਾ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог пронизывает всё творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35708,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਪਾਇ ਸਭ ਕੀਮਤਿ ਪਾਈ ॥",
          "roman": "āp upāe sabh kīmat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸ੍ਰਿਸ਼ਟੀ ਨੂੰ) ਆਪ (ਹੀ) ਪੈਦਾ ਕਰ ਕੇ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਦੀ ਕਦਰ ਭੀ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Создав всё, Он знает истинную ценность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35709,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਵੈ ਸੁ ਕਰੈ ਬੀਚਾਰੁ ॥",
          "roman": "gurmukh hovē su karē bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੁੰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਨੂੰ) ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гурмукх размышляет о Его качествах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35710,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸੰਜਮੁ ਕਰਣੀ ਹੈ ਕਾਰ ॥",
          "roman": "sach sanjam karaṇī hē kār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ, ਅਤੇ ਇੰਦ੍ਰਿਆਂ ਨੂੰ ਵਿਕਾਰਾਂ ਵਲੋਂ ਬਚਾਈ ਰੱਖਣ ਦਾ ਉੱਦਮ-ਇਹ ਉਸ ਮਨੁੱਖ ਦਾ ਨਿੱਤ ਦਾ ਕਰਤੱਬ, ਨਿੱਤ ਦੀ ਕਾਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его делом становится память об Истине и самоконтроль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35711,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤੁ ਨੇਮੁ ਨਿਤਾਪ੍ਰਤਿ ਪੂਜਾ ॥ ਬਿਨੁ ਬੂਝੇ ਸਭੁ ਭਾਉ ਹੈ ਦੂਜਾ ॥੭॥",
          "roman": "varat nem nitāprat pūjā bin būjhe sabh bhāo hē dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਵਰਤ ਰੱਖਣਾ, ਕਰਮ ਕਾਂਡ ਦਾ ਹਰੇਕ ਨੇਮ ਨਿਬਾਹੁਣਾ, ਰੋਜ਼ਾਨਾ ਦੇਵ-ਪੂਜਾ- ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਤੋਂ ਬਿਨਾ ਇਹ ਸਾਰਾ ਉੱਦਮ ਮਾਇਆ ਦਾ ਪਿਆਰ (ਹੀ ਪੈਦਾ ਕਰਨ ਵਾਲਾ) ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Посты и ритуалы без понимания лишь усиливают привязанность к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35712,
          "is_rahao": false,
          "gurmukhi": "ਛਨਿਛਰਵਾਰਿ ਸਉਣ ਸਾਸਤ ਬੀਚਾਰੁ ॥",
          "roman": "chhanichharvār sauṇ sāstat bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਛੱਡ ਕੇ) ਸ਼ੋਨਕ ਦਾ ਜੋਤਿਸ਼ ਸ਼ਾਸਤ੍ਰ (ਆਦਿਕ) ਵਿਚਾਰਦੇ ਰਹਿਣਾ-"
            },
            "sahib_singh_ru": {
              "main": "Размышление над писаниями без Имени —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35713,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮੇਰਾ ਭਰਮੈ ਸੰਸਾਰੁ ॥",
          "roman": "haumē merā bharmē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦੇ ਕਾਰਣ) ਜਗਤ ਮਮਤਾ ਅਤੇ ਹਉਮੈ ਵਿਚ ਭਟਕਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "приводит мир к блужданию в эго и привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35714,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖੁ ਅੰਧਾ ਦੂਜੈ ਭਾਇ ॥",
          "roman": "manmukh andhā dūjē bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਅੰਨ੍ਹਾ, ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Следующий за умом слеп и погружён в двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35715,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਦਰਿ ਬਾਧਾ ਚੋਟਾ ਖਾਇ ॥",
          "roman": "jam dar bādhā choṭā khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਜਿਹਾ ਮਨੁੱਖ) ਜਮਰਾਜ ਦੇ ਦਰ ਤੇ ਬੱਝਾ ਹੋਇਆ (ਵਿਕਾਰਾਂ ਦੀਆਂ) ਸੱਟਾਂ ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он связан у врат смерти и терпит удары."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35716,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਸਦਾ ਸੁਖੁ ਪਾਏ ॥",
          "roman": "gur parsādī sadā sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру человек обретает вечное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35717,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਕਰਣੀ ਸਾਚਿ ਲਿਵ ਲਾਏ ॥੮॥",
          "roman": "sach karaṇī sāch liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਨੂੰ (ਆਪਣਾ ਰੋਜ਼ਾਨਾ) ਕਰਤੱਬ ਬਣਾਂਦਾ ਹੈ ਅਤੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਵਿਚ ਸੁਰਤ ਜੋੜੀ ਰੱਖਦਾ ਹੈ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Когда делает Истину своим делом и соединяется с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35718,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵਹਿ ਸੇ ਵਡਭਾਗੀ ॥",
          "roman": "satgur seveh se vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਮਨੁੱਖ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਹੁੰਦੇ ਹਨ ਜਿਹੜੇ ਗੁਰੂ ਦੀ ਸਰਨ ਆ ਪੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Служащие Сатгуру — очень удачливы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35719,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮਾਰਿ ਸਚਿ ਲਿਵ ਲਾਗੀ ॥",
          "roman": "haumē mār sach liv lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਮੁਕਾ ਕੇ (ਉਹਨਾਂ ਦੀ) ਸੁਰਤ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਵਿਚ ਲੱਗ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Уничтожив эго, они соединяются с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35720,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਰੰਗਿ ਰਾਤੇ ਸਹਜਿ ਸੁਭਾਇ ॥",
          "roman": "terē rang rāte sahaj subhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਣ ਵਾਲੇ ਮਨੁੱਖ) ਤੇਰੇ ਪਿਆਰ-ਰੰਗ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они естественно окрашены в Твою любовь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
