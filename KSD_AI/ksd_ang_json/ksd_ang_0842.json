{
  "ang": 842,
  "shabads": [
    {
      "shabad_id": 3151,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35721,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਸੁਖਦਾਤਾ ਲੈਹਿ ਮਿਲਾਇ ॥",
          "roman": "tū sukhdātā lēh milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਸੁਖ ਦੇਣ ਵਾਲਾ ਤੂੰ (ਆਪ ਹੀ ਉਹਨਾਂ ਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਮਿਲਾ ਲੈਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты сам соединяешь их с собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35722,
          "is_rahao": false,
          "gurmukhi": "ਏਕਸ ਤੇ ਦੂਜਾ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "ekas te dūjā nāhī koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਕ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ (ਉਸ ਵਰਗਾ) ਹੋਰ ਕੋਈ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Единого нет другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35723,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਬੂਝੈ ਸੋਝੀ ਹੋਇ ॥੯॥",
          "roman": "gurmukh būjhē sojhī hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ, ਉਹ (ਇਸ ਗੱਲ ਨੂੰ) ਸਮਝ ਲੈਂਦਾ ਹੈ, (ਉਸ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਆ ਜਾਂਦੀ ਹੈ) ॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "Гурмукх понимает это и обретает знание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35724,
          "is_rahao": false,
          "gurmukhi": "ਪੰਦ੍ਰਹ ਥਿਤਂੀ ਤੈ ਸਤ ਵਾਰ ॥",
          "roman": "pandraḥ thitīṅ tē sat vār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਵੇਂ) ਪੰਦ੍ਰਾਂ ਥਿੱਤਾਂ ਅਤੇ ਸੱਤ ਵਾਰ,"
            },
            "sahib_singh_ru": {
              "main": "Как пятнадцать фаз и семь дней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35725,
          "is_rahao": false,
          "gurmukhi": "ਮਾਹਾ ਰੁਤੀ ਆਵਹਿ ਵਾਰ ਵਾਰ ॥",
          "roman": "māhā rutī āveh vār vār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਹੀਨੇ, ਰੁੱਤਾਂ ਮੁੜ ਮੁੜ ਆਉਂਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "месяцы и сезоны приходят снова и снова,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35726,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨਸੁ ਰੈਣਿ ਤਿਵੈ ਸੰਸਾਰੁ ॥",
          "roman": "dinas rēn tivē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਤ, ਦਿਨ (ਦੀ ਗਤੀ ਵਾਂਗ) ਤਿਵੇਂ ਇਹ ਜਗਤ ਹੈ (ਭਾਵ, ਜਗਤ ਦੇ ਜੀਵ ਜੰਮਦੇ ਮਰਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "так же и мир подобен дню и ночи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35727,
          "is_rahao": false,
          "gurmukhi": "ਆਵਾ ਗਉਣੁ ਕੀਆ ਕਰਤਾਰਿ ॥",
          "roman": "āvā gauṇ kīā kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਨੇ (ਆਪ ਹੀ ਜੀਵਾਂ ਵਾਸਤੇ) ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਬਣਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Творец установил круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35728,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਸਾਚੁ ਰਹਿਆ ਕਲ ਧਾਰਿ ॥",
          "roman": "nihchal sāch rahia kal dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਟੱਲ ਰਹਿਣ ਵਾਲਾ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਹੀ ਹੈ ਜੋ (ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ ਆਪਣੀ) ਸੱਤਾ ਟਿਕਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только Истина неизменна и поддерживает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35729,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਬੂਝੈ ਕੋ ਸਬਦੁ ਵੀਚਾਰਿ ॥੧੦॥੧॥",
          "roman": "nānak gurmukh būjhē ko sabad vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਕੋਈ (ਭਾਗਾਂ ਵਾਲਾ) ਮਨੁੱਖ (ਗੁਰੂ ਦੇ) ਸ਼ਬਦ ਨੂੰ (ਆਪਣੇ) ਮਨ ਵਿਚ ਵਸਾ ਕੇ (ਇਸ ਗੱਲ ਨੂੰ) ਸਮਝ ਲੈਂਦਾ ਹੈ ॥੧੦॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак: лишь гурмукх, размышляя над словом, понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3152,
      "rahao_verse_id": 35738,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35730,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੩ ॥",
          "roman": "bilāval mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35731,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖੁ ਆਪੇ ਸ੍ਰਿਸਟਿ ਸਾਜੇ ॥",
          "roman": "ād purakh āpe srisht sāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਰੇ ਜਗਤ ਦਾ ਮੂਲ ਅਕਾਲ ਪੁਰਖ ਆਪ ਹੀ ਜਗਤ ਨੂੰ ਪੈਦਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Изначальный Творец Сам создает весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35732,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਮਾਇਆ ਮੋਹਿ ਪਾਜੇ ॥",
          "roman": "jīa jant māiā moh pāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ) ਜੀਵਾਂ ਨੂੰ (ਉਸ ਨੇ) ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਜੋੜਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Согласно совершенным деяниям Он связал живых существ узами привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35733,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਪਰਪੰਚਿ ਲਾਗੇ ॥",
          "roman": "dūjē bhāe parpanch lāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾ ਕੇ) ਹੋਰ ਪਿਆਰ ਵਿਚ ਦਿੱਸਦੇ ਜਗਤ ਦੇ ਮੋਹ ਵਿਚ ਫਸੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Забыв Бога, люди увлечены ложной привязанностью к видимому миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35734,
          "is_rahao": false,
          "gurmukhi": "ਆਵਹਿ ਜਾਵਹਿ ਮਰਹਿ ਅਭਾਗੇ ॥",
          "roman": "āveh jāveh mareh abhāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਜਿਹੇ) ਭਾਗਹੀਨ ਜੀਵ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਏ ਰਹਿੰਦੇ ਹਨ, ਆਤਮਕ ਮੌਤ ਸਹੇੜੀ ਰੱਖਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Такие несчастные существа остаются в круге рождения и смерти и несут духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35735,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਭੇਟਿਐ ਸੋਝੀ ਪਾਇ ॥",
          "roman": "satgur bhetai sojhī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਕਿਸੇ ਭਾਗਾਂ ਵਾਲੇ ਨੂੰ) ਗੁਰੂ ਮਿਲ ਪਏ, ਤਾਂ ਉਹ (ਆਤਮਕ ਜੀਵਨ ਦੀ) ਸਮਝ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если кому-то по судьбе встречается Гуру, он обретает понимание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35736,
          "is_rahao": false,
          "gurmukhi": "ਪਰਪੰਚੁ ਚੂਕੈ ਸਚਿ ਸਮਾਇ ॥੧॥",
          "roman": "parpanch chūkē sach samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਜਗਤ ਦਾ ਮੋਹ ਮੁੱਕ ਜਾਂਦਾ ਹੈ, (ਉਹ ਮਨੁੱਖ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ (ਦੀ ਯਾਦ) ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда исчезает привязанность к миру, и человек пребывает в Истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35737,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੈ ਮਸਤਕਿ ਲਿਖਿਆ ਲੇਖੁ ॥",
          "roman": "jā kē mastak likhiā lekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਉੱਤੇ (ਮਨੁੱਖ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ ਪਰਮਾਤਮਾ ਵਲੋਂ) ਲੇਖ ਲਿਖਿਆ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! У кого на челе записано предначертание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35738,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕੈ ਮਨਿ ਵਸਿਆ ਪ੍ਰਭੁ ਏਕੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā kē man vasiā prabh ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਮਨੁੱਖ) ਦੇ ਮਨ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ (ਹੀ) ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в сердце того пребывает один Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35739,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਿਸਟਿ ਉਪਾਇ ਆਪੇ ਸਭੁ ਵੇਖੈ ॥",
          "roman": "srisht upāe āpe sabh vekhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਗਤ ਪੈਦਾ ਕਰ ਕੇ (ਪਰਮਾਤਮਾ) ਆਪ ਹੀ ਹਰੇਕ ਦੀ ਸੰਭਾਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Создав мир, Он Сам заботится обо всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35740,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਮੇਟੈ ਤੇਰੈ ਲੇਖੈ ॥",
          "roman": "koe na metē terē lekhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜੀਵ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ ਉਸ ਦੇ ਮੱਥੇ ਉੱਤੇ ਜਿਹੜਾ ਲੇਖ ਤੂੰ ਲਿਖਦਾ ਹੈਂ) ਤੇਰੇ (ਉਸ ਲਿਖੇ) ਲੇਖ ਨੂੰ ਕੋਈ ਜੀਵ (ਆਪਣੇ ਉੱਦਮ ਨਾਲ) ਮਿਟਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не может стереть написанное Тобой предначертание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35741,
          "is_rahao": false,
          "gurmukhi": "ਸਿਧ ਸਾਧਿਕ ਜੇ ਕੋ ਕਹੈ ਕਹਾਏ ॥",
          "roman": "sidh sādhik je ko kahē kahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਆਪਣੀ ਹਉਮੈ ਦੇ ਆਸਰੇ) ਜੇ ਕੋਈ ਮਨੁੱਖ (ਆਪਣੇ ਆਪ ਨੂੰ) ਸਿੱਧ ਆਖਦਾ ਅਖਵਾਂਦਾ ਹੈ, ਸਾਧਿਕ ਆਖਦਾ ਅਖਵਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то по эго называет себя сидхом или подвижником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35742,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮੇ ਭੂਲਾ ਆਵੈ ਜਾਏ ॥",
          "roman": "bharme bhūlā āvē jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਹਉਮੈ ਦੀ) ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ ਕੁਰਾਹੇ ਪਿਆ ਰਹਿੰਦਾ ਹੈ, ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "он заблуждается и остается в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35743,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵੈ ਸੋ ਜਨੁ ਬੂਝੈ ॥",
          "roman": "satgur sevē so jan būjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਹੜਾ ਮਨੁੱਖ (ਆਪਣੀ ਹਉਮੈ ਦੀ ਟੇਕ ਛੱਡ ਕੇ) ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ (ਜੀਵਨ ਦਾ ਸਹੀ ਰਸਤਾ ਸਮਝ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто служит Гуру, понимает истинный путь жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35744,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮਾਰੇ ਤਾ ਦਰੁ ਸੂਝੈ ॥੨॥",
          "roman": "haumē māre tā dar sūjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ (ਆਪਣੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਮੁਕਾਂਦਾ ਹੈ, ਤਦੋਂ (ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ) ਦਰ ਦਿੱਸ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Когда он побеждает эго, ему открывается Божественный двор."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35745,
          "is_rahao": false,
          "gurmukhi": "ਏਕਸੁ ਤੇ ਸਭੁ ਦੂਜਾ ਹੂਆ ॥",
          "roman": "ekas te sabh dūjā hūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਤੋਂ) ਵੱਖਰਾ ਦਿੱਸਦਾ ਇਹ ਸਾਰਾ ਜਗਤ ਇਕ ਪਰਮਾਤਮਾ ਤੋਂ ਹੀ ਬਣਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Весь этот мир, кажущийся отдельным, создан из Единого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35746,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਵਰਤੈ ਅਵਰੁ ਨ ਬੀਆ ॥",
          "roman": "eko vartē avar na bīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੇ ਜਗਤ ਵਿਚ) ਇਕ ਪ੍ਰਭੂ ਹੀ ਮੌਜੂਦ ਹੈ, (ਉਸ ਤੋਂ ਬਿਨਾ) ਕੋਈ ਹੋਰ ਦੂਜਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Везде присутствует только один Бог, кроме Него нет другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35747,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੇ ਤੇ ਜੇ ਏਕੋ ਜਾਣੈ ॥",
          "roman": "dūje te je eko jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਮਨੁੱਖ) ਇਸ ਵੱਖਰੇ ਦਿੱਸ ਰਹੇ ਜਗਤ (ਦੇ ਮੋਹ) ਤੋਂ (ਉੱਚਾ ਹੋ ਕੇ) ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਈ ਰੱਖੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек, поднявшись над привязанностью к миру, соединяется с Единым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35748,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਹਰਿ ਦਰਿ ਨੀਸਾਣੈ ॥",
          "roman": "gur kē sabad har dar nīsāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ ਰਾਹਦਾਰੀ ਸਮੇਤ (ਬਿਨਾ ਰੋਕ-ਟੋਕ) ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ (ਪਹੁੰਚ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "то через Слово Гуру он достигает Божьего двора без препятствий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35749,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟੇ ਤਾ ਏਕੋ ਪਾਏ ॥",
          "roman": "satgur bhete tā eko pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਮਨੁੱਖ ਨੂੰ) ਗੁਰੂ ਮਿਲ ਪਏ, ਤਾਂ ਉਹ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਮਿਲਾਪ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, человек достигает Единого Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35750,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਹੁ ਦੂਜਾ ਠਾਕਿ ਰਹਾਏ ॥੩॥",
          "roman": "vichah dūjā ṭhāk rahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਆਪਣੇ) ਅੰਦਰੋਂ ਵੱਖਰੇ ਦਿੱਸ ਰਹੇ ਜਗਤ ਦਾ ਮੋਹ ਰੋਕ ਰੱਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и устраняет изнутри привязанность к двойственности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35751,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਦਾ ਸਾਹਿਬੁ ਡਾਢਾ ਹੋਇ ॥",
          "roman": "jis dā sāhib dāṛhā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮਾਇਆ ਦੇ ਕਾਮਾਦਿਕ ਸੂਰਮੇ ਹਨ ਤਾਂ ਬੜੇ ਬਲੀ, ਪਰ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਸਿਰ ਉੱਤੇ ਰਾਖਾ ਸਭ ਤੋਂ ਬਲੀ ਮਾਲਕ-ਪ੍ਰਭੂ ਆਪ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если над человеком стоит сильный Владыка-Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35752,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਨੋ ਮਾਰਿ ਨ ਸਾਕੈ ਕੋਇ ॥",
          "roman": "tis no mār na sākē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕੋਈ (ਕਾਮਾਦਿਕ ਵੈਰੀ) ਢਾਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "никто не может повредить ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35753,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬ ਕੀ ਸੇਵਕੁ ਰਹੈ ਸਰਣਾਈ ॥",
          "roman": "sāhib kī sevak rahē saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸੇਵਕ (ਆਪਣੇ) ਮਾਲਕ-ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Потому что слуга пребывает в прибежище Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35754,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਬਖਸੇ ਦੇ ਵਡਿਆਈ ॥",
          "roman": "āpe bakhse de vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ (ਉਸ ਉਤੇ) ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ, (ਤੇ, ਉਸ ਨੂੰ) ਇੱਜ਼ਤ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и Он Сам дарует ему милость и честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35755,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਤੇ ਊਪਰਿ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "tis te ūpar nāhī koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ (ਪਰਮਾਤਮਾ) ਨਾਲੋਂ ਵੱਡਾ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нет никого выше Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35756,
          "is_rahao": false,
          "gurmukhi": "ਕਉਣੁ ਡਰੈ ਡਰੁ ਕਿਸ ਕਾ ਹੋਇ ॥੪॥",
          "roman": "kaun ḍarē ḍar kis kā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕ ਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਬਣ ਜਾਂਦਾ ਹੈ, ਇਸ ਵਾਸਤੇ) ਕਿਸੇ ਤੋਂ ਨਹੀਂ ਡਰਦਾ, ਉਸ ਨੂੰ ਕਿਸੇ (ਕਾਮਾਦਿਕ ਵੈਰੀ) ਦਾ ਡਰ-ਦਬਾਉ ਨਹੀਂ ਹੁੰਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда человек никого не боится и не испытывает страха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35757,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤੀ ਸਾਂਤਿ ਵਸੈ ਸਰੀਰ ॥",
          "roman": "gurmatī sānt vasē sarīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਮਤਿ ਉੱਤੇ ਤੁਰ ਕੇ (ਵਡਭਾਗੀ ਮਨੁੱਖ ਦੇ) ਹਿਰਦੇ ਵਿਚ ਸ਼ਾਂਤੀ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Следуя наставлению Гуру, в сердце поселяется покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35758,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਚੀਨਿੑ ਫਿਰਿ ਲਗੈ ਨ ਪੀਰ ॥",
          "roman": "sabad chīnh phir lagē na pīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਕੇ ਉਸ ਨੂੰ (ਕਾਮਾਦਿਕ ਵੈਰੀ ਤੋਂ ਕੋਈ) ਕਲੇਸ਼ ਨਹੀਂ ਪੋਹ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Соединяясь со Словом Гуру, человек освобождается от страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35759,
          "is_rahao": false,
          "gurmukhi": "ਆਵੈ ਨ ਜਾਇ ਨਾ ਦੁਖੁ ਪਾਏ ॥",
          "roman": "āvē na jāi na dukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ, ਉਹ (ਇਸ ਗੇੜ ਦਾ) ਦੁੱਖ ਨਹੀਂ ਸਹਾਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он не попадает в круг рождения и смерти и не испытывает боли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35760,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਰਾਤੇ ਸਹਜਿ ਸਮਾਏ ॥",
          "roman": "nāme rāte sahaj samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਰੰਗੇ ਹੋਏ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Погруженные в Имя пребывают в духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35761,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਵੇਖੈ ਹਦੂਰਿ ॥",
          "roman": "nānak gurmukh vekhē hadūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ) ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਵੇਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Гурмукх видит Бога рядом с собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35762,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਸਦ ਰਹਿਆ ਭਰਪੂਰਿ ॥੫॥",
          "roman": "merā prabh sad rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ ਆਖਦਾ ਹੈ ਕਿ) ਮੇਰਾ ਪਰਮਾਤਮਾ ਸਦਾ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Он говорит, что мой Бог везде присутствует."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35763,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਸੇਵਕ ਇਕਿ ਭਰਮਿ ਭੁਲਾਏ ॥",
          "roman": "ik sevak ik bharam bhulāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕਈ (ਜੀਵਾਂ ਨੂੰ ਉਸ ਨੇ ਆਪਣੇ) ਸੇਵਕ ਬਣਾਇਆ ਹੋਇਆ ਹੈ, ਅਤੇ ਕਈ ਜੀਵਾਂ ਨੂੰ ਭਟਕਣਾ (ਪਾ ਕੇ) ਕੁਰਾਹੇ ਪਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Некоторых Он делает слугами, а других вводит в заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35764,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰੇ ਹਰਿ ਆਪਿ ਕਰਾਏ ॥",
          "roman": "āpe kare har āp karāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ (ਸਭ ਕੁਝ) ਕਰਦਾ ਹੈ, ਆਪ ਹੀ (ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог делает всё и побуждает всё происходить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35765,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਵਰਤੈ ਅਵਰੁ ਨ ਕੋਇ ॥",
          "roman": "eko vartē avar na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰ ਥਾਂ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਮੌਜੂਦ ਹੈ, (ਉਸ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Везде есть только Он, кроме Него никого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35766,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਰੋਸੁ ਕੀਜੈ ਜੇ ਦੂਜਾ ਹੋਇ ॥",
          "roman": "man ros kījē je dūjā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਸੇ ਨੂੰ ਗੁਰਮੁਖ ਅਤੇ ਕਿਸੇ ਨੂੰ ਮਨਮੁਖ ਵੇਖ ਕੇ) ਮਨ ਵਿਚ ਗਿਲਾ ਤਾਂ ਹੀ ਕੀਤਾ ਜਾਏ ਜੇ (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕਿਤੇ) ਕੋਈ ਹੋਰ ਹੋਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "Жаловаться можно было бы, если бы существовал кто-то другой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35767,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵੇ ਕਰਣੀ ਸਾਰੀ ॥",
          "roman": "satgur seve karaṇī sārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਰਹਿਣਾ ਹੀ) ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਕਰਤੱਬ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служение Гуру — высшее действие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35768,
          "is_rahao": false,
          "gurmukhi": "ਦਰਿ ਸਾਚੈ ਸਾਚੇ ਵੀਚਾਰੀ ॥੬॥",
          "roman": "dar sāchē sāche vīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ, ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਸੁਰਖ਼ਰੂ ਹੁੰਦੇ ਹਨ, ਵਿਚਾਰਵਾਨ (ਮੰਨੇ ਜਾਂਦੇ) ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Такие люди становятся почитаемыми у истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35769,
          "is_rahao": false,
          "gurmukhi": "ਥਿਤੀ ਵਾਰ ਸਭਿ ਸਬਦਿ ਸੁਹਾਏ ॥",
          "roman": "thitī vār sabh sabad suhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਲੋਕ ਖ਼ਾਸ ਖ਼ਾਸ ਥਿੱਤਾਂ ਤੇ ਵਾਰਾਂ ਨੂੰ ਪਵਿੱਤਰ ਮੰਨ ਕੇ ਖ਼ਾਸ ਖ਼ਾਸ ਧਾਰਮਿਕ ਕਰਮ ਕਰਦੇ ਹਨ ਅਤੇ ਖ਼ਾਸ ਖ਼ਾਸ ਫਲ ਮਿਲਣ ਦੀ ਆਸ ਰੱਖਦੇ ਹਨ, ਪਰ) ਸਾਰੀਆਂ ਥਿੱਤਾਂ ਸਾਰੇ ਵਾਰ (ਤਦੋਂ ਹੀ) ਸੋਹਣੇ ਹਨ (ਜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੇ) ਸ਼ਬਦ ਵਿਚ (ਜੁੜੇ ਰਹਿਣ)।"
            },
            "sahib_singh_ru": {
              "main": "Все дни и даты становятся благими, если человек соединен со Словом Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35770,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵੇ ਤਾ ਫਲੁ ਪਾਏ ॥",
          "roman": "satgur seve tā phal pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ, ਤਦੋਂ ਹੀ (ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ ਸ੍ਰੇਸ਼ਟ) ਫਲ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служа Гуру, человек обретает плод жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35771,
          "is_rahao": false,
          "gurmukhi": "ਥਿਤੀ ਵਾਰ ਸਭਿ ਆਵਹਿ ਜਾਹਿ ॥",
          "roman": "thitī vār sabh āveh jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਥਿੱਤਾਂ ਇਹ ਵਾਰ ਸਾਰੇ ਆਉਂਦੇ ਹਨ ਅਤੇ ਲੰਘ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все дни и даты приходят и уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35772,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਬਦੁ ਨਿਹਚਲੁ ਸਦਾ ਸਚਿ ਸਮਾਹਿ ॥",
          "roman": "gur sabad nihchal sadā sach samāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਸ਼ਬਦ (ਹੀ) ਅਟੱਲ ਰਹਿਣ ਵਾਲਾ ਹੈ (ਸ਼ਬਦ ਦੀ ਬਰਕਤ ਨਾਲ ਮਨੁੱਖ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਵਿਚ ਸਦਾ ਲੀਨ ਰਹਿ ਸਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Слово Гуру неизменно и соединяет с вечным Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35773,
          "is_rahao": false,
          "gurmukhi": "ਥਿਤੀ ਵਾਰ ਤਾ ਜਾ ਸਚਿ ਰਾਤੇ ॥",
          "roman": "thitī vār tā jā sach rāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ) ਥਿੱਤਾਂ ਤੇ ਵਾਰ ਤਦੋਂ ਹੀ (ਮਨੁੱਖਾਂ ਲਈ ਭਲੇ ਹੁੰਦੇ ਹਨ) ਜਦੋਂ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Дни и даты благословенны лишь тогда, когда человек пропитан любовью к Истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35774,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਸਭਿ ਭਰਮਹਿ ਕਾਚੇ ॥੭॥",
          "roman": "bin nāvē sabh bharmeh kāche",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਖੁੰਝੇ ਹੋਏ ਸਾਰੇ ਜੀਵ ਕਮਜ਼ੋਰ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ (ਹੋਣ ਕਰ ਕੇ) ਭਟਕਦੇ ਰਹਿੰਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени все люди остаются духовно слабыми и блуждают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35775,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਮਰਹਿ ਮਰਿ ਬਿਗਤੀ ਜਾਹਿ ॥",
          "roman": "manmukh mareh mar bigatī jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮਨੁੱਖ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਲੈਂਦੇ ਹਨ, ਆਤਮਕ ਮੌਤੇ ਮਰ ਕੇ (ਜਗਤ ਤੋਂ) ਮੰਦੀ ਆਤਮਕ ਹਾਲਤ ਵਿਚ ਹੀ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Манмукхи умирают духовно и уходят в худшем состоянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35776,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਨ ਚੇਤਹਿ ਦੂਜੈ ਲੋਭਾਹਿ ॥",
          "roman": "ek na cheteh dūjē lobhāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ (ਕਦੇ) ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਨਹੀਂ ਕਰਦੇ; ਅਤੇ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੀ ਫਸੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они не помнят Бога и погружены в привязанность к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35777,
          "is_rahao": false,
          "gurmukhi": "ਅਚੇਤ ਪਿੰਡੀ ਅਗਿਆਨ ਅੰਧਾਰੁ ॥",
          "roman": "achet piṇḍī agiān andhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੂਰਖ ਮਤਿ ਵਾਲਾ ਮਨੁੱਖ, ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਬੇ-ਸਮਝ ਮਨੁੱਖ, ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਅੰਨ੍ਹਾ ਹੋਇਆ ਮਨੁੱਖ-"
            },
            "sahib_singh_ru": {
              "main": "Невежественный человек слеп из-за привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35778,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਕਿਉ ਪਾਏ ਪਾਰੁ ॥",
          "roman": "bin sabdē kio pāe pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵਿਕਾਰਾਂ-ਭਰੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਦਾ) ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ (ਉਹ ਸਦਾ ਵਿਕਾਰਾਂ ਵਿਚ ਹੀ ਡੁੱਬਾ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Без Слова Гуру он не может пересечь океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35779,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਪਾਏ ਉਪਾਵਣਹਾਰੁ ॥",
          "roman": "āp upāe upāvaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵ ਦੇ ਵੱਸ ਦੀ ਗੱਲ ਨਹੀਂ), (ਜੀਵਾਂ ਨੂੰ) ਪੈਦਾ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੇ ਆਪ (ਹੀ ਜੀਵਾਂ ਨੂੰ) ਪੈਦਾ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Создатель Сам создал все существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35780,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕੀਤੋਨੁ ਗੁਰ ਵੀਚਾਰੁ ॥੮॥",
          "roman": "āpe kīton gur vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੇ) ਆਪ ਹੀ (ਸਹੀ ਜੀਵਨ ਬਾਰੇ) ਗੁਰੂ ਦਾ (ਦੱਸਿਆ) ਵਿਚਾਰ ਬਣਾਇਆ ਹੋਇਆ ਹੈ (ਗੁਰੂ ਦੇ ਰਸਤੇ ਉੱਤੇ ਉਹ ਆਪ ਹੀ ਜੀਵਾਂ ਨੂੰ ਤੋਰਦਾ ਹੈ) ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Он Сам установил учение Гуру и ведет по этому пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35781,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੇ ਭੇਖ ਕਰਹਿ ਭੇਖਧਾਰੀ ॥",
          "roman": "bahute bhekh kareh bhekhdhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਿਰੇ ਧਾਰਮਿਕ ਪਹਿਰਾਵੇ ਦਾ ਆਸਰਾ ਲੈਣ ਵਾਲੇ ਮਨੁੱਖ ਅਨੇਕਾਂ ਭੇਖ ਕਰਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Многие надевают религиозные одежды и практикуют внешние обряды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35782,
          "is_rahao": false,
          "gurmukhi": "ਭਵਿ ਭਵਿ ਭਰਮਹਿ ਕਾਚੀ ਸਾਰੀ ॥",
          "roman": "bhav bhav bharmeh kāchī sārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ ਆਦਿਕ ਕਈ ਥਾਈਂ) ਭੌਂ ਭੋਂ ਕੇ ਭਟਕਦੇ ਰਹਿੰਦੇ ਹਨ, (ਅਜਿਹੇ ਮਨੁੱਖ) ਕੱਚੀਆਂ ਨਰਦਾਂ (ਵਾਂਗ ਵਿਕਾਰਾਂ ਤੋਂ ਮਾਰ ਖਾਂਦੇ ਹੀ ਰਹਿੰਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Они скитаются и остаются слабыми, подверженными порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35783,
          "is_rahao": false,
          "gurmukhi": "ਐਥੈ ਸੁਖੁ ਨ ਆਗੈ ਹੋਇ ॥",
          "roman": "ēthē sukh na āgē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਆਤਮਕ ਆਨੰਦ ਨਾਹ ਇਸ ਲੋਕ ਵਿਚ ਮਿਲਦਾ ਹੈ ਨਾਹ ਪਰਲੋਕ ਵਿਚ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Они не находят покоя ни здесь, ни в будущем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
