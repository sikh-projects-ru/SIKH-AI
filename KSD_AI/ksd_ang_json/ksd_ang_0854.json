{
  "ang": 854,
  "shabads": [
    {
      "shabad_id": 3194,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36190,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਕੈ ਵਲਿ ਹੋਆ ਮੇਰਾ ਸੁਆਮੀ ਹਰਿ ਸਜਣ ਪੁਰਖੁ ਸੁਜਾਨੁ ॥",
          "roman": "jan nānak kē val hoā merā suāmī har sajaṇ purakh sujān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой Владыка, Хари, Друг, мудрый Пуракх, стал на сторону раба Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36191,
          "is_rahao": false,
          "gurmukhi": "ਪਉਦੀ ਭਿਤਿ ਦੇਖਿ ਕੈ ਸਭਿ ਆਇ ਪਏ ਸਤਿਗੁਰ ਕੀ ਪੈਰੀ ਲਾਹਿਓਨੁ ਸਭਨਾ ਕਿਅਹੁ ਮਨਹੁ ਗੁਮਾਨੁ ॥੧੦॥",
          "roman": "paudī bhit dekh kē sabh āe pae satigur kī pērī lāhion sabhnā kiah manhu gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Увидев падающую стену, все пришли и припали к стопам Сатгуру; Он снял гордыню с умов всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3195,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36192,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mėhlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36193,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਵਾਹੇ ਕੋ ਲੁਣੈ ਕੋ ਪਾਏ ਖਲਿਹਾਨਿ ॥",
          "roman": "koī vāhe ko luṇē ko pāe khalihān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один человек пашет, другой жнёт урожай, третий складывает его на гумне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36194,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਏਵ ਨ ਜਾਪਈ ਕੋਈ ਖਾਇ ਨਿਦਾਨਿ ॥੧॥",
          "roman": "nānak ev na jāpaī koī khāe nidān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: так невозможно понять волю Бога — в конце этот хлеб ест кто-то другой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3196,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36195,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mėhlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36196,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਵਸਿਆ ਤਰਿਆ ਸੋਇ ॥",
          "roman": "jis man vasiā tariā soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, в чьём уме поселяется Бог, переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36197,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੋ ਭਾਵੈ ਸੋ ਹੋਇ ॥੨॥",
          "roman": "nānak jo bhāvē so hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: тогда он понимает, что происходит лишь то, что угодно Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3197,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36198,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36199,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮਿ ਦਇਆਲਿ ਸਾਗਰੁ ਤਾਰਿਆ ॥",
          "roman": "pārbrahm dayāl sāgar tāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милостивый Парабрахм переправил его через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36200,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਮਿਹਰਵਾਨਿ ਭਰਮੁ ਭਉ ਮਾਰਿਆ ॥",
          "roman": "gur pūrē miharvān bharam bhau māriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный милосердный Гуру уничтожил его блуждание и страх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36201,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧੁ ਬਿਕਰਾਲੁ ਦੂਤ ਸਭਿ ਹਾਰਿਆ ॥",
          "roman": "kām krodh bikrāl dūt sabh hāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Страшные враги — похоть, гнев и другие — все потеряли над ним силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36202,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਨਿਧਾਨੁ ਕੰਠਿ ਉਰਿ ਧਾਰਿਆ ॥",
          "roman": "amrit nām nidhān kaṇṭh ur dhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он навсегда утвердил в горле и сердце амрит-Имя, сокровищницу всех благ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36203,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧੂ ਸੰਗਿ ਜਨਮੁ ਮਰਣੁ ਸਵਾਰਿਆ ॥੧੧॥",
          "roman": "nānak sādhū saṅg janam maraṇ savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: в обществе Гуру он упорядочил всю свою жизнь, от рождения до смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3198,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36204,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੩ ॥",
          "roman": "salok mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36205,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑੀ ਨਾਮੁ ਵਿਸਾਰਿਆ ਕੂੜੇ ਕਹਣ ਕਹੰਨਿੑ ॥",
          "roman": "jinhī nām visāriā kūṛe kahaṇ kahaṅn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто забыл Имя Бога, всё время говорят лишь о преходящих вещах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36206,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਚੋਰ ਤਿਨਾ ਘਰੁ ਮੁਹਨਿੑ ਹਉਮੈ ਅੰਦਰਿ ਸੰਨਿੑ ॥",
          "roman": "pañch chor tinā ghar muhan haumē andar sann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пять воров грабят дом их сердца, а внутри Хоумэ постоянно пробивает пролом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36207,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਮੁਠੇ ਦੁਰਮਤੀ ਹਰਿ ਰਸੁ ਨ ਜਾਣੰਨਿੑ ॥",
          "roman": "sākat muṭhe durmatī har ras na jāṇann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Отвернувшиеся от Бога люди с дурным разумением обмануты этими пороками и не знают вкуса Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36208,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑੀ ਅੰਮ੍ਰਿਤੁ ਭਰਮਿ ਲੁਟਾਇਆ ਬਿਖੁ ਸਿਉ ਰਚਹਿ ਰਚੰਨਿੑ ॥",
          "roman": "jinhī amrit bharam luṭāiā bikh siu racheh rachann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто в блуждании растратил амрит-рас Имени, остаются привязаны к яду майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36209,
          "is_rahao": false,
          "gurmukhi": "ਦੁਸਟਾ ਸੇਤੀ ਪਿਰਹੜੀ ਜਨ ਸਿਉ ਵਾਦੁ ਕਰੰਨਿੑ ॥",
          "roman": "dusṭā setī pirhaṛī jan siu vād karann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С дурными людьми у них любовь, а со служителями Бога они поддерживают ссору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36210,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਕਤ ਨਰਕ ਮਹਿ ਜਮਿ ਬਧੇ ਦੁਖ ਸਹੰਨਿੑ ॥",
          "roman": "nānak sākat narak meh jam badhe dukh sahann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: отвернувшиеся от Бога, связанные петлёй духовной смерти, словно находятся в аду и всё время терпят страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36211,
          "is_rahao": false,
          "gurmukhi": "ਪਇਐ ਕਿਰਤਿ ਕਮਾਵਦੇ ਜਿਵ ਰਾਖਹਿ ਤਿਵੈ ਰਹੰਨਿੑ ॥੧॥",
          "roman": "pēē kirat kamāvde jiv rākheh tivē rahann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По прежним делам они продолжают совершать такие же поступки; как Ты, Господь, держишь их, так они и живут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3199,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36212,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36213,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑੀ ਸਤਿਗੁਰੁ ਸੇਵਿਆ ਤਾਣੁ ਨਿਤਾਣੇ ਤਿਸੁ ॥",
          "roman": "jinhī satigur seviā tāṇ nitāṇe tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слабый человек, который служит Сатгуру и следует его делу, получает духовную силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36214,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਗਿਰਾਸਿ ਸਦਾ ਮਨਿ ਵਸੈ ਜਮੁ ਜੋਹਿ ਨ ਸਕੈ ਤਿਸੁ ॥",
          "roman": "sās girās sadā man vasē jam joh na sakē tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С каждым дыханием и каждым куском пищи Бог всегда пребывает в его уме, и духовная смерть не может приблизиться к нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36215,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਹਰਿ ਹਰਿ ਨਾਮ ਰਸੁ ਕਵਲਾ ਸੇਵਕਿ ਤਿਸੁ ॥",
          "roman": "hirdē har har nām ras kavlā sevak tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В его сердце остаётся вкус Имени Хар-Хар, а майя становится его служанкой и не имеет над ним власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36216,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਾਸਾ ਕਾ ਦਾਸੁ ਹੋਇ ਪਰਮ ਪਦਾਰਥੁ ਤਿਸੁ ॥",
          "roman": "har dāsā kā dās hoe param padārath tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он становится слугой слуг Хари и обретает высший дар — Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36217,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਨਿ ਤਨਿ ਜਿਸੁ ਪ੍ਰਭੁ ਵਸੈ ਹਉ ਸਦ ਕੁਰਬਾਣੈ ਤਿਸੁ ॥",
          "roman": "nānak man tan jis prabh vasē hau sad kurbāṇē tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: я всегда жертвенно предан тому, в чьём уме и сердце пребывает Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36218,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑ ਕਉ ਪੂਰਬਿ ਲਿਖਿਆ ਰਸੁ ਸੰਤ ਜਨਾ ਸਿਉ ਤਿਸੁ ॥੨॥",
          "roman": "jinh kau pūrab likhiā ras sant janā siu tis",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь у тех возникает любовь к святым, у кого по прежним делам записана судьба вкуса симрана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3200,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36219,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36220,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਬੋਲੇ ਪੂਰਾ ਸਤਿਗੁਰੂ ਸੋ ਪਰਮੇਸਰਿ ਸੁਣਿਆ ॥",
          "roman": "jo bole pūrā satigurū so parmesar suṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какое слово хвалы произносит полный Сатгуру, на то Бог обращает внимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36221,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਵਰਤਿਆ ਜਗਤ ਮਹਿ ਘਟਿ ਘਟਿ ਮੁਖਿ ਭਣਿਆ ॥",
          "roman": "soī vartiā jagat meh ghaṭ ghaṭ mukh bhaṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это слово действует во всём мире, влияет на каждое сердце, и каждый произносит его устами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36222,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਵਡਿਆਈਆ ਸਾਹਿਬੈ ਨਹ ਜਾਹੀ ਗਣੀਆ ॥",
          "roman": "bahut vaḍiāīā sāhibē nah jāhī gaṇīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Владыки бесчисленные величия и достоинства; их невозможно сосчитать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36223,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸਹਜੁ ਅਨਦੁ ਸਤਿਗੁਰੂ ਪਾਸਿ ਸਚੀ ਗੁਰ ਮਣੀਆ ॥",
          "roman": "sach sahaj anad satigurū pās sachī gur maṇīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вечное Имя, духовная устойчивость и духовный блаженный покой находятся у Сатгуру; наставление Гуру — вечная драгоценность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36224,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੰਤ ਸਵਾਰੇ ਪਾਰਬ੍ਰਹਮਿ ਸਚੇ ਜਿਉ ਬਣਿਆ ॥੧੨॥",
          "roman": "nānak sant savāre pārbrahm sache jiu baṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: Парабрахм Сам украшает жизнь святых; они становятся подобны вечному Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3201,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36225,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੩ ॥",
          "roman": "salok mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36226,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਆਪੁ ਨ ਪਛਾਣਈ ਹਰਿ ਪ੍ਰਭੁ ਜਾਤਾ ਦੂਰਿ ॥",
          "roman": "apṇā āp na pachhāṇaī har prabh jātā dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, идущий за своим умом, не распознаёт свою духовную жизнь и считает Хари-Прабху далёким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36227,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੇਵਾ ਵਿਸਰੀ ਕਿਉ ਮਨੁ ਰਹੈ ਹਜੂਰਿ ॥",
          "roman": "gur kī sevā visrī kiu man rahē hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда он забывает служение, указанное Гуру, как его ум может пребывать в Божьем присутствии?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36228,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਜਨਮੁ ਗਵਾਇਆ ਝੂਠੈ ਲਾਲਚਿ ਕੂਰਿ ॥",
          "roman": "manmukh janam gavāiā jhūṭhē lālach kūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх теряет свою жизнь в ложной жадности и во лжи привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36229,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਖਸਿ ਮਿਲਾਇਅਨੁ ਸਚੈ ਸਬਦਿ ਹਦੂਰਿ ॥੧॥",
          "roman": "nānak bakhas milāian sachē sabad hadūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: тех, кто через истинное Слово хвалы пребывает в Божьем присутствии, Бог по милости соединяет с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3202,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36230,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36231,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪ੍ਰਭੁ ਸਚਾ ਸੋਹਿਲਾ ਗੁਰਮੁਖਿ ਨਾਮੁ ਗੋਵਿੰਦੁ ॥",
          "roman": "har prabh sachā sohilā gurmukh nām govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хари-Прабху, Говинд, вечен; песнь Его хвалы, Его Имя, обретается в прибежище Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36232,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਨਾਮੁ ਸਲਾਹਣਾ ਹਰਿ ਜਪਿਆ ਮਨਿ ਆਨੰਦੁ ॥",
          "roman": "an-din nām salāhaṇā har japiā man ānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто получает Имя Хари, всегда воспевает Имя; повторяя Хари, он хранит духовный ананд в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36233,
          "is_rahao": false,
          "gurmukhi": "ਵਡਭਾਗੀ ਹਰਿ ਪਾਇਆ ਪੂਰਨੁ ਪਰਮਾਨੰਦੁ ॥",
          "roman": "vaḍbhāgī har pāiā pūran parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Бог, Владыка высшего блаженства, обретается лишь по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36234,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਸਲਾਹਿਆ ਬਹੁੜਿ ਨ ਮਨਿ ਤਨਿ ਭੰਗੁ ॥੨॥",
          "roman": "jan nānak nām salāhiā bahuṛ na man tan bhaṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: те слуги, которые воспели Имя, больше никогда не имеют в уме и теле разрыва с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
