{
  "ang": 864,
  "shabads": [
    {
      "shabad_id": 3232,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36556,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨੁ ਰੈਣਿ ਨਾਨਕੁ ਨਾਮੁ ਧਿਆਏ ॥",
          "roman": "din rēn nānak nām dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹੋ ਜਿਹੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ) ਨਾਨਕ ਦਿਨ ਰਾਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "«(ਹੇ ਭਾਈ! ਇਹੋ ਜਿਹੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ) ਨਾਨਕ ਦਿਨ ਰਾਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ,»"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36557,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਹਰਿ ਨਾਏ ॥੪॥੪॥੬॥",
          "roman": "sūkh sahaj ānand har nāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤ ਨਾਲ (ਨਾਨਕ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਆਨੰਦ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "«ਅਤੇ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤ ਨਾਲ (ਨਾਨਕ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਆਨੰਦ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੪॥੬॥»"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3233,
      "rahao_verse_id": 36564,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36558,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "gond mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36559,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਮੂਰਤਿ ਮਨ ਮਹਿ ਧਿਆਨੁ ॥",
          "roman": "gur kī mūrat man meh dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਹੀ ਗੁਰੂ ਦੀ ਮੂਰਤੀ ਹੈ) ਗੁਰੂ ਦੀ (ਇਸ) ਮੂਰਤੀ ਦਾ (ਮੇਰੇ) ਮਨ ਵਿਚ ਧਿਆਨ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "«О брат!» Слово Гуру и есть форма Гуру; на этой форме Гуру в моём уме удерживается сосредоточение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36560,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਮੰਤ੍ਰੁ ਮਨੁ ਮਾਨ ॥",
          "roman": "gur kē sabad mantar man mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਮੇਰਾ ਮਨ ਨਾਮ-ਮੰਤ੍ਰ ਨੂੰ (ਸਭ ਮੰਤ੍ਰਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਮੰਤ੍ਰ) ਮੰਨ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через слово Гуру мой ум принимает Нам-мантру как высший из всех мантр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36561,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਨ ਰਿਦੈ ਲੈ ਧਾਰਉ ॥",
          "roman": "gur ke charan ridē lē dhārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ, ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਲੈ ਕੇ ਵਸਾਈ ਰੱਖਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о брат, я помещаю стопы Гуру в своём сердце и удерживаю их там."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36562,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਾਰਬ੍ਰਹਮੁ ਸਦਾ ਨਮਸਕਾਰਉ ॥੧॥",
          "roman": "gur pārbrahm sadā namaskārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤਾਂ ਗੁਰੂ (ਨੂੰ) ਪਰਮਾਤਮਾ (ਦਾ ਰੂਪ ਜਾਣ ਕੇ ਉਸ) ਨੂੰ ਸਦਾ ਨਮਸਕਾਰ ਕਰਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Я считаю Гуру образом Бога и всегда склоняюсь перед ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36563,
          "is_rahao": true,
          "gurmukhi": "ਮਤ ਕੋ ਭਰਮਿ ਭੁਲੈ ਸੰਸਾਰਿ ॥",
          "roman": "mat ko bharam bhulē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਦੁਨੀਆ ਵਿਚ ਕਿਤੇ ਕੋਈ ਮਨੁੱਖ ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ (ਇਹ ਗੱਲ) ਨਾਹ ਭੁੱਲ ਜਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть никто в мире, впав в заблуждение, не забудет это,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36564,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਬਿਨੁ ਕੋਇ ਨ ਉਤਰਸਿ ਪਾਰਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur bin koī na utaras pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਭੀ ਜੀਵ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਨਹੀਂ ਲੰਘ ਸਕੇਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что без Гуру ни одно существо не сможет переправиться через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36565,
          "is_rahao": false,
          "gurmukhi": "ਭੂਲੇ ਕਉ ਗੁਰਿ ਮਾਰਗਿ ਪਾਇਆ ॥",
          "roman": "bhūle kau gur mārag pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੁਰਾਹੇ ਜਾ ਰਹੇ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਨੇ (ਹੀ ਸਹੀ ਜੀਵਨ ਦੇ) ਰਸਤੇ ਉਤੇ (ਸਦਾ) ਪਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Заблудшего человека Гуру наставил на путь истинной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36566,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਤਿਆਗਿ ਹਰਿ ਭਗਤੀ ਲਾਇਆ ॥",
          "roman": "avar tiāg har bhagti lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ (ਦੇਵੀ ਦੇਵਤਿਆਂ ਦੀ ਭਗਤੀ) ਛਡਾ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਵਿਚ ਜੋੜਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "оставив прочие почитания, он привёл его к преданности Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36567,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਨ ਕੀ ਤ੍ਰਾਸ ਮਿਟਾਈ ॥",
          "roman": "janam maran kī trās miṭāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ, ਇਸ ਤਰ੍ਹਾਂ ਉਸ ਦੇ ਅੰਦਰੋਂ) ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦਾ ਸਹਿਮ ਮੁਕਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И так страх круга рождения и смерти был устранён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36568,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਬੇਅੰਤ ਵਡਾਈ ॥੨॥",
          "roman": "gur pūre kī beant vaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰੇ ਗੁਰੂ ਦੀ ਵਡਿਆਈ ਦਾ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Нет конца величию совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36569,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਊਰਧ ਕਮਲ ਬਿਗਾਸ ॥",
          "roman": "gur prasād ūrdh kamal bigās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮਾਇਆ ਵਲ) ਉਲਟਿਆ ਹੋਇਆ ਹਿਰਦਾ-ਕੌਲ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪਰਤ ਕੇ) ਖਿੜ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Перевёрнутый к майе лотос сердца по милости Гуру раскрывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36570,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਕਾਰ ਮਹਿ ਭਇਆ ਪ੍ਰਗਾਸ ॥",
          "roman": "andhkār meh bhaīā pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਘੁੱਪ ਹਨੇਰੇ ਵਿਚ (ਸਹੀ ਉੱਚੇ ਆਤਮਕ ਜੀਵਨ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В глубокой тьме привязанности возникает свет истинной духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36571,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕੀਆ ਸੋ ਗੁਰ ਤੇ ਜਾਨਿਆ ॥",
          "roman": "jin kīā so gur te jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਉਸ ਪਰਮਾਤਮਾ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਬਣ ਜਾਂਦੀ ਹੈ ਜਿਸ ਨੇ (ਇਹ ਸਾਰਾ ਜਗਤ) ਪੈਦਾ ਕੀਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через Гуру происходит знакомство с Тем, кто сотворил весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36572,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਮੁਗਧ ਮਨੁ ਮਾਨਿਆ ॥੩॥",
          "roman": "gur kirpā te mugadh man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ) ਮੂਰਖ ਮਨ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜਨਾ) ਗਿੱਝ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру этот глупый ум привыкает соединяться с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36573,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਕਰਤਾ ਗੁਰੁ ਕਰਣੈ ਜੋਗੁ ॥",
          "roman": "gur kartā gur karṇē jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ (ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਕਰਤਾਰ ਨਾਲ ਇਕ-ਸੁਰ ਹੋਣ ਕਰਕੇ ਉਸ) ਕਰਤਾਰ ਦਾ ਰੂਪ ਹੈ ਜੋ ਸਭ ਕੁਝ ਕਰਨ ਦੇ ਸਮਰਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру есть образ Творца, способного совершать всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36574,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਹੈ ਭੀ ਹੋਗੁ ॥",
          "roman": "gur parmesar hē bhī hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਪਰਮੇਸਰ ਦਾ ਰੂਪ ਹੈ, ਜੋ (ਪਹਿਲਾਂ ਭੀ ਮੌਜੂਦ ਸੀ) ਹੁਣ ਭੀ ਮੌਜੂਦ ਹੈ ਅਤੇ ਸਦਾ ਕਾਇਮ ਰਹੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — образ Бога, который был, есть и будет вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36575,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭਿ ਇਹੈ ਜਨਾਈ ॥",
          "roman": "kah nānak prabh ihē janāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਪ੍ਰਭੂ ਨੇ ਮੈਨੂੰ ਇਹੀ ਗੱਲ ਸਮਝਾਈ ਹੈ (ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: Бог открыл мне это,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36576,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਮੁਕਤਿ ਨ ਪਾਈਐ ਭਾਈ ॥੪॥੫॥੭॥",
          "roman": "bin gur mukat na pāīai bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ (ਦੀ ਸਰਨ ਪੈਣ) ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਅੰਧਕਾਰ ਤੋਂ) ਖ਼ਲਾਸੀ ਨਹੀਂ ਹੋ ਸਕਦੀ ॥੪॥੫॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "что без Гуру освобождение невозможно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3234,
      "rahao_verse_id": 36583,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36577,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "gond mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36578,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੂ ਗੁਰੂ ਗੁਰੁ ਕਰਿ ਮਨ ਮੋਰ ॥",
          "roman": "gurū gurū gur kar man mor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਹਰ ਵੇਲੇ ਗੁਰੂ (ਦੇ ਉਪਦੇਸ਼) ਨੂੰ ਚੇਤੇ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Всегда помни наставление Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36579,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੂ ਬਿਨਾ ਮੈ ਨਾਹੀ ਹੋਰ ॥",
          "roman": "gurū binā mē nāhī hor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਆਸਰਾ ਨਹੀਂ ਸੁੱਝਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "У меня нет иной опоры кроме Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36580,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਟੇਕ ਰਹਹੁ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "gur kī ṭek rahah din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਗੁਰੂ ਦੇ ਆਸਰੇ ਦਿਨ ਰਾਤ ਟਿਕਿਆ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Оставайся в опоре Гуру день и ночь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36581,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਕੋਇ ਨ ਮੇਟੈ ਦਾਤਿ ॥੧॥",
          "roman": "jā kī koī na meṭē dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਦੀ ਬਖ਼ਸ਼ੀ ਹੋਈ ਆਤਮਕ ਜੀਵਨ ਦੀ ਦਾਤ ਨੂੰ ਕੋਈ ਮਿਟਾ ਨਹੀਂ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "дар духовной жизни которого никто не может уничтожить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36582,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਏਕੋ ਜਾਣੁ ॥",
          "roman": "gur parmesar eko jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਅਤੇ ਪਰਮਾਤਮਾ ਨੂੰ ਇੱਕ ਰੂਪ ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Считай Гуру и Бога единым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36583,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਪਰਵਾਣੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo tis bhāvē so parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ, ਉਹੀ ਗੁਰੂ ਭੀ (ਸਿਰ-ਮੱਥੇ) ਕਬੂਲ ਕਰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Что угодно Богу, то принимает и Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36584,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚਰਣੀ ਜਾ ਕਾ ਮਨੁ ਲਾਗੈ ॥",
          "roman": "gur charaṇī jā kā man lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Чей ум пребывает в стопах Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36585,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਭ੍ਰਮੁ ਤਾ ਕਾ ਭਾਗੈ ॥",
          "roman": "dūkh dard bhram tā kā bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਹਰੇਕ ਭਟਕਣਾ ਹਰੇਕ ਦੁੱਖ ਦਰਦ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у того исчезают все страдания, боли и заблуждения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36586,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੇਵਾ ਪਾਏ ਮਾਨੁ ॥",
          "roman": "gur kī sevā pāe mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਮਨੁੱਖ (ਹਰ ਥਾਂ) ਆਦਰ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! В служении Гуру человек обретает почёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36587,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਊਪਰਿ ਸਦਾ ਕੁਰਬਾਨੁ ॥੨॥",
          "roman": "gur ūpar sadā kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਹੋ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Всегда будь предан Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36588,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਦਰਸਨੁ ਦੇਖਿ ਨਿਹਾਲ ॥",
          "roman": "gur kā darsan dekh nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਗੁਰੂ ਦਾ ਦਰਸ਼ਨ ਕਰ ਕੇ (ਮਨੁੱਖ ਦਾ ਤਨ ਮਨ) ਖਿੜ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Видя Гуру, тело и ум наполняются радостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36589,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਸੇਵਕ ਕੀ ਪੂਰਨ ਘਾਲ ॥",
          "roman": "gur ke sevak kī pūran ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਵਾਲੇ ਮਨੁੱਖ ਦੀ ਮੇਹਨਤ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Труд служащего Гуру становится успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36590,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਸੇਵਕ ਕਉ ਦੁਖੁ ਨ ਬਿਆਪੈ ॥",
          "roman": "gur ke sevak kau dukh na biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਭੀ ਦੁੱਖ ਗੁਰੂ ਦੇ ਸੇਵਕ ਉਤੇ (ਆਪਣਾ) ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никакое страдание не может одолеть слугу Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36591,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸੇਵਕੁ ਦਹ ਦਿਸਿ ਜਾਪੈ ॥੩॥",
          "roman": "gur kā sevak dah dis jāapē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ ਸਾਰੇ ਸੰਸਾਰ ਵਿਚ ਪਰਗਟ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Слуга Гуру становится известным во всех направлениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36592,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਮਹਿਮਾ ਕਥਨੁ ਨ ਜਾਇ ॥",
          "roman": "gur kī mahimā kathan na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਵਡਿਆਈ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Величие Гуру невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36593,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਗੁਰੁ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "pārbrahm gur rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ, ਜੋ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру есть образ Бога, который пронизывает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36594,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕੇ ਪੂਰੇ ਭਾਗ ॥",
          "roman": "kah nānak jā ke pūre bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦੇ ਵੱਡੇ ਭਾਗ ਜਾਗਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: у кого пробуждаются великие заслуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36595,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚਰਣੀ ਤਾ ਕਾ ਮਨੁ ਲਾਗ ॥੪॥੬॥੮॥",
          "roman": "gur charaṇī tā kā man lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੬॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "того ум пребывает в стопах Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3235,
      "rahao_verse_id": 36602,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36596,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "gond mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36597,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਮੇਰੀ ਪੂਜਾ ਗੁਰੁ ਗੋਬਿੰਦੁ ॥",
          "roman": "gur merī pūjā gur gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮੇਰਾ) ਗੁਰੂ (ਗੁਰੂ ਦੀ ਸਰਨ ਹੀ) ਮੇਰੇ ਵਾਸਤੇ (ਦੇਵ-) ਪੂਜਾ ਹੈ, (ਮੇਰਾ) ਗੁਰੂ ਗੋਬਿੰਦ (ਦਾ ਰੂਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Мой Гуру — моя почитаемая форма, мой Гуру есть образ Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36598,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਮੇਰਾ ਪਾਰਬ੍ਰਹਮੁ ਗੁਰੁ ਭਗਵੰਤੁ ॥",
          "roman": "gur merā pārbrahm gur bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਗੁਰੂ ਪਰਮਾਤਮਾ (ਦਾ ਰੂਪ) ਹੈ, ਗੁਰੂ ਬੜੀ ਸਮਰਥਾ ਦਾ ਮਾਲਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Гуру — образ Бога, обладатель великой силы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36599,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਮੇਰਾ ਦੇਉ ਅਲਖ ਅਭੇਉ ॥",
          "roman": "gur merā deu alakh abheu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਗੁਰੂ ਉਸ ਪ੍ਰਕਾਸ਼-ਰੂਪ ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਹੈ ਜਿਸ ਦਾ ਸਰੂਪ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ ਅਤੇ ਜਿਸ ਦਾ ਭੇਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Гуру — образ Того, чью сущность нельзя описать и постичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36600,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਪੂਜ ਚਰਨ ਗੁਰ ਸੇਉ ॥੧॥",
          "roman": "sarb pūj charan gur seo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤਾਂ ਉਹਨਾਂ ਗੁਰ-ਚਰਨਾਂ ਦੀ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹਾਂ ਜਿਨ੍ਹਾਂ ਨੂੰ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਪੂਜਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Я пребываю в прибежище стоп Гуру, которых почитает всё творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36601,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਬਿਨੁ ਅਵਰੁ ਨਾਹੀ ਮੈ ਥਾਉ ॥",
          "roman": "gur bin avar nāhī mē thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਘੁੱਪ ਹਨੇਰੇ ਵਿਚੋਂ ਬਚਣ ਲਈ) ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ ਥਾਂ ਨਹੀਂ ਸੁੱਝਦਾ (ਜਿਸ ਦਾ ਆਸਰਾ ਲੈ ਸਕਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! У меня нет иной опоры кроме Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36602,
          "is_rahao": true,
          "gurmukhi": "ਅਨਦਿਨੁ ਜਪਉ ਗੁਰੂ ਗੁਰ ਨਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "andin japau gurū gur nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ) ਮੈਂ ਹਰ ਵੇਲੇ ਗੁਰੂ ਦਾ ਨਾਮ ਹੀ ਜਪਦਾ ਹਾਂ (ਗੁਰੂ ਦੀ ਓਟ ਤੱਕੀ ਬੈਠਾ ਹਾਂ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Я всегда повторяю имя Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36603,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਮੇਰਾ ਗਿਆਨੁ ਗੁਰੁ ਰਿਦੈ ਧਿਆਨੁ ॥",
          "roman": "gur merā giān gur ridē dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਧਾਰਮਿਕ ਚਰਚਾ ਹੈ, ਗੁਰੂ (ਸਦਾ ਮੇਰੇ) ਹਿਰਦੇ ਵਿਚ ਟਿਕਿਆ ਹੋਇਆ ਹੈ, ਇਹੀ ਮੇਰੀ ਸਮਾਧੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру — моё знание, он пребывает в моём сердце как сосредоточение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36604,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਗੋਪਾਲੁ ਪੁਰਖੁ ਭਗਵਾਨੁ ॥",
          "roman": "gur gopāl purakh bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਭਗਵਾਨ ਦਾ ਰੂਪ ਹੈ ਜੋ ਸਰਬ-ਵਿਆਪਕ ਹੈ ਅਤੇ ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਪਾਲਣਹਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — образ Бога, всепроникающего и поддерживающего творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36605,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸਰਣਿ ਰਹਉ ਕਰ ਜੋਰਿ ॥",
          "roman": "gur kī saraṇ rahau kar jor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਆਪਣੇ) ਦੋਵੇਂ ਹੱਥ ਜੋੜ ਕੇ (ਸਦਾ) ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я, сложив руки, пребываю в прибежище Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36606,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੂ ਬਿਨਾ ਮੈ ਨਾਹੀ ਹੋਰੁ ॥੨॥",
          "roman": "gurū binā mē nāhī hor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ ਆਸਰਾ ਨਹੀਂ ਸੁੱਝਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Без Гуру у меня нет иной опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36607,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਬੋਹਿਥੁ ਤਾਰੇ ਭਵ ਪਾਰਿ ॥",
          "roman": "gur bohith tāre bhav pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਜਹਾਜ਼ ਹੈ ਜੋ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру — корабль, переправляющий через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36608,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਜਮ ਤੇ ਛੁਟਕਾਰਿ ॥",
          "roman": "gur sevā jam te chhuṭkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਜਮਾਂ (ਦੇ ਡਰ) ਤੋਂ ਖ਼ਲਾਸੀ ਮਿਲ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В служении Гуру приходит освобождение от страха смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36609,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਕਾਰ ਮਹਿ ਗੁਰ ਮੰਤ੍ਰੁ ਉਜਾਰਾ ॥",
          "roman": "andhkār meh gur mantar ujārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਘੁੱਪ ਹਨੇਰੇ ਵਿਚ ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਹੀ (ਆਤਮਕ ਜੀਵਨ ਦਾ) ਚਾਨਣ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В тьме привязанности учение Гуру даёт свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36610,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸੰਗਿ ਸਗਲ ਨਿਸਤਾਰਾ ॥੩॥",
          "roman": "gur kē sang sagal nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਸਾਰੇ ਜੀਵਾਂ ਦਾ ਪਾਰ-ਉਤਾਰਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру происходит спасение всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36611,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪਾਈਐ ਵਡਭਾਗੀ ॥",
          "roman": "gur pūrā pāīai vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Совершенного Гуру находят великой удачей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36612,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੇਵਾ ਦੂਖੁ ਨ ਲਾਗੀ ॥",
          "roman": "gur kī sevā dūkh na lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਕੋਈ ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "В служении Гуру страдание не касается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36613,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਨ ਮੇਟੈ ਕੋਇ ॥",
          "roman": "gur kā sabad na meṭē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਗੁਰੂ ਦਾ ਸ਼ਬਦ (ਵੱਸ ਪਏ ਉਸ ਦੇ ਅੰਦਰੋਂ) ਕੋਈ ਮਨੁੱਖ (ਆਤਮਕ ਜੀਵਨ ਦੇ ਉਜਾਰੇ ਨੂੰ) ਮਿਟਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не может уничтожить слово Гуру, укоренившееся в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36614,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਨਾਨਕੁ ਨਾਨਕੁ ਹਰਿ ਸੋਇ ॥੪॥੭॥੯॥",
          "roman": "gurū nānak nānak har soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਨਾਨਕ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ ॥੪॥੭॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру Нанак есть образ Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
