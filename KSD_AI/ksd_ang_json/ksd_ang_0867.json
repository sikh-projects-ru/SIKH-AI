      "lines": [
        {
          "verse_id": 36731,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਹੋਇ ਤੁਮੑਾਰਾ ਚੀਤ ॥",
          "roman": "nirmal hoi tumhārā chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਤੇਰਾ ਮਨ ਪਵਿੱਤਰ ਹੋ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਤੇਰਾ ਮਨ ਪਵਿੱਤਰ ਹੋ ਜਾਇਗਾ।"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36732,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਕੀ ਸਭ ਮਿਟੈ ਬਲਾਇ ॥",
          "roman": "man tan kī sabh miṭē balāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਿੱਤਰ! ਨਾਮ ਜਪਿਆਂ) ਮਨ ਦੀ ਸਰੀਰ ਦੀ ਹਰੇਕ ਬਿਪਤਾ ਮਿਟ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(ਹੇ ਮਿੱਤਰ! ਨਾਮ ਜਪਿਆਂ) ਮਨ ਦੀ ਸਰੀਰ ਦੀ ਹਰੇਕ ਬਿਪਤਾ ਮਿਟ ਜਾਂਦੀ ਹੈ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36733,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਅੰਧੇਰਾ ਸਗਲਾ ਜਾਇ ॥੧॥",
          "roman": "dukh andherā saglā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, (ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ) ਸਾਰਾ ਹਨੇਰਾ ਮੁੱਕ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, (ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ) ਸਾਰਾ ਹਨੇਰਾ ਮੁੱਕ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36734,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵਤ ਤਰੀਐ ਸੰਸਾਰੁ ॥",
          "roman": "har guṇ gāvat tarīai sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਗਾਂਦਿਆਂ ਸੰਸਾਰ (-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਗਾਂਦਿਆਂ ਸੰਸਾਰ (-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36735,
          "is_rahao": true,
          "gurmukhi": "ਵਡ ਭਾਗੀ ਪਾਈਐ ਪੁਰਖੁ ਅਪਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "vaḍ bhāgī pāīai purakh apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਗ ਜਾਗ ਪੈਂਦੇ ਹਨ) ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਸਰਬ-ਵਿਆਪਕ ਬੇਅੰਤ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(ਭਾਗ ਜਾਗ ਪੈਂਦੇ ਹਨ) ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਸਰਬ-ਵਿਆਪਕ ਬੇਅੰਤ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36736,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨੁ ਕਰੈ ਕੀਰਤਨੁ ਗੋਪਾਲ ॥ ਤਿਸ ਕਉ ਪੋਹਿ ਨ ਸਕੈ ਜਮਕਾਲੁ ॥",
          "roman": "jo jan karē kīrtan gopāl tis kau poh na sakē jamkāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਿੱਤਰ! ਜੇਹੜਾ ਮਨੁੱਖ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਮੌਤ ਦਾ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "ਹੇ ਮੇਰੇ ਮਿੱਤਰ! ਜੇਹੜਾ ਮਨੁੱਖ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਮੌਤ ਦਾ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36737,
          "is_rahao": false,
          "gurmukhi": "ਜਗ ਮਹਿ ਆਇਆ ਸੋ ਪਰਵਾਣੁ ॥ ਗੁਰਮੁਖਿ ਅਪਨਾ ਖਸਮੁ ਪਛਾਣੁ ॥੨॥",
          "roman": "jag meh āiā so parvāṇ gurmukh apnā khasam pachhāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਦੁਨੀਆ ਵਿਚ ਆਉਣਾ ਸਫਲ ਹੋ ਜਾਂਦਾ ਹੈ। (ਹੇ ਮਿੱਤਰ! ਤੂੰ ਭੀ) ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਪਾਈ ਰੱਖ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਦੁਨੀਆ ਵਿਚ ਆਉਣਾ ਸਫਲ ਹੋ ਜਾਂਦਾ ਹੈ। (ਹੇ ਮਿੱਤਰ! ਤੂੰ ਭੀ) ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਪਾਈ ਰੱਖ ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36738,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵੈ ਸੰਤ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "har guṇ gāvē sant prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਿੱਤਰ! ਜੇਹੜਾ ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(ਹੇ ਮਿੱਤਰ! ਜੇਹੜਾ ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36739,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਮਿਟਹਿ ਉਨਮਾਦ ॥",
          "roman": "kām krodh miṭeh unmād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਕਾਮ ਕ੍ਰੋਧ (ਆਦਿਕ) ਝੱਲ-ਪੁਣੇ ਮਿਟ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਕਾਮ ਕ੍ਰੋਧ (ਆਦਿਕ) ਝੱਲ-ਪੁਣੇ ਮਿਟ ਜਾਂਦੇ ਹਨ।"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36740,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਹਜੂਰਿ ਜਾਣੁ ਭਗਵੰਤ ॥",
          "roman": "sadā hajūr jāṇ bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਿੱਤਰ!) ਭਗਵਾਨ ਨੂੰ ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਸਮਝਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "(ਹੇ ਮਿੱਤਰ!) ਭਗਵਾਨ ਨੂੰ ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਸਮਝਿਆ ਕਰ।"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36741,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕਾ ਪੂਰਨ ਮੰਤ ॥੩॥",
          "roman": "pūre gur kā pūran mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪੂਰੇ ਗੁਰੂ ਦਾ ਸੱਚਾ ਉਪਦੇਸ਼ ਲੈ ਕੇ (ਉਸ ਦਾ ਸਿਮਰਨ ਕਰ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ਅਤੇ ਪੂਰੇ ਗੁਰੂ ਦਾ ਸੱਚਾ ਉਪਦੇਸ਼ ਲੈ ਕੇ (ਉਸ ਦਾ ਸਿਮਰਨ ਕਰ) ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36742,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਧਨੁ ਖਾਟਿ ਕੀਏ ਭੰਡਾਰ ॥",
          "roman": "har dhan khāṭ kīe bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਹਰਿ-ਨਾਮ ਧਨ ਖੱਟ ਕੇ ਖ਼ਜ਼ਾਨੇ ਭਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਹਰਿ-ਨਾਮ ਧਨ ਖੱਟ ਕੇ ਖ਼ਜ਼ਾਨੇ ਭਰ ਲਏ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36743,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਤਿਗੁਰ ਸਭਿ ਕਾਜ ਸਵਾਰ ॥",
          "roman": "mil satgur sabh kāj savār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਉਸ ਨੇ ਆਪਣੇ ਸਾਰੇ ਹੀ ਕੰਮ ਸੰਵਾਰ ਲਏ।"
            },
            "sahib_singh_ru": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਉਸ ਨੇ ਆਪਣੇ ਸਾਰੇ ਹੀ ਕੰਮ ਸੰਵਾਰ ਲਏ।"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36744,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਰੰਗ ਸੰਗਿ ਜਾਗਾ ॥",
          "roman": "har ke nām raṅg saṅg jāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਦੇ ਪ੍ਰੇਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦਾ ਮਨ ਜਾਗ ਪੈਂਦਾ ਹੈ (ਕਾਮ ਕ੍ਰੋਧ ਆਦਿਕ ਵਿਕਾਰਾਂ ਵਲੋਂ ਉਹ ਸਦਾ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "ਹਰਿ-ਨਾਮ ਦੇ ਪ੍ਰੇਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦਾ ਮਨ ਜਾਗ ਪੈਂਦਾ ਹੈ (ਕਾਮ ਕ੍ਰੋਧ ਆਦਿਕ ਵਿਕਾਰਾਂ ਵਲੋਂ ਉਹ ਸਦਾ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36745,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਣੀ ਨਾਨਕ ਮਨੁ ਲਾਗਾ ॥੪॥੧੪॥੧੬॥",
