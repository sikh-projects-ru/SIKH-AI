            }
          }
        },
        {
          "verse_id": 36747,
          "is_rahao": false,
          "gurmukhi": "ਭਵ ਸਾਗਰ ਬੋਹਿਥ ਹਰਿ ਚਰਣ ॥",
          "roman": "bhav sāgar bohith har charaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣ ਵਾਸਤੇ ਜਹਾਜ਼ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! стопы Бога являются кораблём для переправы через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36748,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮੁ ਨਾਹੀ ਫਿਰਿ ਮਰਣ ॥",
          "roman": "simrat nām nāhī phir maraṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਮੁੜ ਮੁੜ (ਆਤਮਕ) ਮੌਤ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Помня Имя Бога, больше не происходит духовной смерти снова и снова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36749,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਰਮਤ ਨਾਹੀ ਜਮ ਪੰਥ ॥",
          "roman": "har guṇ ramat nāhī jam panth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਜਮਾਂ ਦਾ ਰਸਤਾ ਨਹੀਂ ਫੜਨਾ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Господа, не приходится идти путём Ямы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36750,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਬੀਚਾਰ ਪੰਚ ਦੂਤਹ ਮੰਥ ॥੧॥",
          "roman": "mahā bīchār pañch dūtah manth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦੀ) ਵਿਚਾਰ ਜੋ ਹੋਰ ਸਾਰੀਆਂ ਵਿਚਾਰਾਂ ਤੋਂ ਉੱਤਮ ਹੈ (ਕਾਮਾਦਿਕ) ਪੰਜ ਵੈਰੀਆਂ ਦਾ ਨਾਸ ਕਰ ਦੇਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Высшее размышление о Боге уничтожает пять врагов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36751,
          "is_rahao": true,
          "gurmukhi": "ਤਉ ਸਰਣਾਈ ਪੂਰਨ ਨਾਥ ॥",
          "roman": "tau saraṇāī pūran nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ ਭਰਪੂਰ ਖਸਮ-ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О совершенный Господь, я пришёл в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36752,
          "is_rahao": true,
          "gurmukhi": "ਜੰਤ ਅਪਨੇ ਕਉ ਦੀਜਹਿ ਹਾਥ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jant apne kau dījeh hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ) ਆਪਣੇ ਪੈਦਾ ਕੀਤੇ ਗਰੀਬ ਸੇਵਕ ਨੂੰ ਕਿਰਪਾ ਕਰ ਕੇ ਆਪਣੇ ਹੱਥ ਫੜਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Даруй этому Твоему созданию, бедному слуге, Свою поддержку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36753,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮ੍ਰਿਤਿ ਸਾਸਤ੍ਰ ਬੇਦ ਪੁਰਾਣ ॥",
          "roman": "simrit sāstr bed purāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਿਮ੍ਰਿਤੀਆਂ, ਸ਼ਾਸਤਰ, ਵੇਦ, ਪੁਰਾਣ (ਆਦਿਕ ਸਾਰੇ ਧਰਮ-ਪੁਸਤਕ)"
            },
            "sahib_singh_ru": {
              "main": "О брат, смрити, шастры, веды и пураны"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36754,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕਾ ਕਰਹਿ ਵਖਿਆਣ ॥",
          "roman": "pārbrahm kā kareh vakhyāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦਾ ਬਿਆਨ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "описывают качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36755,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਜਤੀ ਬੈਸਨੋ ਰਾਮਦਾਸ ॥",
          "roman": "jogī jatī bēsno rāmdās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗੀ ਜਤੀ, ਵੈਸ਼ਨਵ ਸਾਧੂ, (ਨਿਰਤ-ਕਾਰੀ ਕਰਨ ਵਾਲੇ) ਬੈਰਾਗੀ ਭਗਤ ਭੀ ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਦਾ ਵਿਚਾਰ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Йоги, аскеты, вайшнавы и отрешённые преданные также размышляют о качествах Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36756,
          "is_rahao": false,
          "gurmukhi": "ਮਿਤਿ ਨਾਹੀ ਬ੍ਰਹਮ ਅਬਿਨਾਸ ॥੨॥",
          "roman": "mit nāhī brahm abinās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਅਬਿਨਾਸੀ ਪ੍ਰਭੂ ਦਾ ਕੋਈ ਭੀ ਅੰਤ ਨਹੀਂ ਪਾ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но никто не может найти предел Бессмертного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36757,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਪਲਾਹ ਕਰਹਿ ਸਿਵ ਦੇਵ ॥",
          "roman": "karaṇ palāh kareh siv dev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸ਼ਿਵ ਜੀ ਅਤੇ ਹੋਰ ਅਨੇਕਾਂ ਦੇਵਤੇ (ਉਸ ਪ੍ਰਭੂ ਦਾ ਅੰਤ ਲੱਭਣ ਵਾਸਤੇ) ਤਰਲੇ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, Шива и другие боги умоляют, стремясь найти предел Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36758,
          "is_rahao": false,
          "gurmukhi": "ਤਿਲੁ ਨਹੀ ਬੂਝਹਿ ਅਲਖ ਅਭੇਵ ॥",
          "roman": "til nahī būjheh alakh abhev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦੇ ਸਰੂਪ ਨੂੰ ਰਤਾ ਭਰ ਭੀ ਨਹੀਂ ਸਮਝ ਸਕਦੇ। ਉਸ ਪ੍ਰਭੂ ਦਾ ਸਰੂਪ ਸਹੀ ਤਰੀਕੇ ਨਾਲ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ, ਉਸ ਪ੍ਰਭੂ ਦਾ ਭੇਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Но не могут понять даже малую часть Его сущности; Его невозможно полностью описать и постичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36759,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਜਿਸੁ ਆਪੇ ਦੇਇ ॥",
          "roman": "prem bhagat jis āpe dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੂੰ) ਪ੍ਰਭੂ ਆਪਣੀ ਪ੍ਰੇਮਾ ਭਗਤੀ ਬਖ਼ਸ਼ ਦਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тем, кому Сам Господь дарует любовь и преданность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36760,
          "is_rahao": false,
          "gurmukhi": "ਜਗ ਮਹਿ ਵਿਰਲੇ ਕੇਈ ਕੇਇ ॥੩॥",
          "roman": "jag meh virle keī kei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੰਸਾਰ ਤੇ ਬਹੁਤ ਘੱਟ ਗਿਣਤੀ ਵਿੱਚ ਹੀ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "таких людей в мире очень мало."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36761,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਨਿਰਗੁਣ ਗੁਣੁ ਕਿਛਹੂ ਨਾਹਿ ॥",
          "roman": "moh nirguṇ guṇ kichhū nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਮੈਂ ਤਾਂ ਹਾਂ ਨਾ-ਚੀਜ਼। ਭਲਾ ਮੈਂ ਤੇਰਾ ਅੰਤ ਕਿਵੇਂ ਪਾ ਸਕਾਂ?) ਮੈਂ ਗੁਣ-ਹੀਣ ਵਿਚ ਕੋਈ ਭੀ ਗੁਣ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, во мне нет никаких достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36762,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਤੇਰੀ ਦ੍ਰਿਸਟੀ ਮਾਹਿ ॥",
          "roman": "sarab nidhān terī drisṭī māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਾਂ,) ਤੇਰੀ ਮੇਹਰ ਦੀ ਨਿਗਾਹ ਵਿਚ ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਹਨ (ਜਿਸ ਉਤੇ ਨਜ਼ਰ ਕਰਦਾ ਹੈਂ, ਉਸ ਨੂੰ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Все сокровища находятся в Твоём милостивом взгляде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36763,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਦੀਨੁ ਜਾਚੈ ਤੇਰੀ ਸੇਵ ॥",
          "roman": "nānak dīn jāchē terī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਦਾਸ) ਗਰੀਬ ਨਾਨਕ (ਤੈਥੋਂ) ਤੇਰੀ ਭਗਤੀ ਮੰਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бедный Нанак просит у Тебя служения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36764,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਦੀਜੈ ਗੁਰਦੇਵ ॥੪॥੧੫॥੧੭॥",
          "roman": "kar kirpā dījē gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤੋਂ ਵੱਡੇ ਦੇਵ! ਮੇਹਰ ਕਰ ਕੇ ਇਹ ਖ਼ੈਰ ਪਾ ॥੪॥੧੫॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Великий Господь, по милости даруй это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3244,
      "rahao_verse_id": 36771,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36765,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "goṇḍ mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36766,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਾ ਲੀਆ ਧਰਤਿ ਬਿਦਾਰਉ ॥",
          "roman": "sant kā līā dharat bidārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤਾਹੀਏਂ ਪਰਮਾਤਮਾ ਆਖਦਾ ਹੈ-) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਸੰਤ ਫਿਟਕਾਰ ਪਾਏ, ਮੈਂ ਉਸ ਦੀਆਂ ਜੜ੍ਹਾਂ ਪੁੱਟ ਦੇਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Того, кого осуждает святой, Я вырываю с корнем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36767,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਾ ਨਿੰਦਕੁ ਅਕਾਸ ਤੇ ਟਾਰਉ ॥",
          "roman": "sant kā nindak akās te ṭārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਨਿੰਦਾ ਕਰਨ ਵਾਲੇ ਨੂੰ ਮੈਂ ਉੱਚੇ ਮਰਾਤਬੇ ਤੋਂ ਹੇਠਾਂ ਡੇਗ ਦੇਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Клеветника святого Я сбрасываю с высоты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36768,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਉ ਰਾਖਉ ਅਪਨੇ ਜੀਅ ਨਾਲਿ ॥",
          "roman": "sant kau rākhu apne jīa nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਨੂੰ ਮੈਂ ਸਦਾ ਆਪਣੀ ਜਿੰਦ ਦੇ ਨਾਲ ਰੱਖਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Святого Я держу рядом со Своей душой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36769,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਉਧਾਰਉ ਤਤਖਿਣ ਤਾਲਿ ॥੧॥",
          "roman": "sant udhārau tatkhiṇ tāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਸੇ ਭੀ ਬਿਪਤਾ ਤੋਂ) ਸੰਤ ਨੂੰ ਮੈਂ ਤੁਰਤ ਉਸੇ ਵੇਲੇ ਬਚਾ ਲੈਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Святого Я мгновенно спасаю от беды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36770,
          "is_rahao": true,
          "gurmukhi": "ਸੋਈ ਸੰਤੁ ਜਿ ਭਾਵੈ ਰਾਮ ॥",
          "roman": "soī sant jo bhāvē rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ, ਉਹੀ ਹੈ ਸੰਤ।"
            },
            "sahib_singh_ru": {
              "main": "Тот есть святой, кто становится любим Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36771,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਗੋਬਿੰਦ ਕੈ ਏਕੈ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sant gobind kē ekē kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੇ ਹਿਰਦੇ ਵਿਚ ਅਤੇ ਗੋਬਿੰਦ ਦੇ ਮਨ ਵਿਚ ਇਕੋ ਜਿਹਾ ਕੰਮ ਹੁੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "У святого и Господа одно дело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36772,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਊਪਰਿ ਦੇਇ ਪ੍ਰਭੁ ਹਾਥ ॥",
          "roman": "sant kē ūpar dei prabh hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਆਪਣਾ ਹੱਥ (ਆਪਣੇ) ਸੰਤ ਉੱਤੇ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь кладёт руку на святого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36773,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਸੰਗਿ ਬਸੈ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "sant kē sang basē din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੰਤ ਦੇ ਨਾਲ ਦਿਨ ਰਾਤ (ਹਰ ਵੇਲੇ) ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь пребывает со святым день и ночь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36774,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਸੰਤਹ ਪ੍ਰਤਿਪਾਲਿ ॥",
          "roman": "sās sās santah pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੰਤਾਂ ਦੀ (ਉਹਨਾਂ ਦੇ) ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਰਾਖੀ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "С каждым дыханием Господь заботится о святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36775,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਾ ਦੋਖੀ ਰਾਜ ਤੇ ਟਾਲਿ ॥੨॥",
          "roman": "sant kā dokhī rāj te ṭāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦਾ ਬੁਰਾ ਮੰਗਣ ਵਾਲੇ ਨੂੰ ਪ੍ਰਭੂ ਰਾਜ ਤੋਂ (ਭੀ) ਹੇਠਾਂ ਡੇਗ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Врага святого Господь лишает даже власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36776,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਨਿੰਦਾ ਕਰਹੁ ਨ ਕੋਇ ॥",
          "roman": "sant kī nindā karah na koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਭੀ ਮਨੁੱਖ ਕਿਸੇ ਸੰਤ ਦੀ ਨਿੰਦਾ ਨਾਹ ਕਰਿਆ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не должен клеветать на святого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36777,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਨਿੰਦੈ ਤਿਸ ਕਾ ਪਤਨੁ ਹੋਇ ॥",
          "roman": "jo nindē tis kā patan hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਨਿੰਦਾ ਕਰਦਾ ਹੈ, ਉਹ ਆਤਮਕ ਜੀਵਨ ਤੋਂ ਡਿੱਗ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто клевещет, падает духовно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36778,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਉ ਰਾਖੈ ਸਿਰਜਨਹਾਰੁ ॥",
          "roman": "jis kau rākhe sirjanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਆਪ ਜਿਸ ਮਨੁੱਖ ਦੀ ਰੱਖਿਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кого защищает Творец,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36779,
          "is_rahao": false,
          "gurmukhi": "ਝਖ ਮਾਰਉ ਸਗਲ ਸੰਸਾਰੁ ॥੩॥",
          "roman": "jhakh mārau sagal sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰਾ ਸੰਸਾਰ (ਉਸ ਦਾ ਨੁਕਸਾਨ ਕਰਨ ਲਈ) ਬੇ-ਸ਼ੱਕ ਪਿਆ ਝਖਾਂ ਮਾਰੇ (ਉਸ ਦਾ ਕੋਈ ਵਿਗਾੜ ਨਹੀਂ ਕਰ ਸਕਦਾ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "весь мир не может ему повредить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36780,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਪਨੇ ਕਾ ਭਇਆ ਬਿਸਾਸੁ ॥",
          "roman": "prabh apne kā bhaiā bisās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੇ ਪ੍ਰਭੂ ਉਤੇ ਭਰੋਸਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У кого возникает вера в Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36781,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਸਭੁ ਤਿਸ ਕੀ ਰਾਸਿ ॥",
          "roman": "jīu piṇḍ sabh tis kī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ) ਇਹ ਜਿੰਦ ਤੇ ਇਹ ਸਰੀਰ ਸਭ ਕੁਝ ਉਸ ਪ੍ਰਭੂ ਦਾ ਦਿੱਤਾ ਹੋਇਆ ਹੀ ਸਰਮਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот понимает, что душа и тело — дар Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36782,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਉਪਜੀ ਪਰਤੀਤਿ ॥",
          "roman": "nānak kau upjī partīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਨਕ ਦੇ ਹਿਰਦੇ ਵਿਚ ਭੀ ਇਹ ਯਕੀਨ ਬਣ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В сердце Нанака возникла эта вера,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36783,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਹਾਰ ਗੁਰਮੁਖ ਸਦ ਜੀਤਿ ॥੪॥੧੬॥੧੮॥",
          "roman": "manmukh hār gurmukh sad jīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ (ਜੀਵਨ-ਬਾਜ਼ੀ ਵਿਚ) ਹਾਰ ਜਾਂਦਾ ਹੈ, ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਵਾਲੇ ਮਨੁੱਖ ਨੂੰ ਸਦਾ ਜਿੱਤ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ ॥੪॥੧੬॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "что идущий за своим умом проигрывает, а идущий за Гуру всегда побеждает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3245,
      "rahao_verse_id": 36786,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36784,
          "is_rahao": true,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "goṇḍ mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36785,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੁ ਨਿਰੰਜਨੁ ਨੀਰਿ ਨਰਾਇਣ ॥",
          "roman": "nām niranjan nīr narāyaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਰਾਇਣ ਦਾ ਨਾਮ ਮਾਇਆ ਦੀ ਕਾਲਖ ਤੋਂ ਬਚਾਣ ਵਾਲਾ (ਹੈ, ਇਸ ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਸਿੰਜ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Нараяна очищает от скверны майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36786,
          "is_rahao": true,
          "gurmukhi": "ਰਸਨਾ ਸਿਮਰਤ ਪਾਪ ਬਿਲਾਇਣ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rasnā simrat pāp bilāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਨਾਮ) ਜੀਭ ਨਾਲ ਜਪਦਿਆਂ (ਸਾਰੇ) ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя языком, грехи исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
