{
  "ang": 868,
  "shabads": [
    {
      "shabad_id": 3245,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36787,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਸਭ ਮਾਹਿ ਨਿਵਾਸ ॥",
          "roman": "narāyaṇ sabh māh nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਭ ਜੀਵਾਂ ਵਿਚ ਨਾਰਾਇਣ ਦਾ ਨਿਵਾਸ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нараян пребывает во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36788,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਘਟਿ ਘਟਿ ਪਰਗਾਸ ॥",
          "roman": "narāyaṇ ghaṭ ghaṭ pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਨਾਰਾਇਣ (ਦੀ ਜੋਤਿ) ਦਾ ਹੀ ਚਾਨਣ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В каждом теле сияет свет Нараяна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36789,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਕਹਤੇ ਨਰਕਿ ਨ ਜਾਹਿ ॥",
          "roman": "narāyaṇ kahte narak na jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ (ਦਾ ਨਾਮ) ਜਪਣ ਵਾਲੇ ਜੀਵ ਨਰਕ ਵਿਚ ਨਹੀਂ ਪੈਂਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кто повторяют Имя Нараяна, не попадают в ад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36790,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਸੇਵਿ ਸਗਲ ਫਲ ਪਾਹਿ ॥੧॥",
          "roman": "narāyaṇ sev sagal phal pāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ ਦੀ ਭਗਤੀ ਕਰ ਕੇ ਸਾਰੇ ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Служа Нараяну, получают все плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36791,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਮਨ ਮਾਹਿ ਅਧਾਰ ॥",
          "roman": "narāyaṇ man māh adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਰਾਇਣ (ਦੇ ਨਾਮ) ਨੂੰ (ਆਪਣੇ) ਮਨ ਵਿਚ ਆਸਰਾ ਬਣਾ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сделай Имя Нараяна опорой в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36792,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਬੋਹਿਥ ਸੰਸਾਰ ॥",
          "roman": "narāyaṇ bohith sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ (ਦਾ ਨਾਮ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ ਪਾਰ ਲੰਘਣ ਲਈ ਜਹਾਜ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Нараяна — корабль для переправы через мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36793,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਕਹਤ ਜਮੁ ਭਾਗਿ ਪਲਾਇਣ ॥",
          "roman": "narāyaṇ kahat jam bhāg palāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ ਦਾ ਨਾਮ ਜਪਦਿਆਂ ਜਮ ਭੱਜ ਕੇ ਪਰੇ ਚਲਾ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "При повторении Имени Яма убегает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36794,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਦੰਤ ਭਾਨੇ ਡਾਇਣ ॥੨॥",
          "roman": "narāyaṇ dant bhāne ḍāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ (ਦਾ ਨਾਮ ਮਾਇਆ) ਡੈਣ ਦੇ ਦੰਦ ਭੰਨ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Нараяна ломает зубы ведьмы майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36795,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਸਦ ਸਦ ਬਖਸਿੰਦ ॥",
          "roman": "narāyaṇ sad sad bakhsiṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਰਾਇਣ ਸਦਾ ਹੀ ਬਖ਼ਸ਼ਣਹਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нараян всегда милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36796,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਕੀਨੇ ਸੂਖ ਅਨੰਦ ॥",
          "roman": "narāyaṇ kīne sūkh anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਰਾਇਣ (ਆਪਣੇ ਸੇਵਕਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਸੁਖ ਆਨੰਦ ਪੈਦਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нараян приносит радость и счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36797,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਪ੍ਰਗਟ ਕੀਨੋ ਪਰਤਾਪ ॥",
          "roman": "narāyaṇ pragat kīno partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਆਪਣਾ) ਤੇਜ-ਪਰਤਾਪ ਪਰਗਟ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он проявляет своё величие внутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36798,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਸੰਤ ਕੋ ਮਾਈ ਬਾਪ ॥੩॥",
          "roman": "narāyaṇ sant ko māī bāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਰਾਇਣ ਆਪਣੇ ਸੇਵਕਾਂ ਸੰਤਾਂ ਦਾ ਮਾਂ ਪਿਉ (ਵਾਂਗ ਰਾਖਾ) ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нараян — как мать и отец для святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36799,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਸਾਧਸੰਗਿ ਨਰਾਇਣ ॥",
          "roman": "narāyaṇ sādhsaṅg narāyaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜੇ ਮਨੁੱਖ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਟਿਕ ਕੇ ਸਦਾ ਨਾਰਾਇਣ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто пребывают в святом собрании и повторяют Имя Нараяна,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36800,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰੰ ਬਾਰ ਨਰਾਇਣ ਗਾਇਣ ॥",
          "roman": "bāraṅ bār narāyaṇ gāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁੜ ਮੁੜ ਉਸ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "снова и снова воспевают Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36801,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤੁ ਅਗੋਚਰ ਗੁਰ ਮਿਲਿ ਲਹੀ ॥",
          "roman": "bast agochar gur mil lahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਉਹ ਮਿਲਾਪ-ਰੂਪ ਕੀਮਤੀ) ਚੀਜ਼ ਲੱਭ ਲੈਂਦੇ ਹਨ ਜੇਹੜੀ ਇਹਨਾਂ ਇੰਦਰਿਆਂ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, они находят скрытое сокровище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36802,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਓਟ ਨਾਨਕ ਦਾਸ ਗਹੀ ॥੪॥੧੭॥੧੯॥",
          "roman": "narāyaṇ oṭ nānak dās gahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਨਾਰਾਇਣ ਦੇ ਦਾਸ ਸਦਾ ਨਾਰਾਇਣ ਦਾ ਆਸਰਾ ਲਈ ਰੱਖਦੇ ਹਨ ॥੪॥੧੭॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "Слуги Нараяна держатся за Его защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3246,
      "rahao_verse_id": 36805,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36803,
          "is_rahao": true,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "gond mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36804,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕਉ ਰਾਖੈ ਰਾਖਣਹਾਰੁ ॥",
          "roman": "jā kau rākhē rākhanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਰੱਖਣ-ਜੋਗ ਪ੍ਰਭੂ (ਕਾਮਾਦਿਕ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾਣਾ ਚਾਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Того человека, которого Господь, достойный защищать, хочет уберечь от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36805,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸ ਕਾ ਅੰਗੁ ਕਰੇ ਨਿਰੰਕਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tis kā ang kare nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਉਸ ਮਨੁੱਖ ਦਾ ਪੱਖ ਕਰਦਾ ਹੈ (ਉਸ ਦੀ ਮਦਦ ਕਰਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Господь становится на сторону этого человека, помогает ему"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36806,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਗਰਭ ਮਹਿ ਅਗਨਿ ਨ ਜੋਹੈ ॥",
          "roman": "māt garabh meh agan na johē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਵੇਂ ਜੀਵ ਨੂੰ) ਮਾਂ ਦੇ ਪੇਟ ਵਿਚ ਅੱਗ ਦੁੱਖ ਨਹੀਂ ਦੇਂਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Как в утробе матери огонь не причиняет страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36807,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਲੋਭੁ ਮੋਹੁ ਨ ਪੋਹੈ ॥",
          "roman": "kām krodh lobh moh na pohē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਵੇਂ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਦਾ ਪੱਖ ਕਰਦਾ ਹੈ, ਉਸ ਨੂੰ) ਕਾਮ, ਕ੍ਰੋਧ, ਲੋਭ, ਮੋਹ (ਕੋਈ ਭੀ) ਆਪਣੇ ਦਬਾਉ ਵਿਚ ਨਹੀਂ ਲਿਆ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "так и того, кому Господь помогает, не могут подчинить себе похоть, гнев, жадность и привязанность"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36808,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਪੈ ਨਿਰੰਕਾਰੁ ॥",
          "roman": "sādh sangat japē nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਟਿਕ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек пребывает в обществе Гуру и повторяет Имя Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36809,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕੈ ਮੁਹਿ ਲਾਗੈ ਛਾਰੁ ॥੧॥",
          "roman": "nindak kē muh lāgē chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਸ) ਦੀ ਨਿੰਦਾ ਕਰਨ ਵਾਲੇ ਮਨੁੱਖ ਦੇ ਸਿਰ ਉਤੇ ਸੁਆਹ ਪੈਂਦੀ ਹੈ (ਨਿੰਦਕ ਬਦਨਾਮੀ ਹੀ ਖੱਟਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "А на голову клеветника падает пепел, он лишь приобретает позор"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36810,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਕਵਚੁ ਦਾਸ ਕਾ ਸੰਨਾਹੁ ॥",
          "roman": "rām kavach dās kā sannāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਸੇਵਕ ਵਾਸਤੇ (ਸ਼ਸਤ੍ਰਾਂ ਦੀ ਮਾਰ ਤੋਂ ਬਚਾਣ ਵਾਲਾ) ਤੰਤ੍ਰ ਹੈ, ਸੰਜੋਅ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — это защита и броня для Его слуги"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36811,
          "is_rahao": false,
          "gurmukhi": "ਦੂਤ ਦੁਸਟ ਤਿਸੁ ਪੋਹਤ ਨਾਹਿ ॥",
          "roman": "dūt dusat tis pohat nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ ਪਾਸ ਰਾਮ-ਨਾਮ ਦਾ ਕਵਚ ਹੈ ਸੰਜੋਅ ਹੈ) ਉਸ ਨੂੰ (ਕਾਮਾਦਿਕ) ਚੰਦਰੇ ਵੈਰੀ ਪੋਹ ਨਹੀਂ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Имеющего эту защиту не могут коснуться злые враги"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36812,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਗਰਬੁ ਕਰੇ ਸੋ ਜਾਇ ॥",
          "roman": "jo jo garab kare so jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜੇਹੜਾ ਜੇਹੜਾ ਮਨੁੱਖ (ਆਪਣੀ ਤਾਕਤ ਦਾ) ਮਾਣ ਕਰਦਾ ਹੈ, ਉਹ (ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ) ਤਬਾਹ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но каждый, кто гордится своей силой, разрушается духовно"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36813,
          "is_rahao": false,
          "gurmukhi": "ਗਰੀਬ ਦਾਸ ਕੀ ਪ੍ਰਭੁ ਸਰਣਾਇ ॥੨॥",
          "roman": "garīb dās kī prabh saraṇāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗ਼ਰੀਬ ਦਾ ਆਸਰਾ ਸੇਵਕ ਦਾ ਆਸਰਾ ਪ੍ਰਭੂ ਆਪ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Прибежище бедного слуги — Сам Господь"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36814,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਸਰਣਿ ਪਇਆ ਹਰਿ ਰਾਇ ॥",
          "roman": "jo jo saraṇ paiā har rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਜੇਹੜਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਪਾਤਿਸ਼ਾਹ ਦੀ ਸਰਨੀ ਪੈ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каждый, кто приходит в прибежище Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36815,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਦਾਸੁ ਰਖਿਆ ਅਪਣੈ ਕੰਠਿ ਲਾਇ ॥",
          "roman": "so dās rakhia apṇē kanth lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸੇਵਕ ਨੂੰ ਪ੍ਰਭੂ ਆਪਣੇ ਗਲ ਨਾਲ ਲਾ ਕੇ (ਦੁਸਟ ਦੂਤਾਂ ਤੋਂ) ਬਚਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того Господь обнимает и защищает от злых сил"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36816,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਬਹੁਤੁ ਕਰੇ ਅਹੰਕਾਰੁ ॥",
          "roman": "je ko bahut kare ahaṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਹੜਾ ਮਨੁੱਖ (ਆਪਣੀ ਹੀ ਤਾਕਤ ਉਤੇ) ਬੜਾ ਮਾਣ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но тот, кто сильно гордится своей силой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36817,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਖਿਨ ਮਹਿ ਰੁਲਤਾ ਖਾਕੂ ਨਾਲਿ ॥੩॥",
          "roman": "ohu khin meh rultā khākū nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖਾਂ (ਇਹਨਾਂ ਦੂਤਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਇਕ ਖਿਨ ਵਿਚ ਹੀ ਮਿੱਟੀ ਵਿਚ ਮਿਲ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тот в одно мгновение обращается в прах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36818,
          "is_rahao": false,
          "gurmukhi": "ਹੈ ਭੀ ਸਾਚਾ ਹੋਵਣਹਾਰੁ ॥",
          "roman": "hē bhī sāchā hovanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਹੁਣ ਭੀ ਮੌਜੂਦ ਹੈ, ਸਦਾ ਲਈ ਮੌਜੂਦ ਰਹੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Истинный Господь существует сейчас и будет существовать всегда"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36819,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਾੲਂੀ ਬਲਿਹਾਰ ॥",
          "roman": "sadā sadā jāī baliḥār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਸਦਾ ਉਸੇ ਉਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я всегда жертвую собой ради Него"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36820,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੇ ਦਾਸ ਰਖੇ ਕਿਰਪਾ ਧਾਰਿ ॥",
          "roman": "apṇe dās rakhe kirpā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਆਪਣੇ ਦਾਸ ਨੂੰ ਕਿਰਪਾ ਕਰ ਕੇ (ਵਿਕਾਰਾਂ ਤੋਂ ਸਦਾ) ਬਚਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь по милости защищает Своих слуг"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36821,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੇ ਪ੍ਰਭ ਪ੍ਰਾਣ ਅਧਾਰ ॥੪॥੧੮॥੨੦॥",
          "roman": "nānak ke prabh prāṇ adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਦੇ ਪ੍ਰਭੂ ਜੀ ਆਪਣੇ ਦਾਸਾਂ ਦੀ ਜਿੰਦ ਦਾ ਆਸਰਾ ਹਨ ॥੪॥੧੮॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "Господь Нанака — опора жизни для Своих слуг"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3247,
      "rahao_verse_id": 36823,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36822,
          "is_rahao": true,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "gond mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36823,
          "is_rahao": true,
          "gurmukhi": "ਅਚਰਜ ਕਥਾ ਮਹਾ ਅਨੂਪ ॥ ਪ੍ਰਾਤਮਾ ਪਾਰਬ੍ਰਹਮ ਕਾ ਰੂਪੁ ॥ ਰਹਾਉ ॥",
          "roman": "acharaj kathā mahā anūp prātmā pārbrahm kā rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀਆਂ ਗੱਲਾਂ ਹੈਰਾਨ ਕਰਨ ਵਾਲੀਆਂ ਹਨ ਤੇ ਬੜੀਆਂ ਅਦੁਤੀ ਹਨ, ਜੀਵਾਤਮਾ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਰੂਪ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Славословие Господа удивительно и несравненно, душа есть образ Высшего Брахмана"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36824,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਬੂਢਾ ਨਾ ਇਹੁ ਬਾਲਾ ॥",
          "roman": "nā ih būḍhā nā ih bālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵਾਤਮਾ ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ ਉਹ ਐਸਾ ਹੈ ਕਿ) ਨਾਹ ਇਹ ਕਦੇ ਬੁੱਢਾ ਹੁੰਦਾ ਹੈ, ਨਾਹ ਹੀ ਇਹ ਕਦੇ ਬਾਲਕ (ਅਵਸਥਾ ਵਿਚ ਪਰ-ਅਧੀਨ) ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он не стареет и не становится ребёнком"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36825,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਦੂਖੁ ਨਹੀ ਜਮ ਜਾਲਾ ॥",
          "roman": "nā is dūkh nahī jam jālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਨੂੰ ਕੋਈ ਦੁੱਖ ਨਹੀਂ ਪੋਹ ਸਕਦਾ, ਜਮਾਂ ਦਾ ਜਾਲ ਫਸਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Его не может коснуться страдание и сеть смерти"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36826,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਬਿਨਸੈ ਨਾ ਇਹੁ ਜਾਇ ॥",
          "roman": "nā ih binsē nā ih jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਐਸਾ ਹੈ ਕਿ) ਨਾਹ ਇਹ ਕਦੇ ਮਰਦਾ ਹੈ ਨਾਹ ਜੰਮਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он не умирает и не рождается"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36827,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਜੁਗਾਦੀ ਰਹਿਆ ਸਮਾਇ ॥੧॥",
          "roman": "ād jugādī rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਤਾਂ ਸ਼ੁਰੂ ਤੋਂ ਹੀ, ਜੁਗਾਂ ਦੇ ਸ਼ੁਰੂ ਤੋਂ ਹੀ (ਹਰ ਥਾਂ) ਵਿਆਪਕ ਚਲਿਆ ਆ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "С самого начала времён Он пребывает повсюду"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36828,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਉਸਨੁ ਨਹੀ ਇਸੁ ਸੀਤੁ ॥",
          "roman": "nā is usan nahī is sīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵਾਤਮਾ ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਹੈ ਉਹ ਐਸਾ ਹੈ ਕਿ) ਇਸ ਨੂੰ (ਵਿਕਾਰਾਂ ਦੀ) ਤਪਸ਼ ਨਹੀਂ ਪੋਹ ਸਕਦੀ (ਚਿੰਤਾ-ਫ਼ਿਕਰ ਦਾ) ਪਾਲਾ ਨਹੀਂ ਵਿਆਪ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Его не касается ни жар, ни холод"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36829,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਦੁਸਮਨੁ ਨਾ ਇਸੁ ਮੀਤੁ ॥",
          "roman": "nā is dusman nā is mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਸ ਦਾ ਕੋਈ ਵੈਰੀ ਹੈ ਨਾਹ ਮਿੱਤਰ ਹੈ (ਕਿਉਂਕਿ ਇਸ ਦੇ ਬਰਾਬਰ ਦਾ ਕੋਈ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "У Него нет ни врага, ни друга"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36830,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਹਰਖੁ ਨਹੀ ਇਸੁ ਸੋਗੁ ॥",
          "roman": "nā is harakh nahī is sog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਖ਼ੁਸ਼ੀ ਜਾਂ ਗ਼ਮੀ ਭੀ ਇਸ ਉਤੇ ਆਪਣਾ ਪ੍ਰਭਾਵ ਨਹੀਂ ਪਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Ни радость, ни печаль не влияют на Него"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36831,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਇਸ ਕਾ ਇਹੁ ਕਰਨੈ ਜੋਗੁ ॥੨॥",
          "roman": "sabh kichh is kā ih karnē jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੀ) ਹਰੇਕ ਸ਼ੈ ਇਸੇ ਦੀ ਹੀ ਪੈਦਾ ਕੀਤੀ ਹੋਈ ਹੈ, ਇਹ ਸਭ ਕੁਝ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Всё создано Им, и Он способен на всё"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36832,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਬਾਪੁ ਨਹੀ ਇਸੁ ਮਾਇਆ ॥",
          "roman": "nā is bāp nahī is māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵਾਤਮਾ ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ ਉਹ ਐਸਾ ਹੈ ਕਿ) ਇਸ ਦਾ ਨਾਹ ਕੋਈ ਪਿਉ ਹੈ, ਨਾਹ ਇਸ ਦੀ ਮਾਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У Него нет ни отца, ни матери"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36833,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਅਪਰੰਪਰੁ ਹੋਤਾ ਆਇਆ ॥",
          "roman": "ih aparampar hotā āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਤਾਂ ਪਰੇ ਤੋਂ ਪਰੇ ਹੈ, ਤੇ ਸਦਾ ਹੀ ਹੋਂਦ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он беспределен и существует вечно"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36834,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਪੁੰਨ ਕਾ ਇਸੁ ਲੇਪੁ ਨ ਲਾਗੈ ॥",
          "roman": "pāp punn kā is lep na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਾਪਾਂ ਅਤੇ ਪੁੰਨਾਂ ਦਾ ਭੀ ਇਸ ਉਤੇ ਕੋਈ ਅਸਰ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Ни грех, ни заслуга не прилипают к Нему"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36835,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਸਦ ਹੀ ਜਾਗੈ ॥੩॥",
          "roman": "ghaṭ ghaṭ antar sad hī jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਪ੍ਰਭੂ ਹਰੇਕ ਸਰੀਰ ਦੇ ਅੰਦਰ ਮੌਜੂਦ ਹੈ, ਅਤੇ ਸਦਾ ਹੀ ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает внутри каждого и всегда бодрствует"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36836,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਗੁਣਾ ਇਕ ਸਕਤਿ ਉਪਾਇਆ ॥",
          "roman": "tīn guṇā ik sakat upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵਾਤਮਾ ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ) ਇਹ ਬੜੀ ਡਾਢੀ ਮਾਇਆ ਉਸੇ ਦਾ ਹੀ ਪਰਛਾਵਾਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Эта могучая майя есть лишь Его отражение"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36837,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਮਾਇਆ ਤਾ ਕੀ ਹੈ ਛਾਇਆ ॥",
          "roman": "mahā māiā tā kī hē chhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਤਿੰਨਾਂ ਗੁਣਾਂ ਵਾਲੀ ਮਾਇਆ ਉਸੇ ਨੇ ਹੀ ਪੈਦਾ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эту трёхгунную майю создал Он Сам"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36838,
          "is_rahao": false,
          "gurmukhi": "ਅਛਲ ਅਛੇਦ ਅਭੇਦ ਦਇਆਲ ॥",
          "roman": "achhal achhed abhed dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ (ਕੋਈ ਵਿਕਾਰ) ਛਲ ਨਹੀਂ ਸਕਦਾ, ਵਿੰਨ੍ਹ ਨਹੀਂ ਸਕਦਾ, ਉਸ ਦਾ ਭੇਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ, ਉਹ ਦਇਆ ਦਾ ਘਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его невозможно обмануть, пронзить или постичь, Он — источник милости"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36839,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਸਦਾ ਕਿਰਪਾਲ ॥",
          "roman": "dīn dayāl sadā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਦੀਨਾਂ ਉਤੇ ਸਦਾ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈ, ਤੇ, ਦਇਆ ਦਾ ਸੋਮਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он всегда милостив к смиренным"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36840,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਗਤਿ ਮਿਤਿ ਕਛੂ ਨ ਪਾਇ ॥",
          "roman": "tā kī gat mit kachhū na pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਕਿਹੋ ਜਿਹਾ ਹੈ ਤੇ ਕੇਡਾ ਵੱਡਾ ਹੈ-ਇਹ ਭੇਤ ਲੱਭਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Невозможно постичь Его состояние и величие"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36841,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੈ ਬਲਿ ਬਲਿ ਜਾਇ ॥੪॥੧੯॥੨੧॥",
          "roman": "nānak tā kē bal bal jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹੈ ॥੪॥੧੯॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак всегда жертвует собой ради Него"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
