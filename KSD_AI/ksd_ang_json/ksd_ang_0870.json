{
  "ang": 870,
  "shabads": [
    {
      "shabad_id": 3250,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36897,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਭਗਤਾ ਕੀ ॥",
          "roman": "rāg goṇḍ bāṇī bhagtā kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਗੋਂਡ ਵਿੱਚ ਭਗਤਾਂ ਦੀ ਬਾਣੀ।(ਰਾਗ ਗੋਂਡ)"
            },
            "sahib_singh_ru": {
              "main": "В раге Гонд — бани Бхагатов. (Раг Гонд)"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3251,
      "rahao_verse_id": 36903,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36898,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਜੀ ਘਰੁ ੧",
          "roman": "kabīr jī ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘਰ ੧ ਵਿੱਚ ਭਗਤ ਕਬੀਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В доме 1 — бани Бхагата Кабира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36899,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуракх один, и постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36900,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤੁ ਮਿਲੈ ਕਿਛੁ ਸੁਨੀਐ ਕਹੀਐ ॥",
          "roman": "sant milē kichh sunīē kahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਭਲਾ ਮਨੁੱਖ ਮਿਲ ਪਏ ਤਾਂ (ਉਸ ਦੀ ਸਿੱਖਿਆ) ਸੁਣਨੀ ਚਾਹੀਦੀ ਹੈ, ਤੇ (ਜੀਵਨ ਦੇ ਰਾਹ ਦੀਆਂ ਗੁੰਝਲਾਂ) ਪੁੱਛਣੀਆਂ ਚਾਹੀਦੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Если встречается добрый человек, следует слушать его наставление и спрашивать о жизненных трудностях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36901,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੈ ਅਸੰਤੁ ਮਸਟਿ ਕਰਿ ਰਹੀਐ ॥੧॥",
          "roman": "milē asant mast kar rahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਕੋਈ ਭੈੜਾ ਬੰਦਾ ਮਿਲ ਪਏ, ਤਾਂ ਉੱਥੇ ਚੁੱਪ ਰਹਿਣਾ ਹੀ ਠੀਕ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Если же встретится дурной человек, лучше оставаться молчаливым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36902,
          "is_rahao": true,
          "gurmukhi": "ਬਾਬਾ ਬੋਲਨਾ ਕਿਆ ਕਹੀਐ ॥",
          "roman": "bābā bolṇā kiā kahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਗਤ ਵਿਚ ਰਹਿੰਦਿਆਂ) ਕਿਹੋ ਜਿਹੇ ਬੋਲ ਬੋਲੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Какие слова следует произносить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36903,
          "is_rahao": true,
          "gurmukhi": "ਜੈਸੇ ਰਾਮ ਨਾਮ ਰਵਿ ਰਹੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jēse rām nām rav rahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੀ ਬਰਕਤਿ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਸੁਰਤ ਟਿਕੀ ਰਹੇ? (ਨੋਟ: ਬਾਕੀ ਦੇ ਸਾਰੇ ਸ਼ਬਦ ਵਿਚ ਇਸ ਪ੍ਰਸ਼ਨ ਦਾ ਉੱਤਰ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы благодаря им ум пребывал в Имени Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36904,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਸਿਉ ਬੋਲੇ ਉਪਕਾਰੀ ॥",
          "roman": "santan siu bole upkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਭਲਿਆਂ ਨਾਲ ਗੱਲ ਕੀਤਿਆਂ ਕੋਈ ਭਲਾਈ ਦੀ ਗੱਲ ਨਿਕਲੇਗੀ,"
            },
            "sahib_singh_ru": {
              "main": "Общение с добрыми приносит благо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36905,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖ ਸਿਉ ਬੋਲੇ ਝਖ ਮਾਰੀ ॥੨॥",
          "roman": "mūrakh siu bole jhakh mārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੂਰਖ ਨਾਲ ਬੋਲਿਆਂ ਵਿਅਰਥ ਖਪ-ਖਪਾ ਹੀ ਹੋਵੇਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а разговор с глупцом ведёт лишь к напрасной суете."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36906,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲਤ ਬੋਲਤ ਬਢਹਿ ਬਿਕਾਰਾ ॥",
          "roman": "bolat bolat baḍhah bikārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ) ਜਿਉਂ ਜਿਉਂ (ਮੂਰਖ ਨਾਲ) ਗੱਲਾਂ ਕਰੀਏ (ਉਸ ਦੇ ਕੁਸੰਗ ਵਿਚ) ਵਿਕਾਰ ਹੀ ਵਿਕਾਰ ਵਧਦੇ ਹਨ; (ਪਰ ਇਸ ਦਾ ਭਾਵ ਇਹ ਨਹੀਂ ਕਿ ਕਿਸੇ ਨਾਲ ਭੀ ਬਹਿਣਾ-ਖਲੋਣਾ ਨਹੀਂ ਚਾਹੀਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "При общении с глупым человеком пороки только возрастают;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36907,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੋਲੇ ਕਿਆ ਕਰਹਿ ਬੀਚਾਰਾ ॥੩॥",
          "roman": "bin bole kiā karahi bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਭਲੇ ਮਨੁੱਖਾਂ ਨਾਲ ਭੀ ਨਹੀਂ ਬੋਲਾਂਗੇ, (ਭਾਵ, ਜੇ ਭਲਿਆਂ ਪਾਸ ਭੀ ਨਹੀਂ ਬੈਠਾਂਗੇ) ਤਾਂ ਵਿਚਾਰ ਦੀਆਂ ਗੱਲਾਂ ਕਿਵੇਂ ਕਰ ਸਕਦੇ ਹਾਂ? ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но если не общаться и с добрыми, как возникнут разумные мысли?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36908,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਛੂਛਾ ਘਟੁ ਬੋਲੈ ॥",
          "roman": "kah kabīr chhūchhā ghaṭ bolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਸੱਚੀ ਗੱਲ ਇਹ ਹੈ ਕਿ (ਜਿਵੇਂ) ਖ਼ਾਲੀ ਘੜਾ ਬੋਲਦਾ ਹੈ, ਜੇ ਉਹ (ਪਾਣੀ ਨਾਲ) ਭਰਿਆ ਹੋਇਆ ਹੋਵੇ ਤਾਂ ਉਹ ਕਦੇ ਡੋਲਦਾ ਨਹੀਂ (ਇਸੇ ਤਰ੍ਹਾਂ ਬਹੁਤੀਆਂ ਫ਼ਾਲਤੂ ਗੱਲਾਂ ਗੁਣ-ਹੀਨ ਮਨੁੱਖ ਹੀ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: пустой сосуд звучит;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36909,
          "is_rahao": false,
          "gurmukhi": "ਭਰਿਆ ਹੋਇ ਸੁ ਕਬਹੁ ਨ ਡੋਲੈ ॥੪॥੧॥",
          "roman": "bhariā hoi su kabah na dolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਗੁਣਵਾਨ ਹੈ ਉਹ ਅਡੋਲ ਰਹਿੰਦਾ ਹੈ। ਸੋ, ਜਗਤ ਵਿਚ ਕੋਈ ਐਸਾ ਉੱਦਮ ਕਰੀਏ, ਜਿਸ ਨਾਲ ਗੁਣ ਗ੍ਰਹਿਣ ਕਰ ਸਕੀਏ, ਤੇ ਇਹ ਗੁਣ ਮਿਲ ਸਕਦੇ ਹਨ ਭਲਿਆਂ ਪਾਸੋਂ ਹੀ) ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "наполненный остаётся устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3252,
      "rahao_verse_id": 36914,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36910,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36911,
          "is_rahao": false,
          "gurmukhi": "ਨਰੂ ਮਰੈ ਨਰੁ ਕਾਮਿ ਨ ਆਵੈ ॥",
          "roman": "narū marē nar kām na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ ਕਦੇ ਸੋਚ ਹੀ ਨਹੀਂ ਫੁਰਦੀ ਕਿ ਮੈਂ ਕਿਸ ਸਰੀਰ ਤੇ ਮਾਣ ਕਰ ਕੇ ਮੰਦੇ ਕੰਮ ਕਰਦਾ ਰਹਿੰਦਾ ਹਾਂ, ਮੇਰਾ ਅਸਲਾ ਤਾਂ ਇਹੀ ਹੈ ਨਾ ਕਿ) ਜਦੋਂ ਮਨੁੱਖ ਮਰ ਜਾਂਦਾ ਹੈ ਤਾਂ ਮਨੁੱਖ (ਦਾ ਸਰੀਰ) ਕਿਸੇ ਕੰਮ ਨਹੀਂ ਆਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек умирает, его тело уже ни на что не годится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36912,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਮਰੈ ਦਸ ਕਾਜ ਸਵਾਰੈ ॥੧॥",
          "roman": "pasū marē das kāj savārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਸ਼ੂ ਮਰਦਾ ਹੈ ਤਾਂ (ਫਿਰ ਭੀ ਉਸ ਦਾ ਸਰੀਰ ਮਨੁੱਖ ਦੇ) ਕਈ ਕੰਮ ਸਵਾਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а животное после смерти приносит пользу во многих делах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36913,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਕਰਮ ਕੀ ਗਤਿ ਮੈ ਕਿਆ ਜਾਨਉ ॥",
          "roman": "apne karam kī gat mē kiā jānau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਬਾਬਾ! ਮੈਂ ਕਦੇ ਸੋਚਦਾ ਹੀ ਨਹੀਂ ਕਿ ਮੈਂ ਕਿਹੋ ਜਿਹੇ ਨਿੱਤ-ਕਰਮ ਕਰੀ ਜਾ ਰਿਹਾ ਹਾਂ, (ਮੈਂ ਮੰਦੇ ਪਾਸੇ ਹੀ ਲੱਗਾ ਰਹਿੰਦਾ ਹਾਂ, ਤੇ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я не задумываюсь, какие поступки совершаю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36914,
          "is_rahao": true,
          "gurmukhi": "ਮੈ ਕਿਆ ਜਾਨਉ ਬਾਬਾ ਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mē kiā jānau bābā re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਖ਼ਿਆਲ ਹੀ ਨਹੀਂ ਆਉਂਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "мне даже не приходит это в голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36915,
          "is_rahao": false,
          "gurmukhi": "ਹਾਡ ਜਲੇ ਜੈਸੇ ਲਕਰੀ ਕਾ ਤੂਲਾ ॥",
          "roman": "hāḍ jale jēse lakrī kā tūlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਬਾਬਾ! ਮੈਂ ਕਦੇ ਸੋਚਿਆ ਹੀ ਨਹੀਂ ਕਿ ਮੌਤ ਆਇਆਂ ਇਸ ਸਰੀਰ ਦੀਆਂ) ਹੱਡੀਆਂ ਲੱਕੜਾਂ ਦੇ ਢੇਰ ਵਾਂਗ ਸੜ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Кости сгорают, как куча дров,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36916,
          "is_rahao": false,
          "gurmukhi": "ਕੇਸ ਜਲੇ ਜੈਸੇ ਘਾਸ ਕਾ ਪੂਲਾ ॥੨॥",
          "roman": "kes jale jēse ghās kā pūlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਇਸ ਦੇ) ਕੇਸ ਘਾਹ ਦੇ ਪੂਲੇ ਵਾਂਘ ਸੜ ਜਾਂਦੇ ਹਨ (ਤੇ ਜਿਸ ਸਰੀਰ ਦਾ ਮਗਰੋਂ ਇਹ ਹਾਲ ਹੁੰਦਾ ਹੈ, ਉਸੇ ਉੱਤੇ ਮੈਂ ਸਾਰੀ ਉਮਰ ਮਾਣ ਕਰਦਾ ਰਹਿੰਦਾ ਹਾਂ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "волосы сгорают, как пучок травы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36917,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਤਬ ਹੀ ਨਰੁ ਜਾਗੈ ॥",
          "roman": "kah kabīr tab hī nar jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਕਬੀਰ ਆਖਦਾ ਹੈ- ਸੱਚ ਇਹ ਹੈ ਕਿ ਮਨੁੱਖ ਇਸ ਮੂਰਖਤਾ ਵਲੋਂ ਤਦੋਂ ਹੀ ਜਾਗਦਾ ਹੈ (ਤਦੋਂ ਹੀ ਪਛਤਾਉਂਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: человек пробуждается"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36918,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਕਾ ਡੰਡੁ ਮੂੰਡ ਮਹਿ ਲਾਗੈ ॥੩॥੨॥",
          "roman": "jam kā ḍaṇḍ muṇḍ mahi lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮੌਤ ਦਾ ਡੰਡਾ ਇਸ ਦੇ ਸਿਰ ਉੱਤੇ ਆ ਵੱਜਦਾ ਹੈ ॥੩॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "только тогда, когда удар смерти падает на его голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3253,
      "rahao_verse_id": 36923,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36919,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36920,
          "is_rahao": false,
          "gurmukhi": "ਆਕਾਸਿ ਗਗਨੁ ਪਾਤਾਲਿ ਗਗਨੁ ਹੈ ਚਹੁ ਦਿਸਿ ਗਗਨੁ ਰਹਾਇਲੇ ॥",
          "roman": "ākās gagan pātāl gagan hē chah dis gagan rahāile",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਜਿੰਦ ਜਿਸ ਦਾ ਅੰਸ਼ ਹੈ ਉਹ) ਚੇਤਨ-ਸੱਤਾ ਅਕਾਸ਼ ਤੋਂ ਪਤਾਲ ਤੱਕ ਹਰ ਪਾਸੇ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сознательная сущность присутствует повсюду — от небес до подземья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36921,
          "is_rahao": false,
          "gurmukhi": "ਆਨਦ ਮੂਲੁ ਸਦਾ ਪੁਰਖੋਤਮੁ ਘਟੁ ਬਿਨਸੈ ਗਗਨੁ ਨ ਜਾਇਲੇ ॥੧॥",
          "roman": "ānand mūl sadā purkhotam ghaṭ binsē gagan na jāile",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ (ਜੀਵਾਂ ਦੇ) ਸੁਖ ਦਾ ਮੂਲ-ਕਾਰਨ ਹੈ। ਉਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਉਹ ਹੀ (ਹੈ ਜਿਸ ਨੂੰ) ਉੱਤਮ ਪੁਰਖ (ਪਰਮਾਤਮਾ ਕਹੀਦਾ) ਹੈ। (ਜੀਵਾਂ ਦਾ) ਸਰੀਰ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ, ਪਰ (ਸਰੀਰ ਵਿਚ ਵੱਸਦੀ ਜਿੰਦ ਦਾ ਸੋਮਾ) ਚੇਤਨ-ਸੱਤਾ ਨਾਸ ਨਹੀਂ ਹੁੰਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Она — источник блаженства, вечна; тело разрушается, но эта сущность не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36922,
          "is_rahao": true,
          "gurmukhi": "ਮੋਹਿ ਬੈਰਾਗੁ ਭਇਓ ॥",
          "roman": "moh bērāg bhēō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਮਨ ਵਿੱਚ (ਹੋਰਨਾਂ ਗੱਲਾਂ ਵਲੋਂ) ਉਪਰਾਮਤਾ ਹੋ ਰਹੀ ਹੈ, (ਮੈਨੂੰ ਹੋਰ ਗੱਲਾਂ ਗ਼ੈਰ-ਜ਼ਰੂਰੀ ਜਾਪਦੀਆਂ ਹਨ।)"
            },
            "sahib_singh_ru": {
              "main": "Во мне возникает отрешённость от всего остального,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36923,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਜੀਉ ਆਇ ਕਹਾ ਗਇਓ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ih jīu āi kahā gaiō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਨਿਸ਼ਚਾ ਹੁਣ ਇਸ ਗੱਲ ਉੱਤੇ ਟਿਕ ਗਿਆ ਹੈ ਕਿ ਇਹ ਜਿੰਦ ਕਦੇ ਮਰਦੀ ਨਹੀਂ (ਕਿਉਂਕਿ ਇਹ ਜਿੰਦ ਉਸ ਸਰਬ-ਵਿਆਪਕ ਸਦਾ-ਥਿਰ ਚੇਤਨ-ਸੱਤਾ ਦਾ ਅੰਸ਼ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "я утвердился в понимании, что душа не умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36924,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਤਤੁ ਮਿਲਿ ਕਾਇਆ ਕੀਨੑੀ ਤਤੁ ਕਹਾ ਤੇ ਕੀਨੁ ਰੇ ॥",
          "roman": "pañch tat mil kāiā kīnhī tat kahā te kīn re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੰਜਾਂ ਤੱਤਾਂ ਨੇ ਮਿਲ ਕੇ ਇਹ ਸਰੀਰ ਬਣਾਇਆ ਹੈ (ਪਰ ਇਹਨਾਂ ਤੱਤਾਂ ਦੀ ਭੀ ਕੋਈ ਵੱਖਰੀ ਹਸਤੀ ਨਹੀਂ ਹੈ), ਇਹ ਤੱਤ ਭੀ ਹੋਰ ਕਿੱਥੋਂ ਬਣਨੇ ਸਨ? (ਇਹ ਭੀ ਚੇਤਨ-ਸੱਤਾ ਤੋਂ ਹੀ ਬਣੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Тело создано из пяти элементов, но сами элементы тоже имеют источник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36925,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਬਧ ਤੁਮ ਜੀਉ ਕਹਤ ਹੌ ਕਰਮਹਿ ਕਿਨਿ ਜੀਉ ਦੀਨੁ ਰੇ ॥੨॥",
          "roman": "karam badh tum jīu kahat hau karmah kin jīu dīn re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੁਸੀ ਲੋਕ ਇਹ ਆਖਦੇ ਹੋ ਕਿ ਜੀਵਾਤਮਾ ਕੀਤੇ ਕਰਮਾਂ ਕਰਮਾਂ ਦਾ ਬੱਝਾ ਹੋਇਆ ਹੈ, (ਪਰ ਅਸਲ ਗੱਲ ਇਹ ਹੈ ਕਿ) ਕਰਮਾਂ ਨੂੰ ਭੀ ਪਹਿਲਾਂ ਚੇਤਨ-ਸੱਤਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕਿਸ ਨੇ ਵਜੂਦ ਵਿਚ ਲਿਆਉਣਾ ਸੀ? (ਭਾਵ, ਕਰਮਾਂ ਨੂੰ ਭੀ ਪਹਿਲਾਂ ਇਹ ਚੇਤਨ-ਸੱਤਾ ਹੀ ਵਜੂਦ ਵਿਚ ਲਿਆਉਂਦੀ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Вы говорите, что душа связана кармой, но кто дал существование самой карме?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36926,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮਹਿ ਤਨੁ ਹੈ ਤਨ ਮਹਿ ਹਰਿ ਹੈ ਸਰਬ ਨਿਰੰਤਰਿ ਸੋਇ ਰੇ ॥",
          "roman": "har mah tan hē tan mah har hē sarab nirantar soi re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਚੇਤਨ-ਸੱਤਾ ਪ੍ਰਭੂ ਦੇ ਅੰਦਰ ਇਹ (ਜੀਵਾਂ ਦਾ) ਸਰੀਰ ਵਜੂਦ ਵਿਚ ਆਉਂਦਾ ਹੈ, ਤੇ ਸਰੀਰਾਂ ਵਿਚ ਉਹ ਪ੍ਰਭੂ ਵੱਸਦਾ ਹੈ। ਸਭਨਾਂ ਦੇ ਅੰਦਰ ਉਹੀ ਹੈ, ਕਿਤੇ ਵਿੱਥ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тело пребывает в Боге, и Бог пребывает в теле — Он повсюду без разделения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36927,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਰਾਮ ਨਾਮੁ ਨ ਛੋਡਉ ਸਹਜੇ ਹੋਇ ਸੁ ਹੋਇ ਰੇ ॥੩॥੩॥",
          "roman": "kahi kabīr rām nām na chhoḍau sahje hoi su hoi re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਕਬੀਰ ਆਖਦਾ ਹੈ-ਐਸੇ ਚੇਤਨ-ਸੱਤਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮੈਂ ਕਦੇ ਨਹੀਂ ਭੁਲਾਵਾਂਗਾ, (ਨਾਮ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹੀ ਇਹ ਸਮਝ ਆਉਂਦੀ ਹੈ ਕਿ) ਜੋ ਕੁਝ ਜਗਤ ਵਿਚ ਹੋ ਰਿਹਾ ਹੈ ਸੁਤੇ ਹੀ (ਉਸ ਚੇਤਨ-ਸੱਤਾ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ) ਹੋ ਰਿਹਾ ਹੈ ॥੩॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я не оставлю Имя Бога — всё происходит по Его воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3254,
      "rahao_verse_id": 36935,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36928,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਕਬੀਰ ਜੀਉ ਕੀ ਘਰੁ ੨",
          "roman": "rāg goṇḍ bāṇī kabīr jīu kī ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਗੋਂਡ, ਘਰ ੨ ਵਿੱਚ ਭਗਤ ਕਬੀਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, дом 2 — бани Кабира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36929,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуракх один, и постигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36930,
          "is_rahao": false,
          "gurmukhi": "ਭੁਜਾ ਬਾਂਧਿ ਭਿਲਾ ਕਰਿ ਡਾਰਿਓ ॥",
          "roman": "bhujā bāndh bhilā kar ḍāriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀਆਂ ਬਾਹਾਂ ਬੰਨ੍ਹ ਕੇ ਢੇਮ ਵਾਂਗ (ਮੈਨੂੰ ਇਹਨਾਂ ਲੋਕਾਂ ਹਾਥੀ ਅੱਗੇ) ਸੁੱਟ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мне связали руки и бросили перед слоном,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36931,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤੀ ਕ੍ਰੋਪਿ ਮੂੰਡ ਮਹਿ ਮਾਰਿਓ ॥",
          "roman": "hastī krop muṇḍ mah māriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਹਾਵਤ ਨੇ) ਗੁੱਸੇ ਵਿਚ ਆ ਕੇ ਹਾਥੀ ਦੇ ਸਿਰ ਉੱਤੇ (ਸੱਟ) ਮਾਰੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "погонщик ударил слона по голове."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36932,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤਿ ਭਾਗਿ ਕੈ ਚੀਸਾ ਮਾਰੈ ॥",
          "roman": "hast bhāg kē chīsā mārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹਾਥੀ (ਮੈਨੂੰ ਪੈਰਾਂ ਹੇਠ ਲਿਤਾੜਨ ਦੇ ਥਾਂ) ਚੀਕਾਂ ਮਾਰ ਕੇ (ਹੋਰ ਪਾਸੇ) ਭੱਜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но слон, вместо того чтобы растоптать, закричал и убежал,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36933,
          "is_rahao": false,
          "gurmukhi": "ਇਆ ਮੂਰਤਿ ਕੈ ਹਉ ਬਲਿਹਾਰੈ ॥੧॥",
          "roman": "iā mūrat kē hau balihārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਆਖਦਾ ਹੈ-) ਮੈਂ ਸਦਕੇ ਹਾਂ ਇਸ ਸੋਹਣੇ ਬੰਦੇ ਤੋਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "словно преклоняется перед этим человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36934,
          "is_rahao": true,
          "gurmukhi": "ਆਹਿ ਮੇਰੇ ਠਾਕੁਰ ਤੁਮਰਾ ਜੋਰੁ ॥",
          "roman": "āh mere ṭhākur tumrā jor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਤੇਰਾ ਤਾਣ ਹੈ (ਸੋ, ਤੇਰੀ ਬਰਕਤਿ ਨਾਲ ਮੈਨੂੰ ਕੋਈ ਫ਼ਿਕਰ ਨਹੀਂ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Я полагаюсь на Твою силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36935,
          "is_rahao": true,
          "gurmukhi": "ਕਾਜੀ ਬਕਿਬੋ ਹਸਤੀ ਤੋਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kājī bakibo hastī tor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਜ਼ੀ ਤਾਂ ਕਹਿ ਰਿਹਾ ਹੈ ਕਿ (ਇਸ ਕਬੀਰ ਉੱਤੇ) ਹਾਥੀ ਚਾੜ੍ਹ ਦੇਹ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Кази говорит: направьте на него слона."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36936,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਹਾਵਤ ਤੁਝੁ ਡਾਰਉ ਕਾਟਿ ॥",
          "roman": "re mahāvat tujh ḍārau kāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਾਜ਼ੀ ਆਖਦਾ ਹੈ-) ਨਹੀਂ ਤਾਂ ਮੈਂ ਤੇਰਾ ਸਿਰ ਉਤਰਾ ਦਿਆਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Иначе я отрублю тебе голову,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36937,
          "is_rahao": false,
          "gurmukhi": "ਇਸਹਿ ਤੁਰਾਵਹੁ ਘਾਲਹੁ ਸਾਟਿ ॥",
          "roman": "isah turāvah ghālah sāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਹਾਥੀ ਨੂੰ ਸੱਟ ਮਾਰ ਤੇ (ਕਬੀਰ ਵਲ) ਤੋਰ।"
            },
            "sahib_singh_ru": {
              "main": "бей слона и гони его вперёд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36938,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤਿ ਨ ਤੋਰੈ ਧਰੈ ਧਿਆਨੁ ॥",
          "roman": "hast na torē dharē dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹਾਥੀ ਤੁਰਦਾ ਨਹੀਂ (ਉਹ ਤਾਂ ਇਉਂ ਦਿੱਸਦਾ ਹੈ ਜਿਵੇਂ) ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਮਸਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но слон не идёт, словно пребывает в созерцании,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36939,
          "is_rahao": false,
          "gurmukhi": "ਵਾ ਕੈ ਰਿਦੈ ਬਸੈ ਭਗਵਾਨੁ ॥੨॥",
          "roman": "vā kē ridē basē bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ (ਪਰਗਟ ਹੋ ਕੇ) ਵੱਸ ਰਿਹਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "как будто Бог пребывает в его сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36940,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਅਪਰਾਧੁ ਸੰਤ ਹੈ ਕੀਨੑਾ ॥",
          "roman": "kiā aparādh sant hē kīnhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਲਾ ਮੈਂ ਆਪਣੇ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਨੇ ਇਹਨਾਂ ਦਾ ਕੀਹ ਵਿਗਾੜ ਕੀਤਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "Какое зло я причинил им?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36941,
          "is_rahao": false,
          "gurmukhi": "ਬਾਂਧਿ ਪੋਟ ਕੁੰਚਰ ਕਉ ਦੀਨੑਾ ॥",
          "roman": "bāndh poṭ kunchar kau dīnhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮੇਰੀ ਪੋਟਲੀ ਬੰਨ੍ਹ ਕੇ (ਇਹਨਾਂ ਮੈਨੂੰ) ਹਾਥੀ ਅੱਗੇ ਸੁੱਟ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Почему связали меня и бросили перед слоном?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36942,
          "is_rahao": false,
          "gurmukhi": "ਕੁੰਚਰੁ ਪੋਟ ਲੈ ਲੈ ਨਮਸਕਾਰੈ ॥",
          "roman": "kunchar poṭ lē lē namaskārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵੇਂ ਕਿ) ਹਾਥੀ (ਮੇਰੇ ਸਰੀਰ ਦੀ ਬਣੀ) ਪੋਟਲੀ ਨੂੰ ਮੁੜ ਮੁੜ ਸਿਰ ਨਿਵਾ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слон склоняется перед моим телом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36943,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝੀ ਨਹੀ ਕਾਜੀ ਅੰਧਿਆਰੈ ॥੩॥",
          "roman": "būjhī nahī kājī andhiārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਾਜ਼ੀ ਨੂੰ (ਤੁਅੱਸਬ ਦੇ) ਹਨੇਰੇ ਵਿਚ ਇਹ ਸਮਝ ਹੀ ਨਹੀਂ ਆਈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но кази в своём невежестве этого не понимает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36944,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਬਾਰ ਪਤੀਆ ਭਰਿ ਲੀਨਾ ॥",
          "roman": "tīn bār patīā bhar līnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਾਜ਼ੀ ਨੇ ਹਾਥੀ ਨੂੰ ਮੇਰੇ ਉਪਰ ਚਾੜ੍ਹ ਚਾੜ੍ਹ ਕੇ) ਤਿੰਨ ਵਾਰੀ ਪਰਤਾਵਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Трижды он пытался испытать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
