{
  "ang": 871,
  "shabads": [
    {
      "shabad_id": 3254,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36945,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਠੋਰੁ ਅਜਹੂ ਨ ਪਤੀਨਾ ॥",
          "roman": "man kaṭhor ajahū na patīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦੀ (ਫਿਰ ਭੀ) ਤਸੱਲੀ ਨਾਹ ਹੋਈ (ਕਿਉਂਕਿ ਉਹ) ਮਨ ਦਾ ਕਠੋਰ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "но его сердце осталось жёстким и неудовлетворённым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36946,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਹਮਰਾ ਗੋਬਿੰਦੁ ॥",
          "roman": "kah kabīr hamrā gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ-(ਕਾਜ਼ੀ ਨੂੰ ਇਹ ਸਮਝ ਨਾਹ ਆਈ ਕਿ) ਸਾਡਾ (ਪ੍ਰਭੂ ਦੇ ਸੇਵਕਾਂ ਦਾ ਰਾਖਾ) ਪਰਮਾਤਮਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: наш защитник — Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36947,
          "is_rahao": false,
          "gurmukhi": "ਚਉਥੇ ਪਦ ਮਹਿ ਜਨ ਕੀ ਜਿੰਦੁ ॥੪॥੧॥੪॥",
          "roman": "chauthē pad mahi jan kī jind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਦਾਸਾਂ ਦੀ ਜਿੰਦ ਸਦਾ ਉਸ ਅਵਸਥਾ ਵਿਚ, ਜੋ ਤਿੰਨ ਗੁਣਾਂ ਤੋਂ ਉਤਾਂਹ ਹੈ, ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ (ਇਸ ਵਾਸਤੇ ਉਹਨਾਂ ਨੂੰ ਕੋਈ ਡਰਾ ਧਮਕਾ ਨਹੀਂ ਸਕਦਾ) ॥੪॥੧॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "душа Его слуг пребывает в высшем состоянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3255,
      "rahao_verse_id": 36954,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36948,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "gond",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36949,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਮਾਨਸੁ ਨਾ ਇਹੁ ਦੇਉ ॥",
          "roman": "nā ih mānas nā ih deo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੀਹ ਮਨੁੱਖ, ਕੀਹ ਦੇਵਤਾ; ਕੀਹ ਜਤੀ, ਤੇ ਕੀਹ ਸ਼ਿਵ-ਉਪਾਸ਼ਕ; ਕੀਹ ਜੋਗੀ, ਤੇ ਕੀਹ ਤਿਆਗੀ; ਹਰੇਕ ਵਿਚ ਇੱਕ ਉਹੀ ਵੱਸਦਾ ਹੈ; ਪਰ ਫਿਰ ਭੀ ਸਦਾ ਲਈ) ਨਾਹ ਇਹ ਮਨੁੱਖ ਹੈ ਨਾਹ ਦੇਵਤਾ;"
            },
            "sahib_singh_ru": {
              "main": "ни это человек, ни это божество;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36950,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਜਤੀ ਕਹਾਵੈ ਸੇਉ ॥",
          "roman": "nā ih jatī kahāvē seo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਜਤੀ ਹੈ ਨਾਹ ਸ਼ਿਵ-ਉਪਾਸ਼ਕ,"
            },
            "sahib_singh_ru": {
              "main": "ни аскет, ни поклонник Шивы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36951,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਜੋਗੀ ਨਾ ਅਵਧੂਤਾ ॥",
          "roman": "nā ih jogī nā avadhūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਜੋਗੀ ਹੈ, ਨਾਹ ਤਿਆਗੀ;"
            },
            "sahib_singh_ru": {
              "main": "ни йог, ни отрешённый;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36952,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਮਾਇ ਨ ਕਾਹੂ ਪੂਤਾ ॥੧॥",
          "roman": "nā is māi na kāhū pūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਸ ਦੀ ਕੋਈ ਮਾਂ ਹੈ ਨਾਹ ਇਹ ਕਿਸੇ ਦਾ ਪੁੱਤਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ни у него есть мать, ни он чей-то сын ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36953,
          "is_rahao": true,
          "gurmukhi": "ਇਆ ਮੰਦਰ ਮਹਿ ਕੌਨ ਬਸਾਈ ॥",
          "roman": "iā mandar meh kaun basāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਡੇ) ਇਸ ਸਰੀਰ-ਰੂਪ ਘਰ ਵਿਚ ਕੌਣ ਵੱਸਦਾ ਹੈ? ਉਸ ਦਾ ਕੀਹ ਅਸਲਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "в этом теле-доме кто обитает? какова его сущность?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36954,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕਾ ਅੰਤੁ ਨ ਕੋਊ ਪਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā kā ant na koū pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਗੱਲ ਦੀ ਤਹਿ ਵਿਚ ਕੋਈ ਨਹੀਂ ਅੱਪੜਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "никто не достиг сути этого ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36955,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਗਿਰਹੀ ਨਾ ਓਦਾਸੀ ॥",
          "roman": "nā ih girhī nā odāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗ੍ਰਿਹਸਤੀ, ਉਦਾਸੀ; ਰਾਜਾ, ਕੰਗਾਲ; ਬ੍ਰਾਹਮਣ, ਖੱਤ੍ਰੀ; ਸਭ ਵਿਚ ਇਹੀ ਵੱਸਦਾ ਹੈ; ਫਿਰ ਭੀ ਇਹਨਾਂ ਵਿਚ ਰਹਿਣ ਕਰ ਕੇ ਸਦਾ ਲਈ) ਨਾਹ ਇਹ ਗ੍ਰਿਹਸਤੀ ਹੈ ਨਾਹ ਉਦਾਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "ни домохозяин, ни отшельник,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36956,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਰਾਜ ਨ ਭੀਖ ਮੰਗਾਸੀ ॥",
          "roman": "nā ih rāj na bhīkh maṅgāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਹ ਰਾਜਾ ਹੈ ਨਾਹ ਮੰਗਤਾ;"
            },
            "sahib_singh_ru": {
              "main": "ни царь, ни нищий;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36957,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਸੁ ਪਿੰਡੁ ਨ ਰਕਤੂ ਰਾਤੀ ॥",
          "roman": "nā is piṇḍ na raktū rātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਸ ਦਾ ਕੋਈ ਸਰੀਰ ਹੈ ਨਾਹ ਇਸ ਵਿਚ ਰਤਾ ਭਰ ਭੀ ਲਹੂ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у него нет тела, и ни капли крови в нём нет;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36958,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਬ੍ਰਹਮਨੁ ਨਾ ਇਹੁ ਖਾਤੀ ॥੨॥",
          "roman": "nā ih brahman nā ih khātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਹ ਬ੍ਰਾਹਮਣ ਹੈ ਨਾਹ ਖੱਤ੍ਰੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ни брахман, ни кшатрий ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36959,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਤਪਾ ਕਹਾਵੈ ਸੇਖੁ ॥",
          "roman": "nā ih tapā kahāvē sekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਪੇ, ਸ਼ੇਖ਼, ਸਭ ਵਿਚ ਇਹੀ ਹੈ; ਸਭ ਸਰੀਰਾਂ ਵਿਚ ਆ ਕੇ ਜੰਮਦਾ ਮਰਦਾ ਭੀ ਜਾਪਦਾ ਹੈ, ਫਿਰ ਭੀ ਸਦਾ ਲਈ) ਨਾਹ ਇਹ ਕੋਈ ਤਪਸ੍ਵੀ ਹੈ ਨਾਹ ਕੋਈ ਸ਼ੇਖ਼ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "ни подвижник, ни шейх;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36960,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਇਹੁ ਜੀਵੈ ਨ ਮਰਤਾ ਦੇਖੁ ॥",
          "roman": "nā ih jīvē na martā dekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਇਹ ਜੰਮਦਾ ਹੈ ਨਾਹ ਮਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "он не рождается и не умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36961,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਰਤੇ ਕਉ ਜੇ ਕੋਊ ਰੋਵੈ ॥",
          "roman": "is marte kau je koū rovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਕੋਈ ਜੀਵ ਇਸ (ਅੰਦਰ-ਵੱਸਦੇ) ਨੂੰ ਮਰਦਾ ਸਮਝ ਕੇ ਰੋਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тот, кто считает это умирающим и плачет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36962,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਰੋਵੈ ਸੋਈ ਪਤਿ ਖੋਵੈ ॥੩॥",
          "roman": "jo rovē soī pat khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਜੋ ਰੋਂਦਾ ਹੈ) ਖ਼ੁਆਰ ਹੀ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тот сам теряет достоинство ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36963,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਮੈ ਡਗਰੋ ਪਾਇਆ ॥",
          "roman": "gur prasād mē ḍagro pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਦਾ) ਮੈਂ ਆਪਣੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਜ਼ਿੰਦਗੀ ਦਾ ਸਹੀ) ਰਸਤਾ ਲੱਭਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру я нашёл путь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36964,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਮਰਨੁ ਦੋਊ ਮਿਟਵਾਇਆ ॥",
          "roman": "jīvan maran doū miṭvāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣਾ ਜਨਮ ਮਰਨ ਦੋਵੇਂ ਖ਼ਤਮ ਕਰਾ ਲਏ ਹਨ (ਭਾਵ, ਮੇਰਾ ਜਨਮ-ਮਰਨ ਦਾ ਗੇੜ ਮੁੱਕ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "я устранил рождение и смерть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36965,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਇਹੁ ਰਾਮ ਕੀ ਅੰਸੁ ॥",
          "roman": "kaho kabīr ih rām kī aṅs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- (ਹੁਣ ਮੈਨੂੰ ਸਮਝ ਆ ਗਈ ਹੈ ਕਿ) ਸਾਡੇ ਅੰਦਰ ਵੱਸਣ ਵਾਲਾ ਇਹ ਪਰਮਾਤਮਾ ਦੀ ਅੰਸ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: это часть Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36966,
          "is_rahao": false,
          "gurmukhi": "ਜਸ ਕਾਗਦ ਪਰ ਮਿਟੈ ਨ ਮੰਸੁ ॥੪॥੨॥੫॥",
          "roman": "jas kāgad par miṭē na maṅs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇਹ ਦੋਵੇਂ ਆਪੋ ਵਿਚ ਇਉਂ ਜੁੜੇ ਹੋਏ ਹਨ ਜਿਵੇਂ ਕਾਗ਼ਜ਼ ਅਤੇ (ਕਾਗ਼ਜ਼ ਉੱਤੇ ਲਿਖੇ ਅੱਖਰਾਂ ਦੀ) ਸਿਆਹੀ ॥੪॥੨॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и они связаны как бумага и чернила ॥੪॥੨॥੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3256,
      "rahao_verse_id": 36973,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36967,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "gond",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36968,
          "is_rahao": false,
          "gurmukhi": "ਤੂਟੇ ਤਾਗੇ ਨਿਖੁਟੀ ਪਾਨਿ ॥",
          "roman": "ṭūṭe tāge nikhutī pān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਨੂੰ ਘਰ ਦੇ ਕੰਮ-ਕਾਜ ਦਾ ਕੋਈ ਫ਼ਿਕਰ ਹੀ ਨਹੀਂ, ਜੇ) ਤਾਣੀ ਦੇ ਧਾਗੇ ਟੁੱਟੇ ਪਏ ਹਨ (ਤਾਂ ਟੁੱਟੇ ਹੀ ਰਹਿੰਦੇ ਹਨ), ਜੇ ਪਾਣ ਮੁੱਕ ਗਈ ਹੈ (ਤਾਂ ਮੁੱਕੀ ਹੀ ਪਈ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "если нити порвались, так и остаются; если вода кончилась, так и лежит пусто"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36969,
          "is_rahao": false,
          "gurmukhi": "ਦੁਆਰ ਊਪਰਿ ਝਿਲਕਾਵਹਿ ਕਾਨ ॥",
          "roman": "duār ūpar jhilkāvah kān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੂਹੇ ਤੇ (ਸੱਖਣੇ) ਕਾਨੇ ਪਏ ਲਿਸ਼ਕਦੇ ਹਨ (ਵਰਤਣ ਖੁਣੋਂ ਪਏ ਹਨ);"
            },
            "sahib_singh_ru": {
              "main": "на пороге лежат пустые сосуды и блестят без дела"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36970,
          "is_rahao": false,
          "gurmukhi": "ਕੂਚ ਬਿਚਾਰੇ ਫੂਏ ਫਾਲ ॥",
          "roman": "kūch bichāre phūe phāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਚਾਰੇ ਕੁੱਚ ਤੀਲਾ ਤੀਲਾ ਹੋ ਰਹੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "бедные хлопковые пучки распадаются"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36971,
          "is_rahao": false,
          "gurmukhi": "ਇਆ ਮੁੰਡੀਆ ਸਿਰਿ ਚਢਿਬੋ ਕਾਲ ॥੧॥",
          "roman": "iā muṇḍīā sir chaṛhibo kāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਤਾ ਨਹੀਂ ਇਸ ਸਾਧੂ ਦਾ ਕੀਹ ਬਣੇਗਾ), ਇਸ ਸਾਧੂ ਦੇ ਸਿਰ ਮੌਤ ਸਵਾਰ ਹੋਈ ਜਾਪਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "на этого святого будто смерть взобралась ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36972,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਮੁੰਡੀਆ ਸਗਲੋ ਦ੍ਰਬੁ ਖੋਈ ॥",
          "roman": "ihu muṇḍīā saglo drab khoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰਾ) ਇਹ (ਖਸਮ) ਸਾਧੂ ਸਾਰਾ (ਕਮਾਇਆ) ਧਨ ਗਵਾਈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот святой растрачивает всё имущество"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36973,
          "is_rahao": true,
          "gurmukhi": "ਆਵਤ ਜਾਤ ਨਾਕ ਸਰ ਹੋਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āvat jāt nāk sar hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦੇ ਸਤਸੰਗੀਆਂ ਦੀ) ਆਵਾਜਾਈ ਨਾਲ ਮੇਰੀ ਨੱਕ-ਜਿੰਦ ਆਈ ਪਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "из-за постоянных приходов и уходов мне тяжело жить ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36974,
          "is_rahao": false,
          "gurmukhi": "ਤੁਰੀ ਨਾਰਿ ਕੀ ਛੋਡੀ ਬਾਤਾ ॥",
          "roman": "turī nār kī chhoḍī bātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੁਰੀ ਤੇ ਨਾਲਾਂ (ਦੇ ਵਰਤਣ) ਦਾ ਇਸ ਨੂੰ ਚੇਤਾ ਹੀ ਨਹੀਂ (ਭਾਵ, ਕੱਪੜਾ ਉਣਨ ਦਾ ਇਸ ਨੂੰ ਕੋਈ ਖ਼ਿਆਲ ਹੀ ਨਹੀਂ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "он совсем не заботится о ткачестве"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36975,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਵਾ ਕਾ ਮਨੁ ਰਾਤਾ ॥",
          "roman": "rām nām vā kā man rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਦਾ ਮਨ ਸਦਾ ਰਾਮ-ਨਾਮ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "его ум окрашен в Имя Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36976,
          "is_rahao": false,
          "gurmukhi": "ਲਰਿਕੀ ਲਰਿਕਨ ਖੈਬੋ ਨਾਹਿ ॥",
          "roman": "larikī larikan khēbo nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਘਰ ਵਿਚ) ਕੁੜੀ ਮੁੰਡਿਆਂ ਦੇ ਖਾਣ ਜੋਗਾ ਕੁਝ ਨਹੀਂ (ਰਹਿੰਦਾ)"
            },
            "sahib_singh_ru": {
              "main": "детям нечего есть"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36977,
          "is_rahao": false,
          "gurmukhi": "ਮੁੰਡੀਆ ਅਨਦਿਨੁ ਧਾਪੇ ਜਾਹਿ ॥੨॥",
          "roman": "muṇḍīā anadin dhāpe jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਸ ਦੇ ਸਤਸੰਗੀ ਹਰ ਰੋਜ਼ ਰੱਜ ਕੇ ਜਾਂਦੇ ਹਨ। (ਨੋਟ: ਸ਼ਿਕਾਇਤ ਇਹੀ ਹੈ ਕਿ ਸਾਂਭ ਕੇ ਨਹੀਂ ਰੱਖਦਾ। ਕੰਮ ਕਰਨਾ ਨਹੀਂ ਛੱਡਿਆ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но его гости каждый день уходят сытыми ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36978,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਦੁਇ ਮੰਦਰਿ ਇਕ ਦੁਇ ਬਾਟ ॥",
          "roman": "ik dui mandar ik dui bāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਇੱਕ ਦੋ ਸਾਧੂ (ਸਾਡੇ) ਘਰ ਬੈਠੇ ਹਨ ਤਾਂ ਇਕ ਦੋ ਤੁਰੇ ਭੀ ਆ ਰਹੇ ਹਨ, (ਹਰ ਵੇਲੇ ਆਵਾਜਾਈ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "если один-два сидят, другие уже идут"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36979,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਕਉ ਸਾਥਰੁ ਉਨ ਕਉ ਖਾਟ ॥",
          "roman": "ham kau sāthar un kau khāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਨੂੰ ਭੁੰਞੇ ਸੌਣਾ ਪੈਂਦਾ ਹੈ, ਉਹਨਾਂ ਨੂੰ ਮੰਜੇ ਦਿੱਤੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "мы спим на земле, им дают кровати"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36980,
          "is_rahao": false,
          "gurmukhi": "ਮੂਡ ਪਲੋਸਿ ਕਮਰ ਬਧਿ ਪੋਥੀ ॥",
          "roman": "mūḍ palos kamr badh pothī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਧੂ ਲੱਕਾਂ ਨਾਲ ਪੋਥੀਆਂ ਲਮਕਾਈਆਂ ਹੋਈਆਂ ਸਿਰਾਂ ਤੇ ਹੱਥ ਫੇਰਦੇ ਤੁਰੇ ਆਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они идут с книгами на поясе и гладят головы"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36981,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਕਉ ਚਾਬਨੁ ਉਨ ਕਉ ਰੋਟੀ ॥੩॥",
          "roman": "ham kau chāban un kau roṭī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਈ ਵਾਰ ਉਹਨਾਂ ਦੇ ਕੁਵੇਲੇ ਆ ਜਾਣ ਤੇ) ਸਾਨੂੰ ਤਾਂ ਭੁੱਜੇ ਦਾਣੇ ਚੱਬਣੇ ਪੈਂਦੇ ਹਨ, ਉਹਨਾਂ ਨੂੰ ਰੋਟੀਆਂ ਮਿਲਦੀਆਂ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "нам остаётся жевать зёрна, им дают хлеб ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36982,
          "is_rahao": false,
          "gurmukhi": "ਮੁੰਡੀਆ ਮੁੰਡੀਆ ਹੂਏ ਏਕ ॥",
          "roman": "muṇḍīā muṇḍīā hūe ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਬੀਰ! (ਆਖ-ਇਹਨਾਂ ਸਤ-ਸੰਗੀਆਂ ਨਾਲ ਇਹ ਪਿਆਰ ਇਸ ਵਾਸਤੇ ਹੈ ਕਿ) ਸਤ ਸੰਗੀਆਂ ਦੇ ਦਿਲ ਆਪੋ ਵਿਚ ਮਿਲੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "святые едины сердцем"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36983,
          "is_rahao": false,
          "gurmukhi": "ਏ ਮੁੰਡੀਆ ਬੂਡਤ ਕੀ ਟੇਕ ॥",
          "roman": "e muṇḍīā būḍat kī ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇਹ ਸਤ-ਸੰਗੀ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਦੇ ਵਿਕਾਰਾਂ ਵਿਚ) ਡੁੱਬਦਿਆਂ ਦਾ ਸਹਾਰਾ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они опора тонущим"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36984,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਅੰਧਲੀ ਲੋਈ ਬੇਪੀਰਿ ॥",
          "roman": "sun andhlī loī bepīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਨ੍ਹੀ ਨਿਗੁਰੀ ਲੋਈ! ਸੁਣ!"
            },
            "sahib_singh_ru": {
              "main": "слушай, слепая безгурная женщина"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36985,
          "is_rahao": false,
          "gurmukhi": "ਇਨੑ ਮੁੰਡੀਅਨ ਭਜਿ ਸਰਨਿ ਕਬੀਰ ॥੪॥੩॥੬॥",
          "roman": "inh muṇḍīan bhaj saran kabīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਭੀ ਇਹਨਾਂ ਸਤ-ਸੰਗੀਆਂ ਦੀ ਸ਼ਰਨ ਪਉ ॥੪॥੩॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "иди в их прибежище ॥੪॥੩॥੬॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3257,
      "rahao_verse_id": 36992,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36986,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "gond",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36987,
          "is_rahao": false,
          "gurmukhi": "ਖਸਮੁ ਮਰੈ ਤਉ ਨਾਰਿ ਨ ਰੋਵੈ ॥",
          "roman": "khasam marē tau nār na rovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਸ ਮਾਇਆ ਨੂੰ ਇਸਤ੍ਰੀ ਬਣਾ ਕੇ ਰੱਖਣ ਵਾਲਾ) ਮਨੁੱਖ (ਆਖ਼ਰ) ਮਰ ਜਾਂਦਾ ਹੈ, ਇਹ (ਮਾਇਆ) ਵਹੁਟੀ (ਉਸ ਦੇ ਮਰਨ ਤੇ) ਰੋਂਦੀ ਭੀ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "когда хозяин умирает, жена не плачет"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36988,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਰਖਵਾਰਾ ਅਉਰੋ ਹੋਵੈ ॥",
          "roman": "us rakhvārā auro hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਇਸ ਦਾ ਰਾਖਾ (ਖਸਮ) ਕੋਈ ਧਿਰ ਹੋਰ ਬਣ ਜਾਂਦਾ ਹੈ (ਸੋ, ਇਹ ਕਦੇ ਭੀ ਰੰਡੀ ਨਹੀਂ ਹੁੰਦੀ)।"
            },
            "sahib_singh_ru": {
              "main": "потому что появляется другой защитник"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36989,
          "is_rahao": false,
          "gurmukhi": "ਰਖਵਾਰੇ ਕਾ ਹੋਇ ਬਿਨਾਸ ॥",
          "roman": "rakhvāre kā hoi binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਮਾਇਆ ਦਾ) ਰਾਖਾ ਮਰ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "защитник умирает"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36990,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਨਰਕੁ ਈਹਾ ਭੋਗ ਬਿਲਾਸ ॥੧॥",
          "roman": "āgē narak īhā bhog bilās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਇੱਥੇ ਇਸ ਮਾਇਆ ਦੇ ਭੋਗਾਂ (ਵਿਚ ਮਸਤ ਰਹਿਣ) ਕਰਕੇ ਅਗਾਂਹ (ਆਪਣੇ ਲਈ) ਨਰਕ ਸਹੇੜਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "наслаждения здесь ведут к аду впереди ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36991,
          "is_rahao": true,
          "gurmukhi": "ਏਕ ਸੁਹਾਗਨਿ ਜਗਤ ਪਿਆਰੀ ॥",
          "roman": "ek suhāgan jagat piārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਮਾਇਆ) ਇਕ ਐਸੀ ਸੁਹਾਗਣ ਨਾਰ ਹੈ ਜਿਸ ਨੂੰ ਸਾਰਾ ਜਗਤ ਪਿਆਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "эта майя — возлюбленная мира"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36992,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲੇ ਜੀਅ ਜੰਤ ਕੀ ਨਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sagle jīa jant kī nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਆ ਜੰਤ ਇਸ ਨੂੰ ਆਪਣੀ ਇਸਤ੍ਰੀ ਬਣਾ ਕੇ ਰੱਖਣਾ ਚਾਹੁੰਦੇ ਹਨ (ਆਪਣੇ ਵੱਸ ਵਿਚ ਰੱਖਣਾ ਚਾਹੁੰਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "все существа хотят обладать ею ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36993,
          "is_rahao": false,
          "gurmukhi": "ਸੋਹਾਗਨਿ ਗਲਿ ਸੋਹੈ ਹਾਰੁ ॥",
          "roman": "sohāgan gal sohē hār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਸੋਹਾਗਣ ਨਾਰ ਦੇ ਗਲ ਵਿਚ ਹਾਰ ਸੋਭਦਾ ਹੈ, (ਭਾਵ, ਜੀਵਾਂ ਦੇ ਮਨ ਮੋਹਣ ਨੂੰ ਸਦਾ ਸੁਹਣੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "она украшена и привлекательна"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36994,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਉ ਬਿਖੁ ਬਿਗਸੈ ਸੰਸਾਰੁ ॥",
          "roman": "sant kau bikh bigsē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਨੂੰ ਵੇਖ ਵੇਖ ਕੇ) ਜਗਤ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ, ਪਰ ਸੰਤਾਂ ਨੂੰ ਇਹ ਜ਼ਹਿਰ (ਵਾਂਗ) ਦਿੱਸਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "мир радуется ей, но для святых она как яд"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36995,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਸੀਗਾਰੁ ਬਹੈ ਪਖਿਆਰੀ ॥",
          "roman": "kar sīgār bahē pakhiyārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਸਵਾ (ਵਾਂਗ) ਸਦਾ ਸ਼ਿੰਗਾਰ ਕਰੀ ਰੱਖਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "она украшает себя как блудница"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36996,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਠਿਠਕੀ ਫਿਰੈ ਬਿਚਾਰੀ ॥੨॥",
          "roman": "sant kī ṭhiṭhkī phirē bichārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਸੰਤਾਂ ਦੀ ਫਿਟਕਾਰੀ ਹੋਈ ਵਿਚਾਰੀ (ਸੰਤਾਂ ਤੋਂ) ਪਰੇ ਪਰੇ ਹੀ ਫਿਰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но держится вдали от святых ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36997,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਭਾਗਿ ਓਹ ਪਾਛੈ ਪਰੈ ॥",
          "roman": "sant bhāg oh pāchhē parē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਮਾਇਆ) ਭੱਜ ਕੇ ਸੰਤਾਂ ਦੇ ਲੜ ਲੱਗਣ ਦੀ ਕੋਸ਼ਸ਼ ਕਰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "она стремится следовать за святыми"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36998,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਮਾਰਹੁ ਡਰੈ ॥",
          "roman": "gur parsādī mārah ḍarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਸੰਤਾਂ ਉੱਤੇ) ਗੁਰੂ ਦੀ ਮਿਹਰ ਹੋਣ ਕਰ ਕੇ (ਇਹ ਸੰਤਾਂ ਦੀ) ਮਾਰ ਤੋਂ ਭੀ ਡਰਦੀ ਹੈ (ਇਸ ਵਾਸਤੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕਦੀ)।"
            },
            "sahib_singh_ru": {
              "main": "но боится их силы по милости Гуру"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36999,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਕੀ ਓਹ ਪਿੰਡ ਪਰਾਇਣਿ ॥",
          "roman": "sākat kī oh piṇḍ parāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਮਾਇਆ ਪ੍ਰਭੂ ਨਾਲੋਂ ਟੁੱਟੇ ਹੋਏ ਬੰਦਿਆਂ ਦੀ ਜਿੰਦ-ਜਾਨ ਬਣੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "для безбожных она становится жизнью"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37000,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਕਉ ਦ੍ਰਿਸਟਿ ਪਰੈ ਤ੍ਰਖਿ ਡਾਇਣਿ ॥੩॥",
          "roman": "ham kau driṣṭ parē trakh ḍāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਨੂੰ ਤਾਂ ਇਹ ਭਿਆਨਕ ਡੈਣ ਦਿੱਸਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но мне она кажется страшной ведьмой ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37001,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਤਿਸ ਕਾ ਬਹੁ ਜਾਨਿਆ ਭੇਉ ॥",
          "roman": "ham tis kā bah jāniā bheo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਤੋਂ ਮੈਂ ਇਸ ਮਾਇਆ ਦਾ ਭੇਤ ਪਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "я узнал её тайну"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37002,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਹੂਏ ਕ੍ਰਿਪਾਲ ਮਿਲੇ ਗੁਰਦੇਉ ॥",
          "roman": "jab hūe kirpāl mile gurdeo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮੇਰੇ ਸਤਿਗੁਰੂ ਜੀ ਮੇਰੇ ਉੱਤੇ ਦਿਆਲ ਹੋਏ ਤੇ ਮੈਨੂੰ ਮਿਲ ਪਏ।"
            },
            "sahib_singh_ru": {
              "main": "когда встретил милостивого Гуру"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37003,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਅਬ ਬਾਹਰਿ ਪਰੀ ॥",
          "roman": "kaho kabīr ab bāhar parī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਮੈਥੋਂ ਤਾਂ ਇਹ ਮਾਇਆ (ਹੁਣ) ਪਰੇ ਹਟ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: теперь она ушла от меня"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37004,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰੈ ਕੈ ਅੰਚਲਿ ਲਰੀ ॥੪॥੪॥੭॥",
          "roman": "sansārē kē añchal larī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸੰਸਾਰੀ ਜੀਵਾਂ ਦੇ ਪੱਲੇ ਜਾ ਲੱਗੀ ਹੈ ॥੪॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и пристала к миру ॥੪॥੪॥੭॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
