{
  "ang": 872,
  "shabads": [
    {
      "shabad_id": 3258,
      "rahao_verse_id": 37010,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37005,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "Gonḍ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37006,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹਿ ਸੋਭਾ ਜਾ ਕੈ ਰੇ ਨਾਹਿ ॥",
          "roman": "grih sobhā jā kē rē nāh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, у того человека, в чьём доме нет майи — украшения дома,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37007,
          "is_rahao": false,
          "gurmukhi": "ਆਵਤ ਪਹੀਆ ਖੂਧੇ ਜਾਹਿ ॥",
          "roman": "āvat pahīā khūdhe jāh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "пришедшие путники уходят голодными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37008,
          "is_rahao": false,
          "gurmukhi": "ਵਾ ਕੈ ਅੰਤਰਿ ਨਹੀ ਸੰਤੋਖੁ ॥",
          "roman": "vā kē antar nahī santokh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И в сердце хозяина такого дома нет утешения и довольства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37009,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸੋਹਾਗਨਿ ਲਾਗੈ ਦੋਖੁ ॥੧॥",
          "roman": "bin sohāgan lāgē dokh. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому без этой майи, всегда пребывающей при своём Хозяине, на домохозяйство ложится упрёк. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37010,
          "is_rahao": true,
          "gurmukhi": "ਧਨੁ ਸੋਹਾਗਨਿ ਮਹਾ ਪਵੀਤ ॥ ਤਪੇ ਤਪੀਸਰ ਡੋਲੈ ਚੀਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dhan sohāgan mahā pavīt. tape tapīsar ḍolē chīt. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенна эта майя, всегда пребывающая при Хозяине; она велика и чиста, ибо без неё колеблется ум даже великих аскетов. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37011,
          "is_rahao": false,
          "gurmukhi": "ਸੋਹਾਗਨਿ ਕਿਰਪਨ ਕੀ ਪੂਤੀ ॥",
          "roman": "sohāgan kirpan kī pūtī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но эта майя становится дочерью скупца, то есть скупой лишь копит её и не пользуется ею."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37012,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਤਜਿ ਜਗਤ ਸਿਉ ਸੂਤੀ ॥",
          "roman": "sēvak taj jagat siu sūtī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив слуг Господа, она подчинила себе весь остальной мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37013,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਠਾਢੀ ਦਰਬਾਰਿ ॥",
          "roman": "sādhū kē ṭhāḍhī darbār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У двери святых она стоит и взывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37014,
          "is_rahao": false,
          "gurmukhi": "ਸਰਨਿ ਤੇਰੀ ਮੋ ਕਉ ਨਿਸਤਾਰਿ ॥੨॥",
          "roman": "saran terī mo kau nistār. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я пришла в твоё прибежище — спаси меня. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37015,
          "is_rahao": false,
          "gurmukhi": "ਸੋਹਾਗਨਿ ਹੈ ਅਤਿ ਸੁੰਦਰੀ ॥",
          "roman": "sohāgan hē at sundarī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эта майя очень красива."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37016,
          "is_rahao": false,
          "gurmukhi": "ਪਗ ਨੇਵਰ ਛਨਕ ਛਨਹਰੀ ॥",
          "roman": "pag nēvar chhanak chhanharī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На её ногах словно звенят браслеты — чхан-чхан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37017,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਲਗੁ ਪ੍ਰਾਨ ਤਊ ਲਗੁ ਸੰਗੇ ॥",
          "roman": "jau lag prān taū lag sangē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока в человеке есть жизнь, до тех пор она остаётся с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37018,
          "is_rahao": false,
          "gurmukhi": "ਨਾਹਿ ਤ ਚਲੀ ਬੇਗਿ ਉਠਿ ਨੰਗੇ ॥੩॥",
          "roman": "nāh ta chalī bēg uṭh nangē. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но как только жизнь уходит, она тоже тотчас убегает босиком, оставляя его. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37019,
          "is_rahao": false,
          "gurmukhi": "ਸੋਹਾਗਨਿ ਭਵਨ ਤ੍ਰੈ ਲੀਆ ॥",
          "roman": "sohāgan bhavan trē līā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эта майя подчинила себе существ всех трёх миров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37020,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਅਠ ਪੁਰਾਣ ਤੀਰਥ ਰਸ ਕੀਆ ॥",
          "roman": "das aṭh purāṇ tīrath ras kīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Она увлекла и тех, кто читает восемнадцать Пуран и ходит по местам паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37021,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮਾ ਬਿਸਨੁ ਮਹੇਸਰ ਬੇਧੇ ॥",
          "roman": "brahmā bisan mahesar bēdhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Брахму, Вишну и Шиву она тоже пронзила своим влиянием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37022,
          "is_rahao": false,
          "gurmukhi": "ਬਡੇ ਭੂਪਤਿ ਰਾਜੇ ਹੈ ਛੇਧੇ ॥੪॥",
          "roman": "baḍe bhūpat rājē hē chhēdhē. ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И великих властителей, царей и князей, она тоже держит в своих узах. ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37023,
          "is_rahao": false,
          "gurmukhi": "ਸੋਹਾਗਨਿ ਉਰਵਾਰਿ ਨ ਪਾਰਿ ॥",
          "roman": "sohāgan urvār na pār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эта майя имеет огромный размах; ни ближнего, ни дальнего берега её не найти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37024,
          "is_rahao": false,
          "gurmukhi": "ਪਾਂਚ ਨਾਰਦ ਕੈ ਸੰਗਿ ਬਿਧਵਾਰਿ ॥",
          "roman": "pāñch nārad kē sang bidhvār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Она тесно связана с пятью чувствами познания, которые вносят смятение в духовную жизнь человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37025,
          "is_rahao": false,
          "gurmukhi": "ਪਾਂਚ ਨਾਰਦ ਕੇ ਮਿਟਵੇ ਫੂਟੇ ॥",
          "roman": "pāñch nārad kē miṭvē phūṭē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но мои пять глиняных сосудов чувств разбились, то есть влияние майи больше не действует на чувства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37026,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਗੁਰ ਕਿਰਪਾ ਛੂਟੇ ॥੫॥੫॥੮॥",
          "roman": "kah Kabīr gur kirpā chhūṭē. ||5||5||8||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Говорит Кабир: по милости Гуру я освободился от её удара. ||5||5||8||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3259,
      "rahao_verse_id": 37033,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37027,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "Gonḍ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37028,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਮੰਦਰ ਮਹਿ ਬਲਹਰ ਨਾ ਠਾਹਰੈ ॥",
          "roman": "jēsē mandar meh balhar nā ṭhāhrē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как крыша дома не может держаться без балки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37029,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕੈਸੇ ਪਾਰਿ ਉਤਰੈ ॥",
          "roman": "nām binā kēsē pār utarē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так без Имени Господа человек не может переправиться через водовороты мирового океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37030,
          "is_rahao": false,
          "gurmukhi": "ਕੁੰਭ ਬਿਨਾ ਜਲੁ ਨਾ ਟੀਕਾਵੈ ॥",
          "roman": "kumbh binā jal nā ṭīkāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как без кувшина вода не удерживается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37031,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਐਸੇ ਅਬਗਤੁ ਜਾਵੈ ॥੧॥",
          "roman": "sādhū bin ēsē abgat jāvē. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так без Гуру ум человека не утверждается, и человек уходит из мира в дурном состоянии. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37032,
          "is_rahao": true,
          "gurmukhi": "ਜਾਰਉ ਤਿਸੈ ਜੁ ਰਾਮੁ ਨ ਚੇਤੈ ॥",
          "roman": "jārau tisē ju Rām na chētē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я сжёг бы тот ум, который не помнит Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37033,
          "is_rahao": true,
          "gurmukhi": "ਤਨ ਮਨ ਰਮਤ ਰਹੈ ਮਹਿ ਖੇਤੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tan man ramat rahē meh khētē. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он всем телом и умом остаётся погружён лишь в телесные наслаждения. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37034,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਹਲਹਰ ਬਿਨਾ ਜਿਮੀ ਨਹੀ ਬੋਈਐ ॥",
          "roman": "jēsē halhar binā jimī nahī boīē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как без земледельца нельзя засеять землю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37035,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤ ਬਿਨਾ ਕੈਸੇ ਮਣੀ ਪਰੋਈਐ ॥",
          "roman": "sūt binā kēsē maṇī paroīē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и как без нити нельзя нанизать бусины,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37036,
          "is_rahao": false,
          "gurmukhi": "ਘੁੰਡੀ ਬਿਨੁ ਕਿਆ ਗੰਠਿ ਚੜ੍ਹਾਈਐ ॥",
          "roman": "ghuṇḍī bin kiā gaṇṭh chaṛhāīai.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и как без петли нельзя завязать узел,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37037,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਤੈਸੇ ਅਬਗਤੁ ਜਾਈਐ ॥੨॥",
          "roman": "sādhū bin tēsē abgat jāīē. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так без прибежища Гуру человек уходит в дурном состоянии. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37038,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਮਾਤ ਪਿਤਾ ਬਿਨੁ ਬਾਲੁ ਨ ਹੋਈ ॥",
          "roman": "jēsē māt pitā bin bāl na hoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как без соединения матери и отца не рождается ребёнок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37039,
          "is_rahao": false,
          "gurmukhi": "ਬਿੰਬ ਬਿਨਾ ਕੈਸੇ ਕਪਰੇ ਧੋਈ ॥",
          "roman": "bimb binā kēsē kaprē dhoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и как без воды не выстирать одежду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37040,
          "is_rahao": false,
          "gurmukhi": "ਘੋਰ ਬਿਨਾ ਕੈਸੇ ਅਸਵਾਰ ॥",
          "roman": "ghor binā kēsē asvār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и как без коня человек не может называться всадником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37041,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਬਿਨੁ ਨਾਹੀ ਦਰਵਾਰ ॥੩॥",
          "roman": "sādhū bin nāhī darvār. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так без Гуру невозможно достичь Двора Господа. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37042,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਬਾਜੇ ਬਿਨੁ ਨਹੀ ਲੀਜੈ ਫੇਰੀ ॥",
          "roman": "jēsē bājē bin nahī lījē phērī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как без музыкальных инструментов не может быть танца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37043,
          "is_rahao": false,
          "gurmukhi": "ਖਸਮਿ ਦੁਹਾਗਨਿ ਤਜਿ ਅਉਹੇਰੀ ॥",
          "roman": "khasam duhāgan taj auhērī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "так и без Хозяина женщина не может быть счастливой супругой; дурную жену Хозяин отвергает и презирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37044,
          "is_rahao": false,
          "gurmukhi": "ਕਹੈ ਕਬੀਰੁ ਏਕੈ ਕਰਿ ਕਰਨਾ ॥",
          "roman": "kahē Kabīr ēkē kar karnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: делай одно единственное дело, достойное делания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37045,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਇ ਬਹੁਰਿ ਨਹੀ ਮਰਨਾ ॥੪॥੬॥੯॥",
          "roman": "gurmukh hoī bahur nahī marnā. ||4||6||9||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Стань обращённым к Гуру и повторяй Имя — тогда больше не придётся снова рождаться и умирать. ||4||6||9||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3260,
      "rahao_verse_id": 37052,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37046,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "Gonḍ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37047,
          "is_rahao": false,
          "gurmukhi": "ਕੂਟਨੁ ਸੋਇ ਜੁ ਮਨ ਕਉ ਕੂਟੈ ॥",
          "roman": "kūṭan soī ju man kau kūṭē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный «кутан» — тот, кто сокрушает свой собственный ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37048,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕੂਟੈ ਤਉ ਜਮ ਤੇ ਛੂਟੈ ॥",
          "roman": "man kūṭē tau jam tē chhūṭē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек сокрушает ум, он освобождается от ямов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37049,
          "is_rahao": false,
          "gurmukhi": "ਕੁਟਿ ਕੁਟਿ ਮਨੁ ਕਸਵਟੀ ਲਾਵੈ ॥",
          "roman": "kuṭ kuṭ man kasvaṭī lāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто снова и снова усмиряет ум и проверяет его на пробном камне,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37050,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕੂਟਨੁ ਮੁਕਤਿ ਬਹੁ ਪਾਵੈ ॥੧॥",
          "roman": "so kūṭan mukat bah pāvē. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тот, как сокрушающий свой ум «кутан», обретает освобождение. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37051,
          "is_rahao": true,
          "gurmukhi": "ਕੂਟਨੁ ਕਿਸੈ ਕਹਹੁ ਸੰਸਾਰ ॥",
          "roman": "kūṭan kisē kahah sansār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О люди мира, кого вы называете «кутан»?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37052,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲ ਬੋਲਨ ਕੇ ਮਾਹਿ ਬੀਚਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sagal bolan kē māh bīchār. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во всех словах могут быть разные смыслы и оттенки. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37053,
          "is_rahao": false,
          "gurmukhi": "ਨਾਚਨੁ ਸੋਇ ਜੁ ਮਨ ਸਿਉ ਨਾਚੈ ॥",
          "roman": "nāchan soī ju man siu nāchē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный «начан» — тот, кто танцует не телом, а умом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37054,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠਿ ਨ ਪਤੀਐ ਪਰਚੈ ਸਾਚੈ ॥",
          "roman": "jhūṭh na patīē parchē sāchē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не увлекается ложью, а утверждается в Истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37055,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਮਨ ਆਗੇ ਪੂਰੈ ਤਾਲ ॥",
          "roman": "is man āgē pūrē tāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он перед этим умом отбивает полный ритм, стараясь привести его в духовный восторг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37056,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਨਾਚਨ ਕੇ ਮਨ ਰਖਵਾਲ ॥੨॥",
          "roman": "is nāchan kē man rakhvāl. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хранителем ума такого танцующего становится сам Господь. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37057,
          "is_rahao": false,
          "gurmukhi": "ਬਜਾਰੀ ਸੋ ਜੁ ਬਜਾਰਹਿ ਸੋਧੈ ॥",
          "roman": "bajārī so ju bajāreh sodhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный «базари» — тот, кто исследует рынок своего тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37058,
          "is_rahao": false,
          "gurmukhi": "ਪਾਂਚ ਪਲੀਤਹ ਕਉ ਪਰਬੋਧੈ ॥",
          "roman": "pāñch palītah kau parbodhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он пробуждает пять испорченных чувств познания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37059,
          "is_rahao": false,
          "gurmukhi": "ਨਉ ਨਾਇਕ ਕੀ ਭਗਤਿ ਪਛਾਨੈ ॥",
          "roman": "nau nāik kī bhagat pachhānē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он учится распознавать путь поклонения Господу, Владыке девяти частей земли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37060,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬਾਜਾਰੀ ਹਮ ਗੁਰ ਮਾਨੇ ॥੩॥",
          "roman": "so bājārī ham gur mānē. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такого «базари» я считаю великим, превосходным человеком. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37061,
          "is_rahao": false,
          "gurmukhi": "ਤਸਕਰੁ ਸੋਇ ਜਿ ਤਾਤਿ ਨ ਕਰੈ ॥",
          "roman": "taskar soī j tāt na karē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный «таскар» — тот, кто не держит в себе зависти, словно украл её из собственного ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37062,
          "is_rahao": false,
          "gurmukhi": "ਇੰਦ੍ਰੀ ਕੈ ਜਤਨਿ ਨਾਮੁ ਉਚਰੈ ॥",
          "roman": "indrī kē jatan nām ucharē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обуздав чувства, он произносит Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37063,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਮ ਐਸੇ ਲਖਨ ॥",
          "roman": "kah Kabīr ham aisē lakhan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Говорит Кабир: эти признаки и качества я обрёл благодаря ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37064,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਗੁਰਦੇਵ ਅਤਿ ਰੂਪ ਬਿਚਖਨ ॥੪॥੭॥੧੦॥",
          "roman": "dhan gurdev at rūp bichakhan. ||4||7||10||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословен мой Гурдев — прекрасный, мудрый и достойный хвалы. ||4||7||10||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
