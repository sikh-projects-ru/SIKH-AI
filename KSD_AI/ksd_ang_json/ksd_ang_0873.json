{
  "ang": 873,
  "shabads": [
    {
      "shabad_id": 3261,
      "rahao_verse_id": 37071,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37065,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37066,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਗੁਪਾਲ ਧੰਨੁ ਗੁਰਦੇਵ ॥",
          "roman": "dhann gupāl dhann gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословен Гупал, Господь-хранитель земли; благословен Гурдев, Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37067,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਅਨਾਦਿ ਭੂਖੇ ਕਵਲੁ ਟਹਕੇਵ ॥",
          "roman": "dhann anād bhūkhey kaval ṭahkev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенно зерно: от него сердце голодного человека расцветает, как цветок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37068,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਓਇ ਸੰਤ ਜਿਨ ਐਸੀ ਜਾਨੀ ॥",
          "roman": "dhan oi sant jin aisī jānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенны те святые, которые поняли это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37069,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕਉ ਮਿਲਿਬੋ ਸਾਰਿੰਗਪਾਨੀ ॥੧॥",
          "roman": "tin kau milibo sāriṅgpānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Им встречается Параматма, Господь с луком в руке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37070,
          "is_rahao": true,
          "gurmukhi": "ਆਦਿ ਪੁਰਖ ਤੇ ਹੋਇ ਅਨਾਦਿ ॥",
          "roman": "ād purakh te hoi anād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Зерно рождается от Изначального Пуруша, от Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37071,
          "is_rahao": true,
          "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਅੰਨ ਕੈ ਸਾਦਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "japīē nām ann kē sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Бога можно повторять, когда тело поддержано вкусом и силой пищи. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37072,
          "is_rahao": false,
          "gurmukhi": "ਜਪੀਐ ਨਾਮੁ ਜਪੀਐ ਅੰਨੁ ॥",
          "roman": "japīai nām japīai ann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следует повторять Имя и также с любовью принимать зерно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37073,
          "is_rahao": false,
          "gurmukhi": "ਅੰਭੈ ਕੈ ਸੰਗਿ ਨੀਕਾ ਵੰਨੁ ॥",
          "roman": "ambhē kē saṅg nīkā vann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Посмотри, какой прекрасный вид получает зерно в соединении с водой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37074,
          "is_rahao": false,
          "gurmukhi": "ਅੰਨੈ ਬਾਹਰਿ ਜੋ ਨਰ ਹੋਵਹਿ ॥",
          "roman": "annē bāhar jo nar hovah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые отворачиваются от зерна,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37075,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਭਵਨ ਮਹਿ ਅਪਨੀ ਖੋਵਹਿ ॥੨॥",
          "roman": "tīn bhavan meh apnī khovahi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "везде теряют собственную честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37076,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਹਿ ਅੰਨੁ ਕਰਹਿ ਪਾਖੰਡ ॥",
          "roman": "chhoḍah ann karah pākhaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто оставляет зерно и творит этот показной обман,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37077,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸੋਹਾਗਨਿ ਨਾ ਓਹਿ ਰੰਡ ॥",
          "roman": "nā sohāgan nā oh raṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "подобны женщинам, которые ни замужние, ни вдовы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37078,
          "is_rahao": false,
          "gurmukhi": "ਜਗ ਮਹਿ ਬਕਤੇ ਦੂਧਾਧਾਰੀ ॥",
          "roman": "jag meh bakte dūdhādhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мире они объявляют: «Мы живём только на молоке»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37079,
          "is_rahao": false,
          "gurmukhi": "ਗੁਪਤੀ ਖਾਵਹਿ ਵਟਿਕਾ ਸਾਰੀ ॥੩॥",
          "roman": "guptī khāvahi vaṭikā sārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но тайком съедают целые лепёшки из риса и маша."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37080,
          "is_rahao": false,
          "gurmukhi": "ਅੰਨੈ ਬਿਨਾ ਨ ਹੋਇ ਸੁਕਾਲੁ ॥",
          "roman": "annē binā na hoi sukāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без зерна не бывает благополучного времени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37081,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿਐ ਅੰਨਿ ਨ ਮਿਲੈ ਗੁਪਾਲੁ ॥",
          "roman": "taji-ē ann na milē gupāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив зерно, Гупала не встретить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37082,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਮ ਐਸੇ ਜਾਨਿਆ ॥",
          "roman": "kaho kabīr ham aise jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Говорит Кабир: мы поняли это так."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37083,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਅਨਾਦਿ ਠਾਕੁਰ ਮਨੁ ਮਾਨਿਆ ॥੪॥੮॥੧੧॥",
          "roman": "dhann anād ṭhākur man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенно зерно; принимая его и совершая симран, наш ум соединяется с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3262,
      "rahao_verse_id": 37090,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37084,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਨਾਮਦੇਉ ਜੀ ਕੀ ਘਰੁ ੧",
          "roman": "rāg goṇḍ bāṇī nāmdev jī kī ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, бани Намдев Джи, первый дом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37085,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37086,
          "is_rahao": false,
          "gurmukhi": "ਅਸੁਮੇਧ ਜਗਨੇ ॥",
          "roman": "asumedh jagne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если человек совершит жертвоприношения ашвамедха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37087,
          "is_rahao": false,
          "gurmukhi": "ਤੁਲਾ ਪੁਰਖ ਦਾਨੇ ॥",
          "roman": "tulā purakh dāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даст дары, равные весу собственного тела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37088,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਗ ਇਸਨਾਨੇ ॥੧॥",
          "roman": "prāg isnāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и совершит омовения в Праяге и других тиртхах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37089,
          "is_rahao": true,
          "gurmukhi": "ਤਉ ਨ ਪੁਜਹਿ ਹਰਿ ਕੀਰਤਿ ਨਾਮਾ ॥",
          "roman": "tau na pujah har kīrat nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "всё это не может сравниться с Именем и восхвалением Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37090,
          "is_rahao": true,
          "gurmukhi": "ਅਪੁਨੇ ਰਾਮਹਿ ਭਜੁ ਰੇ ਮਨ ਆਲਸੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "apune rāmeh bhaj re man ālasīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ленивый мой ум, вспоминай своего возлюбленного Рама. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37091,
          "is_rahao": false,
          "gurmukhi": "ਗਇਆ ਪਿੰਡੁ ਭਰਤਾ ॥",
          "roman": "gaiā piṇḍ bhartā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если человек в Гае совершает подношение пинды предкам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37092,
          "is_rahao": false,
          "gurmukhi": "ਬਨਾਰਸਿ ਅਸਿ ਬਸਤਾ ॥",
          "roman": "banāras as bastā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "живёт у реки Аси возле Бенареса,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37093,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖਿ ਬੇਦ ਚਤੁਰ ਪੜਤਾ ॥੨॥",
          "roman": "mukh bed chatur paṛtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и устами наизусть читает четыре Веды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37094,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਧਰਮ ਅਛਿਤਾ ॥",
          "roman": "sagal dharam achhitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даже если человек совершает все религиозные дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37095,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਗਿਆਨ ਇੰਦ੍ਰੀ ਦ੍ਰਿੜਤਾ ॥",
          "roman": "gur giān indrī driṛtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "получив наставление гуру, держит чувства под контролем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37096,
          "is_rahao": false,
          "gurmukhi": "ਖਟੁ ਕਰਮ ਸਹਿਤ ਰਹਤਾ ॥੩॥",
          "roman": "khaṭ karam sahit rahtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и постоянно исполняет все шесть брахманских обязанностей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37097,
          "is_rahao": false,
          "gurmukhi": "ਸਿਵਾ ਸਕਤਿ ਸੰਬਾਦੰ ॥",
          "roman": "sivā sakat saṃbādaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даже если читает повествования о беседе Шивы и Парвати,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37098,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਛੋਡਿ ਛੋਡਿ ਸਗਲ ਭੇਦੰ ॥",
          "roman": "man chhoḍ chhoḍ sagal bhedaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "о мой ум, оставь, оставь все эти дела: они создают отделённость от Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37099,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਗੋਬਿੰਦੰ ॥",
          "roman": "simar simar gobindaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова вспоминай Гобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37100,
          "is_rahao": false,
          "gurmukhi": "ਭਜੁ ਨਾਮਾ ਤਰਸਿ ਭਵ ਸਿੰਧੰ ॥੪॥੧॥",
          "roman": "bhaj nāmā taras bhav sindhaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Намдев, воспевай Имя: только так переплывёшь океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3263,
      "rahao_verse_id": 37105,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37101,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37102,
          "is_rahao": false,
          "gurmukhi": "ਨਾਦ ਭ੍ਰਮੇ ਜੈਸੇ ਮਿਰਗਾਏ ॥",
          "roman": "nād bhrame jēse mirgāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как олень, забыв себя, бежит за звуком ловчего инструмента,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37103,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਨ ਤਜੇ ਵਾ ਕੋ ਧਿਆਨੁ ਨ ਜਾਏ ॥੧॥",
          "roman": "prān taje vā ko dhiān na jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "он отдаёт жизнь, но память об этом звуке не покидает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37104,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਰਾਮਾ ਐਸੇ ਹੇਰਉ ॥",
          "roman": "aise rāmā aise herau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так и я смотрю на своего возлюбленного Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37105,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮੁ ਛੋਡਿ ਚਿਤੁ ਅਨਤ ਨ ਫੇਰਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām chhoḍ chit anat na pherau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив память о Раме, я не обращаю свой ум никуда в сторону. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37106,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮੀਨਾ ਹੇਰੈ ਪਸੂਆਰਾ ॥",
          "roman": "jiu mīnā herē pasūārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как рыбак пристально смотрит на рыб,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37107,
          "is_rahao": false,
          "gurmukhi": "ਸੋਨਾ ਗਢਤੇ ਹਿਰੈ ਸੁਨਾਰਾ ॥੨॥",
          "roman": "sonā gaḍhte hirē sunārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "как ювелир, обрабатывая золото, внимательно смотрит на него,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37108,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਬਿਖਈ ਹੇਰੈ ਪਰ ਨਾਰੀ ॥",
          "roman": "jiu bikhī herē par nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "как чувственный человек смотрит на чужую женщину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37109,
          "is_rahao": false,
          "gurmukhi": "ਕਉਡਾ ਡਾਰਤ ਹਿਰੈ ਜੁਆਰੀ ॥੩॥",
          "roman": "kauḍā ḍārat hirē juārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "как игрок, бросив каури, пристально смотрит, какой выпал ход,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37110,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜਹ ਦੇਖਉ ਤਹ ਤਹ ਰਾਮਾ ॥",
          "roman": "jah jah dekhau tah tah rāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "куда бы я ни смотрел, везде вижу Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37111,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਚਰਨ ਨਿਤ ਧਿਆਵੈ ਨਾਮਾ ॥੪॥੨॥",
          "roman": "har ke charan nit dhiāvē nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Намдев постоянно созерцает стопы Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3264,
      "rahao_verse_id": 37114,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37112,
          "is_rahao": true,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37113,
          "is_rahao": true,
          "gurmukhi": "ਮੋ ਕਉ ਤਾਰਿ ਲੇ ਰਾਮਾ ਤਾਰਿ ਲੇ ॥",
          "roman": "mo kau tār le rāmā tār le",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Рам, переправь меня, спаси меня через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37114,
          "is_rahao": true,
          "gurmukhi": "ਮੈ ਅਜਾਨੁ ਜਨੁ ਤਰਿਬੇ ਨ ਜਾਨਉ ਬਾਪ ਬੀਠੁਲਾ ਬਾਹ ਦੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mē ajān jan taribe na jānau bāp bīṭhulā bāh de",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О отец Битхул, дай мне свою руку: я твой неразумный слуга и не умею переплывать. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37115,
          "is_rahao": false,
          "gurmukhi": "ਨਰ ਤੇ ਸੁਰ ਹੋਇ ਜਾਤ ਨਿਮਖ ਮੈ ਸਤਿਗੁਰ ਬੁਧਿ ਸਿਖਲਾਈ ॥",
          "roman": "nar te sur hoi jāt nimakh mē satgur budh sikhlāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По наставлению Сатгуру человек в мгновение ока становится подобным божеству."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37116,
          "is_rahao": false,
          "gurmukhi": "ਨਰ ਤੇ ਉਪਜਿ ਸੁਰਗ ਕਉ ਜੀਤਿਓ ਸੋ ਅਵਖਧ ਮੈ ਪਾਈ ॥੧॥",
          "roman": "nar te upaj surag kau jītio so avakhadh mē pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть я получу то лекарство, благодаря которому, родившись человеком, можно победить даже желание небес."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37117,
          "is_rahao": false,
          "gurmukhi": "ਜਹਾ ਜਹਾ ਧੂਅ ਨਾਰਦੁ ਟੇਕੇ ਨੈਕੁ ਟਿਕਾਵਹੁ ਮੋਹਿ ॥",
          "roman": "jahā jahā dhūa nārad ṭeke nēk ṭikāvah moh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В какие духовные состояния Ты утвердил Дхру и Нарада, туда же навсегда утверди и меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37118,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਨਾਮ ਅਵਿਲੰਬਿ ਬਹੁਤੁ ਜਨ ਉਧਰੇ ਨਾਮੇ ਕੀ ਨਿਜ ਮਤਿ ਏਹ ॥੨॥੩॥",
          "roman": "tere nām avilaṃb bahut jan udhre nāme kī nij mat eh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твёрдое убеждение Намдева таково: опираясь на Твоё Имя, бесчисленные люди спаслись от пороков океана мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
