{
  "ang": 874,
  "shabads": [
    {
      "shabad_id": 3265,
      "rahao_verse_id": 37123,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37119,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37120,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਲਾਗਤੀ ਤਾਲਾਬੇਲੀ ॥",
          "roman": "moh lāgatī tālābelī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ (ਪ੍ਰਭੂ ਤੋਂ ਵਿਛੁੜ ਕੇ) ਤੜਫਣੀ ਲੱਗਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мне (разлучившись с Господом) становится мучительно, я томлюсь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37121,
          "is_rahao": false,
          "gurmukhi": "ਬਛਰੇ ਬਿਨੁ ਗਾਇ ਅਕੇਲੀ ॥੧॥",
          "roman": "bachhare bin gāy akelī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਵੱਛੇ ਤੋਂ ਵਿੱਛੜ ਕੇ ਇਕੱਲੀ ਗਾਂ (ਘਾਬਰਦੀ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "как корова, оставшись без телёнка, тревожится одна ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37122,
          "is_rahao": true,
          "gurmukhi": "ਪਾਨੀਆ ਬਿਨੁ ਮੀਨੁ ਤਲਫੈ ॥",
          "roman": "pānīā bin mīn talaphē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਤੋਂ ਬਿਨਾ ਮੱਛੀ ਫੜਫਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как рыба без воды трепещет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37123,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਰਾਮ ਨਾਮਾ ਬਿਨੁ ਬਾਪੁਰੋ ਨਾਮਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "aise rām nāmā bin bāpuro nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਮੈਂ ਨਾਮਦੇਵ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਘਾਬਰਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "так и я, Намдев, без Имени Господа мучаюсь ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37124,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਗਾਇ ਕਾ ਬਾਛਾ ਛੂਟਲਾ ॥",
          "roman": "jēse gāy kā bāchhā chhūṭlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਜਦੋਂ) ਗਾਂ ਦਾ ਵੱਛਾ ਕਿੱਲੇ ਨਾਲੋਂ ਖੁਲ੍ਹਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как когда телёнок освобождается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37125,
          "is_rahao": false,
          "gurmukhi": "ਥਨ ਚੋਖਤਾ ਮਾਖਨੁ ਘੂਟਲਾ ॥੨॥",
          "roman": "than chokhtā mākhṇ ghūṭlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਗਾਂ ਦੇ) ਥਣ ਚੁੰਘਦਾ ਹੈ, ਤੇ ਮੱਖਣ ਦੇ ਘੁੱਟ ਭਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "он сосёт вымя и пьёт глотки масла ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37126,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਦੇਉ ਨਾਰਾਇਨੁ ਪਾਇਆ ॥",
          "roman": "nāmdeu nārāyan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਮੈਨੂੰ ਨਾਮਦੇਵ ਨੂੰ ਮੈਨੂੰ ਰੱਬ ਮਿਲ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "так и я, Намдев, нашёл Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37127,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਭੇਟਤ ਅਲਖੁ ਲਖਾਇਆ ॥੩॥",
          "roman": "gur bheṭat alakh lakhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਅਲੱਖ ਪ੍ਰਭੂ ਦੀ ਸੂਝ ਪੈ ਗਈ, ਜਦੋਂ ਸਤਿਗੁਰੂ ਮਿਲਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "когда встретил Сатгуру, постиг Невидимого ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37128,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਬਿਖੈ ਹੇਤ ਪਰ ਨਾਰੀ ॥",
          "roman": "jēse bikhē het par nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਵਿਸ਼ਈ ਨੂੰ) ਵਿਸ਼ੇ ਵਾਸਤੇ ਪਰਾਈ ਨਾਰ ਨਾਲ ਪਿਆਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как страстный человек любит чужую женщину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37129,
          "is_rahao": false,
          "gurmukhi": "ਐਸੇ ਨਾਮੇ ਪ੍ਰੀਤਿ ਮੁਰਾਰੀ ॥੪॥",
          "roman": "aise nāme prīt murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਨਾਮੇ ਨੂੰ ਪ੍ਰਭੂ ਨਾਲ ਪਿਆਰ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "так и у меня, Намы, любовь к Господу ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37130,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਤਾਪਤੇ ਨਿਰਮਲ ਘਾਮਾ ॥",
          "roman": "jēse tāpate nirmal ghāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਚਮਕਦੀ ਧੁੱਪ ਵਿਚ (ਜੀਵ-ਜੰਤ) ਤਪਦੇ-ਲੁੱਛਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "как в жарком солнце живые существа мучаются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37131,
          "is_rahao": false,
          "gurmukhi": "ਤੈਸੇ ਰਾਮ ਨਾਮਾ ਬਿਨੁ ਬਾਪੁਰੋ ਨਾਮਾ ॥੫॥੪॥",
          "roman": "tēse rām nāmā bin bāpuro nāmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਤੋਂ ਵਿੱਛੜ ਕੇ ਮੈਂ ਨਾਮਦੇਵ ਇਉਂ ਘਾਬਰਦਾ ਹਾਂ। ਭਾਵ: ਪ੍ਰੀਤ ਦਾ ਸਰੂਪ-ਵਿਛੋੜਾ ਅਸਹਿ ਹੁੰਦਾ ਹੈ ॥੫॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "так и я, Намдев, без Имени Господа страдаю ॥5॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3266,
      "rahao_verse_id": 37139,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37132,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਨਾਮਦੇਉ ਜੀਉ ਕੀ ਘਰੁ ੨",
          "roman": "rāg goṇḍ bāṇī nāmdeu jīu kī ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਗੋਂਡ, ਘਰ ੨ ਵਿੱਚ ਭਗਤ ਨਾਮਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, дом 2, бани Бхагата Намдева."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37133,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог; достигается милостью Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37134,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਰਤ ਮਿਟੇ ਸਭਿ ਭਰਮਾ ॥",
          "roman": "har har karat miṭe sabh bharamā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਸਿਮਰਿਆਂ ਸਭ ਭਟਕਣਾਂ ਦੂਰ ਹੋ ਜਾਂਦੀਆਂ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Хар, исчезают все заблуждения;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37135,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੋ ਨਾਮੁ ਲੈ ਊਤਮ ਧਰਮਾ ॥",
          "roman": "har ko nām lē ūṭam dharamā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਮ ਸਿਮਰ, ਇਹੀ ਹੈ ਸਭ ਤੋਂ ਚੰਗਾ ਧਰਮ।"
            },
            "sahib_singh_ru": {
              "main": "о брат, помни Имя — это высшая дхарма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37136,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਰਤ ਜਾਤਿ ਕੁਲ ਹਰੀ ॥",
          "roman": "har har karat jāt kul harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਸਿਮਰਿਆਂ (ਨੀਵੀਂ ਉੱਚੀ) ਜਾਤ ਕੁਲ ਦਾ ਵਿਤਕਰਾ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "с Имени исчезают различия каст и рода."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37137,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਹਰਿ ਅੰਧੁਲੇ ਕੀ ਲਾਕਰੀ ॥੧॥",
          "roman": "so har andhule kī lākarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹਰਿ-ਨਾਮ ਹੀ ਮੈਂ ਅੰਨ੍ਹੇ ਦਾ ਆਸਰਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Хар — опора для слепого ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37138,
          "is_rahao": true,
          "gurmukhi": "ਹਰਏ ਨਮਸਤੇ ਹਰਏ ਨਮਹ ॥",
          "roman": "hare namaste hare namah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਨਮਸਕਾਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Поклон тому Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37139,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਰਤ ਨਹੀ ਦੁਖੁ ਜਮਹ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har har karat nahī dukh jamah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਜਮਾਂ ਦਾ ਦੁੱਖ ਨਹੀਂ ਰਹਿੰਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "воспоминая Которого, нет страдания Ямы ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37140,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਨਾਖਸ ਹਰੇ ਪਰਾਨ ॥",
          "roman": "har harnākhas hare parān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਹਰਨਾਖਸ਼ (ਦੈਂਤ) ਨੂੰ ਮਾਰਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Господь уничтожил Хироньякашипу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37141,
          "is_rahao": false,
          "gurmukhi": "ਅਜੈਮਲ ਕੀਓ ਬੈਕੁੰਠਹਿ ਥਾਨ ॥",
          "roman": "ajēml kīo bēkunṭh thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜਾਮਲ ਪਾਪੀ ਨੂੰ ਬੈਕੁੰਠ ਵਿਚ ਥਾਂ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "Аджамилу дал место в Вайкунтхе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37142,
          "is_rahao": false,
          "gurmukhi": "ਸੂਆ ਪੜਾਵਤ ਗਨਿਕਾ ਤਰੀ ॥",
          "roman": "sūā paṛāvat ganikā tarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਹਰੀ ਦਾ ਨਾਮ ਤੋਤੇ ਨੂੰ ਪੜ੍ਹਾਉਂਦਿਆਂ ਵੇਸਵਾ ਭੀ ਵਿਕਾਰਾਂ ਵਲੋਂ ਹਟ ਗਈ;"
            },
            "sahib_singh_ru": {
              "main": "даже блудница, обучая попугая Имени, освободилась;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37143,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਹਰਿ ਨੈਨਹੁ ਕੀ ਪੂਤਰੀ ॥੨॥",
          "roman": "so har nēnah kī pūtrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਪ੍ਰਭੂ ਮੇਰੀਆਂ ਅੱਖਾਂ ਦੀ ਪੁਤਲੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот Господь — зрачок моих глаз ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37144,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਕਰਤ ਪੂਤਨਾ ਤਰੀ ॥",
          "roman": "har har karat pūtnā tarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਤਨਾ ਦਾਈ ਭੀ ਤਰ ਗਈ, ਜਦੋਂ ਉਸ ਨੇ ਹਰਿ-ਨਾਮ ਸਿਮਰਿਆ;"
            },
            "sahib_singh_ru": {
              "main": "Путана также освободилась через Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37145,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲ ਘਾਤਨੀ ਕਪਟਹਿ ਭਰੀ ॥",
          "roman": "bāl ghātanī kapaṭah bharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਲਾਂ ਨੂੰ ਮਾਰਨ ਵਾਲੀ ਅਤੇ ਕਪਟ ਨਾਲ ਭਰੀ ਹੋਈ (ਉਸ ਪੂਤਨਾ ਦਾ ਉਧਾਰ ਹੋ ਗਿਆ)।"
            },
            "sahib_singh_ru": {
              "main": "убийца детей, полная коварства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37146,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਨ ਦ੍ਰੋਪਦ ਸੁਤ ਉਧਰੀ ॥",
          "roman": "simran dropad sut udharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਮਰਨ ਦੀ ਬਰਕਤ ਨਾਲ ਹੀ ਦ੍ਰੋਪਤੀ (ਨਿਰਾਦਰੀ ਤੋਂ) ਬਚੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "благодаря воспоминанию Драупади была спасена,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37147,
          "is_rahao": false,
          "gurmukhi": "ਗਊਤਮ ਸਤੀ ਸਿਲਾ ਨਿਸਤਰੀ ॥੩॥",
          "roman": "gautam satī silā nistarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਗੌਤਮ ਦੀ ਨੇਕ ਇਸਤ੍ਰੀ ਦਾ ਪਾਰ-ਉਤਾਰਾ ਹੋਇਆ ਸੀ, ਜੋ (ਗੌਤਮ ਦੇ ਸ੍ਰਾਪ ਨਾਲ) ਸਿਲਾ ਬਣ ਗਈ ਸੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и жена Гаутамы была освобождена из камня ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37148,
          "is_rahao": false,
          "gurmukhi": "ਕੇਸੀ ਕੰਸ ਮਥਨੁ ਜਿਨਿ ਕੀਆ ॥",
          "roman": "kesī kans mathan jin kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਪ੍ਰਭੂ ਨੇ ਕੇਸੀ ਤੇ ਕੰਸ ਦਾ ਨਾਸ ਕੀਤਾ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Он уничтожил Кеси и Кансу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37149,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਦਾਨੁ ਕਾਲੀ ਕਉ ਦੀਆ ॥",
          "roman": "jīa dān kālī kau dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਕਾਲੀ ਨਾਗ ਦੀ ਜਿੰਦ-ਬਖ਼ਸ਼ੀ ਕੀਤੀ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "и даровал жизнь Калия-нагу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37150,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵੈ ਨਾਮਾ ਐਸੋ ਹਰੀ ॥",
          "roman": "praṇvē nāmā ēso harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਬੇਨਤੀ ਕਰਦਾ ਹੈ-ਪ੍ਰਭੂ ਐਸਾ (ਬਖ਼ਸ਼ੰਦ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Намдев молится: таков Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37151,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਭੈ ਅਪਦਾ ਟਰੀ ॥੪॥੧॥੫॥",
          "roman": "jās japat bhē apdā ṭarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਸਭ ਡਰ ਤੇ ਮੁਸੀਬਤਾਂ ਟਲ ਜਾਂਦੀਆਂ ਹਨ ॥੪॥੧॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "что при воспоминании Его исчезают страх и беды ॥4॥1॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3267,
      "rahao_verse_id": 37156,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37152,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37153,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਭੂਤ ਸੀਤਲਾ ਧਾਵੈ ॥",
          "roman": "bhērau bhūt sītlā dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਭੈਰੋਂ ਵਲ ਜਾਂਦਾ ਹੈ (ਭਾਵ, ਜੋ ਭੈਰੋਂ ਦੀ ਅਰਾਧਨਾ ਕਰਦਾ ਹੈ), ਉਹ (ਵਧ ਤੋਂ ਵਧ ਭੈਰੋਂ ਵਰਗਾ ਹੀ) ਭੂਤ ਬਣ ਜਾਂਦਾ ਹੈ। ਜੋ ਸੀਤਲਾ ਨੂੰ ਅਰਾਧਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто поклоняется Бхайраву — становится подобным духу; кто Ситале —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37154,
          "is_rahao": false,
          "gurmukhi": "ਖਰ ਬਾਹਨੁ ਉਹੁ ਛਾਰੁ ਉਡਾਵੈ ॥੧॥",
          "roman": "khar bāhan uh chhār uḍāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਸੀਤਲਾ ਵਾਂਗ) ਖੋਤੇ ਦੀ ਸਵਾਰੀ ਕਰਦਾ ਹੈ ਤੇ (ਖੋਤੇ ਦੇ ਨਾਲ) ਸੁਆਹ ਹੀ ਉਡਾਉਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ездит на осле и разбрасывает пепел ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37155,
          "is_rahao": true,
          "gurmukhi": "ਹਉ ਤਉ ਏਕੁ ਰਮਈਆ ਲੈਹਉ ॥",
          "roman": "hau tau ek ramaīā lēhau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਤ!) ਮੈਂ ਤਾਂ ਇੱਕ ਸੋਹਣੇ ਰਾਮ ਦਾ ਨਾਮ ਹੀ ਲਵਾਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "я же приму только Имя одного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37156,
          "is_rahao": true,
          "gurmukhi": "ਆਨ ਦੇਵ ਬਦਲਾਵਨਿ ਦੈਹਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ān dev badlāvan dehau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੁਹਾਡੇ) ਹੋਰ ਸਾਰੇ ਦੇਵਤਿਆਂ ਨੂੰ ਉਸ ਨਾਮ ਦੇ ਵੱਟੇ ਵਿਚ ਦੇ ਦਿਆਂਗਾ, (ਭਾਵ, ਪ੍ਰਭੂ-ਨਾਮ ਦੇ ਟਾਕਰੇ ਤੇ ਮੈਨੂੰ ਤੁਹਾਡੇ ਕਿਸੇ ਭੀ ਦੇਵੀ ਦੇਵਤੇ ਦੀ ਲੋੜ ਨਹੀਂ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "всех прочих богов отдам взамен ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37157,
          "is_rahao": false,
          "gurmukhi": "ਸਿਵ ਸਿਵ ਕਰਤੇ ਜੋ ਨਰੁ ਧਿਆਵੈ ॥",
          "roman": "siv siv karte jo nar dhiāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਸ਼ਿਵ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто медитирует на Шиву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37158,
          "is_rahao": false,
          "gurmukhi": "ਬਰਦ ਚਢੇ ਡਉਰੂ ਢਮਕਾਵੈ ॥੨॥",
          "roman": "barad chaḍhe ḍaurū ḍhamkāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਵਧ ਤੋਂ ਵਧ ਜੋ ਕੁਝ ਹਾਸਲ ਕਰ ਸਕਦਾ ਹੈ ਇਹ ਹੈ ਕਿ ਸ਼ਿਵ ਦਾ ਰੂਪ ਲੈ ਕੇ, ਸ਼ਿਵ ਦੀ ਸਵਾਰੀ) ਬਲਦ ਉੱਤੇ ਚੜ੍ਹਦਾ ਹੈ ਤੇ (ਸ਼ਿਵ ਵਾਂਗ) ਡਮਰੂ ਵਜਾਉਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ездит на быке и бьёт в дамару ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37159,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਮਾਈ ਕੀ ਪੂਜਾ ਕਰੈ ॥",
          "roman": "mahā māī kī pūjā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪਾਰਬਤੀ ਦੀ ਪੂਜਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто поклоняется Парвати,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37160,
          "is_rahao": false,
          "gurmukhi": "ਨਰ ਸੈ ਨਾਰਿ ਹੋਇ ਅਉਤਰੈ ॥੩॥",
          "roman": "nar sē nār hoi autarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਤੋਂ ਜ਼ਨਾਨੀ ਬਣ ਕੇ ਜਨਮ ਲੈਂਦਾ ਹੈ (ਕਿਉਂਕਿ ਪੂਜਾ ਕਰਨ ਵਾਲਾ ਆਪਣੇ ਪੂਜਯ ਦਾ ਰੂਪ ਹੀ ਬਣ ਸਕਦਾ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тот рождается женщиной ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37161,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਕਹੀਅਤ ਹੀ ਆਦਿ ਭਵਾਨੀ ॥",
          "roman": "tū kahīat hī ād bhavānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਵਾਨੀ! ਤੂੰ ਸਭ ਦਾ ਮੁੱਢ ਅਖਵਾਉਂਦੀ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "о Бхавани, тебя называют изначальной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37162,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਕੀ ਬਰੀਆ ਕਹਾ ਛਪਾਨੀ ॥੪॥",
          "roman": "mukat kī barīā kahā chhapānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਆਪਣੇ ਭਗਤਾਂ ਨੂੰ) ਮੁਕਤੀ ਦੇਣ ਵੇਲੇ ਤੂੰ ਭੀ, ਪਤਾ ਨਹੀਂ, ਕਿੱਥੇ ਲੁਕੀ ਰਹਿੰਦੀ ਹੈਂ (ਭਾਵ, ਮੁਕਤੀ ਭਵਾਨੀ ਪਾਸ ਭੀ ਨਹੀਂ ਹੈ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "но где ты скрываешься, когда приходит время освобождения? ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37163,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਰਾਮ ਨਾਮ ਗਹੁ ਮੀਤਾ ॥",
          "roman": "gurmat rām nām gah mītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ (ਪੰਡਤ!) ਸਤਿਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਲੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਓਟ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "о друг, держись Имени Господа по наставлению Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37164,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵੈ ਨਾਮਾ ਇਉ ਕਹੈ ਗੀਤਾ ॥੫॥੨॥੬॥",
          "roman": "praṇvē nāmā iu kahē gītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
