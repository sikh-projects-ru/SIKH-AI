{
  "ang": 875,
  "shabads": [
    {
      "shabad_id": 3268,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37171,
          "is_rahao": false,
          "gurmukhi": "ਪਾਂਡੇ ਤੁਮਰਾ ਰਾਮਚੰਦੁ ਸੋ ਭੀ ਆਵਤੁ ਦੇਖਿਆ ਥਾ ॥",
          "roman": "pāṇḍe tumrā rāmchand so bhī āvat dekhiā thā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਂਡੇ! ਤੇਰੇ ਸ੍ਰੀ ਰਾਮ ਚੰਦਰ ਜੀ ਭੀ ਆਉਂਦੇ ਵੇਖੇ ਹਨ (ਭਾਵ, ਜਿਸ ਸ੍ਰੀ ਰਾਮ ਚੰਦਰ ਜੀ ਦੀ ਤੂੰ ਉਪਾਸ਼ਨਾ ਕਰਦਾ ਹੈਂ, ਉਹਨਾਂ ਦੀ ਬਾਬਤ ਭੀ ਤੈਥੋਂ ਇਹੀ ਕੁਝ ਅਸਾਂ ਸੁਣਿਆ ਹੈ ਕਿ)"
            },
            "sahib_singh_ru": {
              "main": "о пандит, твоего Рамчандра тоже видели,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37172,
          "is_rahao": false,
          "gurmukhi": "ਰਾਵਨ ਸੇਤੀ ਸਰਬਰ ਹੋਈ ਘਰ ਕੀ ਜੋਇ ਗਵਾਈ ਥੀ ॥੩॥",
          "roman": "rāvan setī sarbar hoī ghar kī joi gavāī thī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਵਣ ਨਾਲ ਉਹਨਾਂ ਦੀ ਲੜਾਈ ਹੋ ਪਈ, ਕਿਉਂਕਿ ਉਹ ਵਹੁਟੀ (ਸੀਤਾ ਜੀ) ਗਵਾ ਬੈਠੇ ਸਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "он воевал с Раваном, потеряв жену ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37173,
          "is_rahao": false,
          "gurmukhi": "ਹਿੰਦੂ ਅੰਨੑਾ ਤੁਰਕੂ ਕਾਣਾ ॥",
          "roman": "hindū andhā turkū kāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ ਹਿੰਦੂ ਦੋਵੇਂ ਅੱਖਾਂ ਗਵਾ ਬੈਠਾ ਹੈ, ਪਰ ਮੁਸਲਮਾਨ ਦੀ ਇੱਕ ਅੱਖ ਹੀ ਖ਼ਰਾਬ ਹੋਈ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "индус слеп, мусульманин одноглаз,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37174,
          "is_rahao": false,
          "gurmukhi": "ਦੁਹਾਂ ਤੇ ਗਿਆਨੀ ਸਿਆਣਾ ॥",
          "roman": "duhāṅ te giānī siāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਦੋਹਾਂ ਨਾਲੋਂ ਸਿਆਣਾ ਉਹ ਬੰਦਾ ਹੈ ਜਿਸ ਨੂੰ (ਪ੍ਰਭੂ ਦੀ ਹਸਤੀ ਦਾ ਸਹੀ) ਗਿਆਨ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но мудр тот, кто познал истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37175,
          "is_rahao": false,
          "gurmukhi": "ਹਿੰਦੂ ਪੂਜੈ ਦੇਹੁਰਾ ਮੁਸਲਮਾਣੁ ਮਸੀਤਿ ॥",
          "roman": "hindū pūjē dehurā musalmāṇ masīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਿੰਦੂ ਨੇ ਇੱਕ ਅੱਖ ਤਾਂ ਤਦੋਂ ਗਵਾਈ ਜਦੋਂ ਉਹ ਆਪਣੇ ਇਸ਼ਟ ਬਾਰੇ ਸ਼ਰਧਾ-ਹੀਣ ਕਹਾਣੀਆਂ ਘੜਨ ਲੱਗ ਪਿਆ, ਤੇ ਦੂਜੀ ਗਵਾਈ, ਜਦੋਂ ਉਹ ਪਰਮਾਤਮਾ ਨੂੰ ਨਿਰਾ ਮੰਦਰ ਵਿਚ ਬੈਠਾ ਸਮਝ ਕੇ) ਮੰਦਰ ਨੂੰ ਪੂਜਣ ਲੱਗ ਪਿਆ, ਮੁਸਲਮਾਨ (ਦੀ ਹਜ਼ਰਤ ਮੁਹੰਮਦ ਸਾਹਿਬ ਵਿਚ ਪੂਰੀ ਸ਼ਰਧਾ ਹੋਣ ਕਰਕੇ ਇੱਕ ਅੱਖ ਤਾਂ ਸਾਬਤ ਹੈ ਪਰ ਦੂਜੀ ਗਵਾ ਬੈਠਾ ਹੈ, ਕਿਉਂਕਿ ਰੱਬ ਨੂੰ ਨਿਰਾ ਮਸਜਿਦ ਵਿਚ ਜਾਣ ਕੇ) ਮਸਜਿਦ ਨੂੰ ਹੀ ਰੱਬ ਦਾ ਘਰ ਸਮਝ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "индус поклоняется храму, мусульманин — мечети,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37176,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਸੋਈ ਸੇਵਿਆ ਜਹ ਦੇਹੁਰਾ ਨ ਮਸੀਤਿ ॥੪॥੩॥੭॥",
          "roman": "nāme soī seviā jah dehurā na masīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਨਾਮਦੇਵ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਹਾਂ ਜਿਸ ਦਾ ਨਾਹ ਕੋਈ ਖ਼ਾਸ ਮੰਦਰ ਹੈ ਤੇ ਨਾ ਮਸਜਿਦ ॥੪॥੩॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "а я, Намдев, служу Тому, у Которого нет ни храма, ни мечети ॥4॥3॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3269,
      "rahao_verse_id": 37184,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37177,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਬਾਣੀ ਰਵਿਦਾਸ ਜੀਉ ਕੀ ਘਰੁ ੨",
          "roman": "rāg goṇḍ bāṇī ravīdās jīu kī ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਗੋਂਡ, ਘਰ ੨ ਵਿੱਚ ਭਗਤ ਰਵਿਦਾਸ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, дом 2: бани Бхагата Равидаса Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37178,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ака́л Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37179,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕੰਦ ਮੁਕੰਦ ਜਪਹੁ ਸੰਸਾਰ ॥",
          "roman": "mukand mukand japah sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਲੋਕੋ! ਮੁਕਤੀ-ਦਾਤੇ ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "О люди! Всегда поминайте Освободителя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37180,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਮੁਕੰਦ ਤਨੁ ਹੋਇ ਅਉਹਾਰ ॥",
          "roman": "bin mukand tan hoī auhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਇਹ ਸਰੀਰ ਵਿਅਰਥ ਹੀ ਚਲਾ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Без Его поминания это тело проходит впустую."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37181,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਮੁਕੰਦੁ ਮੁਕਤਿ ਕਾ ਦਾਤਾ ॥",
          "roman": "soī mukand mukt kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਹੀ ਦੁਨੀਆ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਮੇਰੀ ਰਾਖੀ ਕਰ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь Он способен освободить меня от мирских уз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37182,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਮੁਕੰਦੁ ਹਮਰਾ ਪਿਤ ਮਾਤਾ ॥੧॥",
          "roman": "soī mukand hamrā pit mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਤਾਂ ਮਾਂ ਪਿਉ ਹੀ ਉਹ ਪ੍ਰਭੂ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он для меня и отец, и мать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37183,
          "is_rahao": true,
          "gurmukhi": "ਜੀਵਤ ਮੁਕੰਦੇ ਮਰਤ ਮੁਕੰਦੇ ॥",
          "roman": "jīvat mukande marat mukande",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੰਦਗੀ ਕਰਨ ਵਾਲਾ ਜਿਊਂਦਾ ਭੀ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਹੈ ਤੇ ਮਰਦਾ ਭੀ ਉਸੇ ਨੂੰ ਯਾਦ ਕਰਦਾ ਹੈ (ਸਾਰੀ ਉਮਰ ਹੀ ਪ੍ਰਭੂ ਨੂੰ ਚੇਤੇ ਰੱਖਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Преданный помнит Господа и при жизни, и в смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37184,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਕੇ ਸੇਵਕ ਕਉ ਸਦਾ ਅਨੰਦੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tā ke sevak kau sadā anande",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਦੇਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਬੰਦਗੀ ਕਰਨ ਵਾਲੇ ਨੂੰ ਸਦਾ ਹੀ ਅਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Служащий Ему всегда пребывает в блаженстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37185,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕੰਦ ਮੁਕੰਦ ਹਮਾਰੇ ਪ੍ਰਾਨੰ ॥",
          "roman": "mukand mukand hamāre prānan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਮੇਰੀ ਜਿੰਦ (ਦਾ ਆਸਰਾ ਬਣ ਗਿਆ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Поминание Господа стало опорой моей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37186,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਮੁਕੰਦ ਮਸਤਕਿ ਨੀਸਾਨੰ ॥",
          "roman": "jap mukand mastak nīsānan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰ ਕੇ ਮੇਰੇ ਮੱਥੇ ਉੱਤੇ ਭਾਗ ਜਾਗ ਪਏ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Поминая Его, на моём челе пробудилась удача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37187,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵ ਮੁਕੰਦ ਕਰੈ ਬੈਰਾਗੀ ॥",
          "roman": "sev mukand karē bērāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ (ਮਨੁੱਖ ਨੂੰ) ਵੈਰਾਗਵਾਨ ਕਰ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Преданность Господу делает человека отрешённым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37188,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਮੁਕੰਦੁ ਦੁਰਬਲ ਧਨੁ ਲਾਧੀ ॥੨॥",
          "roman": "soī mukand durbal dhan lādhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਗ਼ਰੀਬ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਧਨ ਲੱਭ ਪਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Я, бедный, обрёл Его Имя как богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37189,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਮੁਕੰਦੁ ਕਰੈ ਉਪਕਾਰੁ ॥",
          "roman": "ek mukand karē upkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਇੱਕ ਪਰਮਾਤਮਾ ਮੇਰੇ ਉੱਤੇ ਮਿਹਰ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если Единственный Господь окажет мне милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37190,
          "is_rahao": false,
          "gurmukhi": "ਹਮਰਾ ਕਹਾ ਕਰੈ ਸੰਸਾਰੁ ॥",
          "roman": "hamrā kahā karē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਮੈਨੂੰ ਚਮਾਰ ਚਮਾਰ ਆਖਣ ਵਾਲੇ ਇਹ) ਲੋਕ ਮੇਰਾ ਕੁਝ ਭੀ ਵਿਗਾੜ ਨਹੀਂ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "тогда люди не смогут причинить мне вред."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37191,
          "is_rahao": false,
          "gurmukhi": "ਮੇਟੀ ਜਾਤਿ ਹੂਏ ਦਰਬਾਰਿ ॥",
          "roman": "meṭī jāt hūe darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਤੇਰੀ ਭਗਤੀ ਨੇ) ਮੇਰੀ (ਨੀਵੀਂ) ਜਾਤ (ਵਾਲੀ ਢਹਿੰਦੀ ਕਲਾ ਮੇਰੇ ਅੰਦਰੋਂ) ਮਿਟਾ ਦਿੱਤੀ ਹੈ, ਕਿਉਂਕਿ ਮੈਂ ਸਦਾ ਤੇਰੇ ਦਰ ਤੇ ਹੁਣ ਰਹਿੰਦਾ ਹਾਂ;"
            },
            "sahib_singh_ru": {
              "main": "Благодаря преданности исчезла моя низкая кастовость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37192,
          "is_rahao": false,
          "gurmukhi": "ਤੁਹੀ ਮੁਕੰਦ ਜੋਗ ਜੁਗ ਤਾਰਿ ॥੩॥",
          "roman": "tuhī mukand jog jug tār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹੀ ਸਦਾ ਮੈਨੂੰ (ਦੁਨੀਆ ਦੇ ਬੰਧਨਾਂ ਤੇ ਮੁਥਾਜੀਆਂ ਤੋਂ) ਪਾਰ ਲੰਘਾਉਣ ਵਾਲਾ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ты один всегда переправляешь меня через мирские узы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37193,
          "is_rahao": false,
          "gurmukhi": "ਉਪਜਿਓ ਗਿਆਨੁ ਹੂਆ ਪਰਗਾਸ ॥",
          "roman": "upjiō giān hūā pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਬੰਦਗੀ ਨਾਲ ਮੇਰੇ ਅੰਦਰ) ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਪੈਦਾ ਹੋ ਗਈ ਹੈ, ਚਾਨਣ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Во мне возникло духовное знание и свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37194,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਲੀਨੇ ਕੀਟ ਦਾਸ ॥",
          "roman": "kar kirpā līne kīṭ dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਨਿਮਾਣੇ ਦਾਸ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਆਪਣਾ ਬਣਾ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Он принял меня, ничтожного раба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37195,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਰਵਿਦਾਸ ਅਬ ਤ੍ਰਿਸਨਾ ਚੂਕੀ ॥",
          "roman": "kah ravīdās ab trisanā chūkī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਵਿਦਾਸ ਆਖਦਾ ਹੈ- ਹੁਣ ਮੇਰੀ ਤ੍ਰਿਸ਼ਨਾ ਮੁੱਕ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Равидас говорит: теперь моя жажда угасла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37196,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਮੁਕੰਦ ਸੇਵਾ ਤਾਹੂ ਕੀ ॥੪॥੧॥",
          "roman": "jap mukand sevā tāhū kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਹੁਣ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਹਾਂ, ਨਿੱਤ ਪ੍ਰਭੂ ਦੀ ਹੀ ਭਗਤੀ ਕਰਦਾ ਹਾਂ ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Я поминаю Господа и служу только Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3270,
      "rahao_verse_id": 37203,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37197,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ॥",
          "roman": "goṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37198,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਓਹੁ ਅਠਸਠਿ ਤੀਰਥ ਨੑਾਵੈ ॥",
          "roman": "je oh aṭhasaṭh tīrath nhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਅਠਾਹਠ ਤੀਰਥਾਂ ਦਾ ਇਸ਼ਨਾਨ (ਭੀ) ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек совершит омовения в шестьдесят восьми святых местах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37199,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਓਹੁ ਦੁਆਦਸ ਸਿਲਾ ਪੂਜਾਵੈ ॥",
          "roman": "je oh duādas silā pūjāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਬਾਰਾਂ ਸ਼ਿਵਲਿੰਗਾਂ ਦੀ ਪੂਜਾ ਭੀ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "если поклонится двенадцати шивалингам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37200,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਓਹੁ ਕੂਪ ਤਟਾ ਦੇਵਾਵੈ ॥",
          "roman": "je oh kūp taṭā devāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਲੋਕਾਂ ਦੇ ਭਲੇ ਲਈ) ਖੂਹ ਤਲਾਬ (ਆਦਿਕ) ਲਵਾਏ;"
            },
            "sahib_singh_ru": {
              "main": "если устроит колодцы и пруды для людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37201,
          "is_rahao": false,
          "gurmukhi": "ਕਰੈ ਨਿੰਦ ਸਭ ਬਿਰਥਾ ਜਾਵੈ ॥੧॥",
          "roman": "karē nind sabh birthā jāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਉਹ (ਗੁਰਮੁਖਾਂ ਦੀ) ਨਿੰਦਿਆ ਕਰਦਾ ਹੈ, ਤਾਂ ਉਸ ਦੀ ਇਹ ਸਾਰੀ ਮਿਹਨਤ ਵਿਅਰਥ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но если он порицает святых, всё это напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37202,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧ ਕਾ ਨਿੰਦਕੁ ਕੈਸੇ ਤਰੈ ॥",
          "roman": "sādh kā nindak kēsē tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਗੁਰਮੁਖਿ ਦੀ ਨਿੰਦਾ ਕਰਨ ਵਾਲਾ ਮਨੁੱਖ (ਜਗਤ ਦੀਆਂ ਨਿਵਾਣਾਂ ਵਿਚੋਂ) ਪਾਰ ਨਹੀਂ ਲੰਘ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Порицающий святых не сможет переправиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37203,
          "is_rahao": true,
          "gurmukhi": "ਸਰਪਰ ਜਾਨਹੁ ਨਰਕ ਹੀ ਪਰੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarpar jānah narak hī parē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਯਕੀਨ ਨਾਲ ਜਾਣੋ ਉਹ ਸਦਾ ਨਰਕ ਵਿਚ ਹੀ ਪਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Знайте наверняка — он остаётся в аду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37204,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਓਹੁ ਗ੍ਰਹਨ ਕਰੈ ਕੁਲਖੇਤਿ ॥",
          "roman": "je oh grahan karē kulkhet",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਕੁਲਖੇਤ੍ਰ ਤੇ (ਜਾ ਕੇ) ਗ੍ਰਹਿਣ (ਦਾ ਇਸ਼ਨਾਨ) ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек совершит омовение во время затмения в Курукшетре,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37205,
          "is_rahao": false,
          "gurmukhi": "ਅਰਪੈ ਨਾਰਿ ਸੀਗਾਰ ਸਮੇਤਿ ॥",
          "roman": "arpē nār sīgār samet",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਹਿਣਿਆਂ ਸਮੇਤ ਆਪਣੀ ਵਹੁਟੀ (ਬ੍ਰਾਹਮਣਾਂ ਨੂੰ) ਦਾਨ ਕਰ ਦੇਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "если пожертвует свою жену вместе с украшениями,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37206,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੀ ਸਿੰਮ੍ਰਿਤਿ ਸ੍ਰਵਨੀ ਸੁਨੈ ॥",
          "roman": "saglī simrit sravanī sunē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀਆਂ ਸਿਮ੍ਰਿਤੀਆਂ ਧਿਆਨ ਨਾਲ ਸੁਣੇ;"
            },
            "sahib_singh_ru": {
              "main": "если внимательно слушает все смрити,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37207,
          "is_rahao": false,
          "gurmukhi": "ਕਰੈ ਨਿੰਦ ਕਵਨੈ ਨਹੀ ਗੁਨੈ ॥੨॥",
          "roman": "karē nind kavanē nahī gunē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਉਹ ਭਲਿਆਂ ਦੀ ਨਿੰਦਿਆ ਕਰਦਾ ਹੈ, ਤਾਂ ਇਹਨਾਂ ਸਾਰੇ ਕੰਮਾਂ ਤੋਂ ਕੋਈ ਭੀ ਲਾਭ ਨਹੀਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но если он порицает праведных — пользы нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37208,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਓਹੁ ਅਨਿਕ ਪ੍ਰਸਾਦ ਕਰਾਵੈ ॥",
          "roman": "je oh anik prasād karāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਠਾਕਰਾਂ ਨੂੰ ਕਈ ਤਰ੍ਹਾਂ ਦੇ ਭੋਗ ਲਵਾਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек предлагает божествам множество подношений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37209,
          "is_rahao": false,
          "gurmukhi": "ਭੂਮਿ ਦਾਨ ਸੋਭਾ ਮੰਡਪਿ ਪਾਵੈ ॥",
          "roman": "bhūm dān sobhā maṇḍap pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜ਼ਮੀਨ ਦਾ ਦਾਨ ਕਰੇ (ਜਿਸ ਕਰਕੇ) ਜਗਤ ਵਿਚ ਸ਼ੋਭਾ ਖੱਟ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "если дарует землю и приобретает славу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37210,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਬਿਗਾਰਿ ਬਿਰਾਂਨਾ ਸਾਂਢੈ ॥",
          "roman": "apnā bigār birānā sāṇḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਆਪਣਾ ਨੁਕਸਾਨ ਕਰ ਕੇ ਭੀ ਦੂਜਿਆਂ ਦੇ ਕੰਮ ਸਵਾਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "если жертвует собой ради помощи другим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37211,
          "is_rahao": false,
          "gurmukhi": "ਕਰੈ ਨਿੰਦ ਬਹੁ ਜੋਨੀ ਹਾਂਢੈ ॥੩॥",
          "roman": "karē nind bah jonī hāṇḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਜੇ ਉਹ ਭਲਿਆਂ ਦੀ ਨਿੰਦਿਆ ਕਰਦਾ ਹੈ ਤਾਂ ਕਈ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но порицая святых, он блуждает в многих рождениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37212,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਾ ਕਹਾ ਕਰਹੁ ਸੰਸਾਰਾ ॥",
          "roman": "nindā kahā karah sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੁਨੀਆ ਦੇ ਲੋਕੋ! ਤੁਸੀ (ਸੰਤਾਂ ਦੀ) ਨਿੰਦਿਆ ਕਿਉਂ ਕਰਦੇ ਹੋ?"
            },
            "sahib_singh_ru": {
              "main": "О люди мира! Почему вы порицаете святых?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37213,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕਾ ਪਰਗਟਿ ਪਾਹਾਰਾ ॥",
          "roman": "nindak kā pargaṭ pāhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
