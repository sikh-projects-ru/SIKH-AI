{
  "ang": 885,
  "shabads": [
    {
      "shabad_id": 3296,
      "rahao_verse_id": 37566,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37560,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "Rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37561,
          "is_rahao": false,
          "gurmukhi": "ਓਅੰਕਾਰਿ ਏਕ ਧੁਨਿ ਏਕੈ ਏਕੈ ਰਾਗੁ ਅਲਾਪੈ ॥",
          "roman": "Oaṅkār ek dhun ekē ekē rāg alāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਰਾਸ ਪਾਣ ਵਾਲਾ ਉਹ ਮਨੁੱਖ) ਸਿਰਫ਼ ਇਕ ਪਰਮਾਤਮਾ (ਦੇ ਚਰਨਾਂ) ਵਿਚ ਲਿਵ ਲਾਈ ਰੱਖਦਾ ਹੈ, ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он держит внимание только на одном Боге, поёт лишь песнь хвалы одному Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37562,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਦੇਸੀ ਏਕੁ ਦਿਖਾਵੈ ਏਕੋ ਰਹਿਆ ਬਿਆਪੈ ॥",
          "roman": "Ekā desī ek dikhāvē eko rahiā biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ, ਹੋਰਨਾਂ ਨੂੰ ਭੀ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਉਪਦੇਸ਼ ਕਰਦਾ ਹੈ, (ਉਸ ਰਾਸਧਾਰੀਏ ਨੂੰ) ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਹਰ ਥਾਂ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "пребывает только в Боге, и другим также указывает лишь на одного Бога, и везде видит только Его присутствие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37563,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਸੁਰਤਿ ਏਕਾ ਹੀ ਸੇਵਾ ਏਕੋ ਗੁਰ ਤੇ ਜਾਪੈ ॥੧॥",
          "roman": "Ekā surat ekā hī sevā eko gur te jāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਸੁਰਤ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਵਿਚ ਹੀ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ, ਉਹ ਸਿਰਫ਼ ਪ੍ਰਭੂ ਦੀ ਹੀ ਭਗਤੀ ਕਰਦਾ ਹੈ। ਗੁਰੂ ਪਾਸੋਂ (ਸਿੱਖਿਆ ਲੈ ਕੇ) ਉਹ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਨਾਮ ਜਪਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Его сознание сосредоточено только на Боге, он служит только Ему, и, получив наставление от Гуру, повторяет только Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37564,
          "is_rahao": true,
          "gurmukhi": "ਭਲੋ ਭਲੋ ਰੇ ਕੀਰਤਨੀਆ ॥",
          "roman": "Bhalo bhalo re kīrtanīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹੀ ਹੈ ਸਭ ਤੋਂ ਚੰਗਾ ਰਾਸਧਾਰੀਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! именно он — наилучший певец киртана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37565,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਰਮਾ ਰਾਮਾ ਗੁਨ ਗਾਉ ॥",
          "roman": "Rām ramā rāmā gun gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "который воспевает качества вездесущего Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37566,
          "is_rahao": true,
          "gurmukhi": "ਛੋਡਿ ਮਾਇਆ ਕੇ ਧੰਧ ਸੁਆਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Chhod māiā ke dhanḍh suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਾਇਆ ਦੇ ਧੰਧੇ ਛੱਡ ਕੇ, ਮਾਇਆ ਦੀ ਗ਼ਰਜ਼ ਛੱਡ ਕੇ (ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и оставив дела и корысть майи, поёт хвалу Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37567,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਬਜਿਤ੍ਰ ਕਰੇ ਸੰਤੋਖਾ ਸਾਤ ਸੁਰਾ ਲੈ ਚਾਲੈ ॥",
          "roman": "Panch bajitr kare santokhā sāt surā lē chālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੇ ਦਰ ਦਾ ਰਾਸਧਾਰੀਆ ਸਤ) ਸੰਤੋਖ (ਆਦਿਕ ਗੁਣਾਂ) ਨੂੰ ਪੰਜ (ਕਿਸਮ ਦੇ) ਸਾਜ ਬਣਾਂਦਾ ਹੈ, ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਰਹਿ ਕੇ ਉਹ ਦੁਨੀਆ ਦੀ ਕਿਰਤ-ਕਾਰ ਕਰਦਾ ਹੈ-ਇਹੀ ਉਸ ਵਾਸਤੇ (ਸਾ, ਰੇ ਆਦਿਕ) ਸੱਤ ਸੁਰਾਂ (ਦਾ ਆਲਾਪ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Он делает удовлетворённость и другие добродетели своими инструментами, и живя в единении с Богом, ведёт мирские дела — это и есть его семь нот."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37568,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜਾ ਮਾਣੁ ਤਾਣੁ ਤਜਿ ਤਾਨਾ ਪਾਉ ਨ ਬੀਗਾ ਘਾਲੈ ॥",
          "roman": "Bājā māṇ tāṇ taj tānā pāu na bīgā ghālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੀ ਤਾਕਤ ਦਾ ਭਰੋਸਾ ਤਿਆਗਦਾ ਹੈ-ਇਹੀ ਉਸ ਦਾ ਵਾਜਾ (ਵਜਾਣਾ) ਹੈ। ਉਹ ਮਨੁੱਖ ਮੰਦੇ ਪਾਸੇ ਪੈਰ ਨਹੀਂ ਧਰਦਾ-ਇਹੀ ਉਸ ਵਾਸਤੇ ਤਾਨ-ਪਲਟਾ (ਆਲਾਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он отказывается от опоры на свою силу — это его инструмент; он не ступает на дурной путь — это его музыкальное исполнение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37569,
          "is_rahao": false,
          "gurmukhi": "ਫੇਰੀ ਫੇਰੁ ਨ ਹੋਵੈ ਕਬ ਹੀ ਏਕੁ ਸਬਦੁ ਬੰਧਿ ਪਾਲੈ ॥੨॥",
          "roman": "Pherī pher na hovē kab hī ek sabad bandh pālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਆਪਣੇ ਪੱਲੇ ਬੰਨ੍ਹੀ ਰੱਖਦਾ ਹੈ (ਹਿਰਦੇ ਵਿਚ ਵਸਾਈ ਰੱਖਦਾ ਹੈ। ਇਸ ਸ਼ਬਦ ਦੀ ਬਰਕਤ ਨਾਲ ਉਸ ਨੂੰ) ਕਦੇ ਜਨਮ-ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਹੁੰਦਾ-ਇਹੀ (ਰਾਸ ਪਾਣ ਵੇਲੇ) ਉਸ ਦੀ ਨਾਚ-ਭੁਆਂਟਣੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он держит Слово Гуру в сердце, и благодаря этому никогда не попадает в круг рождений и смертей — это его танец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37570,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਦੀ ਨਰਹਰ ਜਾਣਿ ਹਦੂਰੇ ॥",
          "roman": "Nāradī narhar jāṇ hadūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੇ ਦਰ ਦਾ ਰਾਸਧਾਰੀਆ) ਪਰਮਾਤਮਾ ਨੂੰ (ਸਦਾ ਆਪਣੇ) ਅੰਗ-ਸੰਗ ਜਾਣਦਾ ਹੈ-ਇਹ ਹੈ ਉਸ ਦੇ ਵਾਸਤੇ ਨਾਰਦ-ਭਗਤੀ ਵਾਲਾ ਨਾਚ।"
            },
            "sahib_singh_ru": {
              "main": "Он всегда ощущает Бога рядом с собой — это его нардовская преданность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37571,
          "is_rahao": false,
          "gurmukhi": "ਘੂੰਘਰ ਖੜਕੁ ਤਿਆਗਿ ਵਿਸੂਰੇ ॥",
          "roman": "Ghūṅghar khaṛak tiāg visūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਉਹ (ਦੁਨੀਆ ਦੇ ਸਾਰੇ) ਚਿੰਤਾ-ਝੋਰੇ ਤਿਆਗ ਦੇਂਦਾ ਹੈ-ਇਹ ਹੈ ਉਸ ਲਈ ਘੂੰਘਰੂਆਂ ਦੀ ਛਣਕਾਰ।"
            },
            "sahib_singh_ru": {
              "main": "Он оставляет все тревоги — это звон его колокольчиков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37572,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਅਨੰਦ ਦਿਖਾਵੈ ਭਾਵੈ ॥",
          "roman": "Sahaj anand dikhāvē bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ ਦਰ ਦਾ ਰਾਸਧਾਰੀਆ) ਆਤਮਕ ਅਡੋਲਤਾ ਦਾ ਸੁਖ ਮਾਣਦਾ ਹੈ (ਮਾਨੋ, ਉਹ) ਨਿਰਤਕਾਰੀ ਦੇ ਕਲੋਲ ਵਿਖਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает в покое и радости — словно показывает танцевальные движения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37573,
          "is_rahao": false,
          "gurmukhi": "ਏਹੁ ਨਿਰਤਿਕਾਰੀ ਜਨਮਿ ਨ ਆਵੈ ॥੩॥",
          "roman": "Eh nirtikārī janam na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਇਹ ਨਿਰਤਕਾਰੀ ਕਰਦਾ ਹੈ, ਉਹ ਜਨਮਾਂ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто исполняет этот танец, не попадает в круг рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37574,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਅਪਨੇ ਠਾਕੁਰ ਭਾਵੈ ॥ ਕੋਟਿ ਮਧਿ ਏਹੁ ਕੀਰਤਨੁ ਗਾਵੈ ॥",
          "roman": "Je ko apne ṭhākur bhāvē kot madh eh kīrtan gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇ ਕ੍ਰੋੜਾਂ ਵਿਚੋਂ ਕੋਈ ਮਨੁੱਖ ਆਪਣੇ ਪਰਮਾਤਮਾ ਨੂੰ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ, ਤਾਂ ਉਹ (ਪ੍ਰਭੂ ਦਾ) ਇਹ ਕੀਰਤਨ ਗਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если среди миллионов кто-то становится угодным Богу, он поёт этот киртан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37575,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕੀ ਜਾਵਉ ਟੇਕ ॥",
          "roman": "Sādhsangat kī jāu ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤਾਂ ਸਾਧ ਸੰਗਤਿ ਦੀ ਸਰਨੀਂ ਪੈਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я ищу опору в садх-сангате,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37576,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਿਸੁ ਕੀਰਤਨੁ ਏਕ ॥੪॥੮॥",
          "roman": "Kaho Nānak tis kīrtan ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਨਾਨਕ ਆਖਦਾ ਹੈ-  (ਸਾਧ ਸੰਗਤਿ ਨੂੰ ਕੀਰਤਨ ਹੀ ਜ਼ਿੰਦਗੀ ਦਾ) ਇਕੋ ਇਕ ਸਹਾਰਾ ਹੈ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "ибо, говорит Нанак, киртан — их единственная опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3297,
      "rahao_verse_id": 37581,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37577,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "Rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37578,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਬੋਲੈ ਰਾਮ ਰਾਮ ਕੋਈ ਖੁਦਾਇ ॥",
          "roman": "Koī bolē rām rām koī khudāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) 'ਰਾਮ ਰਾਮ' ਉਚਾਰਦਾ ਹੈ, ਕੋਈ ਉਸ ਨੂੰ 'ਖ਼ੁਦਾਇ, ਖ਼ੁਦਾਇ' ਆਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то произносит Рам Рам, кто-то называет Его Худā,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37579,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਸੇਵੈ ਗੁਸਈਆ ਕੋਈ ਅਲਾਹਿ ॥੧॥",
          "roman": "Koī sevē gusāīā koī alāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ ਉਸ ਨੂੰ 'ਗੋਸਾਈਂ' ਆਖ ਕੇ ਉਸ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ, ਕੋਈ 'ਅੱਲਾ' ਆਖ ਕੇ ਬੰਦਗੀ ਕਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "кто-то служит Ему как Госайну, кто-то поклоняется как Аллаху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37580,
          "is_rahao": true,
          "gurmukhi": "ਕਾਰਣ ਕਰਣ ਕਰੀਮ ॥",
          "roman": "Kāraṇ karaṇ karīm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਜਗਤ ਦੇ ਮੂਲ! ਹੇ ਬਖ਼ਸ਼ਿੰਦ!"
            },
            "sahib_singh_ru": {
              "main": "О причина всего сущего! О Милостивый!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37581,
          "is_rahao": true,
          "gurmukhi": "ਕਿਰਪਾ ਧਾਰਿ ਰਹੀਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Kirpā dhār rahīm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਿਰਪਾਲ! ਹੇ ਰਹਿਮ ਕਰਨ ਵਾਲੇ! (ਜੀਵਾਂ ਨੇ ਆਪੋ ਆਪਣੇ ਧਰਮ-ਪੁਸਤਕਾਂ ਦੀ ਬੋਲੀ ਅਨੁਸਾਰ ਤੇਰੇ ਵਖ ਵਖ ਨਾਮ ਰੱਖੇ ਹੋਏ ਹਨ, ਪਰ ਤੂੰ ਸਭ ਦਾ ਸਾਂਝਾ ਹੈਂ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О сострадательный, милосердный! Люди называют Тебя по-разному, но Ты один для всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37582,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਨਾਵੈ ਤੀਰਥਿ ਕੋਈ ਹਜ ਜਾਇ ॥",
          "roman": "Koī nāvē tīrath koī haj jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਮਨੁੱਖ ਕਿਸੇ ਤੀਰਥ ਉਤੇ ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈ, ਕੋਈ ਮਨੁੱਖ (ਮੱਕੇ) ਹੱਜ ਕਰਨ ਵਾਸਤੇ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то совершает омовение на святых местах, кто-то отправляется в хадж,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37583,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਕਰੈ ਪੂਜਾ ਕੋਈ ਸਿਰੁ ਨਿਵਾਇ ॥੨॥",
          "roman": "Koī karē pūjā koī sir nivāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ (ਪ੍ਰਭੂ ਦੀ ਮੂਰਤੀ ਬਣਾ ਕੇ) ਪੂਜਾ ਕਰਦਾ ਹੈ, ਕੋਈ ਨਮਾਜ਼ ਪੜ੍ਹਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "кто-то поклоняется идолам, кто-то читает намаз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37584,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਪੜੈ ਬੇਦ ਕੋਈ ਕਤੇਬ ॥",
          "roman": "Koī paṛē bed koī kateb",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ (ਹਿੰਦੂ) ਵੇਦ ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕ ਪੜ੍ਹਦਾ ਹੈ, ਕੋਈ (ਮੁਸਲਮਾਨ ਆਦਿਕ) ਕੁਰਾਨ ਅੰਜੀਲ ਆਦਿਕ ਪੜ੍ਹਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то читает Веды, кто-то — писания вроде Корана и Евангелия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37585,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਓਢੈ ਨੀਲ ਕੋਈ ਸੁਪੇਦ ॥੩॥",
          "roman": "Koī oḍhē nīl koī suped",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ (ਮੁਸਲਮਾਨ ਹੋ ਕੇ) ਨੀਲੇ ਕੱਪੜੇ ਪਹਿਨਦਾ ਹੈ, ਕੋਈ (ਹਿੰਦੂ) ਚਿੱਟੇ ਬਸਤ੍ਰ ਪਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "кто-то носит синюю одежду, кто-то — белую."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37586,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਕਹੈ ਤੁਰਕੁ ਕੋਈ ਕਹੈ ਹਿੰਦੂ ॥",
          "roman": "Koī kahē turak koī kahē hindū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਮਨੁੱਖ ਆਖਦਾ ਹੈ 'ਮੈਂ ਮੁਸਲਮਾਨ ਹਾਂ', ਕੋਈ ਆਖਦਾ ਹੈ 'ਮੈਂ ਹਿੰਦੂ ਹਾਂ'।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то говорит, что он мусульманин, кто-то — что он индуист,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37587,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਬਾਛੈ ਭਿਸਤੁ ਕੋਈ ਸੁਰਗਿੰਦੂ ॥੪॥",
          "roman": "Koī bāchhē bhisat koī suragindū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਪਾਸੋਂ) ਬਹਿਸ਼ਤ ਮੰਗਦਾ ਹੈ, ਕੋਈ ਸੁਰਗ ਮੰਗਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "кто-то просит рай, кто-то — небеса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37588,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਨਿ ਹੁਕਮੁ ਪਛਾਤਾ ॥",
          "roman": "Kaho Nānak jin hukam pachhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਹੁਕਮ ਪਛਾਣਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: тот, кто понял волю Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37589,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਾਹਿਬ ਕਾ ਤਿਨਿ ਭੇਦੁ ਜਾਤਾ ॥੫॥੯॥",
          "roman": "Prabh sāhib kā tin bhed jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਦਾ ਭੇਤ ਪਾ ਲਿਆ ਹੈ (ਕਿ ਉਸ ਨੂੰ ਕਿਵੇਂ ਪ੍ਰਸੰਨ ਕਰ ਸਕੀਦਾ ਹੈ) ॥੫॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "тот познал тайну Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3298,
      "rahao_verse_id": 37596,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37590,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "Rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37591,
          "is_rahao": false,
          "gurmukhi": "ਪਵਨੈ ਮਹਿ ਪਵਨੁ ਸਮਾਇਆ ॥",
          "roman": "Pavanē mah pavan samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਦੋਂ ਅਸੀਂ ਇਹ ਸਮਝਦੇ ਹਾਂ ਕਿ ਕੋਈ ਪ੍ਰਾਣੀ ਮਰ ਗਿਆ ਹੈ, ਅਸਲ ਵਿਚ ਇਹ ਹੁੰਦਾ ਹੈ ਕਿ ਉਸ ਦੇ ਪੰਜ-ਤੱਤੀ ਸਰੀਰ ਵਿਚੋਂ) ਸੁਆਸ ਹਵਾ ਵਿਚ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Дыхание сливается с воздухом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37592,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤੀ ਮਹਿ ਜੋਤਿ ਰਲਿ ਜਾਇਆ ॥",
          "roman": "Jotī mah jot ral jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵਾਤਮਾ (ਸਰਬ-ਵਿਆਪਕ) ਜੋਤਿ ਨਾਲ ਜਾ ਰਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "душа соединяется с Божественным светом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37593,
          "is_rahao": false,
          "gurmukhi": "ਮਾਟੀ ਮਾਟੀ ਹੋਈ ਏਕ ॥",
          "roman": "Māṭī māṭī hoī ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਰੀਰ ਦੀ) ਮਿੱਟੀ (ਧਰਤੀ ਦੀ) ਮਿੱਟੀ ਨਾਲ ਮਿਲ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тело становится прахом и соединяется с землёй,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37594,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਨਹਾਰੇ ਕੀ ਕਵਨ ਟੇਕ ॥੧॥",
          "roman": "Rovanhāre kī kavan ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੁਏ ਨੂੰ) ਰੋਣ ਵਾਲਾ ਭੁਲੇਖੇ ਦੇ ਕਾਰਨ ਹੀ ਰੋਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "плачущий плачет по заблуждению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37595,
          "is_rahao": true,
          "gurmukhi": "ਕਉਨੁ ਮੂਆ ਰੇ ਕਉਨੁ ਮੂਆ ॥",
          "roman": "Kaun mūā re kaun mūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਅਸਲ ਵਿਚ) ਕੋਈ ਭੀ ਜੀਵਾਤਮਾ ਮਰਦਾ ਨਹੀਂ, ਇਹ ਪੱਕੀ ਗੱਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто умер? На самом деле никто не умирает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37596,
          "is_rahao": true,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਮਿਲਿ ਕਰਹੁ ਬੀਚਾਰਾ ਇਹੁ ਤਉ ਚਲਤੁ ਭਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Brahm giānī mil karah bīchārā ih tau chalat bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕੋਈ ਗੁਰਮੁਖਿ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਂਦਾ ਹੈ ਉਸ ਨੂੰ ਮਿਲ ਕੇ (ਬੇ-ਸ਼ੱਕ) ਵਿਚਾਰ ਕਰ ਲਵੋ, (ਜੰਮਣ ਮਰਨ ਵਾਲੀ ਤਾਂ) ਇਹ ਇਕ ਖੇਡ ਬਣੀ ਹੋਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "встреться с познавшим Бога и подумай: это лишь игра."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37597,
          "is_rahao": false,
          "gurmukhi": "ਅਗਲੀ ਕਿਛੁ ਖਬਰਿ ਨ ਪਾਈ ॥",
          "roman": "Aglī kichh khabar na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਿਸੇ ਦੇ ਸਰੀਰਕ ਵਿਛੋੜੇ ਤੇ ਰੋਣ ਵਾਲਾ ਪ੍ਰਾਣੀ ਉਸ ਵੇਲੇ) ਅਗਾਂਹ (ਸਦਾ) ਬੀਤਣ ਵਾਲੀ ਗੱਲ ਨਹੀਂ ਸਮਝਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Человек не понимает будущего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37598,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਨਹਾਰੁ ਭਿ ਊਠਿ ਸਿਧਾਈ ॥",
          "roman": "Rovanhār bh ūṭh sidhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਜੇਹੜਾ (ਹੁਣ ਕਿਸੇ ਦੇ ਵਿਛੋੜੇ ਤੇ) ਰੋ ਰਿਹਾ ਹੈ (ਆਖ਼ਰ) ਉਸ ਨੇ ਭੀ ਇਥੋਂ ਕੂਚ ਕਰ ਜਾਣਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ведь тот, кто сейчас плачет, тоже уйдёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37599,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮ ਮੋਹ ਕੇ ਬਾਂਧੇ ਬੰਧ ॥",
          "roman": "Bharam moh ke bāndhe bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵਾਂ ਨੂੰ) ਭਰਮ ਅਤੇ ਮੋਹ ਦੇ ਬੰਧਨ ਬੱਝੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди связаны узами иллюзии и привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37600,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨੁ ਭਇਆ ਭਖਲਾਏ ਅੰਧ ॥੨॥",
          "roman": "Supan bhaiā bhakhlāe andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਤਮਾ ਅਤੇ ਸਰੀਰ ਦਾ ਮਿਲਾਪ ਤਾਂ ਸੁਪਨੇ ਵਾਂਗ ਹੈ, ਇਹ ਆਖ਼ਰ) ਸੁਪਨਾ ਹੋ ਕੇ ਬੀਤ ਜਾਂਦਾ ਹੈ, ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਅੰਨ੍ਹਾ ਹੋਇਆ ਜੀਵ (ਵਿਅਰਥ ਹੀ) ਬਰੜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "всё это как сон, а ослеплённый человек бредит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37601,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਤਉ ਰਚਨੁ ਰਚਿਆ ਕਰਤਾਰਿ ॥",
          "roman": "Ih tau rachan rachī kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਹ ਜਗਤ ਤਾਂ ਕਰਤਾਰ ਨੇ ਇਕ ਖੇਡ ਰਚੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот мир — лишь творение Творца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37602,
          "is_rahao": false,
          "gurmukhi": "ਆਵਤ ਜਾਵਤ ਹੁਕਮਿ ਅਪਾਰਿ ॥",
          "roman": "Āvat jāvat hukam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਕਰਤਾਰ ਦੇ ਕਦੇ ਖ਼ਤਮ ਨਾਹ ਹੋਣ ਵਾਲੇ ਹੁਕਮ ਵਿਚ ਹੀ ਜੀਵ ਇਥੇ ਆਉਂਦੇ ਰਹਿੰਦੇ ਹਨ ਤੇ ਇਥੋਂ ਜਾਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "в Его бесконечной воле приходят и уходят существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37603,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਕੋ ਮੂਆ ਨ ਮਰਣੈ ਜੋਗੁ ॥",
          "roman": "Nah ko mūā na marṇē jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਂਞ ਕੋਈ ਭੀ ਜੀਵਾਤਮਾ ਕਦੇ ਮਰਦਾ ਨਹੀਂ ਹੈ, ਕਿਉਂਕਿ ਇਹ ਮਰਨ-ਜੋਗਾ ਹੀ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не умирает, ибо душа не подвержена смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37604,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਬਿਨਸੈ ਅਬਿਨਾਸੀ ਹੋਗੁ ॥੩॥",
          "roman": "Nah binsē abināsī hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜੀਵਾਤਮਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ, ਇਸ ਦਾ ਅਸਲਾ ਜੁ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੀ ਹੋਇਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "она не исчезает — она вечна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37605,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਹੁ ਜਾਣਹੁ ਸੋ ਇਹੁ ਨਾਹਿ ॥",
          "roman": "Jo ih jāṇah so ih nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਤੁਸੀ ਇਸ ਜੀਵਾਤਮਾ ਨੂੰ ਜਿਹੋ ਜਿਹਾ ਸਮਝ ਰਹੇ ਹੋ, ਇਹ ਉਹੋ ਜਿਹਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "То, что ты считаешь душой, не является тем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37606,
          "is_rahao": false,
          "gurmukhi": "ਜਾਨਣਹਾਰੇ ਕਉ ਬਲਿ ਜਾਉ ॥",
          "roman": "Jāṇanhāre kau bal jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਮਨੁੱਖ ਤੋਂ ਕੁਰਬਾਨ ਹਾਂ, ਜਿਸ ਨੇ ਇਹ ਅਸਲੀਅਤ ਸਮਝ ਲਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "я преклоняюсь перед тем, кто это понял."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37607,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰਿ ਭਰਮੁ ਚੁਕਾਇਆ ॥",
          "roman": "Kaho Nānak gur bharam chukāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਗੁਰੂ ਨੇ ਜਿਸ ਦਾ ਭੁਲੇਖਾ ਦੂਰ ਕਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: Гуру устраняет заблуждение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37608,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕੋਈ ਮਰੈ ਨ ਆਵੈ ਜਾਇਆ ॥੪॥੧੦॥",
          "roman": "Nā koī marē na āvē jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ, ਉਹ ਮੁੜ ਮੁੜ ਜੰਮਦਾ ਮਰਦਾ ਨਹੀਂ ॥੪॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "и человек не попадает в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3299,
      "rahao_verse_id": 37611,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37609,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "Rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37610,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਗੋਬਿੰਦੁ ਗੋਪਾਲ ਲਾਲੁ ॥",
          "roman": "Jap gobind gopāl lāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੋਬਿੰਦ (ਦਾ ਨਾਮ) ਜਪਿਆ ਕਰ, ਸੋਹਣੇ ਗੋਪਾਲ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Повторяй Имя Гобинда, прекрасного Гопала,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37611,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਸਿਮਰਿ ਤੂ ਜੀਵਹਿ ਫਿਰਿ ਨ ਖਾਈ ਮਹਾ ਕਾਲੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Rām nām simar tū jīvah fir na khāi mahā kāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ, (ਜਿਉਂ ਜਿਉਂ ਨਾਮ ਸਿਮਰੇਂਗਾ) ਤੈਨੂੰ ਉੱਚਾ ਆਤਮਕ ਜੀਵਨ ਮਿਲਿਆ ਰਹੇਗਾ। ਭਿਆਨਕ ਆਤਮਕ ਮੌਤ (ਤੇਰੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ) ਫਿਰ ਕਦੇ ਮੁਕਾ ਨਹੀਂ ਸਕੇਗੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "помни Имя Бога — и будешь жить духовно, и смерть не сможет тебя одолеть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37612,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਆਇਓ ॥",
          "roman": "Koṭ janam bhram bhram bhram āio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ) ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਵਿਚ ਭਟਕ ਕੇ (ਹੁਣ ਤੂੰ ਮਨੁੱਖਾ ਜਨਮ ਵਿਚ) ਆਇਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты прошёл через миллионы рождений в блужданиях,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
