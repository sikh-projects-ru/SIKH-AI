{
  "ang": 886,
  "shabads": [
    {
      "shabad_id": 3299,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37613,
          "is_rahao": false,
          "gurmukhi": "ਬਡੈ ਭਾਗਿ ਸਾਧਸੰਗੁ ਪਾਇਓ ॥੧॥",
          "roman": "Baḍe bhāg sādhsang pāio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ, ਇਥੇ) ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ (ਤੈਨੂੰ) ਗੁਰੂ ਦਾ ਸਾਥ ਮਿਲ ਗਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и по великой удаче получил общение с Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37614,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਪੂਰੇ ਨਾਹੀ ਉਧਾਰੁ ॥",
          "roman": "Bin gur pūre nāhī udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਤੋਂ ਬਿਨਾ (ਅਨੇਕਾਂ ਜੂਨਾਂ ਤੋਂ) ਪਾਰ-ਉਤਾਰਾ ਨਹੀਂ ਹੋ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без совершенного Гуру нет освобождения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37615,
          "is_rahao": false,
          "gurmukhi": "ਬਾਬਾ ਨਾਨਕੁ ਆਖੈ ਏਹੁ ਬੀਚਾਰੁ ॥੨॥੧੧॥",
          "roman": "Bābā Nānak ākhē eh bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਨਕ (ਤੈਨੂੰ) ਇਹ ਵਿਚਾਰ ਦੀ ਗੱਲ ਦੱਸਦਾ ਹੈ ॥੨॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "это наставление даёт Баба Нанак."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3300,
      "rahao_verse_id": 37623,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37616,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਰਾਮਕਲੀ ਮਹਲਾ ੫ ਘਰੁ ੨",
          "roman": "rāg rāmkalī mehlā 5 ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37617,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37618,
          "is_rahao": false,
          "gurmukhi": "ਚਾਰਿ ਪੁਕਾਰਹਿ ਨਾ ਤੂ ਮਾਨਹਿ ॥",
          "roman": "chār pukārah na tū mānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਚਾਰ ਵੇਦ ਪੁਕਾਰ ਪੁਕਾਰ ਕੇ ਆਖ ਰਹੇ ਹਨ (ਕਿ ਸਭ ਜੀਵਾਂ ਵਿਚ (ਰੱਬੀ ਜੋਤਿ-ਰੂਪ ਸੁੰਦਰ ਕਿੰਗਰੀ ਹਰ ਥਾਂ ਵੱਜ ਰਹੀ ਹੈ) ਪਰ ਤੂੰ ਯਕੀਨ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О йог! Четыре Веды вновь и вновь говорят, что во всех существах звучит божественная струна, но ты не веришь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37619,
          "is_rahao": false,
          "gurmukhi": "ਖਟੁ ਭੀ ਏਕਾ ਬਾਤ ਵਖਾਨਹਿ ॥",
          "roman": "khaṭ bhī ekā bāt vakhānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਛੇ ਸ਼ਾਸਤਰ ਭੀ ਇਹੀ ਗੱਲ ਬਿਆਨ ਕਰ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О йог! Шесть шастр тоже излагают ту же самую истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37620,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਅਸਟੀ ਮਿਲਿ ਏਕੋ ਕਹਿਆ ॥",
          "roman": "das asṭī mil eko kahiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਠਾਰਾਂ ਪੁਰਾਣਾਂ ਨੇ ਮਿਲ ਕੇ ਭੀ ਇਹੋ ਬਚਨ ਆਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Восемнадцать пуран также единогласно сказали это же."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37621,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਭੀ ਜੋਗੀ ਭੇਦੁ ਨ ਲਹਿਆ ॥੧॥",
          "roman": "tā bhī jogī bhed na lahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹੇ ਜੋਗੀ! (ਹਰੇਕ ਹਿਰਦੇ ਵਿਚ ਵੱਜ ਰਹੀ ਸੋਹਣੀ ਕਿੰਗ ਦਾ) ਭੇਤ ਤੂੰ ਨਹੀਂ ਸਮਝਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о йог, ты не понял этого тайного смысла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37622,
          "is_rahao": true,
          "gurmukhi": "ਕਿੰਕੁਰੀ ਅਨੂਪ ਵਾਜੈ ॥",
          "roman": "kiṅkurī anūp vājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ, ਅੱਗੇ ਹੀ) ਸੁੰਦਰ ਕਿੰਗ ਬੜੀ ਸੋਹਣੀ ਵੱਜ ਰਹੀ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Смотри, прекрасная струна звучит удивительно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37623,
          "is_rahao": true,
          "gurmukhi": "ਜੋਗੀਆ ਮਤਵਾਰੋ ਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jogīā matvāro re",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੀ ਨਿੱਕੀ ਜਿਹੀ ਕਿੰਗ ਵਜਾਣ ਵਿਚ) ਮਸਤ ਹੇ ਜੋਗੀ! (ਹਰੇਕ ਜੀਵ ਦੇ ਹਿਰਦੇ ਵਿਚ ਰੱਬੀ ਰੌ ਚੱਲ ਰਹੀ ਹੈ-ਇਹੀ ਹੈ ਸੋਹਣੀ ਕਿੰਗ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О йог, ты опьянён своей маленькой струной, тогда как в каждом сердце звучит божественная."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37624,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਥਮੇ ਵਸਿਆ ਸਤ ਕਾ ਖੇੜਾ ॥",
          "roman": "prathame vasiā sat kā kheṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਤੂੰ ਇਹੀ ਸਮਝਦਾ ਆ ਰਿਹਾ ਹੈਂ ਕਿ) ਪਹਿਲੇ ਜੁਗ (ਸਤਜੁਗ) ਵਿਚ ਦਾਨ ਦਾ ਨਗਰ ਵੱਸਦਾ ਸੀ (ਭਾਵ, ਦਾਨ ਕਰਨ ਦਾ ਕਰਮ ਪ੍ਰਧਾਨ ਸੀ),"
            },
            "sahib_singh_ru": {
              "main": "Ты считаешь, что в Сатъюге главным было даяние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37625,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਤੀਏ ਮਹਿ ਕਿਛੁ ਭਇਆ ਦੁਤੇੜਾ ॥",
          "roman": "tritīe meh kich bhaiā duteṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਤ੍ਰੇਤੇ ਜੁਗ ਵਿਚ (ਧਰਮ ਦੇ ਅੰਦਰ) ਕੁਝ ਤ੍ਰੇੜ ਆ ਗਈ (ਧਰਮ-ਬਲਦ ਦੀਆਂ ਤਿੰਨ ਲੱਤਾਂ ਰਹਿ ਗਈਆਂ)।"
            },
            "sahib_singh_ru": {
              "main": "А в Трета-юге произошёл некоторый упадок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37626,
          "is_rahao": false,
          "gurmukhi": "ਦੁਤੀਆ ਅਰਧੋ ਅਰਧਿ ਸਮਾਇਆ ॥",
          "roman": "dutiā ardho ardh samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਤੂੰ ਇਹੀ ਨਿਸਚਾ ਬਣਾਇਆ ਹੋਇਆ ਹੈ ਕਿ) ਦੁਆਪਰ ਜੁਗ ਅੱਧ ਵਿਚ ਟਿਕ ਗਿਆ (ਭਾਵ, ਦੁਆਪਰ ਜੁਗ ਵਿਚ ਧਰਮ-ਬਲਦ ਦੀਆਂ ਦੋ ਲੱਤਾਂ ਰਹਿ ਗਈਆਂ)"
            },
            "sahib_singh_ru": {
              "main": "В Двапара-юге осталось лишь половина."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37627,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਰਹਿਆ ਤਾ ਏਕੁ ਦਿਖਾਇਆ ॥੨॥",
          "roman": "ek rahiā tā ek dikhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਹੁਣ ਜਦੋਂ ਕਲਜੁਗ ਵਿਚ ਧਰਮ-ਬਲਦ ਸਿਰਫ਼) ਇੱਕ (ਲੱਤ ਵਾਲਾ) ਰਹਿ ਗਿਆ ਹੈ, ਤਦੋਂ (ਦਾਨ, ਤਪ, ਜੱਗ ਆਦਿਕ ਦੇ ਥਾਂ ਹਰਿ-ਨਾਮ-ਸਿਮਰਨ ਦਾ) ਇੱਕੋ (ਰਸਤਾ ਮੂਰਤੀ-ਪੂਜਾ ਨੇ ਜੀਵਾਂ ਨੂੰ) ਵਿਖਾਇਆ ਹੈ (ਪਰ ਤੈਨੂੰ ਇਹ ਭੁਲੇਖਾ ਹੈ ਕਿ ਇਕੋ ਪਰਮਾਤਮਾ ਦੇ ਰਚੇ ਜਗਤ ਵਿਚ ਵਖ ਵਖ ਜੁਗਾਂ ਵਿਚ ਵਖ ਵਖ ਧਰਮ-ਆਦਰਸ਼ ਹੋ ਗਏ। ਪਰਮਾਤਮਾ ਦੀ ਬਣਾਈ ਮਰਯਾਦਾ ਸਦਾ ਇਕ-ਸਾਰ ਰਹਿੰਦੀ ਹੈ, ਉਸ ਵਿਚ ਤਬਦੀਲੀ ਨਹੀਂ ਆਉਂਦੀ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "А теперь в Кали-юге остался только один путь, который и показывают людям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37628,
          "is_rahao": false,
          "gurmukhi": "ਏਕੈ ਸੂਤਿ ਪਰੋਏ ਮਣੀਏ ॥",
          "roman": "ekē sūt paroē maṇīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ, ਹੇ ਜੋਗੀ! ਜਿਵੇਂ ਮਾਲਾ ਦੇ ਇਕੋ ਧਾਗੇ ਵਿਚ ਕਈ ਮਣਕੇ ਪ੍ਰੋਤੇ ਹੋਏ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Как множество бусин нанизаны на одну нить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37629,
          "is_rahao": false,
          "gurmukhi": "ਗਾਠੀ ਭਿਨਿ ਭਿਨਿ ਭਿਨਿ ਭਿਨਿ ਤਣੀਏ ॥",
          "roman": "gāṭhī bhin bhin bhin bhin taṇīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਉਸ ਮਾਲਾ ਨੂੰ ਮਨੁੱਖ ਫੇਰਦਾ ਰਹਿੰਦਾ ਹੈ, ਤਿਵੇਂ) ਜਗਤ ਦੇ ਸਾਰੇ ਹੀ ਜੀਵ-ਮਣਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸੱਤਾ-ਰੂਪ ਧਾਗੇ ਵਿਚ ਪ੍ਰੋਤੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "так и все существа связаны одной нитью божественной силы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37630,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਤੀ ਮਾਲਾ ਬਹੁ ਬਿਧਿ ਭਾਇ ॥",
          "roman": "phirtī mālā bah bidh bhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਸਾਰ-ਚੱਕਰ ਦੀ) ਇਹ ਮਾਲਾ ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਕਈ ਜੁਗਤੀਆਂ ਨਾਲ ਫਿਰਦੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эта гирлянда мира вращается многими способами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37631,
          "is_rahao": false,
          "gurmukhi": "ਖਿੰਚਿਆ ਸੂਤੁ ਤ ਆਈ ਥਾਇ ॥੩॥",
          "roman": "khiñchiā sūt ta āī thāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਪਰਮਾਤਮਾ ਆਪਣੀ) ਸੱਤਾ-ਰੂਪ ਧਾਗਾ (ਇਸ ਜਗਤ-ਮਾਲਾ ਵਿਚੋਂ) ਖਿੱਚ ਲੈਂਦਾ ਹੈ, ਤਾਂ (ਸਾਰੀ ਮਾਲਾ ਇਕੋ) ਥਾਂ ਵਿਚ ਆ ਜਾਂਦੀ ਹੈ (ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਇਕੋ ਪਰਮਾਤਮਾ ਵਿਚ ਹੀ ਲੀਨ ਹੋ ਜਾਂਦੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда нить вытягивается, всё возвращается в одно место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37632,
          "is_rahao": false,
          "gurmukhi": "ਚਹੁ ਮਹਿ ਏਕੈ ਮਟੁ ਹੈ ਕੀਆ ॥",
          "roman": "chah meh ekē maṭ hē kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ, ਹੇ ਜੋਗੀ! ਜੋਗੀਆਂ ਦੇ ਮਠ ਵਾਂਗ ਇਹ ਜਗਤ ਇਕ ਮਠ ਹੈ) ਚਹੁੰਆਂ ਹੀ ਜੁਗਾਂ ਵਿਚ (ਸਦਾ ਤੋਂ ਹੀ) ਇਹ ਜਗਤ-ਮਠ ਇਕ (ਪਰਮਾਤਮਾ) ਦਾ ਹੀ ਬਣਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Во всех четырёх эпохах этот мир — один монастырь, созданный одним Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37633,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬਿਖੜੇ ਥਾਨ ਅਨਿਕ ਖਿੜਕੀਆ ॥",
          "roman": "tah bikhṛe thān anik khiṛkīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਜਗਤ-ਮਠ ਵਿਚ ਜੀਵ ਨੂੰ ਖ਼ੁਆਰ ਕਰਨ ਲਈ ਅਨੇਕਾਂ (ਵਿਕਾਰ-ਰੂਪ) ਔਖੇ ਥਾਂ ਹਨ (ਅਤੇ ਵਿਕਾਰਾਂ ਵਿਚ ਫਸੇ ਜੀਵਾਂ ਵਾਸਤੇ) ਅਨੇਕਾਂ ਹੀ ਜੂਨਾਂ ਹਨ (ਜਿਨ੍ਹਾਂ ਵਿਚੋਂ ਦੀ ਜੀਵਾਂ ਨੂੰ ਲੰਘਣਾ ਪੈਂਦਾ ਹੈ, ਜਿਵੇਂ ਕਿਸੇ ਘਰ ਦੀ ਖਿੜਕੀ ਵਿਚੋਂ ਦੀ ਲੰਘੀਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "В нём есть множество трудных мест и путей, через которые проходят души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37634,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਖੋਜਤ ਦੁਆਰੇ ਆਇਆ ॥",
          "roman": "khojat khojat duāre āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜਦੋਂ ਕੋਈ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੇ ਦੇਸ ਦੀ) ਭਾਲ ਕਰਦਾ ਕਰਦਾ (ਗੁਰੂ ਦੇ) ਦਰ ਤੇ ਆ ਪਹੁੰਚਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ища, человек приходит к двери Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37635,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਨਾਨਕ ਜੋਗੀ ਮਹਲੁ ਘਰੁ ਪਾਇਆ ॥੪॥",
          "roman": "tā nānak jogī mahal ghar pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਤਦੋਂ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜੇ ਉਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਮਹਲ ਪਰਮਾਤਮਾ ਦਾ ਘਰ ਲੱਭ ਪੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда, говорит Нанак, он находит обитель Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37636,
          "is_rahao": true,
          "gurmukhi": "ਇਉ ਕਿੰਕੁਰੀ ਆਨੂਪ ਵਾਜੈ ॥",
          "roman": "iu kiṅkurī anūp vājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਇਸ ਤਰ੍ਹਾਂ ਖੋਜ ਕਰਦਿਆਂ ਕਰਦਿਆਂ ਗੁਰੂ ਦੇ ਦਰ ਤੇ ਪਹੁੰਚ ਕੇ ਮਨੁੱਖ ਨੂੰ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ ਕਿ ਹਰੇਕ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਚੇਤਨ-ਸੱਤਾ ਦੀ) ਸੁੰਦਰ ਕਿੰਗਰੀ ਵੱਜ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Так человек понимает, что в каждом сердце звучит божественная струна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37637,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਜੋਗੀ ਕੈ ਮਨਿ ਮੀਠੀ ਲਾਗੈ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥੧॥੧੨॥",
          "roman": "suṇ jogī kē man mīṭhī lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸੁੰਦਰ ਕਿੰਗਰੀ ਵੱਜਦੀ) ਸੁਣ ਸੁਣ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜੇ ਹੋਏ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ (ਇਹ ਕਿੰਗਰੀ) ਮਿੱਠੀ ਲੱਗਣ ਲੱਗ ਪੈਂਦੀ ਹੈ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥੧॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "Слушая её, душа ощущает сладость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3301,
      "rahao_verse_id": 37644,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37638,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37639,
          "is_rahao": false,
          "gurmukhi": "ਤਾਗਾ ਕਰਿ ਕੈ ਲਾਈ ਥਿਗਲੀ ॥",
          "roman": "tāgā kar kē lāī thiglī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਉਸ ਜਗਤ-ਨਾਥ ਨੇ ਨਾੜੀਆਂ ਨੂੰ) ਧਾਗਾ ਬਣਾ ਕੇ (ਸਾਰੇ ਸਰੀਰਕ ਅੰਗਾਂ ਦੀਆਂ) ਟਾਕੀਆਂ ਜੋੜ ਦਿੱਤੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Он создал тело, соединив части как нитью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37640,
          "is_rahao": false,
          "gurmukhi": "ਲਉ ਨਾੜੀ ਸੂਆ ਹੈ ਅਸਤੀ ॥",
          "roman": "lau nāṛī sūā hē astī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਸਰੀਰ-ਗੋਦੜੀ ਦੀਆਂ) ਨਾੜੀਆਂ ਤਰੋਪਿਆਂ ਦਾ ਕੰਮ ਕਰ ਰਹੀਆਂ ਹਨ, (ਅਤੇ ਸਰੀਰ ਦੀ ਹਰੇਕ) ਹੱਡੀ ਸੂਈ ਦਾ ਕੰਮ ਕਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нервы служат нитями, кости — иглами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37641,
          "is_rahao": false,
          "gurmukhi": "ਅੰਭੈ ਕਾ ਕਰਿ ਡੰਡਾ ਧਰਿਆ ॥",
          "roman": "ambhē kā kar daṇḍā dhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨਾਥ ਨੇ ਮਾਤਾ ਪਿਤਾ ਦੀ) ਰਕਤ-ਬੂੰਦ ਨਾਲ (ਸਰੀਰ-) ਡੰਡਾ ਖੜਾ ਕਰ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Из крови родителей он создал тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37642,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਤੂ ਜੋਗੀ ਗਰਬਹਿ ਪਰਿਆ ॥੧॥",
          "roman": "kiā tū jogī garbah pariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਤੂੰ (ਆਪਣੀ ਗੋਦੜੀ ਦਾ) ਕੀਹ ਪਿਆ ਮਾਣ ਕਰਦਾ ਹੈਂ? ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О йог, чем же ты гордишься?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37643,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਨਾਥੁ ਦਿਨੁ ਰੈਨਾਈ ॥",
          "roman": "jap nāth din rēnāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਤੇਰਾ ਇਹ ਸਰੀਰ ਦੋ ਦਿਨਾਂ ਦਾ ਹੀ ਪਰਾਹੁਣਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О йог, это тело лишь на короткое время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37644,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੀ ਖਿੰਥਾ ਦੋ ਦਿਹਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "terī khiṅthā do dihāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਿਨ ਰਾਤ (ਜਗਤ ਦੇ) ਨਾਥ-ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяй имя Господа днём и ночью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37645,
          "is_rahao": false,
          "gurmukhi": "ਗਹਰੀ ਬਿਭੂਤ ਲਾਇ ਬੈਠਾ ਤਾੜੀ ॥",
          "roman": "gahri bibhūt lāi bēṭhā ṭāṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਆਪਣੇ ਸਰੀਰ ਉੱਤੇ) ਸੰਘਣੀ ਸੁਆਹ ਮਲ ਕੇ ਤੂੰ ਸਮਾਧੀ ਲਾ ਕੇ ਬੈਠਾ ਹੋਇਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты покрываешь тело пеплом и сидишь в медитации,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37646,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੀ ਤੇਰੀ ਮੁੰਦ੍ਰਾ ਧਾਰੀ ॥",
          "roman": "merī terī mundrā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਕੰਨਾਂ ਵਿਚ) ਮੁੰਦ੍ਰਾਂ (ਭੀ) ਪਾਈਆਂ ਹੋਈਆਂ ਹਨ (ਪਰ ਤੇਰੇ ਅੰਦਰ) ਮੇਰ-ਤੇਰ ਵੱਸ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "носишь серьги, но внутри держишь разделение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37647,
          "is_rahao": false,
          "gurmukhi": "ਮਾਗਹਿ ਟੂਕਾ ਤ੍ਰਿਪਤਿ ਨ ਪਾਵੈ ॥",
          "roman": "māgah ṭūkā tripat na pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਘਰ ਘਰ ਤੋਂ ਤੂੰ ਟੁੱਕਰ ਮੰਗਦਾ ਫਿਰਦਾ ਹੈਂ, ਤੇਰੇ ਅੰਦਰ ਸ਼ਾਂਤੀ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ты просишь пищу, но не находишь удовлетворения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37648,
          "is_rahao": false,
          "gurmukhi": "ਨਾਥੁ ਛੋਡਿ ਜਾਚਹਿ ਲਾਜ ਨ ਆਵੈ ॥੨॥",
          "roman": "nāth chhoḍ jāchah lāj na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੇ ਜਗਤ ਦੇ) ਨਾਥ ਨੂੰ ਛੱਡ ਕੇ ਤੂੰ (ਲੋਕਾਂ ਦੇ ਦਰ ਤੋਂ) ਮੰਗਦਾ ਹੈਂ। ਹੇ ਜੋਗੀ! ਤੈਨੂੰ (ਇਸ ਦੀ) ਸ਼ਰਮ ਨਹੀਂ ਆ ਰਹੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Оставив Господа, ты просишь у людей и не стыдишься."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37649,
          "is_rahao": false,
          "gurmukhi": "ਚਲ ਚਿਤ ਜੋਗੀ ਆਸਣੁ ਤੇਰਾ ॥",
          "roman": "chal chit jogī āsaṇ terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਡੋਲਦੇ ਮਨ ਵਾਲੇ ਜੋਗੀ! ਤੇਰਾ ਆਸਣ (ਜਮਾਣਾ ਕਿਸੇ ਅਰਥ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "О йог с нестабильным умом, твоя поза бесполезна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37650,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਙੀ ਵਾਜੈ ਨਿਤ ਉਦਾਸੇਰਾ ॥",
          "roman": "siṅgī vājē nit udāsera",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਲੋਕਾਂ ਨੂੰ ਵਿਖਾਣ ਲਈ ਤੇਰੀ) ਸਿੰਙੀ ਵੱਜ ਰਹੀ ਹੈ, ਪਰ ਤੇਰਾ ਮਨ ਸਦਾ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ (ਇਹ ਸਿੰਙੀ ਤਾਂ ਇਕਾਗ੍ਰਤਾ ਦੀ ਖ਼ਾਤਰ ਸੀ)।"
            },
            "sahib_singh_ru": {
              "main": "Твой рог звучит, но ум блуждает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37651,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਗੋਰਖ ਕੀ ਤੈ ਬੂਝ ਨ ਪਾਈ ॥",
          "roman": "gur gorakh kī tē būjh na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! (ਇਸ ਤਰ੍ਹਾਂ) ਉਸ ਸਭ ਤੋਂ ਵੱਡੇ ਗੋਰਖ (ਜਗਤ-ਰੱਖਿਅਕ ਪ੍ਰਭੂ) ਦੀ ਤੈਨੂੰ ਸੋਝੀ ਨਹੀਂ ਪਈ।"
            },
            "sahib_singh_ru": {
              "main": "Ты не понял Великого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37652,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਫਿਰਿ ਜੋਗੀ ਆਵੈ ਜਾਈ ॥੩॥",
          "roman": "phir phir jogī āvē jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਜਿਹਾ) ਜੋਗੀ ਤਾਂ ਮੁੜ ਮੁੜ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Такой йог снова и снова рождается и умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37653,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਹੋਆ ਨਾਥੁ ਕ੍ਰਿਪਾਲਾ ॥",
          "roman": "jis no hoā nāth kripālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ (ਸਾਰੇ ਜਗਤ ਦਾ) ਨਾਥ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кому Господь становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37654,
          "is_rahao": false,
          "gurmukhi": "ਰਹਰਾਸਿ ਹਮਾਰੀ ਗੁਰ ਗੋਪਾਲਾ ॥",
          "roman": "rahrās hamārī gur gopālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਅੱਗੇ ਹੀ ਬੇਨਤੀ ਕਰਦਾ ਹੈ, ਤੇ ਆਖਦਾ ਹੈ-) ਹੇ ਗੁਰ ਗੋਪਾਲ! ਸਾਡੀ ਅਰਜ਼ੋਈ ਤੇਰੇ ਦਰ ਤੇ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот обращается к Богу как к единственному прибежищу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37655,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੈ ਖਿੰਥਾ ਨਾਮੈ ਬਸਤਰੁ ॥",
          "roman": "nāmē khiṅthā nāmē bastar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਨਾਮ ਹੀ ਮੇਰੀ ਗੋਦੜੀ ਹੈ, ਤੇਰਾ ਨਾਮ ਹੀ ਮੇਰਾ (ਭਗਵਾ) ਕੱਪੜਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — его одежда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37656,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਜੋਗੀ ਹੋਆ ਅਸਥਿਰੁ ॥੪॥",
          "roman": "jan nānak jogī hoā asthir",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਇਹੋ ਜਿਹਾ ਮਨੁੱਖ ਅਸਲ) ਜੋਗੀ ਹੈ, ਅਤੇ ਉਹ ਕਦੇ ਡੋਲਦਾ ਨਹੀਂ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Такой человек становится истинным устойчивым йогом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37657,
          "is_rahao": true,
          "gurmukhi": "ਇਉ ਜਪਿਆ ਨਾਥੁ ਦਿਨੁ ਰੈਨਾਈ ॥",
          "roman": "iu japiā nāth din rēnāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੋਗੀ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਦਿਨ ਰਾਤ ਇਸ ਤਰ੍ਹਾਂ (ਜਗਤ ਦੇ) ਨਾਥ ਨੂੰ ਸਿਮਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто помнит Господа день и ночь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37658,
          "is_rahao": true,
          "gurmukhi": "ਹੁਣਿ ਪਾਇਆ ਗੁਰੁ ਗੋਸਾਈ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥੨॥੧੩॥",
          "roman": "huṇ pāiā gur gosāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਇਸੇ ਜਨਮ ਵਿਚ ਉਸ ਸਭ ਤੋਂ ਵੱਡੇ ਜਗਤ-ਨਾਥ ਦਾ ਮਿਲਾਪ ਹਾਸਲ ਕਰ ਲਿਆ ਹੈ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥੨॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "тот достигает Его уже в этой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3302,
      "rahao_verse_id": 37665,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37659,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37660,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਸੋਈ ॥",
          "roman": "karan karāvan soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਸਭ ਕੁਝ ਕਰਨ-ਜੋਗ ਹੈ ਅਤੇ (ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ ਸਭ ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਵਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только Он совершает и побуждает к действиям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37661,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਨ ਦੀਸੈ ਕੋਈ ॥",
          "roman": "ān na dīsē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਤੇ ਭੀ) ਉਸ ਤੋਂ ਬਿਨਾ ਕੋਈ ਦੂਜਾ ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Него никого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37662,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰੁ ਮੇਰਾ ਸੁਘੜੁ ਸੁਜਾਨਾ ॥",
          "roman": "ṭhākur merā sughaṛ sujānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਉਹ ਮਾਲਕ-ਪ੍ਰਭੂ ਗੰਭੀਰ ਸੁਭਾਉ ਵਾਲਾ ਹੈ ਤੇ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Господь мудр и всеведущ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37663,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਮਿਲਿਆ ਰੰਗੁ ਮਾਨਾ ॥੧॥",
          "roman": "gurmukh miliā raṅg mānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਰਾਹੀਂ, ਜਿਸ ਨੂੰ ਉਹ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Кто встречает Его через Гуру, испытывает радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37664,
          "is_rahao": true,
          "gurmukhi": "ਐਸੋ ਰੇ ਹਰਿ ਰਸੁ ਮੀਠਾ ॥",
          "roman": "aiso re har ras mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਅਸਚਰਜ ਹੈ ਮਿੱਠਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сладок вкус имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37665,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕਿਨੈ ਵਿਰਲੈ ਡੀਠਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gurmukh kinē virlē ḍīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਵਿਰਲੇ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਉਸ ਦਾ ਦਰਸਨ ਕੀਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек через Гуру видит Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37666,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਜੋਤਿ ਅੰਮ੍ਰਿਤੁ ਹਰਿ ਨਾਮ ॥",
          "roman": "nirmal jot amrit har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨੂਰ ਮੈਲ-ਰਹਿਤ ਹੈ, ਉਸ ਦਾ ਨਾਮ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਜਲ ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "Его свет чист, Его имя — амрит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
