{
  "ang": 888,
  "shabads": [
    {
      "shabad_id": 3305,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37724,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਕੀਨੋ ਦਹ ਦਿਸ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "man kīno dah dis bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦਾ ਮਨ ਦਸੀਂ ਪਾਸੀਂ ਟਿਕਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но его ум разбросан во все стороны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37725,
          "is_rahao": false,
          "gurmukhi": "ਤਿਲਕੁ ਚਰਾਵੈ ਪਾਈ ਪਾਇ ॥",
          "roman": "tilak charāvē pāī pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹਾ (ਮਨੁੱਖ ਆਪਣੇ ਮੱਥੇ ਉੱਤੇ) ਤਿਲਕ ਲਾਂਦਾ ਹੈ, (ਮੂਰਤੀ ਦੇ) ਪੈਰਾਂ ਉੱਤੇ (ਭੀ) ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он наносит тилак и падает к ногам (идола),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37726,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕ ਪਚਾਰਾ ਅੰਧੁ ਕਮਾਇ ॥੨॥",
          "roman": "lok pachārā andh kamāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਸਭ ਕੁਝ ਉਹ ਸਿਰਫ਼ ਦੁਨੀਆ ਨੂੰ ਪਤਿਆਉਣ ਦਾ ਕੰਮ ਹੀ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но всё это делает лишь ради показухи перед людьми ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37727,
          "is_rahao": false,
          "gurmukhi": "ਖਟੁ ਕਰਮਾ ਅਰੁ ਆਸਣੁ ਧੋਤੀ ॥",
          "roman": "khaṭ karmā aru āsan dhotī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਅੰਨ੍ਹਾ ਮਨੁੱਖ ਸ਼ਾਸਤ੍ਰਾਂ ਦੇ ਦੱਸੇ ਹੋਏ) ਛੇ ਧਾਰਮਿਕ ਕੰਮ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он совершает шесть религиозных действий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37728,
          "is_rahao": false,
          "gurmukhi": "ਭਾਗਠਿ ਗ੍ਰਿਹਿ ਪੜੈ ਨਿਤ ਪੋਥੀ ॥",
          "roman": "bhāgaṭ grih paṛē nit pothī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੇਵ-ਪੂਜਾ ਕਰਨ ਵਾਸਤੇ ਉਸ ਨੇ ਉੱਨ ਆਦਿਕ ਦਾ) ਆਸਣ (ਭੀ ਰੱਖਿਆ ਹੋਇਆ ਹੈ, ਪੂਜਾ ਕਰਨ ਵੇਲੇ) ਧੋਤੀ (ਭੀ ਪਹਿਨਦਾ ਹੈ), ਕਿਸੇ ਧਨਾਢ ਦੇ ਘਰ (ਜਾ ਕੇ) ਸਦਾ (ਆਪਣੀ ਧਾਰਮਿਕ) ਪੁਸਤਕ ਭੀ ਪੜ੍ਹਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "сидит на особом месте, надевает дхоти и читает книги в доме богатых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37729,
          "is_rahao": false,
          "gurmukhi": "ਮਾਲਾ ਫੇਰੈ ਮੰਗੈ ਬਿਭੂਤ ॥",
          "roman": "mālā pherē maṅgē bibhūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਘਰ ਬੈਠ ਕੇ) ਮਾਲਾ ਫੇਰਦਾ ਹੈ, (ਫਿਰ ਉਸ ਧਨਾਢ ਪਾਸੋਂ) ਧਨ-ਪਦਾਰਥ ਮੰਗਦਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "перебирает чётки и просит богатства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37730,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਬਿਧਿ ਕੋਇ ਨ ਤਰਿਓ ਮੀਤ ॥੩॥",
          "roman": "ih bidh koī na tariō mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਇਸ ਤਰੀਕੇ ਨਾਲ ਕੋਈ ਮਨੁੱਖ ਕਦੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਨਹੀਂ ਲੰਘਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но так никто не переправился через океан мира, друг ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37731,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪੰਡਿਤੁ ਗੁਰ ਸਬਦੁ ਕਮਾਇ ॥",
          "roman": "so pandit gur sabad kamāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਹੀ) ਪੰਡਿਤ ਹੈ ਜੇਹੜਾ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਅਨੁਸਾਰ ਆਪਣਾ ਜੀਵਨ ਢਾਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот истинный пандит, кто живёт по Слову Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37732,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਗੁਣ ਕੀ ਓਸੁ ਉਤਰੀ ਮਾਇ ॥",
          "roman": "trē guṇ kī os uṭrī māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿੰਨਾਂ ਗੁਣਾਂ ਵਾਲੀ ਇਹ ਮਾਇਆ ਉਸ ਮਨੁੱਖ ਉਤੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Майя трёх гун не имеет над ним власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37733,
          "is_rahao": false,
          "gurmukhi": "ਚਤੁਰ ਬੇਦ ਪੂਰਨ ਹਰਿ ਨਾਇ ॥",
          "roman": "chatur bed pūran har nāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਭਾ ਦੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ (ਹੀ) ਚਾਰੇ ਵੇਦ ਮੁਕੰਮਲ ਤੌਰ ਤੇ ਆ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "В имени Бога для него заключены все четыре веды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37734,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸ ਕੀ ਸਰਣੀ ਪਾਇ ॥੪॥੬॥੧੭॥",
          "roman": "nānak tis kī sarnī pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਕੋਈ ਭਾਗਾਂ ਵਾਲਾ ਮਨੁੱਖ) ਉਸ (ਪੰਡਿਤ) ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ ॥੪॥੬॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Счастлив тот, кто ищет убежище у такого пандита ॥4॥6॥17॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3306,
      "rahao_verse_id": 37741,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37735,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37736,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਬਿਘਨ ਨਹੀ ਆਵਹਿ ਨੇਰਿ ॥",
          "roman": "koṭ bighan nahī āvah nēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਸ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਦੇ ਰਾਹ ਵਿਚ ਆਉਣ ਵਾਲੀਆਂ) ਕ੍ਰੋੜਾਂ ਰੁਕਾਵਟਾਂ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਆਉਂਦੀਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! (на жизненном пути того человека) миллионы препятствий не приближаются к нему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37737,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਮਾਇਆ ਹੈ ਤਾ ਕੀ ਚੇਰਿ ॥",
          "roman": "anik māiā hē tā kī cher",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ (ਤਰੀਕਿਆਂ ਨਾਲ ਮੋਹਣ ਵਾਲੀ) ਮਾਇਆ ਉਸ ਦੀ ਦਾਸੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "многообразная (соблазняющая разными способами) майя становится его служанкой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37738,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪਾਪ ਤਾ ਕੇ ਪਾਨੀਹਾਰ ॥",
          "roman": "anik pāp tā ke pānīhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੇ) ਅਨੇਕਾਂ ਵਿਕਾਰ ਉਸ ਦਾ ਪਾਣੀ ਭਰਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ (ਉਸ ਉੱਤੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੇ),"
            },
            "sahib_singh_ru": {
              "main": "множество пороков (мира) становятся его водоносами (не могут оказывать на него влияние),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37739,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਮਇਆ ਭਈ ਕਰਤਾਰ ॥੧॥",
          "roman": "jā kau maiā bhaī kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਕਰਤਾਰ ਦੀ ਮੇਹਰ ਹੁੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "на кого нисходит милость Творца ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37740,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸਹਿ ਸਹਾਈ ਹੋਇ ਭਗਵਾਨ ॥",
          "roman": "jisah sahāī hoi bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਦਦਗਾਰ ਪਰਮਾਤਮਾ (ਆਪ) ਬਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! кому Сам Бог становится помощником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37741,
          "is_rahao": true,
          "gurmukhi": "ਅਨਿਕ ਜਤਨ ਉਆ ਕੈ ਸਰੰਜਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "anik jatan uā kē saranjām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਘਰ ਵਿਚ (ਉਸ ਦੇ) ਅਨੇਕਾਂ ਉੱਦਮ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в его доме (все его) многочисленные усилия становятся успешными ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37742,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤਾ ਰਾਖੈ ਕੀਤਾ ਕਉਨੁ ॥",
          "roman": "kartā rākhē kītā kaun",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕਰਤਾਰ ਜਿਸ ਮਨੁੱਖ ਦੀ ਰੱਖਿਆ ਕਰਦਾ ਹੈ, ਉਸ ਦਾ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਜੀਵ ਉਸ ਮਨੁੱਖ ਦਾ ਕੁਝ ਭੀ ਨਹੀਂ ਵਿਗਾੜ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! кого защищает Творец, того ни одно созданное существо не может повредить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37743,
          "is_rahao": false,
          "gurmukhi": "ਕੀਰੀ ਜੀਤੋ ਸਗਲਾ ਭਵਨੁ ॥",
          "roman": "kīrī jīto saglā bhavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਕਰਤਾਰ ਦੀ ਮੇਹਰ ਹੋਵੇ, ਤਾਂ) ਕੀੜੀ (ਭੀ) ਸਾਰੇ ਜਗਤ ਨੂੰ ਜਿੱਤ ਲੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(если есть милость Творца,) даже муравей побеждает весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37744,
          "is_rahao": false,
          "gurmukhi": "ਬੇਅੰਤ ਮਹਿਮਾ ਤਾ ਕੀ ਕੇਤਕ ਬਰਨ ॥",
          "roman": "beant mahimā tā kī ketak baran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਕਰਤਾਰ ਦੀ ਬੇਅੰਤ ਵਡਿਆਈ ਹੈ। ਕਿਤਨੀ ਕੁ ਬਿਆਨ ਕੀਤੀ ਜਾਏ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! бесконечна Его слава. Как можно её описать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37745,
          "is_rahao": false,
          "gurmukhi": "ਬਲਿ ਬਲਿ ਜਾਈਐ ਤਾ ਕੇ ਚਰਨ ॥੨॥",
          "roman": "bal bal jāīai tā ke charan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਚਰਨਾਂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Его стопам следует постоянно посвящать себя ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37746,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਹੀ ਕੀਆ ਜਪੁ ਤਪੁ ਧਿਆਨੁ ॥",
          "roman": "tin hī kīā jap tap dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸੇ ਮਨੁੱਖ ਨੇ ਜਪ ਕੀਤਾ ਸਮਝੋ, ਉਸੇ ਮਨੁੱਖ ਨੇ ਤਪ ਸਾਧਿਆ ਜਾਣੋ, ਉਸੇ ਮਨੁੱਖ ਨੇ ਸਮਾਧੀ ਲਾਈ ਸਮਝੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! только тот человек считается совершившим джап, совершившим тапас, погрузившимся в медитацию,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37747,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪ੍ਰਕਾਰ ਕੀਆ ਤਿਨਿ ਦਾਨੁ ॥",
          "roman": "anik prakār kīā tin dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਮਨੁੱਖ ਨੇ ਹੀ ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦਾ ਦਾਨ ਦਿੱਤਾ ਜਾਣੋ (ਉਹੀ ਅਸਲ ਜਪੀ ਹੈ ਉਹੀ ਅਸਲ ਤਪੀ ਹੈ, ਉਹੀ ਅਸਲ ਜੋਗੀ ਹੈ, ਉਹੀ ਅਸਲ ਦਾਨੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "только он считается давшим разнообразные дары (он и есть истинный практикующий, аскет, йог и щедрый),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37748,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤੁ ਸੋਈ ਕਲਿ ਮਹਿ ਪਰਵਾਨੁ ॥",
          "roman": "bhagat soī kal meh parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਅਸਲ ਭਗਤ ਹੈ, ਉਹੀ ਜਗਤ ਵਿਚ ਮੰਨਿਆ-ਪ੍ਰਮੰਨਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он — истинный бхакт, он признан в мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37749,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਠਾਕੁਰਿ ਦੀਆ ਮਾਨੁ ॥੩॥",
          "roman": "jā kau ṭhākur dīā mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੇ ਆਦਰ ਬਖ਼ਸ਼ਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "кому Господь даровал честь ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37750,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਿਲਿ ਭਏ ਪ੍ਰਗਾਸ ॥",
          "roman": "sādhsang mil bhae pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਦੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਦਾ ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в общении с Гуру в них загорается свет духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37751,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸੂਖ ਆਸ ਨਿਵਾਸ ॥",
          "roman": "sahaj sūkh ās nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ) ਪਰਮਾਤਮਾ ਆਤਮਕ ਅਡੋਲਤਾ ਅਤੇ ਸੁਖਾਂ ਦਾ ਸੋਮਾ ਹੈ, ਪਰਮਾਤਮਾ ਹੀ ਸਭ ਦੀਆਂ ਆਸਾਂ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(они убеждаются, что) Бог — источник устойчивости и радости, Он исполняет все надежды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37752,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਸਤਿਗੁਰਿ ਦੀਆ ਬਿਸਾਸ ॥",
          "roman": "pūrē satgur dīā bisās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਕਰਾ ਦਿੱਤਾ ਕਿ"
            },
            "sahib_singh_ru": {
              "main": "полный Гуру дарует им это убеждение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37753,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹੋਏ ਦਾਸਨਿ ਦਾਸ ॥੪॥੭॥੧੮॥",
          "roman": "nānak hoe dāsan dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਦਾਸਾਂ ਦੇ ਦਾਸ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੭॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! такие люди становятся слугами слуг Бога ॥4॥7॥18॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3307,
      "rahao_verse_id": 37760,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37754,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37755,
          "is_rahao": false,
          "gurmukhi": "ਦੋਸੁ ਨ ਦੀਜੈ ਕਾਹੂ ਲੋਗ ॥",
          "roman": "dos na dījē kāhū log",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਨੇ ਇਉਂ ਸਮਝਿਆ ਹੈ ਕਿ ਆਪਣੀ ਕਿਸੇ ਔਖਿਆਈ ਬਾਰੇ) ਕਿਸੇ ਹੋਰ ਪ੍ਰਾਣੀਆਂ ਨੂੰ ਦੋਸ ਨਹੀਂ ਦੇਣਾ ਚਾਹੀਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат! святые поняли так:) нельзя обвинять других существ в своих трудностях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37756,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਮਾਵਨੁ ਸੋਈ ਭੋਗ ॥",
          "roman": "jo kamāvan soī bhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਜੋ ਕਰਮ ਕਮਾਂਦਾ ਹੈ, ਉਸੇ ਦਾ ਹੀ ਫਲ ਭੋਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "человек пожинает плоды тех деяний, которые сам совершает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37757,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਕਰਮ ਆਪੇ ਹੀ ਬੰਧ ॥",
          "roman": "āpan karam āpe hī bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਕੀਤੇ ਕਰਮਾਂ (ਦੇ ਸੰਸਕਾਰਾਂ) ਅਨੁਸਾਰ ਮਨੁੱਖ ਆਪ ਹੀ (ਮਾਇਆ ਦੇ) ਬੰਧਨਾਂ ਵਿਚ (ਜਕੜਿਆ ਰਹਿੰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "своими же поступками человек сам связывает себя (узами майи),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37758,
          "is_rahao": false,
          "gurmukhi": "ਆਵਨੁ ਜਾਵਨੁ ਮਾਇਆ ਧੰਧ ॥੧॥",
          "roman": "āvan jāvan māiā dhandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਧੰਧਿਆਂ ਦੇ ਕਾਰਨ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и из-за дел майи продолжается круг рождения и смерти ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37759,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਜਾਨੀ ਸੰਤ ਜਨੀ ॥",
          "roman": "aisī jānī sant janī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਨੇ (ਹੀ ਇਸ ਜੀਵਨ-ਜੁਗਤਿ ਨੂੰ) ਸਮਝਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! именно святые так поняли жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37760,
          "is_rahao": true,
          "gurmukhi": "ਪਰਗਾਸੁ ਭਇਆ ਪੂਰੇ ਗੁਰ ਬਚਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pargās bhaīā pūre gur bachnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਦੇ ਬਚਨਾਂ ਉੱਤੇ ਤੁਰ ਕੇ (ਉਨ੍ਹਾਂ ਦੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਦਾ) ਚਾਨਣ ਹੋ ਗਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "следуя словам совершенного Гуру, в них загорается свет духовной жизни ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37761,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਧਨੁ ਕਲਤੁ ਮਿਥਿਆ ਬਿਸਥਾਰ ॥",
          "roman": "tan dhan kalat mithīā bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਰੀਰ, ਧਨ, ਵਹੁਟੀ-(ਮੋਹ ਦੇ ਇਹ ਸਾਰੇ) ਖਿਲਾਰੇ ਨਾਸਵੰਤ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! тело, богатство, жена — все эти проявления привязанности преходящи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37762,
          "is_rahao": false,
          "gurmukhi": "ਹੈਵਰ ਗੈਵਰ ਚਾਲਨਹਾਰ ॥",
          "roman": "hēvar gēvar chālanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਧੀਆ ਘੋੜੇ, ਵਧੀਆ ਹਾਥੀ-ਇਹ ਭੀ ਨਾਸਵੰਤ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "лучшие кони, лучшие слоны — всё это также преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37763,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜ ਰੰਗ ਰੂਪ ਸਭਿ ਕੂਰ ॥",
          "roman": "rāj rang rūp sabh kūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ ਦੀਆਂ ਬਾਦਸ਼ਾਹੀਆਂ, ਰੰਗ-ਤਮਾਸ਼ੇ ਅਤੇ ਸੁੰਦਰ ਨੁਹਾਰਾਂ-ਇਹ ਭੀ ਸਾਰੇ ਕੂੜੇ ਪਸਾਰੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "царства, развлечения и красота — всё это ложные проявления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37764,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਹੋਇ ਜਾਸੀ ਧੂਰ ॥੨॥",
          "roman": "nām binā hoi jāsī dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਹਰੇਕ ਸ਼ੈ ਮਿੱਟੀ ਹੋ ਜਾਇਗੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! без Имени всё обратится в прах ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37765,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਿ ਭੂਲੇ ਬਾਦਿ ਅਹੰਕਾਰੀ ॥",
          "roman": "bharam bhūle bād ahaṅkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਨ੍ਹਾਂ ਪਦਾਰਥਾਂ ਦੀ ਖ਼ਾਤਰ ਮਨੁੱਖ ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ ਜੀਵਨ ਦੇ ਗ਼ਲਤ ਰਸਤੇ ਪੈ ਜਾਂਦੇ ਹਨ ਅਤੇ ਵਿਅਰਥ ਮਾਣ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! ради этих вещей человек заблуждается, сбивается с пути и напрасно гордится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37766,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਨਾਹੀ ਰੇ ਸਗਲ ਪਸਾਰੀ ॥",
          "roman": "sang nāhī re sagal pasārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੇ ਖਿਲਾਰੇ ਕਿਸੇ ਦੇ ਨਾਲ ਨਹੀਂ ਜਾ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "но всё это не пойдёт с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37767,
          "is_rahao": false,
          "gurmukhi": "ਸੋਗ ਹਰਖ ਮਹਿ ਦੇਹ ਬਿਰਧਾਨੀ ॥",
          "roman": "sog harakh meh deh biradhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਖ਼ੁਸ਼ੀ ਵਿਚ, ਗ਼ਮੀ ਵਿਚ, (ਇਉਂ ਹੀ) ਸਰੀਰ ਬੁੱਢਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в радости и печали тело стареет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37768,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਇਵ ਹੀ ਕਰਤ ਬਿਹਾਨੀ ॥੩॥",
          "roman": "sākat iv hī karat bihānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਟੁੱਟੇ ਹੋਏ ਮਨੁੱਖ ਦੀ ਉਮਰ ਇਸੇ ਤਰ੍ਹਾਂ ਹੀ ਬੀਤ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так проходит жизнь человека, оторванного от Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37769,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਅੰਮ੍ਰਿਤੁ ਕਲਿ ਮਾਹਿ ॥",
          "roman": "har kā nām amrit kal māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਗਤ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ (ਪਦਾਰਥ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! в этом мире только Имя Бога даёт духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37770,
          "is_rahao": false,
          "gurmukhi": "ਏਹੁ ਨਿਧਾਨਾ ਸਾਧੂ ਪਾਹਿ ॥",
          "roman": "eh nidhānā sādhū pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਖ਼ਜ਼ਾਨਾ ਗੁਰੂ ਦੇ ਪਾਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот клад находится у Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37771,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰੁ ਗੋਵਿਦੁ ਜਿਸੁ ਤੂਠਾ ॥",
          "roman": "nānak gur govid jis tūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਗੁਰੂ ਪ੍ਰਸੰਨ ਹੁੰਦਾ ਹੈ, ਪਰਮਾਤਮਾ ਪ੍ਰਸੰਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! на кого милостив Гуру, на того милостив и Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37772,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਰਮਈਆ ਤਿਨ ਹੀ ਡੀਠਾ ॥੪॥੮॥੧੯॥",
          "roman": "ghaṭ ghaṭ ramaīā tin hī dīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਮਨੁੱਖ ਨੇ ਸੋਹਣੇ ਪ੍ਰਭੂ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੇਖਿਆ ਹੈ ॥੪॥੮॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "тот видит прекрасного Бога во всех существах ॥4॥8॥19॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3308,
      "rahao_verse_id": 37779,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37773,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37774,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਸਬਦ ਤਹ ਪੂਰਨ ਨਾਦ ॥",
          "roman": "pañch sabad tah pūran nād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ (ਇਉਂ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ ਜਿਵੇਂ) ਪੰਜ ਕਿਸਮਾਂ ਦੇ ਸਾਜ਼ਾਂ ਦੀ ਘਨਘੋਰ ਆਵਾਜ਼ ਹੋ ਰਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! в том духовном состоянии словно звучат пять видов инструментов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37775,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਬਾਜੇ ਅਚਰਜ ਬਿਸਮਾਦ ॥",
          "roman": "anhad bāje acharaj bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਇੱਕ-ਰਸ ਵਾਜੇ ਵੱਜ ਰਹੇ ਹਨ। ਉਹ ਅਵਸਥਾ ਅਚਰਜ ਤੇ ਹੈਰਾਨੀ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "внутри непрерывно звучат божественные звуки — состояние удивительное и изумляющее."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37776,
          "is_rahao": false,
          "gurmukhi": "ਕੇਲ ਕਰਹਿ ਸੰਤ ਹਰਿ ਲੋਗ ॥",
          "roman": "kel karah sant har log",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਾਧ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਪ੍ਰਭੂ ਦੇ ਸੰਤ-ਜਨ (ਉਸ ਅਵਸਥਾ ਵਿਚ ਪਹੁੰਚ ਕੇ) ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! благодаря святому общению святые наслаждаются духовным блаженством,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37777,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਨਿਰਜੋਗ ॥੧॥",
          "roman": "pārbrahm pūran nirjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਜੁੜੇ ਰਹਿੰਦੇ ਹਨ ਜੋ) ਨਿਰਲੇਪ ਤੇ ਸਰਬ-ਵਿਆਪਕ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "соединяясь с Высшим Богом, который вне привязанностей и всепроникающий ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37778,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਭਵਨ ॥",
          "roman": "sūkh sahaj ānand bhavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ, ਆਤਮਕ ਸੁਖ-ਆਨੰਦ ਦੀ ਅਵਸਥਾ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! такие люди достигают состояния духовной устойчивости и блаженства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37779,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਬੈਸਿ ਗੁਣ ਗਾਵਹਿ ਤਹ ਰੋਗ ਸੋਗ ਨਹੀ ਜਨਮ ਮਰਨ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhsang bēs guṇ gāvah tah rog sog nahī janam maran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਬੈਠ ਕੇ (ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ। ਉਸ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਕੋਈ ਰੋਗ ਕੋਈ ਗ਼ਮ ਕੋਈ ਜਨਮ-ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਵਿਆਪਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "которые, сидя в обществе Гуру, поют Его качества — там нет ни болезней, ни скорби, ни круга рождения и смерти ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37780,
          "is_rahao": false,
          "gurmukhi": "ਊਹਾ ਸਿਮਰਹਿ ਕੇਵਲ ਨਾਮੁ ॥",
          "roman": "ūhā simrah keval nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ (ਪਹੁੰਚੇ ਹੋਏ ਸੰਤ-ਜਨ) ਸਿਰਫ਼ (ਹਰਿ-) ਨਾਮ ਸਿਮਰਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! в том состоянии они помнят только Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37781,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਲੇ ਪਾਵਹਿ ਓਹੁ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "birle pāvah oh bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਹ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਵਿਰਲੇ ਮਨੁੱਖਾਂ ਨੂੰ ਹਾਸਲ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но этого высшего покоя достигают лишь редкие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37782,
          "is_rahao": false,
          "gurmukhi": "ਭੋਜਨੁ ਭਾਉ ਕੀਰਤਨ ਆਧਾਰੁ ॥",
          "roman": "bhojan bhāu kīrtan ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਅਵਸਥਾ ਵਿਚ ਪ੍ਰਭੂ-ਪ੍ਰੇਮ ਹੀ ਮਨੁੱਖ ਦੀ ਆਤਮਕ ਖ਼ੁਰਾਕ ਹੋ ਜਾਂਦੀ ਹੈ, ਆਤਮਕ ਜੀਵਨ ਵਾਸਤੇ ਮਨੁੱਖ ਨੂੰ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦਾ ਹੀ ਸਹਾਰਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! там любовь к Богу становится духовной пищей, а воспевание Его — опорой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
