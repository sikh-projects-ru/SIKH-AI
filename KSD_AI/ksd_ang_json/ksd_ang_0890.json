      "lines": [
        {
          "verse_id": 37889,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37890,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਾਪ ਤਾਪ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "koṭ jāp tāp bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਕ੍ਰੋੜਾਂ ਜਪਾਂ ਤਪਾਂ (ਦਾ ਫਲ ਉਸ ਦੇ ਅੰਦਰ) ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Плод миллионов аскез пребывает в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37891,
          "is_rahao": false,
          "gurmukhi": "ਰਿਧਿ ਬੁਧਿ ਸਿਧਿ ਸੁਰ ਗਿਆਨ ॥",
          "roman": "ridh budh sidh sur giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਦੇਵਤਿਆਂ ਵਾਲੀ ਸੂਝ-ਬੂਝ ਹੋ ਜਾਂਦੀ ਹੈ, ਉਸ ਦੀ ਬੁੱਧੀ (ਉੱਚੀ ਹੋ ਜਾਂਦੀ ਹੈ) ਉਹ ਰਿੱਧੀਆਂ ਸਿੱਧੀਆਂ (ਦਾ ਮਾਲਕ ਹੋ ਜਾਂਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Он обретает божественную мудрость и силы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37892,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰੂਪ ਰੰਗ ਭੋਗ ਰਸੈ ॥",
          "roman": "anik rūp raṅg bhog rasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਮਾਨੋ) ਅਨੇਕਾਂ ਰੂਪਾਂ ਰੰਗਾਂ ਅਤੇ ਮਾਇਕ ਪਦਾਰਥਾਂ ਦਾ ਰਸ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он как будто наслаждается всеми формами и удовольствиями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37893,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਨਿਮਖ ਰਿਦੈ ਵਸੈ ॥੧॥",
          "roman": "gurmukh nām nimakh ridē vasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਰਾਹੀਂ (ਜਿਸ ਮਨੁੱਖ ਦੇ) ਹਿਰਦੇ ਵਿਚ ਅੱਖ ਦੇ ਫੋਰ ਜਿਤਨੇ ਸਮੇ ਵਾਸਤੇ ਭੀ ਹਰਿ-ਨਾਮ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Если хотя бы на мгновение Имя пребывает в сердце через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37894,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "har ke nām kī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਮਹੱਤਤਾ (ਦੱਸੀ ਨਹੀਂ ਜਾ ਸਕਦੀ)"
            },
            "sahib_singh_ru": {
              "main": "Величие Имени Бога невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37895,
          "is_rahao": true,
          "gurmukhi": "ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kīmat kahan na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਦਾ ਮੁੱਲ ਪਾਇਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Его ценность невозможно выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37896,
          "is_rahao": false,
          "gurmukhi": "ਸੂਰਬੀਰ ਧੀਰਜ ਮਤਿ ਪੂਰਾ ॥",
          "roman": "sūrbīr dhīraj mat pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਮਨੁੱਖ (ਵਿਕਾਰਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਸੂਰਮਾ ਹੈ ਬਹਾਦਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он становится храбрым и стойким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
