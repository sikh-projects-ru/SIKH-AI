{
  "ang": 890,
  "shabads": [
    {
      "shabad_id": 3311,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37841,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਤੀਅ ਬਿਵਸਥਾ ਸਿੰਚੇ ਮਾਇ ॥",
          "roman": "tritīa bivasthā sinche māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਵਾਨੀ ਲੰਘ ਜਾਣ ਤੇ) ਤੀਜੀ ਉਮਰੇ ਮਾਇਆ ਜੋੜਨ ਲੱਗ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в зрелости начинает накапливать майю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37842,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਧਿ ਭਇਆ ਛੋਡਿ ਚਲਿਓ ਪਛੁਤਾਇ ॥੨॥",
          "roman": "birdh bhaeā chhoḍ chaliō pachhutāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਖ਼ਰ ਜਦੋਂ) ਬੁੱਢਾ ਹੋ ਜਾਂਦਾ ਹੈ ਤਾਂ ਅਫ਼ਸੋਸ ਕਰਦਾ (ਜੋੜੀ ਹੋਈ ਮਾਇਆ) ਛੱਡ ਕੇ (ਇਥੋਂ) ਤੁਰ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "в старости с сожалением всё оставляет и уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37843,
          "is_rahao": false,
          "gurmukhi": "ਚਿਰੰਕਾਲ ਪਾਈ ਦ੍ਰੁਲਭ ਦੇਹ ॥",
          "roman": "chiraṅkāl pāī drulabh deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਬੜੇ ਚਿਰਾਂ ਪਿੱਛੋਂ ਜੀਵ ਨੂੰ ਇਹ ਦੁਰਲੱਭ ਮਨੁੱਖਾ ਸਰੀਰ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "о брат! спустя долгое время даётся это редкое человеческое тело,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37844,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਣੀ ਹੋਈ ਖੇਹ ॥",
          "roman": "nām bihūṇī hoī kheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਨਾਮ ਤੋਂ ਵਾਂਜੇ ਰਹਿ ਕੇ ਇਹ ਸਰੀਰ ਮਿੱਟੀ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но без Имени оно превращается в прах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37845,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਪਰੇਤ ਮੁਗਧ ਤੇ ਬੁਰੀ ॥",
          "roman": "pasū paret mugadh te burī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਤੋਂ ਬਿਨਾ, ਵਿਕਾਰਾਂ ਦੇ ਕਾਰਨ) ਮੂਰਖ ਜੀਵ ਦੀ ਇਹ ਦੇਹੀ ਪਸ਼ੂਆਂ ਤੇ ਪਰੇਤਾਂ ਨਾਲੋਂ ਭੀ ਭੈੜੀ (ਸਮਝੋ)।"
            },
            "sahib_singh_ru": {
              "main": "без Имени тело глупца хуже животных и духов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37846,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਨ ਬੂਝੈ ਜਿਨਿ ਏਹ ਸਿਰੀ ॥੩॥",
          "roman": "tisah na būjhē jin eh sirī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ (ਇਸ ਦੀ) ਇਹ ਮਨੁੱਖਾ ਦੇਹੀ ਬਣਾਈ ਉਸ ਨੂੰ ਕਦੇ ਚੇਤੇ ਨਹੀਂ ਕਰਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "он не помнит Того, кто дал ему это тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37847,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਕਰਤਾਰ ਗੋਵਿੰਦ ਗੋਪਾਲ ॥",
          "roman": "suṇ kartār govind gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਵਿਚਾਰੇ ਕੀਹ ਕਰਨ? ਹੇ ਕਰਤਾਰ! ਹੇ ਗੋਬਿੰਦ! ਹੋ ਗੋਪਾਲ!"
            },
            "sahib_singh_ru": {
              "main": "что могут сделать бедные существа? о Творец, Говинд, Гопал!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37848,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਸਦਾ ਕਿਰਪਾਲ ॥",
          "roman": "dīn dayāl sadā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ! ਹੇ ਸਦਾ ਹੀ ਕਿਰਪਾ ਦੇ ਸੋਮੇ!"
            },
            "sahib_singh_ru": {
              "main": "о милосердный к бедным, всегда благой!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37849,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਹਿ ਛਡਾਵਹੁ ਛੁਟਕਹਿ ਬੰਧ ॥",
          "roman": "tumah chhaḍāvah chhuṭkah bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪ ਹੀ ਜੀਵਾਂ ਦੇ ਮਾਇਆ ਦੇ ਬੰਧਨ ਤੋੜੇਂ ਤਾਂ ਹੀ ਟੁੱਟ ਸਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "только Ты освобождаешь от уз майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37850,
          "is_rahao": false,
          "gurmukhi": "ਬਖਸਿ ਮਿਲਾਵਹੁ ਨਾਨਕ ਜਗ ਅੰਧ ॥੪॥੧੨॥੨੩॥",
          "roman": "bakhas milāvah nānak jag andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਰਤਾਰ! (ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ) ਅੰਨ੍ਹੇ ਹੋਏ ਇਸ ਜਗਤ ਨੂੰ ਤੂੰ ਆਪ ਹੀ ਮਿਹਰ ਕਰ ਕੇ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਜੋੜੀ ਰੱਖ ॥੪॥੧੨॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Творец! по милости соедини этот слепой мир с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3312,
      "rahao_verse_id": 37857,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37851,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37852,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਸੰਜੋਗੁ ਬਨਾਈ ਕਾਛਿ ॥",
          "roman": "kar sanjog banāī kāchh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਕੋਈ ਦਰਜ਼ੀ ਕੱਪੜਾ ਮਾਪ ਕਤਰ ਕੇ ਮਨੁੱਖ ਦੇ ਸਰੀਰ ਵਾਸਤੇ ਕਮੀਜ਼ ਆਦਿਕ ਬਣਾਂਦਾ ਹੈ, ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਨੇ ਜਿੰਦ ਤੇ ਸਰੀਰ ਦੇ) ਮਿਲਾਪ (ਦਾ ਅਵਸਰ) ਬਣਾ ਕੇ (ਜਿੰਦ ਵਾਸਤੇ ਇਹ ਸਰੀਰ-ਚੋਲੀ) ਕੱਛ ਕੇ ਬਣਾ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "Подобно тому как портной, отмерив и раскроив ткань, шьёт одежду для тела, так и Бог создал соединение души и тела, и сшил эту телесную оболочку для души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37853,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸੰਗਿ ਰਹਿਓ ਇਆਨਾ ਰਾਚਿ ॥",
          "roman": "tis sang rahiō iānā rāch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਸਰੀਰ-ਚੋਲੀ) ਨਾਲ ਬੇ-ਸਮਝ ਜੀਵ ਪਰਚਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "С этой телесной оболочкой неразумное существо остаётся привязанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37854,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਤਿਪਾਰੈ ਨਿਤ ਸਾਰਿ ਸਮਾਰੈ ॥",
          "roman": "pratipārē nit sār samārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਇਸ ਸਰੀਰ ਨੂੰ ਪਾਲਦਾ ਪੋਸਦਾ ਰਹਿੰਦਾ ਹੈ, ਤੇ ਸਦਾ ਇਸ ਦੀ ਸਾਂਭ-ਸੰਭਾਲ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно питает это тело и всё время заботится о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37855,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤ ਕੀ ਬਾਰ ਊਠਿ ਸਿਧਾਰੈ ॥੧॥",
          "roman": "ant kī bār ūṭh sidhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਤ ਦੇ ਵੇਲੇ ਜੀਵ (ਇਸ ਨੂੰ ਛੱਡ ਕੇ) ਉੱਠ ਤੁਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но в конце человек встаёт и уходит, оставляя его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37856,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਸਭੁ ਝੂਠੁ ਪਰਾਨੀ ॥",
          "roman": "nām binā sabh jhūṭh parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਇਹ ਸਾਰਾ ਅਡੰਬਰ ਨਾਸਵੰਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О человек! Без Имени Бога всё это лишь тленно и ложно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37857,
          "is_rahao": true,
          "gurmukhi": "ਗੋਵਿਦ ਭਜਨ ਬਿਨੁ ਅਵਰ ਸੰਗਿ ਰਾਤੇ ਤੇ ਸਭਿ ਮਾਇਆ ਮੂਠੁ ਪਰਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "govind bhajan bin avar sang rāte te sabh māiā mūṭh parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! ਜੇਹੜੇ ਬੰਦੇ ਪਰਮਾਤਮਾ ਦੇ ਭਜਨ ਤੋਂ ਬਿਨਾ ਹੋਰ ਪਦਾਰਥਾਂ ਨਾਲ ਮਸਤ ਰਹਿੰਦੇ ਹਨ, ਉਹ ਸਾਰੇ ਮਾਇਆ (ਦੇ ਮੋਹ) ਵਿਚ ਠੱਗੇ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О человек! Те, кто, не предаваясь воспеванию Бога, увлечены другими вещами, все обмануты майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37858,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥ ਨਾਇ ਨ ਉਤਰਸਿ ਮੈਲੁ ॥",
          "roman": "tīrath nāe na utars mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਇਹ) ਮੈਲ ਤੀਰਥਾਂ ਉਤੇ ਇਸ਼ਨਾਨ ਕਰ ਕੇ ਨਹੀਂ ਉਤਰੇਗੀ।"
            },
            "sahib_singh_ru": {
              "main": "Эта нечистота привязанности к майе не смоется омовением в святых местах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37859,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਧਰਮ ਸਭਿ ਹਉਮੈ ਫੈਲੁ ॥",
          "roman": "karam dharam sabh haumē phēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ-ਇਸ਼ਨਾਨ ਆਦਿਕ ਇਹ) ਸਾਰੇ (ਮਿਥੇ ਹੋਏ) ਧਾਰਮਿਕ ਕੰਮ ਹਉਮੈ ਦਾ ਖਿਲਾਰਾ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Все эти религиозные действия — лишь проявление эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37860,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕ ਪਚਾਰੈ ਗਤਿ ਨਹੀ ਹੋਇ ॥",
          "roman": "lok pachārē gat nahī hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ-ਇਸ਼ਨਾਨ ਆਦਿਕ ਕਰਮਾਂ ਦੀ ਰਾਹੀਂ ਆਪਣੇ ਧਾਰਮਿਕ ਹੋਣ ਬਾਰੇ) ਲੋਕਾਂ ਦੀ ਤਸੱਲੀ ਕਰਾਇਆਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Угождение людям не приносит духовного возвышения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37861,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਣੇ ਚਲਸਹਿ ਰੋਇ ॥੨॥",
          "roman": "nām bihūṇe chalsahi roi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਸੱਖਣੇ ਸਭ ਜੀਵ (ਇਥੋਂ) ਰੋ ਰੋ ਕੇ ਹੀ ਜਾਣਗੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Лишённые Имени, все уйдут отсюда, плача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37862,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਨਾਮ ਨ ਟੂਟਸਿ ਪਟਲ ॥",
          "roman": "bin har nām na ṭūṭas paṭal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ) ਪੜਦਾ ਨਹੀਂ ਟੁੱਟੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога завеса майи не разрушится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37863,
          "is_rahao": false,
          "gurmukhi": "ਸੋਧੇ ਸਾਸਤ੍ਰ ਸਿਮ੍ਰਿਤਿ ਸਗਲ ॥",
          "roman": "sodhe sāstr simrit sagal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਹੀ ਸ਼ਾਸਤ੍ਰ ਅਤੇ ਸਿਮ੍ਰਿਤੀਆਂ ਵਿਚਾਰਿਆਂ ਭੀ (ਇਹ ਪੜਦਾ ਦੂਰ ਨਹੀਂ ਹੋਵੇਗਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Даже изучив все шастры и смрити, эта завеса не исчезнет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37864,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਨਾਮੁ ਜਪੈ ਜਿਸੁ ਆਪਿ ਜਪਾਏ ॥",
          "roman": "so nām japē jis āp japāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਹੀ ਬੰਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਆਪ ਨਾਮ ਜਪਣ ਲਈ ਪ੍ਰੇਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот повторяет Имя, кого Сам Бог вдохновляет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37865,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਫਲਾ ਸੇ ਸੂਖਿ ਸਮਾਏ ॥੩॥",
          "roman": "sagal phalā se sūkh samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਬੰਦੇ ਨਾਮ ਜਪਦੇ ਹਨ) ਉਹਨਾਂ ਨੂੰ (ਮਨੁੱਖਾ ਜੀਵਨ ਦੇ) ਸਾਰੇ ਫਲ ਪ੍ਰਾਪਤ ਹੁੰਦੇ ਹਨ, ਉਹ ਬੰਦੇ (ਸਦਾ) ਆਨੰਦ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Такие люди обретают все плоды жизни и пребывают в блаженстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37866,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰੇ ਰਾਖਹੁ ਆਪਿ ॥",
          "roman": "rākhanhāre rākho āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੀ ਰੱਖਿਆ ਕਰਨ ਦੇ ਸਮਰੱਥ ਪ੍ਰਭੂ! ਤੂੰ ਆਪ ਹੀ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਅਸਾਂ ਜੀਵਾਂ ਦੀ) ਰੱਖਿਆ ਕਰ ਸਕਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Защитник! Ты Сам можешь защитить нас от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37867,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸੁਖਾ ਪ੍ਰਭ ਤੁਮਰੈ ਹਾਥਿ ॥",
          "roman": "sagal sukhā prabh tumrē hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਸੁਖ ਤੇਰੇ ਆਪਣੇ ਹੱਥ ਵਿਚ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Все блага находятся в Твоих руках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37868,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਲਾਵਹਿ ਤਿਤੁ ਲਾਗਹ ਸੁਆਮੀ ॥",
          "roman": "jit lāvah tit lāgah suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਲਕ-ਪ੍ਰਭੂ! ਤੂੰ ਜਿਸ ਕੰਮ ਵਿਚ (ਸਾਨੂੰ) ਲਾਂਦਾ ਹੈਂ, ਅਸੀਂ ਉਸੇ ਕੰਮ ਵਿਚ ਲੱਗ ਪੈਂਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! В чём Ты нас задействуешь, тем мы и занимаемся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37869,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਹਿਬੁ ਅੰਤਰਜਾਮੀ ॥੪॥੧੩॥੨੪॥",
          "roman": "nānak sāhib antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਮਾਲਕ-ਪ੍ਰਭੂ ਸਭ ਦੇ ਦਿਲਾਂ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ ॥੪॥੧੩॥੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Господь — Знающий сердца всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3313,
      "rahao_verse_id": 37876,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37870,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37871,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੈ ਸੋਈ ਸੁਖੁ ਜਾਨਾ ॥",
          "roman": "jo kichh karē soī sukh jānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ ਉਹ) ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ ਉਸੇ ਨੂੰ ਉਹ ਸੁਖ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто встречает Гуру, считает всё, что делает Бог, благом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37872,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਅਸਮਝੁ ਸਾਧਸੰਗਿ ਪਤੀਆਨਾ ॥",
          "roman": "man asamajh sādhsaṅg patīānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ (ਪਹਿਲਾ) ਅੰਞਾਣ ਮਨ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਗਿੱਝ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его неразумный ум успокаивается в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37873,
          "is_rahao": false,
          "gurmukhi": "ਡੋਲਨ ਤੇ ਚੂਕਾ ਠਹਰਾਇਆ ॥",
          "roman": "ḍolan te chūkā ṭhaharāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਟਿਕਾਇਆ ਹੋਇਆ ਉਸ ਦਾ ਮਨ ਡੋਲਣ ਤੋਂ ਹਟ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его ум перестаёт колебаться и становится устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37874,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਮਾਹਿ ਲੇ ਸਤਿ ਸਮਾਇਆ ॥੧॥",
          "roman": "sat māhi le sat samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦਾ ਨਾਮ) ਲੈ ਕੇ ਉਸ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Истине, он сливается с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37875,
          "is_rahao": true,
          "gurmukhi": "ਦੂਖੁ ਗਇਆ ਸਭੁ ਰੋਗੁ ਗਇਆ ॥",
          "roman": "dūkh giā sabh rog giā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਨੁੱਖ ਦਾ ਸਾਰਾ ਦੁੱਖ ਸਾਰਾ ਰੋਗ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У него исчезают все страдания и болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37876,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਆਗਿਆ ਮਨ ਮਹਿ ਮਾਨੀ ਮਹਾ ਪੁਰਖ ਕਾ ਸੰਗੁ ਭਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "prabh kī āgiā man meh mānī mahā purakh kā sang bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ। ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਉਸ ਨੂੰ ਮਨ ਵਿਚ ਮਿੱਠੀ ਲੱਗਣ ਲੱਗ ਪੈਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он принимает волю Бога как сладкую, получив встречу с Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37877,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਪਵਿਤ੍ਰ ਸਰਬ ਨਿਰਮਲਾ ॥",
          "roman": "sagal pavitr sarab nirmalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ) ਉਸ ਮਨੁੱਖ ਦੇ ਸਾਰੇ ਉੱਦਮ ਪਵਿੱਤਰ ਹੁੰਦੇ ਹਨ ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਨਿਰਮਲ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все его действия становятся чистыми и святыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37878,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਵਰਤਾਏ ਸੋਈ ਭਲਾ ॥",
          "roman": "jo vartāe soī bhalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ, ਉਸ ਮਨੁੱਖ ਨੂੰ ਉਹੀ ਉਹੀ ਕੰਮ ਭਲਾ ਜਾਪਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что делает Бог, он считает благом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37879,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਰਾਖੈ ਸੋਈ ਮੁਕਤਿ ਥਾਨੁ ॥",
          "roman": "jah rākhe soī mukt thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ) ਜਿੱਥੇ ਉਸ ਨੂੰ ਰੱਖਦਾ ਹੈ ਉਹੀ ਉਸ ਦੇ ਵਾਸਤੇ ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਦਾ ਥਾਂ ਹੁੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Где бы ни был поставлен, это становится местом освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37880,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਪਾਏ ਸੋਈ ਨਾਮੁ ॥੨॥",
          "roman": "jo japāe soī nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਤੋਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਦਾ ਜਪਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он повторяет только то Имя, которое даёт ему Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37881,
          "is_rahao": false,
          "gurmukhi": "ਅਠਸਠਿ ਤੀਰਥ ਜਹ ਸਾਧ ਪਗ ਧਰਹਿ ॥",
          "roman": "aṭhasaṭh tīrath jah sādh pag dharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿੱਥੇ ਗੁਰਮੁਖ ਮਨੁੱਖ (ਆਪਣੇ) ਪੈਰ ਧਰਦੇ ਹਨ ਉਹ ਥਾਂ ਅਠਾਹਠ ਤੀਰਥ ਸਮਝੋ,"
            },
            "sahib_singh_ru": {
              "main": "Там, где ступают святые, — все шестьдесят восемь святых мест."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37882,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬੈਕੁੰਠੁ ਜਹ ਨਾਮੁ ਉਚਰਹਿ ॥",
          "roman": "tah bēkunṭh jah nām ucharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਜਿੱਥੇ ਸੰਤ ਜਨ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦੇ ਹਨ ਉਹ ਥਾਂ ਸੱਚਖੰਡ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где произносится Имя, там и есть небесное царство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37883,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਅਨੰਦ ਜਬ ਦਰਸਨੁ ਪਾਈਐ ॥",
          "roman": "sarab anand jab darsan pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰਮੁਖਾਂ ਦਾ ਦਰਸ਼ਨ ਕਰੀਦਾ ਹੈ ਤਦੋਂ ਸਾਰੇ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "При встрече со святыми обретаются все духовные радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37884,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਗੁਣਾ ਨਿਤ ਨਿਤ ਹਰਿ ਗਾਈਐ ॥੩॥",
          "roman": "rām guṇā nit nit har gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ) ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਸਕੀਦੇ ਹਨ, ਸਦਾ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਗਾਈ ਜਾ ਸਕਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В их обществе можно постоянно воспевать качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37885,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਘਟਿ ਘਟਿ ਰਹਿਆ ਬਿਆਪਿ ॥",
          "roman": "āpe ghaṭ ghaṭ rahiā biāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) (ਹੁਣ ਨਾਨਕ ਨੂੰ ਦਿੱਸ ਰਿਹਾ ਹੈ ਕਿ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам присутствует в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37886,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਪੁਰਖ ਪਰਗਟ ਪਰਤਾਪ ॥",
          "roman": "dayāl purakh pargaṭ partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦੇ ਸੋਮੇ ਅਕਾਲ ਪੁਰਖ ਦਾ ਤੇਜ-ਪਰਤਾਪ ਪ੍ਰਤੱਖ (ਹਰ ਥਾਂ ਦਿੱਸ ਰਿਹਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Его сияние проявлено повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37887,
          "is_rahao": false,
          "gurmukhi": "ਕਪਟ ਖੁਲਾਨੇ ਭ੍ਰਮ ਨਾਠੇ ਦੂਰੇ ॥",
          "roman": "kapaṭ khulāne bhram nāṭhe dūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਨ ਦੇ) ਕਿਵਾੜ ਖੁਲ੍ਹ ਗਏ ਹਨ, ਤੇ, ਸਾਰੇ ਭਰਮ ਕਿਤੇ ਦੂਰ ਭੱਜ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Завесы открываются, и все заблуждения исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37888,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਗੁਰ ਭੇਟੇ ਪੂਰੇ ॥੪॥੧੪॥੨੫॥",
          "roman": "nānak kau gur bheṭe pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਨਾਨਕ ਨੂੰ ਪੂਰੇ ਗੁਰੂ ਜੀ ਮਿਲ ਪਏ ਹਨ ॥੪॥੧੪॥੨੫॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак встретил Совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3314,
