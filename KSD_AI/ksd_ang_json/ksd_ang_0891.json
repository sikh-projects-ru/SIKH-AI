{
  "ang": 891,
  "shabads": [
    {
      "shabad_id": 3314,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37897,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸਮਾਧਿ ਧੁਨਿ ਗਹਿਰ ਗੰਭੀਰਾ ॥",
          "roman": "sahaj samādh dhun gahir gambhīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੀ ਅਕਲ ਅਤੇ ਧੀਰਜ ਦਾ ਮਾਲਕ ਹੈ, ਸਦਾ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ, ਪ੍ਰਭੂ ਵਿਚ ਉਸ ਦੀ ਡੂੰਘੀ ਲਗਨ ਬਣੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает в глубокой внутренней сосредоточенности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37898,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਮੁਕਤੁ ਤਾ ਕੇ ਪੂਰੇ ਕਾਮ ॥",
          "roman": "sadā mukat tā ke pūre kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਵਿਕਾਰਾਂ ਤੋਂ ਆਜ਼ਾਦ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Он всегда свободен, и его дела успешны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37899,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਵਸੈ ਹਰਿ ਨਾਮ ॥੨॥",
          "roman": "jā kē ridē vasē har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "У кого в сердце пребывает Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37900,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸੂਖ ਆਨੰਦ ਅਰੋਗ ॥",
          "roman": "sagal sūkh ānand arog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਨੁੱਖ ਨੂੰ ਸਾਰੇ ਸੁਖ ਆਨੰਦ ਪ੍ਰਾਪਤ ਰਹਿੰਦੇ ਹਨ, ਉਹ (ਮਾਨਸਕ) ਰੋਗਾਂ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он обретает все радости и здоровье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37901,
          "is_rahao": false,
          "gurmukhi": "ਸਮਦਰਸੀ ਪੂਰਨ ਨਿਰਜੋਗ ॥",
          "roman": "samdarsī pūran nirjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਉਹ) ਪੂਰੇ ਤੌਰ ਤੇ ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ, ਸਭਨਾਂ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ ਵੇਖਦਾ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Он становится равновидящим и непривязанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37902,
          "is_rahao": false,
          "gurmukhi": "ਆਇ ਨ ਜਾਇ ਡੋਲੈ ਕਤ ਨਾਹੀ ॥",
          "roman": "āe na jāe ḍolē kat nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕਿਤੇ ਭਟਕਦਾ ਨਹੀਂ, ਕਿਤੇ ਡੋਲਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Он не блуждает и не колеблется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37903,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਨਾਮੁ ਬਸੈ ਮਨ ਮਾਹੀ ॥੩॥",
          "roman": "jā kē nām basē man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਹਰਿ-ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "У кого Имя пребывает в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37904,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਗੋੁਪਾਲ ਗੋਵਿੰਦ ॥",
          "roman": "dīn dayāl gopāl govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਗੋਪਾਲ ਗੋਵਿੰਦ ਦਾ ਨਾਮ ਜਪਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Следует повторять Имя Милостивого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37905,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਪੀਐ ਉਤਰੈ ਚਿੰਦ ॥",
          "roman": "gurmukh japīē utarē chind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਜਪਦਾ ਹੈ, ਉਸ ਦਾ) ਚਿੰਤਾ-ਫ਼ਿਕਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда все тревоги уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37906,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਗੁਰਿ ਦੀਆ ਨਾਮੁ ॥",
          "roman": "nānak kau gur dīā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮੈਨੂੰ) ਨਾਨਕ ਨੂੰ ਗੁਰੂ ਨੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਬਖ਼ਸ਼ਿਆ ਹੈ, ਸੰਤ ਜਨਾਂ ਦੀ ਟਹਿਲ (ਦੀ ਦਾਤਿ) ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нанаку Гуру даровал Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37907,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੀ ਟਹਲ ਸੰਤ ਕਾ ਕਾਮੁ ॥੪॥੧੫॥੨੬॥",
          "roman": "santan kī ṭahal sant kā kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ ਹੀ) ਗੁਰੂ ਦਾ (ਦੱਸਿਆ) ਕੰਮ ਹੈ ॥੪॥੧੫॥੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "Служение святым — путь, указанный Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3315,
      "rahao_verse_id": 37914,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37908,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37909,
          "is_rahao": false,
          "gurmukhi": "ਬੀਜ ਮੰਤ੍ਰੁ ਹਰਿ ਕੀਰਤਨੁ ਗਾਉ ॥",
          "roman": "bīj mantr har kīrtan gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ (ਦਾ ਗੀਤ) ਗਾਇਆ ਕਰੋ (ਪਰਮਾਤਮਾ ਨੂੰ ਵੱਸ ਕਰਨ ਦਾ) ਇਹ ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਮੰਤ੍ਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эй брат! Воспевай хвалу Всевышнего — это самый высший мантр для обретения Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37910,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਮਿਲੀ ਨਿਥਾਵੇ ਥਾਉ ॥",
          "roman": "āgē milī nithāve thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੀਰਤਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਪਰਲੋਕ ਵਿਚ ਨਿਆਸਰੇ ਜੀਵ ਨੂੰ ਭੀ ਆਸਰਾ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря киртану даже безопорная душа получает опору в ином мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37911,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਚਰਣੀ ਲਾਗੁ ॥",
          "roman": "gur pūre kī charṇī lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪੂਰੇ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਤੇ ਪਿਆ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Эй брат! Пребывай у стоп совершенного Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37912,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗੁ ॥੧॥",
          "roman": "janam janam kā soeyā jāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਕਈ ਜਨਮਾਂ ਤੋਂ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ) ਨੀਂਦ ਵਿਚ ਸੁੱਤਾ ਹੋਇਆ ਤੂੰ ਜਾਗ ਪਏਂਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и тогда ты пробудишься от сна, в котором пребывал многие рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37913,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਜਾਪੁ ਜਪਲਾ ॥",
          "roman": "har har jāp japlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ) ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦਾ ਜਾਪ ਜਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто повторяет Имя Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37914,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਹਿਰਦੈ ਵਾਸੈ ਭਉਜਲੁ ਪਾਰਿ ਪਰਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur kirpā te hirdē vāsē bhaujāl pār parlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ) ਹਿਰਦੇ ਵਿਚ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਆ ਵੱਸਦਾ ਹੈ, ਉਹ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਗਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце по милости Гуру поселяется Имя, тот переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37915,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਨਿਧਾਨੁ ਧਿਆਇ ਮਨ ਅਟਲ ॥",
          "roman": "nām nidhān dhiāi man atal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਕਦੇ ਨਾਹ ਮੁੱਕਣ ਵਾਲਾ ਖ਼ਜ਼ਾਨਾ ਹੈ, ਇਸ ਨੂੰ ਸਿਮਰਦਾ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Имя Всевышнего — неиссякаемое сокровище, размышляй о нём,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37916,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਛੂਟਹਿ ਮਾਇਆ ਕੇ ਪਟਲ ॥",
          "roman": "tā chhūṭeh māiā ke paṭal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਤੇਰੇ ਮਾਇਆ (ਦੇ ਮੋਹ) ਦੇ ਪੜਦੇ ਪਾਟਣਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "тогда покровы майи разорвутся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37917,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਅੰਮ੍ਰਿਤ ਰਸੁ ਪੀਉ ॥",
          "roman": "gur kā sabad amrit ras pīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਰਸ ਹੈ, ਇਸ ਨੂੰ ਪੀਂਦਾ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Пей амрит-рас Шабда Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37918,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇਰਾ ਹੋਇ ਨਿਰਮਲ ਜੀਉ ॥੨॥",
          "roman": "tā terā hoi nirmal jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਤੇਰੀ ਜਿੰਦ ਪਵਿੱਤ੍ਰ ਹੋਵੇਗੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда твоя душа станет чистой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37919,
          "is_rahao": false,
          "gurmukhi": "ਸੋਧਤ ਸੋਧਤ ਸੋਧਿ ਬੀਚਾਰਾ ॥",
          "roman": "sodhat sodhat sodh bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਅਸਾਂ ਬਹੁਤ ਵਿਚਾਰ ਵਿਚਾਰ ਕੇ ਇਹ ਸਿੱਟਾ ਕੱਢਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Много размышляя, мы пришли к выводу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37920,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਭਗਤਿ ਨਹੀ ਛੁਟਕਾਰਾ ॥",
          "roman": "bin har bhagat nahī chhuṭkārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ) ਖ਼ਲਾਸੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "что без преданности Богу освобождения нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37921,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਹਰਿ ਭਜਨੁ ਸਾਧ ਕੈ ਸੰਗਿ ॥",
          "roman": "so har bhajan sādh kē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਉਹ ਭਗਤੀ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эта преданность обретается в сангате Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37922,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਰਾਪੈ ਹਰਿ ਕੈ ਰੰਗਿ ॥੩॥",
          "roman": "man tan rāpē har kē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਪ੍ਰਾਪਤੀ ਹੁੰਦੀ ਹੈ, ਉਸ ਦਾ) ਮਨ ਅਤੇ ਤਨ ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда тело и ум окрашиваются в любовь к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37923,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਸਿਆਣਪ ਬਹੁ ਚਤੁਰਾਈ ॥",
          "roman": "chhoḍ siāṇap bah chaturāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! (ਆਪਣੀ) ਸਿਆਣਪ ਅਤੇ ਬਹੁਤੀ ਚਤੁਰਾਈ ਛੱਡ ਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Оставь свою мудрость и хитрость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37924,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਬਿਨੁ ਹਰਿ ਨਾਵੈ ਜਾਇ ਨ ਕਾਈ ॥",
          "roman": "man bin har nāvē jāi na kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਜਾਲੇ ਦੇ ਕਾਰਨ ਭੁਇਂ ਵਿਚ ਪਾਣੀ ਜੀਊਰਦਾ ਨਹੀਂ, ਇਸੇ ਤਰ੍ਹਾਂ ਹਉਮੈ ਦੇ ਕਾਰਨ ਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਦਾ ਅਸਰ ਨਹੀਂ ਹੁੰਦਾ), ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਇਹ ਜਾਲਾ ਦੂਰ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога эта паутина не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37925,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਧਾਰੀ ਗੋਵਿਦ ਗੋੁਸਾਈ ॥",
          "roman": "dayā dhārī govid gosāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਧਰਤੀ ਦਾ ਖਸਮ ਪ੍ਰਭੂ ਦਇਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Господь оказывает милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37926,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਨਕ ਟੇਕ ਟਿਕਾਈ ॥੪॥੧੬॥੨੭॥",
          "roman": "har har nānak ṭek ṭikāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ ਲੈਂਦਾ ਹੈ ॥੪॥੧੬॥੨੭॥"
            },
            "sahib_singh_ru": {
              "main": "тот, о Нанак, принимает опору Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3316,
      "rahao_verse_id": 37933,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37927,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37928,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਸੰਗਿ ਰਾਮ ਰੰਗ ਕੇਲ ॥",
          "roman": "sant kē sang rām rang kel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ ਦੀ ਖੇਡ ਖੇਡਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О пандит! Пребывая в сангате, играй в игру любви к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37929,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਜਮ ਸਿਉ ਹੋਇ ਨ ਮੇਲ ॥",
          "roman": "āgē jam siu hoi na mel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਗਾਂਹ ਪਰਲੋਕ ਵਿਚ ਤੈਨੂੰ ਜਮਾਂ ਨਾਲ ਵਾਹ ਨਹੀਂ ਪਏਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда в ином мире ты не встретишься с Ямой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37930,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਬੁਧਿ ਕਾ ਭਇਆ ਬਿਨਾਸ ॥",
          "roman": "ahambudh kā bhaeā binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਇਹ ਉੱਦਮ ਕਰਦਾ ਹੈ ਉਸ ਦੀ) ਹਉਮੈ ਵਾਲੀ ਅਕਲ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Разрушается ум, наполненный эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37931,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਹੋਈ ਸਗਲੀ ਨਾਸ ॥੧॥",
          "roman": "durmat hoī saglī nās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰੋਂ ਖੋਟੀ ਮਤਿ ਸਾਰੀ ਮੁੱਕ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и вся дурная мысль исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37932,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਗੁਣ ਗਾਇ ਪੰਡਿਤ ॥",
          "roman": "rām nām guṇ gāi paṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਜਪਿਆ ਕਰ, ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾਇਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О пандит! Воспевай Имя и качества Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37933,
          "is_rahao": true,
          "gurmukhi": "ਕਰਮ ਕਾਂਡ ਅਹੰਕਾਰੁ ਨ ਕਾਜੈ ਕੁਸਲ ਸੇਤੀ ਘਰਿ ਜਾਹਿ ਪੰਡਿਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karam kāṇḍ ahankār na kājē kusal setī ghar jāh paṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਤੀਰਥ-ਇਸ਼ਨਾਨ ਆਦਿਕ ਮਿਥੇ ਹੋਏ ਧਾਰਮਿਕ ਕੰਮਾਂ ਦੇ ਸਿਲਸਿਲੇ ਦਾ ਅਹੰਕਾਰ ਤੇਰੇ ਕਿਸੇ ਕੰਮ ਨਹੀਂ ਆਵੇਗਾ। (ਇਸ ਤਰ੍ਹਾਂ) ਤੂੰ ਆਨੰਦ ਨਾਲ (ਜੀਵਨ ਬਤੀਤ ਕਰਦਾ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਾਲੇ ਅਸਲ) ਘਰ ਵਿਚ ਜਾ ਪਹੁੰਚੇਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "ритуалы и гордыня не принесут пользы — так ты достигнешь истинного дома."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37934,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਜਸੁ ਨਿਧਿ ਲੀਆ ਲਾਭ ॥",
          "roman": "har kā jas nidh līā lābh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ (ਦਾ) ਖ਼ਜ਼ਾਨਾ ਲੱਭ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто нашёл сокровище хвалы Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37935,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਭਏ ਮਨੋਰਥ ਸਾਭ ॥",
          "roman": "pūran bhae manorath sābh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "все его желания исполнились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37936,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਨਾਠਾ ਸੁਖੁ ਘਰ ਮਹਿ ਆਇਆ ॥",
          "roman": "dukh nāṭhā sukh ghar meh āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ (ਸਾਰਾ) ਦੁੱਖ ਦੂਰ ਹੋ ਗਿਆ ਉਸ ਦੇ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਸੁਖ ਆ ਵੱਸਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Его страдание исчезло, и счастье поселилось в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37937,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਕਮਲੁ ਬਿਗਸਾਇਆ ॥੨॥",
          "roman": "sant prasād kamal bigsāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ-ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਦੇ ਹਿਰਦੇ ਦਾ ਕੌਲ-ਫੁੱਲ ਖਿੜ ਪਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру лотос сердца расцвёл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37938,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਰਤਨੁ ਜਿਨਿ ਪਾਇਆ ਦਾਨੁ ॥",
          "roman": "nām ratan jin pāiā dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਿਤ! ਤੂੰ ਜਜਮਾਨਾਂ ਪਾਸੋਂ ਦਾਨ ਮੰਗਦਾ ਫਿਰਦਾ ਹੈਂ, ਪਰ) ਜਿਸ ਮਨੁੱਖ ਨੇ (ਗੁਰੂ ਪਾਸੋਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਰਤਨ ਦਾਨ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто получил дар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37939,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਹੋਏ ਸਗਲ ਨਿਧਾਨ ॥",
          "roman": "tis jan hoe sagal nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ (ਮਾਨੋ) ਸਾਰੇ ਹੀ ਖ਼ਜ਼ਾਨੇ ਮਿਲ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "обрёл все сокровища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37940,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤੋਖੁ ਆਇਆ ਮਨਿ ਪੂਰਾ ਪਾਇ ॥",
          "roman": "santokh āiā man pūrā pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਪੂਰਨ ਪ੍ਰਭੂ ਨੂੰ ਪ੍ਰਾਪਤ ਕਰ ਕੇ ਉਸ ਦੇ ਅੰਦਰ ਸੰਤੋਖ ਪੈਦਾ ਹੋ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Обретя Бога, он наполнился удовлетворением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37941,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਫਿਰਿ ਮਾਗਨ ਕਾਹੇ ਜਾਇ ॥੩॥",
          "roman": "phir phir māgan kāhe jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ ਉਹ ਮੁੜ ਮੁੜ (ਜਜਮਾਨਾਂ ਪਾਸੋਂ) ਕਿਉਂ ਮੰਗਣ ਜਾਇਗਾ? ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Зачем ему снова идти просить?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37942,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਕਥਾ ਸੁਨਤ ਪਵਿਤ ॥",
          "roman": "har kī kathā sunat pavit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਿਤ!) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀਆਂ ਗੱਲਾਂ ਸੁਣਦਿਆਂ (ਜੀਵਨ) ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слушая хвалу Бога, жизнь становится чистой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37943,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹਵਾ ਬਕਤ ਪਾਈ ਗਤਿ ਮਤਿ ॥",
          "roman": "jihvā bakat pāī gat mat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਨਾਲ ਉਚਾਰਦਿਆਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਅਤੇ (ਸੁਚੱਜੀ) ਅਕਲ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а произнося её, достигается высшее состояние и разум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37944,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਰਵਾਣੁ ਜਿਸੁ ਰਿਦੈ ਵਸਾਈ ॥",
          "roman": "so parvāṇ jis ridē vasāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਗੁਰੂ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ) ਵਸਾ ਦੇਂਦਾ ਹੈ ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ) ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот принят, в чьём сердце она поселяется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37945,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇ ਜਨ ਊਤਮ ਭਾਈ ॥੪॥੧੭॥੨੮॥",
          "roman": "nānak te jan ūtam bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਨ ਵਾਲੇ ਉਹ ਬੰਦੇ ਉੱਚੇ ਜੀਵਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ ॥੪॥੧੭॥੨੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такие люди становятся возвышенными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3317,
      "rahao_verse_id": 37952,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37946,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37947,
          "is_rahao": false,
          "gurmukhi": "ਗਹੁ ਕਰਿ ਪਕਰੀ ਨ ਆਈ ਹਾਥਿ ॥",
          "roman": "gah kar pakrī na āī hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਇਸ ਮਾਇਆ ਨੂੰ) ਬੜੇ ਧਿਆਨ ਨਾਲ ਭੀ ਫੜਿਆ, ਉਸ ਦੇ ਭੀ ਹੱਥ ਵਿਚ ਨਾਹ ਆਈ।"
            },
            "sahib_singh_ru": {
              "main": "Даже схватив майю, её невозможно удержать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37948,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੀਤਿ ਕਰੀ ਚਾਲੀ ਨਹੀ ਸਾਥਿ ॥",
          "roman": "prīt karī chālī nahī sāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ (ਇਸ ਨਾਲ) ਬੜਾ ਪਿਆਰ ਭੀ ਪਾਇਆ, ਉਸ ਦੇ ਨਾਲ ਭੀ ਰਲ ਕੇ ਇਹ ਨਾ ਤੁਰੀ (ਸਾਥ ਨਾਹ ਨਿਬਾਹ ਸਕੀ)।"
            },
            "sahib_singh_ru": {
              "main": "Даже возлюбив её, она не идёт с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37949,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਉ ਤਿਆਗਿ ਦਈ ॥",
          "roman": "kah nānak jau tiāg daī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਦੋਂ ਕਿਸੇ ਮਨੁੱਖ ਨੇ ਇਸ ਨੂੰ (ਮਨੋਂ) ਛੱਡ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: когда человек оставляет её,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37950,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਓਹ ਚਰਣੀ ਆਇ ਪਈ ॥੧॥",
          "roman": "tab oh charṇī āi paī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਇਹ ਆ ਕੇ ਉਸ ਦੀ ਚਰਨੀਂ ਪੈ ਗਈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда она сама приходит к его стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37951,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਸੰਤਹੁ ਨਿਰਮਲ ਬੀਚਾਰ ॥",
          "roman": "suṇ santah nirmal bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜੀਵਨ ਨੂੰ ਪਵਿੱਤਰ ਕਰਨ ਵਾਲੀ ਇਹ ਵਿਚਾਰ ਸੁਣੋ-"
            },
            "sahib_singh_ru": {
              "main": "Слушайте, святые, эту чистую мысль:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37952,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਗਤਿ ਨਹੀ ਕਾਈ ਗੁਰੁ ਪੂਰਾ ਭੇਟਤ ਉਧਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām nām bin gat nahī kāī gur pūrā bheṭat udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਰਤਾ ਭੀ ਨਹੀਂ ਹੁੰਦੀ, (ਪਰ ਨਾਮ ਗੁਰੂ ਪਾਸੋਂ ਮਿਲਦਾ ਹੈ) ਪੂਰਾ ਗੁਰੂ ਮਿਲਿਆਂ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਖ਼ਲਾਸੀ ਹੋ ਕੇ) ਪਾਰ-ਉਤਾਰਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "без Имени Бога нет освобождения; встретив совершенного Гуру, достигается спасение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
