{
  "ang": 892,
  "shabads": [
    {
      "shabad_id": 3317,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37953,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਉਸ ਕਉ ਕੋਈ ਦੇਵੈ ਮਾਨੁ ॥",
          "roman": "jab us kau koī devē mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜਦੋਂ ਕੋਈ ਮਨੁੱਖ ਉਸ (ਮਾਇਆ) ਨੂੰ ਆਦਰ ਦੇਂਦਾ ਹੈ (ਸਾਂਭ ਸਾਂਭ ਕੇ ਰੱਖਣ ਦਾ ਜਤਨ ਕਰਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Когда человек оказывает почёт майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37954,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਆਪਸ ਊਪਰਿ ਰਖੈ ਗੁਮਾਨੁ ॥",
          "roman": "tab āpas ūpar rakhē gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਹ ਆਪਣੇ ਉਤੇ ਬੜਾ ਮਾਣ ਕਰਦੀ ਹੈ (ਰੁੱਸ ਰੁੱਸ ਕੇ ਨੱਸ ਜਾਣ ਦਾ ਜਤਨ ਕਰਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "она возносится в гордыне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37955,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਉਸ ਕਉ ਕੋਈ ਮਨਿ ਪਰਹਰੈ ॥",
          "roman": "jab us kau koī man parharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਕੋਈ ਮਨੁੱਖ ਉਸ ਨੂੰ ਆਪਣੇ ਮਨ ਤੋਂ ਲਾਹ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек отвергает её,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37956,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਓਹ ਸੇਵਕਿ ਸੇਵਾ ਕਰੈ ॥੨॥",
          "roman": "tab oh sevak sevā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਹ ਉਸ ਦੀ ਦਾਸੀ ਬਣ ਕੇ ਸੇਵਾ ਕਰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "она становится его служанкой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37957,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖਿ ਬੇਰਾਵੈ ਅੰਤਿ ਠਗਾਵੈ ॥",
          "roman": "mukh berāvē ant ṭhagāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਉਹ ਮਾਇਆ ਹਰੇਕ ਪ੍ਰਾਣੀ ਨੂੰ) ਮੂੰਹ ਨਾਲ ਪਰਚਾਂਦੀ ਹੈ, ਪਰ ਆਖ਼ਰ ਧੋਖਾ ਦੇ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Она обольщает словами, но в конце обманывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37958,
          "is_rahao": false,
          "gurmukhi": "ਇਕਤੁ ਠਉਰ ਓਹ ਕਹੀ ਨ ਸਮਾਵੈ ॥",
          "roman": "ikat ṭhaur oh kahī na samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਇੱਕ ਥਾਂ ਤੇ ਉਹ ਕਦੇ ਭੀ ਨਹੀਂ ਟਿਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Она никогда не остаётся на одном месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37959,
          "is_rahao": false,
          "gurmukhi": "ਉਨਿ ਮੋਹੇ ਬਹੁਤੇ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "un mohe bahute brahmaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਾਇਆ ਨੇ ਅਨੇਕਾਂ ਬ੍ਰਹਮੰਡਾਂ (ਦੇ ਜੀਵਾਂ) ਨੂੰ ਆਪਣੇ ਮੋਹ ਵਿਚ ਫਸਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Она увлекла множество миров в заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37960,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਜਨੀ ਕੀਨੀ ਖੰਡ ਖੰਡ ॥੩॥",
          "roman": "rām janī kīnī khaṇḍ khaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਸੰਤ ਜਨਾਂ ਨੇ (ਉਸ ਦੇ ਮੋਹ ਨੂੰ) ਟੋਟੇ ਟੋਟੇ ਕਰ ਦਿੱਤਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но святые разрушили её влияние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37961,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਮਾਗੈ ਸੋ ਭੂਖਾ ਰਹੈ ॥",
          "roman": "jo māgē so bhūkhā rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜਿਹੜਾ ਮਨੁੱਖ (ਹਰ ਵੇਲੇ ਮਾਇਆ ਦੀ ਮੰਗ ਹੀ) ਮੰਗਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਨਹੀਂ ਰੱਜਦਾ (ਉਸ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਕਦੇ ਨਹੀਂ ਮੁੱਕਦੀ)।"
            },
            "sahib_singh_ru": {
              "main": "Кто просит майю, остаётся голодным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37962,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਸੰਗਿ ਰਾਚੈ ਸੁ ਕਛੂ ਨ ਲਹੈ ॥",
          "roman": "is sang rācē so kachhū na lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਇਸ ਮਾਇਆ (ਦੇ ਮੋਹ) ਵਿਚ ਹੀ ਮਸਤ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ (ਆਤਮਕ ਜੀਵਨ ਦੇ ਧਨ ਵਿਚੋਂ) ਕੁਝ ਨਹੀਂ ਮਿਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Кто привязан к ней, ничего не получает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37963,
          "is_rahao": false,
          "gurmukhi": "ਇਸਹਿ ਤਿਆਗਿ ਸਤਸੰਗਤਿ ਕਰੈ ॥",
          "roman": "iseh tiāg satsangat karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਮਾਇਆ ਦੇ ਮੋਹ) ਨੂੰ ਛੱਡ ਕੇ ਜਿਹੜਾ ਮਨੁੱਖ ਭਲਿਆਂ ਦੀ ਸੰਗਤਿ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто оставляет её и ищет сангат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37964,
          "is_rahao": false,
          "gurmukhi": "ਵਡਭਾਗੀ ਨਾਨਕ ਓਹੁ ਤਰੈ ॥੪॥੧੮॥੨੯॥",
          "roman": "vaḍbhāgī nānak oh tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹੇ ਨਾਨਕ! ਉਹ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਠਿਲ੍ਹਾਂ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੪॥੧੮॥੨੯॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот по великой удаче переправляется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3318,
      "rahao_verse_id": 37971,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37965,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37966,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮ ਰਾਮੁ ਸਰਬ ਮਹਿ ਪੇਖੁ ॥",
          "roman": "ātam rām sarab meh pekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਨੂੰ ਸਭ ਜੀਵਾਂ ਵਿਚ (ਵੱਸਦਾ) ਵੇਖ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Видь всепроникающего Бога во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37967,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹਿਆ ਪ੍ਰਭ ਏਕੁ ॥",
          "roman": "pūran pūr rahiā prabh ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਪੂਰਨ ਤੌਰ ਤੇ ਸਭ ਵਿਚ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Один лишь Бог полностью присутствует во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37968,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨੁ ਅਮੋਲੁ ਰਿਦੇ ਮਹਿ ਜਾਨੁ ॥",
          "roman": "ratan amol ride meh jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਹਰਿ-ਨਾਮ ਇਕ ਐਸਾ ਰਤਨ ਹੈ ਜਿਸ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ, ਉਹ ਰਤਨ ਤੇਰੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸ ਰਿਹਾ ਹੈ, ਉਸ ਨਾਲ ਸਾਂਝ ਪਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — бесценный драгоценный камень, он пребывает в твоём сердце — познай его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37969,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਵਸਤੁ ਤੂ ਆਪਿ ਪਛਾਨੁ ॥੧॥",
          "roman": "apnī vastu tū āp pachhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੇ ਸਾਰੇ ਪਦਾਰਥ ਬਿਗਾਨੇ ਹੋ ਜਾਂਦੇ ਹਨ, ਇਹ ਹਰਿ-ਨਾਮ ਹੀ) ਤੇਰੀ ਆਪਣੀ ਚੀਜ਼ ਹੈ, ਤੂੰ ਆਪ ਇਸ ਚੀਜ਼ ਨੂੰ ਪਛਾਣ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Это твоя собственная сущность — распознай её сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37970,
          "is_rahao": true,
          "gurmukhi": "ਪੀ ਅੰਮ੍ਰਿਤੁ ਸੰਤਨ ਪਰਸਾਦਿ ॥",
          "roman": "pī amrit santan parsād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਟਿਕਿਆ ਰਹੁ, ਤੇ) ਸੰਤ-ਜਨਾਂ ਦੀ ਮਿਹਰ ਨਾਲ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਪੀਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Оставайся в обществе святых и пей нектар Имени по их милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37971,
          "is_rahao": true,
          "gurmukhi": "ਵਡੇ ਭਾਗ ਹੋਵਹਿ ਤਉ ਪਾਈਐ ਬਿਨੁ ਜਿਹਵਾ ਕਿਆ ਜਾਣੈ ਸੁਆਦੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "vadē bhāg hovahi tau pāīē bin jihvā kiā jāṇē suād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਅੰਮ੍ਰਿਤ ਤਦੋਂ ਹੀ ਮਿਲਦਾ ਹੈ ਜੇ (ਮਨੁੱਖ ਦੇ) ਵੱਡੇ ਭਾਗ ਹੋਣ। ਇਸ ਨਾਮ ਨੂੰ ਜੀਭ ਨਾਲ ਜਪਣ ਤੋਂ ਬਿਨਾ ਕੋਈ (ਇਸ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਦਾ) ਕੀਹ ਸੁਆਦ ਜਾਣ ਸਕਦਾ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот нектар обретается лишь по великой удаче; без повторения языком как узнать его вкус?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37972,
          "is_rahao": false,
          "gurmukhi": "ਅਠ ਦਸ ਬੇਦ ਸੁਨੇ ਕਹ ਡੋਰਾ ॥",
          "roman": "aṭh das bēd sunē kah ḍorā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਹੇ ਭਾਈ!) ਬੋਲਾ ਮਨੁੱਖ ਅਠਾਰਾਂ ਪੁਰਾਣ ਤੇ ਚਾਰ ਵੇਦ ਕਿਵੇਂ ਸੁਣ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Как глухой услышит восемнадцать пуран и четыре веды?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37973,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਪ੍ਰਗਾਸ ਨ ਦਿਸੈ ਅੰਧੇਰਾ ॥",
          "roman": "koṭ pragās na disē andherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹੇ ਮਨੁੱਖ ਨੂੰ ਕ੍ਰੋੜਾਂ ਸੂਰਜਾਂ ਦਾ ਭੀ ਚਾਨਣ ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Слепому не видно света даже от миллионов солнц."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37974,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਪਰੀਤਿ ਘਾਸ ਸੰਗਿ ਰਚੈ ॥",
          "roman": "pasū parīt ghās sang rachē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਸ਼ੂ ਦਾ ਪਿਆਰ ਘਾਹ ਨਾਲ ਹੀ ਹੁੰਦਾ ਹੈ, ਪਸ਼ੂ ਘਾਹ ਨਾਲ ਹੀ ਖ਼ੁਸ਼ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Животное привязано к траве и довольствуется ею."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37975,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਨਹੀ ਬੁਝਾਵੈ ਸੋ ਕਿਤੁ ਬਿਧਿ ਬੁਝੈ ॥੨॥",
          "roman": "jis nahī bujhāvē so kit bidh bujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਪੈ ਕੇ ਬੋਲਾ ਅੰਨ੍ਹਾ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ, ਪਸ਼ੂ ਸਮਾਨ ਹੋ ਜਾਂਦਾ ਹੈ, ਇਸ ਨੂੰ ਆਪਣੇ ਆਪ ਹਰਿ-ਨਾਮ ਅੰਮ੍ਰਿਤ ਦੀ ਸੂਝ ਨਹੀਂ ਪੈ ਸਕਦੀ, ਤੇ) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪ ਸਮਝ ਨਾਹ ਬਖ਼ਸ਼ੇ, ਉਹ ਕਿਸੇ ਤਰ੍ਹਾਂ ਭੀ ਸਮਝ ਨਹੀਂ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Того, кому Бог не даёт понимания, никто не сможет просветить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37976,
          "is_rahao": false,
          "gurmukhi": "ਜਾਨਣਹਾਰੁ ਰਹਿਆ ਪ੍ਰਭੁ ਜਾਨਿ ॥",
          "roman": "jāṇanhār rahiā prabh jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਪਰਮਾਤਮਾ ਸਦਾ ਹਰੇਕ ਦੇ ਦਿਲ ਦੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог знает сердца всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37977,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਭਗਤਨ ਸੰਗਾਨਿ ॥",
          "roman": "ot pot bhagtan sangān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣੇ ਭਗਤਾਂ ਨਾਲ ਇਉਂ ਮਿਲਿਆ ਰਹਿੰਦਾ ਹੈ ਜਿਵੇਂ ਤਾਣਾ ਪੇਟਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он соединён со своими преданными, как нити ткани."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37978,
          "is_rahao": false,
          "gurmukhi": "ਬਿਗਸਿ ਬਿਗਸਿ ਅਪੁਨਾ ਪ੍ਰਭੁ ਗਾਵਹਿ ॥",
          "roman": "bigas bigas apnā prabh gāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਖ਼ੁਸ਼ ਹੋ ਹੋ ਕੇ ਆਪਣੇ ਪ੍ਰਭੂ (ਦੇ ਗੁਣਾਂ) ਨੂੰ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто с радостью воспевают своего Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37979,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਜਮ ਨੇੜਿ ਨ ਆਵਹਿ ॥੩॥੧੯॥੩੦॥",
          "roman": "nānak tin jam neṛ na āvahi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਮ-ਦੂਤ ਉਹਨਾਂ ਦੇ ਨੇੜੇ ਨਹੀਂ ਆਉਂਦੇ ॥੩॥੧੯॥੩੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! к ним не приближаются посланники смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3319,
      "rahao_verse_id": 37986,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37980,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37981,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨੋ ਨਾਮੁ ਕੀਓ ਪਵਿਤੁ ॥",
          "roman": "dīno nām kīo pavit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਦੇ ਦਿੱਤਾ, (ਉਸ ਦਾ ਜੀਵਨ) ਪਵਿੱਤਰ ਬਣਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому Гуру даровал Имя Бога, жизнь стала чистой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37982,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਧਨੁ ਰਾਸਿ ਨਿਰਾਸ ਇਹ ਬਿਤੁ ॥",
          "roman": "har dhan rās nirās ih bit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੂੰ ਗੁਰੂ ਨੇ) ਹਰਿ-ਨਾਮ ਧਨ ਸਰਮਾਇਆ (ਬਖ਼ਸ਼ਿਆ, ਦੁਨੀਆ ਵਾਲਾ) ਇਹ ਧਨ (ਵੇਖ ਕੇ), ਉਹ (ਇਸ ਵਲੋਂ) ਉਪਰਾਮ-ਚਿੱਤ ਹੀ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кому даровано богатство Имени, тот становится безразличным к мирскому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37983,
          "is_rahao": false,
          "gurmukhi": "ਕਾਟੀ ਬੰਧਿ ਹਰਿ ਸੇਵਾ ਲਾਏ ॥",
          "roman": "kāṭī bandh har sevā lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਜੀਵਨ-ਰਾਹ ਵਿਚੋਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ) ਰੁਕਾਵਟ ਕੱਟ ਦਿੱਤੀ, ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਵਿਚ ਜੋੜ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру устранил преграды и направил его к служению Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37984,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਭਗਤਿ ਰਾਮ ਗੁਣ ਗਾਏ ॥੧॥",
          "roman": "har har bhagat rām guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਸਦਾ) ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ, (ਸਦਾ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно предан Богу и поёт Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37985,
          "is_rahao": true,
          "gurmukhi": "ਬਾਜੇ ਅਨਹਦ ਬਾਜਾ ॥",
          "roman": "bājē anhad bājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਹਨਾਂ ਦੇ ਅੰਦਰ (ਇਉਂ ਖਿੜਾਉ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ, ਮਾਨੋ, ਉਹਨਾਂ ਦੇ ਅੰਦਰ) ਇੱਕ-ਰਸ ਵਾਜੇ ਵੱਜ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри него звучит непрерывная небесная музыка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37986,
          "is_rahao": true,
          "gurmukhi": "ਰਸਕਿ ਰਸਕਿ ਗੁਣ ਗਾਵਹਿ ਹਰਿ ਜਨ ਅਪਨੈ ਗੁਰਦੇਵਿ ਨਿਵਾਜਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rasak rasak guṇ gāvahi har jan apnē gurdev nivājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਉਤੇ) ਆਪਣੇ (ਪਿਆਰੇ) ਗੁਰਦੇਵ ਨੇ ਮਿਹਰ ਕੀਤੀ, ਹਰੀ ਦੇ ਉਹ ਸੇਵਕ ਬੜੇ ਆਨੰਦ ਨਾਲ ਹਰੀ ਦੇ ਗੁਣ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Те, кого благословил Гуру, с радостью воспевают Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37987,
          "is_rahao": false,
          "gurmukhi": "ਆਇ ਬਨਿਓ ਪੂਰਬਲਾ ਭਾਗੁ ॥",
          "roman": "āe baniō pūrablā bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਉਸ ਦਾ ਪਹਿਲੇ ਜਨਮਾਂ ਦਾ ਚੰਗਾ ਭਾਗ ਮਿਲਣ ਦਾ ਸਬੱਬ ਆ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру пробуждается накопленная удача прошлых жизней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37988,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗੁ ॥",
          "roman": "janam janam kā soiā jāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚੋਂ) ਕਈ ਜਨਮਾਂ ਦਾ ਸੁੱਤਾ ਹੋਇਆ ਜਾਗ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Спящий многие жизни пробуждается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37989,
          "is_rahao": false,
          "gurmukhi": "ਗਈ ਗਿਲਾਨਿ ਸਾਧ ਕੈ ਸੰਗਿ ॥",
          "roman": "gaī gilān sādh kē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਿਹਾਂ ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ ਦੂਜਿਆਂ ਵਾਸਤੇ) ਨਫ਼ਰਤ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых исчезает ненависть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37990,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਰਾਤੋ ਹਰਿ ਕੈ ਰੰਗਿ ॥੨॥",
          "roman": "man tan rāto har kē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਦਾ ਮਨ ਤੇ ਤਨ ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ум и тело окрашиваются любовью к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37991,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖੇ ਰਾਖਨਹਾਰ ਦਇਆਲ ॥",
          "roman": "rākhe rākhanhār dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਦੁੱਖਾਂ ਤੋਂ) ਬਚਾਣ ਦੀ ਸਮਰੱਥਾ ਵਾਲੇ ਨੇ ਦਇਆ ਦੇ ਸੋਮੇ ਨੇ ਪਰਮਾਤਮਾ ਨੇ ਉਸ ਦੀ ਰੱਖਿਆ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Милосердный Защитник сохранил его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37992,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕਿਛੁ ਸੇਵਾ ਨਾ ਕਿਛੁ ਘਾਲ ॥",
          "roman": "nā kich sevā nā kich ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਕੀਤੀ ਕੋਈ ਸੇਵਾ ਨਹੀਂ ਵੇਖੀ ਕੋਈ ਮਿਹਨਤ ਨਹੀਂ ਵੇਖੀ।"
            },
            "sahib_singh_ru": {
              "main": "Он не учитывает ни служение, ни усилия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37993,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਕੀਨੀ ਦਇਆ ॥",
          "roman": "kar kirpā prabh kīnī dayā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ) ਪ੍ਰਭੂ ਨੇ ਕਿਰਪਾ ਕੀਤੀ, ਦਇਆ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Бог проявил милость и сострадание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37994,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਦੁਖ ਮਹਿ ਕਾਢਿ ਲਇਆ ॥੩॥",
          "roman": "būḍat dukh meh kāḍh laeā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਦੁੱਖਾਂ ਵਿਚ ਡੁੱਬਦੇ ਨੂੰ (ਪ੍ਰਭੂ ਨੇ ਬਾਹੋਂ ਫੜ ਕੇ) ਬਚਾ ਲਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он спас утопающего в страданиях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37995,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਣਿ ਉਪਜਿਓ ਮਨ ਮਹਿ ਚਾਉ ॥",
          "roman": "sun sun upjiō man meh chāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ) ਮੁੜ ਮੁੜ ਸੁਣ ਕੇ (ਜਿਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ (ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਨ ਦਾ) ਚਾਉ ਪੈਦਾ ਹੋ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Слушая вновь и вновь, в сердце возникло желание восхвалять."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37996,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਕੇ ਗੁਣ ਗਾਉ ॥",
          "roman": "āṭh pahar har ke guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਣ ਲੱਗ ਪਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Он поёт качества Бога постоянно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37997,
          "is_rahao": false,
          "gurmukhi": "ਗਾਵਤ ਗਾਵਤ ਪਰਮ ਗਤਿ ਪਾਈ ॥",
          "roman": "gāvat gāvat param gat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਣ) ਗਾਂਦਿਆਂ ਗਾਂਦਿਆਂ ਉਸ ਨੇ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਹਾਸਲ ਕਰ ਲਈ।"
            },
            "sahib_singh_ru": {
              "main": "Воспевая, он достиг высшего духовного состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37998,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਲਿਵ ਲਾਈ ॥੪॥੨੦॥੩੧॥",
          "roman": "gur prasād nānak liv lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਨੇ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਸੁਰਤ ਜੋੜ ਲਈ ॥੪॥੨੦॥੩੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! по милости Гуру он сосредоточился на Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3320,
      "rahao_verse_id": 38005,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37999,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38000,
          "is_rahao": false,
          "gurmukhi": "ਕਉਡੀ ਬਦਲੈ ਤਿਆਗੈ ਰਤਨੁ ॥",
          "roman": "kauṛī badlē tiāgē ratan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਅਮੋਲਕ ਰਤਨ ਹੈ, ਇਸ ਦੇ ਟਾਕਰੇ ਤੇ ਮਾਇਆ ਕੌਡੀ ਦੇ ਤੁੱਲ ਹੈ; ਪਰ ਸਾਕਤ ਮਨੁੱਖ) ਕੌਡੀ ਦੀ ਖ਼ਾਤਰ (ਕੀਮਤੀ) ਰਤਨ ਨੂੰ ਛੱਡ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ради мелочи он оставляет драгоценный камень Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38001,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਜਾਇ ਤਾਹੂ ਕਾ ਜਤਨੁ ॥",
          "roman": "chhoḍ jāe tāhū kā jatan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਦੀ ਹੀ ਪ੍ਰਾਪਤੀ ਦਾ ਜਤਨ ਕਰਦਾ ਹੈ ਜੋ ਸਾਥ ਛੱਡ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Стремится к тому, что всё равно оставит его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38002,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੰਚੈ ਜੋ ਹੋਛੀ ਬਾਤ ॥",
          "roman": "so sanchē jo hochhī bāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ (ਮਾਇਆ) ਨੂੰ ਹੀ ਇਕੱਠੀ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ ਜਿਸ ਦੀ ਪੁੱਛ-ਪ੍ਰਤੀਤ ਥੋੜ੍ਹੀ ਕੁ ਹੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Собирает лишь то, что не имеет ценности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38003,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿਆ ਟੇਢਉ ਜਾਤ ॥੧॥",
          "roman": "māiā mohiā ṭeḍhau jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਹੋਇਆ (ਸਾਕਤ) ਆਕੜ ਆਕੜ ਕੇ ਤੁਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ослеплённый майей, он идёт с гордыней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38004,
          "is_rahao": true,
          "gurmukhi": "ਅਭਾਗੇ ਤੈ ਲਾਜ ਨਾਹੀ ॥",
          "roman": "abhāgē tē lāj nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਬਦ-ਨਸੀਬ (ਸਾਕਤ)! ਤੈਨੂੰ (ਕਦੇ ਇਹ) ਸ਼ਰਮ ਨਹੀਂ ਆਉਂਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О несчастный! у тебя нет стыда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38005,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖ ਸਾਗਰ ਪੂਰਨ ਪਰਮੇਸਰੁ ਹਰਿ ਨ ਚੇਤਿਓ ਮਨ ਮਾਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukh sāgar pūran parmesar har na chetiō man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਜਿਹੜਾ ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਸਮੁੰਦਰ ਹੈ ਉਸ ਨੂੰ ਤੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਚੇਤੇ ਨਹੀਂ ਕਰਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Ты не вспоминаешь в сердце Бога — океан блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38006,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਕਉਰਾ ਬਿਖਿਆ ਮੀਠੀ ॥",
          "roman": "amrit kauṛā bikhia mīṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਇਸ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਕੌੜਾ ਲੱਗਦਾ ਹੈ ਤੇ ਮਾਇਆ ਮਿੱਠੀ ਲੱਗਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нектар Имени кажется горьким, а майя — сладкой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38007,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਕੀ ਬਿਧਿ ਨੈਨਹੁ ਡੀਠੀ ॥",
          "roman": "sākat kī bidh nēnh ḍīṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਬ ਨਾਲੋਂ ਟੁੱਟੇ ਮਨੁੱਖ ਦੀ (ਇਹ ਭੈੜੀ) ਹਾਲਤ (ਅਸਾਂ) ਅੱਖੀਂ ਵੇਖੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такое состояние отделённого от Бога человека мы видели своими глазами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38008,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜਿ ਕਪਟਿ ਅਹੰਕਾਰਿ ਰੀਝਾਨਾ ॥",
          "roman": "kūṛ kapat ahankār rījhānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਕਤ ਸਦਾ) ਨਾਸਵੰਤ ਪਦਾਰਥ ਵਿਚ, ਠੱਗੀ (ਕਰਨ) ਵਿਚ ਅਤੇ ਅਹੰਕਾਰ ਵਿਚ ਖ਼ੁਸ਼ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он доволен ложью, обманом и гордыней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
