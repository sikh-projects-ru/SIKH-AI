{
  "ang": 894,
  "shabads": [
    {
      "shabad_id": 3323,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38066,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਮਾਧਿ ਗੁਫਾ ਤਹ ਆਸਨੁ ॥",
          "roman": "sunn samādh gufā tah āsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਉਹ ਖ਼ਜ਼ਾਨਾ ਆ ਵੱਸਦਾ ਹੈ) ਉਥੇ ਐਸੀ ਸਮਾਧੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ ਜਿਸ ਵਿਚ ਕੋਈ ਮਾਇਕ ਫੁਰਨਾ ਨਹੀਂ ਉੱਠਦਾ, (ਪਹਾੜਾਂ ਦੀਆਂ ਕੰਦ੍ਰਾਂ ਦੇ ਥਾਂ ਉਸ ਹਿਰਦੇ-) ਗੁਫ਼ਾ ਵਿਚ ਮਨੁੱਖ ਦੀ ਸੁਰਤੀ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в таком сердце пребывает самадхи без мирских мыслей, и внимание человека устойчиво пребывает в этой внутренней пещере,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38067,
          "is_rahao": false,
          "gurmukhi": "ਕੇਵਲ ਬ੍ਰਹਮ ਪੂਰਨ ਤਹ ਬਾਸਨੁ ॥",
          "roman": "keval brahm pūran tah bāsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਸਿਰਫ਼ ਪੂਰਨ ਪਰਮਾਤਮਾ ਦਾ ਨਿਵਾਸ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "там обитает только совершенный Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38068,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਸੰਗਿ ਪ੍ਰਭੁ ਗੋਸਟਿ ਕਰਤ ॥",
          "roman": "bhagat sang prabh gosṭ karat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਭਗਤ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਖ਼ਜ਼ਾਨਾ ਪਰਗਟ ਹੋ ਪੈਂਦਾ ਹੈ ਉਸ) ਭਗਤ ਨਾਲ ਪ੍ਰਭੂ ਮਿਲਾਪ ਬਣਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "с таким преданным Бог устанавливает близкое общение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38069,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਹਰਖ ਨ ਸੋਗ ਨ ਜਨਮ ਨ ਮਰਤ ॥੩॥",
          "roman": "tah harakh na sog na janam na marat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਹਿਰਦੇ ਵਿਚ ਖ਼ੁਸ਼ੀ ਗ਼ਮੀ ਜਨਮ-ਮਰਨ (ਦੇ ਗੇੜ ਦੇ ਡਰ) ਦਾ ਕੋਈ ਅਸਰ ਨਹੀਂ ਹੁੰਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в этом сердце нет ни радости, ни печали, ни страха рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38070,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਆਪਿ ਦਿਵਾਇਆ ॥",
          "roman": "kar kirpā jis āp divāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਆਪ ਕਿਰਪਾ ਕਰ ਕੇ ਇਹ ਧਨ ਦਿਵਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кому Сам Бог по милости дарует это богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38071,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਤਿਨਿ ਹਰਿ ਧਨੁ ਪਾਇਆ ॥",
          "roman": "sādh sang tin har dhan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਰਫ਼) ਉਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਉਹ ਨਾਮ-ਧਨ ਲੱਭਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот в обществе святых обретает это богатство Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38072,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਪੁਰਖ ਨਾਨਕ ਅਰਦਾਸਿ ॥",
          "roman": "dayāl purakh nānak ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਇਆ ਦੇ ਸੋਮੇ ਅਕਾਲ ਪੁਰਖ! (ਤੇਰੇ ਸੇਵਕ) ਨਾਨਕ ਦੀ ਭੀ ਇਹੀ ਅਰਜ਼ੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Милосердный Господь! такова молитва Нанака,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38073,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮੇਰੀ ਵਰਤਣਿ ਹਰਿ ਮੇਰੀ ਰਾਸਿ ॥੪॥੨੪॥੩੫॥",
          "roman": "har merī vartan har merī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਤੇਰਾ ਨਾਮ ਮੇਰਾ ਸਰਮਾਇਆ ਬਣਿਆ ਰਹੇ, ਤੇਰਾ ਨਾਮ ਮੇਰੀ ਹਰ ਵੇਲੇ ਦੀ ਵਰਤਣ ਵਾਲੀ ਸ਼ੈ ਬਣੀ ਰਹੇ ॥੪॥੨੪॥੩੫॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Твоё Имя было моим капиталом и всегдашним средством жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3324,
      "rahao_verse_id": 38080,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38074,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38075,
          "is_rahao": false,
          "gurmukhi": "ਮਹਿਮਾ ਨ ਜਾਨਹਿ ਬੇਦ ॥",
          "roman": "mahimā na jāneh bēd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਕੇਡਾ ਵੱਡਾ ਹੈ-ਇਹ ਗੱਲ (ਚਾਰੇ) ਵੇਦ (ਭੀ) ਨਹੀਂ ਜਾਣਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Насколько велик Бог — этого не знают даже четыре Веды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38076,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮੇ ਨਹੀ ਜਾਨਹਿ ਭੇਦ ॥",
          "roman": "brahme nahī jāneh bhēd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਬ੍ਰਹਮਾ ਭੀ (ਉਸ ਦੇ) ਦਿਲ ਦੀ ਗੱਲ ਨਹੀਂ ਜਾਣਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Даже многочисленные Брахмы не знают сокровенной сути Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38077,
          "is_rahao": false,
          "gurmukhi": "ਅਵਤਾਰ ਨ ਜਾਨਹਿ ਅੰਤੁ ॥",
          "roman": "avtār na jāneh ant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਅਵਤਾਰ ਭੀ ਉਸ (ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ) ਦਾ ਅੰਤ ਨਹੀਂ ਜਾਣਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Все аватары не знают предела Его качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38078,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮੇਸਰੁ ਪਾਰਬ੍ਰਹਮ ਬੇਅੰਤੁ ॥੧॥",
          "roman": "parmesar pārbrahm bēant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਾਰਬ੍ਰਹਮ ਪਰਮੇਸਰ ਬੇਅੰਤ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Парабрахм, Верховный Господь — безграничен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38079,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੀ ਗਤਿ ਆਪਿ ਜਾਨੈ ॥",
          "roman": "apnī gat āp jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਕਿਹੋ ਜਿਹਾ ਹੈ-ਇਹ ਗੱਲ ਉਹ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каков Он — это знает только Он Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38080,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਸੁਣਿ ਅਵਰ ਵਖਾਨੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "suṇ suṇ avar vakhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ) ਹੋਰਨਾਂ ਪਾਸੋਂ ਸੁਣ ਸੁਣ ਕੇ ਹੀ (ਪਰਮਾਤਮਾ ਬਾਰੇ) ਜ਼ਿਕਰ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Живое существо лишь пересказывает, слушая от других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38081,
          "is_rahao": false,
          "gurmukhi": "ਸੰਕਰਾ ਨਹੀ ਜਾਨਹਿ ਭੇਵ ॥",
          "roman": "saṅkrā nahī jāneh bhēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਅਨੇਕਾਂ ਸ਼ਿਵ ਜੀ ਪਰਮਾਤਮਾ ਦੇ ਦਿਲ ਦੀ ਗੱਲ ਨਹੀਂ ਜਾਣਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Даже многочисленные Шивы не знают сокровенной сути Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38082,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਹਾਰੇ ਦੇਵ ॥",
          "roman": "khojat hāre dēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਦੇਵਤੇ ਉਸ ਦੀ ਖੋਜ ਕਰਦੇ ਕਰਦੇ ਥੱਕ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "многие боги устали, разыскивая Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38083,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵੀਆ ਨਹੀ ਜਾਨੈ ਮਰਮ ॥",
          "roman": "dēvīā nahī jānē maram",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੇਵੀਆਂ ਵਿਚੋਂ ਭੀ ਕੋਈ ਉਸ ਪ੍ਰਭੂ ਦਾ ਭੇਦ ਨਹੀਂ ਜਾਣਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Даже среди богинь никто не знает Его тайны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38084,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਊਪਰਿ ਅਲਖ ਪਾਰਬ੍ਰਹਮ ॥੨॥",
          "roman": "sabh ūpar alakh pārbrahm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਸਭਨਾਂ ਤੋਂ ਵੱਡਾ ਹੈ, ਉਸ ਦੇ ਸਹੀ ਸਰੂਪ ਦਾ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог выше всех, и Его истинную сущность невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38085,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੈ ਰੰਗਿ ਕਰਤਾ ਕੇਲ ॥",
          "roman": "apnē raṅg kartā kēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਆਪਣੀ ਮੌਜ ਵਿਚ (ਜਗਤ ਦੇ ਸਾਰੇ) ਕੌਤਕ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог в Своей радости совершает все игры мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38086,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬਿਛੋਰੈ ਆਪੇ ਮੇਲ ॥",
          "roman": "āp bichhorē āpe mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ (ਜੀਵਾਂ ਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਤੋਂ) ਵਿਛੋੜਦਾ ਹੈ, ਆਪ ਹੀ ਮਿਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам разлучает и Сам соединяет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38087,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਭਰਮੇ ਇਕਿ ਭਗਤੀ ਲਾਏ ॥",
          "roman": "ik bharme ik bhagtī lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜੀਵਾਂ ਨੂੰ ਉਸ ਨੇ ਭਟਕਣਾ ਵਿਚ ਪਾਇਆ ਹੋਇਆ ਹੈ, ਤੇ ਅਨੇਕਾਂ ਜੀਵਾਂ ਨੂੰ ਆਪਣੀ ਭਗਤੀ ਵਿਚ ਜੋੜਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Многих Он погружает в заблуждение, а многих соединяет с преданностью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38088,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਕੀਆ ਆਪਿ ਜਣਾਏ ॥੩॥",
          "roman": "apṇā kīā āp jaṇāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਜਗਤ ਉਸ ਦਾ) ਆਪਣਾ ਹੀ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈ, (ਇਸ ਨੂੰ ਉਹ) ਆਪ ਹੀ ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Этот мир создан Им Самим, и Сам Он дарует понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38089,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੀ ਸੁਣਿ ਸਾਚੀ ਸਾਖੀ ॥",
          "roman": "santan kī suṇ sāchī sākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸੰਤ-ਜਨਾਂ ਬਾਰੇ ਇਹ ਸੱਚੀ ਗੱਲ ਸੁਣ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Услышь эту истинную речь о святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38090,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬੋਲਹਿ ਜੋ ਪੇਖਹਿ ਆਖੀ ॥",
          "roman": "so bolah jo pēkhah ākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨ ਉਹ ਕੁਝ ਆਖਦੇ ਹਨ ਜੋ ਉਹ ਆਪਣੀਆਂ ਅੱਖਾਂ ਨਾਲ ਵੇਖਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Святые говорят то, что сами видят своими глазами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38091,
          "is_rahao": false,
          "gurmukhi": "ਨਹੀ ਲੇਪੁ ਤਿਸੁ ਪੁੰਨਿ ਨ ਪਾਪਿ ॥",
          "roman": "nahī lēp tis punn na pāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਤ ਜਨ ਆਖਦੇ ਹਨ ਕਿ) ਉਸ ਪਰਮਾਤਮਾ ਉਤੇ ਨਾਹ ਕਿਸੇ ਪੁੰਨ ਨੇ ਨਾਹ ਕਿਸੇ ਪਾਪ ਨੇ (ਕਦੇ ਆਪਣਾ) ਪ੍ਰਭਾਵ ਪਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ни заслуга, ни грех не оказывают на Него влияния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38092,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਾ ਪ੍ਰਭੁ ਆਪੇ ਆਪਿ ॥੪॥੨੫॥੩੬॥",
          "roman": "nānak kā prabh āpe āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਨਕ ਦਾ ਪਰਮਾਤਮਾ (ਆਪਣੇ ਵਰਗਾ) ਆਪ ਹੀ ਆਪ ਹੈ ॥੪॥੨੫॥੩੬॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог Нанака Сам по Себе и подобен лишь Самому Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3325,
      "rahao_verse_id": 38099,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38093,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38094,
          "is_rahao": false,
          "gurmukhi": "ਕਿਛਹੂ ਕਾਜੁ ਨ ਕੀਓ ਜਾਨਿ ॥",
          "roman": "kichhū kāj na kīo jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਕੋਈ ਭੀ (ਚੰਗਾ) ਕੰਮ ਮਿਥ ਕੇ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я не совершаю ни одного доброго дела осознанно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38095,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਤਿ ਮਤਿ ਨਾਹੀ ਕਿਛੁ ਗਿਆਨਿ ॥",
          "roman": "surat mat nāhī kichh giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਿਆਨ-ਚਰਚਾ ਵਿਚ ਭੀ ਮੇਰੀ ਸੁਰਤ ਮੇਰੀ ਮਤਿ ਨਹੀਂ ਟਿਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Даже в рассуждениях о знании мой ум и разум не удерживаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38096,
          "is_rahao": false,
          "gurmukhi": "ਜਾਪ ਤਾਪ ਸੀਲ ਨਹੀ ਧਰਮ ॥",
          "roman": "jāp tāp sīl nahī dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਪਾਂ ਤਪਾਂ ਸੀਲ-ਧਰਮ ਨੂੰ ਭੀ ਮੈਂ ਨਹੀਂ ਜਾਣਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я не знаю ни повторения, ни аскезы, ни праведности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38097,
          "is_rahao": false,
          "gurmukhi": "ਕਿਛੂ ਨ ਜਾਨਉ ਕੈਸਾ ਕਰਮ ॥੧॥",
          "roman": "kichhū na jānao kēsā karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਕੋਈ ਸਮਝ ਨਹੀਂ ਕਿ ਕਰਮ-ਕਾਂਡ ਕਿਹੋ ਜਿਹੇ ਹੁੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Я не понимаю, как совершаются ритуальные действия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38098,
          "is_rahao": true,
          "gurmukhi": "ਠਾਕੁਰ ਪ੍ਰੀਤਮ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "thākur prītam prabh mērē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰੀਤਮ ਪ੍ਰਭੂ! ਹੇ ਮੇਰੇ ਠਾਕੁਰ!"
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный Господь, о мой Владыка!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38099,
          "is_rahao": true,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਦੂਜਾ ਅਵਰੁ ਨ ਕੋਈ ਭੂਲਹ ਚੂਕਹ ਪ੍ਰਭ ਤੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tujh bin dūjā avar na koī bhūlah chūkah prabh tērē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਅਸੀਂ ਭੁੱਲਾਂ ਕਰਦੇ ਹਾਂ, ਜੇ ਅਸੀਂ (ਜੀਵਨ-ਰਾਹ ਤੋਂ) ਖੁੰਝਦੇ ਹਾਂ, ਤਾਂ ਭੀ ਹੇ ਪ੍ਰਭੂ! ਅਸੀਂ ਤੇਰੇ ਹੀ ਹਾਂ, ਤੈਥੋਂ ਬਿਨਾ ਸਾਡਾ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если мы ошибаемся или сбиваемся с пути, всё равно, о Господь, мы Твои — кроме Тебя у нас никого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38100,
          "is_rahao": false,
          "gurmukhi": "ਰਿਧਿ ਨ ਬੁਧਿ ਨ ਸਿਧਿ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "ridh na budh na sidh pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! ਕਰਾਮਾਤੀ ਤਾਕਤਾਂ ਦੀ ਸੂਝ-ਬੂਝ ਤੇ ਪ੍ਰਕਾਸ਼ ਮੇਰੇ ਅੰਦਰ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Во мне нет понимания чудесных сил и их света."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38101,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੈ ਬਿਆਧਿ ਕੇ ਗਾਵ ਮਹਿ ਬਾਸੁ ॥",
          "roman": "bikhē biādh kē gāv meh bās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਕਾਰਾਂ ਤੇ ਰੋਗਾਂ ਦੇ ਇਸ ਸਰੀਰ-ਪਿੰਡ ਵਿਚ ਮੇਰਾ ਵਸੇਬਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я живу в теле, наполненном пороками и болезнями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38102,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰ ਮੇਰੇ ਪ੍ਰਭ ਏਕ ॥",
          "roman": "karanhār mērē prabh ēk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਸਿਰਜਣਹਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "О мой Творец!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38103,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਤੇਰੇ ਕੀ ਮਨ ਮਹਿ ਟੇਕ ॥੨॥",
          "roman": "nām tērē kī man meh ṭēk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਮਨ ਵਿਚ ਸਿਰਫ਼ ਤੇਰੇ ਨਾਮ ਦਾ ਸਹਾਰਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "В моём уме опора только на Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38104,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਣਿ ਜੀਵਉ ਮਨਿ ਇਹੁ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "suṇ suṇ jīvao man ih bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! (ਤੇਰਾ ਨਾਮ) ਸੁਣ ਸੁਣ ਕੇ ਹੀ ਮੈਂ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹਾਂ। ਮੇਰੇ ਮਨ ਵਿਚ (ਸਿਰਫ਼) ਇਹ ਧਰਵਾਸ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Слушая Твоё Имя, я обретаю духовную жизнь; в уме лишь это утешение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38105,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਖੰਡਨ ਪ੍ਰਭ ਤੇਰੋ ਨਾਮੁ ॥",
          "roman": "pāp khaṇḍan prabh tērō nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਤੇਰਾ ਨਾਮ ਪਾਪਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что Твоё Имя уничтожает грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38106,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਅਗਨਤੁ ਜੀਅ ਕਾ ਦਾਤਾ ॥",
          "roman": "tū agnat jīā kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ! ਤੇਰੀਆਂ ਤਾਕਤਾਂ ਗਿਣੀਆਂ ਨਹੀਂ ਜਾ ਸਕਦੀਆਂ, ਤੂੰ ਹੀ ਜਿੰਦ-ਦੇਣ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои силы неисчислимы, Ты даёшь жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38107,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਜਣਾਵਹਿ ਤਿਨਿ ਤੂ ਜਾਤਾ ॥੩॥",
          "roman": "jisah jaṇāveh tin tū jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਤੂੰ ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈਂ, ਉਸ ਨੇ ਹੀ ਤੇਰੇ ਨਾਲ ਜਾਣ ਪਛਾਣ ਪਾਈ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Кому Ты даруешь понимание, тот и познаёт Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38108,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਉਪਾਇਓ ਤਿਸੁ ਤੇਰੀ ਆਸ ॥",
          "roman": "jo upāio tis tērī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਜੀਵ ਨੂੰ ਤੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ, ਉਸ ਨੂੰ ਤੇਰੀ (ਸਹਾਇਤਾ ਦੀ) ਹੀ ਆਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Каждое созданное Тобой существо надеется только на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38109,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਅਰਾਧਹਿ ਪ੍ਰਭ ਗੁਣਤਾਸ ॥",
          "roman": "sagal ārādhah prabh guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਜੀਵ ਤੇਰਾ ਹੀ ਆਰਾਧਨ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О сокровищница добродетелей! Все существа поклоняются Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38110,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤੇਰੈ ਕੁਰਬਾਣੁ ॥",
          "roman": "nānak dās tērāi kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਦਾਸ ਨਾਨਕ ਤੈਥੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Твой слуга Нанак жертвует собой ради Тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38111,
          "is_rahao": false,
          "gurmukhi": "ਬੇਅੰਤ ਸਾਹਿਬੁ ਮੇਰਾ ਮਿਹਰਵਾਣੁ ॥੪॥੨੬॥੩੭॥",
          "roman": "bēant sāhib mērā mehrvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਆਖਦਾ ਹੈ-) ਤੂੰ ਮੇਰਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਬੇਅੰਤ ਹੈਂ, ਤੂੰ ਸਦਾ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈਂ ॥੪॥੨੬॥੩੭॥"
            },
            "sahib_singh_ru": {
              "main": "и говорит: Ты мой Владыка, Ты безграничен и милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3326,
      "rahao_verse_id": 38118,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38112,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38113,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਦਇਆਲ ॥",
          "roman": "rākhanhār dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਸਭ ਜੀਵਾਂ ਦੀ ਰੱਖਿਆ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈ, ਦਇਆ ਦਾ ਸੋਮਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Бог способен защищать всех и является источником милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38114,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਭਵ ਖੰਡੇ ਨਿਮਖ ਖਿਆਲ ॥",
          "roman": "koṭ bhav khaṇḍe nimakh khiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਅੱਖ ਫਰਕਣ ਜਿਤਨੇ ਸਮੇ ਵਾਸਤੇ ਭੀ ਉਸ ਦਾ ਧਿਆਨ ਧਰੀਏ, ਤਾਂ ਕ੍ਰੋੜਾਂ ਜਨਮ ਦੇ ਗੇੜ ਕੱਟੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Если хотя бы на мгновение сосредоточиться на Нём, уничтожаются миллионы рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38115,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਅਰਾਧਹਿ ਜੰਤ ॥",
          "roman": "sagal ārādhah jant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵ ਉਸੇ ਦਾ ਆਰਾਧਨ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все существа поклоняются Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38116,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੀਐ ਪ੍ਰਭ ਗੁਰ ਮਿਲਿ ਮੰਤ ॥੧॥",
          "roman": "milīai prabh gur mil mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ, ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਲੈ ਕੇ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਸਕੀਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Встретив Гуру и приняв его наставление, можно встретить Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38117,
          "is_rahao": true,
          "gurmukhi": "ਜੀਅਨ ਕੋ ਦਾਤਾ ਮੇਰਾ ਪ੍ਰਭੁ ॥",
          "roman": "jīan ko dātā mērā prabh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਪ੍ਰਭੂ ਸਭ ਜੀਆਂ ਨੂੰ ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Мой Господь — дающий всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38118,
          "is_rahao": true,
          "gurmukhi": "ਪੂਰਨ ਪਰਮੇਸੁਰ ਸੁਆਮੀ ਘਟਿ ਘਟਿ ਰਾਤਾ ਮੇਰਾ ਪ੍ਰਭੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pūran parmesur suāmī ghaṭ ghaṭ rātā mērā prabh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮੇਰਾ ਮਾਲਕ ਪਰਮੇਸਰ ਪ੍ਰਭੂ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ, ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਰਮਿਆ ਹੋਇਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Мой Господь, совершенный Владыка, пребывает во всём и в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38119,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਗਹੀ ਮਨ ਓਟ ॥",
          "roman": "tā kī gahī man oṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲੈ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Тот, кто принял опору в Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38120,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਤੇ ਹੋਈ ਛੋਟ ॥",
          "roman": "bandhan tē hoī chhoṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਬੰਧਨਾਂ ਤੋਂ ਉਸ ਦੀ ਖ਼ਲਾਸੀ ਹੋ ਗਈ।"
            },
            "sahib_singh_ru": {
              "main": "освобождается от уз привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38121,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਜਪਿ ਪਰਮਾਨੰਦ ॥",
          "roman": "hirdē jap parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਤੋਂ ਉੱਚੇ ਸੁਖ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਨੂੰ ਹਿਰਦੇ ਵਿਚ ਜਪ ਕੇ-"
            },
            "sahib_singh_ru": {
              "main": "Повторяя в сердце Господа — источник высшего блаженства —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38122,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਾਹਿ ਭਏ ਅਨੰਦ ॥੨॥",
          "roman": "man māhi bhae anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਖ਼ੁਸ਼ੀਆਂ ਹੀ ਖ਼ੁਸ਼ੀਆਂ ਬਣ ਜਾਂਦੀਆਂ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "в уме возникают радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38123,
          "is_rahao": false,
          "gurmukhi": "ਤਾਰਣ ਤਰਣ ਹਰਿ ਸਰਣ ॥",
          "roman": "tāraṇ taraṇ har saraṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾਣ ਲਈ ਜਹਾਜ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Прибежище Бога — это корабль для переправы через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38124,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਰੂਪ ਹਰਿ ਚਰਣ ॥",
          "roman": "jīvan rūp har charaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਦੀ ਓਟ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Опора на стопы Бога даёт духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
