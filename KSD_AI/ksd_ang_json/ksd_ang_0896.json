{
  "ang": 896,
  "shabads": [
    {
      "shabad_id": 3330,
      "rahao_verse_id": 38194,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38188,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38189,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੀ ਤਿਸ ਕੀ ਕਰਿ ਮਾਨੁ ॥",
          "roman": "jis kī tis kī kar mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਦਿੱਤਾ ਹੋਇਆ (ਇਹ ਸਰੀਰ ਆਦਿਕ) ਹੈ, ਉਸੇ ਦਾ ਹੀ ਮੰਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Считай принадлежащим тому Господу, кому это дано."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38190,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਲਾਹਿ ਗੁਮਾਨੁ ॥",
          "roman": "āpan lāh gumān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸਰੀਰ ਆਦਿਕ ਮੇਰਾ ਹੈ ਮੇਰਾ ਹੈ) ਆਪਣਾ (ਇਹ ਅਹੰਕਾਰ ਦੂਰ ਕਰ)।"
            },
            "sahib_singh_ru": {
              "main": "Убери своё высокомерие «это моё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38191,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਤੂ ਤਿਸ ਕਾ ਸਭੁ ਕੋਇ ॥",
          "roman": "jis kā tū tis kā sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਜੀਵ ਉਸੇ ਪ੍ਰਭੂ ਦਾ ਬਣਾਇਆ ਹੋਇਆ ਹੈ ਜਿਸ ਦਾ ਤੂੰ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Все существа созданы тем Господом, которым создан и ты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38192,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਅਰਾਧਿ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੧॥",
          "roman": "tiseh arādh sadā sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਸਦਾ ਆਤਮਕ ਸੁਖ ਮਿਲਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Поминая Его, всегда обретается духовное счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38193,
          "is_rahao": true,
          "gurmukhi": "ਕਾਹੇ ਭ੍ਰਮਿ ਭ੍ਰਮਹਿ ਬਿਗਾਨੇ ॥",
          "roman": "kāhe bhram bhrameh bigāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ ਤੋਂ ਵਿਛੁੜੇ ਹੋਏ ਜੀਵ! ਕਿਉਂ (ਅਪਣੱਤ ਦੇ) ਭੁਲੇਖੇ ਵਿਚ ਪੈ ਕੇ ਭਟਕ ਰਿਹਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О отделённый от Бога! Почему блуждаешь в заблуждении?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38194,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕਿਛੁ ਕਾਮਿ ਨ ਆਵੈ ਮੇਰਾ ਮੇਰਾ ਕਰਿ ਬਹੁਤੁ ਪਛੁਤਾਨੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām binā kichh kām na āvē merā merā kar bahut pachhutāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ (ਹੋਰ ਕੋਈ ਸ਼ੈ ਕਿਸੇ ਦੇ) ਕੰਮ ਨਹੀਂ ਆਉਂਦੀ। (ਇਹ) ਮੇਰਾ (ਸਰੀਰ ਹੈ, ਇਹ) ਮੇਰਾ (ਧਨ ਹੈ)-ਇਉਂ ਆਖ ਆਖ ਕੇ (ਅਨੇਕਾਂ ਹੀ ਜੀਵ) ਬਹੁਤ ਪਛੁਤਾਂਦੇ ਗਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога ничто не приносит пользы; говоря «моё», многие потом сильно раскаиваются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38195,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਕਰੈ ਸੋਈ ਮਾਨਿ ਲੇਹੁ ॥",
          "roman": "jo jo kare soī mān leh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ ਉਸੇ ਨੂੰ ਠੀਕ ਮੰਨਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Принимай всё, что делает Бог, как правильное."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38196,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਮਾਨੇ ਰਲਿ ਹੋਵਹਿ ਖੇਹ ॥",
          "roman": "bin māne ral hovah kheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰਜ਼ਾ ਨੂੰ) ਮੰਨਣ ਤੋਂ ਬਿਨਾ (ਮਿੱਟੀ ਵਿਚ) ਮਿਲ ਕੇ ਮਿੱਟੀ ਹੋ ਜਾਏਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Не принимая Его воли, растворишься в прахе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38197,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਭਾਣਾ ਲਾਗੈ ਮੀਠਾ ॥",
          "roman": "tis kā bhāṇā lāgē mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਕਿਸੇ ਬੰਦੇ ਨੂੰ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਮਿੱਠੀ ਲੱਗਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому сладка Божья воля,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38198,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਵਿਰਲੇ ਮਨਿ ਵੂਠਾ ॥੨॥",
          "roman": "gur prasād virle man vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਆਪ ਆ ਵੱਸਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру Бог поселяется в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38199,
          "is_rahao": false,
          "gurmukhi": "ਵੇਪਰਵਾਹੁ ਅਗੋਚਰੁ ਆਪਿ ॥",
          "roman": "veparvāh agochar āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ ਪਰਮਾਤਮਾ ਨੂੰ ਕਿਸੇ ਦੀ ਮੁਥਾਜੀ ਨਹੀਂ, ਜੀਵ ਦੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਜਿਸ ਤਕ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Бог независим и недостижим чувствами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38200,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਮਨ ਤਾ ਕਉ ਜਾਪਿ ॥",
          "roman": "āṭh pahar man tā kau jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਅੱਠੇ ਪਹਿਰ ਉਸ ਨੂੰ ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Повторяй Его Имя во все часы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38201,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਚਿਤਿ ਆਏ ਬਿਨਸਹਿ ਦੁਖਾ ॥",
          "roman": "jis chit āe binseh dukhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਪਰਮਾਤਮਾ (ਤੇਰੇ) ਚਿੱਤ ਵਿਚ ਆ ਵੱਸੇ, ਤਾਂ ਤੇਰੇ ਸਾਰੇ ਦੁੱਖ ਨਾਸ ਹੋ ਜਾਣਗੇ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Он пребывает в сердце, исчезают все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38202,
          "is_rahao": false,
          "gurmukhi": "ਹਲਤਿ ਪਲਤਿ ਤੇਰਾ ਊਜਲ ਮੁਖਾ ॥੩॥",
          "roman": "halat palat terā ūjal mukhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਵਿਚ ਅਤੇ ਪਰਲੋਕ ਵਿਚ ਤੇਰਾ ਮੂੰਹ ਉਜਲਾ ਰਹੇਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И в этом мире, и в будущем твоё лицо будет светлым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38203,
          "is_rahao": false,
          "gurmukhi": "ਕਉਨ ਕਉਨ ਉਧਰੇ ਗੁਨ ਗਾਇ ॥",
          "roman": "kaun kaun udhare gun gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਗਾ ਕੇ ਕੌਣ ਕੌਣ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Сколько людей переправились, воспевая Его качества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38204,
          "is_rahao": false,
          "gurmukhi": "ਗਨਣੁ ਨ ਜਾਈ ਕੀਮ ਨ ਪਾਇ ॥",
          "roman": "gaṇan na jāī kīm na pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਗੱਲ ਦਾ ਲੇਖਾ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ। ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਣ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪੈ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "это невозможно сосчитать, и цена этому не может быть определена."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38205,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਲੋਹ ਸਾਧਸੰਗਿ ਤਰੈ ॥",
          "roman": "būdat loh sādhsaṅg tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲੋਹੇ ਵਰਗਾ ਕਠੋਰ-ਚਿੱਤ ਬੰਦਾ ਭੀ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Даже твёрдое сердце, как железо, в обществе святых переправляется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38206,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸਹਿ ਪਰਾਪਤਿ ਕਰੈ ॥੪॥੩੧॥੪੨॥",
          "roman": "nānak jiseh parāpat karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਹੇ ਨਾਨਕ! (ਗੁਣ ਗਾਣ ਦਾ ਉੱਦਮ ਉਹੀ ਮਨੁੱਖ) ਕਰਦਾ ਹੈ ਜਿਸ ਨੂੰ ਧੁਰੋਂ ਇਹ ਦਾਤ ਪ੍ਰਾਪਤ ਹੋਵੇ ॥੪॥੩੧॥੪੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но, говорит Нанак, только тот делает это, кому дана такая милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3331,
      "rahao_verse_id": 38213,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38207,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38208,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਾਹਿ ਜਾਪਿ ਭਗਵੰਤੁ ॥",
          "roman": "man māh jāp bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! -ਆਪਣੇ ਮਨ ਵਿਚ ਭਗਵਾਨ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ-"
            },
            "sahib_singh_ru": {
              "main": "О брат! Повторяй Имя Бога в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38209,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਇਹੁ ਦੀਨੋ ਮੰਤੁ ॥",
          "roman": "gur pūrē ih dīno mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਇਹ ਉਪਦੇਸ਼ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому совершенный Гуру дал это наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38210,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਸਗਲ ਭੈ ਤ੍ਰਾਸ ॥",
          "roman": "miṭe sagal bhē trās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਸਾਰੇ ਡਰ ਸਹਿਮ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "исчезают все страхи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38211,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਈ ਆਸ ॥੧॥",
          "roman": "pūran hoī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਦੀ ਹਰੇਕ ਆਸ ਪੂਰੀ ਹੋ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и исполняются все желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38212,
          "is_rahao": true,
          "gurmukhi": "ਸਫਲ ਸੇਵਾ ਗੁਰਦੇਵਾ ॥",
          "roman": "safal sevā gurdevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਭ ਤੋਂ ਵੱਡੇ ਦੇਵਤੇ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ-ਸੇਵਾ (ਜ਼ਰੂਰ) ਫਲ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служение Богу, высшему Господу, обязательно приносит плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38213,
          "is_rahao": true,
          "gurmukhi": "ਕੀਮਤਿ ਕਿਛੁ ਕਹਣੁ ਨ ਜਾਈ ਸਾਚੇ ਸਚੁ ਅਲਖ ਅਭੇਵਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kīmat kichh kahan na jāī sāche sach alakh abhevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ। ਉਸ ਸਦਾ-ਥਿਰ ਅਲੱਖ ਤੇ ਅਭੇਵ ਪ੍ਰਭੂ ਦਾ ਰਤਾ ਭਰ ਭੀ ਮੁੱਲ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Невозможно описать даже малую цену этого вечного, непостижимого и неисследимого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38214,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਆਪਿ ॥",
          "roman": "karan karāvan āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਜਿਹੜਾ ਪ੍ਰਭੂ ਆਪ ਸਭ ਕੁਝ ਕਰਨ-ਜੋਗਾ ਤੇ ਹੋਰਨਾਂ ਪਾਸੋਂ ਕਰਾ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Бог сам совершает всё и побуждает других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38215,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਉ ਸਦਾ ਮਨ ਜਾਪਿ ॥ ਤਿਸ ਕੀ ਸੇਵਾ ਕਰਿ ਨੀਤ ॥",
          "roman": "tis kau sadā man jāp tis kī sevā kar nīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਦਾ ਸਿਮਰਿਆ ਕਰ। ਹੇ ਮਿੱਤਰ! ਉਸ ਪ੍ਰਭੂ ਦੀ ਸਦਾ ਸੇਵਾ-ਭਗਤੀ ਕਰਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Всегда помни Его и постоянно служи Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38216,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸਹਜੁ ਸੁਖੁ ਪਾਵਹਿ ਮੀਤ ॥੨॥",
          "roman": "sach sahaj sukh pāveh mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਅਟੱਲ ਸੁਖ ਮਾਣੇਂਗਾ, ਤੂੰ ਆਤਮਕ ਅਡੋਲਤਾ ਹਾਸਲ ਕਰ ਲਏਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ты обретёшь устойчивое счастье и духовное равновесие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38217,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬੁ ਮੇਰਾ ਅਤਿ ਭਾਰਾ ॥",
          "roman": "sāhib merā at bhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਬਹੁਤ ਗੰਭੀਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Мой Господь величественен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38218,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਥਾਪਿ ਉਥਾਪਨਹਾਰਾ ॥",
          "roman": "khin meh thāp uthāpanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਖਿਨ ਵਿਚ ਪੈਦਾ ਕਰ ਕੇ ਨਾਸ ਭੀ ਕਰ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он может в мгновение создать и разрушить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38219,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "tis bin avar na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ (ਰੱਖਿਆ ਕਰ ਸਕਣ ਵਾਲਾ) ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Него нет другого защитника."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38220,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਾ ਰਾਖਾ ਸੋਈ ॥੩॥",
          "roman": "jan kā rākhā soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦਾ ਆਪ ਹੀ ਰਾਖਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он сам хранитель своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38221,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਰਦਾਸਿ ਸੁਣੀਜੈ ॥",
          "roman": "kar kirpā ardās suṇījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਕਰ ਕੇ ਮੇਰੀ ਅਰਜ਼ੋਈ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "Смилуйся и услышь мою молитву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38222,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੇ ਸੇਵਕ ਕਉ ਦਰਸਨੁ ਦੀਜੈ ॥",
          "roman": "apne sevak kau darsan dījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-ਹੇ ਪ੍ਰਭੂ!) ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਦਰਸ਼ਨ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "даруй своему слуге Твоё видение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38223,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾਪੀ ਜਪੁ ਜਾਪੁ ॥",
          "roman": "nānak jāpī jap jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਸਦਾ ਹੀ ਉਸ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਦਾ ਜਾਪ ਜਪਦਾ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак всегда повторяет Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38224,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਜਾ ਕਾ ਪਰਤਾਪੁ ॥੪॥੩੨॥੪੩॥",
          "roman": "sabh te ūch jā kā partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਤੇਜ-ਬਲ ਸਭਨਾਂ ਤੋਂ ਉੱਚਾ ਹੈ ॥੪॥੩੨॥੪੩॥"
            },
            "sahib_singh_ru": {
              "main": "чьё величие выше всего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3332,
      "rahao_verse_id": 38231,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38225,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38226,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥਾ ਭਰਵਾਸਾ ਲੋਕ ॥",
          "roman": "birthā bharvāsā lok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਦੁਨੀਆ ਦੀ ਮਦਦ ਦੀ ਆਸ ਰੱਖਣੀ ਵਿਅਰਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Надежда на мирскую помощь тщетна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38227,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਪ੍ਰਭ ਤੇਰੀ ਟੇਕ ॥",
          "roman": "ṭhākur prabh terī ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਠਾਕੁਰ! ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! (ਮੈਨੂੰ ਤਾਂ) ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — моя опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38228,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਛੂਟੀ ਸਭ ਆਸ ॥",
          "roman": "avar chhūṭī sabh ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਸ ਮਨੁੱਖ ਦੀ ਦੁਨੀਆ ਤੋਂ ਕਿਸੇ ਮਦਦ ਦੀ) ਹਰੇਕ ਆਸ ਮੁੱਕ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У такого человека исчезают все надежды на мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38229,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਠਾਕੁਰ ਭੇਟੇ ਗੁਣਤਾਸ ॥੧॥",
          "roman": "achint ṭhākur bheṭe guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਚਿੰਤਾ-ਰਹਿਤ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он встречает беззаботного Господа — сокровище добродетелей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38230,
          "is_rahao": true,
          "gurmukhi": "ਏਕੋ ਨਾਮੁ ਧਿਆਇ ਮਨ ਮੇਰੇ ॥",
          "roman": "eko nām dhiāe man mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Медитируй только на Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38231,
          "is_rahao": true,
          "gurmukhi": "ਕਾਰਜੁ ਤੇਰਾ ਹੋਵੈ ਪੂਰਾ ਹਰਿ ਹਰਿ ਹਰਿ ਗੁਣ ਗਾਇ ਮਨ ਮੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kārāj terā hovē pūrā har har har guṇ gāe man mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ। ਤੇਰਾ (ਸਿਮਰਨ ਕਰਨ ਵਾਲਾ ਇਹ) ਕੰਮ ਜ਼ਰੂਰ ਸਿਰੇ ਚੜ੍ਹੇਗਾ (ਭਾਵ, ਜ਼ਰੂਰ ਫਲ ਦੇਵੇਗਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Бога, твоя цель обязательно исполнится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38232,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਹੀ ਕਾਰਨ ਕਰਨ ॥",
          "roman": "tum hī kāran karan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਸ ਜਗਤ-ਰਚਨਾ ਦਾ ਬਣਾਣ ਵਾਲਾ ਤੂੰ ਹੀ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — создатель этого мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38233,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਰਿ ਸਰਨ ॥",
          "roman": "charan kamal har saran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਤਾਂ ਸਦਾ) ਤੇਰੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦੀ ਸਰਨ ਵਿਚ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я пребываю в прибежище Твоих прекрасных стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38234,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਹਰਿ ਓਹੀ ਧਿਆਇਆ ॥",
          "roman": "man tan har ohī dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣੇ ਮਨ ਵਿਚ ਹਿਰਦੇ ਵਿਚ ਸਿਰਫ਼ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਹੀ ਸਿਮਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто всем сердцем помнит только Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38235,
          "is_rahao": false,
          "gurmukhi": "ਆਨੰਦ ਹਰਿ ਰੂਪ ਦਿਖਾਇਆ ॥੨॥",
          "roman": "ānand har rūp dikhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੇ) ਉਸ ਨੂੰ ਆਨੰਦ-ਰੂਪ ਪ੍ਰਭੂ ਦਾ ਦਰਸ਼ਨ ਕਰਾ ਦਿੱਤਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "видит Бога как воплощение блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38236,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਹੀ ਕੀ ਓਟ ਸਦੀਵ ॥",
          "roman": "tis hī kī oṭ sadīv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਸਦਾ ਹੀ ਉਸੇ ਪ੍ਰਭੂ ਦਾ ਹੀ ਆਸਰਾ ਲਈ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Всегда держись только Его опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38237,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਕੀਨੇ ਹੈ ਜੀਵ ॥",
          "roman": "jā ke kīne hē jīv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ ਇਹ ਸਾਰੇ ਜੀਵ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Он создал всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38238,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਹਰਿ ਕਰਤ ਨਿਧਾਨ ॥",
          "roman": "simrat har karat nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ (ਸਾਰੇ) ਖ਼ਜ਼ਾਨੇ (ਮਿਲ ਜਾਂਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Помня Бога, обретаются все сокровища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38239,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਨਿਦਾਨ ॥੩॥",
          "roman": "rākhanhār nidān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! (ਜਦੋਂ ਹੋਰ ਸਾਰੇ ਸਹਾਰੇ ਮੁੱਕ ਜਾਣ, ਤਾਂ) ਅੰਤ ਨੂੰ ਪਰਮਾਤਮਾ ਹੀ ਰੱਖਿਆ ਕਰ ਸਕਣ ਵਾਲਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В конце только Бог остаётся защитником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38240,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕੀ ਰੇਣ ਹੋਵੀਜੈ ॥",
          "roman": "sarab kī reṇ hovījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਸਭਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Стань пылью у ног всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38241,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਮਿਟਾਇ ਮਿਲੀਜੈ ॥",
          "roman": "āp miṭāe milījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਅੰਦਰੋਂ) ਅਹੰਕਾਰ ਦੂਰ ਕਰ ਕੇ ਹੀ ਪਰਮਾਤਮਾ ਨੂੰ ਮਿਲ ਸਕੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только уничтожив эго, можно соединиться с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38242,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਧਿਆਈਐ ਨਾਮੁ ॥",
          "roman": "andin dhiāīe nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹਰ ਵੇਲੇ ਸਿਮਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда нужно помнить Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38243,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਨਾਨਕ ਇਹੁ ਕਾਮੁ ॥੪॥੩੩॥੪੪॥",
          "roman": "safal nānak ih kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਸਿਮਰਨ ਕਰਨ ਦਾ) ਇਹ ਕੰਮ ਜ਼ਰੂਰ ਫਲ ਦੇਂਦਾ ਹੈ ॥੪॥੩੩॥੪੪॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: это дело обязательно приносит плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3333,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38244,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38245,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਨ ਕਰਨ ਕਰੀਮ ॥",
          "roman": "kāran karan karīm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਗਤ ਦੇ ਮੂਲ! ਹੇ ਬਖ਼ਸ਼ਸ਼ ਕਰਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О источник мира! О милостивый!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38246,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਪ੍ਰਤਿਪਾਲ ਰਹੀਮ ॥",
          "roman": "sarab pratipāl rahīm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਜੀਵਾਂ ਨੂੰ ਪਾਲਣ ਵਾਲੇ! ਹੇ (ਸਭਨਾਂ ਉਤੇ) ਰਹਿਮ ਕਰਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О кормилец всех! О милосердный!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38247,
          "is_rahao": false,
          "gurmukhi": "ਅਲਹ ਅਲਖ ਅਪਾਰ ॥",
          "roman": "alah alakh apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੱਲਾਹ! ਹੇ ਅਲੱਖ! ਹੇ ਅਪਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "О Аллах! О непостижимый! О бесконечный!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38248,
          "is_rahao": false,
          "gurmukhi": "ਖੁਦਿ ਖੁਦਾਇ ਵਡ ਬੇਸੁਮਾਰ ॥੧॥",
          "roman": "khud khudāe vaḍ besumār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪ ਹੀ ਸਭਨਾਂ ਦਾ ਖਸਮ ਹੈਂ, ਤੂੰ ਬੜਾ ਬੇਅੰਤ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты сам — Господь всех, бесконечно велик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
