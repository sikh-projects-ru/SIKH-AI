{
  "ang": 898,
  "shabads": [
    {
      "shabad_id": 3336,
      "rahao_verse_id": 38311,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38305,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38306,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੁ ਭਰਵਾਸੈ ਬਿਚਰਹਿ ਭਵਨ ॥",
          "roman": "kis bharvāsē bichrah bhavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупец, на чью опору, кроме Бога, ты рассчитываешь, странствуя в мире?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38307,
          "is_rahao": false,
          "gurmukhi": "ਮੂੜ ਮੁਗਧ ਤੇਰਾ ਸੰਗੀ ਕਵਨ ॥",
          "roman": "mūṛ mugadh terā saṅgī kavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупец, кто, кроме Бога, может быть твоим настоящим спутником?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38308,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮੁ ਸੰਗੀ ਤਿਸੁ ਗਤਿ ਨਹੀ ਜਾਨਹਿ ॥",
          "roman": "rām saṅgī tis gat nahī jānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твой истинный спутник — Господь, но ты не устанавливаешь с Ним близости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38309,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਬਟਵਾਰੇ ਸੇ ਮੀਤ ਕਰਿ ਮਾਨਹਿ ॥੧॥",
          "roman": "pañch baṭvāre se mīt kar mānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пять разбойников — страсти и пороки — ты считаешь своими друзьями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38310,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਘਰੁ ਸੇਵਿ ਜਿਤੁ ਉਧਰਹਿ ਮੀਤ ॥",
          "roman": "so ghar sev jit udhrah mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг, держись того пристанища, через которое ты сможешь переправиться через мир-океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38311,
          "is_rahao": true,
          "gurmukhi": "ਗੁਣ ਗੋਵਿੰਦ ਰਵੀਅਹਿ ਦਿਨੁ ਰਾਤੀ ਸਾਧਸੰਗਿ ਕਰਿ ਮਨ ਕੀ ਪ੍ਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "guṇ govind ravīah din rātī sādhasaṅg kar man kī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В общении с Гуру соедини любовь своего ума с этим местом; там днём и ночью следует воспевать достоинства Говинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38312,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਬਿਹਾਨੋ ਅਹੰਕਾਰਿ ਅਰੁ ਵਾਦਿ ॥",
          "roman": "janam bihāno ahaṅkār ar vād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жизнь человека проходит в гордыне и спорах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38313,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਪਤਿ ਨ ਆਵੈ ਬਿਖਿਆ ਸਾਦਿ ॥",
          "roman": "tripat na āvē bikhiyā sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во вкусе майи он никогда не находит удовлетворения и не насыщается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38314,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਤ ਭਰਮਤ ਮਹਾ ਦੁਖੁ ਪਾਇਆ ॥",
          "roman": "bharamat bharamat mahā dukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Блуждая снова и снова, он испытывает великие страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38315,
          "is_rahao": false,
          "gurmukhi": "ਤਰੀ ਨ ਜਾਈ ਦੁਤਰ ਮਾਇਆ ॥੨॥",
          "roman": "tarī na jāī dutar māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Майя — труднопреодолимый океан; без Имени Господа через него не переправиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38316,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਨ ਆਵੈ ਸੁ ਕਾਰ ਕਮਾਵੈ ॥",
          "roman": "kām na āvē so kār kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек всё время делает такие дела, которые в конце не приносят ему пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38317,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬੀਜਿ ਆਪੇ ਹੀ ਖਾਵੈ ॥",
          "roman": "āp bīj āpe hī khāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам посеяв семена дурных дел, он сам же вкушает их горький плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38318,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨ ਕਉ ਦੂਸਰ ਨਹੀ ਕੋਇ ॥",
          "roman": "rākhan kau dūsar nahī koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Бога, нет никого другого, кто мог бы спасти его от этой беды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38319,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਨਿਸਤਰੈ ਜਉ ਕਿਰਪਾ ਹੋਇ ॥੩॥",
          "roman": "tau nistarē jau kirpā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь когда приходит милость Бога, человек переправляется через это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38320,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪੁਨੀਤ ਪ੍ਰਭ ਤੇਰੋ ਨਾਮੁ ॥",
          "roman": "patit punīt prabh tero nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твоё Имя очищает тех, кто пал в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38321,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਦਾਸ ਕਉ ਕੀਜੈ ਦਾਨੁ ॥",
          "roman": "apne dās kau kījē dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дай мне, Твоему слуге, дар Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38322,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਗਤਿ ਕਰਿ ਮੇਰੀ ॥",
          "roman": "kar kirpā prabh gat kar merī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, яви милость и возвышай моё духовное состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38323,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਗਹੀ ਨਾਨਕ ਪ੍ਰਭ ਤੇਰੀ ॥੪॥੩੭॥੪੮॥",
          "roman": "saraṇ gahī nānak prabh terī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Нанак ухватился за Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3337,
      "rahao_verse_id": 38330,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38324,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38325,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਲੋਕੇ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "ih loke sukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обрёл дружбу Гуру, наслаждается духовным покоем в этом мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38326,
          "is_rahao": false,
          "gurmukhi": "ਨਹੀ ਭੇਟਤ ਧਰਮ ਰਾਇਆ ॥",
          "roman": "nahī bheṭat dharam rāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В ином мире ему не приходится иметь дело с Дхарам Раджем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38327,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਰਗਹ ਸੋਭਾਵੰਤ ॥",
          "roman": "har dargah sobhāvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В присутствии Бога он становится почитаемым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38328,
          "is_rahao": false,
          "gurmukhi": "ਫੁਨਿ ਗਰਭਿ ਨਾਹੀ ਬਸੰਤ ॥੧॥",
          "roman": "phun garabh nāhī basant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И снова он не попадает в круг рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38329,
          "is_rahao": true,
          "gurmukhi": "ਜਾਨੀ ਸੰਤ ਕੀ ਮਿਤ੍ਰਾਈ ॥",
          "roman": "jānī sant kī mitrāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь я понял ценность дружбы Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38330,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਦੀਨੋ ਹਰਿ ਨਾਮਾ ਪੂਰਬਿ ਸੰਜੋਗਿ ਮਿਲਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā dīno har nāmā pūrab sanjog milāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По прежнему благому союзу эта дружба была обретена; Гуру, явив милость, дал мне Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38331,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਚਰਣਿ ਚਿਤੁ ਲਾਗਾ ॥",
          "roman": "gur kē charaṇ chit lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моё сознание соединилось со стопами Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38332,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨਿ ਧੰਨਿ ਸੰਜੋਗੁ ਸਭਾਗਾ ॥",
          "roman": "dhann dhann sanjog sabhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословен, благословен и счастлив был тот миг встречи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38333,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਧੂਰਿ ਲਾਗੀ ਮੇਰੈ ਮਾਥੇ ॥",
          "roman": "sant kī dhūṛ lāgī merē māthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пыль стоп Гуру коснулась моего лба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38334,
          "is_rahao": false,
          "gurmukhi": "ਕਿਲਵਿਖ ਦੁਖ ਸਗਲੇ ਮੇਰੇ ਲਾਥੇ ॥੨॥",
          "roman": "kilvikh dukh sagle mere lāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все мои грехи и страдания были удалены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38335,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸਚੁ ਟਹਲ ਕਮਾਨੀ ॥",
          "roman": "sādh kī sach ṭahal kamānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда живые существа с верой совершают служение Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38336,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਹੋਏ ਮਨ ਸੁਧ ਪਰਾਨੀ ॥",
          "roman": "tab hoe man sudh parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда, о человек, их умы становятся чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38337,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਾ ਸਫਲ ਦਰਸੁ ਡੀਠਾ ॥",
          "roman": "jan kā saphal daras ḍīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто увидел плодотворный даршан слуги Бога, обрёл плод Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38338,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਪ੍ਰਭੂ ਕਾ ਘਟਿ ਘਟਿ ਵੂਠਾ ॥੩॥",
          "roman": "nām prabhū kā ghaṭ ghaṭ vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Господа, вообще-то, пребывает в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38339,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਾਨੇ ਸਭਿ ਕਲਿ ਕਲੇਸ ॥",
          "roman": "miṭāne sabh kal kales",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря встрече с Гуру все внутренние споры и страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38340,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਤੇ ਉਪਜੇ ਤਿਸੁ ਮਹਿ ਪਰਵੇਸ ॥",
          "roman": "jis te upje tis mah parves",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живые существа растворяются в Том, от Кого они возникли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38341,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟੇ ਆਨੂਪ ਗੋੁਵਿੰਦ ॥",
          "roman": "pragaṭe ānūp govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прекрасный, несравненный Говинд проявляется в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38342,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਪੂਰੇ ਨਾਨਕ ਬਖਸਿੰਦ ॥੪॥੩੮॥੪੯॥",
          "roman": "prabh pūre nānak bakhasind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, проявляется совершенный Господь, дарующий прощение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3338,
      "rahao_verse_id": 38349,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38343,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38344,
          "is_rahao": false,
          "gurmukhi": "ਗਊ ਕਉ ਚਾਰੇ ਸਾਰਦੂਲੁ ॥",
          "roman": "gaū kau chāre sāradūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь смотрит милостивым взором, ставший сильным ум держит органы познания под контролем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38345,
          "is_rahao": false,
          "gurmukhi": "ਕਉਡੀ ਕਾ ਲਖ ਹੂਆ ਮੂਲੁ ॥",
          "roman": "kauḍī kā lakh hūā mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живое существо, прежде ставшее ничтожным, словно каури, теперь обретает цену в сотни тысяч."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38346,
          "is_rahao": false,
          "gurmukhi": "ਬਕਰੀ ਕਉ ਹਸਤੀ ਪ੍ਰਤਿਪਾਲੇ ॥",
          "roman": "bakrī kau hastī pratipāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда прежде гордый, как слон, ум принимает в себе смиренный нрав, подобный козе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38347,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਪ੍ਰਭੁ ਨਦਰਿ ਨਿਹਾਲੇ ॥੧॥",
          "roman": "apnā prabh nadar nihāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так происходит, когда свой возлюбленный Господь смотрит милостивым взором."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38348,
          "is_rahao": true,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਪ੍ਰੀਤਮ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "kripā nidhān prītam prabh mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный Господь, о сокровищница милости!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38349,
          "is_rahao": true,
          "gurmukhi": "ਬਰਨਿ ਨ ਸਾਕਉ ਬਹੁ ਗੁਨ ਤੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "baran na sākau bah guṇ tere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твои качества бесчисленны; я не могу описать их все."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38350,
          "is_rahao": false,
          "gurmukhi": "ਦੀਸਤ ਮਾਸੁ ਨ ਖਾਇ ਬਿਲਾਈ ॥",
          "roman": "dīsat mās na khāe bilāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь смотрит милостиво, кошка не ест мясо, которое видит; жажда ума прекращается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38351,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਕਸਾਬਿ ਛੁਰੀ ਸਟਿ ਪਾਈ ॥",
          "roman": "mahā kasāb chhurī saṭ pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Господа великий мясник, безжалостный ум, бросает нож из рук."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38352,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰ ਪ੍ਰਭੁ ਹਿਰਦੈ ਵੂਠਾ ॥",
          "roman": "karaṇhār prabh hirdē vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда всемогущий Господь поселяется в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38353,
          "is_rahao": false,
          "gurmukhi": "ਫਾਥੀ ਮਛੁਲੀ ਕਾ ਜਾਲਾ ਤੂਟਾ ॥੨॥",
          "roman": "phāthī machhulī kā jālā ṭūṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда сеть майи разрывается для рыбы-души, попавшей в ловушку привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38354,
          "is_rahao": false,
          "gurmukhi": "ਸੂਕੇ ਕਾਸਟ ਹਰੇ ਚਲੂਲ ॥",
          "roman": "sūke kāsaṭ hare chalūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда пришла милость, сухие деревья стали свежо-зелёными; сухость ума ушла, и внутри возникло сострадание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38355,
          "is_rahao": false,
          "gurmukhi": "ਊਚੈ ਥਲਿ ਫੂਲੇ ਕਮਲ ਅਨੂਪ ॥",
          "roman": "ūchē thal phūle kamal anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На высоком сухом месте расцвели прекрасные лотосы; гордый ум, прежде не принимавший дождь Имени, теперь расцвёл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38356,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਨਿਵਾਰੀ ਸਤਿਗੁਰ ਦੇਵ ॥",
          "roman": "agan nivārī satigur dev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный Сатгуру устранил огонь жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38357,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕੁ ਅਪਨੀ ਲਾਇਓ ਸੇਵ ॥੩॥",
          "roman": "sevak apnī lāio sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он присоединил своего слугу к служению Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38358,
          "is_rahao": false,
          "gurmukhi": "ਅਕਿਰਤਘਣਾ ਕਾ ਕਰੇ ਉਧਾਰੁ ॥",
          "roman": "akiratghaṇā kā kare udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь переправляет даже неблагодарных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38359,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਮੇਰਾ ਹੈ ਸਦਾ ਦਇਆਰੁ ॥",
          "roman": "prabh merā hē sadā dēār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой Господь всегда является обителью милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38360,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਕਾ ਸਦਾ ਸਹਾਈ ॥",
          "roman": "sant janā kā sadā sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь всегда помогает святым людям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38361,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਨਾਨਕ ਸਰਣਾਈ ॥੪॥੩੯॥੫੦॥",
          "roman": "charaṇ kamal nānak saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, святые всегда пребывают в прибежище Его прекрасных лотосных стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3339,
      "rahao_verse_id": null,
      "rahao_theme": "",
