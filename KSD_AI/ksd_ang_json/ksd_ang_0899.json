{
  "ang": 899,
  "shabads": [
    {
      "shabad_id": 3339,
      "rahao_verse_id": 38368,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38363,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਸਿੰਘ ਰਾਖੇ ਪ੍ਰਭਿ ਮਾਰਿ ॥",
          "roman": "panch siṅgh rākhe prabh mār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਉਂ ਜਿਉਂ ਮੈਂ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ) ਪ੍ਰਭੂ ਨੇ (ਮੇਰੇ ਅੰਦਰੋਂ) ਪੰਜ ਕਾਮਾਦਿਕ ਸ਼ੇਰ ਮਾਰ ਮੁਕਾਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Бог уничтожил пять львов — страстей внутри меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38364,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਬਿਘਿਆੜੀ ਲਈ ਨਿਵਾਰਿ ॥",
          "roman": "das bighyāṛī laī nivār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਸ ਇੰਦ੍ਰੀਆਂ ਦਾ ਦਬਾਉ ਭੀ ਮੇਰੇ ਉਤੋਂ ਦੂਰ ਕਰ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он устранил давление десяти чувств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38365,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਆਵਰਤ ਕੀ ਚੂਕੀ ਘੇਰ ॥",
          "roman": "tīn āvart kī chūkī gher",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ ਦੀ ਘੁੰਮਣ-ਘੇਰੀ ਦਾ ਚੱਕਰ (ਭੀ) ਮੁੱਕ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Круг трёх качеств майи прекратился."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38366,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਚੂਕੇ ਭੈ ਫੇਰ ॥੧॥",
          "roman": "sādhsaṅg chūke bhē pher",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿਣ ਕਰਕੇ) ਜਨਮ ਮਰਨ ਗੇੜ ਦੇ ਸਾਰੇ ਡਰ ਭੀ ਖ਼ਤਮ ਹੋ ਗਏ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "В общине Гуру исчез страх круговорота рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38367,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਜੀਵਾ ਗੋਵਿੰਦ ॥",
          "roman": "simar simar jīvā govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਮੁੜ ਮੁੜ ਸਿਮਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я живу, постоянно помня Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38368,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਰਾਖਿਓ ਦਾਸੁ ਅਪਨਾ ਸਦਾ ਸਦਾ ਸਾਚਾ ਬਖਸਿੰਦ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā rākhiō dās apnā sadā sadā sāchā bakhsiṅd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਦਾਸ ਨੂੰ ਪਰਮਾਤਮਾ ਨੇ ਕਿਰਪਾ ਕਰ ਕੇ (ਆਪ ਹੀ ਕਾਮਾਦਿਕ ਵਿਕਾਰੋਂ ਤੋਂ) ਬਚਾ ਰੱਖਿਆ ਹੈ। ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਮਾਲਕ ਸਦਾ ਹੀ ਬਖ਼ਸ਼ਸ਼ਾਂ ਕਰਨ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Бог хранит меня, своего слугу, Он вечный дарующий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38369,
          "is_rahao": false,
          "gurmukhi": "ਦਾਝਿ ਗਏ ਤ੍ਰਿਣ ਪਾਪ ਸੁਮੇਰ ॥",
          "roman": "dājh gae triṇ pāp sumer",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਦੇ ਸੁਮੇਰ ਪਰਬਤ ਜੇਡੇ ਹੋ ਚੁਕੇ ਪਾਪ ਘਾਹ ਦੇ ਤੀਲਿਆਂ ਵਾਂਗ ਸੜ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Грехи, как гора, сгорают как травинки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38370,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਨਾਮੁ ਪੂਜੇ ਪ੍ਰਭ ਪੈਰ ॥",
          "roman": "jap jap nām pūje prabh pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਕੋਈ ਜੀਵ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਉਸ ਦੇ ਚਰਨ ਪੂਜਣੇ ਸ਼ੁਰੂ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек повторяет Имя и почитает стопы Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38371,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਰੂਪ ਪ੍ਰਗਟਿਓ ਸਭ ਥਾਨਿ ॥",
          "roman": "anad rūp pragaṭio sabh thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਆਨੰਦ-ਸਰੂਪ ਪ੍ਰਭੂ ਹਰੇਕ ਥਾਂ ਵਿਚ ਵੱਸਦਾ ਦਿੱਸ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Бог, воплощение блаженства, проявляется повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38372,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਜੋਰੀ ਸੁਖ ਮਾਨਿ ॥੨॥",
          "roman": "prem bhagat jorī sukh mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਸੁਖਾਂ ਦੀ ਮਣੀ ਪ੍ਰਭੂ ਦੀ ਪ੍ਰੇਮ ਭਗਤੀ ਵਿਚ ਆਪਣੀ ਸੁਰਤ ਜੋੜੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто соединяется с любовной преданностью, обретает счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38373,
          "is_rahao": false,
          "gurmukhi": "ਸਾਗਰੁ ਤਰਿਓ ਬਾਛਰ ਖੋਜ ॥",
          "roman": "sāgar tariō bāchhar khoj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਨੇ ਭੀ ਨਾਮ ਜਪਿਆ ਉਸ ਨੇ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਇਉਂ ਤਰ ਲਿਆ ਜਿਵੇਂ (ਪਾਣੀ ਨਾਲ ਭਰਿਆ ਹੋਇਆ) ਵੱਛੇ ਦੇ ਖੁਰ ਦਾ ਨਿਸ਼ਾਨ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Он переплывает океан мира, как будто это след копыта телёнка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38374,
          "is_rahao": false,
          "gurmukhi": "ਖੇਦੁ ਨ ਪਾਇਓ ਨਹ ਫੁਨਿ ਰੋਜ ॥",
          "roman": "khed na pāio nah fun roj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਉਸ ਨੂੰ ਕੋਈ ਦੁੱਖ ਪੁਂਹਦਾ ਹੈ ਨਾਹ ਕੋਈ ਚਿੰਤਾ-ਫ਼ਿਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Он не испытывает ни боли, ни забот."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38375,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਧੁ ਸਮਾਇਓ ਘਟੁਕੇ ਮਾਹਿ ॥",
          "roman": "siṅdh samāio ghaṭuke māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਉਸ ਦੇ ਅੰਦਰ ਇਉਂ ਆ ਟਿਕਦਾ ਹੈ ਜਿਵੇਂ ਸਮੁੰਦਰ (ਮਾਨੋ) ਇਕ ਨਿੱਕੇ ਜਿਹੇ ਘੜੇ ਵਿਚ ਆ ਟਿਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "Бог входит в него, как океан в маленький сосуд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38376,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰ ਕਉ ਕਿਛੁ ਅਚਰਜੁ ਨਾਹਿ ॥੩॥",
          "roman": "karaṇhār kau kichh acharaj nāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਿਰਜਨਹਾਰ ਪ੍ਰਭੂ ਵਾਸਤੇ ਇਹ ਕੋਈ ਅਨੋਖੀ ਗੱਲ ਨਹੀਂ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Для Творца в этом нет ничего удивительного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38377,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਛੂਟਉ ਤਉ ਜਾਇ ਪਇਆਲ ॥",
          "roman": "jau chhūṭau tau jāi paiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਦੋਂ (ਕਿਸੇ ਜੀਵ ਦੇ ਹੱਥੋਂ ਪ੍ਰਭੂ ਦਾ ਪੱਲਾ) ਛੁੱਟ ਜਾਂਦਾ ਹੈ, ਤਦੋਂ ਉਹ (ਮਾਨੋ) ਪਾਤਾਲ ਵਿਚ ਜਾ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек отпускает Бога, он словно падает в бездну."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38378,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਕਾਢਿਓ ਤਉ ਨਦਰਿ ਨਿਹਾਲ ॥",
          "roman": "jau kāḍhiō tau nadar nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਆਪ ਉਸ ਨੂੰ ਪਾਤਾਲ ਵਿਚੋਂ ਕੱਢ ਲੈਂਦਾ ਹੈ ਤਦੋਂ ਉਸ ਦੀ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਉਹ ਤਨੋਂ ਮਨੋਂ ਖਿੜ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда Бог поднимает его, он расцветает под Его взглядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38379,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਪੁੰਨ ਹਮਰੈ ਵਸਿ ਨਾਹਿ ॥",
          "roman": "pāp puṇn hamrē vas nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਚੰਗੇ ਮਾੜੇ ਕੰਮ ਕਰਨੇ ਅਸਾਂ ਜੀਵਾਂ ਦੇ ਵੱਸ ਵਿਚ ਨਹੀਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Добро и зло не находятся в нашей власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38380,
          "is_rahao": false,
          "gurmukhi": "ਰਸਕਿ ਰਸਕਿ ਨਾਨਕ ਗੁਣ ਗਾਹਿ ॥੪॥੪੦॥੫੧॥",
          "roman": "rasak rasak nānak guṇ gāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਜਿਨ੍ਹਾਂ ਉਤੇ ਉਹ ਮਿਹਰ ਕਰਦਾ ਹੈ, ਉਹ ਬੰਦੇ) ਬੜੇ ਪ੍ਰੇਮ ਨਾਲ ਉਸ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ ॥੪॥੪੦॥੫੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: те, на кого падает милость, с любовью поют Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3340,
      "rahao_verse_id": 38387,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38381,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38382,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤਨੁ ਤੇਰਾ ਨਾ ਮਨੁ ਤੋਹਿ ॥",
          "roman": "nā tan terā nā man toh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਨਾਹ ਉਹ ਸਰੀਰ ਤੇਰਾ ਹੈ, ਤੇ, ਨਾਹ ਹੀ (ਉਸ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ) ਮਨ ਤੇਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! ни это тело не твоё, ни ум, который в этом теле пребывает, не твой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38383,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿ ਬਿਆਪਿਆ ਧੋਹਿ ॥",
          "roman": "māiā moh biāpiā dhoh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਸਰੀਰ ਦੀ ਖ਼ਾਤਰ) ਤੂੰ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਦੀ ਠੱਗੀ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "из-за этого тела ты пребываешь в обмане, в ловушке привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38384,
          "is_rahao": false,
          "gurmukhi": "ਕੁਦਮ ਕਰੈ ਗਾਡਰ ਜਿਉ ਛੇਲ ॥",
          "roman": "kudam karē gāḍar jio chhel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ!) ਜਿਵੇਂ ਭੇਡ ਦਾ ਬੱਚਾ ਭੇਡ ਨਾਲ ਕਲੋਲ ਕਰਦਾ ਹੈ (ਉਸ ਵਿਚਾਰੇ ਉਤੇ) ਅਚਨਚੇਤ (ਮੌਤ ਦਾ) ਜਾਲ ਆ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Смотри! как ягнёнок играет с овцой, и внезапно на него падает сеть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38385,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੁ ਜਾਲੁ ਕਾਲੁ ਚਕ੍ਰੁ ਪੇਲ ॥੧॥",
          "roman": "achint jāl kāl chakr pel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਉਤੇ) ਮੌਤ ਅਪਣਾ ਚੱਕਰ ਚਲਾ ਦੇਂਦੀ ਹੈ (ਇਹੀ ਹਾਲ ਹਰੇਕ ਜੀਵ ਦਾ ਹੁੰਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и смерть приводит в движение своё колесо — таково состояние каждого живого существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38386,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਚਰਨ ਕਮਲ ਸਰਨਾਇ ਮਨਾ ॥",
          "roman": "har charan kamal sarnāi manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦੀ ਸਰਨ ਪਿਆ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! пребывай в прибежище прекрасных стоп Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38387,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਜਪਿ ਸੰਗਿ ਸਹਾਈ ਗੁਰਮੁਖਿ ਪਾਵਹਿ ਸਾਚੁ ਧਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām nām jap sang sahāī gurmukh pāveh sāch dhanā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਰਿਹਾ ਕਰ, ਇਹੀ ਤੇਰੇ ਨਾਲ ਅਸਲ ਮਦਦਗਾਰ ਹੈ। ਪਰ ਇਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਨਾਮ-ਧਨ ਤੂੰ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਲੱਭ ਸਕੇਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяй Имя Бога — это твой истинный помощник; но это вечное богатство Имени ты найдёшь только через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38388,
          "is_rahao": false,
          "gurmukhi": "ਊਨੇ ਕਾਜ ਨ ਹੋਵਤ ਪੂਰੇ ॥",
          "roman": "ūne kāj na hovat pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਦੇ ਇਹ ਕਦੇ ਨਾਹ ਮੁੱਕ ਸਕਣ ਵਾਲੇ ਕੰਮ ਕਦੇ ਸਿਰੇ ਨਹੀਂ ਚੜ੍ਹਦੇ;"
            },
            "sahib_singh_ru": {
              "main": "Эти бесконечные дела живого существа никогда не завершаются;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38389,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਕ੍ਰੋਧਿ ਮਦਿ ਸਦ ਹੀ ਝੂਰੇ ॥",
          "roman": "kām krodh mad sad hī jhūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ-ਵਾਸਨਾ ਵਿਚ, ਕ੍ਰੋਧ ਵਿਚ, ਮਾਇਆ ਦੇ ਨਸ਼ੇ ਵਿਚ ਜੀਵ ਸਦਾ ਹੀ ਗਿਲੇ-ਗੁਜ਼ਾਰੀਆਂ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в страсти, в гневе, в опьянении майей человек постоянно пребывает в недовольстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38390,
          "is_rahao": false,
          "gurmukhi": "ਕਰੈ ਬਿਕਾਰ ਜੀਅਰੇ ਕੈ ਤਾਈ ॥",
          "roman": "karē bikār jīare kē tāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ ਇਸ ਜਿੰਦ (ਨੂੰ ਸੁਖ ਦੇਣ) ਦੀ ਖ਼ਾਤਰ ਜੀਵ ਵਿਕਾਰ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ради этой своей жизни человек совершает пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38391,
          "is_rahao": false,
          "gurmukhi": "ਗਾਫਲ ਸੰਗਿ ਨ ਤਸੂਆ ਜਾਈ ॥੨॥",
          "roman": "gāfal sang na tasūā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਰੱਬ ਦੀ ਯਾਦ ਵਲੋਂ) ਅਵੇਸਲੇ ਹੋ ਚੁਕੇ ਜੀਵ ਦੇ ਨਾਲ (ਦੁਨੀਆ ਦੇ ਪਦਾਰਥਾਂ ਵਿਚੋਂ) ਰਤਾ ਭੀ ਨਹੀਂ ਜਾਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но с этим беспечным человеком ничего из мирских вещей не уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38392,
          "is_rahao": false,
          "gurmukhi": "ਧਰਤ ਧੋਹ ਅਨਿਕ ਛਲ ਜਾਨੈ ॥",
          "roman": "dharat dhoh anik chhal jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਜੀਵ ਅਨੇਕਾਂ ਠੱਗੀਆਂ ਕਰਦਾ ਹੈ, ਅਨੇਕਾਂ ਫ਼ਰੇਬ ਕਰਨੇ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Глупый человек совершает множество обманов и знает множество уловок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38393,
          "is_rahao": false,
          "gurmukhi": "ਕਉਡੀ ਕਉਡੀ ਕਉ ਖਾਕੁ ਸਿਰਿ ਛਾਨੈ ॥",
          "roman": "kauṛī kauṛī kau khāk sir chhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੌਡੀ ਕੌਡੀ ਕਮਾਣ ਦੀ ਖ਼ਾਤਰ ਆਪਣੇ ਸਿਰ ਉਤੇ (ਦਗ਼ੇ-ਫ਼ਰੇਬ ਦੇ ਕਾਰਨ ਬਦਨਾਮੀ ਦੀ) ਸੁਆਹ ਪਾਂਦਾ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ради каждой мелкой выгоды он сыплет пепел на свою голову — навлекает позор."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38394,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਆ ਤਿਸੈ ਨ ਚੇਤੈ ਮੂਲਿ ॥",
          "roman": "jin dīā tisē na chetē mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਨੇ (ਇਸ ਨੂੰ ਇਹ ਸਭ ਕੁਝ) ਦਿੱਤਾ ਹੈ ਉਸ ਨੂੰ ਇਹ ਬਿਲਕੁਲ ਯਾਦ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Того, кто дал ему всё это, он совсем не вспоминает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38395,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਲੋਭੁ ਨ ਉਤਰੈ ਸੂਲੁ ॥੩॥",
          "roman": "mithiā lobh na utrē sūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦੇ ਅੰਦਰ) ਨਾਸਵੰਤ ਪਦਾਰਥਾਂ ਦਾ ਲੋਭ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ (ਇਹਨਾਂ ਦੀ) ਚੋਭ (ਇਸ ਦੇ ਅੰਦਰੋਂ) ਕਦੇ ਨਹੀਂ ਦੂਰ ਹੁੰਦੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ложная жадность остаётся в нём, и её боль никогда не уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38396,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਜਬ ਭਏ ਦਇਆਲ ॥",
          "roman": "pārbrahm jab bhae dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਜਦੋਂ ਕਿਸੇ ਜੀਵ ਉਤੇ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Верховный Бог становится милостивым к человеку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38397,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਹੋਆ ਸਾਧ ਰਵਾਲ ॥",
          "roman": "ih man hoā sādh ravāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਜੀਵ ਦਾ ਇਹ ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "его ум становится пылью у стоп Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38398,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤ ਕਮਲ ਲੜਿ ਲੀਨੋ ਲਾਇ ॥",
          "roman": "hast kamal laṛ līno lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਨੂੰ ਆਪਣੇ ਸੋਹਣੇ ਹੱਥਾਂ ਨਾਲ ਆਪਣੇ ਪੱਲੇ ਲਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру берёт его своими прекрасными руками и прижимает к себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38399,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੈ ਸਾਚਿ ਸਮਾਇ ॥੪॥੪੧॥੫੨॥",
          "roman": "nānak sāchē sāch samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਹੇ ਨਾਨਕ! (ਉਹ ਭਾਗਾਂ ਵਾਲਾ) ਸਦਾ ਹੀ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੪੧॥੫੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, он пребывает слитым с Вечным Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3341,
      "rahao_verse_id": 38402,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38400,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38401,
          "is_rahao": true,
          "gurmukhi": "ਰਾਜਾ ਰਾਮ ਕੀ ਸਰਣਾਇ ॥",
          "roman": "rājā rām kī sarnāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਹੜੇ ਮਨੁੱਖ ਪ੍ਰਕਾਸ਼-ਸਰੂਪ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! те люди, которые принимают прибежище у сияющего Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38402,
          "is_rahao": true,
          "gurmukhi": "ਨਿਰਭਉ ਭਏ ਗੋਬਿੰਦ ਗੁਨ ਗਾਵਤ ਸਾਧਸੰਗਿ ਦੁਖੁ ਜਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nirbhau bhae gobind gun gāvat sādhsaṅg dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਗਾਂਦਿਆਂ ਉਹ ਦੁਨੀਆ ਦੇ ਡਰਾਂ ਤੋਂ ਮੁਕਤ ਹੋ ਜਾਂਦੇ ਹਨ; ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਉਹਨਾਂ ਦਾ (ਹਰੇਕ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "воспевая качества Бога, становятся бесстрашными; в обществе Гуру их страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38403,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਾਮੁ ਬਸੈ ਮਨ ਮਾਹੀ ॥",
          "roman": "jā kē rām basē man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! тот, в чьём уме поселяется Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38404,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਦੁਤਰੁ ਪੇਖਤ ਨਾਹੀ ॥",
          "roman": "so jan dūtar pekhat nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਔਖਿਆਈ ਨਾਲ ਤਰੇ ਜਾਣ ਵਾਲੇ ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਨੂੰ ਵੇਖਦਾ ਭੀ ਨਹੀਂ (ਉਸ ਦੇ ਰਸਤੇ ਵਿਚ) ਇਹ ਕੋਈ ਰੁਕਾਵਟ ਨਹੀਂ ਪਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "тот человек даже не воспринимает этот труднопреодолимый мир как препятствие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38405,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਕਾਜ ਸਵਾਰੇ ਅਪਨੇ ॥",
          "roman": "sagle kāj savāre apne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚਾੜ੍ਹ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он завершает все свои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38406,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਰਸਨ ਨਿਤ ਜਪਨੇ ॥੧॥",
          "roman": "har har nām rasan nit japne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੀ) ਜੀਭ ਨਾਲ ਨਿੱਤ ਜਪ ਜਪ ਕੇ (ਤਰ ਜਾਂਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Постоянно повторяя Имя Бога языком, он достигает освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38407,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਮਸਤਕਿ ਹਾਥੁ ਗੁਰੁ ਧਰੈ ॥ ਸੋ ਦਾਸੁ ਅਦੇਸਾ ਕਾਹੇ ਕਰੈ ॥",
          "roman": "jis kē mastak hāth gur dharē so dās adesā kāhe karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਉਤੇ ਗੁਰੂ (ਆਪਣਾ) ਹੱਥ ਰੱਖਦਾ ਹੈ, (ਪ੍ਰਭੂ ਦਾ ਉਹ) ਸੇਵਕ ਕਿਸੇ ਤਰ੍ਹਾਂ ਦਾ ਭੀ ਕੋਈ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! тому, на чью голову Гуру кладёт свою руку, слуга Бога не имеет никаких тревог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38408,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਕੀ ਚੂਕੀ ਕਾਣਿ ॥",
          "roman": "janam maran kī chūkī kāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦਾ ਡਰ ਮੁੱਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У такого человека исчезает страх цикла рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38409,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਊਪਰਿ ਕੁਰਬਾਣ ॥੨॥",
          "roman": "pūrai gur ūpar kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੂਰੇ ਗੁਰੂ ਉਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹੈ (ਆਪਣਾ ਆਪਾ ਵਾਰਦਾ ਰਹਿੰਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он полностью предан совершённому Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38410,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਭੇਟਿ ਨਿਹਾਲ ॥",
          "roman": "gur parmesar bheṭ nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਪਰਮੇਸਰ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਹ ਸਦਾ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! тот, кто встречает Гуру — встречает Бога — пребывает в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38411,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਦਰਸਨੁ ਪਾਏ ਜਿਸੁ ਹੋਇ ਦਇਆਲੁ ॥",
          "roman": "so darsan pāe jis hoi dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਗੁਰੂ ਦਾ ਪਰਮੇਸਰ ਦਾ) ਦਰਸਨ ਉਹੀ ਮਨੁੱਖ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ, ਜਿਸ ਉਤੇ ਪ੍ਰਭੂ ਆਪ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но это видение получает только тот, к кому Бог милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38412,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਿਸੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "pārbrahm jis kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਮਿਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, на кого Верховный Бог проявляет милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38413,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸੋ ਭਵਜਲੁ ਤਰੈ ॥੩॥",
          "roman": "sādhsaṅg so bhavjal tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в обществе Гуру переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38414,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਪੀਵਹੁ ਸਾਧ ਪਿਆਰੇ ॥",
          "roman": "amrit pīvh sādh piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਿਆਰੇ ਸੰਤ ਜਨੋ! (ਤੁਸੀ ਭੀ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਪੀਂਦੇ ਰਹੋ,"
            },
            "sahib_singh_ru": {
              "main": "О дорогие святые! пейте нектар Имени, дарующий духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38415,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖ ਊਜਲ ਸਾਚੈ ਦਰਬਾਰੇ ॥",
          "roman": "mukh ūjal sāchē darbāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਦਰਬਾਰ ਵਿਚ ਤੁਹਾਡੇ ਮੂੰਹ ਉਜਲੇ ਹੋਣਗੇ (ਤੁਹਾਨੂੰ ਉਥੇ ਆਦਰ-ਸਤਕਾਰ ਮਿਲੇਗਾ)।"
            },
            "sahib_singh_ru": {
              "main": "и ваши лица будут сиять в дворе Вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38416,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਕਰਹੁ ਤਜਿ ਸਗਲ ਬਿਕਾਰ ॥",
          "roman": "anad karh taj sagal bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ!) ਸਾਰੇ ਵਿਚਾਰ ਛੱਡ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਰਹੋ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! оставьте все пороки и пребывайте в духовной радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38417,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਜਪਿ ਉਤਰਹੁ ਪਾਰਿ ॥੪॥੪੨॥੫੩॥",
          "roman": "nānak har jap utarhu pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਤੁਸੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਉਗੇ ॥੪॥੪੨॥੫੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! повторяя Имя Бога, вы переправитесь через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
