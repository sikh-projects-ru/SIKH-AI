{
  "ang": 904,
  "shabads": [
    {
      "shabad_id": 3354,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38594,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹੁ ਬਿਵਰਜਿ ਸਮਾਏ ॥",
          "roman": "māiā moh bivaraj samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮਾਇਆ ਦਾ ਮੋਹ ਰੋਕ ਕੇ ਪ੍ਰਭੂ-ਨਾਮ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Отбросив привязанность к майе, он сливается с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38595,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟੈ ਮੇਲਿ ਮਿਲਾਏ ॥",
          "roman": "satgur bheṭē mel milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲਦਾ ਹੈ ਗੁਰੂ ਉਸ ਨੂੰ ਸੰਗਤ ਵਿਚ ਮਿਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Встреча с Гуру соединяет с общиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38596,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਰਤਨੁ ਨਿਰਮੋਲਕੁ ਹੀਰਾ ॥",
          "roman": "nām ratan nirmolak hīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਮਾਨੋ, ਇਕ) ਰਤਨ ਹੈ (ਇਕ ਐਸਾ) ਹੀਰਾ ਹੈ ਜਿਸ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Имя — драгоценный камень без цены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38597,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਰਾਤਾ ਮੇਰਾ ਮਨੁ ਧੀਰਾ ॥੨॥",
          "roman": "tit rātā merā man dhīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਮੇਰਾ ਮਨ ਭੀ ਉਸ ਨਾਮ ਵਿਚ ਰੰਗਿਆ ਗਿਆ ਹੈ ਉਸ ਨਾਮ ਵਿਚ ਟਿਕ ਗਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Мой ум окрашен в это Имя и устойчив в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38598,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮਮਤਾ ਰੋਗੁ ਨ ਲਾਗੈ ॥",
          "roman": "haumē mamtā rog na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ) ਹਉਮੈ-ਰੋਗ ਮਾਇਆ ਦੀ ਮਮਤਾ ਦਾ ਰੋਗ (ਮਨ ਨੂੰ) ਨਹੀਂ ਚੰਬੜਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Его не поражает болезнь эго и привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38599,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਭਗਤਿ ਜਮ ਕਾ ਭਉ ਭਾਗੈ ॥",
          "roman": "rām bhagat jam kā bhau bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਰਾਹੀਂ) ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕੀਤਿਆਂ ਮੌਤ ਦਾ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через преданность исчезает страх смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38600,
          "is_rahao": false,
          "gurmukhi": "ਜਮੁ ਜੰਦਾਰੁ ਨ ਲਾਗੈ ਮੋਹਿ ॥",
          "roman": "jam jandār na lāgē moh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਭਿਆਨਕ ਜਮ ਭੀ ਮੈਨੂੰ ਨਹੀਂ ਪੋਂਹਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Смерть не касается меня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38601,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਨਾਮੁ ਰਿਦੈ ਹਰਿ ਸੋਹਿ ॥੩॥",
          "roman": "nirmal nām ridē har soh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪਰਮਾਤਮਾ ਦਾ ਪਵਿਤ੍ਰ ਨਾਮ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਸੋਭ ਰਿਹਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потому что чистое Имя сияет в моём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38602,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਬੀਚਾਰਿ ਭਏ ਨਿਰੰਕਾਰੀ ॥",
          "roman": "sabad bīchār bhae nirankārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਸੋਚ-ਮੰਡਲ ਵਿਚ ਟਿਕਾ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਹੀ (ਸੇਵਕ) ਹੋ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Размышляя над Словом, человек становится слугой Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38603,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਜਾਗੇ ਦੁਰਮਤਿ ਪਰਹਾਰੀ ॥",
          "roman": "gurmat jāge durmat parhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਪ੍ਰਬਲ ਹੋ ਜਾਂਦੀ ਹੈ ਤੇ ਭੈੜੀ ਮੱਤ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Учение Гуру пробуждает, и дурной разум исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38604,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਜਾਗਿ ਰਹੇ ਲਿਵ ਲਾਈ ॥",
          "roman": "andin jāg rahe liv lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਸੁਰਤ ਜੋੜ ਕੇ ਹਰ ਵੇਲੇ (ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਵੱਲੋਂ) ਸੁਚੇਤ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто постоянно бодрствуют в связи с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38605,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਮੁਕਤਿ ਗਤਿ ਅੰਤਰਿ ਪਾਈ ॥੪॥",
          "roman": "jīvan mukat gat antar pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣੇ ਅੰਦਰ ਉਹ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦੇ ਹਨ ਜੋ ਮਾਇਆ ਵਿਚ ਵਰਤਦਿਆਂ ਹੀ ਮਾਇਆ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਆਜ਼ਾਦ ਕਰ ਦੇਂਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "обретают освобождение при жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38606,
          "is_rahao": false,
          "gurmukhi": "ਅਲਿਪਤ ਗੁਫਾ ਮਹਿ ਰਹਹਿ ਨਿਰਾਰੇ ॥",
          "roman": "alipat guphā meh rahe nirāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਨ ਵਾਲੇ ਬੰਦੇ) ਸਰੀਰ-ਗੁਫਾ ਦੇ ਅੰਦਰ ਹੀ ਮਾਇਆ ਤੋਂ ਨਿਰਲੇਪ ਰਹਿੰਦੇ ਹਨ ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਵੱਖਰੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они живут в теле, оставаясь непривязанными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38607,
          "is_rahao": false,
          "gurmukhi": "ਤਸਕਰ ਪੰਚ ਸਬਦਿ ਸੰਘਾਰੇ ॥",
          "roman": "taskar panch sabad sanghāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਉਹ ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਚੋਰਾਂ ਨੂੰ ਮਾਰ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Пять воров уничтожаются Словом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38608,
          "is_rahao": false,
          "gurmukhi": "ਪਰ ਘਰ ਜਾਇ ਨ ਮਨੁ ਡੋਲਾਏ ॥",
          "roman": "par ghar jāe na man ḍolāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਸਿਮਰਨ ਕਰਨ ਵਾਲਾ ਬੰਦਾ) ਆਪਣੇ ਮਨ ਨੂੰ ਪਰਾਏ ਘਰ ਵਲ ਜਾ ਕੇ ਡੋਲਣ ਨਹੀਂ ਦੇਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Ум не блуждает по чужим домам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38609,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਨਿਰੰਤਰਿ ਰਹਉ ਸਮਾਏ ॥੫॥",
          "roman": "sahaj nirantar rahau samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ ਸਿਮਰਨ ਕਰ ਕੇ) ਮੈਂ ਅਡੋਲ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਇਕ-ਰਸ ਲੀਨ ਰਹਿੰਦਾ ਹਾਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Я пребываю в постоянной духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38610,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਾਗਿ ਰਹੇ ਅਉਧੂਤਾ ॥",
          "roman": "gurmukh jāg rahe audhūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਤਿਆਗੀ ਉਹੀ ਹੈ ਜੋ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਸਿਮਰਨ ਦੀ ਰਾਹੀਂ ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Истинный отшельник бодрствует через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38611,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਬੈਰਾਗੀ ਤਤੁ ਪਰੋਤਾ ॥",
          "roman": "sad bērāgī tat parotā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਜਗਤ ਦੇ ਮੂਲ ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰੋਈ ਰੱਖਦਾ ਹੈ ਉਹ ਸਦਾ (ਮਾਇਆ ਤੋਂ) ਵੈਰਾਗਵਾਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он всегда отрешён и связан с сущностью Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38612,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਸੂਤਾ ਮਰਿ ਆਵੈ ਜਾਇ ॥",
          "roman": "jag sūtā mar āvē jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ (ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਵਲੋਂ) ਸੁੱਤਾ ਰਹਿੰਦਾ ਹੈ, ਤੇ, ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਕੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪੈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир спит в майе и вращается в рождении и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38613,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਸਬਦ ਨ ਸੋਝੀ ਪਾਇ ॥੬॥",
          "roman": "bin gur sabad na sojhī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੀ ਨੀਂਦ ਵਿਚ ਸੁੱਤੇ ਪਏ ਨੂੰ) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਤੋਂ ਬਿਨਾ ਇਹ ਸਮਝ ਹੀ ਨਹੀਂ ਪੈਂਦੀ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Без Слова Гуру нет понимания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38614,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਸਬਦੁ ਵਜੈ ਦਿਨੁ ਰਾਤੀ ॥",
          "roman": "anhad sabad vajē din rātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰ) ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਦਿਨ ਰਾਤ ਇਕ-ਰਸ ਪ੍ਰਬਲ ਪ੍ਰਭਾਵ ਪਾਈ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Беззвучное Слово звучит день и ночь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38615,
          "is_rahao": false,
          "gurmukhi": "ਅਵਿਗਤ ਕੀ ਗਤਿ ਗੁਰਮੁਖਿ ਜਾਤੀ ॥",
          "roman": "avigat kī gat gurmukh jātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ। ਉਸ ਨੂੰ ਅਦ੍ਰਿਸ਼ਟ ਪ੍ਰਭੂ ਦੀ (ਸੇਵਾ-ਭਗਤੀ ਦੀ) ਸੂਝ ਆ ਜਾਂਦੀ ਹੈ ।"
            },
            "sahib_singh_ru": {
              "main": "Через Гуру познаётся состояние Невидимого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38616,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਜਾਨੀ ਜਾ ਸਬਦਿ ਪਛਾਨੀ ॥",
          "roman": "tau jānī jā sabad pachhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਸੂਝ ਮਨੁੱਖ ਨੂੰ ਤਦੋਂ ਹੀ ਆਉਂਦੀ ਹੈ ਜਦੋਂ ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਇਹ ਭੇਤ) ਪਛਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Это осознаётся через Слово Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38617,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਰਵਿ ਰਹਿਆ ਨਿਰਬਾਨੀ ॥੭॥",
          "roman": "eko rav rahiā nirbānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਵਾਸਨਾ-ਰਹਿਤ ਪ੍ਰਭੂ ਇਹੋ ਜਿਹਾ ਹੈ ਕਿ ਉਹ ਆਪ ਹੀ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог пронизывает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38618,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਮਾਧਿ ਸਹਜਿ ਮਨੁ ਰਾਤਾ ॥",
          "roman": "sunn samādh sahaj man rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ ਉਸ ਦਾ) ਮਨ ਉਸ ਇਕਾਗ੍ਰਤਾ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ਜਿਥੇ ਮਾਇਆ ਦੇ ਫੁਰਨਿਆਂ ਵਲੋਂ ਸਦਾ ਸੁੰਞ ਰਹਿੰਦੀ ਹੈ ਤੇ ਅਡੋਲ ਆਤਮਕ ਅਵਸਥਾ (ਦੇ ਰੰਗ) ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ум пребывает в глубокой тишине и устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38619,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਹਉ ਲੋਭਾ ਏਕੋ ਜਾਤਾ ॥",
          "roman": "taj haum lobhā eko jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਤੇ ਲੋਭ ਨੂੰ ਤਿਆਗ ਕੇ ਉਹ ਮਨੁੱਖ ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਹੀ ਡੂੰਘੀ ਸਾਂਝ ਪਾਈ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Отбросив эго и жадность, он познаёт Единого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38620,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚੇਲੇ ਅਪਨਾ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "gur chele apnā man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਹੋਏ ਸਿੱਖ ਦਾ ਆਪਣਾ ਮਨ ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਵਿਚ ਪਤੀਜ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ученик принимает учение Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38621,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੂਜਾ ਮੇਟਿ ਸਮਾਨਿਆ ॥੮॥੩॥",
          "roman": "nānak dūjā meṭ samāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਝਾਕ ਮਿਟਾ ਕੇ ਪਰਮਾਤਮਾ ਵਿਚ ਹੀ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੮॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! устранив двойственность, он растворяется в Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3355,
      "rahao_verse_id": 38628,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38622,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੧ ॥",
          "roman": "rāmkalī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38623,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਾ ਗਣਹਿ ਨ ਕਰਹਿ ਬੀਚਾਰੁ ॥",
          "roman": "sāhā gaṇeh na karah vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਤੂੰ (ਵਿਆਹ ਆਦਿਕ ਸਮਿਆਂ ਤੇ ਜਜਮਾਨਾਂ ਵਾਸਤੇ) ਸਭ ਲਗਨ ਮੁਹੂਰਤ ਗਿਣਦਾ ਹੈਂ, ਪਰ ਤੂੰ ਇਹ ਵਿਚਾਰ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Эй пандит! Ты рассчитываешь все благоприятные моменты для брака и прочего для своих заказчиков, но не задумываешься,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38624,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹੇ ਊਪਰਿ ਏਕੰਕਾਰੁ ॥",
          "roman": "sāhe ūpar ekankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਸ਼ੁਭ ਸਮਾਂ ਬਣਾਣ ਨਾਹ ਬਣਾਣ ਵਾਲਾ ਪਰਮਾਤਮਾ (ਆਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что создающим или не создающим благоприятное время является Сам Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38625,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰੁ ਮਿਲੈ ਸੋਈ ਬਿਧਿ ਜਾਣੈ ॥",
          "roman": "jis gur milē soī bidh jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪਏ ਉਹ ਜਾਣਦਾ ਹੈ (ਕਿ ਵਿਆਹ ਆਦਿਕ ਦਾ ਸਮਾ ਕਿਸ) ਢੰਗ (ਨਾਲ ਸ਼ੁਭ ਬਣ ਸਕਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, которому встречается Гуру, понимает способ, каким время становится благоприятным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38626,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਹੋਇ ਤ ਹੁਕਮੁ ਪਛਾਣੈ ॥੧॥",
          "roman": "gurmat hoey ta hukam pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਪ੍ਰਾਪਤ ਹੋ ਜਾਏ ਤਦੋਂ ਉਹ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ ਸਮਝ ਲੈਂਦਾ ਹੈ (ਤੇ ਰਜ਼ਾ ਨੂੰ ਸਮਝਣਾ ਹੀ ਸ਼ੁਭ ਮੁਹੂਰਤ ਦਾ ਮੂਲ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Когда человек получает наставление Гуру, тогда он понимает волю Бога, и понимание этой воли и есть основа истинного благоприятного времени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38627,
          "is_rahao": true,
          "gurmukhi": "ਝੂਠੁ ਨ ਬੋਲਿ ਪਾਡੇ ਸਚੁ ਕਹੀਐ ॥",
          "roman": "jhūṭh na bol pāṛe sach kahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! (ਆਪਣੀ ਆਜੀਵਕਾ ਦੀ ਖ਼ਾਤਰ ਜਜਮਾਨਾਂ ਨੂੰ ਪਤਿ-ਆਉਣ ਵਾਸਤੇ ਵਿਆਹ ਆਦਿਕ ਸਮਿਆਂ ਦੇ ਸ਼ੁਭ ਮੁਹੂਰਤ ਲੱਭਣ ਦਾ) ਝੂਠ ਨਾਹ ਬੋਲ। ਸੱਚ ਬੋਲਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эй пандит! Не говори ложь ради своей выгоды, чтобы угодить заказчикам, ищя благоприятные моменты. Следует говорить истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38628,
          "is_rahao": true,
          "gurmukhi": "ਹਉਮੈ ਜਾਇ ਸਬਦਿ ਘਰੁ ਲਹੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "haumē jāe sabad ghar lahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ (ਅੰਦਰ ਦੀ) ਹਉਮੈ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ ਤਦੋਂ ਉਹ ਘਰ ਲੱਭ ਪੈਂਦਾ ਹੈ (ਜਿਥੋਂ ਆਤਮਕ ਤੇ ਸੰਸਾਰਕ ਸਾਰੇ ਪਦਾਰਥ ਮਿਲਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда, соединяясь с Шабдом Гуру, исчезает Хоумэ, тогда находится тот дом, откуда приходят все духовные и мирские блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38629,
          "is_rahao": false,
          "gurmukhi": "ਗਣਿ ਗਣਿ ਜੋਤਕੁ ਕਾਂਡੀ ਕੀਨੀ ॥",
          "roman": "gaṇ gaṇ jotak kāṇḍī kīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪੰਡਿਤ) ਜੋਤਸ਼ (ਦੇ ਲੇਖੇ) ਗਿਣ ਗਿਣ ਕੇ (ਕਿਸੇ ਜਜਮਾਨ ਦੇ ਪੁੱਤਰ ਦੀ) ਜਨਮ ਪੱਤ੍ਰੀ ਬਣਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пандит, подсчитывая астрологические расчёты, составляет гороскоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38630,
          "is_rahao": false,
          "gurmukhi": "ਪੜੈ ਸੁਣਾਵੈ ਤਤੁ ਨ ਚੀਨੀ ॥",
          "roman": "paṛē suṇāvē tat na chīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋਤਸ਼ ਦਾ ਹਿਸਾਬ ਆਪ) ਪੜ੍ਹਦਾ ਹੈ ਤੇ (ਜਜਮਾਨ ਨੂੰ) ਸੁਣਾਂਦਾ ਹੈ ਪਰ ਅਸਲੀਅਤ ਨੂੰ ਨਹੀਂ ਪਛਾਣਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он читает и рассказывает другим, но не распознаёт сути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38631,
          "is_rahao": false,
          "gurmukhi": "ਸਭਸੈ ਊਪਰਿ ਗੁਰ ਸਬਦੁ ਬੀਚਾਰੁ ॥",
          "roman": "sabhsē ūpar gur sabad vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸ਼ੁਭ ਮੁਹੂਰਤ ਆਦਿਕ ਦੀਆਂ) ਸਾਰੀਆਂ ਵਿਚਾਰਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਵਿਚਾਰ ਇਹ ਹੈ ਕਿ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਮਨ ਵਿਚ ਵਸਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "Выше всех размышлений о благоприятных моментах есть размышление о Шабде Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38632,
          "is_rahao": false,
          "gurmukhi": "ਹੋਰ ਕਥਨੀ ਬਦਉ ਨ ਸਗਲੀ ਛਾਰੁ ॥੨॥",
          "roman": "hor kathnī badau na saglī chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਗੁਰ-ਸ਼ਬਦ ਦੇ ਟਾਕਰੇ ਤੇ ਸ਼ੁਭ ਮੁਹੂਰਤ ਤੇ ਜਨਮ-ਪੱਤ੍ਰੀ ਆਦਿਕ ਦੀ ਕਿਸੇ) ਹੋਰ ਗੱਲ ਦੀ ਪਰਵਾਹ ਨਹੀਂ ਕਰਦਾ, ਹੋਰ ਸਾਰੀਆਂ ਵਿਚਾਰਾਂ ਵਿਅਰਥ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Я не придаю значения никаким другим рассуждениям — всё остальное пусто."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38633,
          "is_rahao": false,
          "gurmukhi": "ਨਾਵਹਿ ਧੋਵਹਿ ਪੂਜਹਿ ਸੈਲਾ ॥",
          "roman": "nāveh dhovah pūjah sēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਿਤ!) ਤੂੰ (ਤੀਰਥ ਆਦਿਕ ਤੇ) ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈਂ (ਸਰੀਰ ਮਲ ਮਲ ਕੇ) ਧੋਂਦਾ ਹੈਂ, ਤੇ ਪੱਥਰ (ਦੇ ਦੇਵੀ ਦੇਵਤੇ) ਪੂਜਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты совершаешь омовения, очищаешь тело и поклоняешься камням,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38634,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਰਾਤੇ ਮੈਲੋ ਮੈਲਾ ॥",
          "roman": "bin har rāte mēlo mēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗੇ ਜਾਣ ਤੋਂ ਬਿਨਾ (ਮਨ ਵਿਕਾਰਾਂ ਨਾਲ) ਸਦਾ ਮੈਲਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но без окрашивания в любовь к Богу ум остаётся нечистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38635,
          "is_rahao": false,
          "gurmukhi": "ਗਰਬੁ ਨਿਵਾਰਿ ਮਿਲੈ ਪ੍ਰਭੁ ਸਾਰਥਿ ॥",
          "roman": "garab nivār milē prabh sārath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਿਤ! ਨਾਮ ਜਪ ਕੇ) ਅਹੰਕਾਰ ਦੂਰ ਕੀਤਿਆਂ (ਜੀਵਨ ਰਥ ਦਾ) ਰਥਵਾਹੀ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Удалив гордость, человек встречает Бога — управляющего колесницей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38636,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਪ੍ਰਾਨ ਜਪਿ ਹਰਿ ਕਿਰਤਾਰਥਿ ॥੩॥",
          "roman": "mukat prān jap har kirtārath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਜਿੰਦ ਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਦਿਵਾਣ ਵਾਲੇ ਤੇ ਜੀਵਨ ਸਫਲਾ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому повторяй Имя Бога, который освобождает душу и делает жизнь успешной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38637,
          "is_rahao": false,
          "gurmukhi": "ਵਾਚੈ ਵਾਦੁ ਨ ਬੇਦੁ ਬੀਚਾਰੈ ॥",
          "roman": "vāchē vād na bed vīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪੰਡਿਤ) ਵੇਦ (ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕਾਂ) ਨੂੰ (ਜੀਵਨ ਦੀ ਅਗਵਾਈ ਵਾਸਤੇ) ਨਹੀਂ ਵਿਚਾਰਦਾ, (ਅਰਥ ਤੇ ਕਰਮ ਕਾਂਡ ਆਦਿਕ ਦੀ) ਬਹਿਸ ਨੂੰ ਹੀ ਪੜ੍ਹਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пандит не размышляет над Ведами как руководством к жизни, а лишь изучает споры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38638,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਡੁਬੈ ਕਿਉ ਪਿਤਰਾ ਤਾਰੈ ॥",
          "roman": "āp ḍubē kiu pitrā tārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਦੀਆਂ ਵਿਕਾਰ-ਲਹਿਰਾਂ ਵਿਚ ਡੁੱਬਾ ਰਹਿੰਦਾ ਹੈ), ਜੇਹੜਾ ਮਨੁੱਖ ਆਪ ਡੁੱਬਿਆ ਰਹੇ ਉਹ ਆਪਣੇ (ਬੀਤ ਚੁਕੇ) ਬਜ਼ੁਰਗਾਂ ਨੂੰ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ) ਕਿਵੇਂ ਪਾਰ ਲੰਘਾ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Сам утопая, как он может переправить своих предков?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38639,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਬ੍ਰਹਮੁ ਚੀਨੈ ਜਨੁ ਕੋਇ ॥",
          "roman": "ghaṭ ghaṭ brahm chīnē jan koey",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਪਛਾਣਦਾ ਹੈ ਕਿ ਪਰਮਾਤਮਾ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек понимает, что Бог присутствует в каждом существе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38640,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮਿਲੈ ਤ ਸੋਝੀ ਹੋਇ ॥੪॥",
          "roman": "satgur milē ta sojhī hoey",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪਏ, ਉਸ ਨੂੰ ਇਹ ਸਮਝ ਆਉਂਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Когда человек встречает Гуру, тогда приходит это понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38641,
          "is_rahao": false,
          "gurmukhi": "ਗਣਤ ਗਣੀਐ ਸਹਸਾ ਦੁਖੁ ਜੀਐ ॥",
          "roman": "gaṇat gaṇīai sahsā dukh jīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਉਂ ਜਿਉਂ ਸ਼ੁਭ ਅਸ਼ੁਭ ਮੁਹੂਰਤਾਂ ਦੇ ਲੇਖੇ ਗਿਣਦੇ ਰਹੀਏ ਤਿਉਂ ਤਿਉਂ ਜਿੰਦ ਨੂੰ ਸਦਾ ਸਹਿਮ ਦਾ ਰੋਗ ਲੱਗਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Чем больше считать благоприятные и неблагоприятные моменты, тем больше душу мучает тревога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38642,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸਰਣਿ ਪਵੈ ਸੁਖੁ ਥੀਐ ॥",
          "roman": "gur kī saraṇ pavē sukh thīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ ਤਦੋਂ ਇਸ ਨੂੰ ਆਤਮਕ ਆਨੰਦ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек приходит в убежище Гуру, он обретает внутренний покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38643,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਅਪਰਾਧ ਸਰਣਿ ਹਮ ਆਇਆ ॥",
          "roman": "kar aparādh saraṇ ham āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਾਪ ਅਪਰਾਧ ਕਰ ਕੇ ਭੀ ਜਦੋਂ ਅਸੀਂ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਆਉਂਦੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Даже совершив ошибки, если мы приходим к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38644,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਹਰਿ ਭੇਟੇ ਪੁਰਬਿ ਕਮਾਇਆ ॥੫॥",
          "roman": "gur har bheṭe purab kamāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਪਰਮਾਤਮਾ ਸਾਡੇ ਪੂਰਬਲੇ ਕਰਮਾਂ ਅਨੁਸਾਰ ਗੁਰੂ ਨੂੰ ਮਿਲਾ ਦੇਂਦਾ ਹੈ (ਤੇ ਗੁਰੂ ਸਹੀ ਜੀਵਨ-ਰਾਹ ਵਿਖਾਂਦਾ ਹੈ) ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "то по прежним заслугам Бог приводит нас к Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38645,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਰਣਿ ਨ ਆਈਐ ਬ੍ਰਹਮੁ ਨ ਪਾਈਐ ॥",
          "roman": "gur saraṇ na āīai brahm na pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤਕ ਗੁਰੂ ਦੀ ਸਰਨ ਨਾਹ ਆਵੀਏ ਤਦ ਤਕ ਪਰਮਾਤਮਾ ਨਹੀਂ ਮਿਲਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек не приходит в убежище Гуру, он не находит Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38646,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਿ ਭੁਲਾਈਐ ਜਨਮਿ ਮਰਿ ਆਈਐ ॥",
          "roman": "bharam bhulāīai janam mar āīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਟਕਣਾ ਵਿਚ ਕੁਰਾਹੇ ਪੈ ਕੇ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਕੇ ਮੁੜ ਮੁੜ ਜਨਮ ਵਿਚ ਆਉਂਦੇ ਰਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Заблуждаясь, он снова и снова рождается и умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38647,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਦਰਿ ਬਾਧਉ ਮਰੈ ਬਿਕਾਰੁ ॥",
          "roman": "jam dar bādhau marē bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਬਿਨਾ ਜੀਵ) ਜਮ ਦੇ ਦਰ ਤੇ ਬੱਧਾ ਹੋਇਆ ਵਿਅਰਥ ਹੀ ਆਤਮਕ ਮੌਤੇ ਮਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Без Гуру человек связан у врат Ямы и умирает в пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38648,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਰਿਦੈ ਨਾਮੁ ਨ ਸਬਦੁ ਅਚਾਰੁ ॥੬॥",
          "roman": "nā ridē nām na sabad achār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਨਾਹ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ ਨਾਹ ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਵੱਸਦਾ ਹੈ, ਨਾਹ ਹੀ ਉਸ ਦਾ ਚੰਗਾ ਆਚਰਨ ਬਣਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "В его сердце нет ни Имени Бога, ни Шабда, ни правильного поведения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38649,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਪਾਧੇ ਪੰਡਿਤ ਮਿਸਰ ਕਹਾਵਹਿ ॥",
          "roman": "ik pādhe paṇḍit misar kahāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ (ਕੁਲੀਨ ਤੇ ਵਿਦਵਾਨ ਬ੍ਰਾਹਮਣ) ਆਪਣੇ ਆਪ ਨੂੰ ਪਾਂਧੇ ਪੰਡਿਤ ਮਿਸਰ ਅਖਵਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Многие называют себя учёными пандитами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38650,
          "is_rahao": false,
          "gurmukhi": "ਦੁਬਿਧਾ ਰਾਤੇ ਮਹਲੁ ਨ ਪਾਵਹਿ ॥",
          "roman": "dubidhā rāte mahal na pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਹੋਰ ਆਸਰੇ ਦੀ ਝਾਕ ਵਿਚ ਗ਼ਲਤਾਨ ਰਹਿੰਦੇ ਹਨ, ਪਰਮਾਤਮਾ ਦਾ ਦਰ-ਘਰ ਨਹੀਂ ਲੱਭ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "но, погружённые в двойственность, не находят обители Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
