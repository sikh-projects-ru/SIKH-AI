{
  "ang": 905,
  "shabads": [
    {
      "shabad_id": 3355,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38651,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰ ਪਰਸਾਦੀ ਨਾਮੁ ਅਧਾਰੁ ॥",
          "roman": "jis gur parsādī nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਮਿਲ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто по милости Гуру получил Имя Бога как опору,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38652,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮਧੇ ਕੋ ਜਨੁ ਆਪਾਰੁ ॥੭॥",
          "roman": "koṭ madhē ko jan āpār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ) ਕ੍ਰੋੜਾਂ ਵਿਚੋਂ ਕੋਈ ਉਹ ਬੰਦਾ ਅਦੁਤੀ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "среди миллионов — редчайший человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38653,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਬੁਰਾ ਭਲਾ ਸਚੁ ਏਕੈ ॥",
          "roman": "ek burā bhalā sach ekē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! (ਜਗਤ ਵਿਚ) ਚਾਹੇ ਕੋਈ ਭਲਾ ਹੈ ਚਾਹੇ ਬੁਰਾ ਹੈ ਹਰੇਕ ਵਿਚ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਹੀ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Будь человек хорош или плох — в каждом присутствует один Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38654,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝੁ ਗਿਆਨੀ ਸਤਗੁਰ ਕੀ ਟੇਕੈ ॥",
          "roman": "būjh giānī satgur kī ṭekē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਗਿਆਨਵਾਨ ਬਣਨਾ ਹੈ ਤਾਂ ਗੁਰੂ ਦਾ ਆਸਰਾ-ਪਰਨਾ ਲੈ ਕੇ ਇਹ ਗੱਲ ਸਮਝ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если хочешь быть мудрым, пойми это, опираясь на Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38655,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਵਿਰਲੀ ਏਕੋ ਜਾਣਿਆ ॥",
          "roman": "gurmukh virlī eko jāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਵਿਰਲੇ ਬੰਦਿਆਂ ਨੇ ਹਰ ਥਾਂ ਇਕ ਪਰਮਾਤਮਾ ਨੂੰ ਹੀ ਵਿਆਪਕ ਸਮਝਿਆ ਹੈ ਜੇਹੜੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Редкие гурмукхи осознали одного Бога во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38656,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣੁ ਜਾਣਾ ਮੇਟਿ ਸਮਾਣਿਆ ॥੮॥",
          "roman": "āvaṇ jāṇā meṭ samāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰ-ਸਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਉਹ ਆਪਣਾ ਜਨਮ ਮਰਨ ਮਿਟਾ ਕੇ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਰਹਿੰਦੇ ਹਨ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Они устранили круг рождения и смерти и слились с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38657,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕੈ ਹਿਰਦੈ ਏਕੰਕਾਰੁ ॥",
          "roman": "jin kē hirdē ekankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У тех, в чьём сердце пребывает Один Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38658,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਗੁਣੀ ਸਾਚਾ ਬੀਚਾਰੁ ॥",
          "roman": "sarab guṇī sāchā vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵਾਂ ਦਾ ਮਾਲਕ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਉਹਨਾਂ ਦੀ ਸੁਰਤ ਦਾ ਸਦਾ ਨਿਸ਼ਾਨਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь всех существ становится постоянным центром их внимания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38659,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਭਾਣੈ ਕਰਮ ਕਮਾਵੈ ॥",
          "roman": "gur kē bhāṇē karam kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰ ਕੇ (ਆਪਣੇ) ਸਾਰੇ ਕੰਮ ਕਰਦਾ ਹੈ (ਤੇ ਸ਼ੁਭ ਅਸ਼ੁਭ ਮੁਹੂਰਤਾਂ ਦੇ ਭਰਮ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ),"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто действует в соответствии с волей Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38660,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੇ ਸਾਚਿ ਸਮਾਵੈ ॥੯॥੪॥",
          "roman": "nānak sāche sāch samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸਦਾ-ਥਿਰ ਪਰਮਾਤਮਾ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ (ਤੇ ਉਸ ਨੂੰ ਆਤਮਕ ਤੇ ਸੰਸਾਰਕ ਪਦਾਰਥ ਉਸ ਦਰ ਤੋਂ ਮਿਲਦੇ ਰਹਿੰਦੇ ਹਨ) ॥੯॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, он сливается с вечным Истинным Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3356,
      "rahao_verse_id": 38666,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38661,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੧ ॥",
          "roman": "rāmkalī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38662,
          "is_rahao": false,
          "gurmukhi": "ਹਠੁ ਨਿਗ੍ਰਹੁ ਕਰਿ ਕਾਇਆ ਛੀਜੈ ॥",
          "roman": "haṭh nigrah kar kāiā chhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਨੂੰ ਇਕਾਗ੍ਰ੍ਰ ਕਰਨ ਵਾਸਤੇ ਧੱਕੇ ਨਾਲ ਸਰੀਰ ਨੂੰ ਔਖਿਆਂ ਕੀਤਿਆਂ, ਮਨ ਦੇ ਫੁਰਨਿਆਂ ਨੂੰ ਬਦੋ ਬਦੀ ਰੋਕਣ ਦੇ ਜਤਨ ਕਰਨ ਨਾਲ, ਸਰੀਰ ਹੀ ਦੁਖੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Чтобы сосредоточить ум, если силой истязать тело и насильно подавлять мысли ума, страдает только тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38663,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤੁ ਤਪਨੁ ਕਰਿ ਮਨੁ ਨਹੀ ਭੀਜੈ ॥",
          "roman": "varat tapan kar man nahī bhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਰਤ ਰੱਖਣ ਨਾਲ, ਤਪ ਤਪਣ ਨਾਲ (ਇਹਨਾਂ ਕਸ਼ਟਾਂ ਦਾ) ਮਨ ਉਤੇ ਅਸਰ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "От постов и аскезы ум не пропитывается (этими страданиями не изменяется)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38664,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਸਰਿ ਅਵਰੁ ਨ ਪੂਜੈ ॥੧॥",
          "roman": "rām nām sar avar na pūjē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਠ ਨਾਲ ਕੀਤਾ ਹੋਇਆ) ਕੋਈ ਭੀ ਕਰਮ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Никакое действие не может сравниться с памятованием Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38665,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਸੇਵਿ ਮਨਾ ਹਰਿ ਜਨ ਸੰਗੁ ਕੀਜੈ ॥",
          "roman": "gur sev manā har jan sang kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਗੁਰੂ ਦੀ (ਦੱਸੀ) ਸੇਵਾ ਕਰ, ਤੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Служи Гуру и пребывай в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38666,
          "is_rahao": true,
          "gurmukhi": "ਜਮੁ ਜੰਦਾਰੁ ਜੋਹਿ ਨਹੀ ਸਾਕੈ ਸਰਪਨਿ ਡਸਿ ਨ ਸਕੈ ਹਰਿ ਕਾ ਰਸੁ ਪੀਜੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jam jandār joh nahī sākē sarpan das na sakē har kā ras pījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਰਸ ਪੀ, (ਇਸ ਤਰ੍ਹਾਂ) ਭਿਆਨਕ ਜਮ ਪੋਹ ਨਹੀਂ ਸਕੇਗਾ ਅਤੇ ਮਾਇਆ-ਸਪਣੀ (ਮੋਹ ਦਾ) ਡੰਗ ਮਾਰ ਨਹੀਂ ਸਕੇਗੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Пей нектар Имени Бога — тогда Яма не сможет коснуться, и змея майи не сможет ужалить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38667,
          "is_rahao": false,
          "gurmukhi": "ਵਾਦੁ ਪੜੈ ਰਾਗੀ ਜਗੁ ਭੀਜੈ ॥",
          "roman": "vād paṛē rāgī jag bhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਧਾਰਮਿਕ ਚਰਚਾ (ਦੇ ਪੁਸਤਕ) ਪੜ੍ਹਦਾ ਹੈ, ਦੁਨੀਆ ਦੇ ਰੰਗ-ਤਮਾਸ਼ਿਆਂ ਵਿਚ ਹੀ ਖ਼ੁਸ਼ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мир читает религиозные споры и наслаждается внешними развлечениями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38668,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਗੁਣ ਬਿਖਿਆ ਜਨਮਿ ਮਰੀਜੈ ॥",
          "roman": "trē guṇ bikhiyā janam marījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਤ੍ਰੈ-ਗੁਣੀ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪੈਂਦਾ ਹੈ (ਉਂਞ ਇਸ ਚਰਚਾ ਆਦਿਕ ਨੂੰ ਧਾਰਮਿਕ ਕੰਮ ਸਮਝਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "И, попав в сети трёх гун майи, вращается в цикле рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38669,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਦੂਖੁ ਸਹੀਜੈ ॥੨॥",
          "roman": "rām nām bin dūkh sahījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਦੁੱਖ ਹੀ ਸਹਾਰਨਾ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога приходится терпеть страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38670,
          "is_rahao": false,
          "gurmukhi": "ਚਾੜਸਿ ਪਵਨੁ ਸਿੰਘਾਸਨੁ ਭੀਜੈ ॥",
          "roman": "chāṛas pavan siṅghāsan bhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਠ-ਜੋਗੀ ਸੁਆਸ (ਦਸਮ ਦੁਆਰ ਵਿਚ) ਚਾੜ੍ਹਦਾ ਹੈ (ਇਤਨੀ ਮੇਹਨਤ ਕਰਦਾ ਹੈ ਕਿ ਪਸੀਨੇ ਨਾਲ ਉਸ ਦਾ) ਸਿੰਘਾਸਨ ਭੀ ਭਿੱਜ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Хатха-йог поднимает дыхание и так трудится, что даже его сиденье пропитывается потом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38671,
          "is_rahao": false,
          "gurmukhi": "ਨਿਉਲੀ ਕਰਮ ਖਟੁ ਕਰਮ ਕਰੀਜੈ ॥",
          "roman": "niulī karam khaṭ karam karījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਂਦਰਾਂ ਸਾਫ਼ ਰੱਖਣ ਲਈ) ਨਿਉਲੀ ਕਰਮ ਤੇ (ਹਠ ਜੋਗ ਦੇ) ਛੇ ਕਰਮ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он выполняет очистительные практики и шесть йогических действий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38672,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਬਿਰਥਾ ਸਾਸੁ ਲੀਜੈ ॥੩॥",
          "roman": "rām nām bin birthā sās lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਵਿਅਰਥ ਜੀਵਨ ਜੀਉਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но без Имени Бога жизнь проходит напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38673,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪੰਚ ਅਗਨਿ ਕਿਉ ਧੀਰਜੁ ਧੀਜੈ ॥",
          "roman": "antar panch agan kiō dhīraj dhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਚਿਰ ਕਾਮਾਦਿਕ ਪੰਜ ਵਿਕਾਰਾਂ ਦੀ ਅੱਗ ਅੰਤਰ ਆਤਮੇ ਭੜਕ ਰਹੀ ਹੋਵੇ, ਉਤਨਾ ਚਿਰ ਮਨ ਧੀਰਜ ਨਹੀਂ ਧਾਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Пока внутри горит огонь пяти пороков, ум не может обрести покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38674,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਚੋਰੁ ਕਿਉ ਸਾਦੁ ਲਹੀਜੈ ॥",
          "roman": "antar chor kiō sāḍ lahījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਚਿਰ ਮੋਹ-ਚੋਰ ਅੰਦਰ ਵੱਸ ਰਿਹਾ ਹੈ ਆਤਮਕ ਆਨੰਦ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Пока внутри живёт вор-мох, невозможно обрести духовную радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38675,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਇ ਕਾਇਆ ਗੜੁ ਲੀਜੈ ॥੪॥",
          "roman": "gurmukh hoi kāiā gaṛ lījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਇਸ ਸਰੀਰ-ਕਿਲ੍ਹੇ ਨੂੰ ਜਿੱਤੇ (ਇਸ ਵਿਚ ਆਕੀ ਹੋਇਆ ਮਨ ਵੱਸ ਵਿਚ ਆ ਜਾਇਗਾ ਤੇ ਆਤਮਕ ਆਨੰਦ ਮਿਲੇਗਾ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Став гурумухом, победи крепость тела (и обуздай ум)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38676,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਮੈਲੁ ਤੀਰਥ ਭਰਮੀਜੈ ॥",
          "roman": "antar mēl tīrath bharmījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮਨ ਵਿਚ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ) ਮੈਲ ਟਿਕੀ ਰਹੇ, ਤੀਰਥਾਂ ਤੇ (ਇਸ਼ਨਾਨ ਲਈ) ਭੌਂਦੇ ਫਿਰੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если внутри остаётся грязь, то даже скитания по тirthам бесполезны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38677,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਨਹੀ ਸੂਚਾ ਕਿਆ ਸੋਚ ਕਰੀਜੈ ॥",
          "roman": "man nahī sūchā kiā soch karījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਮਨ ਸੁੱਚਾ ਨਹੀਂ ਹੋ ਸਕਦਾ (ਤੀਰਥ-) ਇਸ਼ਨਾਨ ਦਾ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Так ум не очищается — омовения не приносят пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38678,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਤੁ ਪਇਆ ਦੋਸੁ ਕਾ ਕਉ ਦੀਜੈ ॥੫॥",
          "roman": "kirat pēā dos kā kau dījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪਿਛਲੇ ਕੀਤੇ ਕਰਮਾਂ ਦੇ ਸੰਸਕਾਰਾਂ ਦਾ ਇਕੱਠ (ਗ਼ਲਤ ਰਸਤੇ ਵਲ ਹੀ ਪ੍ਰੇਰਨਾ ਕਰੀ ਜਾਂਦਾ ਹੈ, ਇਸ ਵਾਸਤੇ) ਕਿਸੇ ਨੂੰ ਦੋਸ਼ੀ ਭੀ ਨਹੀਂ ਠਹਿਰਾਇਆ ਜਾ ਸਕਦਾ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Карма прошлого побуждает — потому никого нельзя обвинить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38679,
          "is_rahao": false,
          "gurmukhi": "ਅੰਨੁ ਨ ਖਾਹਿ ਦੇਹੀ ਦੁਖੁ ਦੀਜੈ ॥",
          "roman": "ann na khāh dehī dukh dījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਬੰਦੇ ਅੰਨ ਨਹੀਂ ਖਾਂਦੇ (ਇਸ ਤਰ੍ਹਾਂ ਉਹ ਕੋਈ ਆਤਮਕ ਲਾਭ ਤਾਂ ਨਹੀਂ ਖੱਟਦੇ) ਸਰੀਰ ਨੂੰ ਹੀ ਕਸ਼ਟ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто не едят пищу, лишь причиняют страдание телу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38680,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਗਿਆਨ ਤ੍ਰਿਪਤਿ ਨਹੀ ਥੀਜੈ ॥",
          "roman": "bin gur giān tripat nahī thījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਤੋਂ ਮਿਲੇ ਗਿਆਨ ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਵਲੋਂ ਵਿਕਾਰਾਂ) ਤ੍ਰਿਪਤੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Без знания от Гуру не достигается удовлетворение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38681,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਜਨਮੈ ਜਨਮਿ ਮਰੀਜੈ ॥੬॥",
          "roman": "manmukh janmē janam marījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ ਜੰਮਦਾ ਹੈ ਮਰਦਾ ਹੈ, ਜੰਮਦਾ ਹੈ ਮਰਦਾ ਹੈ (ਉਸ ਦਾ ਇਹ ਗੇੜ ਤੁਰਿਆ ਰਹਿੰਦਾ ਹੈ) ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Манмукх снова и снова рождается и умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38682,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਪੂਛਿ ਸੰਗਤਿ ਜਨ ਕੀਜੈ ॥",
          "roman": "satgur pūchh sangat jan kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਲੈ ਕੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Следует принять наставление Гуру и пребывать в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38683,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਹਰਿ ਰਾਚੈ ਨਹੀ ਜਨਮਿ ਮਰੀਜੈ ॥",
          "roman": "man har rāchē nahī janam marījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ) ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ, ਤੇ ਇਸ ਤਰ੍ਹਾਂ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਵਿਆਪਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда ум соединяется с Богом и выходит из круга рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38684,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਕਿਆ ਕਰਮੁ ਕੀਜੈ ॥੭॥",
          "roman": "rām nām bin kiā karam kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਾਹ ਸਿਮਰਿਆ, ਤਾਂ ਕਿਸੇ ਹੋਰ ਹਠ-ਕਰਮ ਦਾ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੁੰਦਾ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога никакие действия не приносят пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38685,
          "is_rahao": false,
          "gurmukhi": "ਊਂਦਰ ਦੂੰਦਰ ਪਾਸਿ ਧਰੀਜੈ ॥",
          "roman": "ūndar dūndar pās dharījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੂਹੇ ਵਾਂਗ ਅੰਦਰੋ ਅੰਦਰ ਸ਼ੋਰ ਮਚਾਣ ਵਾਲੇ ਮਨ ਦੇ ਸੰਕਲਪ ਵਿਕਲਪ ਅੰਦਰੋਂ ਕੱਢ ਦੇਣੇ ਚਾਹੀਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Внутренние шумные колебания ума следует отбросить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38686,
          "is_rahao": false,
          "gurmukhi": "ਧੁਰ ਕੀ ਸੇਵਾ ਰਾਮੁ ਰਵੀਜੈ ॥",
          "roman": "dhur kī sevā rām ravījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸਿਮਰਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ, ਇਹੀ ਹੈ ਧੁਰੋਂ ਮਿਲੀ ਸੇਵਾ (ਜੋ ਮਨੁੱਖ ਨੇ ਕਰਨੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Памятование Имени — это истинное служение, дарованное свыше."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38687,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਮਿਲੈ ਕਿਰਪਾ ਪ੍ਰਭ ਕੀਜੈ ॥੮॥੫॥",
          "roman": "nānak nām milē kirpā prabh kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਅਗੇ ਅਰਦਾਸ ਕਰ-) ਹੇ ਪ੍ਰਭੂ! ਮੇਹਰ ਕਰ, ਮੈਨੂੰ ਤੇਰੇ ਨਾਮ ਦੀ ਦਾਤ ਮਿਲੇ ॥੮॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись: Господи, даруй мне Имя по Своей милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3357,
      "rahao_verse_id": 38694,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38688,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੧ ॥",
          "roman": "rāmkalī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38689,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਉਤਭੁਜੁ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "antar utbhuj avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਪਰਮਾਤਮਾ ਐਸਾ ਹੈ ਕਿ) ਸ੍ਰਿਸ਼ਟੀ ਦੀ ਉਤਪੱਤੀ (ਦੀ ਤਾਕਤ) ਉਸ ਦੇ ਆਪਣੇ ਅੰਦਰ ਹੀ ਹੈ (ਉਤਪੱਤੀ ਕਰਨ ਵਾਲਾ) ਹੋਰ ਕੋਈ ਭੀ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сила творения находится внутри Него — нет иного творца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38690,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਹੀਐ ਸੋ ਪ੍ਰਭ ਤੇ ਹੋਈ ॥",
          "roman": "jo kahīai so prabh te hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਭੀ ਚੀਜ਼ ਦਾ ਨਾਮ ਲਿਆ ਜਾਏ ਉਹ ਪਰਮਾਤਮਾ ਤੋਂ ਹੀ ਪੈਦਾ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что существует, произошло от Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38691,
          "is_rahao": false,
          "gurmukhi": "ਜੁਗਹ ਜੁਗੰਤਰਿ ਸਾਹਿਬੁ ਸਚੁ ਸੋਈ ॥",
          "roman": "jugah jugantar sāhib sach soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਾਲਕ ਜੁਗਾਂ ਜੁਗਾਂ ਵਿਚ ਸਦਾ-ਥਿਰ ਚਲਿਆ ਆ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он — тот же Истинный Господь во все эпохи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38692,
          "is_rahao": false,
          "gurmukhi": "ਉਤਪਤਿ ਪਰਲਉ ਅਵਰੁ ਨ ਕੋਈ ॥੧॥",
          "roman": "utpat parlau avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਦੀ ਉਤਪੱਤੀ ਤੇ ਜਗਤ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ (ਉਸ ਤੋਂ ਬਿਨਾ) ਕੋਈ ਹੋਰ ਨਹੀਂ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Никто кроме Него не создаёт и не разрушает мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38693,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਮੇਰਾ ਠਾਕੁਰੁ ਗਹਿਰ ਗੰਭੀਰੁ ॥",
          "roman": "aisā merā ṭhākur gahir gambhīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਡਾ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਬੜਾ ਅਥਾਹ ਹੈ ਤੇ ਵੱਡੇ ਜਿਗਰੇ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Господь глубок и величественен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38694,
          "is_rahao": true,
          "gurmukhi": "ਜਿਨਿ ਜਪਿਆ ਤਿਨ ਹੀ ਸੁਖੁ ਪਾਇਆ ਹਰਿ ਕੈ ਨਾਮਿ ਨ ਲਗੈ ਜਮ ਤੀਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jin japiā tin hī sukh pāiā har kē nām na lagē jam tīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਭੀ ਮਨੁੱਖ ਨੇ (ਉਸ ਦਾ ਨਾਮ) ਜਪਿਆ ਹੈ ਉਸੇ ਨੇ ਹੀ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਹੈ। ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜਿਆਂ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਪੋਂਹਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто повторяет Имя, обретает блаженство, и страх смерти его не касается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38695,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਰਤਨੁ ਹੀਰਾ ਨਿਰਮੋਲੁ ॥",
          "roman": "nām ratan hīrā nirmol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਇਕ ਐਸਾ) ਰਤਨ ਹੈ ਹੀਰਾ ਹੈ, ਜਿਸ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ (ਜੋ ਕਿਸੇ ਕੀਮਤ ਤੋਂ ਨਹੀਂ ਮਿਲ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — бесценный драгоценный камень."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38696,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਾ ਸਾਹਿਬੁ ਅਮਰੁ ਅਤੋਲੁ ॥",
          "roman": "sāchā sāhib amar atol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਮਾਲਕ ਹੈ ਉਹ ਕਦੇ ਮਰਨ ਵਾਲਾ ਨਹੀਂ ਹੈ, ਉਸ ਦੇ ਵਡੱਪਣ ਨੂੰ ਤੋਲਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Господь вечен и неизмерим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38697,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹਵਾ ਸੂਚੀ ਸਾਚਾ ਬੋਲੁ ॥",
          "roman": "jihvā sūchī sāchā bol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਭ (ਉਸ ਅਮਰ ਅਡੋਲ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ ਸਾਲਾਹ ਦਾ) ਬੋਲ ਬੋਲਦੀ ਹੈ ਉਹ ਸੁੱਚੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Та речь чиста, которая говорит истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38698,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਦਰਿ ਸਾਚਾ ਨਾਹੀ ਰੋਲੁ ॥੨॥",
          "roman": "ghar dar sāchā nāhī rol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨ ਵਾਲੇ ਬੰਦੇ ਨੂੰ ਅੰਦਰ ਬਾਹਰ ਹਰ ਥਾਂ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਹੀ ਦਿੱਸਦਾ ਹੈ, ਇਸ ਬਾਰੇ ਉਸ ਨੂੰ ਕੋਈ ਭੁਲੇਖਾ ਨਹੀਂ ਲੱਗਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Повсюду он видит только Истину и не пребывает в сомнении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38699,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਬਨ ਮਹਿ ਬੈਸਹਿ ਡੂਗਰਿ ਅਸਥਾਨੁ ॥",
          "roman": "ik ban meh bēsah ḍūgar asthān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਬੰਦੇ (ਗ੍ਰਿਹਸਤ ਤਿਆਗ ਕੇ) ਜੰਗਲਾਂ ਵਿਚ ਜਾ ਬੈਠਦੇ ਹਨ, ਪਹਾੜ ਵਿਚ (ਗੁਫ਼ਾ ਆਦਿਕ) ਥਾਂ (ਬਣਾ ਕੇ) ਬੈਠਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Некоторые уходят в леса и горы, живут в пещерах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38700,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਬਿਸਾਰਿ ਪਚਹਿ ਅਭਿਮਾਨੁ ॥",
          "roman": "nām bisār pachah abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਇਸ ਉੱਦਮ ਦਾ) ਮਾਣ (ਭੀ) ਕਰਦੇ ਹਨ, ਪਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵਿਸਾਰ ਕੇ ਉਹ ਖ਼ੁਆਰ (ਹੀ) ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Гордясь этим, они забывают Имя и страдают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38701,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕਿਆ ਗਿਆਨ ਧਿਆਨੁ ॥",
          "roman": "nām binā kiā giān dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਵਾਂਜੇ ਰਹਿ ਕੇ ਕੋਈ ਗਿਆਨ-ਚਰਚਾ ਤੇ ਕੋਈ ਸਮਾਧੀ ਕਿਸੇ ਅਰਥ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Без Имени знание и медитация бесполезны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38702,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਵਹਿ ਦਰਗਹਿ ਮਾਨੁ ॥੩॥",
          "roman": "gurmukh pāvah dargeh mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਰਸਤੇ ਤੁਰਦੇ ਹਨ (ਤੇ ਨਾਮ ਜਪਦੇ ਹਨ) ਉਹ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ ਪਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Гурумухи получают почёт в присутствии Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38703,
          "is_rahao": false,
          "gurmukhi": "ਹਠੁ ਅਹੰਕਾਰੁ ਕਰੈ ਨਹੀ ਪਾਵੈ ॥",
          "roman": "haṭh ahankār karē nahī pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਇਕਾਗ੍ਰਤਾ ਆਦਿਕ ਵਾਸਤੇ ਸਰੀਰ ਉਤੇ ਕੋਈ) ਧੱਕਾ-ਜ਼ੋਰ ਕਰਦਾ ਹੈ (ਤੇ ਇਸ ਉੱਦਮ ਦਾ) ਮਾਣ (ਭੀ) ਕਰਦਾ ਹੈ, ਉਹ ਪਰਮਾਤਮਾ ਨੂੰ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто практикует с насилием и гордостью, не достигает Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38704,
          "is_rahao": false,
          "gurmukhi": "ਪਾਠ ਪੜੈ ਲੇ ਲੋਕ ਸੁਣਾਵੈ ॥",
          "roman": "pāṭh paṛē le lok suṇāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ (ਲੋਕ-ਵਿਖਾਵੇ ਦੀ ਖ਼ਾਤਰ) ਧਾਰਮਿਕ ਪੁਸਤਕਾਂ ਪੜ੍ਹਦਾ ਹੈ, ਪੁਸਤਕਾਂ ਲੈ ਕੇ ਲੋਕਾਂ ਨੂੰ (ਹੀ) ਸੁਣਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто читает писания ради показухи, лишь демонстрирует их людям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
