{
  "ang": 941,
  "shabads": [
    {
      "shabad_id": 3419,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40108,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬੂਝੈ ਜਿਸੁ ਆਪਿ ਬੁਝਾਏ ਗੁਰ ਕੈ ਸਬਦਿ ਸੁ ਮੁਕਤੁ ਭਇਆ ॥",
          "roman": "so būjhē jis āp bujhāe gur kē sabad so mukat bhēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Понимает тот, кому Он сам даёт понять; через Шабд Гуру он становится свободным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40109,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾਰੇ ਤਾਰਣਹਾਰਾ ਹਉਮੈ ਦੂਜਾ ਪਰਹਰਿਆ ॥੨੫॥",
          "roman": "Nānak tāre tāraṇhārā haumē dūjā parhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: Спасающий сам переправляет; Хоумэ и двойственность тогда отбрасываются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40110,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਭੂਲੈ ਜਮ ਕੀ ਕਾਣਿ ॥",
          "roman": "manmukh bhūlē jam kī kāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт за своим умом, сбивается с верного пути и становится подвластным Джаму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40111,
          "is_rahao": false,
          "gurmukhi": "ਪਰ ਘਰੁ ਜੋਹੈ ਹਾਣੇ ਹਾਣਿ ॥",
          "roman": "par ghar johē hāṇe hāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он засматривается на чужой дом, и в этом получает только ущерб за ущербом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40112,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਭਰਮਿ ਭਵੈ ਬੇਬਾਣਿ ॥",
          "roman": "manmukh bharam bhavē bebāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх, пребывая в заблуждении, будто блуждает в лесу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40113,
          "is_rahao": false,
          "gurmukhi": "ਵੇਮਾਰਗਿ ਮੂਸੈ ਮੰਤ੍ਰਿ ਮਸਾਣਿ ॥",
          "roman": "vē-mārag mūsē mantra masāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сойдя на неверный путь, он оказывается обманутым, как человек, читающий мантры на месте кремации и увлечённый дурным направлением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40114,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਨ ਚੀਨੈ ਲਵੈ ਕੁਬਾਣਿ ॥",
          "roman": "sabad na chīnē lavē kubāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не распознаёт Шабд Гуру, не ценит его и произносит дурные слова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40115,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚਿ ਰਤੇ ਸੁਖੁ ਜਾਣਿ ॥੨੬॥",
          "roman": "Nānak sāch rate sukh jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: знай, что покой обрёл тот, кто окрашен в Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3420,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40116,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਕਾ ਭਉ ਪਾਵੈ ॥",
          "roman": "gurmukh sāche kā bhau pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх утверждает в сердце благоговейный страх перед Истинным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40117,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਬਾਣੀ ਅਘੜੁ ਘੜਾਵੈ ॥",
          "roman": "gurmukh bāṇī aghaṛ ghaṛāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Бани Гуру гурмукх приводит неукрощённый ум в должную форму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40118,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਿਰਮਲ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥",
          "roman": "gurmukh nirmal har guṇ gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх воспевает славу чистого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40119,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਵਿਤ੍ਰੁ ਪਰਮ ਪਦੁ ਪਾਵੈ ॥",
          "roman": "gurmukh pavitar param pad pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так он достигает чистого и высшего духовного состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40120,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰੋਮਿ ਰੋਮਿ ਹਰਿ ਧਿਆਵੈ ॥",
          "roman": "gurmukh rom rom har dhiāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх всем телом и всей душой помнит Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40121,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਾਚਿ ਸਮਾਵੈ ॥੨੭॥",
          "roman": "Nānak gurmukh sāch samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: через преданность гурмукх остаётся слитым с вечно пребывающим Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40122,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਬੇਦ ਬੀਚਾਰੀ ॥",
          "roman": "gurmukh parchē bed bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обретает глубокую связь с Гуру, становится словно знатоком Вед и уже не нуждается в них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40123,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਤਰੀਐ ਤਾਰੀ ॥",
          "roman": "gurmukh parchē tarīē tārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через глубокую связь с Гуру переправляются через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40124,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਸੁ ਸਬਦਿ ਗਿਆਨੀ ॥",
          "roman": "gurmukh parchē so sabad giānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через такую связь и через Гур-Шабд человек становится познавшим Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40125,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਚੈ ਅੰਤਰ ਬਿਧਿ ਜਾਨੀ ॥",
          "roman": "gurmukh parchē antar bidh jānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он начинает понимать внутреннее состояние и внутренний порядок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40126,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਈਐ ਅਲਖ ਅਪਾਰੁ ॥",
          "roman": "gurmukh pāīai alakh apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обратившись к Гуру, обретают невидимого и бесконечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40127,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮੁਕਤਿ ਦੁਆਰੁ ॥੨੮॥",
          "roman": "Nānak gurmukh mukat duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: только через Гуру находится дверь освобождения от Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3421,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40128,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਅਕਥੁ ਕਥੈ ਬੀਚਾਰਿ ॥",
          "roman": "gurmukh akath kathē bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идущий путём Гуру через данное Гуру размышление воспевает Того, чей истинный облик невозможно выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40129,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਿਬਹੈ ਸਪਰਵਾਰਿ ॥",
          "roman": "gurmukh nibhē saparvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой гурмукх, даже живя в семье, успешно проходит игру жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40130,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਪੀਐ ਅੰਤਰਿ ਪਿਆਰਿ ॥",
          "roman": "gurmukh japīai antar piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только обратившись к Гуру, можно с любовью в сердце повторять и помнить Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40131,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਈਐ ਸਬਦਿ ਅਚਾਰਿ ॥",
          "roman": "gurmukh pāīai sabad achār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Гур-Шабд и высокий образ жизни обретается Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40132,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਭੇਦਿ ਜਾਣੈ ਜਾਣਾਈ ॥",
          "roman": "sabad bhed jāṇē jāṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пронзив свой ум Шабдом Гуру, он распознаёт Господа и помогает другим распознать Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40133,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਉਮੈ ਜਾਲਿ ਸਮਾਈ ॥੨੯॥",
          "roman": "Nānak haumē jāl samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: гурмукх сжигает свою Хоумэ, эгоистичность, и остаётся слитым с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40134,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਧਰਤੀ ਸਾਚੈ ਸਾਜੀ ॥",
          "roman": "gurmukh dhartī sāchē sājī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный Господь создал землю ради появления гурмукха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40135,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਮਹਿ ਓਪਤਿ ਖਪਤਿ ਸੁ ਬਾਜੀ ॥",
          "roman": "tis mah opat khapat so bājī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На этой земле рождение и уничтожение являются игрой для развития состояния гурмукха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40136,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਰਪੈ ਰੰਗੁ ਲਾਇ ॥",
          "roman": "gur kē sabad rapē raṅg lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек через Шабд Гуру соединяет любовь с Господом, он окрашивается в Его цвет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40137,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਿ ਰਤਉ ਪਤਿ ਸਿਉ ਘਰਿ ਜਾਇ ॥",
          "roman": "sāch rato pat siu ghar jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Окрашенный Истинным, гурмукх с честью достигает своего дома."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40138,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਸਬਦ ਬਿਨੁ ਪਤਿ ਨਹੀ ਪਾਵੈ ॥",
          "roman": "sāch sabad bin pat nahī pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Истинного Шабда человек не может обрести честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40139,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਿਨੁ ਨਾਵੈ ਕਿਉ ਸਾਚਿ ਸਮਾਵੈ ॥੩੦॥",
          "roman": "Nānak bin nāvē kiu sāch samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: без Имени как человек может слиться с Истинным Господом? Не может."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3422,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40140,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਅਸਟ ਸਿਧੀ ਸਭਿ ਬੁਧੀ ॥",
          "roman": "gurmukh asaṭ sidhī sabh budhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идти путём Гуру — это и есть обретение всех восьми сиддхи и всех разумений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40141,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਭਵਜਲੁ ਤਰੀਐ ਸਚ ਸੁਧੀ ॥",
          "roman": "gurmukh bhavjal tarīai sach sudhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обратившись к Гуру, переправляются через океан мира и обретают прекрасное понимание Истинного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40142,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਰ ਅਪਸਰ ਬਿਧਿ ਜਾਣੈ ॥",
          "roman": "gurmukh sar apsar bidh jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идущий путём Гуру понимает состояние благого и неблагого времени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40143,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਵਿਰਤਿ ਨਰਵਿਰਤਿ ਪਛਾਣੈ ॥",
          "roman": "gurmukh parvirat narvirat pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он распознаёт, что следует принять и что следует оставить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40144,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਤਾਰੇ ਪਾਰਿ ਉਤਾਰੇ ॥",
          "roman": "gurmukh tāre pār utāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх переправляет и других через океан мира к дальнему берегу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40145,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਬਦਿ ਨਿਸਤਾਰੇ ॥੩੧॥",
          "roman": "Nānak gurmukh sabad nistāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: тот, кто идёт по наставлению Гуру, через Шабд спасает и других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40146,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਰਾਤੇ ਹਉਮੈ ਜਾਇ ॥",
          "roman": "nāme rāte haumē jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто окрашен в Имя Господа, исчезает Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40147,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਚਿ ਰਹੇ ਸਮਾਇ ॥",
          "roman": "nām rate sach rahe samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто окрашен в Имя, пребывают слитыми с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40148,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਜੋਗ ਜੁਗਤਿ ਬੀਚਾਰੁ ॥",
          "roman": "nām rate jog jugat bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только окрашенные в Имя получают подлинный способ йоги и верное размышление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40149,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਪਾਵਹਿ ਮੋਖ ਦੁਆਰੁ ॥",
          "roman": "nām rate pāvah mokh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Окрашенные в Имя находят дверь освобождения от Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40150,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਤ੍ਰਿਭਵਣ ਸੋਝੀ ਹੋਇ ॥",
          "roman": "nām rate tribhavaṇ sojhī hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Окрашенные в Имя обретают понимание трёх миров: вместо малой отдельности им видна родственная связь всего через Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40151,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਤੇ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੩੨॥",
          "roman": "Nānak nām rate sadā sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: окрашенный в Имя Господа обретает вечно устойчивый покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3423,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40152,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਿਧ ਗੋਸਟਿ ਹੋਇ ॥",
          "roman": "nām rate sidh gosṭ hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только через окрашенность в Имя происходит встреча с совершенным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40153,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਦਾ ਤਪੁ ਹੋਇ ॥",
          "roman": "nām rate sadā tap hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывать окрашенным в Имя Господа — это вечное благодетельное подвижничество."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40154,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਸਚੁ ਕਰਣੀ ਸਾਰੁ ॥",
          "roman": "nām rate sach karṇī sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Привязанность к Имени — это истинное и высшее деяние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40155,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਗੁਣ ਗਿਆਨ ਬੀਚਾਰੁ ॥",
          "roman": "nām rate guṇ giān bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только оставаясь окрашенным в Имя, человек узнаёт качества Господа и вступает с Ним в связь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40156,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਬੋਲੈ ਸਭੁ ਵੇਕਾਰੁ ॥",
          "roman": "bin nāvē bolē sabh vekār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Имени Господа всё, что говорит человек, бесплодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40157,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਤੇ ਤਿਨ ਕਉ ਜੈਕਾਰੁ ॥੩੩॥",
          "roman": "Nānak nām rate tin kau jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: тем, кто окрашен в Имя, наше почтение и прославление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40158,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਤੇ ਨਾਮੁ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "pūre gur te nām pāiā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Господа обретается от совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40159,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗ ਜੁਗਤਿ ਸਚਿ ਰਹੈ ਸਮਾਇ ॥",
          "roman": "jog jugat sach rahē samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Быть слитым с Истинным Господом — это и есть подлинный способ йоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40160,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰਹ ਮਹਿ ਜੋਗੀ ਭਰਮਾਏ ਸੰਨਿਆਸੀ ਛਿਅ ਚਾਰਿ ॥",
          "roman": "bārah mah jogī bharmāe sanniāsī chhia chār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Йоги заблуждаются в своих двенадцати течениях, а санньяси — в своих десяти течениях и различных средствах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40161,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਜੋ ਮਰਿ ਜੀਵੈ ਸੋ ਪਾਏ ਮੋਖ ਦੁਆਰੁ ॥",
          "roman": "gur kē sabad jo mar jīvē so pāe mokh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто через Шабд Сатгуру умирает для майи и живёт духовно, находит дверь освобождения от Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
