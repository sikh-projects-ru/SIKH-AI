{
  "ang": 942,
  "shabads": [
    {
      "shabad_id": 3423,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40162,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਸਭਿ ਦੂਜੈ ਲਾਗੇ ਦੇਖਹੁ ਰਿਦੈ ਬੀਚਾਰਿ ॥",
          "roman": "bin sabdē sabh dūjē lāgē dēkhah ridē bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Шабда все привязаны к двойственности; посмотри и обдумай это в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40163,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵਡੇ ਸੇ ਵਡਭਾਗੀ ਜਿਨੀ ਸਚੁ ਰਖਿਆ ਉਰ ਧਾਰਿ ॥੩੪॥",
          "roman": "nānak vaḍē sē vaḍbhāgī jinī sach rakhyā ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, велики и весьма удачливы те, кто удержал Истину в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3424,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40164,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਤਨੁ ਲਹੈ ਲਿਵ ਲਾਇ ॥",
          "roman": "gurmukh ratan lahē liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт лицом к Гуру, соединяя сознание с Господом, находит драгоценность Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40165,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਰਖੈ ਰਤਨੁ ਸੁਭਾਇ ॥",
          "roman": "gurmukh parakhē ratan subhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек естественно, через свою внутреннюю любовь, узнаёт ценность этой драгоценности Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40166,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੀ ਕਾਰ ਕਮਾਇ ॥",
          "roman": "gurmukh sāchī kār kamāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно это истинное дело совершает гурмукх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40167,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਮਨੁ ਪਤੀਆਇ ॥",
          "roman": "gurmukh sāchē man patīāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он приучает свой ум пребывать в Истинном Господе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40168,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਅਲਖੁ ਲਖਾਏ ਤਿਸੁ ਭਾਵੈ ॥",
          "roman": "gurmukh alakh lakhāe tis bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда тому Господу это угодно, гурмукх даёт и другим понимание качеств Непостижимого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40169,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਚੋਟ ਨ ਖਾਵੈ ॥੩੫॥",
          "roman": "nānak gurmukh choṭ na khāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто идёт по слову Гуру, не получает ударов от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40170,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਦਾਨੁ ਇਸਨਾਨੁ ॥",
          "roman": "gurmukh nām dān isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто идёт путём Гуру, принятны повторение Имени, даяние и омовение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40171,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਲਾਗੈ ਸਹਜਿ ਧਿਆਨੁ ॥",
          "roman": "gurmukh lāgē sahaj dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь в обращённости к Гуру сознание соединяется в состоянии духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40172,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਵੈ ਦਰਗਹ ਮਾਨੁ ॥",
          "roman": "gurmukh pāvē dargah mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх получает почёт в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40173,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਭਉ ਭੰਜਨੁ ਪਰਧਾਨੁ ॥",
          "roman": "gurmukh bhau bhañjan pardhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он встречает Господа, разрушающего страхи мира и являющегося Владыкой всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40174,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕਰਣੀ ਕਾਰ ਕਰਾਏ ॥",
          "roman": "gurmukh karṇī kār karāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх побуждает и других совершать достойное дело — идти по повелению Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40175,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮੇਲਿ ਮਿਲਾਏ ॥੩੬॥",
          "roman": "nānak gurmukh mēl milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, так он соединяет их с единением с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3425,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40176,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਸਤ੍ਰ ਸਿਮ੍ਰਿਤਿ ਬੇਦ ॥",
          "roman": "gurmukh sāstar simrit bēd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт путём Гуру, словно уже постиг Шастры, Симрити и Веды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40177,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਪਾਵੈ ਘਟਿ ਘਟਿ ਭੇਦ ॥",
          "roman": "gurmukh pāvē ghaṭ ghaṭ bhēd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через повеление Гуру он понимает тайну Господа, присутствующего в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40178,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਵੈਰ ਵਿਰੋਧ ਗਵਾਵੈ ॥",
          "roman": "gurmukh vēr virōdh gavāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх отбрасывает вражду и противостояние к другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40179,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਗਲੀ ਗਣਤ ਮਿਟਾਵੈ ॥",
          "roman": "gurmukh saglī gaṇat miṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он полностью стирает весь счёт обид и никогда не держит в уме чужой несправедливости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40180,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਮ ਨਾਮ ਰੰਗਿ ਰਾਤਾ ॥",
          "roman": "gurmukh rām nām raṅg rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх пребывает окрашенным любовью к Имени Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40181,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਖਸਮੁ ਪਛਾਤਾ ॥੩੭॥",
          "roman": "nānak gurmukh khasam pachhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, человек, обращённый к Гуру, распознал своего Господина — Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40182,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਭਰਮੈ ਆਵੈ ਜਾਇ ॥",
          "roman": "bin gur bharmē āvē jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без прибежища у Сатгуру человек блуждает в майе и продолжает рождаться и умирать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40183,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਘਾਲ ਨ ਪਵਈ ਥਾਇ ॥",
          "roman": "bin gur ghāl na pavaī thāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без прибежища у Гуру никакое усилие не принимается, потому что Хоумэ остаётся внутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40184,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਮਨੂਆ ਅਤਿ ਡੋਲਾਇ ॥",
          "roman": "bin gur manūā at ḍōlāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Сатгуру этот беспокойный ум остаётся в сильных сомнениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40185,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਤ੍ਰਿਪਤਿ ਨਹੀ ਬਿਖੁ ਖਾਇ ॥",
          "roman": "bin gur tripat nahī bikh khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поедая яд, то есть наслаждаясь мирскими предметами, он всё равно не насыщается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40186,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਬਿਸੀਅਰੁ ਡਸੈ ਮਰਿ ਵਾਟ ॥",
          "roman": "bin gur bisīar ḍasē mar vāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без пути Гуру змея мирского влечения продолжает жалить, и человек духовно умирает посреди жизненного пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40187,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਬਿਨੁ ਘਾਟੇ ਘਾਟ ॥੩੮॥",
          "roman": "nānak gur bin ghāṭē ghāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, без следования повелению Сатгуру человек терпит один духовный убыток за другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3426,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40188,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰੁ ਮਿਲੈ ਤਿਸੁ ਪਾਰਿ ਉਤਾਰੈ ॥",
          "roman": "jis gur milē tis pār utārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того человека, кому встречается Сатгуру, он переправляет через труднопроходимый океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40189,
          "is_rahao": false,
          "gurmukhi": "ਅਵਗਣ ਮੇਟੈ ਗੁਣਿ ਨਿਸਤਾਰੈ ॥",
          "roman": "avgaṇ mēṭē guṇ nistārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру стирает его недостатки и, наделяя добродетелью, спасает от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40190,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਮਹਾ ਸੁਖ ਗੁਰ ਸਬਦੁ ਬੀਚਾਰਿ ॥",
          "roman": "mukt mahā sukh gur sabad bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Размышляя над Шабдом Сатгуру, он получает великое блаженство освобождения от уз майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40191,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕਦੇ ਨ ਆਵੈ ਹਾਰਿ ॥",
          "roman": "gurmukh kadē na āvē hār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх никогда не возвращается побеждённым в игре жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40192,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਹਟੜੀ ਇਹੁ ਮਨੁ ਵਣਜਾਰਾ ॥",
          "roman": "tan haṭṛī ih man vaṇjārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх делает своё тело прекрасной лавкой, а ум — торговцем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40193,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਹਜੇ ਸਚੁ ਵਾਪਾਰਾ ॥੩੯॥",
          "roman": "nānak sahjē sach vāpārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, пребывая в духовной устойчивости, он ведёт торговлю Истинным Именем Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40194,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਬਾਂਧਿਓ ਸੇਤੁ ਬਿਧਾਤੈ ॥",
          "roman": "gurmukh bāndhiō sēt bidhātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Творец построил мост в виде гурмукха через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40195,
          "is_rahao": false,
          "gurmukhi": "ਲੰਕਾ ਲੂਟੀ ਦੈਤ ਸੰਤਾਪੈ ॥",
          "roman": "laṅkā lūṭī dēt santāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как была разграблена Ланка и поражены ракшасы, так Гуру освобождает тело от власти похоти и прочих страстей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40196,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਚੰਦਿ ਮਾਰਿਓ ਅਹਿ ਰਾਵਣੁ ॥",
          "roman": "rāmchand māriō ah rāvaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как Рамчандра убил Равана, так гурмукх убивает змею-ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40197,
          "is_rahao": false,
          "gurmukhi": "ਭੇਦੁ ਬਭੀਖਣ ਗੁਰਮੁਖਿ ਪਰਚਾਇਣੁ ॥",
          "roman": "bhēd babhīkhaṇ gurmukh parchāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наставление Сатгуру помогает победить ум так же, как тайна, раскрытая Бибхишаном, помогла победить Равана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40198,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਇਰਿ ਪਾਹਣ ਤਾਰੇ ॥",
          "roman": "gurmukh sāir pāhaṇ tārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру переправляет через мировой океан даже каменносердечных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40199,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕੋਟਿ ਤੇਤੀਸ ਉਧਾਰੇ ॥੪੦॥",
          "roman": "gurmukh kōṭ tetīs udhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Гуру переправились тридцать три крора, то есть бесчисленные живые существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3427,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40200,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਚੂਕੈ ਆਵਣ ਜਾਣੁ ॥",
          "roman": "gurmukh chūkē āvaṇ jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто идёт по повелению Гуру, прекращается круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40201,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਦਰਗਹ ਪਾਵੈ ਮਾਣੁ ॥",
          "roman": "gurmukh dargah pāvē māṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх получает почёт в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40202,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਖੋਟੇ ਖਰੇ ਪਛਾਣੁ ॥",
          "roman": "gurmukh khōṭē kharē pachhāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх становится знающим различие между ложными и истинными делами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40203,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਲਾਗੈ ਸਹਜਿ ਧਿਆਨੁ ॥",
          "roman": "gurmukh lāgē sahaj dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому он не попадает в ложные дела, и его сознание остаётся соединённым в духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40204,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਦਰਗਹ ਸਿਫਤਿ ਸਮਾਇ ॥",
          "roman": "gurmukh dargah sifat samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через восхваление Господа гурмукх пребывает в Его присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40205,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਬੰਧੁ ਨ ਪਾਇ ॥੪੧॥",
          "roman": "nānak gurmukh bandh na pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, на пути жизни гурмукха не возникает преграды пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40206,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਨਿਰੰਜਨ ਪਾਏ ॥",
          "roman": "gurmukh nām nirañjan pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, идущий по повелению Гуру, получает Имя Нираджана, Господа, свободного от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40207,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹਉਮੈ ਸਬਦਿ ਜਲਾਏ ॥",
          "roman": "gurmukh haumē sabad jalāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Шабд Гуру он сжигает свою Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40208,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੇ ਕੇ ਗੁਣ ਗਾਏ ॥",
          "roman": "gurmukh sāchē kē guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обратившись к Гуру, человек поёт достоинства Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40209,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚੈ ਰਹੈ ਸਮਾਏ ॥",
          "roman": "gurmukh sāchē rahē samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он остаётся погружённым в вечно пребывающего Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40210,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚਿ ਨਾਮਿ ਪਤਿ ਊਤਮ ਹੋਇ ॥",
          "roman": "gurmukh sāch nām pat ūtam hōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставаясь соединённым с Истинным Именем, гурмукх получает высокую честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40211,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਗਲ ਭਵਣ ਕੀ ਸੋਝੀ ਹੋਇ ॥੪੨॥",
          "roman": "nānak gurmukh sagal bhavaṇ kī sōjhī hōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, гурмукху приходит понимание всех миров: он осознаёт, что Господь присутствует во всех мирах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3428,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40212,
          "is_rahao": false,
          "gurmukhi": "ਕਵਣ ਮੂਲੁ ਕਵਣ ਮਤਿ ਵੇਲਾ ॥",
          "roman": "kavaṇ mūl kavaṇ mat vēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вопрос: каков корень жизни и какое учение следует принимать в это время человеческого рождения?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40213,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਕਵਣੁ ਗੁਰੂ ਜਿਸ ਕਾ ਤੂ ਚੇਲਾ ॥",
          "roman": "tērā kavaṇ gurū jis kā tū chēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чьим учеником ты являешься, и кто твой Гуру?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40214,
          "is_rahao": false,
          "gurmukhi": "ਕਵਣ ਕਥਾ ਲੇ ਰਹਹੁ ਨਿਰਾਲੇ ॥",
          "roman": "kavaṇ kathā lē rahah nirālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря какому учению ты остаёшься отдельным и незапятнанным?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40215,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਨਾਨਕੁ ਸੁਣਹੁ ਤੁਮ ਬਾਲੇ ॥",
          "roman": "bōlē nānak suṇah tum bālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: йоги сказали — слушай, о юный Нанак."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40216,
          "is_rahao": false,
          "gurmukhi": "ਏਸੁ ਕਥਾ ਕਾ ਦੇਇ ਬੀਚਾਰੁ ॥",
          "roman": "ēs kathā kā dēe bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Объясни нам также смысл этого вопроса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40217,
          "is_rahao": false,
          "gurmukhi": "ਭਵਜਲੁ ਸਬਦਿ ਲੰਘਾਵਣਹਾਰੁ ॥੪੩॥",
          "roman": "bhavjal sabad laṅghāvaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Объясни, как через Шабд Гуру способен переправить живое существо через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
