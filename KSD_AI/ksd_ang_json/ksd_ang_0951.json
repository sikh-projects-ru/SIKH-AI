{
  "ang": 951,
  "shabads": [
    {
      "shabad_id": 3472,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40575,
          "is_rahao": false,
          "gurmukhi": "ਮਲੁ ਕੂੜੀ ਨਾਮਿ ਉਤਾਰੀਅਨੁ ਜਪਿ ਨਾਮੁ ਹੋਆ ਸਚਿਆਰੁ ॥",
          "roman": "mal kūṛī nām utārīan jap nām hoā sachiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лживую грязь Он снял посредством Имени; повторяя Имя, человек стал правдивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40576,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਜਿਸ ਦੇ ਏਹਿ ਚਲਤ ਹਹਿ ਸੋ ਜੀਵਉ ਦੇਵਣਹਾਰੁ ॥੨॥",
          "roman": "jan Nānak jis dē ēh chalat hah so jīvau dēvaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак говорит: да живёт Податель, чьи чудесные дела таковы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3473,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40577,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40578,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਜੇਵਡੁ ਦਾਤਾ ਨਾਹਿ ਕਿਸੁ ਆਖਿ ਸੁਣਾਈਐ ॥",
          "roman": "tudh jēvaḍ dātā nāh kis ākh suṇāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, нет подателя, равного Тебе; о ком ещё можно сказать и поведать, что он подобен Тебе?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40579,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਪਾਇ ਜਿਥਹੁ ਹਉਮੈ ਜਾਈਐ ॥",
          "roman": "gur prasādī pāe jithah haumē jāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нектар Имени обретается по милости Сатгуру; именно через Гуру исчезает Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40580,
          "is_rahao": false,
          "gurmukhi": "ਰਸ ਕਸ ਸਾਦਾ ਬਾਹਰਾ ਸਚੀ ਵਡਿਆਈਐ ॥",
          "roman": "ras kas sādā bāhrā sachī vaḍiāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Податель нектара Имени выше влияния всех вкусов и наслаждений; Его величие вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40581,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਬਖਸੇ ਤਿਸੁ ਦੇਇ ਆਪਿ ਲਏ ਮਿਲਾਈਐ ॥",
          "roman": "jis nō bakhsē tis dē āp laē milāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Господь милует, тому Он дарует этот нектар и Сам соединяет его с Собою."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40582,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਅੰਤਰਿ ਅੰਮ੍ਰਿਤੁ ਰਖਿਓਨੁ ਗੁਰਮੁਖਿ ਕਿਸੈ ਪਿਆਈ ॥੯॥",
          "roman": "ghaṭ antar amrit rakhiōn gurmukh kisē piāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот нектар Он поместил в сердце каждого, но кому даёт его испить, тому даёт через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3474,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40583,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੩ ॥",
          "roman": "salok mahallā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40584,
          "is_rahao": false,
          "gurmukhi": "ਬਾਬਾਣੀਆ ਕਹਾਣੀਆ ਪੁਤ ਸਪੁਤ ਕਰੇਨਿ ॥",
          "roman": "bābāṇīā kahāṇīā put saput karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сказания Сатгуру делают учеников-сыновей достойными, гурмукх-сыновьями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40585,
          "is_rahao": false,
          "gurmukhi": "ਜਿ ਸਤਿਗੁਰ ਭਾਵੈ ਸੁ ਮੰਨਿ ਲੈਨਿ ਸੇਈ ਕਰਮ ਕਰੇਨਿ ॥",
          "roman": "j satgur bhāvē su mann lēn sēī karam karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря этим сказаниям ученики принимают то, что угодно Сатгуру, и совершают такие дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40586,
          "is_rahao": false,
          "gurmukhi": "ਜਾਇ ਪੁਛਹੁ ਸਿਮ੍ਰਿਤਿ ਸਾਸਤ ਬਿਆਸ ਸੁਕ ਨਾਰਦ ਬਚਨ ਸਭ ਸ੍ਰਿਸਟਿ ਕਰੇਨਿ ॥",
          "roman": "jāe puchhah simrit sāsat Biās Suk Nārad bachan sabh srisaṭ karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пойдите и спросите Смрити, Шастры, Вьясу, Шука и Нарада, то есть прочтите их писания: они давали наставление всей вселенной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40587,
          "is_rahao": false,
          "gurmukhi": "ਸਚੈ ਲਾਏ ਸਚਿ ਲਗੇ ਸਦਾ ਸਚੁ ਸਮਾਲੇਨਿ ॥",
          "roman": "sachē lāē sach lagē sadā sach samālēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Истинный Господь соединил с памятью о чудесах Сатгуру, те присоединились и к Истинному Господу и всегда помнят Истинного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40588,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਏ ਸੇ ਪਰਵਾਣੁ ਭਏ ਜਿ ਸਗਲੇ ਕੁਲ ਤਾਰੇਨਿ ॥੧॥",
          "roman": "Nānak āē sē parvāṇ bhaē ji saglē kul tārēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: принято в мире пришествие только тех, кто спасает не только себя, но и все свои роды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3475,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40589,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahallā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40590,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੂ ਜਿਨਾ ਕਾ ਅੰਧੁਲਾ ਸਿਖ ਭੀ ਅੰਧੇ ਕਰਮ ਕਰੇਨਿ ॥",
          "roman": "gurū jinā kā andhulā sikh bhī andhē karam karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех людей, чей гуру сам слеп от неведения, ученики тоже совершают слепые, дурные дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40591,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਭਾਣੈ ਚਲਨਿ ਆਪਣੈ ਨਿਤ ਝੂਠੋ ਝੂਠੁ ਬੋਲੇਨਿ ॥",
          "roman": "ōe bhāṇē chalan āpṇē nit jhūṭhō jhūṭh bōlēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти ученики идут за собственной волей и постоянно говорят одну ложь за другой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40592,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜੁ ਕੁਸਤੁ ਕਮਾਵਦੇ ਪਰ ਨਿੰਦਾ ਸਦਾ ਕਰੇਨਿ ॥",
          "roman": "kūṛ kusat kamāvdē par nindā sadā karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они творят ложь и обман и всегда клевещут на других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40593,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਆਪਿ ਡੁਬੇ ਪਰ ਨਿੰਦਕਾ ਸਗਲੇ ਕੁਲ ਡੋਬੇਨਿ ॥",
          "roman": "ōe āp ḍubē par nindakā saglē kul ḍōbēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти клеветники сами тонут и топят все свои роды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40594,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਤੁ ਓਇ ਲਾਏ ਤਿਤੁ ਲਗੇ ਉਇ ਬਪੁੜੇ ਕਿਆ ਕਰੇਨਿ ॥੨॥",
          "roman": "Nānak jit ōe lāē tit lagē ue bapuṛē kiā karēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: что же могут сделать эти бедные? Куда Господь их направил, туда они и привязаны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3476,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40595,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40596,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਨਦਰੀ ਅੰਦਰਿ ਰਖਦਾ ਜੇਤੀ ਸਿਸਟਿ ਸਭ ਕੀਤੀ ॥",
          "roman": "sabh nadrī andar rakhdā jētī sisaṭ sabh kītī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всю сотворённую Им вселенную Господь держит под Своим взором."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40597,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਕੂੜਿ ਕੁਸਤਿ ਲਾਇਅਨੁ ਮਨਮੁਖ ਵਿਗੂਤੀ ॥",
          "roman": "ik kūṛ kusat lāian manmukh vigūtī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторых существ Он поместил в ложь и обман; следуя за своим умом, они разоряются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40598,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਦਾ ਧਿਆਈਐ ਅੰਦਰਿ ਹਰਿ ਪ੍ਰੀਤੀ ॥",
          "roman": "gurmukh sadā dhiāīē andar har prītī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто идут по повелению Гуру, всегда медитируют на Господа, потому что в их сердце пребывает любовь к Нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40599,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕਉ ਪੋਤੈ ਪੁੰਨੁ ਹੈ ਤਿਨੑ ਵਾਤਿ ਸਿਪੀਤੀ ॥",
          "roman": "jin kau pōtē punn hē tinh vāt sipītī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех, в чьей доле есть прежняя добродетель, в устах пребывает хвала Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40600,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਈਐ ਸਚੁ ਸਿਫਤਿ ਸਨਾਈ ॥੧੦॥",
          "roman": "Nānak nām dhiāīē sach sifat sanāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: следует медитировать на Имя; хвала и слава Всевышнего — единственное вечно пребывающее."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3477,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40601,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40602,
          "is_rahao": false,
          "gurmukhi": "ਸਤੀ ਪਾਪੁ ਕਰਿ ਸਤੁ ਕਮਾਹਿ ॥",
          "roman": "satī pāp kar sat kamāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто называют себя добродетельными и чистыми в поведении, тайно совершают порок, но внешне показывают, будто творят праведность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40603,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਦੀਖਿਆ ਘਰਿ ਦੇਵਣ ਜਾਹਿ ॥",
          "roman": "gur dīkhiā ghar dēvaṇ jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто называют себя гуру, ради майи идут в дома учеников давать наставление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40604,
          "is_rahao": false,
          "gurmukhi": "ਇਸਤਰੀ ਪੁਰਖੈ ਖਟਿਐ ਭਾਉ ॥",
          "roman": "istrī purakhē khaṭiē bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жена любит мужа лишь тогда, когда он зарабатывает и приносит домой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40605,
          "is_rahao": false,
          "gurmukhi": "ਭਾਵੈ ਆਵਉ ਭਾਵੈ ਜਾਉ ॥",
          "roman": "bhāvē āvau bhāvē jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А иначе, пусть муж приходит или уходит, жена не заботится о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40606,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਤੁ ਬੇਦੁ ਨ ਮਾਨੈ ਕੋਇ ॥",
          "roman": "sāsat bēd na mānē kōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто не следует ни Ведам, ни Шастрам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40607,
          "is_rahao": false,
          "gurmukhi": "ਆਪੋ ਆਪੈ ਪੂਜਾ ਹੋਇ ॥",
          "roman": "āpō āpē pūjā hōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый поклоняется только своей собственной выгоде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40608,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਹੋਇ ਕੈ ਬਹੈ ਨਿਆਇ ॥",
          "roman": "kājī hōe kē bahē niāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кази садится вершить суд над другими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40609,
          "is_rahao": false,
          "gurmukhi": "ਫੇਰੇ ਤਸਬੀ ਕਰੇ ਖੁਦਾਇ ॥",
          "roman": "phērē tasbī karē khudāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он перебирает чётки и повторяет имя Худая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40610,
          "is_rahao": false,
          "gurmukhi": "ਵਢੀ ਲੈ ਕੈ ਹਕੁ ਗਵਾਏ ॥",
          "roman": "vaḍhī lē kē hak gavāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но при суде берёт взятку и лишает другого его права."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40611,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਪੁਛੈ ਤਾ ਪੜਿ ਸੁਣਾਏ ॥",
          "roman": "jē kō puchhē tā paṛ suṇāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А если кто-нибудь возразит против этого, он прочтёт и приведёт какое-нибудь положение шариата."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40612,
          "is_rahao": false,
          "gurmukhi": "ਤੁਰਕ ਮੰਤ੍ਰੁ ਕਨਿ ਰਿਦੈ ਸਮਾਹਿ ॥",
          "roman": "turak mantar kan ridē samāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В ухе и сердце индуистские вожди держат приказ тюркских правителей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40613,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕ ਮੁਹਾਵਹਿ ਚਾੜੀ ਖਾਹਿ ॥",
          "roman": "lōk muhāvah chāṛī khāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они заставляют народ быть ограбленным и питаются клеветой, донося на людей правителям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40614,
          "is_rahao": false,
          "gurmukhi": "ਚਉਕਾ ਦੇ ਕੈ ਸੁਚਾ ਹੋਇ ॥",
          "roman": "chauṅkā dē kē suchā hōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, обмазав место для готовки, они считают себя чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40615,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਹਿੰਦੂ ਵੇਖਹੁ ਕੋਇ ॥",
          "roman": "aisā hindū vēkhah kōe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Посмотрите на такого индуиста: одной лишь кухонной чистотой он ходит и считает себя чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40616,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਗਿਰਹੀ ਜਟਾ ਬਿਭੂਤ ॥",
          "roman": "jōgī girahī jaṭā bibhūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Йогин носит спутанные волосы и натирается пеплом, но сам остаётся домохозяином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40617,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਪਾਛੈ ਰੋਵਹਿ ਪੂਤ ॥",
          "roman": "āgē pāchhē rōvah pūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вокруг него, впереди и позади, плачут его дети."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40618,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੁ ਨ ਪਾਇਆ ਜੁਗਤਿ ਗਵਾਈ ॥",
          "roman": "jōg na pāiā jugat gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не обрёл пути йоги и потерял искусство правильной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40619,
          "is_rahao": false,
          "gurmukhi": "ਕਿਤੁ ਕਾਰਣਿ ਸਿਰਿ ਛਾਈ ਪਾਈ ॥",
          "roman": "kit kāraṇ sir chhāī pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для чего же он посыпал голову пеплом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40620,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਲਿ ਕਾ ਏਹੁ ਪਰਵਾਣੁ ॥",
          "roman": "Nānak kal kā ēh parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: таково влияние Кали-юги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40621,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਖਣੁ ਆਪੇ ਜਾਣੁ ॥੧॥",
          "roman": "āpē ākhaṇ āpē jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек калиюжного нрава сам становится начальником и сам же прославляет свои поступки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3478,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40622,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40623,
          "is_rahao": false,
          "gurmukhi": "ਹਿੰਦੂ ਕੈ ਘਰਿ ਹਿੰਦੂ ਆਵੈ ॥",
          "roman": "hindū kē ghar hindū āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В дом индуиста, то есть кшатрия или другого человека, приходит брахман."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40624,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤੁ ਜਨੇਊ ਪੜਿ ਗਲਿ ਪਾਵੈ ॥",
          "roman": "sūt janēū paṛ gal pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прочитав мантры, он надевает тому на шею нить джанеу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40625,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤੁ ਪਾਇ ਕਰੇ ਬੁਰਿਆਈ ॥",
          "roman": "sūt pāe karē buriāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но человек, надев эту нить, всё равно продолжает совершать дурные дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40626,
          "is_rahao": false,
          "gurmukhi": "ਨਾਤਾ ਧੋਤਾ ਥਾਇ ਨ ਪਾਈ ॥",
          "roman": "nātā dhōtā thāe na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Одними ежедневными омовениями и очищениями он не становится принятым у Двора Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40627,
          "is_rahao": false,
          "gurmukhi": "ਮੁਸਲਮਾਨੁ ਕਰੇ ਵਡਿਆਈ ॥",
          "roman": "musalmān karē vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мусульманин говорит о величии своей веры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
