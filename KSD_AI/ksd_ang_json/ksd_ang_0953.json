{
  "ang": 953,
  "shabads": [
    {
      "shabad_id": 3484,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40684,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਪਾਖੰਡੀ ਜਰਾ ਨ ਮਰਣਾ ॥",
          "roman": "tis pākhaṇḍī jarā na marṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такому паханди не страшны ни старость, ни смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40685,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਚਰਪਟੁ ਸਤਿ ਸਰੂਪੁ ॥",
          "roman": "bolē Charpaṭ sat sarūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чарпат говорит о Господе, Истинной Сущности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40686,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਤੰਤ ਮਹਿ ਰੇਖ ਨ ਰੂਪੁ ॥੫॥",
          "roman": "param tant meh rēkh na rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В высшей Основе не остаётся ни очертания, ни отдельной формы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3485,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40687,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40688,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬੈਰਾਗੀ ਜਿ ਉਲਟੇ ਬ੍ਰਹਮੁ ॥",
          "roman": "so bērāgī j ulṭē brahm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный вайраги — тот, кто обращает Бога к своему сердцу, то есть поселяет Господа на ложе своего сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40689,
          "is_rahao": false,
          "gurmukhi": "ਗਗਨ ਮੰਡਲ ਮਹਿ ਰੋਪੈ ਥੰਮੁ ॥",
          "roman": "gagan maṇḍal meh ropē thamm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он утверждает опору Имени Господа в сфере дэсам-дуар, делая Имя такой поддержкой, что его сознание пребывает в стопах Господа и не падает к майским предметам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40690,
          "is_rahao": false,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਅੰਤਰਿ ਰਹੈ ਧਿਆਨਿ ॥",
          "roman": "ahinis antar rahē dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Днём и ночью он остаётся внутри себя, в сердце, соединённым с памятью о Господе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40691,
          "is_rahao": false,
          "gurmukhi": "ਤੇ ਬੈਰਾਗੀ ਸਤ ਸਮਾਨਿ ॥",
          "roman": "tē bērāgī sat samān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такие вайраги становятся подобны Вечно пребывающему Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40692,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਭਰਥਰਿ ਸਤਿ ਸਰੂਪੁ ॥",
          "roman": "bolē Bharthar sat sarūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Бхартхари тоже, применяя такой путь вайраги, будет поминать Господа, Истинную Сущность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40693,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਤੰਤ ਮਹਿ ਰੇਖ ਨ ਰੂਪੁ ॥੬॥",
          "roman": "param tant meh rēkh na rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то и он сольётся с Высшим Брахмом, и у него не останется никакой отдельной формы или очертания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3486,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40694,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40695,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਮਰੈ ਮੰਦਾ ਕਿਉ ਜੀਵੈ ਜੁਗਤਿ ॥",
          "roman": "kiu marē mandā kiu jīvē jugat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этим способом ни зло из ума не уходит, ни высокая жизнь не обретается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40696,
          "is_rahao": false,
          "gurmukhi": "ਕੰਨ ਪੜਾਇ ਕਿਆ ਖਾਜੈ ਭੁਗਤਿ ॥",
          "roman": "kann paṛāe kiā khājē bhugat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет никакой духовной пользы в том, чтобы прокалывать уши и есть йогический чурма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40697,
          "is_rahao": false,
          "gurmukhi": "ਆਸਤਿ ਨਾਸਤਿ ਏਕੋ ਨਾਉ ॥",
          "roman": "āst nāst ēko nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единственное Имя Господа существует и при бытии мира, и при его отсутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40698,
          "is_rahao": false,
          "gurmukhi": "ਕਉਣੁ ਸੁ ਅਖਰੁ ਜਿਤੁ ਰਹੈ ਹਿਆਉ ॥",
          "roman": "kauṇ su akhar jit rahē hiau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если спросить, какое это слово, в котором сердце может оставаться соединённым, ответ таков: это Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40699,
          "is_rahao": false,
          "gurmukhi": "ਧੂਪ ਛਾਵ ਜੇ ਸਮ ਕਰਿ ਸਹੈ ॥",
          "roman": "dhūp chhāv jē sam kar sahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если человек, благодаря этому Имени, одинаково переносит и горе, и радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40700,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਨਾਨਕੁ ਆਖੈ ਗੁਰੁ ਕੋ ਕਹੈ ॥",
          "roman": "tā Nānak ākhē gur ko kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда, говорит Нанак, именно он по-настоящему помнит Гуру, то есть живёт согласно слову Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40701,
          "is_rahao": false,
          "gurmukhi": "ਛਿਅ ਵਰਤਾਰੇ ਵਰਤਹਿ ਪੂਤ ॥",
          "roman": "chhia vartārē vartah pūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ученики натхов заняты лишь шестью внешними облачениями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40702,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸੰਸਾਰੀ ਨਾ ਅਉਧੂਤ ॥",
          "roman": "nā sansārī nā audhūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В действительности они ни домохозяева, ни отрешённые."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40703,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰੰਕਾਰਿ ਜੋ ਰਹੈ ਸਮਾਇ ॥",
          "roman": "nirankār jo rahē samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который остаётся соединённым с Единым Нирankar,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40704,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੇ ਭੀਖਿਆ ਮੰਗਣਿ ਜਾਇ ॥੭॥",
          "roman": "kāhē bhīkhiā mangaṇ jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "зачем ему ходить и просить милостыню? Ему нет нужды становиться факиром: трудясь своими руками, он может оставаться погружённым в стопы Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3487,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40705,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40706,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮੰਦਰੁ ਸੋਈ ਆਖੀਐ ਜਿਥਹੁ ਹਰਿ ਜਾਤਾ ॥",
          "roman": "har mandar soī ākhīē jithah har jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хотя все тела являются обителями Господа, истинно храмом Господа следует называть то тело, в котором Господь познан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40707,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨਸ ਦੇਹ ਗੁਰ ਬਚਨੀ ਪਾਇਆ ਸਭੁ ਆਤਮ ਰਾਮੁ ਪਛਾਤਾ ॥",
          "roman": "mānas dēh gur bachnī pāiā sabh ātam rām pachhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В человеческом теле, следуя слову Гуру, человек находит Господа и узнаёт везде пронизывающий Свет Атма-Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40708,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਮੂਲਿ ਨ ਖੋਜੀਐ ਘਰ ਮਾਹਿ ਬਿਧਾਤਾ ॥",
          "roman": "bāhar mūl na khojīē ghar māh bidhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совсем не нужно искать вне тела: в этом доме-теле пребывает сам Творец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40709,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਹਰਿ ਮੰਦਰ ਕੀ ਸਾਰ ਨ ਜਾਣਨੀ ਤਿਨੀ ਜਨਮੁ ਗਵਾਤਾ ॥",
          "roman": "manmukh har mandar kī sār na jāṇnī tinī janam gavātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмухи не знают ценности этого человеческого тела как храма Господа и, следуя за умом, теряют человеческое рождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40710,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਇਕੁ ਵਰਤਦਾ ਗੁਰ ਸਬਦੀ ਪਾਇਆ ਜਾਈ ॥੧੨॥",
          "roman": "sabh meh ik vartdā gur sabdī pāiā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один Господь пребывает во всех, но найти Его можно через Шабд Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3488,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40711,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੩ ॥",
          "roman": "salok mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40712,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖੁ ਹੋਵੈ ਸੋ ਸੁਣੈ ਮੂਰਖ ਕਾ ਕਹਣਾ ॥",
          "roman": "mūrakh hovē so suṇē mūrakh kā kahṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слова глупца слушает и принимает лишь тот, кто сам глуп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40713,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖ ਕੇ ਕਿਆ ਲਖਣ ਹੈ ਕਿਆ ਮੂਰਖ ਕਾ ਕਰਣਾ ॥",
          "roman": "mūrakh kē kiā lakhaṇ hē kiā mūrakh kā karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каковы признаки глупца и каковы его поступки?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40714,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖੁ ਓਹੁ ਜਿ ਮੁਗਧੁ ਹੈ ਅਹੰਕਾਰੇ ਮਰਣਾ ॥",
          "roman": "mūrakh oh j mugadh hē ahaṅkārē marṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Глупцом называется тот, кто обманут майей и умирает духовной смертью в эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40715,
          "is_rahao": false,
          "gurmukhi": "ਏਤੁ ਕਮਾਣੈ ਸਦਾ ਦੁਖੁ ਦੁਖ ਹੀ ਮਹਿ ਰਹਣਾ ॥",
          "roman": "ēt kamāṇē sadā dukh dukh hī meh rahṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "То, что делается в опьянении майей и эго, всегда приносит страдание, и человек остаётся в страдании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40716,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਪਿਆਰਾ ਪਵੈ ਖੂਹਿ ਕਿਹੁ ਸੰਜਮੁ ਕਰਣਾ ॥",
          "roman": "at piārā pavē khūh kih sanjam karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто слишком любит майю, остаётся упавшим в колодец её привязанности; какое усилие может его спасти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40717,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹੋਇ ਸੁ ਕਰੇ ਵੀਚਾਰੁ ਓਸੁ ਅਲਿਪਤੋ ਰਹਣਾ ॥",
          "roman": "gurmukh hoē su karē vīchār os alipto rahṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто становится гурмукхом, размышляет над этим и остаётся отдельным от колодца привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40718,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਜਪੈ ਆਪਿ ਉਧਰੈ ਓਸੁ ਪਿਛੈ ਡੁਬਦੇ ਭੀ ਤਰਣਾ ॥",
          "roman": "har nām japē āp udharē os pichhē ḍubdē bhī tarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он повторяет Имя Господа, сам спасается, и те, кто следует его примеру, хотя и тонули, тоже переправляются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40719,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਕਰੇ ਜੋ ਦੇਇ ਸੁ ਸਹਣਾ ॥੧॥",
          "roman": "Nānak jo tis bhāvē so karē jo dē so sahṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Господь делает то, что Ему угодно; что бы Он ни дал, живое существо принимает и переносит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3489,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40720,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40721,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਆਖੈ ਰੇ ਮਨਾ ਸੁਣੀਐ ਸਿਖ ਸਹੀ ॥",
          "roman": "Nānak ākhē rē manā suṇīē sikh sahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о ум, слушай истинное наставление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40722,
          "is_rahao": false,
          "gurmukhi": "ਲੇਖਾ ਰਬੁ ਮੰਗੇਸੀਆ ਬੈਠਾ ਕਢਿ ਵਹੀ ॥",
          "roman": "lēkhā rabb mangēsīā bēṭhā kaḍh vahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог, сидя с раскрытой книгой твоих дел, спросит у тебя отчёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40723,
          "is_rahao": false,
          "gurmukhi": "ਤਲਬਾ ਪਉਸਨਿ ਆਕੀਆ ਬਾਕੀ ਜਿਨਾ ਰਹੀ ॥",
          "roman": "talbā pausan ākīā bākī jinā rahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем бунтующим манмухам, у кого останется долг по счёту, будут посланы вызовы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40724,
          "is_rahao": false,
          "gurmukhi": "ਅਜਰਾਈਲੁ ਫਰੇਸਤਾ ਹੋਸੀ ਆਇ ਤਈ ॥",
          "roman": "Ajrāīl farēstā hosī āe taī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ангел смерти Азраил придёт и будет стоять готовым, назначенным причинить страдание согласно совершённым делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40725,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣੁ ਜਾਣੁ ਨ ਸੁਝਈ ਭੀੜੀ ਗਲੀ ਫਹੀ ॥",
          "roman": "āvaṇ jāṇ na sujhaī bhīṛī galī fahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Душа, попавшая в эту тесную беду, тогда не сможет понять, куда идти и что делать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40726,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜ ਨਿਖੁਟੇ ਨਾਨਕਾ ਓੜਕਿ ਸਚਿ ਰਹੀ ॥੨॥",
          "roman": "kūṛ nikhuṭē nānakā oṛak sach rahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, торговцы ложью уходят побеждёнными; в конце остаётся лишь тот, кто совершил истинную сделку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3490,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40727,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40728,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਸਭੁ ਸਰੀਰੁ ਹੈ ਹਰਿ ਰਵਿ ਰਹਿਆ ਸਭੁ ਆਪੈ ॥",
          "roman": "har kā sabh sarīr hē har rav rahiā sabh āpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вся форма этого мира словно тело Господа; Сам Господь везде пронизывает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40729,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਕੀਮਤਿ ਨ ਪਵੈ ਕਿਛੁ ਕਹਣੁ ਨ ਜਾਪੈ ॥",
          "roman": "har kī kīmat na pavē kichh kahaṇ na jāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Цену величия Господа невозможно определить; не находится никаких слов, которыми можно было бы описать Его славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40730,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਸਾਲਾਹੀਐ ਹਰਿ ਭਗਤੀ ਰਾਪੈ ॥",
          "roman": "gur parsādī salāhīē har bhagtī rāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Сатгуру можно восхвалять Господа; тот, кто делает это, окрашивается в преданность Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40731,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਮਨੁ ਤਨੁ ਹਰਿਆ ਹੋਇਆ ਅਹੰਕਾਰੁ ਗਵਾਪੈ ॥",
          "roman": "sabh man tan hariā hoiā ahaṅkār gavāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его ум и тело расцветают, а эго исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40732,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਹਰਿ ਕਾ ਖੇਲੁ ਹੈ ਗੁਰਮੁਖਿ ਕਿਸੈ ਬੁਝਾਈ ॥੧੩॥",
          "roman": "sabh kichh har kā khēl hē gurmukh kisē bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё это — игра, созданная Господом; через Сатгуру Он даёт это понимание какому-нибудь редкому гурмукху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3491,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40733,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40734,
          "is_rahao": false,
          "gurmukhi": "ਸਹੰਸਰ ਦਾਨ ਦੇ ਇੰਦ੍ਰੁ ਰੋਆਇਆ ॥",
          "roman": "sahansar dān dē Indar roāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наложив наказание в тысячу отметин, Гаутама-риши заставил Индру плакать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40735,
          "is_rahao": false,
          "gurmukhi": "ਪਰਸ ਰਾਮੁ ਰੋਵੈ ਘਰਿ ਆਇਆ ॥",
          "roman": "Paras Rām rovē ghar āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Парасрам, лишившись своей силы перед Шри Рамом, вернулся домой и плакал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40736,
          "is_rahao": false,
          "gurmukhi": "ਅਜੈ ਸੁ ਰੋਵੈ ਭੀਖਿਆ ਖਾਇ ॥",
          "roman": "Ajē su rovē bhīkhiā khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Царь Аджай плакал, когда ему пришлось есть поданную им самим милостыню."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40737,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਦਰਗਹ ਮਿਲੈ ਸਜਾਇ ॥",
          "roman": "ēsī dargah milē sajāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В присутствии Господа бывает получено именно такое наказание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40738,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵੈ ਰਾਮੁ ਨਿਕਾਲਾ ਭਇਆ ॥",
          "roman": "rovē Rām nikālā bhēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рам тоже плакал, когда получил изгнание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
