{
  "ang": 954,
  "shabads": [
    {
      "shabad_id": 3491,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40739,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਾ ਲਖਮਣੁ ਵਿਛੁੜਿ ਗਇਆ ॥",
          "roman": "sītā lakhmaṇ vichhuṛ ga-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сита и Лакхман оказались разлучены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40740,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵੈ ਦਹਸਿਰੁ ਲੰਕ ਗਵਾਇ ॥ ਜਿਨਿ ਸੀਤਾ ਆਦੀ ਡਉਰੂ ਵਾਇ ॥",
          "roman": "rovē dahsir laṅk gavāe. jin sītā ādī ḍaurū vāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Десятиглавый Раван плачет, потеряв Ланку, тот, кто из-за Ситы поднял весь этот шум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40741,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਹਿ ਪਾਂਡਵ ਭਏ ਮਜੂਰ ॥ ਜਿਨ ਕੈ ਸੁਆਮੀ ਰਹਤ ਹਦੂਰਿ ॥",
          "roman": "rovah pāṇḍav bhae majūr. jin kē suāmī rahat hadūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пандавы плачут, став подневольными работниками, хотя их Владыка пребывал рядом с ними."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40742,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵੈ ਜਨਮੇਜਾ ਖੁਇ ਗਇਆ ॥",
          "roman": "rovē janmejā khui ga-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Джанмеджая плачет, погибнув и потеряв путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40743,
          "is_rahao": false,
          "gurmukhi": "ਏਕੀ ਕਾਰਣਿ ਪਾਪੀ ਭਇਆ ॥",
          "roman": "ēkī kāraṇ pāpī bha-iā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за одного поступка он стал грешником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40744,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਹਿ ਸੇਖ ਮਸਾਇਕ ਪੀਰ ॥",
          "roman": "rovah sekh masāik pīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Плачут шейхи, наставники и пиры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40745,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਿ ਕਾਲਿ ਮਤੁ ਲਾਗੈ ਭੀੜ ॥",
          "roman": "ant kāl mat lāgē bhīṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они боятся, как бы в последний час не настигла их беда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40746,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਹਿ ਰਾਜੇ ਕੰਨ ਪੜਾਇ ॥",
          "roman": "rovah rājē kann paṛāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Плачут цари, проколовшие себе уши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40747,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਘਰਿ ਮਾਗਹਿ ਭੀਖਿਆ ਜਾਇ ॥",
          "roman": "ghar ghar māgah bhīkhiyā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они ходят от дома к дому и просят милостыню."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40748,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਹਿ ਕਿਰਪਨ ਸੰਚਹਿ ਧਨੁ ਜਾਇ ॥",
          "roman": "rovah kirpan sañchah dhan jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Плачут скупцы, когда уходит накопленное ими богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40749,
          "is_rahao": false,
          "gurmukhi": "ਪੰਡਿਤ ਰੋਵਹਿ ਗਿਆਨੁ ਗਵਾਇ ॥",
          "roman": "paṇḍit rovah giān gavāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пандиты плачут, утратив своё знание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40750,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲੀ ਰੋਵੈ ਨਾਹਿ ਭਤਾਰੁ ॥",
          "roman": "bālī rovē nāh bhatār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Молодая женщина плачет, когда нет у неё мужа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40751,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੁਖੀਆ ਸਭੁ ਸੰਸਾਰੁ ॥",
          "roman": "nānak dukhīā sabh sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: весь мир страдает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40752,
          "is_rahao": false,
          "gurmukhi": "ਮੰਨੇ ਨਾਉ ਸੋਈ ਜਿਣਿ ਜਾਇ ॥",
          "roman": "mannē nāu soī jiṇ jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Побеждает лишь тот, кто принимает Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40753,
          "is_rahao": false,
          "gurmukhi": "ਅਉਰੀ ਕਰਮ ਨ ਲੇਖੈ ਲਾਇ ॥੧॥",
          "roman": "aurī karam na lekhē lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Другие дела не идут в зачёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3492,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40754,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40755,
          "is_rahao": false,
          "gurmukhi": "ਜਪੁ ਤਪੁ ਸਭੁ ਕਿਛੁ ਮੰਨਿਐ ਅਵਰਿ ਕਾਰਾ ਸਭਿ ਬਾਦਿ ॥",
          "roman": "jap tap sabh kichh mannīai avar kārā sabh bād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если ум утвердится в Имени Господа, то в этом уже заключены джап, тап и всякое усилие; без Имени все прочие дела напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40756,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮੰਨਿਆ ਮੰਨੀਐ ਬੁਝੀਐ ਗੁਰ ਪਰਸਾਦਿ ॥੨॥",
          "roman": "nānak manniā mannīai bujhīai gur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто принял Имя, получает почёт; это понимается по милости Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3493,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40757,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40758,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਹੰਸ ਧੁਰਿ ਮੇਲੁ ਕਰਤੈ ਲਿਖਿ ਪਾਇਆ ॥",
          "roman": "kāiā haṅs dhur mel kartē likh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Союз тела и души изначально установлен Творцом согласно Его повелению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40759,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਗੁਪਤੁ ਵਰਤਦਾ ਗੁਰਮੁਖਿ ਪ੍ਰਗਟਾਇਆ ॥",
          "roman": "sabh meh gupat varatdā gurmukh pragṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь скрыто пребывает во всех существах и проявляется через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40760,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵੈ ਗੁਣ ਉਚਰੈ ਗੁਣ ਮਾਹਿ ਸਮਾਇਆ ॥",
          "roman": "guṇ gāvē guṇ ucharē guṇ māh samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, пришедший к прибежищу Гуру, воспевает и произносит качества Господа и растворяется в этих качествах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40761,
          "is_rahao": false,
          "gurmukhi": "ਸਚੀ ਬਾਣੀ ਸਚੁ ਹੈ ਸਚੁ ਮੇਲਿ ਮਿਲਾਇਆ ॥",
          "roman": "sachī bāṇī sach hē sach mel milāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через истинную Бани Сатгуру человек становится образом Истинного Господа; Гуру соединяет его с Истинным, сохраняя в святом общении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40762,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਆਪੇ ਆਪਿ ਹੈ ਆਪੇ ਦੇਇ ਵਡਿਆਈ ॥੧੪॥",
          "roman": "sabh kichh āpē āp hē āpē dēi vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во всяком существовании Сам Господь присутствует, и Сам Он дарует величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3494,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40763,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੨ ॥",
          "roman": "salok mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Салок, Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40764,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅੰਧਾ ਹੋਇ ਕੈ ਰਤਨਾ ਪਰਖਣ ਜਾਇ ॥",
          "roman": "nānak andhā hoe kē ratnā parakhaṇ jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если человек сам слеп и идёт проверять драгоценности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40765,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨਾ ਸਾਰ ਨ ਜਾਣਈ ਆਵੈ ਆਪੁ ਲਖਾਇ ॥੧॥",
          "roman": "ratnā sār na jāṇaī āvē āp lakhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то он не знает ценности драгоценностей, а только обнаруживает собственную слепоту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3495,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40766,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40767,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨਾ ਕੇਰੀ ਗੁਥਲੀ ਰਤਨੀ ਖੋਲੀ ਆਇ ॥",
          "roman": "ratnā kerī guthlī ratnī kholī āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру, знаток драгоценностей, пришёл и раскрыл суму драгоценностей — качеств Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40768,
          "is_rahao": false,
          "gurmukhi": "ਵਖਰ ਤੈ ਵਣਜਾਰਿਆ ਦੁਹਾ ਰਹੀ ਸਮਾਇ ॥",
          "roman": "vakhar tē vaṇjāriā duhā rahī samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти драгоценности дороги и продавцу-Сатгуру, и покупателю-гурмукху; они пребывают в сердцах обоих."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40769,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਗੁਣੁ ਪਲੈ ਨਾਨਕਾ ਮਾਣਕ ਵਣਜਹਿ ਸੇਇ ॥",
          "roman": "jin guṇ pallē nānakā māṇak vaṇjah seī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только те люди покупают драгоценности Имени, у кого в сердце есть качество восхваления Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40770,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨਾ ਸਾਰ ਨ ਜਾਣਨੀ ਅੰਧੇ ਵਤਹਿ ਲੋਇ ॥੨॥",
          "roman": "ratnā sār na jāṇnī andhē vatah loe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А те, кто не знает ценности этих драгоценностей, бродят по миру словно слепые."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3496,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40771,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40772,
          "is_rahao": false,
          "gurmukhi": "ਨਉ ਦਰਵਾਜੇ ਕਾਇਆ ਕੋਟੁ ਹੈ ਦਸਵੈ ਗੁਪਤੁ ਰਖੀਜੈ ॥",
          "roman": "nau darvāje kāiā koṭ hē dasvē gupat rakhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело подобно крепости: у него есть девять явных дверей-чувств, а десятая дверь скрыта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40773,
          "is_rahao": false,
          "gurmukhi": "ਬਜਰ ਕਪਾਟ ਨ ਖੁਲਨੀ ਗੁਰ ਸਬਦਿ ਖੁਲੀਜੈ ॥",
          "roman": "bajar kapāṭ na khulanī gur sabad khulījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Створки этой десятой двери очень крепки и не открываются; они открываются только через Шабад Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40774,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਵਾਜੇ ਧੁਨਿ ਵਜਦੇ ਗੁਰ ਸਬਦਿ ਸੁਣੀਜੈ ॥",
          "roman": "anhad vāje dhun vajdē gur sabad suṇījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда эти крепкие створки открываются, звучат непрерывные инструменты, и их мелодия слышится через Шабад Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40775,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਘਟ ਅੰਤਰਿ ਚਾਨਣਾ ਕਰਿ ਭਗਤਿ ਮਿਲੀਜੈ ॥",
          "roman": "tit ghaṭ antar chānaṇā kar bhagat milījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В том сердце возникает свет знания; совершая преданность Господу, человек соединяется с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40776,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਏਕੁ ਵਰਤਦਾ ਜਿਨਿ ਆਪੇ ਰਚਨ ਰਚਾਈ ॥੧੫॥",
          "roman": "sabh meh ek varatdā jin āpē rachan rachāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Господь, Сам сотворивший всё творение, пребывает во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3497,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40777,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੨ ॥",
          "roman": "salok mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Салок, Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40778,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧੇ ਕੈ ਰਾਹਿ ਦਸਿਐ ਅੰਧਾ ਹੋਇ ਸੁ ਜਾਇ ॥",
          "roman": "andhē kē rāh dasiē andhā hoe so jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если слепой человек указывает путь, то по этому пути идёт лишь тот, кто сам слеп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40779,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਸੁਜਾਖਾ ਨਾਨਕਾ ਸੋ ਕਿਉ ਉਝੜਿ ਪਾਇ ॥",
          "roman": "hoe sujākhā nānakā so kiu ujhaṛ pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, зрячий человек не собьётся на ложный путь по слову слепого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40780,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧੇ ਏਹਿ ਨ ਆਖੀਅਨਿ ਜਿਨ ਮੁਖਿ ਲੋਇਣ ਨਾਹਿ ॥",
          "roman": "andhē eh na ākhīan jin mukh loiṇ nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В духовной жизни слепыми не называются те, у кого нет глаз на лице."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40781,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧੇ ਸੇਈ ਨਾਨਕਾ ਖਸਮਹੁ ਘੁਥੇ ਜਾਹਿ ॥੧॥",
          "roman": "andhē seī nānakā khasmhu ghuthē jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, слепы те, кто удаляется от Владыки-Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3498,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40782,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40783,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬਿ ਅੰਧਾ ਜੋ ਕੀਆ ਕਰੇ ਸੁਜਾਖਾ ਹੋਇ ॥",
          "roman": "sāhib andhā jo kīā karē sujākhā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кого Владыка-Господь Сам сделал слепым, может стать зрячим только если Господь Сам сделает его зрячим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40784,
          "is_rahao": false,
          "gurmukhi": "ਜੇਹਾ ਜਾਣੈ ਤੇਹੋ ਵਰਤੈ ਜੇ ਸਉ ਆਖੈ ਕੋਇ ॥",
          "roman": "jehā jāṇē teho vartē je sau ākhē koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Иначе слепой человек поступает согласно своему пониманию, даже если кто-нибудь объясняет ему сто раз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40785,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਸੁ ਵਸਤੁ ਨ ਜਾਪਈ ਆਪੇ ਵਰਤਉ ਜਾਣਿ ॥",
          "roman": "jithē so vasat na jāpaī āpē vartau jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В том человеке, где нет понимания предмета Имени, знай: там действует самость и сила Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40786,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗਾਹਕੁ ਕਿਉ ਲਏ ਸਕੈ ਨ ਵਸਤੁ ਪਛਾਣਿ ॥੨॥",
          "roman": "nānak gāhak kiu lae sakē na vasat pachhāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, как покупатель может приобрести товар, если он не способен его распознать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3499,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40787,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahlā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40788,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਅੰਧਾ ਆਖੀਐ ਜਿ ਹੁਕਮਹੁ ਅੰਧਾ ਹੋਇ ॥",
          "roman": "so kiu andhā ākhīai j hukamh andhā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кто по воле Господа лишён зрения, мы не называем слепым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40789,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹੁਕਮੁ ਨ ਬੁਝਈ ਅੰਧਾ ਕਹੀਐ ਸੋਇ ॥੩॥",
          "roman": "nānak hukam na bujhaī andhā kahīai soe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, слепым называется тот, кто не понимает Божественного Хукама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
