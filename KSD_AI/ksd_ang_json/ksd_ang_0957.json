{
  "ang": 957,
  "shabads": [
    {
      "shabad_id": 3517,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40888,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਕੀ ਵਾਰ ਮਹਲਾ ੫",
          "roman": "Rāmkalī kī vār mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вар в раге Рамкали, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40889,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "Ik ōaṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3518,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40890,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok maḥ 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40891,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਸਤਿਗੁਰੁ ਸੁਣੀਦਾ ਤੈਸੋ ਹੀ ਮੈ ਡੀਠੁ ॥",
          "roman": "jēsā satigur suṇīdā tēso hī mē ḍīṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каким Сатгуру был слышен, таким же я увидел его собственными глазами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40892,
          "is_rahao": false,
          "gurmukhi": "ਵਿਛੁੜਿਆ ਮੇਲੇ ਪ੍ਰਭੂ ਹਰਿ ਦਰਗਹ ਕਾ ਬਸੀਠੁ ॥",
          "roman": "vichhuṛiā mēlē prabhū har dargah kā basīṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру — посредник в присутствии Господа; он снова соединяет с Господом тех, кто был отделён от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40893,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੋ ਮੰਤ੍ਰੁ ਦ੍ਰਿੜਾਇਦਾ ਕਟੇ ਹਉਮੈ ਰੋਗੁ ॥",
          "roman": "har nāmo mantar driṛāidā kaṭē haumē rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он твёрдо утверждает в сердце наставление о памятовании имени Господа и тем самым удаляет болезнь Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40894,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਤਿਗੁਰੁ ਤਿਨਾ ਮਿਲਾਇਆ ਜਿਨਾ ਧੁਰੇ ਪਇਆ ਸੰਜੋਗੁ ॥੧॥",
          "roman": "Nānak satigur tinā milāiā jinā dhurē paiā sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Господь соединяет с Сатгуру только тех, у кого от самого Истока в судьбе записана эта встреча."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3519,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40895,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "maḥ 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40896,
          "is_rahao": false,
          "gurmukhi": "ਇਕੁ ਸਜਣੁ ਸਭਿ ਸਜਣਾ ਇਕੁ ਵੈਰੀ ਸਭਿ ਵਾਦਿ ॥",
          "roman": "ik sajaṇ sabh sajaṇā ik vērī sabh vād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если один Господь становится другом, все существа становятся друзьями; если же один Акал Пуракх становится как бы врагом, все существа становятся противниками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40897,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਦੇਖਾਲਿਆ ਵਿਣੁ ਨਾਵੈ ਸਭ ਬਾਦਿ ॥",
          "roman": "gur pūrē dēkhāliā viṇ nāvē sabh bād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Гуру показал, что без памятования Имени, без того чтобы сделать Господа своим другом, всякое другое дело бесполезно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40898,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਦੁਰਜਨ ਭਰਮਿਆ ਜੋ ਲਗੇ ਦੂਜੈ ਸਾਦਿ ॥",
          "roman": "sākat durjan bharamiā jo lagē dūjē sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Отделённые от Бога порочные люди, увлечённые вкусом майи и двойственности, блуждают в заблуждении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40899,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕਿ ਹਰਿ ਪ੍ਰਭੁ ਬੁਝਿਆ ਗੁਰ ਸਤਿਗੁਰ ਕੈ ਪਰਸਾਦਿ ॥੨॥",
          "roman": "jan Nānak har prabh bujhiā gur satigur kē parsād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак, по милости Сатгуру, обрёл глубокую связь с Господом-Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3520,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40900,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40901,
          "is_rahao": false,
          "gurmukhi": "ਥਟਣਹਾਰੈ ਥਾਟੁ ਆਪੇ ਹੀ ਥਟਿਆ ॥",
          "roman": "thaṭaṇhārē thāṭ āpē hī thaṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Создатель сам создал это устройство мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40902,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਪੂਰਾ ਸਾਹੁ ਆਪੇ ਹੀ ਖਟਿਆ ॥",
          "roman": "āpē pūrā sāh āpē hī khaṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этом мировом рынке Он сам совершенный купец, и Он сам зарабатывает прибыль своего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40903,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਿ ਪਾਸਾਰੁ ਆਪੇ ਰੰਗ ਰਟਿਆ ॥",
          "roman": "āpē kar pāsār āpē raṅg raṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам развернув творение мира, Он сам проникнут его красками и пребывает в них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40904,
          "is_rahao": false,
          "gurmukhi": "ਕੁਦਰਤਿ ਕੀਮ ਨ ਪਾਇ ਅਲਖ ਬ੍ਰਹਮਟਿਆ ॥",
          "roman": "kudrat kīm na pāi alakh brahmaṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Невозможно определить цену природе, созданной тем Непостижимым Параматмой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40905,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਥਾਹ ਬੇਅੰਤ ਪਰੈ ਪਰਟਿਆ ॥",
          "roman": "agam athāh bēant parē paraṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь недосягаем, бездонен, бесконечен; Он дальше самого дальнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40906,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵਡ ਪਾਤਿਸਾਹੁ ਆਪਿ ਵਜੀਰਟਿਆ ॥",
          "roman": "āpē vaḍ pātisāh āp vajīraṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сам великий царь и сам себе советник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40907,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਜਾਣੈ ਕੀਮ ਕੇਵਡੁ ਮਟਿਆ ॥",
          "roman": "koi na jāṇē kīm kēvaḍ maṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ни одно существо не может оценить Его величие; никто не знает, насколько высоко Его обиталище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40908,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਸਾਹਿਬੁ ਆਪਿ ਗੁਰਮੁਖਿ ਪਰਗਟਿਆ ॥੧॥",
          "roman": "sachā sāhib āp gurmukh pargaṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сам вечный Владыка; через Гуру, идя путём Гуру, приходит Его постижение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3521,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40909,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੫ ॥",
          "roman": "salok maḥ 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40910,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸਜਣ ਪ੍ਰੀਤਮ ਮੇਰਿਆ ਮੈ ਸਤਿਗੁਰੁ ਦੇਹੁ ਦਿਖਾਲਿ ॥",
          "roman": "suṇ sajaṇ prītam mēriā mē satigur dēh dikhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой любимый друг-Прабху, услышь мою мольбу: дай мне увидеть Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40911,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਤਿਸੁ ਦੇਵਾ ਮਨੁ ਆਪਣਾ ਨਿਤ ਹਿਰਦੈ ਰਖਾ ਸਮਾਲਿ ॥",
          "roman": "hau tis dēvā man āpaṇā nit hirdē rakhā samāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я отдам тому Гуру свой ум и всегда буду бережно хранить его в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40912,
          "is_rahao": false,
          "gurmukhi": "ਇਕਸੁ ਸਤਿਗੁਰ ਬਾਹਰਾ ਧ੍ਰਿਗੁ ਜੀਵਣੁ ਸੰਸਾਰਿ ॥",
          "roman": "ikas satigur bāhrā dhrig jīvaṇ sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без единого Сатгуру жизнь в мире достойна порицания, ибо без пути, указанного Гуру, человек встречает лишь укоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40913,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸਤਿਗੁਰੁ ਤਿਨਾ ਮਿਲਾਇਓਨੁ ਜਿਨ ਸਦ ਹੀ ਵਰਤੈ ਨਾਲਿ ॥੧॥",
          "roman": "jan Nānak satigur tinā milāion jin sad hī vartē nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак, Господь соединяет с Сатгуру тех счастливцев, с кем Он сам всегда пребывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3522,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40914,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "maḥ 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40915,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੈ ਅੰਤਰਿ ਲੋਚਾ ਮਿਲਣ ਕੀ ਕਿਉ ਪਾਵਾ ਪ੍ਰਭ ਤੋਹਿ ॥",
          "roman": "mērē antar lochā milaṇ kī kiu pāvā prabh toh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху, в моём сердце есть жажда встречи с Тобой; как мне встретить Тебя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40916,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਐਸਾ ਸਜਣੁ ਲੋੜਿ ਲਹੁ ਜੋ ਮੇਲੇ ਪ੍ਰੀਤਮੁ ਮੋਹਿ ॥",
          "roman": "koī aisā sajaṇ loṛ lah jo mēlē prītam moh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Найдите мне такого друга, который соединит меня с моим любимым Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40917,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਮੇਲਾਇਆ ਜਤ ਦੇਖਾ ਤਤ ਸੋਇ ॥",
          "roman": "gur pūrē mēlāiā jat dēkhā tat soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Гуру соединил меня с Прабху; теперь куда бы я ни взглянул, везде вижу только Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40918,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸੋ ਪ੍ਰਭੁ ਸੇਵਿਆ ਤਿਸੁ ਜੇਵਡੁ ਅਵਰੁ ਨ ਕੋਇ ॥੨॥",
          "roman": "jan Nānak so prabh sēviā tis jēvaḍ avar na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак, я помню и служу тому Прабху; нет никого другого, равного Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3523,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40919,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40920,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵਣਹਾਰੁ ਦਾਤਾਰੁ ਕਿਤੁ ਮੁਖਿ ਸਾਲਾਹੀਐ ॥",
          "roman": "dēvaṇhār dātār kit mukh salāhīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какими устами можно восхвалить Прабху, Дающего и Подателя? Ни одно существо не может полностью воспеть Его славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40921,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਰਖੈ ਕਿਰਪਾ ਧਾਰਿ ਰਿਜਕੁ ਸਮਾਹੀਐ ॥",
          "roman": "jis rakhē kirpā dhār rijak samāhīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тому существу, которого Прабху хранит по своей милости, Он доставляет пропитание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40922,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਕਿਸ ਹੀ ਵਸਿ ਸਭਨਾ ਇਕ ਧਰ ॥",
          "roman": "koi na kis hī vas sabhnā ik dhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На самом деле ни одно существо не находится под опорой другого; опора всех существ — один Параматма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40923,
          "is_rahao": false,
          "gurmukhi": "ਪਾਲੇ ਬਾਲਕ ਵਾਗਿ ਦੇ ਕੈ ਆਪਿ ਕਰ ॥",
          "roman": "pālē bālak vāg dē kē āp kar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам даёт свои руки и заботится о существах, как о детях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40924,
          "is_rahao": false,
          "gurmukhi": "ਕਰਦਾ ਅਨਦ ਬਿਨੋਦ ਕਿਛੂ ਨ ਜਾਣੀਐ ॥",
          "roman": "kardā anad binod kichhū na jāṇīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам совершает свои чудесные игры и забавы; их невозможно постигнуть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40925,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਧਾਰ ਸਮਰਥ ਹਉ ਤਿਸੁ ਕੁਰਬਾਣੀਐ ॥",
          "roman": "sarab dhār samrath hau tis kurbāṇīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой тому Прабху, который является опорой всех существ и обладает силой совершить всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40926,
          "is_rahao": false,
          "gurmukhi": "ਗਾਈਐ ਰਾਤਿ ਦਿਨੰਤੁ ਗਾਵਣ ਜੋਗਿਆ ॥",
          "roman": "gāīai rāt dinant gāvaṇ jogiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Днём и ночью следует петь славу Прабху; только Он достоин того, чтобы Его качества воспевались."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40927,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਗੁਰ ਕੀ ਪੈਰੀ ਪਾਹਿ ਤਿਨੀ ਹਰਿ ਰਸੁ ਭੋਗਿਆ ॥੨॥",
          "roman": "jo gur kī pērī pāh tinī har ras bhogiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но радость воспевания Господа вкушают только те, кто припадает к стопам Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3524,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40928,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok maḥ 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40929,
          "is_rahao": false,
          "gurmukhi": "ਭੀੜਹੁ ਮੋਕਲਾਈ ਕੀਤੀਅਨੁ ਸਭ ਰਖੇ ਕੁਟੰਬੈ ਨਾਲਿ ॥",
          "roman": "bhīṛah moklāī kītīan sabh rakhē kuṭambē nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Прабху освобождает тебя от бед и хранит тебя вместе со всем твоим семейством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40930,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜ ਆਪਿ ਸਵਾਰਿਅਨੁ ਸੋ ਪ੍ਰਭ ਸਦਾ ਸਭਾਲਿ ॥",
          "roman": "kāraj āp savārian so prabh sadā sabhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда помни того Прабху, который сам устраивает и исправляет все твои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40931,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਮਾਤ ਪਿਤਾ ਕੰਠਿ ਲਾਇਦਾ ਲਹੁੜੇ ਬਾਲਕ ਪਾਲਿ ॥",
          "roman": "prabh māt pitā kaṇṭh lāidā lahuṛē bālak pāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как мать и отец, Прабху выращивает малых, неразумных детей и прижимает их к своему горлу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40932,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਹੋਏ ਸਭ ਜੀਅ ਜੰਤ੍ਰ ਹਰਿ ਨਾਨਕ ਨਦਰਿ ਨਿਹਾਲ ॥੧॥",
          "roman": "daiāl hoē sabh jīa jantar har Nānak nadar nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, на того человека, на кого Господь смотрит милостивым взором, все живые существа становятся милостивыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
