{
  "ang": 958,
  "shabads": [
    {
      "shabad_id": 3525,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40933,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40934,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਤੁਧੁ ਹੋਰੁ ਜਿ ਮੰਗਣਾ ਸਿਰਿ ਦੁਖਾ ਕੈ ਦੁਖ ॥",
          "roman": "viṇ tudh hor je maṅgaṇā sir dukhā kē dukh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Просить у Тебя чего-либо иного, кроме Твоего имени, значит навлекать на себя тяжкие страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40935,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹਿ ਨਾਮੁ ਸੰਤੋਖੀਆ ਉਤਰੈ ਮਨ ਕੀ ਭੁਖ ॥",
          "roman": "dēh nām santokhīā utrē man kī bhukh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Дай мне Своё Имя, чтобы я обрёл удовлетворение и чтобы жажда моего ума исчезла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40936,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਵਣੁ ਤਿਣੁ ਹਰਿਆ ਕੀਤਿਆ ਨਾਨਕ ਕਿਆ ਮਨੁਖ ॥੨॥",
          "roman": "gur vaṇ tiṇ hariā kītā Nānak kiā manukh. 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Гуру, который сделал зелёными лес и сухую травинку леса, — разве трудно ему оживить людей?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3526,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40937,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40938,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਐਸਾ ਦਾਤਾਰੁ ਮਨਹੁ ਨ ਵੀਸਰੈ ॥",
          "roman": "so ēsā dātār manah na vīsarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такого Подателя даров, Прабху, не следует забывать в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40939,
          "is_rahao": false,
          "gurmukhi": "ਘੜੀ ਨ ਮੁਹਤੁ ਚਸਾ ਤਿਸੁ ਬਿਨੁ ਨਾ ਸਰੈ ॥",
          "roman": "ghaṛī na muhat chasā tis bin nā sarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ибо без Него, забыв Его, даже час, два часа, миг или совсем малое мгновение жизни не проходят легко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40940,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਸੰਗਿ ਕਿਆ ਕੋ ਲੁਕਿ ਕਰੈ ॥",
          "roman": "antar bāhar saṅg kiā ko luk karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху всегда пребывает внутри существа и снаружи, вокруг него; никто не может сделать что-либо тайно, скрывшись от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40941,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪਤਿ ਰਖੈ ਆਪਿ ਸੋ ਭਵਜਲੁ ਤਰੈ ॥",
          "roman": "jis pat rakhē āp so bhavjal tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот человек переправляется через океан мира и спасается от мирских пороков, чью честь Сам Прабху оберегает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40942,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤੁ ਗਿਆਨੀ ਤਪਾ ਜਿਸੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "bhagat gyānī tapā jis kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот и есть бхагат, тот и есть знающий, тот и есть подвижник, на кого Прабху проливает Свою милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40943,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪੂਰਾ ਪਰਧਾਨੁ ਜਿਸ ਨੋ ਬਲੁ ਧਰੈ ॥",
          "roman": "so pūrā pardhān jis no bal dharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кому Прабху дарует духовную силу для противостояния порокам, становится человеком с успешной духовной практикой и обретает почёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40944,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਜਰਾਏ ਆਪਿ ਸੋਈ ਅਜਰੁ ਜਰੈ ॥",
          "roman": "jiseh jarāē āp soī ajar jarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эту трудно выносимую и легко сбивающую с пути силу выдерживает лишь тот человек, кому Сам Прабху помогает сохранить устойчивость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40945,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਹੀ ਮਿਲਿਆ ਸਚੁ ਮੰਤ੍ਰੁ ਗੁਰ ਮਨਿ ਧਰੈ ॥੩॥",
          "roman": "tis hī miliā sach mantar gur man dharē. 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто утверждает в сердце наставление Гуру, встречает вечно пребывающего Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3527,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40946,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятая махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40947,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਰਾਗ ਸੁਰੰਗੜੇ ਆਲਾਪਤ ਸਭ ਤਿਖ ਜਾਇ ॥",
          "roman": "dhan so rāg suraṅgaṛē ālāpat sabh tikh jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенны прекрасные раги, при пении которых исчезает вся жажда ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40948,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਜੰਤ ਸੁਹਾਵੜੇ ਜੋ ਗੁਰਮੁਖਿ ਜਪਦੇ ਨਾਉ ॥",
          "roman": "dhan so jant suhāvaṛē jo gurmukh japdē nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенны прекрасные существа, которые, став лицом к Гуру, повторяют Имя Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40949,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੀ ਇਕ ਮਨਿ ਇਕੁ ਅਰਾਧਿਆ ਤਿਨ ਸਦ ਬਲਿਹਾਰੈ ਜਾਉ ॥",
          "roman": "jinī ik man ik arādhiā tin sad balihārē jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я всегда приношу себя в жертву тем людям, которые единым умом вспоминают Единого Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40950,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕੀ ਧੂੜਿ ਹਮ ਬਾਛਦੇ ਕਰਮੀ ਪਲੈ ਪਾਇ ॥",
          "roman": "tin kī dhūṛ ham bāchhdē karmī palē pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я желаю пыли их стоп, но эта пыль обретается лишь по милости Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40951,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਰਤੇ ਰੰਗਿ ਗੋਵਿਦ ਕੈ ਹਉ ਤਿਨ ਬਲਿਹਾਰੈ ਜਾਉ ॥",
          "roman": "jo ratē raṅg Govind kē hau tin balihārē jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто окрашены любовью к Параматме, — им я приношу себя в жертву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40952,
          "is_rahao": false,
          "gurmukhi": "ਆਖਾ ਬਿਰਥਾ ਜੀਅ ਕੀ ਹਰਿ ਸਜਣੁ ਮੇਲਹੁ ਰਾਇ ॥",
          "roman": "ākhā birthā jīa kī Har sajaṇ melah rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я рассказываю им боль своего сердца и говорю: соедините меня с любимым Прабху-Патишахом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40953,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਮੇਲਾਇਆ ਜਨਮ ਮਰਣ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "gur pūrē melāiā janam maraṇ dukh jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого совершенный Сатгуру соединяет с Прабху, у того исчезает страдание всей жизни, страдание рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40954,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਪਾਇਆ ਅਗਮ ਰੂਪੁ ਅਨਤ ਨ ਕਾਹੂ ਜਾਇ ॥੧॥",
          "roman": "jan Nānak pāiā agam rūp anat na kāhū jāē. 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такой человек обретает недостижимого Прабху, чей облик невозможно постичь полностью, и больше не блуждает ни в какую другую сторону."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3528,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40955,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40956,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਵੇਲਾ ਘੜੀ ਧੰਨੁ ਧਨੁ ਮੂਰਤੁ ਪਲੁ ਸਾਰੁ ॥",
          "roman": "dhan so vēlā ghaṛī dhan dhan mūrat pal sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенны тот час и та минута; благословен тот мухурт, и прекрасен тот миг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40957,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਦਿਨਸੁ ਸੰਜੋਗੜਾ ਜਿਤੁ ਡਿਠਾ ਗੁਰ ਦਰਸਾਰੁ ॥",
          "roman": "dhan so dinas sañjogaṛā jit ḍiṭhā gur darsār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенны тот день и то прекрасное соединение обстоятельств, когда происходит даршан Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40958,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕੀਆ ਇਛਾ ਪੂਰੀਆ ਹਰਿ ਪਾਇਆ ਅਗਮ ਅਪਾਰੁ ॥",
          "roman": "man kīā ichhā pūrīā Har pāiā agam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря даршану Сатгуру исполняются все желания ума, то есть ум становится свободным от страстных влечений, и обретается недостижимый, бесконечный Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40959,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਤੁਟਾ ਮੋਹੜਾ ਇਕੁ ਸਚੁ ਨਾਮੁ ਆਧਾਰੁ ॥",
          "roman": "haumē tuṭā mohṛā ik sach nām ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хоумэ уничтожается, злой мох исчезает, и лишь вечно пребывающее Имя Прабху становится опорой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40960,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਨਾਨਕੁ ਲਗਾ ਸੇਵ ਹਰਿ ਉਧਰਿਆ ਸਗਲ ਸੰਸਾਰੁ ॥੨॥",
          "roman": "jan Nānak lagā sēv Har udhariā sagal sansār. 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дас Нанак тоже, благодаря даршану Гуру, прилепился к симрану Прабху; благодаря этому симрану весь мир спасается от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3529,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40961,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40962,
          "is_rahao": false,
          "gurmukhi": "ਸਿਫਤਿ ਸਲਾਹਣੁ ਭਗਤਿ ਵਿਰਲੇ ਦਿਤੀਅਨੁ ॥",
          "roman": "sifat salāhaṇ bhagat virlē ditīan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дар восхваления и бхагати Прабху даёт лишь редкому счастливому человеку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40963,
          "is_rahao": false,
          "gurmukhi": "ਸਉਪੇ ਜਿਸੁ ਭੰਡਾਰ ਫਿਰਿ ਪੁਛ ਨ ਲੀਤੀਅਨੁ ॥",
          "roman": "saupē jis bhaṇḍār phir puchh na lītīan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которому Он передаёт сокровища восхваления, Он потом уже не спрашивает отчёта за совершённые дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40964,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਲਗਾ ਰੰਗੁ ਸੇ ਰੰਗਿ ਰਤਿਆ ॥",
          "roman": "jis no lagā raṅg sē raṅg ratiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, к кому привилась любовь восхваления, навсегда окрашиваются в этот цвет любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40965,
          "is_rahao": false,
          "gurmukhi": "ਓਨਾ ਇਕੋ ਨਾਮੁ ਅਧਾਰੁ ਇਕਾ ਉਨ ਭਤਿਆ ॥",
          "roman": "onā iko nām adhār ikā un bhatiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Память о Прабху становится единственной опорой их жизни, и это одно Имя становится их духовной пищей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40966,
          "is_rahao": false,
          "gurmukhi": "ਓਨਾ ਪਿਛੈ ਜਗੁ ਭੁੰਚੈ ਭੋਗਈ ॥",
          "roman": "onā pichhē jag bhuñchē bhogaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следуя по следам таких людей, весь мир вкушает и наслаждается пищей восхваления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40967,
          "is_rahao": false,
          "gurmukhi": "ਓਨਾ ਪਿਆਰਾ ਰਬੁ ਓਨਾਹਾ ਜੋਗਈ ॥",
          "roman": "onā piārā rab onāhā jogaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рэб становится им настолько дорог, что оказывается во власти их любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40968,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਿਲਿਆ ਗੁਰੁ ਆਇ ਤਿਨਿ ਪ੍ਰਭੁ ਜਾਣਿਆ ॥",
          "roman": "jis miliā gur āē tin Prabh jāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но знакомство с Прабху обрёл только тот человек, к кому пришёл и встретился Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40969,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬਲਿਹਾਰੀ ਤਿਨ ਜਿ ਖਸਮੈ ਭਾਣਿਆ ॥੪॥",
          "roman": "hau balihārī tin je khasmē bhāṇiā. 4",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я приношу себя в жертву тем счастливым людям, которые стали угодны Хозяину-Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3530,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40970,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятая махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40971,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕਸੈ ਨਾਲਿ ਮੈ ਦੋਸਤੀ ਹਰਿ ਇਕਸੈ ਨਾਲਿ ਮੈ ਰੰਗੁ ॥",
          "roman": "Har iksē nāl mē dostī Har iksē nāl mē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя дружба только с одним Прабху; только с одним Прабху моя любовь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40972,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕੋ ਮੇਰਾ ਸਜਣੋ ਹਰਿ ਇਕਸੈ ਨਾਲਿ ਮੈ ਸੰਗੁ ॥",
          "roman": "Har iko mērā sajaṇo Har iksē nāl mē saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только Прабху — мой истинный друг; только с одним Прабху у меня истинное товарищество."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40973,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕਸੈ ਨਾਲਿ ਮੈ ਗੋਸਟੇ ਮੁਹੁ ਮੈਲਾ ਕਰੈ ਨ ਭੰਗੁ ॥",
          "roman": "Har iksē nāl mē gosṭē muh mēlā karē na bhaṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только с одним Прабху у меня общение и близость, ибо этот Прабху никогда не делает недовольного лица и никогда не хмурит лоб."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40974,
          "is_rahao": false,
          "gurmukhi": "ਜਾਣੈ ਬਿਰਥਾ ਜੀਅ ਕੀ ਕਦੇ ਨ ਮੋੜੈ ਰੰਗੁ ॥",
          "roman": "jāṇē birthā jīa kī kadē na moṛē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он знает боль моего сердца и никогда не отталкивает мою любовь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40975,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕੋ ਮੇਰਾ ਮਸਲਤੀ ਭੰਨਣ ਘੜਨ ਸਮਰਥੁ ॥",
          "roman": "Har iko mērā maslatī bhaṅnaṇ ghaṛan samrath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Параматма, обладающий силой создавать и разрушать всех существ, — единственный мой советник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40976,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕੋ ਮੇਰਾ ਦਾਤਾਰੁ ਹੈ ਸਿਰਿ ਦਾਤਿਆ ਜਗ ਹਥੁ ॥",
          "roman": "Har iko mērā dātār hē sir dātiā jag hath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только Он — мой Податель даров; Его рука пребывает над всеми дарителями мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40977,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਇਕਸੈ ਦੀ ਮੈ ਟੇਕ ਹੈ ਜੋ ਸਿਰਿ ਸਭਨਾ ਸਮਰਥੁ ॥",
          "roman": "Har iksē dī mē ṭēk hē jo sir sabhnā samrath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя опора только в одном Прабху, который могуществен над всеми существами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40978,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਸੰਤੁ ਮਿਲਾਇਆ ਮਸਤਕਿ ਧਰਿ ਕੈ ਹਥੁ ॥",
          "roman": "satgur sant milāiā mastak dhar kē hath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру, положив руку на мой лоб, соединил меня с Параматмой, источником покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
