{
  "ang": 961,
  "shabads": [
    {
      "shabad_id": 3537,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41060,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਾਣੀ ਸਤਿਗੁਰ ਪੂਰੇ ਕੀ ਜਿਸੁ ਕਿਰਪਾਲੁ ਹੋਵੈ ਤਿਸੁ ਰਿਦੈ ਵਸੇਹਾ ॥",
          "roman": "amrit bāṇī satigur pūrē kī jis kirpāl hovē tis ridē vasēhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Амритная Бани совершенного Сатгуру поселяется в сердце того, к кому Господь милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41061,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣ ਜਾਣਾ ਤਿਸ ਕਾ ਕਟੀਐ ਸਦਾ ਸਦਾ ਸੁਖੁ ਹੋਹਾ ॥੨॥",
          "roman": "āvaṇ jāṇā tis kā kaṭīai sadā sadā sukh hohā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его круг приходов и уходов пресекается, и он навсегда обретает покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3538,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41062,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41063,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਣਾ ਜੰਤੁ ਸੋ ਤੁਧੁ ਬੁਝਈ ॥",
          "roman": "jo tudh bhāṇā jant so tudh bujhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! То существо, которое становится Тебе дорогим, входит с Тобой в связь и познаёт Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41064,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਣਾ ਜੰਤੁ ਸੁ ਦਰਗਹ ਸਿਝਈ ॥",
          "roman": "jo tudh bhāṇā jant so dargah sijhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "То существо, которое становится Тебе дорогим, успешно завершает путь жизни и достигает Твоего присутствия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41065,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਨਦਰਿ ਹਉਮੈ ਤਿਸੁ ਗਈ ॥",
          "roman": "jis no terī nadar haumē tis gaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На кого падает Твой милостивый взгляд, у того исчезает Хоумэ, чувство собственного «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41066,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੂ ਸੰਤੁਸਟੁ ਕਲਮਲ ਤਿਸੁ ਖਈ ॥",
          "roman": "jis no tū santusṭ kalmal tis khaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кем Ты доволен, у того уничтожаются все грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41067,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਸੁਆਮੀ ਵਲਿ ਨਿਰਭਉ ਸੋ ਭਈ ॥",
          "roman": "jis kē suāmī val nirbhau so bhaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, на чьей стороне Владыка-Господь, становится бесстрашным перед страхами мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41068,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੂ ਕਿਰਪਾਲੁ ਸਚਾ ਸੋ ਥਿਅਈ ॥",
          "roman": "jis no tū kirpāl sachā so thiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! К кому Ты милостив, тот становится устойчивым и непоколебимым перед нападениями майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41069,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਮਇਆ ਨ ਪੋਹੈ ਅਗਨਈ ॥",
          "roman": "jis no terī mēā na pohē agnaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, на кого есть Твоя милость, не может коснуться огонь майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41070,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਨੋ ਸਦਾ ਦਇਆਲੁ ਜਿਨਿ ਗੁਰ ਤੇ ਮਤਿ ਲਈ ॥੭॥",
          "roman": "tis no sadā daiāl jin gur tē mat laī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь, Ты всегда милостив к тому, кто научился у Гуру мудрости человеческой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3539,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41071,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41072,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਕਿਰਪਾਲ ਆਪੇ ਬਖਸਿ ਲੈ ॥",
          "roman": "kar kirpā kirpāl āpē bakhas lē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый Господь! Прояви милость и Сам прости меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41073,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਪੀ ਤੇਰਾ ਨਾਮੁ ਸਤਿਗੁਰ ਪਾਇ ਪੈ ॥",
          "roman": "sadā sadā japī terā nām satigur pāi pē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть, припав к стопам Сатгуру, я всегда-всегда повторяю Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41074,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਅੰਤਰਿ ਵਸੁ ਦੂਖਾ ਨਾਸੁ ਹੋਇ ॥",
          "roman": "man tan antar vas dūkhā nās hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый! Поселись в моём уме и теле, чтобы мои страдания исчезли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41075,
          "is_rahao": false,
          "gurmukhi": "ਹਥ ਦੇਇ ਆਪਿ ਰਖੁ ਵਿਆਪੈ ਭਉ ਨ ਕੋਇ ॥",
          "roman": "hath dē āp rakh viāpē bhau na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам защити меня, протянув Свою руку, чтобы никакой страх не мог овладеть мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41076,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵਾ ਦਿਨੁ ਰੈਣਿ ਏਤੈ ਕੰਮਿ ਲਾਇ ॥",
          "roman": "guṇ gāvā din rēṇ etē kamm lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый! Держи меня занятым этим делом, чтобы я днём и ночью воспевал Твои качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41077,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਕੈ ਸੰਗਿ ਹਉਮੈ ਰੋਗੁ ਜਾਇ ॥",
          "roman": "sant janā kē saṅg haumē rog jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть в обществе святых людей будет отсечена болезнь моего Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41078,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਖਸਮੁ ਏਕੋ ਰਵਿ ਰਹਿਆ ॥",
          "roman": "sarab niraṅtar khasam ēko rav rahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Один Господь-Владыка непрерывно пребывает во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41079,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਸਚੁ ਸਚੋ ਸਚੁ ਲਹਿਆ ॥",
          "roman": "gur prasādī sach sacho sach lahiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но вечного, истиннейшего Господа находят только по милости Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41080,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਕਰਹੁ ਦਇਆਲ ਅਪਣੀ ਸਿਫਤਿ ਦੇਹੁ ॥",
          "roman": "daiā karah daiāl apṇī sifat dēh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О милостивый Господь! Прояви милость, даруй мне Твоё восхваление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41081,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਦੇਖਿ ਨਿਹਾਲ ਨਾਨਕ ਪ੍ਰੀਤਿ ਏਹ ॥੧॥",
          "roman": "darsan dēkh nihāl nānak prīt eh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Нанака есть лишь это стремление: созерцая Твоё явление, пребывать в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3540,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41082,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41083,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਜਪੀਐ ਮਨੈ ਮਾਹਿ ਇਕਸ ਕੀ ਸਰਣਾਇ ॥",
          "roman": "ēko japīē manē māh ikas kī saraṇāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Одного Господа следует созерцать в уме, прибежище следует принимать только у одного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41084,
          "is_rahao": false,
          "gurmukhi": "ਇਕਸੁ ਸਿਉ ਕਰਿ ਪਿਰਹੜੀ ਦੂਜੀ ਨਾਹੀ ਜਾਇ ॥",
          "roman": "ikas sio kar pirhaṛī dūjī nāhī jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! Люби только одного Господа; кроме Него нет иного места опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41085,
          "is_rahao": false,
          "gurmukhi": "ਇਕੋ ਦਾਤਾ ਮੰਗੀਐ ਸਭੁ ਕਿਛੁ ਪਲੈ ਪਾਇ ॥",
          "roman": "iko dātā maṅgīē sabh kichh palē pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Просить следует только у одного Господа-Даятеля, ибо всё получается только от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41086,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਸਾਸਿ ਗਿਰਾਸਿ ਪ੍ਰਭੁ ਇਕੋ ਇਕੁ ਧਿਆਇ ॥",
          "roman": "man tan sās girās prabh iko ik dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Умом, телом, с каждым дыханием и с каждым куском пищи поминай одного-единственного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41087,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਨਾਮੁ ਨਿਧਾਨੁ ਸਚੁ ਗੁਰਮੁਖਿ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "amrit nām nidhān sach gurmukh pāiā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дающее духовную жизнь Имя Господа, вечное сокровище, обретается только через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41088,
          "is_rahao": false,
          "gurmukhi": "ਵਡਭਾਗੀ ਤੇ ਸੰਤ ਜਨ ਜਿਨ ਮਨਿ ਵੁਠਾ ਆਇ ॥",
          "roman": "vaḍbhāgī tē sant jan jin man vuṭhā āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Великим счастьем обладают те святые люди, в чьих сердцах поселился Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41089,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਰਵਿ ਰਹਿਆ ਦੂਜਾ ਕੋਈ ਨਾਹਿ ॥",
          "roman": "jal thal mahīal rav rahiā dūjā koī nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь пребывает в воде, на земле и в небесном пространстве; кроме Него нигде нет никого другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41090,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਧਿਆਈ ਨਾਮੁ ਉਚਰਾ ਨਾਨਕ ਖਸਮ ਰਜਾਇ ॥੨॥",
          "roman": "nām dhiāī nām ucharā nānak khasam rajāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Молись, чтобы и я созерцал Имя Господа, произносил Имя устами и жил в воле Господа-Владыки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3541,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41091,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41092,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੂ ਰਖਵਾਲਾ ਮਾਰੇ ਤਿਸੁ ਕਉਣੁ ॥",
          "roman": "jis no tū rakhvālā mārē tis kauṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Человека, которому Ты стал Защитником, никто, никакой порок, не может убить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41093,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੂ ਰਖਵਾਲਾ ਜਿਤਾ ਤਿਨੈ ਭੈਣੁ ॥",
          "roman": "jis no tū rakhvālā jitā tinē bhēṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Потому что тот, кому Ты Защитник, уже победил весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41094,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰਾ ਅੰਗੁ ਤਿਸੁ ਮੁਖੁ ਉਜਲਾ ॥",
          "roman": "jis no terā aṅg tis mukh ujlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Тот, кто получил Твою опору, стал просветлённым и достойным в человеческой ответственности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41095,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰਾ ਅੰਗੁ ਸੁ ਨਿਰਮਲੀ ਹੂੰ ਨਿਰਮਲਾ ॥",
          "roman": "jis no terā aṅg so nirmalī hūṅ nirmalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто имеет Твою опору, становится чище самых чистых, человеком святой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41096,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਨਦਰਿ ਨ ਲੇਖਾ ਪੁਛੀਐ ॥",
          "roman": "jis no terī nadar na lekhā puchhīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! С того, кому достался Твой милостивый взгляд, не спрашивают счёта дел, совершённых в жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41097,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਖੁਸੀ ਤਿਨਿ ਨਉ ਨਿਧਿ ਭੁੰਚੀਐ ॥",
          "roman": "jis no terī khushī tin nau nidh bhuñchīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ибо тот, кто получил Твоё благоволение, уже насладился девятью сокровищами в виде Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41098,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੂ ਪ੍ਰਭ ਵਲਿ ਤਿਸੁ ਕਿਆ ਮੁਹਛੰਦਗੀ ॥",
          "roman": "jis no tū prabh val tis kiā muhchhandagī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Тот, на чьей стороне Ты, не остаётся зависимым ни от кого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41099,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਮਿਹਰ ਸੁ ਤੇਰੀ ਬੰਦਿਗੀ ॥੮॥",
          "roman": "jis no terī mihar so terī bandigī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, на ком Твоя милость, совершает Твоё поклонение и служение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3542,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41100,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਹਲਾ ੫ ॥",
          "roman": "salok mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41101,
          "is_rahao": false,
          "gurmukhi": "ਹੋਹੁ ਕ੍ਰਿਪਾਲ ਸੁਆਮੀ ਮੇਰੇ ਸੰਤਾਂ ਸੰਗਿ ਵਿਹਾਵੇ ॥",
          "roman": "hoh kripāl suāmī merē santāṅ saṅg vihāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Владыка! Будь милостив ко мне, чтобы моя жизнь проходила в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41102,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧਹੁ ਭੁਲੇ ਸਿ ਜਮਿ ਜਮਿ ਮਰਦੇ ਤਿਨ ਕਦੇ ਨ ਚੁਕਨਿ ਹਾਵੇ ॥੧॥",
          "roman": "tudhah bhulē se jam jam mardē tin kadē na chukan hāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые отпадают от Тебя, снова и снова рождаются и умирают; их стоны никогда не прекращаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3543,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41103,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41104,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸਿਮਰਹੁ ਆਪਣਾ ਘਟਿ ਅਵਘਟਿ ਘਟ ਘਾਟ ॥",
          "roman": "satigur simrah āpṇā ghaṭ avghaṭ ghaṭ ghāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Помните своего Гуру в сердце, вставая и садясь, во всякое время и в любом месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41105,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪੰਤਿਆ ਕੋਇ ਨ ਬੰਧੈ ਵਾਟ ॥੨॥",
          "roman": "har har nām japantiā koi na bandhē vāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда повторяют Имя Хар-Хар, никакой порок не может преградить путь жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3544,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41106,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
