{
  "ang": 974,
  "shabads": [
    {
      "shabad_id": 3608,
      "rahao_verse_id": 41625,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41624,
          "is_rahao": true,
          "gurmukhi": "ਦੇਵ ਸੰਸੈ ਗਾਂਠਿ ਨ ਛੂਟੈ ॥",
          "roman": "dēv sansē gāṅṭh na chhūṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Боже, узел сомнения не развязывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41625,
          "is_rahao": true,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਮਾਇਆ ਮਦ ਮਤਸਰ ਇਨ ਪੰਚਹੁ ਮਿਲਿ ਲੂਟੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kām krōdh māiā mad matsar in pañchahu mil lūṭē rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Похоть, гнев, майя, гордыня и зависть — эти пятеро, сговорившись, грабят человека. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41626,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਬਡ ਕਬਿ ਕੁਲੀਨ ਹਮ ਪੰਡਿਤ ਹਮ ਜੋਗੀ ਸੰਨਿਆਸੀ ॥",
          "roman": "ham baḍ kab kulīn ham paṇḍit ham jōgī sanniāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы считаем себя великими поэтами, знатными, учёными-пандитами, йогами и санньяси."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41627,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨੀ ਗੁਨੀ ਸੂਰ ਹਮ ਦਾਤੇ ਇਹ ਬੁਧਿ ਕਬਹਿ ਨ ਨਾਸੀ ॥੨॥",
          "roman": "giānī gunī sūr ham dātē ih budh kabah na nāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы считаем себя знающими, добродетельными, героями и дарителями; такая самодовольная мысль никак не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41628,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਰਵਿਦਾਸ ਸਭੈ ਨਹੀ ਸਮਝਸਿ ਭੂਲਿ ਪਰੇ ਜੈਸੇ ਬਉਰੇ ॥",
          "roman": "kah Ravidās sabhē nahī samjhas bhūl parē jēsē baurē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Говорит Равидас: все не понимают истины и, заблудившись, ведут себя как безумные."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41629,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਅਧਾਰੁ ਨਾਮੁ ਨਾਰਾਇਨ ਜੀਵਨ ਪ੍ਰਾਨ ਧਨ ਮੋਰੇ ॥੩॥੧॥",
          "roman": "mohi adhār nām Nārāin jīvan prān dhan mōrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя опора — Имя Нараяна; оно моя жизнь, мои праны и моё богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3609,
      "rahao_verse_id": 41636,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41630,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਬਾਣੀ ਬੇਣੀ ਜੀਉ ਕੀ",
          "roman": "Rāmkali bāṇī Bēṇī jī kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, бани Бени Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41631,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Оанкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41632,
          "is_rahao": false,
          "gurmukhi": "ਇੜਾ ਪਿੰਗੁਲਾ ਅਉਰ ਸੁਖਮਨਾ ਤੀਨਿ ਬਸਹਿ ਇਕ ਠਾਈ ॥",
          "roman": "iṛā piṅgulā aur sukhamnā tīn basah ik ṭhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для человека, достигшего состояния соединения с Господом, ида, пингала и сукхмана — все три пребывают в одном месте; ему уже не нужен особый йогический अभ्यास этих трёх каналов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41633,
          "is_rahao": false,
          "gurmukhi": "ਬੇਣੀ ਸੰਗਮੁ ਤਹ ਪਿਰਾਗੁ ਮਨੁ ਮਜਨੁ ਕਰੇ ਤਿਥਾਈ ॥੧॥",
          "roman": "Bēṇī saṅgam tah Pirāg man majan karē tithāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для него и Трибени-сангам, и святое место Праяг находятся там же; его ум совершает омовение в соединении с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41634,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਤਹਾ ਨਿਰੰਜਨ ਰਾਮੁ ਹੈ ॥",
          "roman": "santah tahā nirañjan Rām hē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, в таком состоянии в уме человека обитает свободный от майи Рам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41635,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਗਮਿ ਚੀਨੈ ਬਿਰਲਾ ਕੋਇ ॥",
          "roman": "gur gam chīnē birlā kōi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек, придя к Гуру и встав под его защиту, распознаёт это состояние и устанавливает с ним связь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41636,
          "is_rahao": true,
          "gurmukhi": "ਤਹਾਂ ਨਿਰੰਜਨੁ ਰਮਈਆ ਹੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tahāṅ nirañjan Ramaīā hōi rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Там проявляется прекрасный, свободный от майи Рам. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41637,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵ ਸਥਾਨੈ ਕਿਆ ਨੀਸਾਣੀ ॥",
          "roman": "dēv sathānē kiā nīsāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если спросить: каковы признаки того места, где Господь проявился в уме?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41638,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬਾਜੇ ਸਬਦ ਅਨਾਹਦ ਬਾਣੀ ॥",
          "roman": "tah bājē śabad anāhad bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В таком состоянии Слово Сатгуру и бани хвалы Господу рождают в сердце человека внутренний подъём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41639,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਚੰਦੁ ਨ ਸੂਰਜੁ ਪਉਣੁ ਨ ਪਾਣੀ ॥",
          "roman": "tah chand na sūraj pauṇ na pāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для рассеивания внутренней тьмы луна и солнце не так сильны, как этот подъём; и ветер с водой не дают такого покоя, какой он даёт уму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41640,
          "is_rahao": false,
          "gurmukhi": "ਸਾਖੀ ਜਾਗੀ ਗੁਰਮੁਖਿ ਜਾਣੀ ॥੨॥",
          "roman": "sākhī jāgī gurmukh jāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сознание человека пробуждается через наставление Гуру, и через Гуру приходит понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41641,
          "is_rahao": false,
          "gurmukhi": "ਉਪਜੈ ਗਿਆਨੁ ਦੁਰਮਤਿ ਛੀਜੈ ॥",
          "roman": "upjē giān durmat chhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В состоянии соединения с Господом возникает глубокое познание Господа, а дурной разум исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41642,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਰਸਿ ਗਗਨੰਤਰਿ ਭੀਜੈ ॥",
          "roman": "amrit ras gaganantar bhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ум, поднявшийся в высокую духовную высь, пропитывается вкусом амрита Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41643,
          "is_rahao": false,
          "gurmukhi": "ਏਸੁ ਕਲਾ ਜੋ ਜਾਣੈ ਭੇਉ ॥",
          "roman": "ēs kalā jō jāṇē bhēu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто узнаёт тайну этого умения — как достигнуть такого состояния,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41644,
          "is_rahao": false,
          "gurmukhi": "ਭੇਟੈ ਤਾਸੁ ਪਰਮ ਗੁਰਦੇਉ ॥੩॥",
          "roman": "bhēṭē tās param gurdēu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тот встречает Высшего Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41645,
          "is_rahao": false,
          "gurmukhi": "ਦਸਮ ਦੁਆਰਾ ਅਗਮ ਅਪਾਰਾ ਪਰਮ ਪੁਰਖ ਕੀ ਘਾਟੀ ॥",
          "roman": "dasam duārā agam apārā param purakh kī ghāṭī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Десятая дверь, то есть разум в человеческом теле, — место проявления недостижимого, бесконечного, Высшего Пуруша."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41646,
          "is_rahao": false,
          "gurmukhi": "ਊਪਰਿ ਹਾਟੁ ਹਾਟ ਪਰਿ ਆਲਾ ਆਲੇ ਭੀਤਰਿ ਥਾਤੀ ॥੪॥",
          "roman": "ūpar hāṭ hāṭ par ālā ālē bhītar thātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В верхней части тела, словно в лавке головы, есть полка — разум; через эту внутреннюю полку происходит проявление Господнего света."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41647,
          "is_rahao": false,
          "gurmukhi": "ਜਾਗਤੁ ਰਹੈ ਸੁ ਕਬਹੁ ਨ ਸੋਵੈ ॥",
          "roman": "jāgat rahē su kabah na sōvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, в ком проявился Господь, всегда бодрствует и никогда не спит сном майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41648,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਤਿਲੋਕ ਸਮਾਧਿ ਪਲੋਵੈ ॥",
          "roman": "tīn tilōk samādh palōvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он пребывает в такой самадхи, откуда три качества майи и майя трёх миров остаются далеко и не могут воздействовать на него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41649,
          "is_rahao": false,
          "gurmukhi": "ਬੀਜ ਮੰਤ੍ਰੁ ਲੈ ਹਿਰਦੈ ਰਹੈ ॥",
          "roman": "bīj mantar lē hirdē rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он хранит в сердце мантру Имени Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41650,
          "is_rahao": false,
          "gurmukhi": "ਮਨੂਆ ਉਲਟਿ ਸੁੰਨ ਮਹਿ ਗਹੈ ॥੫॥",
          "roman": "manūā ulaṭ sunn meh gahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря этому его ум отворачивается от майи и утверждается в таком состоянии, где не поднимается никакой мысленный импульс."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41651,
          "is_rahao": false,
          "gurmukhi": "ਜਾਗਤੁ ਰਹੈ ਨ ਅਲੀਆ ਭਾਖੈ ॥",
          "roman": "jāgat rahē na alīā bhākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек остаётся пробуждённым и никогда не говорит лжи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41652,
          "is_rahao": false,
          "gurmukhi": "ਪਾਚਉ ਇੰਦ੍ਰੀ ਬਸਿ ਕਰਿ ਰਾਖੈ ॥",
          "roman": "pāchau indrī bas kar rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он держит все пять чувств под своим контролем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41653,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸਾਖੀ ਰਾਖੈ ਚੀਤਿ ॥",
          "roman": "gur kī sākhī rākhē chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он бережно хранит в своём сознании наставление Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41654,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਅਰਪੈ ਕ੍ਰਿਸਨ ਪਰੀਤਿ ॥੬॥",
          "roman": "man tan arpē Krisan parīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Свой ум и своё тело он приносит в жертву любви к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41655,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਪਲਵ ਸਾਖਾ ਬੀਚਾਰੇ ॥",
          "roman": "kar palav sākhā bīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он видит мир как пальцы руки, ветви и листья дерева, то есть как внешнее разрастание от одного корня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41656,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਜਨਮੁ ਨ ਜੂਐ ਹਾਰੇ ॥",
          "roman": "apnā janam na jūai hārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поэтому, не оставляя коренного Господа и не запутываясь в этом разветвлении, он не проигрывает свою жизнь в азартной игре."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41657,
          "is_rahao": false,
          "gurmukhi": "ਅਸੁਰ ਨਦੀ ਕਾ ਬੰਧੈ ਮੂਲੁ ॥",
          "roman": "asur nadī kā bandhē mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он перекрывает сам источник реки пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41658,
          "is_rahao": false,
          "gurmukhi": "ਪਛਿਮ ਫੇਰਿ ਚੜਾਵੈ ਸੂਰੁ ॥",
          "roman": "pachhim phēr chaṛhāvē sūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он отворачивает ум от запада невежества и восходит в нём солнце знания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41659,
          "is_rahao": false,
          "gurmukhi": "ਅਜਰੁ ਜਰੈ ਸੁ ਨਿਝਰੁ ਝਰੈ ॥",
          "roman": "ajar jarē su nijhar jharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри него прорывается источник соединения с Господом, и он наслаждается такой радостью, которая никогда не стареет и не иссякает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41660,
          "is_rahao": false,
          "gurmukhi": "ਜਗੰਨਾਥ ਸਿਉ ਗੋਸਟਿ ਕਰੈ ॥੭॥",
          "roman": "Jagannāth siu gōsaṭ karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он навсегда вступает в соединение с Господом мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41661,
          "is_rahao": false,
          "gurmukhi": "ਚਉਮੁਖ ਦੀਵਾ ਜੋਤਿ ਦੁਆਰ ॥",
          "roman": "chaumukh dīvā jōt duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через свет Господа внутри него, словно четырёхликий светильник, загорается сияние, и повсюду становится светло."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41662,
          "is_rahao": false,
          "gurmukhi": "ਪਲੂ ਅਨਤ ਮੂਲੁ ਬਿਚਕਾਰਿ ॥",
          "roman": "palū anat mūl bichkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В нём словно расцветает цветок: в середине — нектар Господа, а вокруг — бесконечные лепестки Его творения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41663,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਾ ਲੇ ਆਪੇ ਰਹੈ ॥",
          "roman": "sarab kalā lē āpē rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек поселяeт в себе Господа, владеющего всеми силами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41664,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮਾਣਕੁ ਰਤਨਾ ਮਹਿ ਗੁਹੈ ॥੮॥",
          "roman": "man māṇak ratnā meh guhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его ум становится жемчужиной и остаётся соединённым с драгоценностями — качествами Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41665,
          "is_rahao": false,
          "gurmukhi": "ਮਸਤਕਿ ਪਦਮੁ ਦੁਆਲੈ ਮਣੀ ॥",
          "roman": "mastak padam duālē maṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "На его челе словно расцветает лотос, и вокруг этого цветка нанизываются драгоценные камни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41666,
          "is_rahao": false,
          "gurmukhi": "ਮਾਹਿ ਨਿਰੰਜਨੁ ਤ੍ਰਿਭਵਣ ਧਣੀ ॥",
          "roman": "māh nirañjan tribhavaṇ dhaṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В самой глубине такого человека поселяется свободный от майи Господь, Владыка трёх миров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41667,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਸਬਦ ਨਿਰਮਾਇਲ ਬਾਜੇ ॥",
          "roman": "pañch śabad nirmāil bājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри него словно начинают звучать чистые, прекрасные звуки всех пяти видов музыкальных инструментов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41668,
          "is_rahao": false,
          "gurmukhi": "ਢੁਲਕੇ ਚਵਰ ਸੰਖ ਘਨ ਗਾਜੇ ॥",
          "roman": "ḍhulkē chavar saṅkh ghan gājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Над ним словно колышется чаур, громко звучат раковины; его ум становится царём над царями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41669,
          "is_rahao": false,
          "gurmukhi": "ਦਲਿ ਮਲਿ ਦੈਤਹੁ ਗੁਰਮੁਖਿ ਗਿਆਨੁ ॥",
          "roman": "dal mal dētah gurmukh giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это просветление Имени Господа, полученное от Сатгуру, сокрушает и уничтожает демонов — похоть и прочие пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41670,
          "is_rahao": false,
          "gurmukhi": "ਬੇਣੀ ਜਾਚੈ ਤੇਰਾ ਨਾਮੁ ॥੯॥੧॥",
          "roman": "Bēṇī jāchē tērā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, твой слуга Бени просит у твоего Дара только это Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
