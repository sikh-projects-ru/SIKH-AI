{
  "ang": 986,
  "shabads": [
    {
      "shabad_id": 3641,
      "rahao_verse_id": 42019,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42018,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਮਨ ਹਰਿ ਭਜੁ ਸਭ ਕਿਲਬਿਖ ਕਾਟ ॥",
          "roman": "mērē man har bhaj sabh kilbikh kāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Повторяй имя Параматмы; Хар-наам устраняет все грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42019,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਉਰ ਧਾਰਿਓ ਗੁਰਿ ਪੂਰੈ ਮੇਰਾ ਸੀਸੁ ਕੀਜੈ ਗੁਰ ਵਾਟ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har har ur dhāriō gur pūrē, mērā sīs kījē gur vāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но этот Хар-наам всегда вселяет в сердце только совершенный Гуру; пусть моя голова будет принесена на путь такого Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42020,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੇ ਹਰਿ ਪ੍ਰਭ ਕੀ ਮੈ ਬਾਤ ਸੁਨਾਵੈ ਤਿਸੁ ਮਨੁ ਦੇਵਉ ਕਟਿ ਕਾਟ ॥",
          "roman": "mērē har prabh kī mē bāt sunāvē, tis man dēvau kaṭ kāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому, кто расскажет мне о хвале моего любимого Господа-Прабху, я отдам свой ум, разрезав его на кусочки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42021,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਾਜਨੁ ਮੇਲਿਓ ਗੁਰਿ ਪੂਰੈ ਗੁਰ ਬਚਨਿ ਬਿਕਾਨੋ ਹਟਿ ਹਾਟ ॥੧॥",
          "roman": "har sājan mēliō gur pūrē, gur bachan bikānō haṭ hāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру соединил меня с Другом-Прабху; благословением слова Гуру я стал проданным Ему рабом на каждом рынке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42022,
          "is_rahao": false,
          "gurmukhi": "ਮਕਰ ਪ੍ਰਾਗਿ ਦਾਨੁ ਬਹੁ ਕੀਆ ਸਰੀਰੁ ਦੀਓ ਅਧ ਕਾਟਿ ॥",
          "roman": "makar prāg dān bah kīā, sarīr dīō adh kāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Кто-то на Магх-санкранти совершал великие дары в Праяге, а кто-то, отправившись в Каши, позволил рассечь своё тело надвое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42023,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਨਾਮ ਕੋ ਮੁਕਤਿ ਨ ਪਾਵੈ ਬਹੁ ਕੰਚਨੁ ਦੀਜੈ ਕਟਿ ਕਾਟ ॥੨॥",
          "roman": "bin har nām kō mukat na pāvē, bah kanchan dījē kaṭ kāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но без памятования имени Параматмы никто не получает освобождения от пороков, даже если раздаёт много золота, разрезая его на части."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42024,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਿ ਗੁਰਮਤਿ ਜਸੁ ਗਾਇਓ ਮਨਿ ਉਘਰੇ ਕਪਟ ਕਪਾਟ ॥",
          "roman": "har kīrat gurmat jas gāiō, man ughrē kapaṭ kapāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Человек, который, следуя учению Гуру, воспел хвалу Параматмы и прославил Прабху, у того раскрылись двери ума, и в нём возникло понимание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42025,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਕੁਟੀ ਫੋਰਿ ਭਰਮੁ ਭਉ ਭਾਗਾ ਲਜ ਭਾਨੀ ਮਟੁਕੀ ਮਾਟ ॥੩॥",
          "roman": "trikuṭī phōr bharam bhau bhāgā, laj bhānī maṭukī māṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда благодаря хвале была устранена внутренняя раздражённость, изнутри ушли всякое заблуждение и страх, и разбился глиняный кувшин мирского стыда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42026,
          "is_rahao": false,
          "gurmukhi": "ਕਲਜੁਗਿ ਗੁਰੁ ਪੂਰਾ ਤਿਨ ਪਾਇਆ ਜਿਨ ਧੁਰਿ ਮਸਤਕਿ ਲਿਖੇ ਲਿਲਾਟ ॥",
          "roman": "kaljug gur pūrā tin pāiā, jin dhur mastak likhē lilāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! В этом мире совершенного Гуру находят только те существа, на чьём лбу от начала, по воле Прабху, записана такая судьба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42027,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਰਸੁ ਅੰਮ੍ਰਿਤੁ ਪੀਆ ਸਭ ਲਾਥੀ ਭੂਖ ਤਿਖਾਟ ॥੪॥੬॥",
          "roman": "jan Nānak ras amrit pīā, sabh lāthī bhūkh tikhāṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда такие люди по милости Гуру пьют нектарный вкус имени, дающий духовную жизнь, вся их жажда и голод майи исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3642,
      "rahao_verse_id": 42032,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42028,
          "is_rahao": true,
          "gurmukhi": "ਛਕਾ ੧ ॥",
          "roman": "chhakā ik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чхакка первая, то есть собрание из шести шабадов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42029,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫",
          "roman": "mālī gauṛā mahlā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42030,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар, по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42031,
          "is_rahao": true,
          "gurmukhi": "ਰੇ ਮਨ ਟਹਲ ਹਰਿ ਸੁਖ ਸਾਰ ॥",
          "roman": "rē man ṭahal har sukh sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Служение и преданная любовь к Параматме дают истинный, превосходный покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42032,
          "is_rahao": true,
          "gurmukhi": "ਅਵਰ ਟਹਲਾ ਝੂਠੀਆ ਨਿਤ ਕਰੈ ਜਮੁ ਸਿਰਿ ਮਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "avar ṭahlā jhūṭhīā, nit karē jam sir mār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все прочие служения и угождения тщетны; из-за них духовная смерть постоянно нависает над головой человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42033,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਾ ਮਸਤਕਿ ਲੀਖਿਆ ਤੇ ਮਿਲੇ ਸੰਗਾਰ ॥",
          "roman": "jinā mastak līkhiā, tē milē saṅgār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! Те люди, на чьём лбу записана добрая судьба, приходят в сатсанг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42034,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰੁ ਭਉਜਲੁ ਤਾਰਿਆ ਹਰਿ ਸੰਤ ਪੁਰਖ ਅਪਾਰ ॥੧॥",
          "roman": "sansār bhaujal tāriā, har sant purakh apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В сатсанге святые люди бесконечного, всепроникающего Хари переправляют их через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42035,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਚਰਨ ਸੇਵਹੁ ਸਾਧ ਕੇ ਤਜਿ ਲੋਭ ਮੋਹ ਬਿਕਾਰ ॥",
          "roman": "nit charan sēvah sādh kē, taj lōbh mōh bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! Оставив алчность, привязанность и прочие пороки, всегда пребывай у стоп Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42036,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤਜਹੁ ਦੂਜੀ ਆਸੜੀ ਰਖੁ ਆਸ ਇਕ ਨਿਰੰਕਾਰ ॥੨॥",
          "roman": "sabh tajah dūjī āsaṛī, rakh ās ik niraṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! Оставь всякую низкую надежду на кого-либо, кроме Прабху; держи надежду только на единого Нираṅкар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42037,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਭਰਮਿ ਭੂਲੇ ਸਾਕਤਾ ਬਿਨੁ ਗੁਰ ਅੰਧ ਅੰਧਾਰ ॥",
          "roman": "ik bharam bhūlē sākta, bin gur andh andhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! В мире есть многие люди, оторванные от Параматмы; попав в заблуждение майи, они сбиваются с пути, и без Гуру совершенно слепы к духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42038,
          "is_rahao": false,
          "gurmukhi": "ਧੁਰਿ ਹੋਵਨਾ ਸੁ ਹੋਇਆ ਕੋ ਨ ਮੇਟਣਹਾਰ ॥੩॥",
          "roman": "dhur hōvanā su hōiā, kō na mēṭaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но что в их власти? Согласно воле Прабху происходит именно то, чему суждено произойти; ни одно существо не может стереть эту судьбу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42039,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਰੂਪੁ ਗੋਬਿੰਦ ਕਾ ਅਨਿਕ ਨਾਮ ਅਪਾਰ ॥",
          "roman": "agam rūp gōbind kā, anik nām apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум! Сущность Гобинда непостижима; у бесконечного Прабху бесчисленны имена, потому что бесчисленны Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42040,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਧੰਨੁ ਤੇ ਜਨ ਨਾਨਕਾ ਜਿਨ ਹਰਿ ਨਾਮਾ ਉਰਿ ਧਾਰ ॥੪॥੧॥",
          "roman": "dhan dhann tē jan Nānakā, jin har nāmā ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Благословенны те люди, которые поселили имя Параматмы в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3643,
      "rahao_verse_id": 42043,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42041,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
          "roman": "mālī gauṛā mahlā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42042,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਕਉ ਨਮਸਕਾਰ ॥",
          "roman": "rām nām kau namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! С почтением держи в своём сердце имя того Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42043,
          "is_rahao": true,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਹੋਵਤ ਉਧਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jās japat hōvat udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя имя этого Параматмы, человек переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42044,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਮਿਟਹਿ ਧੰਧ ॥",
          "roman": "jā kē simran miṭah dhandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём исчезают мирские хлопоты майи и уже не могут влиять на ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42045,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਛੂਟਹਿ ਬੰਧ ॥",
          "roman": "jā kē simran chhūṭah bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём разрываются петли привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42046,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਮੂਰਖ ਚਤੁਰ ॥",
          "roman": "jā kē simran mūrakh chatur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём даже глупые становятся мудрыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42047,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਕੁਲਹ ਉਧਰ ॥੧॥",
          "roman": "jā kē simran kulah udhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём переправляется вся семья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42048,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਭਉ ਦੁਖ ਹਰੈ ॥",
          "roman": "jā kē simran bhau dukh harē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём человек устраняет всякий страх и все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42049,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਅਪਦਾ ਟਰੈ ॥",
          "roman": "jā kē simran apdā ṭarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём всякая беда отступает от головы человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42050,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਮੁਚਤ ਪਾਪ ॥",
          "roman": "jā kē simran muchat pāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём человек освобождается от всех грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42051,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਨਹੀ ਸੰਤਾਪ ॥੨॥",
          "roman": "jā kē simran nahī santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём никакие страдания и мучения не могут коснуться человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42052,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਰਿਦ ਬਿਗਾਸ ॥",
          "roman": "jā kē simran rid bigās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём сердце остаётся раскрытым и радостным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42053,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਕਵਲਾ ਦਾਸਿ ॥",
          "roman": "jā kē simran kavlā dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём майя становится служанкой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42054,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਨਿਧਿ ਨਿਧਾਨ ॥",
          "roman": "jā kē simran nidh nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём в этом мире словно обретаются все сокровища и все клады."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42055,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਤਰੇ ਨਿਦਾਨ ॥੩॥",
          "roman": "jā kē simran tarē nidān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Нём в конце человек переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42056,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨੁ ਨਾਮੁ ਹਰੀ ॥",
          "roman": "patit pāvan nām harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Хари очищает тех, кто пал в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42057,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਭਗਤ ਉਧਾਰੁ ਕਰੀ ॥",
          "roman": "kōṭ bhagat udhār karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хар-наам освобождает кроры преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42058,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਾਸ ਦਾਸਾ ਦੀਨੁ ਸਰਨ ॥",
          "roman": "har dās dāsā dīn saran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот смиренный пришёл в прибежище слуг слуг Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42059,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਾਥਾ ਸੰਤ ਚਰਨ ॥੪॥੨॥",
          "roman": "Nānak māthā sant charan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лоб Нанака лежит у стоп святых, чтобы и ему обрести имя Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3644,
      "rahao_verse_id": 42062,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42060,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
          "roman": "mālī gauṛā mahlā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42061,
          "is_rahao": true,
          "gurmukhi": "ਐਸੋ ਸਹਾਈ ਹਰਿ ਕੋ ਨਾਮ ॥",
          "roman": "aisō sahāī har kō nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Хари является таким помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42062,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਭਜੁ ਪੂਰਨ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhasaṅgat bhaj pūran kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая в садх-сангате, повторяй имя Параматмы; все твои намерения будут исполняться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42063,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਕਉ ਜੈਸੇ ਬੇੜੀ ਮਿਲਤ ॥",
          "roman": "būḍat kau jēsē bēṛī milat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Прабху помогает так, как тонущему помогает найденная лодка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
