{
  "ang": 1101,
  "shabads": [
    {
      "shabad_id": 3940,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47093,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47094,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਸਮੂਹਾ ਭੋਗ ਭੂਮਿ ਸਬਾਈ ਕੋ ਧਣੀ ॥",
          "roman": "Sukh samūhā bhog bhūm sabāī ko dhaṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть человеку достались все наслаждения и все счастья, пусть он стал владыкой всей земли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47095,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਭੋ ਰੋਗੁ ਮਿਰਤਕ ਨਾਮ ਵਿਹੂਣਿਆ ॥੨॥",
          "roman": "Nānak habho rog mirtak nām vihūṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если он лишён Имени Господа, его душа мертва; все эти счастья для него подобны болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3941,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47096,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47097,
          "is_rahao": false,
          "gurmukhi": "ਹਿਕਸ ਕੂੰ ਤੂ ਆਹਿ ਪਛਾਣੂ ਭੀ ਹਿਕੁ ਕਰਿ ॥",
          "roman": "Hikas kūṅ tū āh pachhāṇū bhī hik kar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Стремись только к одному Господу; только Его сделай своим другом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47098,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਸੜੀ ਨਿਬਾਹਿ ਮਾਨੁਖ ਪਰਥਾਈ ਲਜੀਵਦੋ ॥੩॥",
          "roman": "Nānak āsṛī nibāh mānukh parthāī lajīvdō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Он один исполняет твою надежду; искать опору у человека становится причиной стыда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3942,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47099,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47100,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਏਕੁ ਨਰਾਇਣੋ ਹਰਿ ਅਗਮ ਅਗਾਧਾ ॥",
          "roman": "Nihchal ek narāiṇō har agam agādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только один недоступный и бездонный Хари-Нараян пребывает вечно и неизменно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47101,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਨਾਮੁ ਨਿਧਾਨੁ ਹੈ ਜਿਸੁ ਸਿਮਰਤ ਹਰਿ ਲਾਧਾ ॥",
          "roman": "Nihchal nām nidhān hē jis simrat har lādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сокровищница Имени Хари тоже неиссякаема; вспоминая это Имя, человек обретает Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47102,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਕੀਰਤਨੁ ਗੁਣ ਗੋਬਿੰਦ ਗੁਰਮੁਖਿ ਗਾਵਾਧਾ ॥",
          "roman": "Nihchal kīrtan guṇ gobind gurmukh gāvādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Киртан качеств Гобинда, воспеваемый через Гуру, тоже остаётся вечным сокровищем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47103,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਧਰਮੁ ਤਪੁ ਨਿਹਚਲੋ ਦਿਨੁ ਰੈਨਿ ਅਰਾਧਾ ॥",
          "roman": "Sach dharam tap nihchalo din rēn arādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Днём и ночью следует созерцать Господа; это и есть истинная вечная дхарма и незыблемый тап."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47104,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਧਰਮੁ ਤਪੁ ਨਿਹਚਲੋ ਜਿਸੁ ਕਰਮਿ ਲਿਖਾਧਾ ॥",
          "roman": "Daiā dharam tap nihchalo jis karam likhādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но эта незыблемая милость, дхарма и тап достаются тому, в чьей судьбе это записано по благодати Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47105,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਮਸਤਕਿ ਲੇਖੁ ਲਿਖਿਆ ਸੋ ਟਲੈ ਨ ਟਲਾਧਾ ॥",
          "roman": "Nihchal mastak lekh likhiā so ṭalē na ṭalādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот незыблемый знак, записанный на челе, не может быть устранён ничьими усилиями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47106,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲ ਸੰਗਤਿ ਸਾਧ ਜਨ ਬਚਨ ਨਿਹਚਲੁ ਗੁਰ ਸਾਧਾ ॥",
          "roman": "Nihchal sangat sādh jan bachan nihchal gur sādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сангат святых людей является незыблемым путём для человеческой жизни; слова Гуру-садху тоже являются незыблемым наставлением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47107,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕਉ ਪੂਰਬਿ ਲਿਖਿਆ ਤਿਨ ਸਦਾ ਸਦਾ ਆਰਾਧਾ ॥੧੯॥",
          "roman": "Jin kau pūrab likhiā tin sadā sadā arādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, на чьём челе проявилась запись прежних добрых дел, всегда и снова созерцают Господа в прибежище Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3943,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47108,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "Salok ḍakhaṇē Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалоки дакхане, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47109,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਡੁਬੰਦੋ ਆਪਿ ਸੋ ਤਰਾਏ ਕਿਨੑ ਖੇ ॥",
          "roman": "Jo ḍubandō āp so tarāē kin khe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто сам тонет в волнах пороков мира-океана, кого ещё может переправить?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47110,
          "is_rahao": false,
          "gurmukhi": "ਤਾਰੇਦੜੋ ਭੀ ਤਾਰਿ ਨਾਨਕ ਪਿਰ ਸਿਉ ਰਤਿਆ ॥੧॥",
          "roman": "Tāredṛo bhī tār Nānak pir siu ratiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто окрашен любовью к Господу-Супругу, сами переправляются и других тоже переправляют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3944,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47111,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47112,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਕੋਇ ਕਥੰਨਿ ਨਾਉ ਸੁਣੰਦੋ ਮਾ ਪਿਰੀ ॥",
          "roman": "Jithē koī kathann nāu suṇandō mā pirī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Туда, где гурмукхи слушают и произносят Имя моего Господа-Супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47113,
          "is_rahao": false,
          "gurmukhi": "ਮੂੰ ਜੁਲਾਊਂ ਤਥਿ ਨਾਨਕ ਪਿਰੀ ਪਸੰਦੋ ਹਰਿਓ ਥੀਓਸਿ ॥੨॥",
          "roman": "Mūṅ julāūṅ tath Nānak pirī pasandō hariō thīos",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я тоже пойду туда; ведь, увидев Супруга в садх-сангате, душа зеленеет и получает духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3945,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47114,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47115,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੀ ਮੇਰੀ ਕਿਆ ਕਰਹਿ ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਸਨੇਹ ॥",
          "roman": "Merī merī kiā kareh putr kalatr saneh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Зачем, попав в привязанность, ты всё говоришь: это моя жена, это мой сын?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47116,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮ ਵਿਹੂਣੀਆ ਨਿਮੁਣੀਆਦੀ ਦੇਹ ॥੩॥",
          "roman": "Nānak nām vihūṇīā nimuṇīādī deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если, погрязнув в привязанности, тело остаётся лишённым Имени Господа, оно не имеет основания и уйдёт впустую."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3946,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47117,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47118,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨੀ ਦੇਖਉ ਗੁਰ ਦਰਸਨੋ ਗੁਰ ਚਰਣੀ ਮਥਾ ॥",
          "roman": "Nēnī dekhau gur darsanō gur charṇī mathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Своими глазами я созерцаю даршан Гуру и кладу свой лоб к стопам Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47119,
          "is_rahao": false,
          "gurmukhi": "ਪੈਰੀ ਮਾਰਗਿ ਗੁਰ ਚਲਦਾ ਪਖਾ ਫੇਰੀ ਹਥਾ ॥",
          "roman": "Pērī mārag gur chaldā pakhā pherī hathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Своими ногами я иду по пути, указанному Гуру; своими руками я обмахиваю Гуру и сангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47120,
          "is_rahao": false,
          "gurmukhi": "ਅਕਾਲ ਮੂਰਤਿ ਰਿਦੈ ਧਿਆਇਦਾ ਦਿਨੁ ਰੈਨਿ ਜਪੰਥਾ ॥",
          "roman": "Akāl mūrat ridē dhiāidā din rēn japanthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я утверждаю образ Вневременного в своём сердце и днём и ночью повторяю Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47121,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਛਡਿਆ ਸਗਲ ਅਪਾਇਣੋ ਭਰਵਾਸੈ ਗੁਰ ਸਮਰਥਾ ॥",
          "roman": "Mē chhaḍiā sagal apāiṇō bharvāsē gur samrathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Положившись на всесильного Гуру, я оставил всю мирскую присвоенность и чувство своего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47122,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਬਖਸਿਆ ਨਾਮੁ ਨਿਧਾਨੁ ਸਭੋ ਦੁਖੁ ਲਥਾ ॥",
          "roman": "Gur bakhsiā nām nidhān sabho dukh lathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру даровал мне сокровищницу Имени Господа, и все мои страдания и скорби отпали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47123,
          "is_rahao": false,
          "gurmukhi": "ਭੋਗਹੁ ਭੁੰਚਹੁ ਭਾਈਹੋ ਪਲੈ ਨਾਮੁ ਅਗਥਾ ॥",
          "roman": "Bhogah bhuñchah bhāīho palē nām agathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О братья, пользуйтесь сокровищем Имени невыразимого Господа и собирайте его в свой подол."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47124,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਦਾਨੁ ਇਸਨਾਨੁ ਦਿੜੁ ਸਦਾ ਕਰਹੁ ਗੁਰ ਕਥਾ ॥",
          "roman": "Nām dān isnān diṛh sadā karah gur kathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда ведите рассказы Гуру, повторяйте Имя, служите и очищайте своё поведение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47125,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੁ ਭਇਆ ਪ੍ਰਭੁ ਪਾਇਆ ਜਮ ਕਾ ਭਉ ਲਥਾ ॥੨੦॥",
          "roman": "Sahaj bhaiā prabh pāiā jam kā bhau lathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда возникает внутренняя устойчивость, Господь обретается, и страх смерти исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3947,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47126,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "Salok ḍakhaṇē Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалоки дакхане, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47127,
          "is_rahao": false,
          "gurmukhi": "ਲਗੜੀਆ ਪਿਰੀਅੰਨਿ ਪੇਖੰਦੀਆ ਨਾ ਤਿਪੀਆ ॥",
          "roman": "Lagṛīā pirīann pekhandīā nā tipiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мои глаза соединились с Господом-Супругом; созерцая Его снова и снова, они не насыщаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47128,
          "is_rahao": false,
          "gurmukhi": "ਹਭ ਮਝਾਹੂ ਸੋ ਧਣੀ ਬਿਆ ਨ ਡਿਠੋ ਕੋਇ ॥੧॥",
          "roman": "Habh majhāhū so dhaṇī biā na ḍiṭhō koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот Владыка-Господь видится мне во всех; кроме Него и равного Ему я нигде не увидел никого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3948,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47129,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47130,
          "is_rahao": false,
          "gurmukhi": "ਕਥੜੀਆ ਸੰਤਾਹ ਤੇ ਸੁਖਾਊ ਪੰਧੀਆ ॥",
          "roman": "Kathṛīā santāh te sukhāū pandhīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наставительные слова святых людей являются путём, показывающим счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47131,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਲਧੜੀਆ ਤਿੰਨਾਹ ਜਿਨਾ ਭਾਗੁ ਮਥਾਹੜੈ ॥੨॥",
          "roman": "Nānak ladhṛīā tinnāh jinā bhāg mathāhaṛē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, эти слова получают только те, на чьём челе проявляется доля прежних добрых дел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3949,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47132,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47133,
          "is_rahao": false,
          "gurmukhi": "ਡੂੰਗਰਿ ਜਲਾ ਥਲਾ ਭੂਮਿ ਬਨਾ ਫਲ ਕੰਦਰਾ ॥",
          "roman": "Ḍūṅgar jalā thalā bhūm banā phal kandarā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В горах, водах, пустынных местах, на земле, в лесах, плодах и пещерах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47134,
          "is_rahao": false,
          "gurmukhi": "ਪਾਤਾਲਾ ਆਕਾਸ ਪੂਰਨੁ ਹਭ ਘਟਾ ॥",
          "roman": "Pātālā ākās pūran habh ghaṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В подземных мирах, в небесах и во всех телах везде пребывает Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47135,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪੇਖਿ ਜੀਓ ਇਕਤੁ ਸੂਤਿ ਪਰੋਤੀਆ ॥੩॥",
          "roman": "Nānak pekh jīō ikat sūt parotīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, созерцая Господа, который нанизал всё творение на одну нить, я получаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3950,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47136,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47137,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀ ਮਾਤਾ ਹਰਿ ਜੀ ਪਿਤਾ ਹਰਿ ਜੀਉ ਪ੍ਰਤਿਪਾਲਕ ॥",
          "roman": "Har jī mātā Har jī pitā Har jīo pratipālak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь — моя мать, Господь — мой отец, Господь — мой кормилец и хранитель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47138,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀ ਮੇਰੀ ਸਾਰ ਕਰੇ ਹਮ ਹਰਿ ਕੇ ਬਾਲਕ ॥",
          "roman": "Har jī merī sār kare ham Har ke bālak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь заботится обо мне; мы — дети Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47139,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਸਹਜਿ ਖਿਲਾਇਦਾ ਨਹੀ ਕਰਦਾ ਆਲਕ ॥",
          "roman": "Sahjē sahaj khilāidā nahī kardā ālak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой Хари утверждает меня в духовной устойчивости и даёт мне играть игру жизни; в этом Он не проявляет ни малейшей лености."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47140,
          "is_rahao": false,
          "gurmukhi": "ਅਉਗਣੁ ਕੋ ਨ ਚਿਤਾਰਦਾ ਗਲ ਸੇਤੀ ਲਾਇਕ ॥",
          "roman": "Augaṇ ko na chitārdā gal setī lāik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не вспоминает ни одного моего недостатка и всегда прижимает меня к Своей груди."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47141,
          "is_rahao": false,
          "gurmukhi": "ਮੁਹਿ ਮੰਗਾਂ ਸੋਈ ਦੇਵਦਾ ਹਰਿ ਪਿਤਾ ਸੁਖਦਾਇਕ ॥",
          "roman": "Muh maṅgāṅ soī devdā Har pitā sukh-dāik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что бы я ни попросил устами, мой дарующий счастье Отец-Господь даёт мне именно это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
