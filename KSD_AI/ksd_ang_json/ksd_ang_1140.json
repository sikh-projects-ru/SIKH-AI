{
  "ang": 1140,
  "shabads": [
    {
      "shabad_id": 4079,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48563,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਕੇ ਸਭਿ ਕਾਜ ਸਵਾਰਿ ॥",
          "roman": "Tis jan ke sabh kāj savār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸੇਵਕ ਦੇ ਉਹ ਸਾਰੇ ਕੰਮ ਸਵਾਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у того слуги Он устраивает все дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48564,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਰਾਖਾ ਏਕੋ ਸੋਇ ॥",
          "roman": "Tis kā rākhā eko soi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਰਾਖਾ ਉਹ ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Защитником такого человека остаётся Сам этот единый Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48565,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਅਪੜਿ ਨ ਸਾਕੈ ਕੋਇ ॥੪॥੪॥੧੭॥",
          "roman": "Jan Nānak apaṛ na sākē koi. 4. 4. 17.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਜਗਤ ਦਾ ਕੋਈ ਜੀਵ) ਉਸ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੪॥੪॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! Ни одно существо в мире не может сравниться с Ним. 4. 4. 17."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4080,
      "rahao_verse_id": 48572,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48566,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48567,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਹੋਵੈ ਬਾਹਰਿ ॥",
          "roman": "Tau kaṛīē je hovē bāhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਜੀਵ ਨੂੰ ਇਹ ਖ਼ਿਆਲ ਬਣਿਆ ਰਹੇ ਕਿ ਪਰਮਾਤਮਾ ਮੈਥੋਂ ਵੱਖਰਾ) ਕਿਤੇ ਦੂਰ ਹੈ, ਤਦੋਂ (ਹਰ ਗੱਲੇ) ਚਿੰਤਾ ਕਰੀਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если у живого существа сохраняется мысль, что Бог где-то далеко и отделён от него, тогда оно предаётся тревоге по всякому поводу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48568,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਵਿਸਰੈ ਨਰਹਰਿ ॥",
          "roman": "Tau kaṛīē je visrē narhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਭੀ ਝੁਰਦੇ ਰਹੀਦਾ ਹੈ ਜੇ ਪਰਮਾਤਮਾ (ਸਾਡੇ ਮਨੋਂ) ਭੁੱਲ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "И тогда тоже человек томится, если Бог забывается в его уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48569,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਦੂਜਾ ਭਾਏ ॥",
          "roman": "Tau kaṛīai je dūjā bhāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ) ਕੋਈ ਹੋਰ ਪਦਾਰਥ (ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਵਧੀਕ) ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ, ਤਦੋਂ (ਭੀ) ਝੁਰਦੇ ਰਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда какой-то иной предмет, кроме Бога, начинает казаться более дорогим, тогда человек тоже томится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48570,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਕੜੀਐ ਜਾਂ ਰਹਿਆ ਸਮਾਏ ॥੧॥",
          "roman": "Kiā kaṛīai jāṅ rahiā samāē.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ (ਇਹ ਯਕੀਨ ਬਣਿਆ ਰਹੇ ਕਿ ਪਰਮਾਤਮਾ) ਹਰੇਕ ਥਾਂ ਵਿਆਪਕ ਹੈ, ਤਦੋਂ ਚਿੰਤਾ-ਝੋਰਾ ਮਿਟ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но когда сохраняется уверенность, что Бог пронизывает всякое место, тогда тревога и мучение исчезают. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48571,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿ ਕੜੇ ਕੜਿ ਪਚਿਆ ॥",
          "roman": "Māiā moh kaṛe kaṛ pachhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਹੋਇਆ ਮਨੁੱਖ ਖਿੱਝ ਖਿੱਝ ਕੇ ਆਤਮਕ ਮੌਤ ਮਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, запутавшийся в привязанности к майе, изводится и изводится, умирая духовной смертью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48572,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਖਪਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Bin nāvē bhram bhram bhram khapiā.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਭਟਕ ਕੇ ਭਟਕ ਕੇ ਭਟਕ ਕੇ ਖ਼ੁਆਰ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога он, блуждая, блуждая, блуждая ради майи, всё больше истощается и гибнет. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48573,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਦੂਜਾ ਕਰਤਾ ॥",
          "roman": "Tau kaṛīai je dūjā kartā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਇਹ ਖ਼ਿਆਲ ਟਿਕਿਆ ਰਹੇ ਕਿ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ) ਕੋਈ ਹੋਰ ਕੁਝ ਕਰ ਸਕਣ ਵਾਲਾ ਹੈ, ਤਦੋਂ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਵਿਚ ਫਸੇ ਰਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если держится мысль, что кроме Бога есть кто-то ещё, способный что-то делать, тогда человек остаётся в плену тревоги и беспокойства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48574,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਅਨਿਆਇ ਕੋ ਮਰਤਾ ॥",
          "roman": "Tau kaṛīai je aniāi ko martā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਭੀ ਝੂਰੀਦਾ ਹੈ ਜੇ ਇਹ ਖ਼ਿਆਲ ਬਣੇ ਕਿ ਕੋਈ ਪ੍ਰਾਣੀ ਪਰਮਾਤਮਾ ਦੇ ਹੁਕਮ ਤੋਂ ਬਾਹਰਾ ਮਰ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И тогда тоже он изнывает, если думает, будто какое-либо существо может умереть вне воли Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48575,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਕਿਛੁ ਜਾਣੈ ਨਾਹੀ ॥",
          "roman": "Tau kaṛīē je kichh jāṇē nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਇਹ ਯਕੀਨ ਟਿਕ ਜਾਏ ਕਿ ਪਰਮਾਤਮਾ ਸਾਡੀਆਂ ਲੋੜਾਂ ਜਾਣਦਾ ਨਹੀਂ ਹੈ, ਤਾਂ ਭੀ ਝੁਰਦੇ ਰਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если закрепляется уверенность, что Бог не знает наших нужд, тогда человек тоже томится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48576,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਕੜੀਐ ਜਾਂ ਭਰਪੂਰਿ ਸਮਾਹੀ ॥੨॥",
          "roman": "Kiā kaṛīai jāṅ bharpūr samāhī.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਤਾਂ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈਂ, ਫਿਰ ਅਸੀਂ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਕਿਉਂ ਕਰੀਏ? ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь, Ты присутствуешь повсюду, так зачем же нам предаваться тревоге и беспокойству? ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48577,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਕਿਛੁ ਹੋਇ ਧਿਙਾਣੈ ॥",
          "roman": "Tau kaṛīē je kichh hoi dhiṅāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਕਿਉਂ ਕੀਤਾ ਜਾਏ? ਕੁਝ ਭੀ ਪਰਮਾਤਮਾ ਦੇ ਹੁਕਮ ਤੋਂ ਬਾਹਰਾ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Так зачем же тревожиться? Ничто не происходит вне повеления Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48578,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੜੀਐ ਜੇ ਭੂਲਿ ਰੰਞਾਣੈ ॥",
          "roman": "Tau kaṛīē je bhūl rañjāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਨੂੰ ਭੀ ਉਹ ਭੁਲੇਖੇ ਨਾਲ ਦੁਖੀ ਨਹੀਂ ਕਰਦਾ, ਫਿਰ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਕਿਉਂ ਕੀਤਾ ਜਾਏ?"
            },
            "sahib_singh_ru": {
              "main": "и никого Он не мучит по ошибке, так зачем же тревожиться?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48579,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਕਹਿਆ ਜੋ ਹੋਇ ਸਭੁ ਪ੍ਰਭ ਤੇ ॥",
          "roman": "Gur kahiā jo hoi sabh prabh te",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਇਹ ਦੱਸਿਆ ਹੈ ਕਿ ਜੋ ਕੁਝ ਹੁੰਦਾ ਹੈ ਸਭ ਪ੍ਰਭੂ ਦੇ ਹੁਕਮ ਨਾਲ ਹੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру объяснил: всё, что происходит, происходит только по повелению Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48580,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਕਾੜਾ ਛੋਡਿ ਅਚਿੰਤ ਹਮ ਸੋਤੇ ॥੩॥",
          "roman": "Tab kāṛā chhoḍ achint ham sote.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਵਾਸਤੇ ਅਸੀਂ ਤਾਂ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਛੱਡ ਕੇ (ਉਸ ਦੀ ਰਜ਼ਾ ਵਿਚ) ਬੇ-ਫ਼ਿਕਰ ਟਿਕੇ ਹੋਏ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Потому мы, оставив тревогу и беспокойство, пребываем беззаботно в Его воле. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48581,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਤੂਹੈ ਠਾਕੁਰੁ ਸਭੁ ਕੋ ਤੇਰਾ ॥",
          "roman": "Prabh tūhē ṭhākur sabh ko terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਭ ਜੀਵਾਂ ਦਾ ਮਾਲਕ ਹੈਂ, ਹਰੇਕ ਜੀਵ ਤੇਰਾ (ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты Владыка всех существ, каждое существо принадлежит Тебе и создано Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48582,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਕਰਹਿ ਨਿਬੇਰਾ ॥",
          "roman": "Jiu bhāvē tiu karah nibērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਤੇਰੀ ਰਜ਼ਾ ਹੁੰਦੀ ਹੈ, ਤੂੰ (ਜੀਵਾਂ ਦੀ ਕਿਸਮਤ ਦਾ) ਫ਼ੈਸਲਾ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Какова Твоя воля, так Ты и решаешь судьбу живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48583,
          "is_rahao": false,
          "gurmukhi": "ਦੁਤੀਆ ਨਾਸਤਿ ਇਕੁ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "Dutīā nāsat ik rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਬਿਨਾ (ਤੇਰੇ ਬਰਾਬਰ ਦਾ) ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ, ਤੂੰ ਹੀ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, кроме Тебя нет никого равного Тебе, только Ты один пронизываешь всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48584,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਹੁ ਪੈਜ ਨਾਨਕ ਸਰਣਾਇ ॥੪॥੫॥੧੮॥",
          "roman": "Rākhah pēj Nānak saraṇāi.4.5.18.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਹੀ ਅਰਦਾਸ ਕਰਿਆ ਕਰ ਕਿ, ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ, ਮੇਰੀ ਲਾਜ ਰੱਖ ॥੪॥੫॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись у дверей Господа так: О Господь, я пришёл в Твоё прибежище, сохрани мою честь. ॥4॥5॥18॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4081,
      "rahao_verse_id": 48591,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48585,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48586,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬਾਜੇ ਕੈਸੋ ਨਿਰਤਿਕਾਰੀ ॥",
          "roman": "Bin bāje kēso niratkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਚ ਦੇ ਨਾਲ) ਸਾਜ਼ਾਂ ਤੋਂ ਬਿਨਾ ਨਾਚ ਫਬਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Танец без музыкальных инструментов не бывает хорош."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48587,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਕੰਠੈ ਕੈਸੇ ਗਾਵਨਹਾਰੀ ॥",
          "roman": "Bin kaṇṭhē kēse gāvanhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਲੇ ਤੋਂ ਬਿਨਾ ਕੋਈ ਗਵਈਆ ਗਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без горла певец не может петь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48588,
          "is_rahao": false,
          "gurmukhi": "ਜੀਲ ਬਿਨਾ ਕੈਸੇ ਬਜੈ ਰਬਾਬ ॥",
          "roman": "Jīl binā kēse bajē rabāb",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੰਦੀ ਤੋਂ ਬਿਨਾ ਰਬਾਬ ਨਹੀਂ ਵੱਜ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Без струн рабаб не может звучать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48589,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਬਿਰਥੇ ਸਭਿ ਕਾਜ ॥੧॥",
          "roman": "Nām binā birthe sabh kāj.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸੇ ਤਰ੍ਹਾਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ (ਦੁਨੀਆ ਵਾਲੇ ਹੋਰ) ਸਾਰੇ ਕੰਮ ਵਿਅਰਥ ਚਲੇ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Точно так же без памятования Имени Бога все прочие мирские дела уходят впустую. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48590,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕਹਹੁ ਕੋ ਤਰਿਆ ॥",
          "roman": "Nām binā kahah ko tariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸ, ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਕੌਣ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Скажи, кто может переправиться через океан мира без памятования Имени Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48591,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਸਤਿਗੁਰ ਕੈਸੇ ਪਾਰਿ ਪਰਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Bin satgur kēse pār pariā.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਤੋਂ ਬਿਨਾ ਕਿਵੇਂ ਕੋਈ ਪਾਰ ਲੰਘ ਸਕਦਾ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Как может кто-либо переправиться без того, чтобы прийти в прибежище Гуру? ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48592,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਜਿਹਵਾ ਕਹਾ ਕੋ ਬਕਤਾ ॥",
          "roman": "Bin jihvā kahā ko baktā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਤੋਂ ਬਿਨਾ ਕੋਈ ਬੋਲਣ-ਜੋਗਾ ਨਹੀਂ ਹੋ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Без языка никто не может быть говорящим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48593,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸ੍ਰਵਨਾ ਕਹਾ ਕੋ ਸੁਨਤਾ ॥",
          "roman": "Bin sravnā kahā ko suntā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੰਨਾਂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਸੁਣ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "без ушей никто не может слышать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48594,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨੇਤ੍ਰਾ ਕਹਾ ਕੋ ਪੇਖੈ ॥",
          "roman": "Bin netrā kahā ko pekhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖਾਂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਵੇਖ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без глаз никто не может видеть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48595,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਨਰੁ ਕਹੀ ਨ ਲੇਖੈ ॥੨॥",
          "roman": "Nām binā nar kahī na lekhē.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸੇ ਤਰ੍ਹਾਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਕਿਸੇ ਪੁੱਛ-ਗਿਛ ਵਿਚ ਨਹੀਂ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Точно так же без памятования Имени Бога человек ни во что не ставится. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48596,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬਿਦਿਆ ਕਹਾ ਕੋਈ ਪੰਡਿਤ ॥",
          "roman": "Bin bidiā kahā koī paṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿੱਦਿਆ ਪ੍ਰਾਪਤ ਕਰਨ ਤੋਂ ਬਿਨਾ ਕੋਈ ਪੰਡਿਤ ਨਹੀਂ ਬਣ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Без обретения знания никто не может стать пандитом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48597,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਅਮਰੈ ਕੈਸੇ ਰਾਜ ਮੰਡਿਤ ॥",
          "roman": "Bin amrē kēse rāj maṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰਾਜਿਆਂ ਦੇ) ਹੁਕਮ ਤੋਂ ਬਿਨਾ ਰਾਜ ਦੀਆਂ ਸਜਾਵਟਾਂ ਕਿਸੇ ਕੰਮ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Без царского приказа украшения царства ни на что не годны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48598,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਕਹਾ ਮਨੁ ਠਹਰਾਨਾ ॥",
          "roman": "Bin būjhe kahā man ṭhaharānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ ਜੀਵਨ ਦੀ) ਸੂਝ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਦਾ ਮਨ ਕਿਤੇ ਟਿਕ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без понимания духовной жизни ум человека нигде не может утвердиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48599,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਸਭੁ ਜਗੁ ਬਉਰਾਨਾ ॥੩॥",
          "roman": "Nām binā sabh jag baurānā.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਸਾਰਾ ਜਗਤ ਝੱਲਾ ਹੋਇਆ ਫਿਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога весь мир бродит как безумный. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48600,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੈਰਾਗ ਕਹਾ ਬੈਰਾਗੀ ॥",
          "roman": "Bin bērāg kahā bērāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਵੈਰਾਗੀ ਦੇ ਅੰਦਰ ਮਾਇਆ ਵਲੋਂ ਨਿਰਮੋਹਤਾ ਨਹੀਂ, ਤਾਂ ਉਹ ਵੈਰਾਗੀ ਕਾਹਦਾ?"
            },
            "sahib_singh_ru": {
              "main": "Если в сердце отшельника нет непривязанности к майе, то какой же он отшельник?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48601,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਉ ਤਿਆਗਿ ਕਹਾ ਕੋਊ ਤਿਆਗੀ ॥",
          "roman": "Bin hau tiāg kahā koū tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਨੂੰ ਤਿਆਗਣ ਤੋਂ ਬਿਨਾ ਕੋਈ ਤਿਆਗੀ ਨਹੀਂ ਅਖਵਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Не отвергнув Хоумэ, никто не может называться отречённым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48602,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬਸਿ ਪੰਚ ਕਹਾ ਮਨ ਚੂਰੇ ॥",
          "roman": "Bin bas panch kahā man chūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਨੂੰ ਵੱਸ ਕਰਨ ਤੋਂ ਬਿਨਾ ਮਨ ਮਾਰਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Не подчинив себе пять страстей, нельзя сокрушить ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48603,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਸਦ ਸਦ ਹੀ ਝੂਰੇ ॥੪॥",
          "roman": "Nām binā sad sad hī jhūre.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਸਦਾ ਹੀ ਸਦਾ ਹੀ ਚਿੰਤਾ-ਫ਼ਿਕਰਾਂ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Бога человек всегда и всегда остаётся в тревогах и беспокойствах. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48604,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਦੀਖਿਆ ਕੈਸੇ ਗਿਆਨੁ ॥",
          "roman": "Bin gur dīkhiyā kēse giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਤੋਂ ਬਿਨਾ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਨਹੀਂ ਪੈ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Без наставления Гуру невозможно обрести понимание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48605,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਪੇਖੇ ਕਹੁ ਕੈਸੋ ਧਿਆਨੁ ॥",
          "roman": "Bin pekhe kaho kēso dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਮਾਧੀ ਕਾਹਦੀ, ਜੇ ਆਪਣੇ ਇਸ਼ਟ ਦਾ ਦਰਸਨ ਨਹੀਂ ਹੁੰਦਾ?"
            },
            "sahib_singh_ru": {
              "main": "Что это за самадхи, если не происходит созерцания своего Возлюбленного?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48606,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਭੈ ਕਥਨੀ ਸਰਬ ਬਿਕਾਰ ॥",
          "roman": "Bin bhē kathnī sarab bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਡਰ-ਅਦਬ ਹਿਰਦੇ ਵਿਚ ਰੱਖਣ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਦੀ ਸਾਰੀ ਚੁੰਚ-ਗਿਆਨਤਾ ਵਿਕਾਰਾਂ ਦਾ ਮੂਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Без того чтобы хранить в сердце благоговейный страх и почтение к Богу, вся человеческая говорливость и мнимое знание становятся корнем пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48607,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਦਰ ਕਾ ਬੀਚਾਰ ॥੫॥੬॥੧੯॥",
          "roman": "Kah Nānak dar kā bīchār.5.6.19.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਪਹੁੰਚਾਣ ਵਾਲੀ ਇਹ ਵਿਚਾਰ ਹੈ ॥੫॥੬॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: вот размышление, которое приводит к дверям Бога. ॥5॥6॥19॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4082,
      "rahao_verse_id": 48614,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48608,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48609,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਰੋਗੁ ਮਾਨੁਖ ਕਉ ਦੀਨਾ ॥",
          "roman": "Haumē rog mānukh kau dīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਨੇ) ਮਨੁੱਖ ਨੂੰ ਹਉਮੈ ਦਾ ਰੋਗ ਦੇ ਰੱਖਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человеку дан недуг Хоумэ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48610,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਰੋਗਿ ਮੈਗਲੁ ਬਸਿ ਲੀਨਾ ॥",
          "roman": "Kām rog mēgal bas līnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ-ਵਾਸਨਾ ਦੇ ਰੋਗ ਨੇ ਹਾਥੀ ਨੂੰ ਆਪਣੇ ਵੱਸ ਵਿਚ ਕੀਤਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а болезнь похоти подчинила себе слона."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48611,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿਸਟਿ ਰੋਗਿ ਪਚਿ ਮੁਏ ਪਤੰਗਾ ॥",
          "roman": "Drisaṭ rog pach mue pataṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੀਵੇ ਦੀ ਲਾਟ ਨੂੰ) ਵੇਖਣ ਦੇ ਰੋਗ ਦੇ ਕਾਰਨ ਪਤੰਗੇ (ਦੀਵੇ ਦੀ ਲਾਟ ਉਤੇ) ਸੜ ਮਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Из-за болезни зрения мотыльки сгорают и погибают на пламени лампы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48612,
          "is_rahao": false,
          "gurmukhi": "ਨਾਦ ਰੋਗਿ ਖਪਿ ਗਏ ਕੁਰੰਗਾ ॥੧॥",
          "roman": "Nād rog khap gae kuraṅgā.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਘੰਡੇ ਹੇੜੇ ਦੀ) ਆਵਾਜ਼ (ਸੁਣਨ) ਦੇ ਰੋਗ ਦੇ ਕਾਰਨ ਹਿਰਨ ਖ਼ੁਆਰ ਹੁੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Из-за болезни слуха, из-за звука манка, олени гибнут и изводятся. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48613,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਜੋ ਦੀਸੈ ਸੋ ਸੋ ਰੋਗੀ ॥",
          "roman": "Jo jo dīsē so so rogī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਜਿਹੜਾ ਜੀਵ (ਜਗਤ ਵਿਚ) ਦਿੱਸ ਰਿਹਾ ਹੈ, ਹਰੇਕ ਕਿਸੇ ਨ ਕਿਸੇ ਰੋਗ ਵਿਚ ਫਸਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто бы ни был виден в мире, каждый поражён каким-нибудь недугом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48614,
          "is_rahao": true,
          "gurmukhi": "ਰੋਗ ਰਹਿਤ ਮੇਰਾ ਸਤਿਗੁਰੁ ਜੋਗੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Rog rahit merā satgur jogī.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ) ਜੋਗੀ ਮੇਰਾ ਸਤਿਗੁਰੂ (ਸਭ) ਰੋਗਾਂ ਤੋਂ ਰਹਿਤ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Мой Сатгуру, истинный йог, свободен от всех недугов. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48615,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹਵਾ ਰੋਗਿ ਮੀਨੁ ਗ੍ਰਸਿਆਨੋ ॥",
          "roman": "Jihvā rog mīn grasiyāno",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਦੇ ਰੋਗ ਦੇ ਕਾਰਨ ਮੱਛੀ ਫੜੀ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за болезни языка рыба попадается на крючок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48616,
          "is_rahao": false,
          "gurmukhi": "ਬਾਸਨ ਰੋਗਿ ਭਵਰੁ ਬਿਨਸਾਨੋ ॥",
          "roman": "Bāsan rog bhavar binsāno",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਗੰਧੀ ਦੇ ਰੋਗ ਦੇ ਕਾਰਨ (ਫੁੱਲ ਦੀ ਸੁਗੰਧੀ ਲੈਣ ਦੇ ਰਸ ਦੇ ਕਾਰਨ) ਭੌਰਾ (ਫੁੱਲ ਵਿਚ ਮੀਟਿਆ ਜਾ ਕੇ) ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "из-за болезни запаха шмель погибает, оказавшись запертым в цветке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48617,
          "is_rahao": false,
          "gurmukhi": "ਹੇਤ ਰੋਗ ਕਾ ਸਗਲ ਸੰਸਾਰਾ ॥",
          "roman": "Het rog kā sagal saṅsārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰਾ ਜਗਤ ਮੋਹ ਦੇ ਰੋਗ ਦਾ ਸ਼ਿਕਾਰ ਹੋਇਆ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Весь мир поражён болезнью привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48618,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਬਿਧਿ ਰੋਗ ਮਹਿ ਬਧੇ ਬਿਕਾਰਾ ॥੨॥",
          "roman": "Tribidh rog mahi badhe bikārā.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤ੍ਰਿਗੁਣੀ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਰੋਗ ਵਿਚ ਬੱਝੇ ਹੋਏ ਜੀਵ ਅਨੇਕਾਂ ਵਿਕਾਰ ਕਰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и существа, связанные болезнью привязанности к тройственной майе, совершают множество пороков. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48619,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੇ ਮਰਤਾ ਰੋਗੇ ਜਨਮੈ ॥",
          "roman": "Roge martā roge janmē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਕਿਸੇ ਨ ਕਿਸੇ ਆਤਮਕ) ਰੋਗ ਵਿਚ (ਫਸਿਆ ਹੋਇਆ) ਹੀ ਮਰ ਜਾਂਦਾ ਹੈ, (ਕਿਸੇ ਨ ਕਿਸੇ ਆਤਮਕ) ਰੋਗ ਵਿਚ (ਗ੍ਰਸਿਆ ਹੋਇਆ) ਹੀ ਜੰਮਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек умирает, будучи захвачен каким-нибудь духовным недугом, и рождается тоже, будучи захвачен каким-нибудь духовным недугом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48620,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੇ ਫਿਰਿ ਫਿਰਿ ਜੋਨੀ ਭਰਮੈ ॥",
          "roman": "Roge phir phir jonī bharmē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਰੋਗ ਦੇ ਕਾਰਨ ਹੀ ਮੁੜ ਮੁੜ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и именно из-за этого недуга снова и снова блуждает по рождениям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
