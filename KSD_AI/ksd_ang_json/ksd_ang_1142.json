{
  "ang": 1142,
  "shabads": [
    {
      "shabad_id": 4085,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48680,
          "is_rahao": false,
          "gurmukhi": "ਹਰਾਮਖੋਰ ਨਿਰਗੁਣ ਕਉ ਤੂਠਾ ॥",
          "roman": "Harāmkhor nirguṇ kau tūṭhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਾਇਆ ਹੱਕ ਖਾਣ ਵਾਲੇ ਗੁਣ-ਹੀਨ ਮਨੁੱਖ ਉੱਤੇ ਭੀ ਜਦੋਂ ਪਰਮਾਤਮਾ ਦਇਆਵਾਨ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Даже к лишённому достоинств человеку, питающемуся чужим правом, когда Параматма становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48681,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਸੀਤਲੁ ਮਨਿ ਅੰਮ੍ਰਿਤੁ ਵੂਠਾ ॥",
          "roman": "Man tan sītal man amrit vūṭhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਉਸ ਦਾ ਤਨ ਸ਼ਾਂਤ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਸ ਦੇ ਮਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "его ум и тело становятся спокойными, а в его уме поселяется нектар Имени, дающий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48682,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਰ ਭਏ ਦਇਆਲਾ ॥",
          "roman": "Pārbrahm gur bhae daiālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਸੇਵਕਾਂ ਉਤੇ ਗੁਰੂ ਪਰਮਾਤਮਾ ਦਇਆਲ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те слуги, к которым Гуру-Парабрахм становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48683,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਦੇਖਿ ਭਏ ਨਿਹਾਲਾ ॥੪॥੧੦॥੨੩॥",
          "roman": "Nānak dās dekh bhae nihālā ॥4॥10॥23॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਦਰਸਨ ਕਰ ਕੇ ਨਿਹਾਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੪॥੧੦॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, узрев Его, становятся блаженными ॥4॥10॥23॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4086,
      "rahao_verse_id": 48690,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48684,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlas 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48685,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਬੇਮੁਹਤਾਜੁ ॥",
          "roman": "satgur merā bemuhtāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰੇ ਗੁਰੂ ਨੂੰ ਕਿਸੇ ਦੀ ਮੁਥਾਜੀ ਨਹੀਂ (ਗੁਰੂ ਦੀ ਕੋਈ ਆਪਣੀ ਜ਼ਾਤੀ ਗ਼ਰਜ਼ ਨਹੀਂ)-"
            },
            "sahib_singh_ru": {
              "main": "Мой Сатгуру ни в ком не нуждается, у Гуру нет никакой личной корысти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48686,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਮੇਰੇ ਸਚਾ ਸਾਜੁ ॥",
          "roman": "satgur mere sachā sāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਇਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਮਰਯਾਦਾ ਹੈ (ਕਿ ਉਹ ਸਦਾ ਬੇ-ਗ਼ਰਜ਼ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Таков вечно пребывающий истинный строй Гуру: он всегда бескорыстен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48687,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਸਭਸ ਕਾ ਦਾਤਾ ॥",
          "roman": "satgur merā sabhas kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਸਭ ਜੀਵਾਂ ਨੂੰ (ਦਾਤਾਂ) ਦੇਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Сатгуру — дающий всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48688,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਪੁਰਖੁ ਬਿਧਾਤਾ ॥੧॥",
          "roman": "satgur merā purakh bidhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਅਤੇ ਸਿਰਜਣਹਾਰ ਅਕਾਲ ਪੁਰਖ ਇੱਕ-ਰੂਪ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру и Творец, Акал Пуракх, едины по своей сути. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48689,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਜੈਸਾ ਨਾਹੀ ਕੋ ਦੇਵ ॥",
          "roman": "gur jēsā nāhī ko dev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਵਰਗਾ ਹੋਰ ਕੋਈ ਦੇਵਤਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нет иного божества, подобного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48690,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਮਸਤਕਿ ਭਾਗੁ ਸੁ ਲਾਗਾ ਸੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jis mastak bhāg su lāgā sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਮਨੁੱਖ) ਦੇ ਮੱਥੇ ਉਤੇ ਚੰਗੀ ਕਿਸਮਤ (ਜਾਗ ਪਏ) ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на челе которого пробудилась добрая судьба, приходит в прибежище Гуру. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48691,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਸਰਬ ਪ੍ਰਤਿਪਾਲੈ ॥",
          "roman": "satgur merā sarab pratipālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰਾ ਗੁਰੂ ਸਭ ਜੀਵਾਂ ਦੀ ਰੱਖਿਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мой дорогой Гуру хранит всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48692,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਮਾਰਿ ਜੀਵਾਲੈ ॥",
          "roman": "satgur merā mār jīvālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਉਸ ਦੇ ਦਰ ਤੇ ਆਉਂਦਾ ਹੈ, ਉਸ ਨੂੰ ਮਾਇਆ ਦੇ ਮੋਹ ਵੱਲੋਂ) ਮਾਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਦੇ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, умертвив в человеке привязанность к майе, дарует ему духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48693,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਮੇਰੇ ਕੀ ਵਡਿਆਈ ॥ ਪ੍ਰਗਟੁ ਭਈ ਹੈ ਸਭਨੀ ਥਾਈ ॥੨॥",
          "roman": "satgur mere kī vaḍiāī, pragaṭ bhaī hē sabhnī thāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਇਹ ਉੱਚੀ ਸੋਭਾ- ਸਭਨੀਂ ਥਾਈਂ ਰੌਸ਼ਨ ਹੋ ਗਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Эта великая слава Гуру стала явной и воссияла повсюду. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48694,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਤਾਣੁ ਨਿਤਾਣੁ ॥",
          "roman": "satgur merā tāṇ nitāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਹੋਰ ਕੋਈ ਭੀ ਆਸਰਾ ਨਹੀਂ (ਜਦੋਂ ਉਹ ਗੁਰੂ ਦੀ ਸਰਨ ਆ ਪੈਂਦਾ ਹੈ) ਗੁਰੂ (ਉਸ ਦਾ) ਆਸਰਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для того человека, у которого нет никакой иной опоры, когда он приходит в прибежище Гуру, Гуру становится опорой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48695,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮੇਰਾ ਘਰਿ ਦੀਬਾਣੁ ॥",
          "roman": "satgur merā ghar dībāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਦੇ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਸਹਾਰਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру даёт ему поддержку в доме его сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48696,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਕੈ ਹਉ ਸਦ ਬਲਿ ਜਾਇਆ ॥",
          "roman": "satgur kē hau sad bal jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਤੋਂ ਸਦਾ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я всегда отдаю себя в жертву тому Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48697,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟੁ ਮਾਰਗੁ ਜਿਨਿ ਕਰਿ ਦਿਖਲਾਇਆ ॥੩॥",
          "roman": "pragaṭ mārag jin kar dikhlāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਨੇ ਆਤਮਕ ਜੀਵਨ ਦਾ) ਸਿੱਧਾ ਰਾਹ ਵਿਖਾਲ ਦਿੱਤਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "который показал прямой путь духовной жизни. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48698,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਗੁਰੁ ਸੇਵਿਆ ਤਿਸੁ ਭਉ ਨ ਬਿਆਪੈ ॥",
          "roman": "jin gur seviā tis bhau na biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਮਨੁੱਖ) ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਲਈ ਹੈ, ਕੋਈ ਡਰ ਉਸ ਉਤੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кто пришёл в прибежище Гуру, никакой страх не может одолеть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48699,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਗੁਰੁ ਸੇਵਿਆ ਤਿਸੁ ਦੁਖੁ ਨ ਸੰਤਾਪੈ ॥",
          "roman": "jin gur seviā tis dukh na santāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਮਨੁੱਖ) ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਲਈ ਹੈ, ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ ਉਸ ਨੂੰ ਸਤਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "того, кто пришёл в прибежище Гуру, не могут мучить никакие страдания и беды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48700,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋਧੇ ਸਿੰਮ੍ਰਿਤਿ ਬੇਦ ॥",
          "roman": "nānak sodhe simmrit bed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਿੰਮ੍ਰਿਤੀਆਂ ਵੇਦ (ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕ) ਖੋਜ ਵੇਖੇ ਹਨ (ਗੁਰੂ ਸਭ ਤੋਂ ਉੱਚਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, были исследованы Смрити и Веды, и другие священные книги: Гуру превыше всего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48701,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਰ ਨਾਹੀ ਭੇਦ ॥੪॥੧੧॥੨੪॥",
          "roman": "pārbrahm gur nāhī bhed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਅਤੇ ਪਰਮਾਤਮਾ ਵਿਚ ਕੋਈ ਭੀ ਫ਼ਰਕ ਨਹੀਂ ਹੈ ॥੪॥੧੧॥੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "между Гуру и Парабрахманом нет никакого различия. ॥4॥11॥24॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4087,
      "rahao_verse_id": 48708,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48702,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlas 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48703,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਮਨੁ ਪਰਗਟੁ ਭਇਆ ॥",
          "roman": "nām lēt man pargaṭ bhēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਮਨੁੱਖ ਦਾ) ਮਨ (ਵਿਕਾਰਾਂ ਦੇ ਹਨੇਰੇ ਵਿਚੋਂ ਨਿਕਲ ਕੇ) ਰੌਸ਼ਨ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда повторяют Имя Бога, ум выходит из тьмы пороков и становится светлым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48704,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਪਾਪੁ ਤਨ ਤੇ ਗਇਆ ॥",
          "roman": "nām lēt pāp tan te gēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਨਾਮ ਸਿਮਰਦਿਆਂ (ਹਰੇਕ ਕਿਸਮ ਦਾ) ਪਾਪ ਸਰੀਰ ਤੋਂ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо при памятовании Имени всякий грех отходит от тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48705,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਸਗਲ ਪੁਰਬਾਇਆ ॥",
          "roman": "nām lēt sagal purbāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਸਿਮਰਦਿਆਂ (ਮਾਨੋ) ਸਾਰੇ ਪੁਰਬ ਮਨਾਏ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Имя, как будто отпразднованы все священные праздники,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48706,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਅਠਸਠਿ ਮਜਨਾਇਆ ॥੧॥",
          "roman": "nām lēt aṭhsaṭh majnāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਦਿਆਂ ਅਠਾਹਠ ਤੀਰਥਾਂ ਦਾ ਇਸ਼ਨਾਨ ਹੋ ਗਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "когда повторяют Имя, это словно омовение во всех шестидесяти восьми тиртхах. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48707,
          "is_rahao": true,
          "gurmukhi": "ਤੀਰਥੁ ਹਮਰਾ ਹਰਿ ਕੋ ਨਾਮੁ ॥",
          "roman": "tīrath hamrā har ko nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਾਡਾ ਤੀਰਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари и есть наша тиртха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48708,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਉਪਦੇਸਿਆ ਤਤੁ ਗਿਆਨੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur updesiā tat giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਸਾਨੂੰ) ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦਾ ਇਹ ਨਿਚੋੜ ਸਮਝਾ ਦਿੱਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру объяснил нам эту суть духовного знания. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48709,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਦੁਖੁ ਦੂਰਿ ਪਰਾਨਾ ॥",
          "roman": "nām lēt dukh dūr parānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਹਰੇਕ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда повторяют Имя Бога, всякое страдание уходит прочь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48710,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਅਤਿ ਮੂੜ ਸੁਗਿਆਨਾ ॥",
          "roman": "nām lēt at mūṛ sugiānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਦਿਆਂ ਵੱਡਾ ਭਾਰਾ ਮੂਰਖ ਭੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੋਹਣੀ ਸੂਝ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "когда повторяют Имя, даже великий глупец становится наделённым прекрасным духовным пониманием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48711,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਪਰਗਟਿ ਉਜੀਆਰਾ ॥",
          "roman": "nām lēt pargaṭ ujīārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਸਿਮਰਦਿਆਂ (ਮਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Имя, в уме возникает свет духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48712,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਛੁਟੇ ਜੰਜਾਰਾ ॥੨॥",
          "roman": "nām lēt chhuṭe janjārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਨਾਮ ਜਪਦਿਆਂ (ਮਨ ਦੀਆਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਸਾਰੀਆਂ) ਫਾਹੀਆਂ ਮੁੱਕ ਜਾਂਦੀਆਂ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ибо при повторении Имени исчезают все путы привязанности к майе. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48713,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਜਮੁ ਨੇੜਿ ਨ ਆਵੈ ॥",
          "roman": "nām lēt jam neṛ na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ ਜਮ (ਮਨੁੱਖ ਦੇ) ਨੇੜੇ ਨਹੀਂ ਆਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Когда повторяют Имя Бога, Яма не приближается к человеку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48714,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਦਰਗਹ ਸੁਖੁ ਪਾਵੈ ॥",
          "roman": "nām lēt dargah sukh pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਟਿਕ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "человек утверждается в присутствии Бога и вкушает духовное блаженство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48715,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਪ੍ਰਭੁ ਕਹੈ ਸਾਬਾਸਿ ॥",
          "roman": "nām lēt prabh kahē sābās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਸਿਮਰਦਿਆਂ ਪਰਮਾਤਮਾ (ਭੀ) ਆਦਰ-ਮਾਣ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "когда помнят Имя, Сам Бог дарует честь и одобрение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48716,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੀ ਸਾਚੀ ਰਾਸਿ ॥੩॥",
          "roman": "nām hamārī sāchī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਅਸਾਂ ਜੀਵਾਂ ਵਾਸਤੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਸਰਮਾਇਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — вот наше вечное, непреходящее богатство. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48717,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਉਪਦੇਸੁ ਕਹਿਓ ਇਹੁ ਸਾਰੁ ॥",
          "roman": "gur updes kahio ih sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਮੈਨੂੰ) ਇਹ ਸਭ ਤੋਂ ਵਧੀਆ ਉਪਦੇਸ਼ ਦੇ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру дал мне это наилучшее наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48718,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਿ ਮਨ ਨਾਮੁ ਅਧਾਰੁ ॥",
          "roman": "har kīrat man nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਹੀ) ਮਨ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что хвала Богу и Его Имя — единственная опора для ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48719,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੇ ਨਾਮ ਪੁਨਹਚਾਰ ॥",
          "roman": "nānak udhre nām punahchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ (ਵਿਕਾਰਾਂ ਦੀਆਂ ਲਹਿਰਾਂ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ ਜਿਹੜੇ ਨਾਮ ਜਪਣ ਦੇ ਪ੍ਰਾਸ਼ਚਿਤ ਕਰਮ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те люди переправляются через волны пороков, которые совершают покаянное делание в повторении Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48720,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰਿ ਕਰਮ ਲੋਕਹ ਪਤੀਆਰ ॥੪॥੧੨॥੨੫॥",
          "roman": "avar karam lokah patīār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੇ (ਪ੍ਰਾਸ਼ਚਿਤ) ਕਰਮ ਲੋਕਾਂ ਦੀ ਤਸੱਲੀ ਕਰਾਣ ਵਾਸਤੇ ਹਨ (ਕਿ ਅਸੀਂ ਧਾਰਮਿਕ ਬਣ ਗਏ ਹਾਂ) ॥੪॥੧੨॥੨੫॥"
            },
            "sahib_singh_ru": {
              "main": "Все прочие покаянные дела совершаются лишь для того, чтобы успокоить людей, будто мы стали религиозными. ॥4॥12॥25॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4088,
      "rahao_verse_id": 48727,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48721,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlas 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48722,
          "is_rahao": false,
          "gurmukhi": "ਨਮਸਕਾਰ ਤਾ ਕਉ ਲਖ ਬਾਰ ॥",
          "roman": "namaskār tā kau lakh bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਅੱਗੇ ਲੱਖਾਂ ਵਾਰੀ ਸਿਰ ਨਿਵਾਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Перед тем Богом следует склонять голову сотни тысяч раз,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48723,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਦੀਜੈ ਤਾ ਕਉ ਵਾਰਿ ॥",
          "roman": "ih man dījē tā kau vār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣਾ ਇਹ ਮਨ ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਅੱਗੇ ਭੇਟਾ ਕਰ ਦੇਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "следует поднести этому Богу в дар собственный ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48724,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਨਿ ਤਾ ਕੈ ਮਿਟਹਿ ਸੰਤਾਪ ॥",
          "roman": "simran tā kē miṭah santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਦੀ ਬਰਕਤ ਨਾਲ (ਸਾਰੇ) ਦੁੱਖ-ਕਲੇਸ਼ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию Имени того Бога исчезают все страдания и беды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48725,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਅਨੰਦੁ ਨ ਵਿਆਪਹਿ ਤਾਪ ॥੧॥",
          "roman": "hoi anand na biāpahi tāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨ ਵਿਚ) ਖ਼ੁਸ਼ੀ ਪੈਦਾ ਹੁੰਦੀ ਹੈ, ਕੋਈ ਭੀ ਦੁੱਖ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "в уме рождается радость, и никакая боль уже не может одолеть. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48726,
          "is_rahao": true,
          "gurmukhi": "ਐਸੋ ਹੀਰਾ ਨਿਰਮਲ ਨਾਮ ॥",
          "roman": "aiso hīrā nirmal nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੇ ਹਿਰਦੇ) ਪਵਿੱਤਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਅਜਿਹਾ ਕੀਮਤੀ ਪਦਾਰਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Таково это драгоценное сокровище — очищающее Имя Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48727,
          "is_rahao": true,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਪੂਰਨ ਸਭਿ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jās japat pūran sabh kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਨੂੰ ਜਪਦਿਆਂ ਸਾਰੇ ਕੰਮ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что при его повторении все дела исполняются. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48728,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਦ੍ਰਿਸਟਿ ਦੁਖ ਡੇਰਾ ਢਹੈ ॥",
          "roman": "jā kī drisaṭ dukh ḍerā ḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ (ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਦੁੱਖਾਂ ਦਾ ਡੇਰਾ ਢਹਿ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милостивому взгляду того Бога рушится внутри человека весь стан страданий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48729,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਸੀਤਲੁ ਮਨਿ ਗਹੈ ॥",
          "roman": "amrit nām sītal man gahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਉਸ ਦਾ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ (ਆਪਣੇ) ਮਨ ਵਿਚ ਵਸਾਂਦਾ ਹੈ (ਉਸ ਦਾ ਹਿਰਦਾ) ਠੰਢਾ-ਠਾਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а тот, кто помещает в своём уме Его дающее духовную жизнь Имя, становится прохладным и умиротворённым сердцем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48730,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਭਗਤ ਜਾ ਕੇ ਚਰਨ ਪੂਜਾਰੀ ॥",
          "roman": "anik bhagat jā ke charan pūjārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀ ਭਗਤ ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਪੂਜ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Множество преданных поклоняются стопам того Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48731,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰਨਹਾਰੀ ॥੨॥",
          "roman": "sagal manorath pūranhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ (ਆਪਣੇ ਭਗਤਾਂ ਦੇ) ਸਾਰੇ ਮਨੋਰਥ ਪੂਰੇ ਕਰਨ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он исполняет все желания Своих преданных. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48732,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਊਣੇ ਸੁਭਰ ਭਰਿਆ ॥",
          "roman": "khin mah ūṇe subhar bhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਖ਼ਾਲੀ (ਹਿਰਦਿਆਂ) ਨੂੰ ਇਕ ਖਿਨ ਵਿਚ (ਗੁਣਾਂ ਨਾਲ) ਨਕਾ-ਨਕ ਭਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя того Бога в одно мгновение наполняет пустые сердца до краёв добродетелями,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48733,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਸੂਕੇ ਕੀਨੇ ਹਰਿਆ ॥",
          "roman": "khin mah sūke kīne hariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ) ਸੁੱਕੇ ਹੋਇਆਂ ਨੂੰ ਇਕ ਖਿਨ ਵਿਚ ਹਰੇ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в одно мгновение делает зелёными тех, кто высох в духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48734,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਨਿਥਾਵੇ ਕਉ ਦੀਨੋ ਥਾਨੁ ॥",
          "roman": "khin mah nithāve kau dīno thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਕਿਤੇ ਆਸਰਾ ਨਹੀਂ ਮਿਲਦਾ, ਪਰਮਾਤਮਾ ਉਸ ਨੂੰ ਇਕ ਖਿਨ ਵਿਚ ਸਹਾਰਾ ਦੇ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кто нигде не находит опоры, Бог в одно мгновение даёт прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48735,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਨਿਮਾਣੇ ਕਉ ਦੀਨੋ ਮਾਨੁ ॥੩॥",
          "roman": "khin mahi nimāṇe kau dīno mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਕਿਤੇ ਕੋਈ ਆਦਰ-ਸਤਕਾਰ ਨਹੀਂ ਦੇਂਦਾ, ਉਹ ਪਰਮਾਤਮਾ ਉਸ ਨੂੰ ਇਕ ਖਿਨ ਵਿਚ ਮਾਣ-ਆਦਰ ਬਖ਼ਸ਼ ਦੇਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "того, кому нигде не оказывают уважения, Он в одно мгновение наделяет честью и достоинством. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
