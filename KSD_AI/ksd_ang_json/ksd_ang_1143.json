{
  "ang": 1143,
  "shabads": [
    {
      "shabad_id": 4088,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48736,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਏਕੁ ਰਹਿਆ ਭਰਪੂਰਾ ॥",
          "roman": "sabh mah ek rahiā bharpūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਵਿਚ ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਪੂਰਨ ਤੌਰ ਤੇ ਵੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Во всех существах полно и всецело пребывает один лишь Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48737,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਾਪੈ ਜਿਸੁ ਸਤਿਗੁਰੁ ਪੂਰਾ ॥",
          "roman": "so jāpē jis satgur pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਸ ਦਾ ਨਾਮ) ਉਹ ਮਨੁੱਖ (ਹੀ) ਜਪਦਾ ਹੈ, ਜਿਸ ਨੂੰ ਪੂਰਾ ਗੁਰੂ (ਪ੍ਰੇਰਨਾ ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Но Его Имя повторяет только тот человек, кого побуждает к этому совершенный Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48738,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਨੁ ਤਾ ਕੋ ਆਧਾਰੁ ॥",
          "roman": "har kīrtan tā ko ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਆਸਰਾ ਬਣ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В его сердце хвала Богу становится опорой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48739,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਸੁ ਆਪਿ ਦਇਆਰੁ ॥੪॥੧੩॥੨੬॥",
          "roman": "kah nānak jis āp daiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਆਪ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ ॥੪॥੧੩॥੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "говорит Нанак: тот, к кому Сам Бог милостив. ॥4॥13॥26॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4089,
      "rahao_verse_id": 48746,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48740,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48741,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਦੁਹਾਗਨਿ ਆਪਿ ਸੀਗਾਰੀ ॥",
          "roman": "moh duhāgan āp sīgārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! (ਮੈਂ) ਮੰਦੇ ਭਾਗਾਂ ਵਾਲੀ (ਸਾਂ) ਮੈਨੂੰ (ਖਸਮ-ਪ੍ਰਭੂ ਨੇ) ਆਪ (ਆਤਮਕ ਜੀਵਨ ਦੇ ਗਹਿਣਿਆਂ ਨਾਲ) ਸਜਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О подруги! Я была несчастной, обделённой доброй долей, но Он Сам украсил меня украшениями духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48742,
          "is_rahao": false,
          "gurmukhi": "ਰੂਪ ਰੰਗ ਦੇ ਨਾਮਿ ਸਵਾਰੀ ॥",
          "roman": "rūp raṅg de nām savārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ ਸੋਹਣਾ ਆਤਮਕ) ਰੂਪ ਦੇ ਕੇ (ਸੋਹਣਾ) ਪ੍ਰੇਮ ਬਖ਼ਸ਼ ਕੇ (ਆਪਣੇ) ਨਾਮ ਵਿਚ (ਜੋੜ ਕੇ ਉਸ ਨੇ ਮੈਨੂੰ) ਸੋਹਣੇ ਆਤਮਕ ਜੀਵਨ ਵਾਲੀ ਬਣਾ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "даровав мне прекрасный духовный облик, даровав прекрасную любовь и соединив со Своим Именем, Он сделал меня прекрасной в духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48743,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਿਓ ਦੁਖੁ ਅਰੁ ਸਗਲ ਸੰਤਾਪ ॥",
          "roman": "miṭio dukh aru sagal santāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! (ਮੇਰੇ ਅੰਦਰੋਂ) ਦੁੱਖ ਮਿਟ ਗਿਆ ਹੈ ਸਾਰੇ ਕਲੇਸ਼ ਮਿਟ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О подруги! Изнутри меня исчезла боль, исчезли все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48744,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਹੋਏ ਮੇਰੇ ਮਾਈ ਬਾਪ ॥੧॥",
          "roman": "gur hoē mere māī bāp ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸਾਰੀ ਮਿਹਰ ਗੁਰੂ ਨੇ ਕਰਾਈ ਹੈ, ਗੁਰੂ ਨੇ ਹੀ ਕੰਤ-ਪ੍ਰਭੂ ਨਾਲ ਮਿਲਾਇਆ ਹੈ) ਸਤਿਗੁਰੂ ਹੀ (ਮੇਰੇ ਵਾਸਤੇ) ਮੇਰੀ ਮਾਂ ਮੇਰਾ ਪਿਉ ਬਣਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Эту всю милость устроил Гуру; именно Гуру соединил меня с Господом-Супругом. Сатгуру стал для меня и матерью, и отцом ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48745,
          "is_rahao": true,
          "gurmukhi": "ਸਖੀ ਸਹੇਰੀ ਮੇਰੈ ਗ੍ਰਸਤਿ ਅਨੰਦ ॥",
          "roman": "sakhī saherī merē grasat anand ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ ਸਖੀਓ! ਹੇ ਮੇਰੀ ਸਹੇਲੀਓ! ਮੇਰੇ (ਹਿਰਦੇ-) ਘਰ ਵਿਚ ਆਤਮਕ ਆਨੰਦ ਬਣ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мои подруги, о мои сёстры! В доме моего сердца воцарился духовный блаженный покой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48746,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਭੇਟੇ ਮੋਹਿ ਕੰਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā bheṭe mohi kant ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਮੇਰੇ ਖਸਮ (-ਪ੍ਰਭੂ) ਜੀ ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਮਿਲ ਪਏ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "потому что мой Господь-Супруг по милости встретился мне ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48747,
          "is_rahao": false,
          "gurmukhi": "ਤਪਤਿ ਬੁਝੀ ਪੂਰਨ ਸਭ ਆਸਾ ॥",
          "roman": "tapat bujhī pūran sabh āsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! (ਹੁਣ ਮੇਰੇ ਅੰਦਰੋਂ ਤ੍ਰਿਸ਼ਨਾ-ਅੱਗ ਦੀ) ਸੜਨ ਬੁੱਝ ਗਈ ਹੈ, ਮੇਰੀ ਹਰੇਕ ਆਸ ਪੂਰੀ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруги! Теперь внутри меня погас жгучий огонь жажды, и всякая моя надежда исполнилась,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48748,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਅੰਧੇਰ ਭਏ ਪਰਗਾਸਾ ॥",
          "roman": "miṭe andher bhaē pargāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਸਾਰੇ) ਹਨੇਰੇ ਮਿਟ ਗਏ ਹਨ, (ਮੇਰੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦਾ) ਚਾਨਣ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "вся тьма заблуждения и привязанности к майе исчезла, и внутри меня засиял свет духовного понимания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48749,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਸਬਦ ਅਚਰਜ ਬਿਸਮਾਦ ॥",
          "roman": "anhad sabad acharaj bismād ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਇਉਂ ਹੋ ਗਿਆ ਹੈ ਜਿਵੇਂ) ਇਕ-ਰਸ ਸਾਰੇ ਸਾਜ਼ਾਂ ਦਾ ਰਾਗ (ਮੇਰੇ ਅੰਦਰ ਹੋ ਰਿਹਾ ਹੈ) (ਮੇਰੇ ਅੰਦਰ) ਅਚਰਜ ਤੇ ਹੈਰਾਨ ਕਰਨ ਵਾਲੀ (ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਗਈ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Теперь словно внутри меня звучит неумолкаемая мелодия всех инструментов, и во мне установилось дивное, изумляющее высокое духовное состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48750,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪੂਰਾ ਪਰਸਾਦ ॥੨॥",
          "roman": "gur pūrā pūrā parsād ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਹੇਲੀਓ! ਇਹ ਸਭ ਕੁਝ) ਪੂਰਾ ਗੁਰੂ ਹੀ (ਕਰਨ ਵਾਲਾ ਹੈ, ਇਹ) ਪੂਰੇ (ਗੁਰੂ ਦੀ ਹੀ) ਮਿਹਰ ਹੋਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О подруги! Всё это совершил только Совершенный Гуру; всё это — милость Совершенного Гуру ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48751,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਪ੍ਰਗਟ ਭਏ ਗੋਪਾਲ ॥",
          "roman": "jā kau pragaṭ bhaē gopāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! ਜਿਸ (ਸੁਭਾਗੀ) ਦੇ ਅੰਦਰ ਗੋਪਾਲ-ਪ੍ਰਭੂ ਪਰਗਟ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруги! В ком раскрывается Господь-Гопал,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48752,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਦਰਸਨਿ ਸਦਾ ਨਿਹਾਲ ॥",
          "roman": "tā kē darsan sadā nihāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਦਰਸਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਸਦਾ ਨਿਹਾਲ ਹੋ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, благодаря его даршану, всегда бывает благословлён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48753,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਗੁਣਾ ਤਾ ਕੈ ਬਹੁਤੁ ਨਿਧਾਨ ॥",
          "roman": "sarab guṇā tā kē bahut nidhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸਾਰੇ (ਆਤਮਕ) ਗੁਣ ਪੈਦਾ ਹੋ ਜਾਂਦੇ ਹਨ ਉਸ ਦੇ ਅੰਦਰ (ਮਾਨੋ) ਭਾਰਾ ਖ਼ਜ਼ਾਨਾ ਇਕੱਠਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруги! В его сердце рождаются все духовные достоинства, и внутри него словно собирается великое сокровище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48754,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਸਤਿਗੁਰਿ ਦੀਓ ਨਾਮੁ ॥੩॥",
          "roman": "jā kau satigur dīo nām ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (-ਖ਼ਜ਼ਾਨਾ) ਦੇ ਦਿੱਤਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тому, кому Гуру даровал сокровище Имени Господа ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48755,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਭੇਟਿਓ ਠਾਕੁਰੁ ਅਪਨਾ ॥",
          "roman": "jā kau bheṭio ṭhākur apnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀਓ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О подруги! Тот человек, кому встречается его Владыка-Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48756,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਸੀਤਲੁ ਹਰਿ ਹਰਿ ਜਪਨਾ ॥",
          "roman": "man tan sītal har har japnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹਰ ਵੇਲੇ ਜਪਦਿਆਂ ਉਸ ਦਾ ਮਨ ਉਸ ਦਾ ਤਨ ਠੰਢਾ-ਠਾਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "повторяя Имя Господа всегда, охлаждает и ум свой, и тело своё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48757,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜੋ ਜਨ ਪ੍ਰਭ ਭਾਏ ॥",
          "roman": "kah nānak jo jan prabh bhāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਪਿਆਰੇ ਲੱਗਣ ਲੱਗ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: те люди, которые становятся любимы Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48758,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਰੇਨੁ ਬਿਰਲਾ ਕੋ ਪਾਏ ॥੪॥੧੪॥੨੭॥",
          "roman": "tā kī ren birlā ko pāē ॥4॥14॥27॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵਿਰਲਾ (ਵਡਭਾਗੀ) ਮਨੁੱਖ ਉਹਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਹਾਸਲ ਕਰਦਾ ਹੈ ॥੪॥੧੪॥੨੭॥"
            },
            "sahib_singh_ru": {
              "main": "лишь редкий, поистине счастливый человек получает пыль их стоп ॥4॥14॥27॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4090,
      "rahao_verse_id": 48765,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48759,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48760,
          "is_rahao": false,
          "gurmukhi": "ਚਿਤਵਤ ਪਾਪ ਨ ਆਲਕੁ ਆਵੈ ॥",
          "roman": "chitvat pāp na ālak āvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੁਰਾਹੇ ਪਿਆ ਹੋਇਆ ਮਨੁੱਖ) ਪਾਪ ਸੋਚਦਿਆਂ (ਰਤਾ ਭੀ) ਢਿੱਲ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, сбившийся с пути, когда замышляет грех, не медлит ни капли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48761,
          "is_rahao": false,
          "gurmukhi": "ਬੇਸੁਆ ਭਜਤ ਕਿਛੁ ਨਹ ਸਰਮਾਵੈ ॥",
          "roman": "besuā bhajat kichh nah sarmāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਸੁਆ ਦੇ ਦੁਆਰੇ ਤੇ ਜਾਣੋਂ ਭੀ ਰਤਾ ਸ਼ਰਮ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и идти к дверям блудницы совсем не стыдится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48762,
          "is_rahao": false,
          "gurmukhi": "ਸਾਰੋ ਦਿਨਸੁ ਮਜੂਰੀ ਕਰੈ ॥",
          "roman": "sāro dinas majūrī karē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਸਾਰਾ ਹੀ ਦਿਨ ਮਜੂਰੀ ਕਰ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ради майи он может трудиться весь день напролёт,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48763,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨ ਕੀ ਵੇਲਾ ਬਜਰ ਸਿਰਿ ਪਰੈ ॥੧॥",
          "roman": "har simran kī velā bajar sir parē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਦਾ ਵੇਲਾ ਹੁੰਦਾ ਹੈ (ਤਦੋਂ ਇਉਂ ਹੁੰਦਾ ਹੈ ਜਿਵੇਂ ਇਸ ਦੇ) ਸਿਰ ਉਤੇ ਬਿਜਲੀ ਪੈ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но когда приходит время помнить Бога, ему будто молния падает на голову ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48764,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਲਗਿ ਭੂਲੋ ਸੰਸਾਰੁ ॥",
          "roman": "māiā lag bhūlo sansār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ ਕੁਰਾਹੇ ਪਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мир, увязнув в привязанности к майе, остаётся сбившимся с пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48765,
          "is_rahao": true,
          "gurmukhi": "ਆਪਿ ਭੁਲਾਇਆ ਭੁਲਾਵਣਹਾਰੈ ਰਾਚਿ ਰਹਿਆ ਬਿਰਥਾ ਬਿਉਹਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āp bhulāiā bhulāvaṇhārē rāch rahiā birthā biuhār ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜਗਤ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਕੁਰਾਹੇ ਪਾ ਸਕਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੇ ਆਪ (ਹੀ ਜਗਤ ਨੂੰ) ਕੁਰਾਹੇ ਪਾਇਆ ਹੋਇਆ ਹੈ (ਇਸ ਵਾਸਤੇ ਜਗਤ) ਵਿਅਰਥ ਵਿਹਾਰਾਂ ਵਿਚ ਹੀ ਮਗਨ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Но что тут во власти мира? Сам Господь, способный вводить в заблуждение, ввёл его в заблуждение, и потому мир остаётся поглощённым лишь пустыми делами ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48766,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਤ ਮਾਇਆ ਰੰਗ ਬਿਹਾਇ ॥",
          "roman": "pekhat māiā raṅg bihāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਚੋਜ-ਤਮਾਸ਼ੇ ਵੇਖਦਿਆਂ ਹੀ (ਕੁਰਾਹੇ ਪਏ ਮਨੁੱਖ ਦੀ ਉਮਰ) ਬੀਤ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Созерцая зрелища и забавы майи, человек, сбившийся с пути, так и проводит свою жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48767,
          "is_rahao": false,
          "gurmukhi": "ਗੜਬੜ ਕਰੈ ਕਉਡੀ ਰੰਗੁ ਲਾਇ ॥",
          "roman": "gaṛbaṛ karē kauṛī raṅg lāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੁੱਛ ਜਿਹੀ ਮਾਇਆ ਵਿਚ ਪਿਆਰ ਪਾ ਕੇ (ਰੋਜ਼ਾਨਾ ਕਾਰ-ਵਿਹਾਰ ਵਿਚ ਭੀ) ਹੇਰਾ-ਵੇਰੀ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "привязавшись к ничтожной майе, он даже в повседневных делах продолжает плутовать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48768,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਬਿਉਹਾਰ ਬੰਧ ਮਨੁ ਧਾਵੈ ॥",
          "roman": "andh biuhār bandh man dhāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਅੰਨ੍ਹਾ ਕਰ ਦੇਣ ਵਾਲੇ ਕਾਰ-ਵਿਹਾਰ ਦੇ ਬੰਧਨਾਂ ਵਲ (ਕੁਰਾਹੇ ਪਏ ਮਨੁੱਖ ਦਾ) ਮਨ ਦੌੜਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его ум мчится к узам дел и занятий, которые ослепляют привязанностью к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48769,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੈਹਾਰੁ ਨ ਜੀਅ ਮਹਿ ਆਵੈ ॥੨॥",
          "roman": "karṇēhār na jīa mahi āvē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ ਪਰਮਾਤਮਾ ਇਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਨਹੀਂ ਯਾਦ ਆਉਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но Творец не приходит ему на сердце, не вспоминается им ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48770,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤ ਕਰਤ ਇਵ ਹੀ ਦੁਖੁ ਪਾਇਆ ॥",
          "roman": "karat karat iv hī dukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੁਰਾਹੇ ਪਿਆ ਮਨੁੱਖ) ਇਸੇ ਤਰ੍ਹਾਂ ਕਰਦਿਆਂ ਕਰਦਿਆਂ ਦੁੱਖ ਭੋਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Так поступая снова и снова, человек только испытывает страдание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48771,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਤ ਨ ਕਾਰਜ ਮਾਇਆ ॥",
          "roman": "pūran hot na kāraj māiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਵਾਲੇ (ਇਸ ਦੇ) ਕੰਮ ਕਦੇ ਮੁੱਕਦੇ ਹੀ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "а дела, связанные с майей, никогда не заканчиваются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48772,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਕ੍ਰੋਧਿ ਲੋਭਿ ਮਨੁ ਲੀਨਾ ॥",
          "roman": "kām krodh lobh man līnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ-ਵਾਸਨਾ ਵਿਚ, ਕ੍ਰੋਧ ਵਿਚ, ਲੋਭ ਵਿਚ (ਇਸ ਦਾ) ਮਨ ਡੁੱਬਾ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Его ум погружён в похоть, гнев и жадность;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48773,
          "is_rahao": false,
          "gurmukhi": "ਤੜਫਿ ਮੂਆ ਜਿਉ ਜਲ ਬਿਨੁ ਮੀਨਾ ॥੩॥",
          "roman": "ṭaṛaf mūā jiu jal bin mīnā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮੱਛੀ ਪਾਣੀ ਤੋਂ ਬਿਨਾ ਤੜਫ ਮਰਦੀ ਹੈ, ਤਿਵੇਂ ਨਾਮ ਤੋਂ ਬਿਨਾ ਵਿਕਾਰਾਂ ਵਿਚ ਲੁਛ ਲੁਛ ਕੇ ਇਹ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "как рыба без воды бьётся и умирает, так и он, без Имени, корчась среди пороков, навлекает на себя духовную смерть ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48774,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੇ ਰਾਖੇ ਹੋਇ ਹਰਿ ਆਪਿ ॥",
          "roman": "jis ke rākhe hoi har āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਪ੍ਰਭੂ ਜੀ ਆਪ ਜਿਸ ਮਨੁੱਖ ਦੇ ਰਖਵਾਲੇ ਬਣ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Но тот человек, чьим хранителем Сам стал Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48775,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਸਦਾ ਜਪੁ ਜਾਪਿ ॥",
          "roman": "har har nām sadā jap jāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਹੀ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всегда повторяет Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48776,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੇ ਗੁਣ ਗਾਇਆ ॥",
          "roman": "sādhsang har ke guṇ gāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он, пребывая в Садх-Санге, поёт качества Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48777,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਤਿਗੁਰੁ ਪੂਰਾ ਪਾਇਆ ॥੪॥੧੫॥੨੮॥",
          "roman": "nānak satigur pūrā pāiā ॥4॥15॥28॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਨੂੰ (ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੪॥੧੫॥੨੮॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот, кому по милости Бога встречается Совершенный Гуру ॥4॥15॥28॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4091,
      "rahao_verse_id": 48784,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48778,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48779,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੀ ਦਇਆ ਕਰੇ ਸੋ ਪਾਏ ॥",
          "roman": "apaṇī daiā kre so pāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ) ਪਰਮਾਤਮਾ ਆਪਣੀ ਮਿਹਰ ਕਰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ (ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ) ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на кого Господь изливает Свою милость, получает это памятование Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48780,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਮੰਨਿ ਵਸਾਏ ॥",
          "roman": "har kā nām mann vasāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и водворяет Имя Господа в своём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48781,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਸਬਦੁ ਹਿਰਦੇ ਮਨ ਮਾਹਿ ॥",
          "roman": "sāch sabad hirdē man māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਸ਼ਬਦ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਆਪਣੇ ਮਨ ਵਿਚ ਟਿਕਾਈ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "удерживает в сердце и уме слово хвалы Вечному Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48782,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਕਿਲਵਿਖ ਜਾਹਿ ॥੧॥",
          "roman": "janam janam ke kilvikh jāhi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ ਦੇ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и по его благодати уходят грехи многих рождений ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48783,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਜੀਅ ਕੋ ਆਧਾਰੁ ॥",
          "roman": "rām nām jīa ko ādhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਮਨੁੱਖ ਦੀ) ਜਿੰਦ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Господа — опора жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48784,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਜਪਹੁ ਨਿਤ ਭਾਈ ਤਾਰਿ ਲਏ ਸਾਗਰ ਸੰਸਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur parsād japah nit bhāī tār laē sāgar sansār ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਇਹ ਨਾਮ) ਸਦਾ ਜਪਿਆ ਕਰੋ, (ਪ੍ਰਭੂ ਦਾ ਨਾਮ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Потому по милости Гуру постоянно повторяйте это Имя, о брат; Имя Господа переправляет через океан мира ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48785,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕਉ ਲਿਖਿਆ ਹਰਿ ਏਹੁ ਨਿਧਾਨੁ ॥",
          "roman": "jin kau likhiā har eh nidhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਮੱਥੇ ਉੱਤੇ ਪਰਮਾਤਮਾ ਨੇ ਇਸ ਨਾਮ-ਖ਼ਜ਼ਾਨੇ ਦੀ ਪ੍ਰਾਪਤੀ ਲਿਖੀ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тем людям, у кого на челе Господь начертал получение этого сокровища Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48786,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਜਨ ਦਰਗਹ ਪਾਵਹਿ ਮਾਨੁ ॥",
          "roman": "se jan dargah pāvah mān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਨਾਮ ਜਪ ਕੇ) ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ ਪਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "тем людям, повторяющим Имя, даруется честь в Божественном Присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48787,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਗੁਣ ਗਾਉ ॥",
          "roman": "sūkh sahaj ānand guṇ gāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "Пойте качества Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48788,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਮਿਲੈ ਨਿਥਾਵੇ ਥਾਉ ॥੨॥",
          "roman": "āgē milē nithāve thāu ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਣ ਗਾਵਣ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਆਨੰਦ (ਪ੍ਰਾਪਤ ਹੁੰਦੇ ਹਨ), (ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਜਗਤ ਵਿਚ) ਕੋਈ ਜੀਵ ਭੀ ਸਹਾਰਾ ਨਹੀਂ ਦੇਂਦਾ, ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਥਾਂ ਮਿਲਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и по благодати этого пения обретаются покой, естественная устойчивость и блаженство; тому, у кого в мире нет никакой опоры, даётся место в Присутствии Господа ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48789,
          "is_rahao": false,
          "gurmukhi": "ਜੁਗਹ ਜੁਗੰਤਰਿ ਇਹੁ ਤਤੁ ਸਾਰੁ ॥",
          "roman": "jugah jugaṅtar ihu tat sār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੁਗ ਕੋਈ ਭੀ ਹੋਵੇ) ਹਰੇਕ ਜੁਗ ਵਿਚ (ਨਾਮ-ਸਿਮਰਨ ਹੀ ਜੀਵਨ-ਜੁਗਤਿ ਦਾ) ਤੱਤ ਹੈ ਨਿਚੋੜ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В любой век именно памятование Имени составляет сущность и сердцевину пути жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48790,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਣੁ ਸਾਚਾ ਬੀਚਾਰੁ ॥",
          "roman": "har simraṇ sāchā bīchār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਹੀ (ਆਤਮਕ ਜੀਵਨ ਜੀਊਣ ਦੀ) ਸਹੀ ਵਿਚਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Памятование Бога и есть истинное понимание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
