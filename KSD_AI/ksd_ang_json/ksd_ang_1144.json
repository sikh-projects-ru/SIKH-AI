{
  "ang": 1144,
  "shabads": [
    {
      "shabad_id": 4091,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48791,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਲੜਿ ਲਾਇ ਲਏ ਸੋ ਲਾਗੈ ॥",
          "roman": "jis laṛ lāi laē so lāgē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪ ਆਪਣੇ ਲੜ ਲਾ ਲੈਂਦਾ ਹੈ, ਉਹੀ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но только тот прилепляется, кого Сам Господь привязывает к Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48792,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗੈ ॥੩॥",
          "roman": "janam janam kā soiā jāgē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦਾ ਸੁੱਤਾ ਹੋਇਆ ਜਾਗ ਪੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и только он пробуждается, хотя многие рождения спал в дремоте привязанности к майе ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48793,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਭਗਤ ਭਗਤਨ ਕਾ ਆਪਿ ॥",
          "roman": "tere bhagat bhagtan kā āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਭਗਤ (ਤੇਰੇ ਸਹਾਰੇ ਹਨ), ਤੂੰ ਆਪ ਆਪਣੇ ਭਗਤਾਂ ਦਾ (ਸਦਾ ਰਾਖਾ ਹੈਂ)।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои бхагаты держатся Тобой, и Ты Сам всегда хранишь Своих бхагатов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48794,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੀ ਮਹਿਮਾ ਆਪੇ ਜਾਪਿ ॥",
          "roman": "apaṇī mahimā āpe jāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਗਤਾਂ ਵਿਚ ਬੈਠ ਕੇ) ਤੂੰ ਆਪ ਹੀ ਆਪਣੀ ਵਡਿਆਈ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Сидя среди Своих бхагатов, Ты Сам воспеваешь Своё величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48795,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਭਿ ਤੇਰੈ ਹਾਥਿ ॥",
          "roman": "jīa jant sabh terē hāth ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਹੀ ਜੀਅ ਜੰਤ ਤੇਰੇ ਵੱਸ ਵਿਚ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все живые существа — в Твоей власти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48796,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੇ ਪ੍ਰਭ ਸਦ ਹੀ ਸਾਥਿ ॥੪॥੧੬॥੨੯॥",
          "roman": "nānak ke prabh sad hī sāth ॥4॥16॥29॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ ਦੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਭ ਜੀਵਾਂ ਦੇ ਸਦਾ ਅੰਗ-ਸੰਗ ਰਹਿੰਦਾ ਹੈਂ ॥੪॥੧੬॥੨੯॥"
            },
            "sahib_singh_ru": {
              "main": "о Господь Нанака! Ты всегда пребываешь рядом со всеми существами ॥4॥16॥29॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4092,
      "rahao_verse_id": 48803,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48797,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48798,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "nām hamārē antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲੇ ਹਰੀ ਦਾ ਨਾਮ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари, Знающего сердца всех, обитает в моём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48799,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਆਵੈ ਕਾਮੀ ॥",
          "roman": "nām hamārē āvē kāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਮੇਰੇ ਸਾਰੇ ਕੰਮ ਸਵਾਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Хари-Имя устраивает все мои дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48800,
          "is_rahao": false,
          "gurmukhi": "ਰੋਮਿ ਰੋਮਿ ਰਵਿਆ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "rom rom raviā har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਹਰਿ-ਨਾਮ ਮੇਰੇ ਰੋਮ ਰੋਮ ਵਿਚ ਵੱਸ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру Хари-Имя наполнило каждый мой волосок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48801,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਪੂਰੈ ਕੀਨੋ ਦਾਨੁ ॥੧॥",
          "roman": "satgur pūrē kīno dān ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਮੈਨੂੰ (ਹਰਿ-ਨਾਮ ਰਤਨ ਦਾ) ਦਾਨ ਦਿੱਤਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру дал мне этот дар — драгоценность Хари-Имени. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48802,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੁ ਰਤਨੁ ਮੇਰੈ ਭੰਡਾਰ ॥",
          "roman": "nām ratan merē bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪੂਰੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਕੀਮਤੀ ਨਾਮ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Совершенного Гуру драгоценное Имя поселилось в моём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48803,
          "is_rahao": true,
          "gurmukhi": "ਅਗਮ ਅਮੋਲਾ ਅਪਰ ਅਪਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "agam amolā apar apār ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਪਹੁੰਚ ਤੇ ਬੇਅੰਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਐਸਾ ਖ਼ਜ਼ਾਨਾ ਹੈ ਜੋ ਕਿਸੇ ਕੀਮਤ ਤੋਂ ਨਹੀਂ ਮਿਲ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Имя недосягаемого и беспредельного Вахегуру — такое сокровище, которое нельзя получить ни за какую цену. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48804,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਨਿਹਚਲ ਧਨੀ ॥",
          "roman": "nām hamārē nihchal dhanī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ (ਮੇਰੇ ਸਿਰ ਉਤੇ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਮਾਲਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь Имя Вахегуру и есть мой Владыка, пребывающий вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48805,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੀ ਮਹਿਮਾ ਸਭ ਮਹਿ ਬਨੀ ॥",
          "roman": "nām kī mahimā sabh mah banī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਦੀ ਵਡਿਆਈ ਹੀ ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਸੋਭ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Величие Хари-Имени сияет внутри всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48806,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਪੂਰਾ ਸਾਹੁ ॥",
          "roman": "nām hamārē pūrā sāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ (ਮੇਰੇ ਵਾਸਤੇ ਉਹ) ਸ਼ਾਹ ਹੈ ਜਿਸ ਦੇ ਘਰ ਵਿਚ ਕੋਈ ਕਮੀ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь Имя Вахегуру для меня — тот Шах, в чьём доме нет никакой нехватки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48807,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਬੇਪਰਵਾਹੁ ॥੨॥",
          "roman": "nām hamārē beparvāh ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਹੀ (ਮੇਰੇ ਸਿਰ ਉਤੇ ਉਹ) ਮਾਲਕ ਹੈ ਜਿਸ ਨੂੰ ਕਿਸੇ ਦੀ ਮੁਥਾਜੀ ਨਹੀਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Хари-Имя и есть мой Владыка, не зависящий ни от кого. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48808,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਭੋਜਨ ਭਾਉ ॥",
          "roman": "nām hamārē bhojan bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੋਂ ਪੂਰੇ ਗੁਰੂ ਨੇ ਮੈਨੂੰ ਨਾਮ ਦਾ ਦਾਨ ਦਿੱਤਾ ਹੈ, ਤਦੋਂ ਤੋਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਪਿਆਰ ਹੀ ਮੇਰੀ ਆਤਮਕ ਖ਼ੁਰਾਕ ਬਣ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "С тех пор как Совершенный Гуру дал мне дар Имени, Имя Вахегуру и любовь к Нему стали моей духовной пищей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48809,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਮਨ ਕਾ ਸੁਆਉ ॥",
          "roman": "nām hamārē man kā suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਮੇਰੇ ਮਨ ਦੀ ਹਰ ਵੇਲੇ ਦੀ ਮੰਗ ਹੋ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Хари-Имя стало постоянным стремлением моего ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48810,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਨ ਵਿਸਰੈ ਸੰਤ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "nām na visrē sant prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਸੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮੈਨੂੰ ਕਦੇ ਨਹੀਂ ਭੁੱਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру-Санта Имя Вахегуру никогда не забывается мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48811,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਅਨਹਦ ਪੂਰੇ ਨਾਦ ॥੩॥",
          "roman": "nām lēt anhad pūre nād ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਦਿਆਂ (ਅੰਤਰ ਆਤਮੇ ਇਉਂ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ ਕਿ) ਸਾਰੇ ਸੰਗੀਤਕ ਸਾਜ਼ ਇਕ-ਰਸ ਵੱਜਣ ਲੱਗ ਪਏ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда повторяется Имя, во внутреннем существе словно все музыкальные инструменты начинают звучать в едином ладе. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48812,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਨਾਮੁ ਨਉ ਨਿਧਿ ਪਾਈ ॥",
          "roman": "prabh kirpā te nām nau nidh pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਨੂੰ (ਉਸ ਦਾ) ਨਾਮ ਮਿਲ ਗਿਆ ਹੈ (ਜੋ ਮੇਰੇ ਲਈ, ਮਾਨੋ, ਧਰਤੀ ਦੇ ਸਾਰੇ) ਨੌ ਖ਼ਜ਼ਾਨੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Вахегуру я обрёл Его Имя, которое для меня словно все девять сокровищ земли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48813,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਨਾਮ ਸਿਉ ਬਨਿ ਆਈ ॥",
          "roman": "gur kirpā te nām siu ban āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੇਰਾ ਪਿਆਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨਾਲ ਬਣ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру во мне установилась любовь к Имени Вахегуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48814,
          "is_rahao": false,
          "gurmukhi": "ਧਨਵੰਤੇ ਸੇਈ ਪਰਧਾਨ ॥",
          "roman": "dhanvante seī pardhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਅਸਲ) ਧਨਾਢ ਹਨ, ਉਹੀ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਤੁਰਨੇ-ਸਿਰ ਮਨੁੱਖ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Только те люди по-настоящему богаты, только они — главные и достойные и в этом мире, и в ином,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48815,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾ ਕੈ ਨਾਮੁ ਨਿਧਾਨ ॥੪॥੧੭॥੩੦॥",
          "roman": "nānak jā kē nām nidhān ||4||17||30||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਨ੍ਹਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ (ਆ ਵੱਸਦਾ ਹੈ) ॥੪॥੧੭॥੩੦॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, в чьём сердце поселилось сокровище Имени. ||4||17||30||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4093,
      "rahao_verse_id": 48822,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48816,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48817,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਮੇਰਾ ਪਿਤਾ ਤੂਹੈ ਮੇਰਾ ਮਾਤਾ ॥",
          "roman": "tū merā pitā tūhē merā mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੇਰੇ ਵਾਸਤੇ ਤੂੰ ਹੀ ਪਿਤਾ ਹੈਂ, ਮੇਰੇ ਵਾਸਤੇ ਤੂੰ ਹੀ ਮਾਂ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, для меня Ты — и отец, и мать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48818,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਮੇਰੇ ਜੀਅ ਪ੍ਰਾਨ ਸੁਖਦਾਤਾ ॥",
          "roman": "tū mere jīa prān sukhdātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹੀ ਮੈਨੂੰ ਜਿੰਦ ਦੇਣ ਵਾਲਾ ਹੈਂ, ਤੂੰ ਹੀ ਮੈਨੂੰ ਪ੍ਰਾਣ ਦੇਣ ਵਾਲਾ ਹੈਂ, ਤੂੰ ਹੀ ਮੈਨੂੰ ਸਾਰੇ ਸੁਖ ਦੇਣ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — Тот, Кто даёт мне жизнь, Ты — Тот, Кто даёт мне дыхание, Ты — Тот, Кто дарует мне все радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48819,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਮੇਰਾ ਠਾਕੁਰੁ ਹਉ ਦਾਸੁ ਤੇਰਾ ॥",
          "roman": "tū merā ṭhākur hau dās terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੇਰਾ ਮਾਲਕ ਹੈਂ, ਮੈਂ ਤੇਰਾ ਸੇਵਕ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты мой Владыка, я Твой слуга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48820,
          "is_rahao": false,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਅਵਰੁ ਨਹੀ ਕੋ ਮੇਰਾ ॥੧॥",
          "roman": "tujh bin avar nahī ko merā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਥੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਮੇਰਾ (ਆਸਰਾ) ਨਹੀਂ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя у меня нет никакой иной опоры. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48821,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਕਰਹੁ ਪ੍ਰਭ ਦਾਤਿ ॥",
          "roman": "kar kirpā karah prabh dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮਿਹਰ ਕਰ ਕੇ (ਮੈਨੂੰ ਇਹ) ਦਾਤ ਬਖ਼ਸ਼,"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, по милости Своей даруй мне этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48822,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮੑਰੀ ਉਸਤਤਿ ਕਰਉ ਦਿਨ ਰਾਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tumrī ustat karau din rāt ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਮੈਂ ਦਿਨ ਰਾਤ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы я день и ночь продолжал славить Тебя. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48823,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਤੇਰੇ ਜੰਤ ਤੂ ਬਜਾਵਨਹਾਰਾ ॥",
          "roman": "ham tere jant tū bajāvanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਅਸੀਂ ਜੀਵ ਤੇਰੇ (ਸੰਗੀਤਕ) ਸਾਜ਼ ਹਾਂ, ਤੂੰ (ਇਹਨਾਂ ਸਾਜ਼ਾਂ ਨੂੰ) ਵਜਾਣ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, мы, существа, — Твои музыкальные инструменты, а Ты — Играющий на них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48824,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਤੇਰੇ ਭਿਖਾਰੀ ਦਾਨੁ ਦੇਹਿ ਦਾਤਾਰਾ ॥",
          "roman": "ham tere bhikhārī dān deh dātārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਤਾਰ! ਅਸੀਂ ਤੇਰੇ (ਦਰ ਦੇ) ਮੰਗਤੇ ਹਾਂ, ਤੂੰ ਸਾਨੂੰ ਦਾਨ ਦੇਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Дающий, мы — нищие у Твоих дверей, а Ты подаёшь нам дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48825,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਪਰਸਾਦਿ ਰੰਗ ਰਸ ਮਾਣੇ ॥",
          "roman": "tau parsād rang ras māṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮਿਹਰ ਨਾਲ ਹੀ ਅਸੀਂ (ਬੇਅੰਤ) ਰੰਗ ਰਸ ਮਾਣਦੇ ਆ ਰਹੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Только по Твоей милости мы вкушаем бесчисленные наслаждения и радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48826,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਘਟ ਅੰਤਰਿ ਤੁਮਹਿ ਸਮਾਣੇ ॥੨॥",
          "roman": "ghaṭ ghaṭ antar tumahi samāṇe ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਤੂੰ ਹੀ ਮੌਜੂਦ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, в каждом теле присутствуешь только Ты. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48827,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮੑਰੀ ਕ੍ਰਿਪਾ ਤੇ ਜਪੀਐ ਨਾਉ ॥",
          "roman": "tumrī kripā te japīai nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਮਿਹਰ ਨਾਲ (ਹੀ) ਤੇਰਾ ਨਾਮ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, только по Твоей милости можно повторять Твоё Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48828,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਤੁਮਰੇ ਗੁਣ ਗਾਉ ॥",
          "roman": "sādhsang tumre guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਿਹਰ ਕਰ ਕਿ) ਮੈਂ ਸਾਧ ਸੰਗਤ ਵਿਚ ਟਿਕ ਕੇ ਤੇਰੇ ਗੁਣ ਗਾਂਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "смилуйся, чтобы, пребывая в Садх Сангат, я продолжал петь Твои достоинства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48829,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮੑਰੀ ਦਇਆ ਤੇ ਹੋਇ ਦਰਦ ਬਿਨਾਸੁ ॥",
          "roman": "tumrī daiyā te hoi darad binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਮਿਹਰ ਨਾਲ (ਹੀ) ਮੇਰੇ ਹਰੇਕ ਦਰਦ ਦਾ ਨਾਸ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Вахегуру, только по Твоей милости исчезает всякая моя боль,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48830,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਮਇਆ ਤੇ ਕਮਲ ਬਿਗਾਸੁ ॥੩॥",
          "roman": "tumrī maiā te kamal bigās ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮਿਹਰ ਨਾਲ (ਹੀ) ਮੇਰੇ ਹਿਰਦੇ-ਕੌਲ ਦਾ ਖਿੜਾਉ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и только по Твоей милости расцветает лотос моего сердца. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48831,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਬਲਿਹਾਰਿ ਜਾਉ ਗੁਰਦੇਵ ॥",
          "roman": "hau balihār jāu gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੇ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву своему Гурудэву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48832,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਦਰਸਨੁ ਜਾ ਕੀ ਨਿਰਮਲ ਸੇਵ ॥",
          "roman": "safal darsan jā kī nirmal sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੁਰੂ ਦਾ ਦਰਸਨ ਮੁਰਾਦਾਂ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਸ ਗੁਰੂ ਦੀ ਸੇਵਾ ਜੀਵਨ ਨੂੰ ਪਵਿੱਤਰ ਬਣਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чьё даршан исполняет стремления, а чьё служение делает жизнь чистой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48833,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਕਰਹੁ ਠਾਕੁਰ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "daiyā karah ṭhākur prabh mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਠਾਕੁਰ! ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! ਮਿਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О мой Тхакур, о мой Вахегуру, смилуйся,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48834,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵੈ ਨਾਨਕੁ ਨਿਤ ਤੇਰੇ ॥੪॥੧੮॥੩੧॥",
          "roman": "guṇ gāvē nānak nit tere ||4||18||31||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਦਾਸ) ਨਾਨਕ ਸਦਾ ਤੇਰੇ ਗੁਣ ਗਾਂਦਾ ਰਹੇ ॥੪॥੧੮॥੩੧॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Твой слуга Нанак всегда пел Твои достоинства. ||4||18||31||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4094,
      "rahao_verse_id": 48841,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48835,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48836,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਜਾ ਕਾ ਦਰਬਾਰੁ ॥",
          "roman": "sabh te ūch jā kā darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪਰਮਾਤਮਾ) ਦਾ ਦਰਬਾਰ ਸਭ (ਪਾਤਿਸ਼ਾਹਾਂ ਦੇ ਦਰਬਾਰਾਂ) ਨਾਲੋਂ ਉੱਚਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чей двор выше всех дворов всех царей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48837,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਤਾ ਕਉ ਜੋਹਾਰੁ ॥",
          "roman": "sadā sadā tā kau johār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ) ਨੂੰ ਸਦਾ ਹੀ ਸਦਾ ਨਮਸਕਾਰ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тому Вахегуру-Царю всегда и вечно следует поклоняться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48838,
          "is_rahao": false,
          "gurmukhi": "ਊਚੇ ਤੇ ਊਚਾ ਜਾ ਕਾ ਥਾਨ ॥",
          "roman": "ūche te ūchā jā kā thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਦਾ ਮਹੱਲ ਉੱਚੇ ਤੋਂ ਉੱਚਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чей чертог выше высочайшего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48839,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਅਘਾ ਮਿਟਹਿ ਹਰਿ ਨਾਮ ॥੧॥",
          "roman": "koṭ aghā miṭahi har nām ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਹਰੀ-ਪਾਤਿਸ਼ਾਹ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਕ੍ਰੋੜਾਂ ਪਾਪ ਖ਼ਤਮ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "по благодати Имени этого Хари-Царя исчезают миллионы грехов. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48840,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸੁ ਸਰਣਾਈ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥",
          "roman": "tis saraṇāī sadā sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਪ੍ਰਭੂ) ਦੀ ਸਰਨ ਵਿਚ (ਰਹਿ ਕੇ) ਉਸ ਮਨੁੱਖ ਨੂੰ ਸਦਾ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В прибежище этого Вахегуру человек всегда пребывает в блаженстве,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48841,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਾ ਕਉ ਮੇਲੈ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā jā kau melē soi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਮਿਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "если Сам Вахегуру по милости соединяет его со Своими стопами. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48842,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਕਰਤਬ ਲਖੇ ਨ ਜਾਹਿ ॥",
          "roman": "jā ke kartab lakhe na jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਦੇ ਚੋਜ-ਤਮਾਸ਼ੇ ਸਮਝੇ ਨਹੀਂ ਜਾ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Чьи дивные игры и чудеса невозможно постичь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48843,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਭਰਵਾਸਾ ਸਭ ਘਟ ਮਾਹਿ ॥",
          "roman": "jā kā bharvāsā sabh ghaṭ māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਸਹਾਰਾ ਹਰੇਕ ਜੀਵ ਦੇ ਹਿਰਦੇ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чья опора пребывает в сердце каждого существа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48844,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟ ਭਇਆ ਸਾਧੂ ਕੈ ਸੰਗਿ ॥",
          "roman": "pragaṭ bhēā sādhū kē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ (ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਪਰਗਟ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот Вахегуру-Царь становится явным в сердце человека, когда тот живёт в общении с Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48845,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਅਰਾਧਹਿ ਅਨਦਿਨੁ ਰੰਗਿ ॥੨॥",
          "roman": "bhagat ārādheh anadin rang ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਭਗਤ ਹਰ ਵੇਲੇ ਪ੍ਰੇਮ ਨਾਲ ਉਸ ਦਾ ਨਾਮ ਜਪਦੇ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Его бхагаты во всякое время с любовью продолжают повторять Его Имя. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48846,
          "is_rahao": false,
          "gurmukhi": "ਦੇਦੇ ਤੋਟਿ ਨਹੀ ਭੰਡਾਰ ॥",
          "roman": "dede toṭ nahī bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਨੂੰ ਬੇਅੰਤ ਦਾਤਾਂ) ਦੇਂਦਿਆਂ ਭੀ (ਉਸ ਦੇ) ਖ਼ਜ਼ਾਨਿਆਂ ਵਿਚ ਕਮੀ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Даже раздавая бесконечные дары живым существам, Он не исчерпывает Своих сокровищ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48847,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਥਾਪਿ ਉਥਾਪਨਹਾਰ ॥",
          "roman": "khin mah thāp uthāpanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਇਕ ਖਿਨ ਵਿਚ ਪੈਦਾ ਕਰ ਕੇ ਨਾਸ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он способен в одно мгновение создать и разрушить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48848,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਹੁਕਮੁ ਨ ਮੇਟੈ ਕੋਇ ॥",
          "roman": "jā kā hukam na meṭē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਭੀ ਜੀਵ ਉਸ ਦਾ ਹੁਕਮ ਮੋੜ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Ни одно существо не может отменить Его Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48849,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਿ ਪਾਤਿਸਾਹਾ ਸਾਚਾ ਸੋਇ ॥੩॥",
          "roman": "sir pātisāhā sāchā soi ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੇ) ਪਾਤਿਸ਼ਾਹਾਂ ਦੇ ਸਿਰ ਉੱਤੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ (ਪਾਤਿਸ਼ਾਹ) ਉਹ (ਪਰਮਾਤਮਾ) ਹੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Над царями мира стоит только Он — вечный и истинный Царь. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48850,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੀ ਓਟ ਤਿਸੈ ਕੀ ਆਸਾ ॥",
          "roman": "jis kī oṭ tisē kī āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁੱਖਾਂ ਤੋਂ ਬਚਣ ਲਈ ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ) ਜਿਸ (ਪਰਮਾਤਮਾ) ਦਾ ਆਸਰਾ ਹੈ, (ਸੁਖਾਂ ਦੀ ਪ੍ਰਾਪਤੀ ਲਈ ਭੀ) ਉਸੇ ਦੀ (ਸਹਾਇਤਾ ਦੀ) ਆਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У Кого мы ищем защиты от страданий, на Того же возлагаем надежду и ради обретения счастья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
