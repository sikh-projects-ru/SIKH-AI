{
  "ang": 1145,
  "shabads": [
    {
      "shabad_id": 4094,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48851,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਸੁਖੁ ਹਮਰਾ ਤਿਸ ਹੀ ਪਾਸਾ ॥",
          "roman": "dukh sukh hamrā tis hī pāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਖ (ਤੋਂ ਬਚਣ ਲਈ, ਤੇ) ਸੁਖ (ਦੀ ਪ੍ਰਾਪਤੀ ਲਈ) ਅਸਾਂ ਜੀਵਾਂ ਦੀ ਉਸ ਦੇ ਪਾਸ ਹੀ (ਸਦਾ ਅਰਦਾਸ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И от скорби избавиться, и счастье обрести — ради этого наша мольба всегда только к Нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48852,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੀਨੋ ਸਭੁ ਜਨ ਕਾ ਪੜਦਾ ॥",
          "roman": "rākh līno sabh jan kā paṛdā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸੇਵਕ ਦੀ ਇੱਜ਼ਤ ਪਰਮਾਤਮਾ ਹਰ ਥਾਂ ਰੱਖ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Вахегуру везде сохраняет честь Своего слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48853,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਤਿਸ ਕੀ ਉਸਤਤਿ ਕਰਦਾ ॥੪॥੧੯॥੩੨॥",
          "roman": "nānak tis kī ustat kardā ||4||19||32||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਉਸ ਦੀ (ਹੀ ਸਦਾ) ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ ॥੪॥੧੯॥੩੨॥"
            },
            "sahib_singh_ru": {
              "main": "и Нанак всегда воздаёт хвалу только Ему. ||4||19||32||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4095,
      "rahao_verse_id": 48860,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48854,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48855,
          "is_rahao": false,
          "gurmukhi": "ਰੋਵਨਹਾਰੀ ਰੋਜੁ ਬਨਾਇਆ ॥",
          "roman": "rovanhārī roj banāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਸੇ ਸੰਬੰਧੀ ਦੇ ਮਰਨ ਤੇ ਮਾਇਕ ਸੰਬੰਧਾਂ ਦੇ ਕਾਰਨ ਹੀ) ਰੋਣ ਵਾਲੀ ਇਸਤ੍ਰੀ (ਰੋਣ ਨੂੰ) ਹਰ ਰੋਜ਼ ਦਾ ਨੇਮ ਬਣਾਈ ਰੱਖਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Женщина, которая плачет, из-за мирских привязанностей при смерти близкого сделала плач своим ежедневным обычаем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48856,
          "is_rahao": false,
          "gurmukhi": "ਬਲਨ ਬਰਤਨ ਕਉ ਸਨਬੰਧੁ ਚਿਤਿ ਆਇਆ ॥",
          "roman": "balan bartan kau sanbandh chit āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਉਸ ਨੂੰ ਵਿਛੁੜੇ ਸੰਬੰਧੀ ਦੇ ਨਾਲ) ਵਰਤਣ-ਵਿਹਾਰ ਦਾ ਸੰਬੰਧ ਚੇਤੇ ਆਉਂਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что ей всё вспоминается связь житейских отношений с тем родственником, который ушёл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48857,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝਿ ਬੈਰਾਗੁ ਕਰੇ ਜੇ ਕੋਇ ॥",
          "roman": "būjh bērāg karē jē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਕੋਈ ਪ੍ਰਾਣੀ (ਇਹ) ਸਮਝ ਕੇ (ਕਿ ਇਹ ਮਾਇਕ ਸੰਬੰਧ ਸਦਾ ਕਾਇਮ ਨਹੀਂ ਰਹਿ ਸਕਦੇ ਆਪਣੇ ਅੰਦਰ) ਨਿਰਮੋਹਤਾ ਪੈਦਾ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Но если кто-то, поняв, что эти мирские связи не могут оставаться вечными, взрастит в себе непривязанность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48858,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਫਿਰਿ ਸੋਗੁ ਨ ਹੋਇ ॥੧॥",
          "roman": "janam maraṇ phir sog na hoi 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਸ ਨੂੰ (ਕਿਸੇ ਦੇ) ਜਨਮ (ਦੀ ਖ਼ੁਸ਼ੀ, ਤੇ, ਕਿਸੇ ਦੇ) ਮਰਨ ਦਾ ਗ਼ਮ ਨਹੀਂ ਵਿਆਪਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда его уже не охватывает ни радость от чьего-то рождения, ни горе от чьей-то смерти. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48859,
          "is_rahao": true,
          "gurmukhi": "ਬਿਖਿਆ ਕਾ ਸਭੁ ਧੰਧੁ ਪਸਾਰੁ ॥",
          "roman": "bikhiā kā sabh dhandh pasār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ) ਮਾਇਆ ਦਾ ਹੀ ਸਾਰਾ ਧੰਧਾ ਹੈ, ਮਾਇਆ ਦਾ ਹੀ ਸਾਰਾ ਖਿਲਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В мире всё это — лишь суета майи, весь этот размах тоже майя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48860,
          "is_rahao": true,
          "gurmukhi": "ਵਿਰਲੈ ਕੀਨੋ ਨਾਮ ਅਧਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "virlē kīno nām adhār 1 rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਵਿਰਲੇ ਮਨੁੱਖ ਨੇ (ਮਾਇਆ ਦਾ ਆਸਰਾ ਛੱਡ ਕੇ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ ਲਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек, оставив опору на майю, сделал себе опорой Имя Бога. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48861,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਬਿਧਿ ਮਾਇਆ ਰਹੀ ਬਿਆਪਿ ॥",
          "roman": "tribidh māiā rahī biāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਤ੍ਰਿਗੁਣੀ ਮਾਇਆ (ਸਾਰੇ ਜੀਵਾਂ ਉਤੇ ਆਪਣਾ) ਜ਼ੋਰ ਪਾ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эта трёхкачественная майя держит всех существ под своей властью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48862,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਲਪਟਾਨੋ ਤਿਸੁ ਦੂਖ ਸੰਤਾਪ ॥",
          "roman": "jo lapaṭāno tis dūkh santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ (ਇਸ ਮਾਇਆ ਨੂੰ) ਚੰਬੜਿਆ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ (ਅਨੇਕਾਂ) ਕਲੇਸ਼ ਵਿਆਪਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Кто прилепился к этой майе, того постоянно поражают страдания и муки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48863,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਹੀ ਬਿਨੁ ਨਾਮ ਧਿਆਏ ॥",
          "roman": "sukh nāhī bin nām dhiāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਸੁਖ ਨਹੀਂ ਹੋ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Бога покоя быть не может."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48864,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਨਿਧਾਨੁ ਬਡਭਾਗੀ ਪਾਏ ॥੨॥",
          "roman": "nām nidhān baḍbhāgī pāē 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵਿਰਲਾ ਕਿਸਮਤ ਵਾਲਾ ਮਨੁੱਖ ਹੀ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ ਹਾਸਲ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий счастливец обретает сокровище Имени. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48865,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਵਾਂਗੀ ਸਿਉ ਜੋ ਮਨੁ ਰੀਝਾਵੈ ॥",
          "roman": "savāṅgī siu jo man rījhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਕਿਸੇ ਸਾਂਗ-ਧਾਰੀ ਨਾਲ ਪਿਆਰ ਪਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто привязывается сердцем к человеку в маске, к разыгрывающему роль,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48866,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਵਾਗਿ ਉਤਾਰਿਐ ਫਿਰਿ ਪਛੁਤਾਵੈ ॥",
          "roman": "savāg utāri-ē phir pachhutāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਹ ਸਾਂਗ ਲਾਹ ਦਿੱਤਾ ਜਾਂਦਾ ਹੈ ਤਦੋਂ ਉਹ (ਪਿਆਰ ਪਾਣ ਵਾਲਾ ਅਸਲੀਅਤ ਵੇਖ ਕੇ) ਪਛੁਤਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, когда маску снимают, увидев действительность, потом раскаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48867,
          "is_rahao": false,
          "gurmukhi": "ਮੇਘ ਕੀ ਛਾਇਆ ਜੈਸੇ ਬਰਤਨਹਾਰ ॥",
          "roman": "mēgh kī chhāiā jēsē bartanahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਬੱਦਲਾਂ ਦੀ ਛਾਂ (ਨੂੰ ਟਿਕਵੀਂ ਛਾਂ ਸਮਝ ਕੇ ਉਸ) ਨਾਲ ਵਰਤਣ ਕਰਨਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как если бы кто-то захотел пользоваться тенью облаков, приняв её за устойчивую тень,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48868,
          "is_rahao": false,
          "gurmukhi": "ਤੈਸੋ ਪਰਪੰਚੁ ਮੋਹ ਬਿਕਾਰ ॥੩॥",
          "roman": "tēsō parpanch moh bikār 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਹੀ ਇਹ ਜਗਤ-ਪਸਾਰਾ ਮੋਹ ਆਦਿਕ ਵਿਕਾਰਾਂ ਦਾ ਮੂਲ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так и этот мирской размах — корень привязанности и прочих пороков. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48869,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਵਸਤੁ ਜੇ ਪਾਵੈ ਕੋਇ ॥",
          "roman": "ēk vast jē pāvē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ ਪ੍ਰਾਪਤ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек обретёт единую драгоценность — сокровище Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48870,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਕਾਜੁ ਤਾਹੀ ਕਾ ਹੋਇ ॥",
          "roman": "pūraṇ kāj tāhī kā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਦਾ ਹੀ (ਜੀਵਨ ਦਾ ਅਸਲ) ਕੰਮ ਕਿਸੇ ਸਿਰੇ ਚੜ੍ਹਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "только у него и завершается подлинное дело жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48871,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਜਿਨਿ ਪਾਇਆ ਨਾਮੁ ॥",
          "roman": "gur prasād jin pāiā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹਾਸਲ ਕਰ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто по милости Гуру обрёл Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48872,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਇਆ ਸੋ ਪਰਵਾਨੁ ॥੪॥੨੦॥੩੩॥",
          "roman": "nānak āiā so parvān 4 20 33",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਗਤ ਵਿਚ ਜੰਮਿਆ ਉਹੀ ਮਨੁੱਖ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਕਬੂਲ ਹੁੰਦਾ ਹੈ ॥੪॥੨੦॥੩੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только тот, придя в этот мир, оказывается принятым и здесь, и там. 4. 20. 33."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4096,
      "rahao_verse_id": 48879,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48873,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48874,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਨਿੰਦਾ ਜੋਨੀ ਭਵਨਾ ॥",
          "roman": "sant kī nindā jonī bhavnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਗੁਰਮੁਖ ਦੇ ਆਚਰਨ ਉਤੇ ਅਣਹੋਏ ਦੂਸ਼ਣ ਲਾਣ ਨਾਲ ਮਨੁੱਖ ਕਈ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто возводит ложные обвинения на поведение гурмукха, тот скитается по множеству рождений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48875,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਨਿੰਦਾ ਰੋਗੀ ਕਰਨਾ ॥",
          "roman": "sant kī nindā rogī karnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਉਹ ਮਨੁੱਖ ਉਹਨਾਂ ਦੂਸ਼ਣਾਂ ਦਾ ਜ਼ਿਕਰ ਕਰਦਾ ਕਰਦਾ ਆਪ ਹੀ ਆਪਣੇ ਆਪ ਨੂੰ ਉਹਨਾਂ ਦੂਸ਼ਣਾਂ ਦਾ ਸ਼ਿਕਾਰ ਬਣਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "потому что, постоянно повторяя эти обвинения, сам становится жертвой тех самых пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48876,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਨਿੰਦਾ ਦੂਖ ਸਹਾਮ ॥",
          "roman": "sant kī nindā dūkh sahām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਦਾ ਨਤੀਜਾ ਇਹ ਨਿਕਲਦਾ ਹੈ ਕਿ ਇਥੇ ਜਗਤ ਵਿਚ ਉਹ ਮਨੁੱਖ ਉਸ) ਨਿੰਦਾ ਦੇ ਕਾਰਨ (ਕਈ ਆਤਮਕ) ਦੁੱਖ ਸਹਾਰਦਾ ਰਹਿੰਦਾ ਹੈ."
            },
            "sahib_singh_ru": {
              "main": "и из-за этой клеветы в этом мире он терпит многие духовные страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48877,
          "is_rahao": false,
          "gurmukhi": "ਡਾਨੁ ਦੈਤ ਨਿੰਦਕ ਕਉ ਜਾਮ ॥੧॥",
          "roman": "ḍān dēt nindak kau jām 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਅਗਾਂਹ ਪਰਲੋਕ ਵਿਚ ਭੀ) ਨਿੰਦਕ ਨੂੰ ਜਮਰਾਜ ਸਜ਼ਾ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "А далее и в мире ином клеветника наказывает Яма. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48878,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਕਰਹਿ ਜੋ ਬਾਦੁ ॥",
          "roman": "santsang karah jo bād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਨਾਲ ਝਗੜਾ ਖੜਾ ਕਰੀ ਰੱਖਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто постоянно затевают ссору с преданным Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48879,
          "is_rahao": true,
          "gurmukhi": "ਤਿਨ ਨਿੰਦਕ ਨਾਹੀ ਕਿਛੁ ਸਾਦੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tin nindak nāhī kichh sād 1 rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨਿੰਦਕਾਂ ਨੂੰ ਜੀਵਨ ਦਾ ਕੋਈ ਆਤਮਕ ਆਨੰਦ ਨਹੀਂ ਆਉਂਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "такие клеветники не знают никакой духовной радости жизни. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48880,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਕੀ ਨਿੰਦਾ ਕੰਧੁ ਛੇਦਾਵੈ ॥",
          "roman": "bhagat kī nindā kandh chhēdāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਗੁਰਮੁਖ ਉੱਤੇ ਚਿੱਕੜ ਸੁੱਟਣ ਨਾਲ ਮਨੁੱਖ ਆਪਣੇ ਹੀ ਸਰੀਰ ਨੂੰ ਉਹਨਾਂ ਦੂਸ਼ਣਾਂ ਨਾਲ ਪ੍ਰੋ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек бросает грязь в гурмукха, он как будто пронзает ими собственное тело,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48881,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਕੀ ਨਿੰਦਾ ਨਰਕੁ ਭੁੰਚਾਵੈ ॥",
          "roman": "bhagat kī nindā narak bhuṅchāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਗੁਰਮੁਖ ਦੀ ਨਿੰਦਾ (ਨਿੰਦਾ ਕਰਨ ਵਾਲੇ ਨੂੰ) ਨਰਕ (ਦਾ ਦੁੱਖ) ਭੋਗਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "так клевета на гурмукха заставляет клевещущего испытать муки ада,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48882,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਕੀ ਨਿੰਦਾ ਗਰਭ ਮਹਿ ਗਲੈ ॥",
          "roman": "bhagat kī nindā garabh meh galē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨਿੰਦਾ ਦੇ ਕਾਰਨ ਮਨੁੱਖ ਅਨੇਕਾਂ ਜੂਨਾਂ ਵਿਚ ਗਲਦਾ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "из-за этой клеветы человек истлевает, переходя через многие рождения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48883,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਕੀ ਨਿੰਦਾ ਰਾਜ ਤੇ ਟਲੈ ॥੨॥",
          "roman": "bhagat kī nindā rāj tē ṭalē 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਉੱਚੀ ਆਤਮਕ ਪਦਵੀ ਤੋਂ ਹੇਠਾਂ ਡਿੱਗ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и падает вниз с высокой духовной ступени. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48884,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕੀ ਗਤਿ ਕਤਹੂ ਨਾਹਿ ॥",
          "roman": "nindak kī gat katehū nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੂਜਿਆਂ ਉੱਤੇ ਸਦਾ ਚਿੱਕੜ ਸੁੱਟਣ ਵਾਲੇ ਮਨੁੱਖ ਦੀ ਆਪਣੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਕਦੇ ਭੀ ਨਹੀਂ ਬਣਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "У того, кто всё время бросает грязь в других, никогда не складывается высокая духовная участь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48885,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬੀਜਿ ਆਪੇ ਹੀ ਖਾਹਿ ॥",
          "roman": "āp bīj āpē hī khāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ ਨਿੰਦਕ ਨਿੰਦਾ ਦਾ ਇਹ ਮਾੜਾ ਬੀਜ) ਬੀਜ ਕੇ ਆਪ ਹੀ ਉਸ ਦਾ ਫਲ ਖਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "посеяв это дурное семя клеветы, он сам и пожинает его плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48886,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰ ਜਾਰ ਜੂਆਰ ਤੇ ਬੁਰਾ ॥",
          "roman": "chor jār jūār tē burā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿੰਦਾ ਕਰਨ ਵਾਲਾ ਮਨੁੱਖ ਚੋਰ ਨਾਲੋਂ ਵਿਭਚਾਰੀ ਨਾਲੋਂ ਜੂਆਰੀਏ ਨਾਲੋਂ ਭੀ ਭੈੜਾ ਸਾਬਤ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Клеветник оказывается хуже и вора, и распутника, и игрока,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48887,
          "is_rahao": false,
          "gurmukhi": "ਅਣਹੋਦਾ ਭਾਰੁ ਨਿੰਦਕਿ ਸਿਰਿ ਧਰਾ ॥੩॥",
          "roman": "aṇhoḍā bhār nindak sir dharā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਨਿੰਦਕ ਨੇ ਆਪਣੇ ਸਿਰ ਉਤੇ ਸਦਾ ਉਹਨਾਂ ਵਿਕਾਰਾਂ ਦਾ ਭਾਰ ਚੁੱਕਿਆ ਹੁੰਦਾ ਹੈ ਜੋ ਪਹਿਲਾਂ ਉਸ ਦੇ ਅੰਦਰ ਨਹੀਂ ਸਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потому что он несёт на своей голове тяжесть тех пороков, которых прежде в нём не было. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48888,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੇ ਭਗਤ ਨਿਰਵੈਰ ॥",
          "roman": "pārbrahm kē bhagat nirvēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਕਿਸੇ ਨਾਲ ਭੀ ਵੈਰ ਨਹੀਂ ਰੱਖਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Преданные Всевышнего ни с кем не держат вражды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48889,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਨਿਸਤਰੈ ਜੋ ਪੂਜੈ ਪੈਰ ॥",
          "roman": "so nistarē jo pūjē pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਭੀ ਮਨੁੱਖ ਉਹਨਾਂ ਦੀ ਸਰਨ ਆਉਂਦਾ ਹੈ ਉਹ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всякий, кто приходит под их покров, переправляется через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48890,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖਿ ਨਿੰਦਕੁ ਭੋਲਾਇਆ ॥",
          "roman": "ād purakh nindak bholāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਨਿੰਦਕ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਹੀ ਨਿੰਦਕ ਨੂੰ ਗ਼ਲਤ ਰਸਤੇ ਪਾ ਰੱਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но разве это во власти клеветника? Сам Бог сбил его на ложный путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48891,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਿਰਤੁ ਨ ਜਾਇ ਮਿਟਾਇਆ ॥੪॥੨੧॥੩੪॥",
          "roman": "nānak kirat na jāi miṭāiā 4 21 34",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਿਛਲੇ ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਕੀਤੇ ਹੋਏ ਨਿੰਦਾ ਦੇ ਕਰਮਾਂ ਦੇ ਸੰਸਕਾਰਾਂ ਦਾ ਢੇਰ ਉਸ ਪਾਸੋਂ ਆਪਣੇ ਉੱਦਮ ਨਾਲ ਮਿਟਾਇਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੪॥੨੧॥੩੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, накопленный груз прежних деяний клеветы за многие рождения не может быть стёрт его собственными усилиями. 4. 21. 34."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4097,
      "rahao_verse_id": 48898,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48892,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48893,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਬੇਦ ਅਰੁ ਨਾਦ ॥",
          "roman": "nām hamārē bēd ar nād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੋਂ ਗੁਰੂ ਨੇ ਮੇਰੇ ਅੰਦਰ ਹਰਿ-ਨਾਮ ਦ੍ਰਿੜ੍ਹ ਕੀਤਾ ਹੈ, ਤਦੋਂ ਤੋਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਵੇਦ (ਸ਼ਾਸਤ੍ਰ ਆਦਿਕਾਂ ਦੀ ਚਰਚਾ ਹੈ) ਅਤੇ (ਜੋਗੀਆਂ ਦਾ ਸਿੰਙੀ ਆਦਿਕ) ਵਜਾਣਾ ਹੋ ਚੁਕਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "С тех пор как Гуру утвердил во мне Имя Хари, Имя Бога стало для меня и Ведами, и звучанием рога аскетов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48894,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਪੂਰੇ ਕਾਜ ॥",
          "roman": "nām hamārē pūrē kāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮੇਰੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚਾੜ੍ਹਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога доводит до завершения все мои дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48895,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਪੂਜਾ ਦੇਵ ॥",
          "roman": "nām hamārē pūjā dēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਹਰਿ-ਨਾਮ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਦੇਵ-ਪੂਜਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари стало для меня поклонением божествам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48896,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਗੁਰ ਕੀ ਸੇਵ ॥੧॥",
          "roman": "nām hamārē gur kī sēv 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ ਨਾਮ ਸਿਮਰਨਾ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਗੁਰੂ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਨੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и памятование Имени Хари — это для меня служение и преданность Гуру. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48897,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਦ੍ਰਿੜਿਓ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "gur pūrē driṛhiō har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ (ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪੱਕਾ ਟਿਕਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру прочно утвердил в моём сердце Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48898,
          "is_rahao": true,
          "gurmukhi": "ਸਭ ਤੇ ਊਤਮੁ ਹਰਿ ਹਰਿ ਕਾਮੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sabh tē ūtam har har kām 1 rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਮੈਨੂੰ ਨਿਸ਼ਚਾ ਹੋ ਗਿਆ ਹੈ ਕਿ) ਸਭਨਾਂ ਕੰਮਾਂ ਨਾਲੋਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਦਾ ਕੰਮ ਸ੍ਰੇਸ਼ਟ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь я твёрдо знаю, что из всех дел выше всего — труд памятования Имени Бога. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48899,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਮਜਨ ਇਸਨਾਨੁ ॥",
          "roman": "nām hamārē majan isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੇ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਨਾਮ ਦ੍ਰਿੜ੍ਹ ਕਰ ਦਿੱਤਾ ਹੈ, ਹੁਣ) ਹਰਿ-ਨਾਮ ਜਪਣਾ ਹੀ ਮੇਰੇ ਲਈ ਪੁਰਬਾਂ ਸਮੇ ਤੀਰਥ-ਇਸ਼ਨਾਨ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь повторение Имени Хари для меня и есть омовение в святых местах в дни праздников,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48900,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਪੂਰਨ ਦਾਨੁ ॥",
          "roman": "nām hamārē pūran dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਜਪਣਾ ਹੀ ਮੇਰੇ ਲਈ (ਤੀਰਥਾਂ ਤੇ ਜਾ ਕੇ) ਸਭ ਕੁਝ (ਬ੍ਰਾਹਮਣਾਂ ਨੂੰ) ਦਾਨ ਕਰ ਦੇਣਾ-ਇਹ ਭੀ ਮੇਰੇ ਵਾਸਤੇ ਨਾਮ-ਸਿਮਰਨ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "повторение Имени Хари для меня и есть совершенное подаяние, словно отдать всё на тиртхах брахманам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48901,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਤੇ ਸਗਲ ਪਵੀਤ ॥",
          "roman": "nām lēt tē sagal pavīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਨਾਮ ਜਪਦੇ ਹਨ ਉਹ ਸਾਰੇ ਸੁੱਚੇ ਆਚਰਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все, кто повторяют Имя, становятся людьми чистого поведения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48902,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਮੇਰੇ ਭਾਈ ਮੀਤ ॥੨॥",
          "roman": "nām japat mērē bhāī mīt 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਣ ਵਾਲੇ ਹੀ ਮੇਰੇ ਭਰਾ ਹਨ ਮੇਰੇ ਮਿੱਤਰ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и те, кто повторяют Имя, — мои братья и мои друзья. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48903,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਸਉਣ ਸੰਜੋਗ ॥",
          "roman": "nām hamārē sauṇ sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਾਰਾਂ-ਵਿਹਾਰਾਂ ਦੀ ਸਫਲਤਾ ਵਾਸਤੇ ਲੋਕ) ਸਗਨ (ਵਿਚਾਰਦੇ ਹਨ) ਮੁਹੂਰਤ (ਕਢਾਂਦੇ ਹਨ) ਪਰ ਮੇਰੇ ਵਾਸਤੇ ਤਾਂ ਹਰਿ-ਨਾਮ ਹੀ ਸਭ ਕੁਝ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Люди ищут добрые знамения и выбирают благоприятный миг для успеха дел, но для меня всем этим является Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48904,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਤ੍ਰਿਪਤਿ ਸੁਭੋਗ ॥",
          "roman": "nām hamārē tripat subhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ ਦੇ ਸੁਆਦਲੇ ਪਦਾਰਥਾਂ ਨੂੰ ਖਾ ਖਾ ਕੇ ਰੱਜਣਾ-(ਇਹ ਸਾਰਾ ਸੁਆਦ) ਮੇਰੇ ਵਾਸਤੇ ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Насыщение вкусными мирскими яствами — весь этот вкус для меня заключён в памятовании Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48905,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਸਗਲ ਆਚਾਰ ॥",
          "roman": "nām hamārē sagal āchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ-ਜਾਤ੍ਰਾ ਆਦਿਕ ਮਿਥੇ ਹੋਏ) ਸਾਰੇ ਧਰਮ-ਕਰਮ ਮੇਰੇ ਵਾਸਤੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Все предписанные религиозные обряды, вроде паломничеств, для меня заключены в Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48906,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਹਮਾਰੈ ਨਿਰਮਲ ਬਿਉਹਾਰ ॥੩॥",
          "roman": "nām hamārē nirmal biuhār 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਮੇਰੇ ਲਈ ਪਵਿੱਤਰ ਕਾਰ-ਵਿਹਾਰ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — вот для меня чистое и святое поведение в делах. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48907,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਵਸਿਆ ਪ੍ਰਭੁ ਏਕੁ ॥",
          "roman": "jā kē man vasiā prabh ēk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਆ ਵੱਸਿਆ ਹੈ (ਉਹ ਭਾਗਾਂ ਵਾਲਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Благословен тот человек, в чьём сердце поселился один лишь Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48908,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਜਨਾ ਕੀ ਹਰਿ ਹਰਿ ਟੇਕ ॥",
          "roman": "sagal janā kī har har ṭēk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਹੀ ਸਾਰੇ ਜੀਵਾਂ ਦਾ ਸਹਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог и Его Имя — опора для всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48909,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਨਾਨਕ ਹਰਿ ਗੁਣ ਗਾਉ ॥",
          "roman": "man tan nānak har guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਹੜਾ ਮਨੁੱਖ ਮਨੋਂ ਤਨੋਂ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ (ਉਹ ਭਾਗਾਂ ਵਾਲਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, благословен тот, кто всем сердцем и всем телом воспевает хвалу Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48910,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਿਸੁ ਦੇਵੈ ਨਾਉ ॥੪॥੨੨॥੩੫॥",
          "roman": "sādhsang jis dēvē nāu 4 22 35",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਕੰਮ ਉਹੀ ਮਨੁੱਖ ਕਰਦਾ ਹੈ) ਜਿਸ ਨੂੰ ਪਰਮਾਤਮਾ ਸਾਧ ਸੰਗਤ ਵਿਚ ਰੱਖ ਕੇ ਆਪਣੇ ਨਾਮ ਦੀ ਦਾਤ ਦੇਂਦਾ ਹੈ ॥੪॥੨੨॥੩੫॥"
            },
            "sahib_singh_ru": {
              "main": "но это делает лишь тот, кому Бог, удерживая его в садхсанге, дарует Своё Имя. 4. 22. 35."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
