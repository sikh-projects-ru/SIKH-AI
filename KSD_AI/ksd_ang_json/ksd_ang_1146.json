  "shabads": [
    {
      "shabad_id": 4098,
      "rahao_verse_id": 48917,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48911,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48912,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਧਨ ਕਉ ਤੁਮ ਦੇਵਹੁ ਧਨਾ ॥",
          "roman": "nirdhan kau tum devh dhanā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ (ਜਿਸ) ਕੰਗਾਲ ਨੂੰ (ਆਪਣਾ ਨਾਮ-) ਧਨ ਦੇਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Тому бедняку, которому Ты даёшь богатство Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48913,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪਾਪ ਜਾਹਿ ਨਿਰਮਲ ਮਨਾ ॥",
          "roman": "anik pāp jāh nirmal manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅਨੇਕਾਂ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਸ ਦਾ ਮਨ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у него уходят многие грехи, его ум становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48914,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਪੂਰਨ ਕਾਮ ॥",
          "roman": "sagal manorath pūran kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀਆਂ ਸਾਰੀਆਂ ਮੰਗਾਂ ਪੂਰੀਆਂ ਹੋ ਜਾਂਦੀਆਂ ਹਨ, ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все его желания исполняются, все его дела завершаются успешно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48915,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਅਪੁਨੇ ਕਉ ਦੇਵਹੁ ਨਾਮ ॥੧॥",
          "roman": "bhagat apune kau devhu nām ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਆਪਣੇ ਭਗਤ ਨੂੰ (ਆਪ ਹੀ) ਆਪਣਾ ਨਾਮ ਦੇਂਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Своему преданному Ты Сам даруешь Своё Имя ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48916,
          "is_rahao": true,
          "gurmukhi": "ਸਫਲ ਸੇਵਾ ਗੋਪਾਲ ਰਾਇ ॥",
          "roman": "safal sevā Gopāl rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਕ-ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਦੀ ਭਗਤੀ (ਸਦਾ) ਫਲ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служение Господу, Царю-Попечителю мироздания, всегда приносит плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48917,
          "is_rahao": true,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨਹਾਰ ਸੁਆਮੀ ਤਾ ਤੇ ਬਿਰਥਾ ਕੋਇ ਨ ਜਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karan karāvanhār suāmī tā te birthā koi na jāi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਾਲਕ-ਪ੍ਰਭੂ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲਾ ਹੈ ਤੇ ਜੀਵਾਂ ਪਾਸੋਂ ਸਭ ਕੁਝ ਕਰਾ ਸਕਦਾ ਹੈ, ਉਸ ਦੇ ਦਰ ਤੋਂ ਕੋਈ ਜੀਵ ਖ਼ਾਲੀ ਨਹੀਂ ਜਾਂਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот Владыка-Господь способен всё совершить и может всё совершать через живых существ; от Его дверей никто не уходит с пустыми руками ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48918,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੀ ਕਾ ਪ੍ਰਭ ਖੰਡਹੁ ਰੋਗੁ ॥",
          "roman": "rogī kā prabh khaṇḍh rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂ (ਆਪਣਾ ਨਾਮ-ਦਾਰੂ ਦੇ ਕੇ) ਰੋਗੀ ਦਾ ਰੋਗ ਨਾਸ ਕਰ ਦੇਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Ты, давая лекарство Имени, уничтожаешь болезнь больного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48919,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੀਏ ਕਾ ਮਿਟਾਵਹੁ ਪ੍ਰਭ ਸੋਗੁ ॥",
          "roman": "dukhīe kā miṭāvh prabh sog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਖੀਏ ਦਾ ਗ਼ਮ ਮਿਟਾ ਦੇਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "устраняешь скорбь страдающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48920,
          "is_rahao": false,
          "gurmukhi": "ਨਿਥਾਵੇ ਕਉ ਤੁਮੑ ਥਾਨਿ ਬੈਠਾਵਹੁ ॥",
          "roman": "nithāve kau tumh thān bēṭhāvh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਕਿਤੇ ਭੀ ਸਹਾਰਾ ਨਹੀਂ ਮਿਲਦਾ ਤੂੰ ਉਸ ਨੂੰ (ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ ਕੇ) ਇੱਜ਼ਤ ਵਾਲੀ ਥਾਂ ਤੇ ਬਿਠਾ ਦੇਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "того, кто нигде не находит опоры, Ты, даруя Своё Имя, усаживаешь на почётное место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48921,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਅਪਨੇ ਕਉ ਭਗਤੀ ਲਾਵਹੁ ॥੨॥",
          "roman": "dās apne kau bhagtī lāvhu ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਤੂੰ ਆਪ ਹੀ ਆਪਣੀ ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Своего слугу Ты Сам присоединяешь к Своему почитанию ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48922,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਾਣੇ ਕਉ ਪ੍ਰਭ ਦੇਤੋ ਮਾਨੁ ॥",
          "roman": "nimāṇe kau prabh deto mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਕਿਤੇ ਭੀ ਆਦਰ-ਸਤਕਾਰ ਨਹੀਂ ਮਿਲਦਾ, ਉਸ ਨੂੰ ਤੂੰ (ਆਪਣੀ ਭਗਤੀ ਦੀ ਦਾਤ ਦੇ ਕੇ ਹਰ ਥਾਂ) ਇੱਜ਼ਤ ਬਖ਼ਸ਼ਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Тому человеку, кто нигде не получает почёта и уважения, Ты, даруя дар Своего почитания, везде даёшь честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48923,
          "is_rahao": false,
          "gurmukhi": "ਮੂੜ ਮੁਗਧੁ ਹੋਇ ਚਤੁਰ ਸੁਗਿਆਨੁ ॥",
          "roman": "mūṛh mugadh hoi chatur sugiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰੀ ਭਗਤੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਹਾਂ ਮੂਰਖ ਮਨੁੱਖ ਸਿਆਣਾ ਹੋ ਜਾਂਦਾ ਹੈ ਗਿਆਨਵਾਨ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря благодати Твоего почитания даже великий глупец становится разумным и знающим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48924,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਭਇਆਨ ਕਾ ਭਉ ਨਸੈ ॥",
          "roman": "sagal bhiān kā bhau nasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਮਨ ਵਿਚੋਂ) ਸਾਰੇ ਡਰਾਣ ਵਾਲਿਆਂ ਦਾ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Из его ума исчезает страх перед всем, что пугает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48925,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਅਪਨੇ ਕੈ ਹਰਿ ਮਨਿ ਬਸੈ ॥੩॥",
          "roman": "jan apne kē Har man basē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪਣੇ ਸੇਵਕ ਦੇ (ਸਦਾ) ਮਨ ਵਿਚ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В уме Своего слуги всегда обитает Хари ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48926,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭ ਸੂਖ ਨਿਧਾਨ ॥",
          "roman": "Pārbrahm prabh sūkh nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮੇਸਰ ਪ੍ਰਭੂ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Всевышний Господь — сокровищница всех радостей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48927,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਗਿਆਨੁ ਹਰਿ ਅੰਮ੍ਰਿਤ ਨਾਮ ॥",
          "roman": "tat giān Har aṃmrit nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦੇਂਦਾ ਹੈ ਰਾਜ਼ ਸਮਝਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его нектарное Имя даёт понимание духовной жизни и раскрывает сущность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48928,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਸੰਤ ਟਹਲੈ ਲਾਏ ॥",
          "roman": "kar kirpā sant ṭahlē lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਉਹ ਆਪ ਸੰਤ ਜਨਾਂ ਦੀ ਸੇਵਾ ਵਿਚ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которого Он по милости Сам присоединяет к служению святым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48929,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧੂ ਸੰਗਿ ਸਮਾਏ ॥੪॥੨੩॥੩੬॥",
          "roman": "Nānak sādhū saṅg samāe ॥4॥23॥36॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ (ਸਦਾ) ਸਾਧ ਸੰਗਤ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੨੩॥੩੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такой человек всегда пребывает в Садх Сангат ॥4॥23॥36॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4099,
      "rahao_verse_id": 48936,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48930,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48931,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਹਰਿ ਮਨਿ ਵਸੈ ॥",
          "roman": "sant maṇḍal mah Har man vasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ (ਰਿਹਾਂ) ਪਰਮਾਤਮਾ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ (ਪਰਗਟ ਹੋ ਪੈਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "В Садх Сангат Хари входит и поселяется в уме человека, становится явным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48932,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਦੁਰਤੁ ਸਭੁ ਨਸੈ ॥",
          "roman": "sant maṇḍal mah durat sabh nasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਟਿਕਿਆਂ (ਹਿਰਦੇ ਵਿਚੋਂ) ਹਰੇਕ ਕਿਸਮ ਦਾ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Садх Сангат, всякий грех уходит из сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48933,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "sant maṇḍal mah nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ (ਮਨੁੱਖ ਦੀ) ਜੀਵਨ-ਜੁਗਤਿ ਵਿਕਾਰਾਂ ਦੀ ਮੈਲ ਤੋਂ ਸਾਫ਼ ਰੱਖਣ ਵਾਲੀ ਬਣ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя в Садх Сангат, образ жизни человека становится таким, что сохраняет его чистым от скверны пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48934,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਹੋਇ ਏਕ ਪਰੀਤਿ ॥੧॥",
          "roman": "santsaṅg hoi ek parīt ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਦੀ ਬਰਕਤਿ ਨਾਲ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਪਿਆਰ (ਹਿਰਦੇ ਵਿਚ ਪੈਦਾ) ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и по благодати Садх Сангат в сердце рождается любовь к Единому Богу ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48935,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਮੰਡਲੁ ਤਹਾ ਕਾ ਨਾਉ ॥",
          "roman": "sant maṇḍal tahā kā nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਉਸ ਥਾਂ ਦਾ ਨਾਮ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Садх Сангат — это имя того места,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48936,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੇਵਲ ਗੁਣ ਗਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Pārbrahm keval guṇ gāu ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਹੁੰਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "где звучит только хвала Всевышнему ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48937,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਜਨਮ ਮਰਣੁ ਰਹੈ ॥",
          "roman": "sant maṇḍal mah janam maraṇ rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ ਜਨਮ ਮਰਨ (ਦਾ ਗੇੜ) ਮੁੱਕ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Садх Сангат, человек освобождается от круговорота рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48938,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਜਮੁ ਕਿਛੂ ਨ ਕਹੈ ॥",
          "roman": "sant maṇḍal mah jam kichhū na kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ ਜਮਰਾਜ ਕੋਈ ਡਰਾਵਾ ਨਹੀਂ ਦੇ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "пребывая в Садх Сангат, он уже не может быть устрашён Ямараджем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48939,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਹੋਇ ਨਿਰਮਲ ਬਾਣੀ ॥",
          "roman": "santsaṅg hoi nirmal bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਧ ਸੰਗਤ ਵਿਚ (ਜੀਵਨ ਨੂੰ) ਪਵਿੱਤਰ ਕਰਨ ਵਾਲੀ ਬਾਣੀ ਦਾ ਉਚਾਰਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "потому что в Садх Сангат произносится очищающая Бани,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48940,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਨਾਮੁ ਵਖਾਣੀ ॥੨॥",
          "roman": "sant maṇḍal mahi nām vakhāṇī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਥੇ) ਸਾਧ ਸੰਗਤ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਹੀ) ਉਚਾਰਿਆ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и там, в Садх Сангат, произносится Имя Всевышнего ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48941,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਕਾ ਨਿਹਚਲ ਆਸਨੁ ॥",
          "roman": "sant maṇḍal kā nihchal āsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਦਾ ਟਿਕਾਣਾ (ਐਸਾ ਹੈ ਕਿ ਉਥੇ ਟਿਕਣ ਵਾਲੇ ਵਿਕਾਰਾਂ ਦੇ ਹੱਲਿਆਂ ਤੋਂ) ਅਡੋਲ (ਰਹਿੰਦੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "Пристанище Садх Сангат таково, что пребывающие там остаются непоколебимыми перед натиском пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48942,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਪਾਪ ਬਿਨਾਸਨੁ ॥",
          "roman": "sant maṇḍal mah pāp bināsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਿਹਾਂ (ਸਾਰੇ) ਪਾਪਾਂ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а пребывая в Садх Сангат, все грехи уничтожаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48943,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਨਿਰਮਲ ਕਥਾ ॥",
          "roman": "sant maṇḍal mah nirmal kathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਹੁੰਦੀ ਰਹਿੰਦੀ ਹੈ ਜੋ (ਮਨੁੱਖ ਨੂੰ) ਵਿਕਾਰਾਂ ਦੀ ਮੈਲ ਤੋਂ ਬਚਾਈ ਰੱਖਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В Садх Сангат постоянно звучит хвала Богу, которая хранит человека от грязи пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48944,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਹਉਮੈ ਦੁਖ ਨਸਾ ॥੩॥",
          "roman": "santsaṅg haumē dukh nasā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ ਹਉਮੈ (ਤੋਂ ਪੈਦਾ ਹੋਣ ਵਾਲੇ ਸਾਰੇ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь в Садх Сангат, уходят все страдания, рождаемые Хоумэ ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48945,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਕਾ ਨਹੀ ਬਿਨਾਸੁ ॥",
          "roman": "sant maṇḍal kā nahī binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਦੇ ਵਾਯੂ-ਮੰਡਲ ਦਾ ਕਦੇ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Атмосфера Садх Сангат никогда не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48946,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਮਹਿ ਹਰਿ ਗੁਣਤਾਸੁ ॥",
          "roman": "sant maṇḍal mah Har guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਪਰਮਾਤਮਾ (ਸਦਾ) ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В Садх Сангат всегда пребывает Хари — сокровищница достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48947,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਮੰਡਲ ਠਾਕੁਰ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "sant maṇḍal ṭhākur bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਸਦਾ ਮਾਲਕ-ਪ੍ਰਭੂ ਦਾ ਨਿਵਾਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в Садх Сангат всегда находится обитель Господа-Владыки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48948,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਓਤਿ ਪੋਤਿ ਭਗਵਾਨੁ ॥੪॥੨੪॥੩੭॥",
          "roman": "Nānak ot pot bhagvān ॥4॥24॥37॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਭਗਵਾਨ-ਪ੍ਰਭੂ (ਸਾਧ ਸੰਗਤ ਵਿਚ) ਤਾਣੇ ਪੇਟੇ ਵਾਂਗ ਮਿਲਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੨੪॥੩੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Бог-Господь пронизывает Садх Сангат, как нити основы и утка ткань ॥4॥24॥37॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4100,
      "rahao_verse_id": 48955,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48949,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48950,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਕਵਨੁ ਜਾਂ ਰਾਖੈ ਆਪਿ ॥",
          "roman": "rog kavan jāṅ rākhē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪਰਮਾਤਮਾ ਆਪ (ਕਿਸੇ ਮਨੁੱਖ ਦੀ) ਰੱਖਿਆ ਕਰਦਾ ਹੈ, ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਰੋਗ ਵਿਆਪ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Когда Сам Бог хранит человека, никакая болезнь не может его поразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48951,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਹੋਇ ਨ ਦੂਖੁ ਸੰਤਾਪੁ ॥",
          "roman": "tis jan hoi na dūkh santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਦੁੱਖ ਕੋਈ ਕਲੇਸ਼ ਉਸ ਨੂੰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Такого человека не касается ни страдание, ни мучение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48952,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਊਪਰਿ ਪ੍ਰਭੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "jis ūpar prabh kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਮਿਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, на которого Бог изливает милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48953,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਊਪਰ ਤੇ ਕਾਲੁ ਪਰਹਰੈ ॥੧॥",
          "roman": "tis ūpar te kāl parharē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਿਰ ਉੱਤੋਂ ਉਹ ਮੌਤ (ਦਾ ਡਰ, ਆਤਮਕ ਮੌਤ) ਦੂਰ ਕਰ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он отводит от головы смерть — страх смерти, духовную смерть ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48954,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਸਖਾਈ ਹਰਿ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "sadā sakhāī Har Har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਹੀ ਮਨੁੱਖ ਦਾ) ਸਦਾ ਸਾਥੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари — вечный спутник человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48955,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਚੀਤਿ ਆਵੈ ਤਿਸੁ ਸਦਾ ਸੁਖੁ ਹੋਵੈ ਨਿਕਟਿ ਨ ਆਵੈ ਤਾ ਕੈ ਜਾਮੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jis chīt āvē tis sadā sukh hovē nikaṭ na āvē tā kē jām ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਚਿੱਤ ਵਿਚ ਹਰਿ-ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ, ਉਹ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ, ਜਮਰਾਜ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਆਉਂਦਾ (ਉਸ ਨੂੰ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਰਹਿੰਦਾ। ਆਤਮਕ ਮੌਤ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦੀ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём сознании поселяется Имя Хари, всегда вкушает духовную радость; Ям не приближается к нему, у него больше нет страха смерти. Духовная смерть к нему не подступает ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48956,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਇਹੁ ਨ ਸੋ ਤਬ ਕਿਨਹਿ ਉਪਾਇਆ ॥",
          "roman": "jab ih na so tab kineh upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਇਹ ਜੀਵ ਪਹਿਲਾਂ ਹੈ ਹੀ ਨਹੀਂ ਸੀ ਤਦੋਂ (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ) ਕਿਸ ਨੇ ਇਸ ਨੂੰ ਪੈਦਾ ਕਰ ਸਕਣਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "Когда этого существа ещё вовсе не было, кто, кроме Бога, мог бы создать его?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48957,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਮੂਲ ਤੇ ਕਿਆ ਪ੍ਰਗਟਾਇਆ ॥",
          "roman": "kavan mūl te kiā pragaṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖੋ,) ਕਿਸ ਮੁੱਢ ਤੋਂ (ਪਿਤਾ ਦੀ ਬੂੰਦ ਤੋਂ) ਇਸ ਦੀ ਕੈਸੀ ਸੋਹਣੀ ਸੂਰਤ (ਪਰਮਾਤਮਾ ਨੇ) ਬਣਾ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "Посмотри: из какого начала, из капли отца, Он создал такую прекрасную форму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48958,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਮਾਰਿ ਆਪਿ ਜੀਵਾਲੈ ॥",
          "roman": "āpeh mār āp jīvālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ (ਜੀਵ ਨੂੰ) ਮਾਰਦਾ ਹੈ ਆਪ ਹੀ ਪੈਦਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам убивает и Сам же оживляет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48959,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਭਗਤ ਕਉ ਸਦਾ ਪ੍ਰਤਿਪਾਲੈ ॥੨॥",
          "roman": "apne bhagat kau sadā pratipālē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪਣੇ ਭਗਤ ਦੀ ਸਦਾ ਰੱਖਿਆ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда хранит Своего преданного ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48960,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਿਛੁ ਜਾਣਹੁ ਤਿਸ ਕੈ ਹਾਥ ॥",
          "roman": "sabh kichh jāṇh tis kē hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸੱਚ ਜਾਣੋ ਕਿ ਹਰੇਕ ਤਾਕਤ ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਹੱਥਾਂ ਵਿਚ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Знайте истинно: всякая сила находится в руках того Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48961,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਮੇਰੋ ਅਨਾਥ ਕੋ ਨਾਥ ॥",
          "roman": "prabh mero anāth ko nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਿਆਰਾ ਪ੍ਰਭੂ ਨਿਖਸਮਿਆਂ ਦਾ ਖਸਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой любимый Бог — Владыка беззащитных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48962,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਭੰਜਨੁ ਤਾ ਕਾ ਹੈ ਨਾਉ ॥",
          "roman": "dukh bhañjan tā kā hē nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਨਾਮ ਹੀ ਹੈ 'ਦੁਖ-ਭੰਜਨੁ' (ਭਾਵ, ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Его Имя и есть Дух Бханджан — Разрушитель страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48963,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਪਾਵਹਿ ਤਿਸ ਕੇ ਗੁਣ ਗਾਉ ॥੩॥",
          "roman": "sukh pāvahi tis ke guṇ gāu ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ, ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰੇਂਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Пой Его достоинства — и обретёшь все радости ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48964,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਆਮੀ ਸੰਤਨ ਅਰਦਾਸਿ ॥",
          "roman": "suṇ suāmī santan ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੁਆਮੀ! ਤੂੰ ਆਪਣੇ ਸੰਤ ਜਨਾਂ ਦੀ ਅਰਜ਼ੋਈ ਸੁਣ ਲੈਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Ты слышишь мольбу Своих святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48965,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪ੍ਰਾਨ ਧਨੁ ਤੁਮੑਰੈ ਪਾਸਿ ॥",
          "roman": "jīu prān dhan tumhrē pās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨ ਆਪਣੀ ਜਿੰਦ ਆਪਣੇ ਪ੍ਰਾਣ ਆਪਣਾ ਧਨ ਸਭ ਕੁਝ ਤੇਰੇ ਹਵਾਲੇ ਕਰੀ ਰੱਖਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Святые вверяют Тебе свою жизнь, своё дыхание, всё своё богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48966,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਜਗੁ ਤੇਰਾ ਸਭ ਤੁਝਹਿ ਧਿਆਏ ॥",
          "roman": "ih jag terā sabh tujheh dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਹ ਸਾਰਾ ਜਗਤ ਤੇਰਾ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈ, ਸਾਰੀ ਲੁਕਾਈ ਤੇਰਾ ਹੀ ਧਿਆਨ ਧਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Весь этот мир сотворён Тобой, и всё человечество медитирует именно на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
