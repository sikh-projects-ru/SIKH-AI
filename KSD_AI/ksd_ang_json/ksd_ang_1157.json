{
  "ang": 1157,
  "shabads": [
    {
      "shabad_id": 4124,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49469,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮੁਨੀਸਰ ਮੋੁਨਿ ਮਹਿ ਰਹਤੇ ॥੭॥",
          "roman": "koṭ munīsar moun mahi rahte ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਵੱਡੇ ਵੱਡੇ ਮੁਨੀ ਮੋਨ ਧਾਰੀ ਰੱਖਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "кроры великих мудрецов пребывают в молчании ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49470,
          "is_rahao": false,
          "gurmukhi": "ਅਵਿਗਤ ਨਾਥੁ ਅਗੋਚਰ ਸੁਆਮੀ ॥ ਪੂਰਿ ਰਹਿਆ ਘਟ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "avigat nāth agochar suāmī ॥ pūr rahiā ghaṭ antarjāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਡਾ ਉਹ ਖਸਮ-ਪ੍ਰਭੂ ਅਦ੍ਰਿਸ਼ਟ ਹੈ, ਸਾਡਾ ਉਹ ਸੁਆਮੀ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ, ਸਭ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਉਹ ਪ੍ਰਭੂ ਸਭ ਸਰੀਰਾਂ ਵਿਚ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Наш Господин-Владыка невидим, наш Свами недоступен чувствам познания; Он, Знающий сердца всех существ, присутствует во всех телах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49471,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਦੇਖਉ ਤੇਰਾ ਵਾਸਾ ॥",
          "roman": "jat kat dekhau terā vāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਜਿਧਰ ਕਿਧਰ ਵੇਖਦਾ ਹਾਂ ਮੈਨੂੰ ਤੇਰਾ ਹੀ ਨਿਵਾਸ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, куда бы я ни посмотрел, всюду я вижу Твоё присутствие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49472,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਗੁਰਿ ਕੀਓ ਪ੍ਰਗਾਸਾ ॥੮॥੨॥੫॥",
          "roman": "nānak kau gur kīo pragāsā ॥8॥2॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ) ਨਾਨਕ ਨੂੰ ਗੁਰੂ ਨੇ (ਅਜਿਹਾ ਆਤਮਕ) ਚਾਨਣ ਬਖ਼ਸ਼ਿਆ ਹੈ ॥੮॥੨॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Мне, Нанаку, Гуру даровал такой духовный свет ॥8॥2॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4125,
      "rahao_verse_id": 49479,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49473,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49474,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮੋ ਕਉ ਕੀਨੋ ਦਾਨੁ ॥",
          "roman": "Satigur mo kau kīno dān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਮੈਨੂੰ (ਇਹ) ਦਾਤ ਬਖ਼ਸ਼ੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру даровал мне этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49475,
          "is_rahao": false,
          "gurmukhi": "ਅਮੋਲ ਰਤਨੁ ਹਰਿ ਦੀਨੋ ਨਾਮੁ ॥",
          "roman": "Amol ratan har dīno nām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੇ ਮੈਨੂੰ ਉਹ) ਨਾਮ-ਰਤਨ ਦਿੱਤਾ ਹੈ ਜੋ ਕਿਸੇ ਭੀ ਮੁੱਲ ਤੋਂ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру дал мне имя-драгоценность, которое нельзя получить ни за какую цену."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49476,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਬਿਨੋਦ ਚੋਜ ਆਨੰਤਾ ॥",
          "roman": "Sehaj binod choj ānantā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਮੇਰੇ ਅੰਦਰ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਬੇਅੰਤ ਆਨੰਦ-ਤਮਾਸ਼ੇ ਬਣੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь внутри меня пребывают бесконечные радости и чудеса духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49477,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭੁ ਮਿਲਿਓ ਅਚਿੰਤਾ ॥੧॥",
          "roman": "Nānak kau prabh miliō achintā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ) ਨਾਨਕ ਨੂੰ (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਪਰਮਾਤਮਾ ਆ ਮਿਲਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Мне, Нанаку, по милости Гуру встретился Бог, устраняющий тревогу ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49478,
          "is_rahao": true,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਕੀਰਤਿ ਹਰਿ ਸਾਚੀ ॥",
          "roman": "Kah Nānak kīrat har sāchī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਵਡਿਆਈ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о брат, прославляй непреходящую славу Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49479,
          "is_rahao": true,
          "gurmukhi": "ਬਹੁਰਿ ਬਹੁਰਿ ਤਿਸੁ ਸੰਗਿ ਮਨੁ ਰਾਚੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Bahur bahur tis sang man rāchī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਨੂੰ ਮੁੜ ਮੁੜ ਉਸ (ਸਿਫ਼ਤ-ਸਾਲਾਹ) ਨਾਲ ਜੋੜੀ ਰੱਖ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Снова и снова соединяй свой ум с этой хвалой ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49480,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਭੋਜਨ ਭਾਉ ॥",
          "roman": "Achint hamārē bhojan bhāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੁਣ) ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਪਿਆਰ ਹੀ ਮੇਰੇ ਵਾਸਤੇ (ਆਤਮਕ ਜੀਵਨ ਦੀ) ਖ਼ੁਰਾਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру любовь к Богу, устраняющему тревогу, стала для меня пищей духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49481,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਲੀਚੈ ਨਾਉ ॥",
          "roman": "Achint hamārē līchē nāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਅੰਦਰ ਅਚਿੰਤ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਸਦਾ ਲਿਆ ਜਾ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "во мне постоянно произносится имя Бога, устраняющего тревогу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49482,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਸਬਦਿ ਉਧਾਰ ॥",
          "roman": "Achint hamārē sabad udhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਚਿੰਤ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਦੀ ਰਾਹੀਂ ਵਿਕਾਰਾਂ ਤੋਂ ਮੇਰਾ ਬਚਾਉ ਹੋ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "через слово хвалы Богу, устраняющему тревогу, я спасаюсь от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49483,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਭਰੇ ਭੰਡਾਰ ॥੨॥",
          "roman": "Achint hamārē bhare bhaṇḍār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੇਰੇ ਅੰਦਰ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੇ ਖ਼ਜ਼ਾਨੇ ਭਰੇ ਗਏ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру во мне наполнились сокровищницы имени Бога, устраняющего тревогу ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49484,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਕਾਰਜ ਪੂਰੇ ॥",
          "roman": "Achint hamārē kāraj pūre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰੇ ਸਾਰੇ ਕੰਮ ਸਫਲ ਹੋ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря благодати имени Бога, устраняющего тревогу, все мои дела становятся успешными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49485,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਲਥੇ ਵਿਸੂਰੇ ॥",
          "roman": "Achint hamārē lathe visūre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਮੇਰੇ ਅੰਦਰੋਂ ਸਾਰੇ) ਚਿੰਤਾ-ਝੋਰੇ ਮੁੱਕ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "благодаря благодати имени Бога, устраняющего тревогу, все мои беспокойства исчезли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49486,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਬੈਰੀ ਮੀਤਾ ॥",
          "roman": "Achint hamārē bērī mītā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹੁਣ ਮੈਨੂੰ ਵੈਰੀ ਭੀ ਮਿੱਤਰ ਦਿੱਸ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "благодаря благодати имени Бога, устраняющего тревогу, теперь даже враги кажутся мне друзьями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49487,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੋ ਹੀ ਇਹੁ ਮਨੁ ਵਸਿ ਕੀਤਾ ॥੩॥",
          "roman": "Achinto hī ih mn vasi kītā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਲੈ ਕੇ ਹੀ ਮੈਂ ਆਪਣਾ ਇਹ ਮਨ ਵੱਸ ਵਿਚ ਕਰ ਲਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь принимая имя Хари, устраняющее тревогу, я подчинил себе этот ум ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49488,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਪ੍ਰਭੂ ਹਮ ਕੀਆ ਦਿਲਾਸਾ ॥",
          "roman": "Achint prabhū ham kīā dilāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੇ ਮੈਨੂੰ ਹੌਸਲਾ ਬਖ਼ਸ਼ਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог, устраняющий тревогу, даровал мне утешение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49489,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੀ ਪੂਰਨ ਆਸਾ ॥",
          "roman": "Achint hamārī pūran āsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ (ਦੀ ਕ੍ਰਿਪਾ ਦੁਆਰਾ) ਮੇਰੀਆਂ ਸਾਰੀਆਂ ਆਸਾਂ ਪੂਰੀਆਂ ਹੋ ਗਈਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Бога, устраняющего тревогу, все мои надежды исполнились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49490,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮੑਾ ਕਉ ਸਗਲ ਸਿਧਾਂਤੁ ॥",
          "roman": "Achint hamhā kau sagal sidhānt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਣਾ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਸਾਰੇ ਧਰਮਾਂ ਦਾ ਨਿਚੋੜ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Для меня суть всех религий — это повторение имени Бога, устраняющего тревогу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49491,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੁ ਹਮ ਕਉ ਗੁਰਿ ਦੀਨੋ ਮੰਤੁ ॥੪॥",
          "roman": "Achintu ham kau guri dīno mantu ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਮੰਤ੍ਰ ਮੈਨੂੰ ਗੁਰੂ ਨੇ ਦਿੱਤਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру дал мне мантру-имя Бога, устраняющего тревогу ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49492,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੇ ਬਿਨਸੇ ਬੈਰ ॥",
          "roman": "Achint hamāre binse bēr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ (ਮੇਰੇ ਅੰਦਰੋਂ ਸਾਰੇ) ਵੈਰ-ਵਿਰੋਧ ਨਾਸ ਹੋ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда я повторяю имя Бога, устраняющего тревогу, вся вражда во мне исчезла,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49493,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੇ ਮਿਟੇ ਅੰਧੇਰ ॥",
          "roman": "Achint hamāre miṭe andher ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ (ਮੇਰੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਹਨੇਰੇ ਦੂਰ ਹੋ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "когда я повторяю имя Бога, устраняющего тревогу, тьма привязанности к майе во мне рассеялась."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49494,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੋ ਹੀ ਮਨਿ ਕੀਰਤਨੁ ਮੀਠਾ ॥",
          "roman": "Achinto hī man kīrtan mīṭhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਪ ਕੇ ਹੀ ਮੇਰੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਪਿਆਰੀ ਲੱਗ ਰਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Лишь повторяя имя Хари, устраняющее тревогу, я почувствовал сладость хвалы Богу в своём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49495,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੋ ਹੀ ਪ੍ਰਭੁ ਘਟਿ ਘਟਿ ਡੀਠਾ ॥੫॥",
          "roman": "Achinto hī prabh ghaṭ ghaṭ ḍīṭhā ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਪ ਕੇ ਹੀ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਮੈਂ ਹਰੇਕ ਹਿਰਦੇ ਵਿਚ ਵੱਸਦਾ ਵੇਖ ਲਿਆ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и лишь повторяя это имя Хари, устраняющее тревогу, я увидел Бога пребывающим в каждом сердце ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49496,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਮਿਟਿਓ ਹੈ ਸਗਲੋ ਭਰਮਾ ॥",
          "roman": "Achint miṭiō hē saglo bharamā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰੀ ਸਾਰੀ ਭਟਕਣਾ ਮੁੱਕ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря благодати имени Хари, устраняющего тревогу, все мои блуждания прекратились,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49497,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਵਸਿਓ ਮਨਿ ਸੁਖ ਬਿਸ੍ਰਾਮਾ ॥",
          "roman": "Achint vasiō man sukh bisrāmā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੋਂ) ਅਚਿੰਤ ਪ੍ਰਭੂ ਮੇਰੇ ਮਨ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈ, ਮੇਰੇ ਅੰਦਰ ਆਤਮਕ ਆਨੰਦ ਦਾ (ਪੱਕਾ) ਟਿਕਾਣਾ ਬਣ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "с тех пор как Бог, устраняющий тревогу, поселился в моём уме, во мне утвердилось место духовного покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49498,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਅਨਹਤ ਵਾਜੈ ॥",
          "roman": "Achint hamārē anhat vājē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਅੰਦਰ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਹਰਿ-ਨਾਮ ਦਾ ਇੱਕ-ਰਸ ਵਾਜਾ ਵੱਜ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь во мне звучит непрерывная музыка имени Хари, устраняющего тревогу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49499,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਗੋਬਿੰਦੁ ਗਾਜੈ ॥੬॥",
          "roman": "Achint hamārē Gobindu gājē ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮੇਰੇ ਅੰਦਰ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਹੀ ਹਰ ਵੇਲੇ ਗੱਜ ਰਿਹਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и во мне постоянно гремит имя Гобинда, устраняющего тревогу ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49500,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਹਮਾਰੈ ਮਨੁ ਪਤੀਆਨਾ ॥",
          "roman": "Achint hamārē man patīānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰਾ ਮਨ ਭਟਕਣੋਂ ਹਟ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря благодати имени Хари, устраняющего тревогу, мой ум перестал блуждать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49501,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲ ਧਨੀ ਅਚਿੰਤੁ ਪਛਾਨਾ ॥",
          "roman": "Nihchal dhanī achint pachhānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਚਿੰਤ ਹਰਿ-ਨਾਮ ਜਪ ਕੇ ਮੈਂ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨਾਲ ਸਾਂਝ ਪਾ ਲਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "повторяя имя Хари, устраняющее тревогу, я вошёл в связь с вечно пребывающим Владыкой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49502,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤੋ ਉਪਜਿਓ ਸਗਲ ਬਿਬੇਕਾ ॥",
          "roman": "Achinto upajiō sagal bibekā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਪ ਕੇ ਹੀ ਮੇਰੇ ਅੰਦਰ ਚੰਗੇ ਮਾੜੇ ਕੰਮ ਦੀ ਸਾਰੀ ਪਛਾਣ ਪੈਦਾ ਹੋ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь повторяя имя Хари, устраняющее тревогу, я обрёл полное различение добрых и дурных дел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49503,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਚਰੀ ਹਥਿ ਹਰਿ ਹਰਿ ਟੇਕਾ ॥੭॥",
          "roman": "Achint charī hathi har har ṭekā ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਅਚਿੰਤ ਹਰਿ-ਨਾਮ ਦੀ ਮੈਨੂੰ ਸਦਾ ਲਈ ਟੇਕ ਮਿਲ ਗਈ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Мне навсегда досталась опора этого имени Хари, устраняющего тревогу ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49504,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਪ੍ਰਭੂ ਧੁਰਿ ਲਿਖਿਆ ਲੇਖੁ ॥",
          "roman": "Achint prabhū dhur likhiā lekh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਉਤੇ ਪ੍ਰਭੂ ਨੇ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲੇ ਹਰਿ-ਨਾਮ ਦੀ ਪ੍ਰਾਪਤੀ ਦਾ ਲੇਖ ਧੁਰ ਦਰਗਾਹ ਤੋਂ ਲਿਖ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, на челе которого Бог изначально начертал получение имени Хари, устраняющего тревогу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49505,
          "is_rahao": false,
          "gurmukhi": "ਅਚਿੰਤ ਮਿਲਿਓ ਪ੍ਰਭੁ ਠਾਕੁਰੁ ਏਕੁ ॥",
          "roman": "Achint miliō prabh ṭhākur ek ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਸਭ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "достается этот единый Владыка-Бог, устраняющий тревогу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49506,
          "is_rahao": false,
          "gurmukhi": "ਚਿੰਤ ਅਚਿੰਤਾ ਸਗਲੀ ਗਈ ॥",
          "roman": "Chint achintā saglī gaī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੰਤਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਪ ਕੇ ਮੇਰੀ ਸਾਰੀ ਚਿੰਤਾ ਦੂਰ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяя имя Хари, устраняющее тревогу, я избавился от всякой тревоги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49507,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਨਾਨਕ ਨਾਨਕ ਨਾਨਕ ਮਈ ॥੮॥੩॥੬॥",
          "roman": "Prabh Nānak Nānak Nānak maī ॥8॥3॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਨਾਨਕ ਸਦਾ ਲਈ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਹੋ ਗਿਆ ਹਾਂ ॥੮॥੩॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "теперь я, Нанак, навсегда слился с Богом ॥8॥3॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
