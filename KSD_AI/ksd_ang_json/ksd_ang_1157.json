      "lines": [
        {
          "verse_id": 49508,
          "is_rahao": true,
          "gurmukhi": "ਭੈਰਉ ਬਾਣੀ ਭਗਤਾ ਕੀ ॥ ਕਬੀਰ ਜੀਉ ਘਰੁ ੧",
          "roman": "Bhērau bāṇī bhagtā kī ॥ Kabīr jīu ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਭੈਰਉ ਵਿੱਚ ਭਗਤਾਂ ਦੀ ਬਾਣੀ। (ਰਾਗ ਭੈਰਉ) ਘਰ ੧ ਵਿੱਚ ਭਗਤ ਕਬੀਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани бхагатов в раге Бхайрау. Бани бхагата Кабира Джи в раге Бхайрау, дом 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49509,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "Ik Oaṅkār satigur prasād ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх един и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49510,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਧਨੁ ਮੇਰੇ ਹਰਿ ਕੋ ਨਾਉ ॥",
          "roman": "Ihu dhan mere har ko nāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਇਹ ਨਾਮ ਹੀ ਮੇਰੇ ਲਈ ਧਨ ਹੈ (ਜਿਵੇਂ ਲੋਕ ਧਨ ਨੂੰ ਜੀਵਨ ਦਾ ਸਹਾਰਾ ਬਣਾ ਲੈਂਦੇ ਹਨ, ਮੇਰੇ ਜੀਵਨ ਦਾ ਸਹਾਰਾ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਹੈ, ਪਰ)"
            },
            "sahib_singh_ru": {
              "main": "Это имя Бога и есть для меня богатство, как для людей богатство становится опорой жизни; так и для моей жизни опорой является имя Бога, но"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49511,
          "is_rahao": true,
          "gurmukhi": "ਗਾਂਠਿ ਨ ਬਾਧਉ ਬੇਚਿ ਨ ਖਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Gāṇṭhi na bādhau bechi na khāu ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਨਾਹ ਤਾਂ ਇਸ ਨੂੰ ਲੁਕਾ ਕੇ ਰੱਖਦਾ ਹਾਂ, ਤੇ ਨਾਹ ਹੀ ਵਿਖਾਵੇ ਲਈ ਵਰਤਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "я не прячу его и не использую напоказ ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49512,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਮੇਰੇ ਖੇਤੀ ਨਾਉ ਮੇਰੇ ਬਾਰੀ ॥",
          "roman": "Nāu mere khetī nāu mere bārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੋਈ ਮਨੁੱਖ ਖੇਤੀ-ਵਾੜੀ ਨੂੰ ਆਸਰਾ ਮੰਨਦਾ ਹੈ, ਪਰ) ਮੇਰੇ ਲਈ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਖੇਤੀ ਹੈ, ਤੇ ਨਾਮ ਹੀ ਬਗ਼ੀਚੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то считает опорой земледелие и сад, а для меня имя Бога — и поле, и сад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49513,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰਉ ਜਨੁ ਸਰਨਿ ਤੁਮੑਾਰੀ ॥੧॥",
          "roman": "Bhagat karaū jan saran tumhārī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰਾ ਦਾਸ ਤੇਰੀ ਹੀ ਸ਼ਰਨ ਹਾਂ, ਤੇ ਤੇਰੀ ਭਗਤੀ ਕਰਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Бог, я Твой слуга, я в Твоём прибежище и совершаю Твоё поклонение ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49514,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਮੇਰੇ ਮਾਇਆ ਨਾਉ ਮੇਰੇ ਪੂੰਜੀ ॥",
          "roman": "Nāu mere māiā nāu mere pūnjī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਹੀ ਮੇਰੇ ਲਈ ਮਾਇਆ ਹੈ ਤੇ ਰਾਸ-ਪੂੰਜੀ ਹੈ (ਵਪਾਰ ਕਰਨ ਲਈ। ਭਾਵ, ਵਪਾਰ ਸਰੀਰਕ ਨਿਰਬਾਹ ਵਾਸਤੇ ਹੈ, ਮੇਰੀ ਜ਼ਿੰਦਗੀ ਦਾ ਸਹਾਰਾ ਨਹੀਂ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О Бог, Твоё имя для меня и майя, и капитал для торговли; то есть торговля нужна для телесного пропитания, но не является опорой моей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49515,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਹਿ ਛੋਡਿ ਜਾਨਉ ਨਹੀ ਦੂਜੀ ॥੨॥",
          "roman": "Tumahi chhoḍ jānaū nahī dūjī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਨੂੰ ਵਿਸਾਰ ਕੇ ਮੈਂ ਕਿਸੇ ਹੋਰ ਰਾਸ-ਪੂੰਜੀ ਨਾਲ ਸਾਂਝ ਨਹੀਂ ਬਣਾਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Бог, забыв Тебя, я не связываюсь ни с каким иным капиталом ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49516,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਮੇਰੇ ਬੰਧਿਪ ਨਾਉ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "Nāu mere banḍhip nāu mere bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਮੇਰੇ ਲਈ ਰਿਸ਼ਤੇਦਾਰ ਹੈ, ਨਾਮ ਹੀ ਮੇਰਾ ਭਰਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога для меня и родственник, и брат;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49517,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਮੇਰੇ ਸੰਗਿ ਅੰਤਿ ਹੋਇ ਸਖਾਈ ॥੩॥",
          "roman": "Nāu mere sang anti hoi sakhāī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਹੀ ਮੇਰੇ ਨਾਲ ਆਖ਼ਰ ਨੂੰ ਸਹਾਇਤਾ ਕਰਨ ਵਾਲਾ ਬਣ ਸਕਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "только имя может в конце стать тем, кто поможет мне ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49518,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮਹਿ ਜਿਸੁ ਰਖੈ ਉਦਾਸੁ ॥",
          "roman": "Māiā mah jis rakhē udās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਮਾਇਆ ਵਿਚ ਰਹਿੰਦੇ ਹੋਏ ਨੂੰ ਮਾਇਆ ਤੋਂ ਨਿਰਲੇਪ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кого Бог сохраняет непривязанным к майе, даже пока тот живёт среди неё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49519,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਹਉ ਤਾ ਕੋ ਦਾਸੁ ॥੪॥੧॥",
          "roman": "Kahi Kabīr hau tā ko dās ॥4॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ ਕਿ ਮੈਂ ਉਸ ਮਨੁੱਖ ਦਾ ਸੇਵਕ ਹਾਂ ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я слуга такого человека ॥4॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4127,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49520,
          "is_rahao": false,
          "gurmukhi": "ਨਾਂਗੇ ਆਵਨੁ ਨਾਂਗੇ ਜਾਨਾ ॥",
          "roman": "Nāṅge āvan nāṅge jānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ) ਨੰਗੇ ਆਈਦਾ ਹੈ, ਤੇ ਨੰਗੇ ਹੀ (ਇੱਥੋਂ) ਤੁਰ ਪਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В этот мир приходят нагими и нагими же отсюда уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49521,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਰਹਿਹੈ ਰਾਜਾ ਰਾਨਾ ॥੧॥",
          "roman": "Koi na rahihē rājā rānā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਰਾਜਾ ਹੋਵੇ, ਅਮੀਰ ਹੋਵੇ, ਕਿਸੇ ਨੇ ਇੱਥੇ ਸਦਾ ਨਹੀਂ ਰਹਿਣਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Будь кто царём или богачом, никто не останется здесь навсегда ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
