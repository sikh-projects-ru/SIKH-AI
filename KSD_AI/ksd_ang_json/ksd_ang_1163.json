{
  "ang": 1163,
  "shabads": [
    {
      "shabad_id": 4145,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49794,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰ ਤੇਤੀਸਉ ਜੇਵਹਿ ਪਾਕ ॥",
          "roman": "sur tetīsau jevah pāk",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਦਰ ਤੋਂ ਤੇਤੀ ਕ੍ਰੋੜ ਦੇਵਤੇ ਭੋਜਨ ਛਕਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "от двора Которого питаются тридцать три крора богов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49795,
          "is_rahao": false,
          "gurmukhi": "ਨਵ ਗ੍ਰਹ ਕੋਟਿ ਠਾਢੇ ਦਰਬਾਰ ॥",
          "roman": "nav grah koṭ ṭhāḍhe darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਨੌ ਗ੍ਰਹਿ ਜਿਸ ਦੇ ਦਰਬਾਰ ਵਿਚ ਖਲੋਤੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "при дворе Которого стоят миллионы девяти планет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49796,
          "is_rahao": false,
          "gurmukhi": "ਧਰਮ ਕੋਟਿ ਜਾ ਕੈ ਪ੍ਰਤਿਹਾਰ ॥੨॥",
          "roman": "dharam koṭ jā kē pratihār.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕ੍ਰੋੜਾਂ ਹੀ ਧਰਮ-ਰਾਜ ਜਿਸ ਦੇ ਦਰਬਾਨ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и миллионы Дхармараджей — Его привратники. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49797,
          "is_rahao": false,
          "gurmukhi": "ਪਵਨ ਕੋਟਿ ਚਉਬਾਰੇ ਫਿਰਹਿ ॥",
          "roman": "pavan koṭ chau bāre phirahi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਕੇਵਲ ਉਸ ਪ੍ਰਭੂ ਦੇ ਦਰ ਦਾ ਮੰਗਤਾ ਹਾਂ) ਜਿਸ ਦੇ ਚੁਬਾਰੇ ਉੱਤੇ ਕ੍ਰੋੜਾਂ ਹਵਾਵਾਂ ਚੱਲਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Я — нищий только у того Господа, над чертогами Которого веют миллионы ветров,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49798,
          "is_rahao": false,
          "gurmukhi": "ਬਾਸਕ ਕੋਟਿ ਸੇਜ ਬਿਸਥਰਹਿ ॥",
          "roman": "bāsak koṭ sej bistharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਸ਼ੇਸ਼ਨਾਗ ਜਿਸ ਦੀ ਸੇਜ ਵਿਛਾਉਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "миллионы Шешнаг вьют для Него ложе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49799,
          "is_rahao": false,
          "gurmukhi": "ਸਮੁੰਦ ਕੋਟਿ ਜਾ ਕੇ ਪਾਨੀਹਾਰ ॥",
          "roman": "samund koṭ jā ke pānīhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਸਮੁੰਦਰ ਜਿਸ ਦੇ ਪਾਣੀ ਭਰਨ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "миллионы океанов носят для Него воду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49800,
          "is_rahao": false,
          "gurmukhi": "ਰੋਮਾਵਲਿ ਕੋਟਿ ਅਠਾਰਹ ਭਾਰ ॥੩॥",
          "roman": "romāval koṭ aṭhārah bhār.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਬਨਸਪਤੀ ਦੇ ਕ੍ਰੋੜਾਂ ਹੀ ਅਠਾਰਾਂ ਭਾਰ ਜਿਸ ਦੇ ਜਿਸਮ ਦੇ, ਮਾਨੋ, ਰੋਮ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "а миллионы восемнадцати видов растительности — словно волосы на Его теле. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49801,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕਮੇਰ ਭਰਹਿ ਭੰਡਾਰ ॥",
          "roman": "koṭ kamer bharah bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਹੀ ਮੰਗਦਾ ਹਾਂ) ਜਿਸ ਦੇ ਖ਼ਜ਼ਾਨੇ ਕ੍ਰੋੜਾਂ ਹੀ ਕੁਬੇਰ ਦੇਵਤੇ ਭਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу только у того Господа, чьи сокровищницы наполняют миллионы Куберов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49802,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿਕ ਲਖਮੀ ਕਰੈ ਸੀਗਾਰ ॥",
          "roman": "koṭik lakhmī karē sīgār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਦਰ ਤੇ ਕ੍ਰੋੜਾਂ ਹੀ ਲਛਮੀਆਂ ਸ਼ਿੰਗਾਰ ਕਰ ਰਹੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "при дворе Которого миллионы Лакшми совершают украшение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49803,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿਕ ਪਾਪ ਪੁੰਨ ਬਹੁ ਹਿਰਹਿ ॥",
          "roman": "koṭik pāp puṇn bah hirah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਪਾਪ ਤੇ ਪੁੰਨ ਜਿਸ ਵਲ ਤੱਕ ਰਹੇ ਹਨ (ਕਿ ਸਾਨੂੰ ਆਗਿਆ ਕਰੇ)"
            },
            "sahib_singh_ru": {
              "main": "миллионы грехов и заслуг взирают на Него, ожидая повеления,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49804,
          "is_rahao": false,
          "gurmukhi": "ਇੰਦ੍ਰ ਕੋਟਿ ਜਾ ਕੇ ਸੇਵਾ ਕਰਹਿ ॥੪॥",
          "roman": "indr koṭ jā ke sevā karahi.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕ੍ਰੋੜਾਂ ਹੀ ਇੰਦਰ ਦੇਵਤੇ ਜਿਸ ਦੇ ਦਰ ਤੇ ਸੇਵਾ ਕਰ ਰਹੇ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и миллионы Индр служат у Его двора. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49805,
          "is_rahao": false,
          "gurmukhi": "ਛਪਨ ਕੋਟਿ ਜਾ ਕੈ ਪ੍ਰਤਿਹਾਰ ॥",
          "roman": "chhapan koṭ jā kē pratihār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਕੇਵਲ ਉਸ ਗੋਪਾਲ ਦਾ ਜਾਚਕ ਹਾਂ) ਜਿਸ ਦੇ ਦਰ ਤੇ ਛਵੰਜਾ ਕਰੋੜ ਬੱਦਲ ਦਰਬਾਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Я — проситель только у того Гопала, при дворе Которого пятьдесят шесть крор туч стоят как привратники,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49806,
          "is_rahao": false,
          "gurmukhi": "ਨਗਰੀ ਨਗਰੀ ਖਿਅਤ ਅਪਾਰ ॥",
          "roman": "nagrī nagrī khiat apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜੋ ਥਾਂ ਥਾਂ ਤੇ ਚਮਕ ਰਹੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и повсюду сверкают безмерно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49807,
          "is_rahao": false,
          "gurmukhi": "ਲਟ ਛੂਟੀ ਵਰਤੈ ਬਿਕਰਾਲ ॥",
          "roman": "laṭ chhūṭī vartē bikrāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਕਾਲਕਾ ਕੇਸ ਖੋਲ੍ਹ ਕੇ ਡਰਾਉਣਾ ਰੂਪ ਧਾਰ ਕੇ ਜਿਸ ਦੇ ਦਰ ਤੇ ਮੌਜੂਦ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "миллионы Калика, распустив волосы, приняли грозный вид и пребывают при Его дворе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49808,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕਲਾ ਖੇਲੈ ਗੋਪਾਲ ॥੫॥",
          "roman": "koṭ kalā khelē Gopāl.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਗੋਪਾਲ ਦੇ ਦਰ ਤੇ ਕ੍ਰੋੜਾਂ ਸ਼ਕਤੀਆਂ ਖੇਡਾਂ ਕਰ ਰਹੀਆਂ ਹਨ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и при дворе этого Гопала играют миллионы сил. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49809,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਗ ਜਾ ਕੈ ਦਰਬਾਰ ॥",
          "roman": "koṭ jag jā kē darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਹੀ ਮੰਗਦਾ ਹਾਂ) ਜਿਸ ਦੇ ਦਰਬਾਰ ਵਿਚ ਕ੍ਰੋੜਾਂ ਜੱਗ ਹੋ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу только у того Господа, при дворе Которого совершаются миллионы жертвоприношений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49810,
          "is_rahao": false,
          "gurmukhi": "ਗੰਧ੍ਰਬ ਕੋਟਿ ਕਰਹਿ ਜੈਕਾਰ ॥",
          "roman": "gaṅdhrab koṭ karah jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਕ੍ਰੋੜਾਂ ਗੰਧਰਬ ਜੈ-ਜੈਕਾਰ ਗਾ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "и миллионы гандхарвов возглашают победные славословия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49811,
          "is_rahao": false,
          "gurmukhi": "ਬਿਦਿਆ ਕੋਟਿ ਸਭੈ ਗੁਨ ਕਹੈ ॥",
          "roman": "bidiā koṭ sabhē gun kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਵਿੱਦਿਆ ਜਿਸ ਦੇ ਬੇਅੰਤ ਗੁਣ ਬਿਆਨ ਕਰ ਰਹੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "миллионы наук повествуют о Его бесчисленных достоинствах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49812,
          "is_rahao": false,
          "gurmukhi": "ਤਊ ਪਾਰਬ੍ਰਹਮ ਕਾ ਅੰਤੁ ਨ ਲਹੈ ॥੬॥",
          "roman": "taū pārbrahm kā ant na lahē.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਫਿਰ ਭੀ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪਾ ਸਕਦੀਆਂ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "но всё же не могут дойти до конца качеств Парабрахмана. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49813,
          "is_rahao": false,
          "gurmukhi": "ਬਾਵਨ ਕੋਟਿ ਜਾ ਕੈ ਰੋਮਾਵਲੀ ॥ ਰਾਵਨ ਸੈਨਾ ਜਹ ਤੇ ਛਲੀ ॥",
          "roman": "bāvan koṭ jā kē romāvalī. rāvan sēnā jah te chhalī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਉਸ ਪ੍ਰਭੂ ਦਾ ਜਾਚਕ ਹਾਂ) ਕ੍ਰੋੜਾਂ ਹੀ ਵਾਮਨ ਅਵਤਾਰ ਜਿਸ ਦੇ ਸਰੀਰ ਦੇ, ਮਾਨੋ, ਰੋਮ ਹਨ, ਜਿਸ ਦੇ ਦਰ ਤੇ ਕ੍ਰੋੜਾਂ ਹੀ ਉਹ (ਸ੍ਰੀ ਰਾਮ ਚੰਦਰ ਜੀ) ਹਨ ਜਿਸ ਤੋਂ ਰਾਵਣ ਦੀ ਸੈਨਾ ਹਾਰੀ ਸੀ;"
            },
            "sahib_singh_ru": {
              "main": "Я — проситель у того Господа, у Которого миллионы воплощений Вамана — словно волосы на теле, и у Которого при дворе есть миллионы тех, от кого потерпело поражение войско Равана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49814,
          "is_rahao": false,
          "gurmukhi": "ਸਹਸ ਕੋਟਿ ਬਹੁ ਕਹਤ ਪੁਰਾਨ ॥",
          "roman": "sahas koṭ bah kahat purān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਦਰ ਤੇ ਕ੍ਰੋੜਾਂ ਹੀ ਉਹ (ਕ੍ਰਿਸ਼ਨ ਜੀ) ਹਨ ਜਿਸ ਨੂੰ ਭਾਗਵਤ ਪੁਰਾਣ ਬਿਆਨ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "при дворе Которого миллионы тех, о ком повествует Бхагавата-пурана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49815,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਜੋਧਨ ਕਾ ਮਥਿਆ ਮਾਨੁ ॥੭॥",
          "roman": "durjodhan kā mathiā mān.7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਨੇ ਦੁਰਜੋਧਨ ਦਾ ਅਹੰਕਾਰ ਤੋੜਿਆ ਸੀ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и тех, кто сокрушил гордыню Дурьодхана. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49816,
          "is_rahao": false,
          "gurmukhi": "ਕੰਦ੍ਰਪ ਕੋਟਿ ਜਾ ਕੈ ਲਵੈ ਨ ਧਰਹਿ ॥",
          "roman": "kandrap koṭ jā kē lavē na dharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਉਸ ਤੋਂ ਮੰਗਦਾ ਹਾਂ) ਜਿਸ ਦੀ ਸੁੰਦਰਤਾ ਦੀ ਬਰਾਬਰੀ ਉਹ ਕ੍ਰੋੜਾਂ ਕਾਮਦੇਵ ਭੀ ਨਹੀਂ ਕਰ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу у того, чью красоту не могут сравнить с собой даже миллионы Камдевов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49817,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰ ਅੰਤਰਿ ਮਨਸਾ ਹਰਹਿ ॥",
          "roman": "antar antar mansā harah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਨਿੱਤ ਜੀਵਾਂ ਦੇ ਹਿਰਦਿਆਂ ਦੀ ਅੰਦਰਲੀ ਵਾਸ਼ਨਾ ਚੁਰਾਉਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "которые непрестанно похищают сокровенные желания из сердец живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49818,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਸੁਨਿ ਸਾਰਿਗਪਾਨ ॥",
          "roman": "kah Kabīr sun sārigpān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ, ਹੇ ਧਨਖਧਾਰੀ ਪ੍ਰਭੂ! (ਮੇਰ ਬੇਨਤੀ) ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: о Господь, держащий лук, услышь мою просьбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49819,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹਿ ਅਭੈ ਪਦੁ ਮਾਂਗਉ ਦਾਨ ॥੮॥੨॥੧੮॥੨੦॥",
          "roman": "dehi abhē pad māṅgau dān.8.2.18.20.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਉਹ ਆਤਮਕ ਅਵਸਥਾ ਬਖ਼ਸ਼ ਜਿੱਥੇ ਮੈਨੂੰ ਕੋਈ ਕਿਸੇ (ਦੇਵੀ ਦੇਵਤੇ) ਦਾ ਡਰ ਨਾਹ ਰਹੇ, (ਬੱਸ) ਮੈਂ ਇਹੀ ਦਾਨ ਮੰਗਦਾ ਹੈ ॥੮॥੨॥੧੮॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "даруй мне то духовное состояние, где у меня не останется страха ни перед кем из богов и богинь. Только это подаяние я и прошу. ॥8॥2॥18॥20॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4146,
      "rahao_verse_id": 49825,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49820,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਬਾਣੀ ਨਾਮਦੇਉ ਜੀਉ ਕੀ ਘਰੁ ੧",
          "roman": "Bhērau bāṇī Nāmdeu jīu kī ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਭੈਰਉ, ਘਰ ੧ ਵਿੱਚ ਭਗਤ ਨਾਮਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Рааг Бхайрау, дом 1: bani Бхагата Намдева Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49821,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "Ik ōankār satgur prasād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49822,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਜਿਹਬਾ ਕਰਉ ਸਤ ਖੰਡ ॥",
          "roman": "Re jihbā karau sat khaṇḍ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ ਇਸ (ਜੀਭ) ਦੇ ਸੌ ਟੋਟੇ ਕਰ ਦਿਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я бы разрубил этот язык на сотню частей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49823,
          "is_rahao": false,
          "gurmukhi": "ਜਾਮਿ ਨ ਉਚਰਸਿ ਸ੍ਰੀ ਗੋਬਿੰਦ ॥੧॥",
          "roman": "Jām na ucharas srī Gobind. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਹੁਣ ਕਦੇ ਮੇਰੀ ਜੀਭ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਨਾ ਜਪੇ। (ਭਾਵ, ਮੇਰੀ ਜੀਭ ਇਸ ਤਰ੍ਹਾਂ ਨਾਮ ਦੇ ਰੰਗ ਵਿਚ ਰੰਗੀ ਗਈ ਹੈ ਕਿ ਮੈਨੂੰ ਹੁਣ ਯਕੀਨ ਹੈ ਇਹ ਕਦੇ ਨਾਮ ਨੂੰ ਨਹੀਂ ਵਿਸਾਰੇਗੀ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если бы отныне мой язык хоть когда-нибудь не произносил Имя Господа. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49824,
          "is_rahao": true,
          "gurmukhi": "ਰੰਗੀ ਲੇ ਜਿਹਬਾ ਹਰਿ ਕੈ ਨਾਇ ॥",
          "roman": "Raṅgī le jihbā har kē nāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੀ ਜੀਭ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਰੰਗ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я окрасил свой язык в Имя Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49825,
          "is_rahao": true,
          "gurmukhi": "ਸੁਰੰਗ ਰੰਗੀਲੇ ਹਰਿ ਹਰਿ ਧਿਆਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Suraṅg raṅgīle har har dhiāe. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ ਮੈਂ ਇਸ ਨੂੰ ਸੋਹਣੇ ਰੰਗ ਵਿਚ ਰੰਗ ਲਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "созерцая Имя Господа вновь и вновь, я окрасил его в прекрасный цвет. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49826,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਜਿਹਬਾ ਅਵਰੇਂ ਕਾਮ ॥",
          "roman": "Mithiā jihbā avreṅ kām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਹੋਰ ਆਹਰਾਂ ਵਿਚ ਲੱਗੀ ਹੋਈ ਜੀਭ ਵਿਅਰਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Язык, занятый разными иными делами, напрасен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49827,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਬਾਣ ਪਦੁ ਇਕੁ ਹਰਿ ਕੋ ਨਾਮੁ ॥੨॥",
          "roman": "Nirbāṇ pad ik har ko nām. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਵਾਸ਼ਨਾ-ਰਹਿਤ ਅਵਸਥਾ ਪੈਦਾ ਕਰਦਾ ਹੈ (ਹੋਰ ਹੋਰ ਆਹਰ ਸਗੋਂ ਵਾਸ਼ਨਾ ਪੈਦਾ ਕਰਦੇ ਹਨ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ибо только Имя Вахегуру рождает состояние свободы от желаний. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49828,
          "is_rahao": false,
          "gurmukhi": "ਅਸੰਖ ਕੋਟਿ ਅਨ ਪੂਜਾ ਕਰੀ ॥",
          "roman": "Asaṅkh koṭ an pūjā karī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮੈਂ ਕ੍ਰੋੜਾਂ ਅਸੰਖਾਂ ਹੋਰ ਹੋਰ (ਦੇਵਤਿਆਂ ਦੀ) ਪੂਜਾ ਕਰਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы я совершал поклонение несчётным крорам иных божеств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49829,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਨ ਪੂਜਸਿ ਨਾਮੈ ਹਰੀ ॥੩॥",
          "roman": "Ek na pūjasi nāmē harī. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਉਹ (ਸਾਰੀਆਂ ਮਿਲ ਕੇ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦੀਆਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "всё же все они вместе не сравнятся с Именем Вахегуру. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49830,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵੈ ਨਾਮਦੇਉ ਇਹੁ ਕਰਣਾ ॥",
          "roman": "Praṇvē Nāmdeu ihu karṇā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਬੇਨਤੀ ਕਰਦਾ ਹੈ-(ਮੇਰੀ ਜੀਭ ਲਈ) ਇਹੀ ਕੰਮ ਕਰਨ-ਜੋਗ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Намдев молит: для моего языка достойно делать только это,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49831,
          "is_rahao": false,
          "gurmukhi": "ਅਨੰਤ ਰੂਪ ਤੇਰੇ ਨਾਰਾਇਣਾ ॥੪॥੧॥",
          "roman": "Anant rūp tere Nārāiṇā. 4. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਏ ਤੇ ਆਖੇ-) 'ਹੇ ਨਾਰਾਇਣ! ਤੇਰੇ ਬੇਅੰਤ ਰੂਪ ਹਨ' ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "говорить: «О Нараян! Твои формы беспредельны». 4.1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4147,
      "rahao_verse_id": 49835,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49832,
          "is_rahao": false,
          "gurmukhi": "ਪਰ ਧਨ ਪਰ ਦਾਰਾ ਪਰਹਰੀ ॥",
          "roman": "Par dhan par dārā parharī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਰਾਇਣ ਦਾ ਭਜਨ ਕਰ ਕੇ) ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਾਏ ਧਨ ਤੇ ਪਰਾਈ ਇਸਤ੍ਰੀ ਦਾ ਤਿਆਗ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который отказался от чужого богатства и чужой женщины,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49833,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਨਿਕਟਿ ਬਸੈ ਨਰਹਰੀ ॥੧॥",
          "roman": "Tā kē nikaṭ basē Narharī. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਉਸ ਦੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "рядом с ним пребывает Вахегуру. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49834,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਨ ਭਜੰਤੇ ਨਾਰਾਇਣਾ ॥",
          "roman": "Jo na bhajaṅte Nārāiṇā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਨਹੀਂ ਕਰਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые не поклоняются Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49835,
          "is_rahao": true,
          "gurmukhi": "ਤਿਨ ਕਾ ਮੈ ਨ ਕਰਉ ਦਰਸਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Tin kā mē na karau darsanā. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਹਨਾਂ ਦਾ ਦਰਸ਼ਨ ਨਹੀਂ ਕਰਦਾ (ਭਾਵ, ਮੈਂ ਉਹਨਾਂ ਦੀ ਬੈਠਕ ਨਹੀਂ ਬੈਠਦਾ, ਮੈਂ ਉਹਨਾਂ ਨਾਲ ਬਹਿਣ-ਖਲੋਣ ਨਹੀਂ ਰੱਖਦਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "я не ищу их общества и не смотрю на них. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49836,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕੈ ਭੀਤਰਿ ਹੈ ਅੰਤਰਾ ॥",
          "roman": "Jin kē bhītar hē antarā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਵਿੱਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но те люди, в чьём сердце есть отдалённость от Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49837,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਪਸੁ ਤੈਸੇ ਓਇ ਨਰਾ ॥੨॥",
          "roman": "Jēse pas tēse oi narā. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਸ਼ੂਆਂ ਵਰਗੇ ਹੀ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "такие люди подобны животным. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49838,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵਤਿ ਨਾਮਦੇਉ ਨਾਕਹਿ ਬਿਨਾ ॥",
          "roman": "Praṇvat Nāmdeu nākah binā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਬੇਨਤੀ ਕਰਦਾ ਹੈ- ਨੱਕ ਤੋਂ ਬਿਨਾ-"
            },
            "sahib_singh_ru": {
              "main": "Намдев молвит: без носа"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49839,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸੋਹੈ ਬਤੀਸ ਲਖਨਾ ॥੩॥੨॥",
          "roman": "Nā sohē batīs lakhṇā. 3. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਵਿਚ ਸੁੰਦਰਤਾ ਦੇ ਭਾਵੇਂ ਬੱਤੀ ਦੇ ਬੱਤੀ ਹੀ ਲੱਛਣ ਹੋਣ, ਪਰ ਜੇ ਉਸ ਦਾ ਨੱਕ ਨਾਹ ਹੋਵੇ ਤਾਂ ਉਹ ਸੁਹਣਾ ਨਹੀਂ ਲੱਗਦਾ (ਤਿਵੇਂ, ਹੋਰ ਸਾਰੇ ਗੁਣ ਹੋਣ, ਧਨ ਆਦਿਕ ਭੀ ਹੋਵੇ, ਜੇ ਨਾਮ ਨਹੀਂ ਸਿਮਰਦਾ ਤਾਂ ਕਿਸੇ ਕੰਮ ਦਾ ਨਹੀਂ) ॥੩॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "человек не кажется красивым, даже если у него есть все тридцать два признака красоты. 3.2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4148,
      "rahao_verse_id": 49843,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49840,
          "is_rahao": false,
          "gurmukhi": "ਦੂਧੁ ਕਟੋਰੈ ਗਡਵੈ ਪਾਨੀ ॥ ਕਪਲ ਗਾਇ ਨਾਮੈ ਦੁਹਿ ਆਨੀ ॥੧॥",
          "roman": "Dūdh kaṭorē gaḍvē pānī. Kapal gāe nāmē duhi ānī. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਗੋਬਿੰਦ ਰਾਇ! ਤੇਰੇ ਸੇਵਕ ਨਾਮੇ ਨੇ) ਗੜਵੇ ਵਿਚ ਪਾਣੀ ਪਾਇਆ ਹੈ ਤੇ ਕਟੋਰੇ ਵਿਚ ਦੁੱਧ ਪਾਇਆ ਹੈ ਨਾਮੇ ਨੇ ਗੋਰੀ ਗਾਂ ਚੋ ਕੇ ਲਿਆਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нама налил воду в кувшин, а молоко — в чашу; Нама надоил его от светлой коровы и принёс. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49841,
          "is_rahao": true,
          "gurmukhi": "ਦੂਧੁ ਪੀਉ ਗੋਬਿੰਦੇ ਰਾਇ ॥",
          "roman": "Dūdh pīu Gobinde rāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਰਕਾਸ਼-ਰੂਪ ਗੋਬਿੰਦ! ਦੁੱਧ ਪੀ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Гобинд Рай, выпей молоко,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49842,
          "is_rahao": true,
          "gurmukhi": "ਦੂਧੁ ਪੀਉ ਮੇਰੋ ਮਨੁ ਪਤੀਆਇ ॥",
          "roman": "Dūdh pīu mero man patīāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਧ ਪੀ ਲੈ (ਤਾਂ ਜੋ) ਮੇਰੇ ਮਨ ਨੂੰ ਠੰਢ ਪਏ;"
            },
            "sahib_singh_ru": {
              "main": "выпей молоко, чтобы моё сердце успокоилось;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49843,
          "is_rahao": true,
          "gurmukhi": "ਨਾਹੀ ਤ ਘਰ ਕੋ ਬਾਪੁ ਰਿਸਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Nāhī ta ghar ko bāp risāe. 1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਗੋਬਿੰਦ! ਜੇ ਦੁੱਧ) ਨਹੀਂ (ਪੀਏਂਗਾ) ਤਾਂ ਮੇਰਾ ਆਤਮਾ ਦੁਖੀ ਹੋਵੇਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "а если не выпьешь, моя душа будет страдать. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49844,
          "is_rahao": false,
          "gurmukhi": "ਸੋੁਇਨ ਕਟੋਰੀ ਅੰਮ੍ਰਿਤ ਭਰੀ ॥",
          "roman": "Souin kaṭorī aṃmrit bharī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ-ਅੰਮ੍ਰਿਤ ਦੀ ਭਰੀ ਹੋਈ ਪਵਿੱਤਰ ਹਿਰਦਾ-ਰੂਪ ਕਟੋਰੀ-"
            },
            "sahib_singh_ru": {
              "main": "Чистая чаша-сердце, наполненная нектаром Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49845,
          "is_rahao": false,
          "gurmukhi": "ਲੈ ਨਾਮੈ ਹਰਿ ਆਗੈ ਧਰੀ ॥੨॥",
          "roman": "Lē nāmē har āgē dharī. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮੇ ਨੇ ਲੈ ਕੇ (ਆਪਣੇ) ਹਰੀ ਦੇ ਅੱਗੇ ਰੱਖ ਦਿੱਤੀ ਹੈ, (ਭਾਵ, ਪ੍ਰਭੂ ਦੀ ਯਾਦ ਨਾਲ ਨਿਰਮਲ ਹੋਇਆ ਹਿਰਦਾ ਨਾਮਦੇਵ ਨੇ ਆਪਣੇ ਪ੍ਰਭੂ ਦੇ ਅੱਗੇ ਖੋਲ੍ਹ ਕੇ ਰੱਖ ਦਿੱਤਾ, ਨਾਮਦੇਵ ਦਿਲੀ-ਵਲਵਲੇ ਨਾਲ ਪ੍ਰਭੂ ਅੱਗੇ ਅਰਦਾਸ ਕਰਦਾ ਹੈ ਤੇ ਆਖਦਾ ਹੈ ਕਿ ਮੇਰਾ ਦੁੱਧ ਪੀ ਲੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "её Нама взял и поставил перед своим Хари. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49846,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਭਗਤੁ ਮੇਰੇ ਹਿਰਦੇ ਬਸੈ ॥ ਨਾਮੇ ਦੇਖਿ ਨਰਾਇਨੁ ਹਸੈ ॥੩॥",
          "roman": "Eku bhagat mere hirde basē. Nāme dekhi Narāin hasē. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਅਨੰਨ ਭਗਤ ਸਦਾ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸਦਾ ਹੈ। ਨਾਮੇ ਨੂੰ ਵੇਖ ਵੇਖ ਕੇ ਪਰਮਾਤਮਾ (ਇਉਂ ਆਖਦਾ ਹੈ ਅਤੇ) ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Мой единственный преданный всегда обитает в моём сердце. Видя Наму, Вахегуру радуется и улыбается. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49847,
          "is_rahao": false,
          "gurmukhi": "ਦੂਧੁ ਪੀਆਇ ਭਗਤੁ ਘਰਿ ਗਇਆ ॥",
          "roman": "Dūdh pīāe bhagat ghar gaiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੋਬਿੰਦ ਰਾਇ ਨੂੰ) ਦੁੱਧ ਪਿਆਲ ਕੇ ਭਗਤ (ਨਾਮਦੇਵ) ਸ੍ਵੈ-ਸਰੂਪ ਵਿਚ ਟਿਕ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Напоив Гобинд Рая молоком, бхагат Намдев утвердился в своём подлинном естестве,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
