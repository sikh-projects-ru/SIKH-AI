{
  "ang": 1164,
  "shabads": [
    {
      "shabad_id": 4148,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49848,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਹਰਿ ਕਾ ਦਰਸਨੁ ਭਇਆ ॥੪॥੩॥",
          "roman": "Nāme har kā darsan bhaiā. 4. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਸ੍ਵੈ-ਸਰੂਪ ਵਿਚ) ਮੈਂ (ਨਾਮੇ) ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਦੀਦਾਰ ਹੋਇਆ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и в этом подлинном естестве мне, Наме, открылся даршан Вахегуру. 4.3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4149,
      "rahao_verse_id": 49852,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49849,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਬਉਰੀ ਮੇਰਾ ਰਾਮੁ ਭਤਾਰੁ ॥",
          "roman": "mē baurī merā rām bhatār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਆਪਣੇ ਪ੍ਰਭੂ-ਪਤੀ ਦੀ ਨਾਰ ਬਣ ਚੁੱਕੀ ਹਾਂ) ਪ੍ਰਭੂ ਮੇਰਾ ਖਸਮ ਹੈ ਤੇ ਮੈਂ (ਉਸ ਦੀ ਖ਼ਾਤਰ) ਕਮਲੀ ਹੋ ਰਹੀ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я стала женой моего Господа-мужа; Господь — мой супруг, и я схожу по Нему с ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49850,
          "is_rahao": false,
          "gurmukhi": "ਰਚਿ ਰਚਿ ਤਾ ਕਉ ਕਰਉ ਸਿੰਗਾਰੁ ॥੧॥",
          "roman": "rach rach tā kau karau siṅgār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਮਿਲਣ ਲਈ ਮੈਂ (ਭਗਤੀ ਤੇ ਭਲੇ ਗੁਣਾਂ ਦੇ) ਸੁਹਣੇ ਸੁਹਣੇ ਸ਼ਿੰਗਾਰ ਕਰ ਰਹੀ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы встретить Его, я украшаю себя снова и снова прекрасными украшениями преданности и добродетелей ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49851,
          "is_rahao": true,
          "gurmukhi": "ਭਲੇ ਨਿੰਦਉ ਭਲੇ ਨਿੰਦਉ ਭਲੇ ਨਿੰਦਉ ਲੋਗੁ ॥",
          "roman": "bhalē nindau bhalē nindau bhalē nindau log",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਜਗਤ ਬੇ-ਸ਼ੱਕ ਮੈਨੂੰ ਭੈੜਾ ਆਖੀ ਜਾਏ (ਨਾ ਮੇਰੇ ਕੰਨ ਇਹ ਨਿੰਦਾ ਸੁਣਨ ਦੀ ਪਰਵਾਹ ਕਰਦੇ ਹਨ; ਨਾ ਮੇਰਾ ਮਨ ਨਿੰਦਾ ਸੁਣ ਕੇ ਦੁਖੀ ਹੁੰਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Пусть теперь мир, без сомнения, зовёт меня плохой сколько угодно; мои уши не заботятся о том, чтобы слышать эту хулу, и мой ум не печалится от неё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49852,
          "is_rahao": true,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਰਾਮ ਪਿਆਰੇ ਜੋਗੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tan man rām piārē jog ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਤਨ ਅਤੇ ਮੇਰਾ ਮਨ ਮੇਰੇ ਪਿਆਰੇ ਪ੍ਰਭੂ ਜੋਗੇ ਹੋ ਚੁਕੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "моё тело и мой ум уже посвящены моему Возлюбленному Господу ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49853,
          "is_rahao": false,
          "gurmukhi": "ਬਾਦੁ ਬਿਬਾਦੁ ਕਾਹੂ ਸਿਉ ਨ ਕੀਜੈ ॥",
          "roman": "bād bibād kāhū siu na kījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੋਈ ਨਿੰਦਾ ਪਿਆ ਕਰੇ) ਕਿਸੇ ਨਾਲ ਝਗੜਾ ਕਰਨ ਦੀ ਲੋੜ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то и порицает, нет нужды с кем-либо ссориться,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49854,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਰਾਮ ਰਸਾਇਨੁ ਪੀਜੈ ॥੨॥",
          "roman": "rasnā rām rasāin pījē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਨਾਲ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਸ੍ਰੇਸ਼ਟ ਅੰਮ੍ਰਿਤ ਪੀਣਾ ਚਾਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "языком следует пить высший нектар Имени Господа ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49855,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਜੀਅ ਜਾਨਿ ਐਸੀ ਬਨਿ ਆਈ ॥",
          "roman": "ab jīa jān aisī ban āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਕਰ ਕੇ (ਮੇਰੇ ਅੰਦਰ) ਅਜਿਹੀ ਹਾਲਤ ਬਣ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь, узнав Господа сердцем, во мне установилось такое состояние,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49856,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਉ ਗੁਪਾਲ ਨੀਸਾਨੁ ਬਜਾਈ ॥੩॥",
          "roman": "milau gupāl nīsān bajāī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਮੈਂ ਲੋਕਾਂ ਦੀ ਨਿੰਦਾ ਵਲੋਂ ਬੇ-ਪਰਵਾਹ ਹੋ ਕੇ ਆਪਣੇ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਰਹੀ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "что, не обращая внимания на людскую хулу, я встречаюсь со своим Господом ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49857,
          "is_rahao": false,
          "gurmukhi": "ਉਸਤਤਿ ਨਿੰਦਾ ਕਰੈ ਨਰੁ ਕੋਈ ॥",
          "roman": "ustat nindā karē nar koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ ਮੈਨੂੰ ਚੰਗਾ ਆਖੇ, ਚਾਹੇ ਕੋਈ ਮੰਦਾ ਆਖੇ (ਇਸ ਗੱਲ ਦੀ ਮੈਨੂੰ ਪਰਵਾਹ ਨਹੀਂ ਰਹੀ),"
            },
            "sahib_singh_ru": {
              "main": "Скажет ли кто-то обо мне хорошо, или скажет плохо — мне это уже безразлично,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49858,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਸ੍ਰੀਰੰਗੁ ਭੇਟਲ ਸੋਈ ॥੪॥੪॥",
          "roman": "nāmē srīraṅg bheṭal soī ॥4॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਨਾਮੇ ਨੂੰ (ਲੱਛਮੀ ਦਾ ਪਤੀ) ਪਰਮਾਤਮਾ ਮਿਲ ਪਿਆ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "мне, Наме, встретился Сам Бог, супруг Лакшми ॥4॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4150,
      "rahao_verse_id": 49863,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49859,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਖੀਰਿ ਖਾਡ ਘੀਉ ਨ ਭਾਵੈ ॥",
          "roman": "kabhū khīr khāḍ ghīu na bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ (ਕੋਈ ਜੀਵ ਐਸੀ ਮੌਜ ਵਿਚ ਹੈ ਕਿ ਉਸ ਨੂੰ) ਖੀਰ, ਖੰਡ, ਘਿਉ (ਵਰਗੇ ਸੁਹਣੇ ਪਦਾਰਥ) ਭੀ ਚੰਗੇ ਨਹੀਂ ਲੱਗਦੇ;"
            },
            "sahib_singh_ru": {
              "main": "Иногда живое существо пребывает в таком довольстве, что даже кхир, сахар и топлёное масло ему не нравятся;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49860,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਘਰ ਘਰ ਟੂਕ ਮਗਾਵੈ ॥",
          "roman": "kabhū ghar ghar ṭūk magāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਦੇ (ਉਸ ਪਾਸੋਂ) ਘਰ ਘਰ ਦੇ ਟੁੱਕਰ ਮੰਗਾਉਂਦਾ ਹੈ (ਕਦੇ ਉਸ ਨੂੰ ਮੰਗਤਾ ਬਣਾ ਦੇਂਦਾ ਹੈ, ਤੇ ਉਹ ਘਰ ਘਰ ਦੇ ਟੁਕੜੇ ਮੰਗਦਾ ਫਿਰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "а иногда Он заставляет его просить куски хлеба от дома к дому,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49861,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਕੂਰਨੁ ਚਨੇ ਬਿਨਾਵੈ ॥੧॥",
          "roman": "kabhū kūran chanē bināvē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ (ਉਸ ਪਾਸੋਂ) ਰੂੜੀਆਂ ਫੁਲਾਉਂਦਾ ਹੈ, ਤੇ (ਉਹਨਾਂ ਵਿਚੋਂ) ਦਾਣੇ ਚੁਣਾਉਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "иногда заставляет веять сор и выбирать из него зёрна ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49862,
          "is_rahao": true,
          "gurmukhi": "ਜਿਉ ਰਾਮੁ ਰਾਖੈ ਤਿਉ ਰਹੀਐ ਰੇ ਭਾਈ ॥",
          "roman": "jiu rām rākhē tiu rahīē rē bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਹਾਲਤ ਵਿਚ ਪਰਮਾਤਮਾ (ਸਾਨੂੰ ਜੀਵਾਂ ਨੂੰ) ਰੱਖਦਾ ਹੈ ਉਸੇ ਹਾਲਤ ਵਿਚ (ਅਮੀਰੀ ਦੀ ਆਕੜ ਤੇ ਗਰੀਬੀ ਦੀ ਘਬਰਾਹਟ ਤੋਂ ਨਿਰਲੇਪ) ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В каком состоянии Бог нас держит, в том и следует жить, оставаясь непривязанным и к гордости богатства, и к тревоге бедности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49863,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੀ ਮਹਿਮਾ ਕਿਛੁ ਕਥਨੁ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har kī mahimā kichh kathan na jāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਗੱਲ ਦੱਸੀ ਨਹੀਂ ਜਾ ਸਕਦੀ ਕਿ ਪਰਮਾਤਮਾ ਕੇਡਾ ਵੱਡਾ ਹੈ (ਸਾਡੇ ਦੁਖਾਂ ਸੁਖਾਂ ਦਾ ਭੇਤ ਉਹ ਹੀ ਜਾਣਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Невозможно высказать, насколько велик Господь; только Он знает тайну наших страданий и радостей ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49864,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਤੁਰੇ ਤੁਰੰਗ ਨਚਾਵੈ ॥",
          "roman": "kabhū turē turaṅg nachāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ (ਕੋਈ ਮਨੁੱਖ ਇਤਨਾ ਅਮੀਰ ਹੈ ਕਿ ਉਹ) ਸੋਹਣੇ ਘੋੜੇ ਨਚਾਉਂਦਾ ਹੈ (ਭਾਵ, ਕਦੇ ਉਸ ਪਾਸ ਐਸੀ ਸੁਹਣੀ ਚਾਲ ਵਾਲੇ ਘੋੜੇ ਹਨ ਕਿ ਚੱਲਣ ਵੇਲੇ, ਮਾਨੋ, ਉਹ ਨੱਚ ਰਹੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "Иногда человек так богат, что выводит прекрасных коней, будто танцующих на ходу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49865,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਪਾਇ ਪਨਹੀਓ ਨ ਪਾਵੈ ॥੨॥",
          "roman": "kabhū pāi panahīo na pāvē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਦੇ ਉਸ ਨੂੰ ਪੈਰੀਂ ਜੁੱਤੀ (ਪਾਣ ਜੋਗੀ) ਭੀ ਨਹੀਂ ਲੱਭਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а иногда не находит даже обуви на ноги ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49866,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਖਾਟ ਸੁਪੇਦੀ ਸੁਵਾਵੈ ॥",
          "roman": "kabhū khāṭ supēdī suvāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਕਿਸੇ ਮਨੁੱਖ ਨੂੰ ਚਿੱਟੇ ਵਿਛਾਉਣਿਆਂ ਵਾਲੇ ਪਲੰਘਾਂ ਉੱਤੇ ਸੁਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иногда человека укладывают на кровати с белыми постелями,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49867,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਭੂਮਿ ਪੈਆਰੁ ਨ ਪਾਵੈ ॥੩॥",
          "roman": "kabhū bhūm pēār na pāvē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਦੇ ਉਸ ਨੂੰ ਭੁੰਞੇ (ਵਿਛਾਉਣ ਲਈ) ਪਰਾਲੀ ਭੀ ਨਹੀਂ ਮਿਲਦੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "а иногда ему не достаётся даже соломы, чтобы постелить на земле ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49868,
          "is_rahao": false,
          "gurmukhi": "ਭਨਤਿ ਨਾਮਦੇਉ ਇਕੁ ਨਾਮੁ ਨਿਸਤਾਰੈ ॥",
          "roman": "bhanat nāmdeu ik nām nistārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਆਖਦਾ ਹੈ ਕਿ ਪ੍ਰਭੂ ਦਾ ਇਕ ਨਾਮ ਹੀ ਹੈ ਜੋ (ਇਹਨਾਂ ਦੋਹਾਂ ਹਾਲਤਾਂ ਵਿਚੋਂ ਅਛੋਹ ਰੱਖ ਕੇ) ਪਾਰ ਲੰਘਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Намдев говорит: только одно Имя Господа переправляет через всё это, сохраняя непричастным к обоим состояниям,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49869,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਗੁਰੁ ਮਿਲੈ ਤਿਹ ਪਾਰਿ ਉਤਾਰੈ ॥੪॥੫॥",
          "roman": "jih gur milē tih pār utārē ॥4॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲਦਾ ਹੈ ਉਸ ਨੂੰ ਪ੍ਰਭੂ (ਅਮੀਰੀ ਦੀ ਆਕੜ ਤੇ ਗਰੀਬੀ ਦੀ ਘਬਰਾਹਟ) ਤੋਂ ਪਾਰ ਉਤਾਰਦਾ ਹੈ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "кого встречает Гуру, того Господь выводит за пределы и гордыни богатства, и тревоги бедности ॥4॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4151,
      "rahao_verse_id": 49873,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49870,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤ ਖੇਲਤ ਤੇਰੇ ਦੇਹੁਰੇ ਆਇਆ ॥",
          "roman": "hast khēlat tērē dēhurē āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਬੜੇ ਚਾਅ ਨਾਲ ਤੇਰੇ ਮੰਦਰ ਆਇਆ ਸਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я пришёл в Твой храм с великой радостью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49871,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰਤ ਨਾਮਾ ਪਕਰਿ ਉਠਾਇਆ ॥੧॥",
          "roman": "bhagat karat nāmā pakar uṭhāiā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਚੂੰ ਕਿ ਇਹ ਲੋਕ 'ਮੇਰੀ ਜਾਤਿ ਹੀਨੜੀ' ਸਮਝਦੇ ਹਨ, ਇਹਨਾਂ) ਮੈਨੂੰ ਨਾਮੇ ਨੂੰ ਭਗਤੀ ਕਰਦੇ ਨੂੰ (ਬਾਹੋਂ) ਫੜ ਕੇ (ਮੰਦਰ ਵਿਚੋਂ) ਉਠਾਲ ਦਿੱਤਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но, поскольку эти люди считают мою касту низкой, меня, Наму, во время поклонения схватили за руки и вытащили из храма ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49872,
          "is_rahao": true,
          "gurmukhi": "ਹੀਨੜੀ ਜਾਤਿ ਮੇਰੀ ਜਾਦਿਮ ਰਾਇਆ ॥",
          "roman": "hīnṛī jāt mērī jādim rāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਾਦਵ ਕੁਲ ਦੇ ਸ਼ਿਰੋਮਣੀ! ਹੇ ਕ੍ਰਿਸ਼ਨ! ਹੇ ਪ੍ਰਭੂ! (ਲੋਕ) ਮੇਰੀ ਜਾਤ ਨੂੰ ਬੜੀ ਨੀਵੀਂ (ਆਖਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "О венец рода Ядавов! О Кришна! О Господь! Люди называют мою касту очень низкой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49873,
          "is_rahao": true,
          "gurmukhi": "ਛੀਪੇ ਕੇ ਜਨਮਿ ਕਾਹੇ ਕਉ ਆਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "chhīpē kē janam kāhē kau āiā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਛੀਂਬੇ ਦੇ ਘਰ ਕਿਉਂ ਜੰਮ ਪਿਆ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Господи, зачем я родился в доме чхимбы? ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49874,
          "is_rahao": false,
          "gurmukhi": "ਲੈ ਕਮਲੀ ਚਲਿਓ ਪਲਟਾਇ ॥",
          "roman": "lē kamlī chaliō palaṭāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੀ ਕੰਬਲੀ ਲੈ ਕੇ (ਉੱਥੋਂ) ਮੁੜ ਕੇ ਤੁਰ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Я взял своё одеяло и повернул назад,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49875,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹੁਰੈ ਪਾਛੈ ਬੈਠਾ ਜਾਇ ॥੨॥",
          "roman": "dēhurē pāchhē bēṭhā jāi ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ ਤੇਰੇ ਮੰਦਰ ਦੇ ਪਿਛਲੇ ਪਾਸੇ ਜਾ ਕੇ ਬਹਿ ਗਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, Господи, пошёл и сел позади Твоего храма ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49876,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜਿਉ ਨਾਮਾ ਹਰਿ ਗੁਣ ਉਚਰੈ ॥",
          "roman": "jiu jiu nāmā har guṇ ucharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਪ੍ਰਭੂ ਦੀ ਅਚਰਜ ਖੇਡ ਵਰਤੀ) ਜਿਉਂ ਜਿਉਂ ਨਾਮਾ ਆਪਣੇ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но проявилась дивная игра Господа: чем больше Нама произносил качества Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49877,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਜਨਾਂ ਕਉ ਦੇਹੁਰਾ ਫਿਰੈ ॥੩॥੬॥",
          "roman": "bhagat janāṅ kau dēhurā phirē ॥3॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦਾ) ਮੰਦਰ (ਉਸ ਦੇ) ਭਗਤਾਂ ਦੀ ਖ਼ਾਤਰ, (ਉਸ ਦੇ) ਸੇਵਕਾਂ ਦੀ ਖ਼ਾਤਰ ਫਿਰਦਾ ਜਾ ਰਿਹਾ ਹੈ ॥੩॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "тем больше храм обращался к Его бхактам, к Его слугам ॥3॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4152,
      "rahao_verse_id": 49885,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49878,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਨਾਮਦੇਉ ਜੀਉ ਘਰੁ ੨",
          "roman": "bhērau nāmdeu jīu ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਭੈਰਉ, ਘਰ ੨ ਵਿੱਚ ਭਗਤ ਨਾਮਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Бхайрау, Бани бхагата Намдева Джи, дом 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49879,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oañkār satigur prasād ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49880,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਭੂਖੇ ਪ੍ਰੀਤਿ ਅਨਾਜ ॥",
          "roman": "jēsī bhūkhē prīt anāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਭੁੱਖੇ ਮਨੁੱਖ ਨੂੰ ਅੰਨ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как голодному человеку дорог хлеб,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49881,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਖਾਵੰਤ ਜਲ ਸੇਤੀ ਕਾਜ ॥",
          "roman": "trikhāvant jal sētī kāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਿਆਸੇ ਨੂੰ ਪਾਣੀ ਨਾਲ ਗ਼ਰਜ਼ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как жаждущий нуждается в воде,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49882,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਮੂੜ ਕੁਟੰਬ ਪਰਾਇਣ ॥",
          "roman": "jēsī mūṛ kuṭamb parāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਮੂਰਖ ਆਪਣੇ ਟੱਬਰ ਦੇ ਆਸਰੇ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как глупец полагается на свою семью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49883,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਨਾਮੇ ਪ੍ਰੀਤਿ ਨਰਾਇਣ ॥੧॥",
          "roman": "aisī nāmē prīt narāiṇ ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ (ਮੈਂ) ਨਾਮੇ ਦਾ ਪ੍ਰਭੂ ਨਾਲ ਪਿਆਰ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "такова любовь Намы к Нарайану ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49884,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੇ ਪ੍ਰੀਤਿ ਨਾਰਾਇਣ ਲਾਗੀ ॥",
          "roman": "nāmē prīt nārāiṇ lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੀ) ਨਾਮਦੇਵ ਦੀ ਪ੍ਰੀਤ ਪਰਮਾਤਮਾ ਨਾਲ ਲੱਗ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Любовь Намдева прилепилась к Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49885,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਸੁਭਾਇ ਭਇਓ ਬੈਰਾਗੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sahaj subhāi bhēō bērāgī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪ੍ਰੀਤ ਦੀ ਬਰਕਤਿ ਨਾਲ, ਨਾਮਦੇਵ) ਕੋਈ ਬਾਹਰਲੇ ਭੇਖ ਆਦਿਕ ਦਾ ਉਚੇਚ ਕਰਨ ਤੋਂ ਬਿਨਾ ਹੀ ਬੈਰਾਗੀ ਬਣ ਗਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и по её благодати он без всякого внешнего наряда и усилий стал отрешённым ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49886,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਪਰ ਪੁਰਖਾ ਰਤ ਨਾਰੀ ॥",
          "roman": "jēsī par purkhā rat nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਨਾਰ ਪਰਾਏ ਮਨੁੱਖ ਨਾਲ ਪਿਆਰ ਪਾ ਲੈਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как женщина влюбляется в постороннего мужчину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49887,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭੀ ਨਰੁ ਧਨ ਕਾ ਹਿਤਕਾਰੀ ॥",
          "roman": "lobhī nar dhan kā hitkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕਿਸੇ ਲੋਭੀ ਮਨੁੱਖ ਨੂੰ ਧਨ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "как алчному человеку дорого богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49888,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੀ ਪੁਰਖ ਕਾਮਨੀ ਪਿਆਰੀ ॥",
          "roman": "kāmī purakh kāmnī piārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕਿਸੇ ਵਿਸ਼ਈ ਬੰਦੇ ਨੂੰ ਇਸਤ੍ਰੀ ਚੰਗੀ ਲੱਗਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как похотливому человеку приятна женщина,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49889,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਨਾਮੇ ਪ੍ਰੀਤਿ ਮੁਰਾਰੀ ॥੨॥",
          "roman": "aisī nāmē prīt murārī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਨਾਮੇ ਨੂੰ ਪਰਮਾਤਮਾ ਮਿੱਠਾ ਲੱਗਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так же Наме сладок Господь ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49890,
          "is_rahao": false,
          "gurmukhi": "ਸਾਈ ਪ੍ਰੀਤਿ ਜਿ ਆਪੇ ਲਾਏ ॥",
          "roman": "sāī prīt j āpē lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਅਸਲੀ ਸੁੱਚਾ ਪਿਆਰ ਉਹ ਹੈ ਜੋ ਪ੍ਰਭੂ ਆਪ (ਕਿਸੇ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਪੈਦਾ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Но подлинная чистая любовь — та, которую Сам Господь зарождает в сердце человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49891,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਦੁਬਿਧਾ ਜਾਏ ॥",
          "roman": "gur parsādī dubidhā jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਮੇਰ-ਤੇਰ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਟ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и у такого человека по милости Гуру исчезает двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49892,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੁ ਨ ਤੂਟਸਿ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "kabah na ṭūṭas rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਪ੍ਰਭੂ ਨਾਲ ਪ੍ਰੇਮ ਕਦੇ ਟੁੱਟਦਾ ਨਹੀਂ, ਹਰ ਵੇਲੇ ਉਹ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его любовь к Господу никогда не рвётся; он всегда остаётся погружённым в стопы Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49893,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਚਿਤੁ ਲਾਇਆ ਸਚਿ ਨਾਇ ॥੩॥",
          "roman": "nāmē chit lāiā sach nāi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਨਾਮੇ ਉੱਤੇ ਭੀ ਪ੍ਰਭੂ ਦੀ ਮਿਹਰ ਹੋਈ ਹੈ ਤੇ) ਨਾਮੇ ਦਾ ਚਿੱਤ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਹਰਿ-ਨਾਮ ਵਿਚ ਟਿਕ ਗਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И на меня, Наму, тоже пал взор милости: мой ум утвердился в вечном Имени Хари ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49894,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਪ੍ਰੀਤਿ ਬਾਰਿਕ ਅਰੁ ਮਾਤਾ ॥",
          "roman": "jēsī prīt bārik aru mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਾਂ-ਪੁੱਤਰ ਦਾ ਪਿਆਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Какова любовь матери и ребёнка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49895,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਹਰਿ ਸੇਤੀ ਮਨੁ ਰਾਤਾ ॥",
          "roman": "aisā har sētī man rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਮੇਰਾ ਮਨ ਪ੍ਰਭੂ! (-ਚਰਨਾਂ) ਨਾਲ ਰੰਗਿਆ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так и мой ум окрашен Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49896,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵੈ ਨਾਮਦੇਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "praṇvē nāmdeu lāgī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਬੇਨਤੀ ਕਰਦਾ ਹੈ-ਮੇਰੀ ਪ੍ਰਭੂ ਨਾਲ ਪ੍ਰੀਤ ਲੱਗ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Намдев молитвенно говорит: ко мне пришла любовь к Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49897,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿਦੁ ਬਸੈ ਹਮਾਰੈ ਚੀਤਿ ॥੪॥੧॥੭॥",
          "roman": "gobid basē hamārē chīt ॥4॥1॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ (ਹੁਣ ਸਦਾ) ਮੇਰੇ ਚਿੱਤ ਵਿਚ ਵੱਸਦਾ ਹੈ ॥੪॥੧॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и теперь Господь всегда обитает в моём сердце ॥4॥1॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4153,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49898,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਕੀ ਨਾਰਿ ਤਿਆਗੈ ਅੰਧਾ ॥",
          "roman": "ghar kī nār tiāgē añdhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹਾ (ਪਾਪੀ) ਆਪਣੀ ਵਹੁਟੀ ਛੱਡ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слепой грешник оставляет свою жену,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
