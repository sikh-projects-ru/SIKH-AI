{
  "ang": 1169,
  "shabads": [
    {
      "shabad_id": 4161,
      "rahao_verse_id": 50093,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50093,
          "is_rahao": true,
          "gurmukhi": "ਜਾਮਿ ਨ ਭੀਜੈ ਸਾਚ ਨਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jām na bhījē sāc nāi.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤਕ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਸੱਚੇ ਨਾਮ ਵਿਚ ਨਹੀਂ ਭਿੱਜਦਾ (ਪ੍ਰੀਤ ਨਹੀਂ ਪਾਂਦਾ, ਉਸ ਦਾ ਕੋਈ ਭੀ ਉੱਦਮ ਪ੍ਰਭੂ ਨੂੰ ਪਸੰਦ ਨਹੀਂ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Пока человек не пропитается истинным Именем Бога, пока не полюбит Его, никакое его усилие не угодно Господу. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50094,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਅਠ ਲੀਖੇ ਹੋਵਹਿ ਪਾਸਿ ॥",
          "roman": "das aṭh līkhē hovah pās.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕਿਸੇ ਪੰਡਿਤ ਨੇ ਅਠਾਰਾਂ ਪੁਰਾਣ ਲਿਖ ਕੇ ਕੋਲ ਰੱਖੇ ਹੋਏ ਹੋਣ,"
            },
            "sahib_singh_ru": {
              "main": "Если у какого-нибудь пандита рядом лежат написанные им восемнадцать Пуран,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50095,
          "is_rahao": false,
          "gurmukhi": "ਚਾਰੇ ਬੇਦ ਮੁਖਾਗਰ ਪਾਠਿ ॥",
          "roman": "chārē bēd mukhāgar pāṭh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਪਾਠ ਵਿਚ ਉਹ ਚਾਰੇ ਵੇਦ ਜ਼ਬਾਨੀ ਪੜ੍ਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "если он наизусть читает все четыре Веды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50096,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਬੀ ਨਾਵੈ ਵਰਨਾਂ ਕੀ ਦਾਤਿ ॥",
          "roman": "purbī nāvē varṇāṅ kī dāt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਪਵਿਤ੍ਰ (ਮਿਥੇ) ਦਿਹਾੜਿਆਂ ਤੇ ਤੀਰਥੀਂ ਇਸ਼ਨਾਨ ਕਰੇ, ਸ਼ਾਸਤ੍ਰਾਂ ਦੀ ਦੱਸੀ ਮਰਯਾਦਾ ਅਨੁਸਾਰ ਵਖ ਵਖ ਵਰਨਾਂ ਦੇ ਬੰਦਿਆਂ ਨੂੰ ਦਾਨ-ਪੁੰਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "если он в священные назначенные дни совершает омовения в местах паломничества и раздаёт милостыню людям разных варн по предписанному шастрами обычаю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50097,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤ ਨੇਮ ਕਰੇ ਦਿਨ ਰਾਤਿ ॥੨॥",
          "roman": "varat nēm karē din rāt.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਦਿਨ ਰਾਤ ਵਰਤ ਰੱਖਦਾ ਰਹੇ ਤੇ ਹੋਰ ਨਿਯਮ ਨਿਬਾਹੁੰਦਾ ਰਹੇ (ਤਾਂ ਭੀ ਪ੍ਰਭੂ ਨੂੰ ਇਹ ਕੋਈ ਉੱਦਮ ਪਸੰਦ ਨਹੀਂ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "если он днём и ночью соблюдает посты и исполняет прочие правила, — всё равно Господу такие усилия не угодны. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50098,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਮੁਲਾਂ ਹੋਵਹਿ ਸੇਖ ॥",
          "roman": "kājī mulāṅ hovah sēkh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਬੰਦੇ ਕਾਜ਼ੀ ਮੁੱਲਾਂ ਸ਼ੇਖ਼ ਬਣ ਜਾਣ,"
            },
            "sahib_singh_ru": {
              "main": "Если люди станут кāзи, муллами или шейхами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50099,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਜੰਗਮ ਭਗਵੇ ਭੇਖ ॥",
          "roman": "jōgī jaṅgam bhagvē bhēkh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਜੋਗੀ ਜੰਗਮ ਬਣ ਕੇ ਭਗਵੇ ਕੱਪੜੇ ਪਹਿਨ ਲੈਣ,"
            },
            "sahib_singh_ru": {
              "main": "если кто-то станет йогом или джангамом и наденет шафрановые одежды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50100,
          "is_rahao": false,
          "gurmukhi": "ਕੋ ਗਿਰਹੀ ਕਰਮਾ ਕੀ ਸੰਧਿ ॥",
          "roman": "kō girahī karmā kī saṅdh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਗ੍ਰਿਹਸਤੀ ਬਣ ਕੇ ਪੂਰਾ ਕਰਮ-ਕਾਂਡੀ ਹੋ ਜਾਏ-"
            },
            "sahib_singh_ru": {
              "main": "если кто-то, будучи домохозяином, станет совершенным исполнителем ритуальных действий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50101,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਸਭ ਖੜੀਅਸਿ ਬੰਧਿ ॥੩॥",
          "roman": "bin būjhē sabh khaṛīas baṅdh.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਵਿਚੋਂ ਹਰੇਕ ਦੋਸੀਆਂ ਵਾਂਗ ਬੰਨ੍ਹ ਕੇ ਅੱਗੇ ਲਾ ਲਿਆ ਜਾਇਗਾ, ਜਦ ਤਕ ਉਹ ਸਿਮਰਨ ਦੀ ਕਦਰ ਨਹੀਂ ਸਮਝਿਆ, (ਜਦ ਤਕ ਉਹ ਸੱਚੇ ਨਾਮ ਵਿਚ ਨਹੀਂ ਪਤੀਜਦਾ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "каждый из них будет связан и уведён вперёд, как виновный, пока не поймёт ценность симрана, пока не утвердится в истинном Имени. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50102,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਜੀਅ ਲਿਖੀ ਸਿਰਿ ਕਾਰ ॥",
          "roman": "jētē jīa likhī sir kār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ ਗੱਲ ਇਹ ਹੈ ਕਿ) ਜਿਤਨੇ ਭੀ ਜੀਵ ਹਨ ਸਭਨਾਂ ਦੇ ਸਿਰ ਉਤੇ ਪ੍ਰਭੂ ਦਾ ਇਹੀ ਹੁਕਮ-ਰੂਪ ਲੇਖ ਲਿਖਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Истинное положение таково: над головами всех существ записано повеление Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50103,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੀ ਉਪਰਿ ਹੋਵਗਿ ਸਾਰ ॥",
          "roman": "karaṇī upar hovg sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਹਰੇਕ ਦੀ ਕਾਮਯਾਬੀ ਦਾ ਫ਼ੈਸਲਾ ਉਸ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਉਤੇ ਹੀ ਹੋਵੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "что решение об успехе каждого будет вынесено только по его делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50104,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਕਰਹਿ ਮੂਰਖ ਗਾਵਾਰ ॥",
          "roman": "hukam karah mūrakh gāvār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਬੰਦੇ ਸੁੱਚੇ ਕਰਮ-ਕਾਂਡ ਭੇਖ ਆਦਿਕ ਉਤੇ ਹੀ ਮਾਣ ਕਰਦੇ ਹਨ ਉਹ ਵੱਡੇ ਮੂਰਖ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые гордятся одной лишь внешней чистотой, ритуалами и одеяниями, — великие невежды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50105,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੇ ਕੇ ਸਿਫਤਿ ਭੰਡਾਰ ॥੪॥੩॥",
          "roman": "nānak sāchē kē sifat bhaṇḍār.4.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀਆਂ ਸਿਫ਼ਤਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਭਰੇ ਪਏ ਹਨ (ਉਹਨਾਂ ਵਿਚ ਜੁੜੋ। ਇਹੀ ਹੈ ਪਰਵਾਨ ਹੋਣ ਵਾਲੀ ਕਰਣੀ) ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Сокровищницы хвалы Вечного Господа переполнены — соединяйтесь с ними. Вот что есть действительно принимаемое деяние. ॥4॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4162,
      "rahao_verse_id": 50112,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50106,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੩ ਤੀਜਾ ॥",
          "roman": "basant mahalā 3 tījā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50107,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤ੍ਰ ਉਤਾਰਿ ਦਿਗੰਬਰੁ ਹੋਗੁ ॥",
          "roman": "bastra utār digambar hog ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਕੱਪੜੇ ਉਤਾਰ ਕੇ ਨਾਂਗਾ ਸਾਧੂ ਬਣ ਜਾਏ (ਤਾਂ ਭੀ ਵਿਅਰਥ ਹੀ ਉੱਦਮ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Если человек снимет одежду и станет нагим аскетом, то и это будет лишь напрасным усилием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50108,
          "is_rahao": false,
          "gurmukhi": "ਜਟਾਧਾਰਿ ਕਿਆ ਕਮਾਵੈ ਜੋਗੁ ॥",
          "roman": "jaṭādhār kiā kamāvē jog ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਟਾ ਧਾਰ ਕੇ ਭੀ ਕੋਈ ਜੋਗ ਨਹੀਂ ਕਮਾਇਆ ਜਾ ਸਕਦਾ। (ਪਰਮਾਤਮਾ ਨਾਲ ਜੋਗ (ਮੇਲ) ਨਹੀਂ ਹੋ ਸਕੇਗਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Даже нося джаты, нельзя обрести подлинный йог, нельзя достичь соединения с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50109,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਨਿਰਮਲੁ ਨਹੀ ਦਸਵੈ ਦੁਆਰ ॥",
          "roman": "man nirmal nahī dasvē duār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਸਵੇਂ ਦੁਆਰ ਵਿਚ ਪ੍ਰਾਣ ਚੜ੍ਹਾਇਆਂ ਭੀ ਮਨ ਪਵਿਤ੍ਰ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Даже если поднимать жизненную силу к десятой двери, ум не становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50110,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮਿ ਭ੍ਰਮਿ ਆਵੈ ਮੂੜੑਾ ਵਾਰੋ ਵਾਰ ॥੧॥",
          "roman": "bharam bharam āvē mūṛhā vāro vār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਜੇਹੇ ਸਾਧਨਾਂ ਵਿਚ ਲੱਗਾ ਹੋਇਆ) ਮੂਰਖ ਭਟਕ ਭਟਕ ਕੇ ਮੁੜ ਮੁੜ ਜਨਮ ਲੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Такой глупец, занятый подобными средствами, блуждая и блуждая, снова и снова рождается ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50111,
          "is_rahao": true,
          "gurmukhi": "ਏਕੁ ਧਿਆਵਹੁ ਮੂੜੑ ਮਨਾ ॥",
          "roman": "ēk dhiāvah mūṛh manā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ ਮਨ! ਇਕ ਪਰਮਾਤਮਾ ਨੂੰ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "О глупый ум, помни одного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50112,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਿ ਉਤਰਿ ਜਾਹਿ ਇਕ ਖਿਨਾਂ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pār utar jāhi ik khināṅ ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਇਕ ਪਲ ਵਿਚ ਹੀ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਹਿਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "По благодати этого памятования ты уже в одно мгновение переправишься через мирской океан ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50113,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮ੍ਰਿਤਿ ਸਾਸਤ੍ਰ ਕਰਹਿ ਵਖਿਆਣ ॥",
          "roman": "simrit sāsatr karah vakhiyāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪੰਡਿਤ ਲੋਕ) ਸਿਮ੍ਰਿਤੀਆਂ ਤੇ ਸ਼ਾਸਤ੍ਰ (ਹੋਰਨਾਂ ਨੂੰ ਪੜ੍ਹ ਪੜ੍ਹ ਕੇ) ਸੁਣਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Пандиты читают и разъясняют другим смрити и шастры,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50114,
          "is_rahao": false,
          "gurmukhi": "ਨਾਦੀ ਬੇਦੀ ਪੜੑਹਿ ਪੁਰਾਣ ॥",
          "roman": "nādī bēdī paṛhah purāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗੀ ਨਾਦ ਵਜਾਂਦੇ ਹਨ, ਪੰਡਿਤ ਵੇਦ ਪੜ੍ਹਦੇ ਹਨ, ਕੋਈ ਪੁਰਾਣ ਪੜ੍ਹਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "йоги издают нады, пандиты читают Веды, кто-то читает Пураны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50115,
          "is_rahao": false,
          "gurmukhi": "ਪਾਖੰਡ ਦ੍ਰਿਸਟਿ ਮਨਿ ਕਪਟੁ ਕਮਾਹਿ ॥",
          "roman": "pākhaṇḍ driśaṭ man kapaṭ kamāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਹਨਾਂ ਦੀ ਨਿਗਾਹ ਪਖੰਡ ਵਾਲੀ ਹੈ, ਮਨ ਵਿਚ ਉਹ ਖੋਟ ਕਮਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "но взгляд у них лицемерный, а в уме они творят ложь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50116,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕੈ ਰਮਈਆ ਨੇੜਿ ਨਾਹਿ ॥੨॥",
          "roman": "tin kē ramaīā nēṛ nāhi ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਅਜੇਹੇ ਬੰਦਿਆਂ ਦੇ ਨੇੜੇ ਨਹੀਂ (ਢੁਕਦਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Бог не приближается к таким людям ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50117,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਐਸਾ ਸੰਜਮੀ ਹੋਇ ॥",
          "roman": "jē kō aisā sanjamī hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਅਜੇਹਾ ਬੰਦਾ ਭੀ ਹੋਵੇ ਜੋ ਆਪਣੇ ਇੰਦ੍ਰਿਆਂ ਨੂੰ ਵੱਸ ਕਰਨ ਦੇ ਜਤਨ ਕਰਦਾ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если найдётся и такой человек, который старается обуздать свои чувства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50118,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਆ ਵਿਸੇਖ ਪੂਜਾ ਕਰੇਇ ॥",
          "roman": "kriā visēkh pūjā karēi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਉਚੇਚੀ ਕਿਸਮ ਦੀ ਕ੍ਰਿਆ ਕਰਦਾ ਹੋਵੇ, ਦੇਵ-ਪੂਜਾ ਭੀ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "совершает особые обряды и даже поклоняется божествам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50119,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਲੋਭੁ ਮਨੁ ਬਿਖਿਆ ਮਾਹਿ ॥",
          "roman": "antar lōbh man bikhiyā māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇ ਉਸ ਦੇ ਅੰਦਰ ਲੋਭ ਹੈ, ਜੇ ਉਸ ਦਾ ਮਨ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੀ ਫਸਿਆ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но если внутри у него жадность, если его ум всё ещё запутан в привязанности к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50120,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਨਿਰੰਜਨੁ ਕੈਸੇ ਪਾਹਿ ॥੩॥",
          "roman": "oi nirañjan kēsē pāhi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਅਜੇਹੇ ਬੰਦੇ ਭੀ ਮਾਇਆ ਤੋਂ ਨਿਰਲੇਪ ਪਰਮਾਤਮਾ ਦੀ ਪ੍ਰਾਪਤੀ ਨਹੀਂ ਕਰ ਸਕਦੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то и такие люди не могут достичь Нирянджана, Бога, не затронутого майей ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50121,
          "is_rahao": false,
          "gurmukhi": "ਕੀਤਾ ਹੋਆ ਕਰੇ ਕਿਆ ਹੋਇ ॥",
          "roman": "kītā hoā karē kiā hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵਾਂ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਸਭ ਕੁਝ ਪਰਮਾਤਮਾ ਦਾ ਕੀਤਾ ਹੋ ਰਿਹਾ ਹੈ। ਜੀਵ ਦੇ ਕੀਤਿਆਂ ਕੁਝ ਨਹੀਂ ਹੋ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Но что вообще во власти существ? Всё происходит по деянию Бога, и от действий существа ничего не может произойти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50122,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਆਪਿ ਚਲਾਏ ਸੋਇ ॥",
          "roman": "jis nō āp chalāē soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਨੂੰ ਜਿਵੇਂ ਪਰਮਾਤਮਾ ਜੀਵਨ ਪੰਧ ਉੱਤੇ ਤੋਰਿਆ ਚਾਹੁੰਦਾ ਹੈ, (ਉਹ ਜੀਵ ਉਹੀ ਰਸਤਾ ਅਖ਼ਤਿਆਰ ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "По какому пути Бог хочет повести существо по жизни, тот путь оно и выбирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50123,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਤਾਂ ਭਰਮੁ ਚੁਕਾਏ ॥",
          "roman": "nadar karē tāṅ bharam chukāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਆਪ (ਕਿਸੇ ਜੀਵ ਉਤੇ) ਮੇਹਰ ਦੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ ਤਾਂ ਉਸ ਦੀ ਭਟਕਣਾ ਦੂਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда Сам Господь бросает на кого-то милостивый взгляд, Он устраняет его блуждание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50124,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੈ ਬੂਝੈ ਤਾਂ ਸਾਚਾ ਪਾਏ ॥੪॥",
          "roman": "hukamē būjhē tāṅ sāchā pāē ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ ਹੀ ਜਦੋਂ ਜੀਵ) ਪ੍ਰਭੂ ਦਾ ਹੁਕਮ ਸਮਝਦਾ ਹੈ ਤਾਂ ਉਸ ਦਾ ਮਿਲਾਪ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "И когда по Его милости человек понимает Его Хукам, тогда он обретает встречу с Истинным ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50125,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਜੀਉ ਅੰਤਰੁ ਮੈਲਾ ਹੋਇ ॥",
          "roman": "jis jīu antar mēlā hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਅੰਦਰਲਾ ਆਤਮਾ (ਵਿਕਾਰਾਂ ਨਾਲ) ਮੈਲਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если внутреннее существо человека становится нечистым от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50126,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥ ਭਵੈ ਦਿਸੰਤਰ ਲੋਇ ॥",
          "roman": "tīrath bhavē disaṅtar loi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੇ ਤੀਰਥਾਂ ਉਤੇ ਭੀ ਜਾਂਦਾ ਹੈ ਜੇ ਉਹ ਜਗਤ ਵਿਚ ਹੋਰ ਹੋਰ ਦੇਸਾਂ ਵਿਚ ਭੀ (ਵਿਰਕਤ ਰਹਿਣ ਲਈ) ਤੁਰਿਆ ਫਿਰਦਾ ਹੈ (ਤਾਂ ਭੀ ਉਸ ਦੇ ਮਾਇਆ ਵਾਲੇ ਬੰਧਨ ਟੁੱਟਦੇ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "то даже если он ходит по тиртхам и странствует по разным странам мира ради отрешённости, узы майи всё равно не рвутся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50127,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਿਲੀਐ ਸਤਿਗੁਰ ਸੰਗ ॥",
          "roman": "nānak milīai satigur saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੇ ਗੁਰੂ ਦਾ ਮੇਲ ਪ੍ਰਾਪਤ ਹੋਵੇ ਤਾਂ ਹੀ ਪਰਮਾਤਮਾ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, лишь если обретается встреча с Сатгуру, тогда обретается и Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50128,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਭਵਜਲ ਕੇ ਤੂਟਸਿ ਬੰਧ ॥੫॥੪॥",
          "roman": "tau bhavjal kē tūṭsi bandh ॥5॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਾਲੇ ਬੰਧਨ ਟੁੱਟਦੇ ਹਨ ॥੫॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "только тогда рвутся узы мирского океана ॥5॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4163,
      "rahao_verse_id": 50135,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50129,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੧ ॥",
          "roman": "basant mahalā 1 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50130,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਭਵਨ ਤੇਰੀ ਮਾਇਆ ਮੋਹ ॥",
          "roman": "sagal bhavan tērī māiā moh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਭਵਨਾਂ ਵਿਚ (ਸਾਰੇ ਜਗਤ ਵਿਚ) ਤੇਰੀ ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ ਪਸਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, во всех мирах, во всём творении, распростёрта привязанность к Твоей майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50131,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਅਵਰੁ ਨ ਦੀਸੈ ਸਰਬ ਤੋਹ ॥",
          "roman": "mē avar na dīsē sarab toh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਤੈਥੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਨਹੀਂ ਦਿੱਸਦਾ, ਸਭ ਜੀਵਾਂ ਵਿਚ ਤੇਰਾ ਹੀ ਪ੍ਰਕਾਸ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мне никого не видно кроме Тебя, во всех существах сияет лишь Твой свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50132,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਸੁਰਿ ਨਾਥਾ ਦੇਵਾ ਦੇਵ ॥",
          "roman": "tū sur nāthā dēvā dēv ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਦੇਵਤਿਆਂ ਦਾ ਨਾਥਾਂ ਦਾ ਭੀ ਦੇਵਤਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — Бог богов и владык богов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50133,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਮਿਲੈ ਗੁਰ ਚਰਨ ਸੇਵ ॥੧॥",
          "roman": "har nām milē gur charan sēv ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਸੇਵਾ ਕੀਤਿਆਂ ਹੀ ਤੇਰਾ ਨਾਮ ਮਿਲਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Хари, лишь служением стопам Гуру обретается Твоё Имя ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50134,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਸੁੰਦਰ ਗਹਿਰ ਗੰਭੀਰ ਲਾਲ ॥",
          "roman": "mērē sundar gahir gambhīr lāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਸੋਹਣੇ ਲਾਲ! ਹੇ ਡੂੰਘੇ ਤੇ ਵੱਡੇ ਜਿਗਰੇ ਵਾਲੇ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О мой прекрасный Возлюбленный, о Господь глубокой и великой души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50135,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਮ ਨਾਮ ਗੁਨ ਗਾਏ ਤੂ ਅਪਰੰਪਰੁ ਸਰਬ ਪਾਲ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gurmukh rām nām gun gāē tū aparampar sarab pāl ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਜੀਵਾਂ ਨੂੰ ਪਾਲਣ ਵਾਲੇ ਪ੍ਰਭੂ! ਤੂੰ ਬੜਾ ਹੀ ਬੇਅੰਤ ਹੈਂ। ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ, ਉਹ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, питающий всех существ, Ты поистине безмерен. Тот, кто приходит в прибежище Гуру, воспевает Твои достоинства ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50136,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਾਧ ਨ ਪਾਈਐ ਹਰਿ ਕਾ ਸੰਗੁ ॥",
          "roman": "bin sādh na pāīai har kā saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਬਿਨਾ ਪਰਮਾਤਮਾ ਦਾ ਸਾਥ ਪ੍ਰਾਪਤ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Без прибежища Гуру невозможно обрести близость Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50137,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਮੈਲ ਮਲੀਨ ਅੰਗੁ ॥",
          "roman": "bin gur mēl malīn aṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਦਾ ਸਰੀਰ (ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਨਾਲ ਗੰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что без Гуру тело человека остаётся загрязнённым скверной пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50138,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਨਾਮ ਨ ਸੁਧੁ ਹੋਇ ॥",
          "roman": "bin har nām na sudh hoi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ (ਇਹ ਸਰੀਰ) ਪਵਿਤ੍ਰ ਨਹੀਂ ਹੋ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Бога это тело не может стать чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50139,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਬਦਿ ਸਲਾਹੇ ਸਾਚੁ ਸੋਇ ॥੨॥",
          "roman": "gur sabad slāhē sāch soi ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто, соединившись со Словом Гуру, славит Бога, сам становится образом Вечного Истинного ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50140,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਤੂ ਰਾਖਹਿ ਰਖਨਹਾਰ ॥",
          "roman": "jā kau tū rākhah rakhanhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਰੱਖਣਹਾਰ ਪ੍ਰਭੂ! ਜਿਸ ਨੂੰ ਤੂੰ ਆਪ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Хранитель, того, кого Ты Сам оберегаешь от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50141,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੂ ਮਿਲਾਵਹਿ ਕਰਹਿ ਸਾਰ ॥",
          "roman": "satgurū milāvah karah sār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਤੂੰ ਗੁਰੂ ਮਿਲਾਂਦਾ ਹੈਂ ਤੇ ਜਿਸ ਦੀ ਤੂੰ ਸੰਭਾਲ ਕਰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "кому Ты даруешь встречу с Сатгуру и о ком Сам заботишься,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50142,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੁ ਹਉਮੈ ਮਮਤਾ ਪਰਹਰਾਇ ॥",
          "roman": "bikh haumē mamtā parharāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ ਹਉਮੈ ਤੇ ਮਲਕੀਅਤਾਂ ਬਣਾਣ ਦੇ ਜ਼ਹਰ ਨੂੰ ਦੂਰ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот удаляет изнутри яд Хоумэ и чувства собственности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50143,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਦੂਖ ਬਿਨਾਸੇ ਰਾਮ ਰਾਇ ॥੩॥",
          "roman": "sabh dūkh bināsē rām rāi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਰਾਮਰਾਇ! ਤੇਰੀ ਮੇਹਰ ਨਾਲ ਉਸ ਦੇ ਸਾਰੇ ਦੁੱਖ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Рам Рай, по Твоей милости все его страдания исчезают ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50144,
          "is_rahao": false,
          "gurmukhi": "ਊਤਮ ਗਤਿ ਮਿਤਿ ਹਰਿ ਗੁਨ ਸਰੀਰ ॥",
          "roman": "ūtam gat mit har gun sarīr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਵੱਸ ਪੈਂਦੇ ਹਨ ਉਸ ਦੀ ਆਤਮਕ ਅਵਸਥਾ ਉੱਚੀ ਹੋ ਜਾਂਦੀ ਹੈ ਉਹ ਫ਼ਰਾਖ਼-ਦਿਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда в человеке поселяются качества Бога, его духовное состояние становится высоким, а сердце — просторным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50145,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਪ੍ਰਗਟੇ ਰਾਮ ਨਾਮ ਹੀਰ ॥",
          "roman": "gurmat pragaṭē rām nām hīr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮੱਤ ਤੇ ਤੁਰ ਕੇ ਉਸ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ-ਨਾਮ ਦਾ ਹੀਰਾ ਚਮਕ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "следуя наставлению Гуру, он раскрывает в себе алмаз Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50146,
          "is_rahao": false,
          "gurmukhi": "ਲਿਵ ਲਾਗੀ ਨਾਮਿ ਤਜਿ ਦੂਜਾ ਭਾਉ ॥",
          "roman": "liv lāgī nām taj dūjā bhāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦਾ ਪਿਆਰ ਤਿਆਗ ਕੇ ਉਸ ਦੀ ਸੁਰਤ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "оставив любовь к майе, он соединяет своё сознание с Именем Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50147,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਹਰਿ ਗੁਰੁ ਗੁਰ ਮਿਲਾਉ ॥੪॥੫॥",
          "roman": "jan nānak har gur gur milāu ॥4॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਮੇਰੀ ਤੇਰੇ ਦਰ ਤੇ ਅਰਦਾਸਿ ਹੈ ਕਿ) ਮੈਨੂੰ ਦਾਸ ਨਾਨਕ ਨੂੰ ਗੁਰੂ ਮਿਲਾ, ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਕਰਾ ਦੇ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, такова молитва слуги Нанака у Твоего двора: даруй мне встречу с Гуру, соедини меня с Гуру ॥4॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4164,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50148,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੧ ॥",
          "roman": "basant mahalā 1 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50149,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੀ ਸਖੀ ਸਹੇਲੀ ਸੁਨਹੁ ਭਾਇ ॥",
          "roman": "mērī sakhī sahēlī sunah bhāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ (ਸਤ ਸੰਗਣ) ਸਹੇਲੀਹੋ! ਪ੍ਰੇਮ ਨਾਲ (ਮੇਰੀ ਗੱਲ) ਸੁਣੋ,"
            },
            "sahib_singh_ru": {
              "main": "О мои подруги по святому собранию, выслушайте меня с любовью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50150,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਪਿਰੁ ਰੀਸਾਲੂ ਸੰਗਿ ਸਾਇ ॥",
          "roman": "mērā pir rīsālū saṅg sāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਮੇਰਾ ਸੁੰਦਰ ਪਤੀ-ਪ੍ਰਭੂ ਜਿਸ ਸਹੇਲੀ ਦੇ ਅੰਗ-ਸੰਗ ਹੈ ਉਹੀ ਸਹੇਲੀ (ਸੁਹਾਗਣਿ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что прекрасный Муж-Господь есть рядом лишь с той подругой, которая и есть истинно счастливой супругой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50151,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਅਲਖੁ ਨ ਲਖੀਐ ਕਹਹੁ ਕਾਇ ॥",
          "roman": "ohu alakh na lakhīai kahah kāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਸੋਹਣਾ ਪ੍ਰਭੂ) ਬਿਆਨ ਤੋਂ ਪਰੇ ਹੈ, ਉਸ ਦਾ ਸਰੂਪ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ। ਦੱਸੋ (ਹੇ ਸਹੇਲੀਹੋ!) ਉਹ (ਫਿਰ) ਕਿਵੇਂ (ਮਿਲੇ)।"
            },
            "sahib_singh_ru": {
              "main": "Он, прекрасный Господь, непостижим и вне описания, Его образ нельзя выразить. Скажите же, о подруги, как Его обрести?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
