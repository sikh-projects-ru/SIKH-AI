{
  "ang": 1173,
  "shabads": [
    {
      "shabad_id": 4173,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50290,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਚੂਕੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "nadar karē chūkē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਪਰਮਾਤਮਾ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ ਉਸ ਦੇ ਅੰਦਰੋਂ ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, на кого Параматма обращает взгляд милости, изнутри исчезает гордыня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50291,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਦਰਗਹ ਪਾਵੈ ਮਾਨੁ ॥",
          "roman": "sāchī dargah pāvē mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот человек получает почёт в присутствии вечно-пребывающего Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50292,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਵੇਖੈ ਸਦ ਹਜੂਰਿ ॥",
          "roman": "har jīu vēkhē sad hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਵੇਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря слову Гуру этот человек всегда видит Параматму пребывающим рядом с собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50293,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਰਹਿਆ ਭਰਪੂਰਿ ॥੩॥",
          "roman": "gur kē sabad rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Параматма видится ему пребывающим повсюду ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50294,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਕੀ ਕਰੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "jīa jant kī karē pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ, ਜੋ ਸਾਰੇ ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Параматма, который заботится обо всех живых существах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50295,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਸਦ ਸਮੑਾਲ ॥",
          "roman": "gur parsādī sad samhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਸਦਾ ਯਾਦ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тот человек, который по милости Гуру всегда помнит этого Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50296,
          "is_rahao": false,
          "gurmukhi": "ਦਰਿ ਸਾਚੈ ਪਤਿ ਸਿਉ ਘਰਿ ਜਾਇ ॥",
          "roman": "dar sāchē pat siu ghar jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਘਰ ਵਿਚ ਇੱਜ਼ਤ ਨਾਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "идёт к вратам вечно-пребывающего Прабху, в дом вечно-пребывающего Прабху, с честью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50297,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਵਡਾਈ ਪਾਇ ॥੪॥੩॥",
          "roman": "nānak nām vaḍāī pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਮਨੁੱਖ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਪਾਂਦਾ ਹੈ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Благодаря Имени этот человек получает честь в этом мире и в ином ॥4॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4174,
      "rahao_verse_id": 50304,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50298,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੩ ॥",
          "roman": "basant mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50299,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪੂਜਾ ਮਨ ਤੇ ਹੋਇ ॥",
          "roman": "antar pūjā man tē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਭੀ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ ਉਸ ਦੇ) ਅੰਦਰ ਹੀ ਜੁੜੇ ਮਨ ਨਾਲ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਹੁੰਦੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри него, с сосредоточенным умом, постоянно совершается преданное служение Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50300,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਵੇਖੈ ਅਉਰੁ ਨ ਕੋਇ ॥",
          "roman": "ēko vēkhē aur na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ ਹਰ ਥਾਂ) ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਨੂੰ (ਵੱਸਦਾ) ਵੇਖਦਾ ਹੈ, (ਕਿਤੇ ਭੀ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ) ਕਿਸੇ ਹੋਰ ਨੂੰ ਨਹੀਂ ਵੇਖਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он повсюду видит только Бога и не видит никого иного, кроме Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50301,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਲੋਕੀ ਬਹੁਤੁ ਦੁਖੁ ਪਾਇਆ ॥",
          "roman": "dūjē lokī bahut dukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ ਨੇ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ ਸਦਾ ਬਹੁਤ ਦੁੱਖ ਪਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мир, попав в привязанность к майе, всегда испытывал много страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50302,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮੈਨੋ ਏਕੁ ਦਿਖਾਇਆ ॥੧॥",
          "roman": "satgur mēno ēk dikhāiā. 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਗੁਰੂ ਨੇ (ਮਿਹਰ ਕਰ ਕੇ) ਮੈਨੂੰ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਹੀ (ਹਰ ਥਾਂ ਵੱਸਦਾ) ਵਿਖਾ ਦਿੱਤਾ ਹੈ (ਤੇ, ਮੈਂ ਦੁੱਖ ਤੋਂ ਬਚ ਗਿਆ ਹਾਂ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но Гуру, по милости, показал мне только Бога, пребывающего повсюду, и я спасся от страдания. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50303,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਮਉਲਿਆ ਸਦ ਬਸੰਤੁ ॥",
          "roman": "mērā prabh mauliā sad basant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਆਨੰਦ-ਸਰੂਪ ਮੇਰਾ ਪਰਮਾਤਮਾ (ਹਰ ਥਾਂ) ਆਪਣਾ ਪਰਕਾਸ਼ ਕਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Мой Бог, образ вечного блаженства, повсюду проявляет свой свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50304,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਮਉਲਿਆ ਗਾਇ ਗੁਣ ਗੋਬਿੰਦ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ih man mauliā gāi guṇ gobind. 1. rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਗਾ ਕੇ (ਮੇਰਾ) ਇਹ ਮਨ ਸਦਾ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества этого Бога, мой ум всегда остаётся расцветшим. ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50305,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਛਹੁ ਤੁਮੑ ਕਰਹੁ ਬੀਚਾਰੁ ॥",
          "roman": "gur pūchhah tumh karah bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੁਸਾਂ ਭੀ ਜੇ ਦੁੱਖਾਂ ਤੋਂ ਬਚਣਾ ਹੈ, ਤਾਂ) ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਲਵੋ, ਤੇ, ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਈ ਰੱਖੋ।"
            },
            "sahib_singh_ru": {
              "main": "Если вы тоже хотите спастись от страданий, примите наставление Гуру и держите качества Бога в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50306,
          "is_rahao": false,
          "gurmukhi": "ਤਾਂ ਪ੍ਰਭ ਸਾਚੇ ਲਗੈ ਪਿਆਰੁ ॥",
          "roman": "tāṅ prabh sāchē lagē piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਉਗੇ) ਤਦੋਂ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨਾਲ (ਤੁਹਾਡਾ) ਪਿਆਰ ਬਣ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Когда вы поселите качества Господа в своём уме, тогда у вас возникнет любовь к вечно пребывающему Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50307,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਛੋਡਿ ਹੋਹਿ ਦਾਸਤ ਭਾਇ ॥",
          "roman": "āp chhoḍ hoh dāsat bhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਆਪਾ-ਭਾਵ (ਹਉਮੈ) ਛੱਡ ਕੇ ਸੇਵਕ-ਸੁਭਾਵ ਵਿਚ ਟਿਕਿਆ ਰਹੇਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если ты, оставив чувство самости, Хоумэ, будешь пребывать в настрое слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50308,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਜਗਜੀਵਨੁ ਵਸੈ ਮਨਿ ਆਇ ॥੨॥",
          "roman": "tau jagjīvan vasē man āi. 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਜਗਤ ਨੂੰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ ਪਰਮਾਤਮਾ (ਤੇਰੇ) ਮਨ ਵਿਚ ਆ ਵੱਸੇਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда Бог, создающий мир, придёт и поселится в твоём уме. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50309,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰੇ ਸਦ ਵੇਖੈ ਹਜੂਰਿ ॥",
          "roman": "bhagat karē sad vēkhē hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ, ਉਹ ਪਰਮਾਤਮਾ ਨੂੰ ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੇਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, который совершает преданное служение Богу, всегда видит Бога рядом с собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50310,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਸਦ ਰਹਿਆ ਭਰਪੂਰਿ ॥",
          "roman": "mērā prabh sad rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰਾ ਪ੍ਰਭੂ ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "любимый Господь видится ему вездесущим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50311,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਭਗਤੀ ਕਾ ਕੋਈ ਜਾਣੈ ਭੇਉ ॥",
          "roman": "is bhagtī kā koi jāṇē bhēu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਭੀ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਇਸ ਭਗਤੀ (ਦੇ ਕੌਤਕ) ਦਾ ਭੇਤ ਸਮਝ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Всякий человек, который постигает тайну этого преданного служения Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50312,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਮੇਰਾ ਪ੍ਰਭੁ ਆਤਮ ਦੇਉ ॥੩॥",
          "roman": "sabh mērā prabh ātam dēu. 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਹਰ ਥਾਂ ਵੱਸਦਾ ਦਿੱਸ ਪੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "начинает видеть Бога пребывающим повсюду. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50313,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਤਿਗੁਰੁ ਮੇਲਿ ਮਿਲਾਏ ॥",
          "roman": "āpē satgur mēl milāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, (ਭਗਤੀ ਦੀ ਦਾਤ ਉਸ ਦੀ ਆਪਣੀ ਮਿਹਰ ਨਾਲ ਹੀ ਮਿਲਦੀ ਹੈ) ਜਗਤ ਦਾ ਜੀਵਨ ਪ੍ਰਭੂ ਆਪ ਹੀ (ਮਨੁੱਖ ਨੂੰ) ਗੁਰੂ ਮਿਲਾ ਕੇ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но дар преданного служения даётся только по Его собственной милости: Господь, жизнь мира, сам соединяет человека с Гуру и присоединяет его к своим стопам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50314,
          "is_rahao": false,
          "gurmukhi": "ਜਗਜੀਵਨ ਸਿਉ ਆਪਿ ਚਿਤੁ ਲਾਏ ॥",
          "roman": "jagjīvan siu āp chit lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ ਮਨੁੱਖ ਦਾ ਚਿੱਤ ਆਪਣੇ ਨਾਲ ਜੋੜਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он сам соединяет ум человека с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50315,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਹਰਿਆ ਸਹਜਿ ਸੁਭਾਏ ॥",
          "roman": "man tan hariā sahaj subhāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ, ਉਹ ਪ੍ਰਭੂ-ਪਿਆਰ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ, ਉਹਨਾਂ ਦਾ ਮਨ ਉਹਨਾਂ ਦਾ ਤਨ ਆਤਮਕ ਜੀਵਨ ਨਾਲ ਭਰਪੂਰ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Они пребывают в духовной невозмутимости, они пребывают в любви к Господу; их ум и тело остаются наполненными духовной жизнью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50316,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਰਹੇ ਲਿਵ ਲਾਏ ॥੪॥੪॥",
          "roman": "nānak nām rahē liv lāē. 4. 4",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਸੁਰਤ ਜੋੜੀ ਰੱਖਦੇ ਹਨ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Таковы люди, которые держат своё сознание соединённым с Именем Бога. ॥4॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4175,
      "rahao_verse_id": 50323,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50317,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੩ ॥",
          "roman": "basant mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50318,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਵਛਲੁ ਹਰਿ ਵਸੈ ਮਨਿ ਆਇ ॥",
          "roman": "bhagat vachhal har vasē man āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ ਨਾਲ ਪਿਆਰ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਉਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь, любящий преданное служение, приходит и поселяется в уме того человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50319,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਸਹਜ ਸੁਭਾਇ ॥",
          "roman": "gur kirpā tē sahaj subhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "который по милости Гуру остаётся погружённым в духовную невозмутимость и любовь к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50320,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰੇ ਵਿਚਹੁ ਆਪੁ ਖੋਇ ॥",
          "roman": "bhagat karē vichah āp khoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек устраняет изнутри чувство самости и совершает преданное служение Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50321,
          "is_rahao": false,
          "gurmukhi": "ਤਦ ਹੀ ਸਾਚਿ ਮਿਲਾਵਾ ਹੋਇ ॥੧॥",
          "roman": "tad hī sāch milāvā hoi. 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਸਦਾ-ਥਿਰ ਪਰਮਾਤਮਾ ਵਿਚ ਉਸ ਦਾ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "только тогда происходит его соединение с вечно пребывающим Богом. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50322,
          "is_rahao": true,
          "gurmukhi": "ਭਗਤ ਸੋਹਹਿ ਸਦਾ ਹਰਿ ਪ੍ਰਭ ਦੁਆਰਿ ॥",
          "roman": "bhagat sohah sadā har prabh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਬੰਦਗੀ ਕਰਨ ਵਾਲੇ ਮਨੁੱਖ ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਸੋਭਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди, поклоняющиеся Богу, всегда выглядят прекрасными у двери Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50323,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕੈ ਹੇਤਿ ਸਾਚੈ ਪ੍ਰੇਮ ਪਿਆਰਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur kē hēt sāchē prēm piār. 1. rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਗੁਰੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ (ਜੁੜੇ ਰਹਿੰਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "они всегда остаются соединёнными с любовью к Гуру и с любовью к вечно пребывающему Господу. ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50324,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰੇ ਸੋ ਜਨੁ ਨਿਰਮਲੁ ਹੋਇ ॥",
          "roman": "bhagat karē so jan nirmal hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਪਵਿੱਤਰ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, который совершает преданное служение Богу, становится человеком чистой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50325,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਬਦੀ ਵਿਚਹੁ ਹਉਮੈ ਖੋਇ ॥",
          "roman": "gur sabdī vichah haumē khoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਆਪਣੇ ਅੰਦਰੋਂ ਹਉਮੈ ਦੂਰ ਕਰ ਕੇ (ਭਗਤੀ ਵਿਚ ਜੁੜਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Посредством Слова Гуру он устраняет Хоумэ изнутри себя и соединяется с преданным служением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50326,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਆਪਿ ਵਸੈ ਮਨਿ ਆਇ ॥",
          "roman": "har jīu āp vasē man āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਉਸ ਦੇ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь сам приходит и поселяется в его уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50327,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਾਂਤਿ ਸੁਖਿ ਸਹਜਿ ਸਮਾਇ ॥੨॥",
          "roman": "sadā sāṅt sukh sahaj samāi. 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਸ਼ਾਂਤੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ, ਉਹ ਸਦਾ ਆਨੰਦ ਵਿਚ ਆਤਮਕ ਅਡਲੋਤਾ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Внутри него сохраняется мир; он всегда остаётся погружённым в блаженство и духовную невозмутимость. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50328,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਿ ਰਤੇ ਤਿਨ ਸਦ ਬਸੰਤ ॥",
          "roman": "sāch ratē tin sad basant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦੇ ਪਿਆਰ) ਵਿਚ ਰੰਗੇ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые окрашиваются любовью к вечно пребывающему Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50329,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਹਰਿਆ ਰਵਿ ਗੁਣ ਗੁਵਿੰਦ ॥",
          "roman": "man tan hariā rav guṇ guvind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਸਦਾ ਖਿੜਾਉ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ। ਗੋਬਿੰਦ ਦੇ ਗੁਣ ਯਾਦ ਕਰ ਕਰ ਕੇ ਉਹਨਾਂ ਦਾ ਮਨ ਉਹਨਾਂ ਦਾ ਤਨ ਆਤਮਕ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "внутри них всегда остаётся расцвет. Помня качества Гобинда, их ум и тело обретают духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50330,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਸੂਕਾ ਸੰਸਾਰੁ ॥",
          "roman": "bin nāvē sūkā sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਜਗਤ ਨਿੱਕੇ ਜਿਹੇ ਵਿਤ ਵਾਲਾ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога мир остаётся скудным, с малой внутренней мерой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50331,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਤ੍ਰਿਸਨਾ ਜਲੈ ਵਾਰੋ ਵਾਰ ॥੩॥",
          "roman": "agan trisnā jalē vāro vār. 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁੜ ਮੁੜ (ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਵਿਚ ਸੜਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и снова и снова горит в огне жажды майи. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50332,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਕਰੇ ਜਿ ਹਰਿ ਜੀਉ ਭਾਵੈ ॥",
          "roman": "soī karē j har jīu bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਉਹੀ ਕੁਝ ਕਰਦਾ ਹੈ ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек делает только то, что нравится Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50333,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸੁਖੁ ਸਰੀਰਿ ਭਾਣੈ ਚਿਤੁ ਲਾਵੈ ॥",
          "roman": "sadā sukh sarīr bhāṇē chit lāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਦਾ ਹੈ), ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਭਾਣੇ ਵਿਚ ਆਪਣਾ ਚਿੱਤ ਜੋੜਦਾ ਹੈ, ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆਤਮਕ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, который идёт в согласии с волей Господа, который соединяет своё сознание с Его волей, в его сердце сохраняется духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50334,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਪ੍ਰਭੁ ਸੇਵੇ ਸਹਜਿ ਸੁਭਾਇ ॥",
          "roman": "apṇā prabh sēvē sahaj subhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਪ੍ਰਭੂ-ਪਿਆਰ ਵਿਚ ਜੁੜ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, который, пребывая в духовной невозмутимости и соединяясь с любовью к Господу, совершает преданное служение Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50335,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਵਸੈ ਮਨਿ ਆਇ ॥੪॥੫॥",
          "roman": "nānak nām vasē man āi. 4. 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਸ ਦੇ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! Имя Бога приходит и поселяется в его уме. ॥4॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4176,
      "rahao_verse_id": 50342,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50336,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੩ ॥",
          "roman": "basant mėhlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50337,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹੁ ਸਬਦਿ ਜਲਾਏ ॥",
          "roman": "māiā moh sabad jalāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਆਪਣੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦਾ ਮੋਹ ਸਾੜ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, который посредством Слова Гуру сжигает внутри себя привязанность к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50338,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਹਰਿਆ ਸਤਿਗੁਰ ਭਾਏ ॥",
          "roman": "man tan hariā satigur bhāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਪਿਆਰ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦਾ ਮਨ ਉਸ ਦਾ ਤਨ ਆਤਮਕ ਜੀਵਨ ਨਾਲ ਭਰਪੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по благословению любви Гуру его ум и тело наполняются духовной жизнью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50339,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲਿਓੁ ਬਿਰਖੁ ਹਰਿ ਕੈ ਦੁਆਰਿ ॥",
          "roman": "saflio birakh har kē duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ (ਸਰੀਰ-) ਰੁੱਖ ਸਫਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Дерево тела этого человека становится плодоносящим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50340,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਬਾਣੀ ਨਾਮ ਪਿਆਰਿ ॥੧॥",
          "roman": "sāchī bāṇī nām piār. 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਿਚ, ਹਰਿ-ਨਾਮ ਦੇ ਪਿਆਰ ਵਿਚ (ਟਿਕ ਕੇ ਸਦਾ) ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Это тот человек, который пребывает в восхвалении вечно пребывающего Господа, в любви к Имени Хари, всегда у двери Бога, у стоп Господа. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50341,
          "is_rahao": true,
          "gurmukhi": "ਏ ਮਨ ਹਰਿਆ ਸਹਜ ਸੁਭਾਇ ॥",
          "roman": "ē man hariā sahaj subhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਆਤਮਕ ਅਡੋਲਤਾ ਦੇਣ ਵਾਲੇ (ਗੁਰ-) ਪਿਆਰ ਵਿਚ (ਟਿਕਿਆ ਰਹੁ। ਇਸ ਤਰ੍ਹਾਂ ਤੂੰ) ਆਤਮਕ ਜੀਵਨ ਦੀ ਤਰਾਵਤ ਨਾਲ ਭਰਪੂਰ ਹੋ ਜਾਇਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Пребывай в любви Гуру, дающей духовную невозмутимость. Так ты наполнишься свежестью духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50342,
          "is_rahao": true,
          "gurmukhi": "ਸਚ ਫਲੁ ਲਾਗੈ ਸਤਿਗੁਰ ਭਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sach phal lāgē satigur bhāi. 1. rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਗੁਰੂ ਦੇ ਪਿਆਰ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਸਰੀਰ-ਰੁੱਖ ਨੂੰ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਫਲ ਲੱਗਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О ум! По благословению любви Гуру на дереве тела появляется плод Имени вечно пребывающего Бога. ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50343,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਨੇੜੈ ਆਪੇ ਦੂਰਿ ॥",
          "roman": "āpē nēṛē āpē dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ ਕਿ ਪ੍ਰਭੂ) ਆਪ ਹੀ (ਕਿਸੇ ਨੂੰ) ਨੇੜੇ (ਦਿੱਸ ਰਿਹਾ ਹੈ) ਆਪ ਹੀ (ਕਿਸੇ ਨੂੰ ਦੂਰ ਵੱਸਦਾ ਜਾਪਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ему становится понятно, что Господь сам кому-то кажется близким, и сам кому-то кажется пребывающим далеко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50344,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਵੇਖੈ ਸਦ ਹਜੂਰਿ ॥",
          "roman": "gur kē sabad vēkhē sad hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ) ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਵੇਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который по благословению Слова Гуру всегда видит Бога пребывающим рядом с собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50345,
          "is_rahao": false,
          "gurmukhi": "ਛਾਵ ਘਣੀ ਫੂਲੀ ਬਨਰਾਇ ॥",
          "roman": "chhāv ghaṇī phūlī banrāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮਨੁੱਖ ਨੂੰ ਪਰਤੱਖ ਦਿੱਸਦਾ ਹੈ ਕਿ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ-ਅਗਨੀ ਨਾਲ ਹੀ) ਸਾਰੀ ਬਨਸਪਤੀ ਸੰਘਣੀ ਛਾਂ ਵਾਲੀ ਹੈ ਤੇ ਖਿੜੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "ясно видит, что именно светом-огнём Бога вся растительность имеет густую тень и цветёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50346,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਬਿਗਸੈ ਸਹਜਿ ਸੁਭਾਇ ॥੨॥",
          "roman": "gurmukh bigsē sahaj subhāi. 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਪ੍ਰਭੂ-ਪਿਆਰ ਵਿਚ ਜੁੜ ਕੇ (ਸਦਾ) ਆਨੰਦ-ਭਰਪੂਰ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Человек, обращённый к Гуру, пребывая в духовной невозмутимости и соединяясь с любовью к Господу, всегда остаётся наполненным радостью. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50347,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਕੀਰਤਨੁ ਕਰਹਿ ਦਿਨ ਰਾਤਿ ॥",
          "roman": "an-din kīrtan karah din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਦਿਨ ਰਾਤ ਹਰ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди, которые днём и ночью, всё время, совершают восхваление Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50348,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਗਵਾਈ ਵਿਚਹੁ ਜੂਠਿ ਭਰਾਂਤਿ ॥",
          "roman": "satigur gavāī vichah jūṭh bharāṅt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ (ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਭਟਕਣਾ ਦੀ ਮੈਲ ਦੂਰ ਕਰ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "изнутри них Гуру удалил грязь блуждания ради майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
