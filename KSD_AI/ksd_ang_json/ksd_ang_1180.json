{
  "ang": 1180,
  "shabads": [
    {
      "shabad_id": 4197,
      "rahao_verse_id": 50622,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50615,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ਘਰੁ ੧ ਦੁਤੁਕੇ",
          "roman": "basant mahalā 5 ghar 1 dutukē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਸੰਤੁ, ਘਰ ੧ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਦੋ-ਤੁਕੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Басант, дом 1, двухстрочная бани Гуру Арджандев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50616,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и Он обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50617,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਸੇਵਉ ਕਰਿ ਨਮਸਕਾਰ ॥",
          "roman": "gur sēvau kar namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਗੁਰੂ ਅੱਗੇ ਸਿਰ ਨਿਵਾ ਕੇ ਗੁਰੂ ਦੀ ਸੇਵਾ ਕਰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я склоняю голову перед Гуру и служу Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50618,
          "is_rahao": false,
          "gurmukhi": "ਆਜੁ ਹਮਾਰੈ ਮੰਗਲਚਾਰ ॥",
          "roman": "āj hamārē mangalchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਬੜਾ ਆਨੰਦ ਬਣਿਆ ਪਿਆ ਹੈ। (ਇਹ ਸਾਰੀ ਮਿਹਰ ਗੁਰੂ ਦੀ ਹੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Теперь в моём сердце пребывает великая радость. Вся эта милость — именно от Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50619,
          "is_rahao": false,
          "gurmukhi": "ਆਜੁ ਹਮਾਰੈ ਮਹਾ ਅਨੰਦ ॥",
          "roman": "āj hamārē mahā anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੇਰੇ ਅੰਦਰ ਖ਼ੁਸ਼ੀਆਂ ਹੀ ਖ਼ੁਸ਼ੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь внутри меня — одни лишь радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50620,
          "is_rahao": false,
          "gurmukhi": "ਚਿੰਤ ਲਥੀ ਭੇਟੇ ਗੋਬਿੰਦ ॥੧॥",
          "roman": "chint lathī bhēṭē gobind ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਣ ਗਾਵਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੈਨੂੰ ਗੋਬਿੰਦ ਜੀ ਮਿਲ ਪਏ ਹਨ, ਮੇਰੀ ਹਰੇਕ ਚਿੰਤਾ ਦੂਰ ਹੋ ਗਈ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "По благодати воспевания достоинств я встретил Гобинда, и всякая моя тревога ушла ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50621,
          "is_rahao": true,
          "gurmukhi": "ਆਜੁ ਹਮਾਰੈ ਗ੍ਰਿਹਿ ਬਸੰਤ ॥",
          "roman": "āj hamārē grih basant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਬੇਅੰਤ ਪ੍ਰਭੂ! ਤਦੋਂ ਤੋਂ ਹੁਣ ਮੇਰੇ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਆਤਮਕ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О бесконечный Прабху! С тех пор в доме моего сердца постоянно пребывает духовная радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50622,
          "is_rahao": true,
          "gurmukhi": "ਗੁਨ ਗਾਏ ਪ੍ਰਭ ਤੁਮੑ ਬੇਅੰਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gun gāē prabh tumh beant ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੋਂ ਮੈਂ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਣੇ ਸ਼ੁਰੂ ਕੀਤੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "с тех пор как я начал петь песни Твоей хвалы ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50623,
          "is_rahao": false,
          "gurmukhi": "ਆਜੁ ਹਮਾਰੈ ਬਨੇ ਫਾਗ ॥",
          "roman": "āj hamārē banē phāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੇਰੇ ਅੰਦਰ (ਮਾਨੋ) ਫੱਗਣ ਦੀ ਹੋਲੀ ਬਣੀ ਪਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По благодати хвалы Параматмы внутри меня словно наступила холи месяца Пхагган,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50624,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸੰਗੀ ਮਿਲਿ ਖੇਲਨ ਲਾਗ ॥",
          "roman": "prabh sangī mil khēlan lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸੰਤ ਜਨ (ਸਾਧ ਸੰਗਤ ਵਿਚ) ਮਿਲ ਕੇ (ਇਹ ਹੋਲੀ) ਖੇਡਣ ਲੱਗ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "святые люди Прабху, собравшись в садх сангат, начали играть в эту холи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50625,
          "is_rahao": false,
          "gurmukhi": "ਹੋਲੀ ਕੀਨੀ ਸੰਤ ਸੇਵ ॥",
          "roman": "holī kīnī sant sēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਹੋਲੀ ਕੀਹ ਹੈ?) ਸੰਤ ਜਨਾਂ ਦੀ ਸੇਵਾ ਨੂੰ ਮੈਂ ਹੋਲੀ ਬਣਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что это за холи? Служение святым людям я сделал своей холи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50626,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗੁ ਲਾਗਾ ਅਤਿ ਲਾਲ ਦੇਵ ॥੨॥",
          "roman": "rang lāgā at lāl dēv ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੇਰੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦੇ ਪਿਆਰ ਦਾ ਗੂੜ੍ਹਾ (ਆਤਮਕ) ਰੰਗ ਚੜ੍ਹ ਗਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По благодати общества святых внутри меня проявился глубокий духовный цвет любви Параматмы ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50627,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਮਉਲਿਓ ਅਤਿ ਅਨੂਪ ॥",
          "roman": "man tan maulio at anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਵਣ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੇਰਾ ਮਨ ਸੋਹਣਾ ਖਿੜ ਪਿਆ ਹੈ ਮੇਰਾ ਤਨ ਬਹੁਤ ਸੋਹਣਾ ਖਿੜ ਪਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По благодати воспевания достоинств Прабху мой ум прекрасно расцвёл, моё тело очень прекрасно расцвело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50628,
          "is_rahao": false,
          "gurmukhi": "ਸੂਕੈ ਨਾਹੀ ਛਾਵ ਧੂਪ ॥",
          "roman": "sūkē nāhī chhāv dhūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਸੁਖ ਹੋਣ ਚਾਹੇ ਦੁੱਖ ਹੋਣ (ਮੇਰੇ ਮਨ ਤਨ ਵਿਚ) ਆਤਮਕ ਖਿੜਾਉ ਦੀ ਤਰਾਵਤ ਕਦੇ ਮੁੱਕਦੀ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь, будь то радость или страдание, свежесть духовного расцвета в моём уме и теле никогда не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50629,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੀ ਰੂਤੀ ਹਰਿਆ ਹੋਇ ॥",
          "roman": "saglī rūti hariā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਮੇਰਾ ਮਨ) ਸਾਰੇ ਸਮਿਆਂ ਵਿਚ ਹੀ ਆਤਮਕ ਜੀਵਨ ਨਾਲ ਭਰਪੂਰ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь мой ум во все времена остаётся наполненным духовной жизнью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50630,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਬਸੰਤ ਗੁਰ ਮਿਲੇ ਦੇਵ ॥੩॥",
          "roman": "sad basant gur milē dēv ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਗੁਰਦੇਵ ਜੀ ਮਿਲ ਪਏ ਹਨ, ਮੇਰੇ ਅੰਦਰ ਸਦਾ ਖਿੜਾਉ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Я встретил Гурдев Джи, и внутри меня всегда сохраняется расцвет ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50631,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਖੁ ਜਮਿਓ ਹੈ ਪਾਰਜਾਤ ॥",
          "roman": "birakh jamio hē pārjāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰੇ ਅੰਦਰੋਂ, ਮਾਨੋ, ਸਾਰੀਆਂ ਮਨੋ-ਕਾਮਨਾ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲਾ ਸਵਰਗੀ) ਪਾਰਜਾਤ ਰੁੱਖ ਉੱਗ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По благодати хвалы внутри меня словно вырос небесный париджат, исполняющий все желания ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50632,
          "is_rahao": false,
          "gurmukhi": "ਫੂਲ ਲਗੇ ਫਲ ਰਤਨ ਭਾਂਤਿ ॥",
          "roman": "phūl lagē phal ratan bhānt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਭਾਂਤ ਭਾਂਤ ਦੇ ਕੀਮਤੀ ਫੁੱਲ ਤੇ ਫਲ ਲੱਗੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "на котором появились драгоценные цветы и плоды разных видов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50633,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਪਤਿ ਅਘਾਨੇ ਹਰਿ ਗੁਣਹ ਗਾਇ ॥",
          "roman": "tripat aghānē har guṇah gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਹਰੀ ਦੇ ਗੁਣ ਗਾ ਗਾ ਕੇ (ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਪੂਰਨ ਤੌਰ ਤੇ ਰੱਜ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно воспевая достоинства Хари, люди полностью насыщаются и отстраняются от привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50634,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਹਰਿ ਹਰਿ ਹਰਿ ਧਿਆਇ ॥੪॥੧॥",
          "roman": "jan nānak har har har dhiāi ||4||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਭਾਈ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਕੇ (ਮਾਇਆ ਦਾ ਮੋਹ ਦੂਰ ਹੁੰਦਾ ਹੈ) ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак говорит: о брат! Постоянно поминая имя Параматмы, привязанность к майе уходит ॥4॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4198,
      "rahao_verse_id": 50641,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50635,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50636,
          "is_rahao": false,
          "gurmukhi": "ਹਟਵਾਣੀ ਧਨ ਮਾਲ ਹਾਟੁ ਕੀਤੁ ॥",
          "roman": "haṭvāṇī dhan māl hāṭ kīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਕੋਈ) ਦੁਕਾਨਦਾਰ (ਆਪਣੇ ਮਨ-ਪਸੰਦ ਦੇ) ਮਾਲ-ਧਨ ਦੀ ਦੁਕਾਨ ਚਲਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как лавочник ведёт лавку с желанными для него товарами и богатством,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50637,
          "is_rahao": false,
          "gurmukhi": "ਜੂਆਰੀ ਜੂਏ ਮਾਹਿ ਚੀਤੁ ॥",
          "roman": "jūārī jūē māh chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਕਿਸੇ) ਜੁਆਰੀਏ ਦਾ ਮਨ ਜੂਏ ਵਿਚ ਮਗਨ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как ум игрока погружён в азартную игру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50638,
          "is_rahao": false,
          "gurmukhi": "ਅਮਲੀ ਜੀਵੈ ਅਮਲੁ ਖਾਇ ॥",
          "roman": "amlī jīvē amal khāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਅਫੀਮੀ ਅਫੀਮ ਖਾ ਕੇ ਸੁਖ ਪ੍ਰਤੀਤ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как опиоман, съев опиум, ощущает удовольствие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50639,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨੁ ਜੀਵੈ ਹਰਿ ਧਿਆਇ ॥੧॥",
          "roman": "tiu har jan jīvē har dhiāi ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦਾ ਭਗਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так и преданный Параматмы, поминая имя Параматмы, обретает духовную жизнь ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50640,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੈ ਰੰਗਿ ਸਭੁ ਕੋ ਰਚੈ ॥",
          "roman": "apnē rang sabh ko rachē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਜੀਵ ਆਪੋ ਆਪਣੇ ਮਨ-ਭਾਉਂਦੇ ਸੁਆਦ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Каждое существо остаётся погружённым в тот вкус, который приятен его уму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50641,
          "is_rahao": true,
          "gurmukhi": "ਜਿਤੁ ਪ੍ਰਭਿ ਲਾਇਆ ਤਿਤੁ ਤਿਤੁ ਲਗੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jit prabh lāiā tit tit lagē ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪ੍ਰਭੂ ਨੇ (ਹੀ) ਜਿਸ (ਸੁਆਦ) ਵਿਚ ਲਾਇਆ ਹੈ, ਉਸ ਉਸ (ਸੁਆਦ) ਵਿਚ (ਹਰੇਕ ਜੀਵ) ਲੱਗਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но в какой вкус Прабху его поместил, в том вкусе каждое существо и остаётся занятым ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50642,
          "is_rahao": false,
          "gurmukhi": "ਮੇਘ ਸਮੈ ਮੋਰ ਨਿਰਤਿਕਾਰ ॥",
          "roman": "mēgh samē mōr nirtikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘਟਾਂ ਚੜ੍ਹਦੀਆਂ ਹਨ ਤਾਂ ਮੋਰ ਪੈਲਾਂ ਪਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда поднимаются облака, павлины начинают танцевать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50643,
          "is_rahao": false,
          "gurmukhi": "ਚੰਦ ਦੇਖਿ ਬਿਗਸਹਿ ਕਉਲਾਰ ॥",
          "roman": "chand dēkh bigsah kaulār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੰਦ ਨੂੰ ਵੇਖ ਕੇ ਕੰਮੀਆਂ ਖਿੜਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "увидев луну, лотосы раскрываются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50644,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤਾ ਬਾਰਿਕ ਦੇਖਿ ਅਨੰਦ ॥",
          "roman": "mātā bārik dēkh anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ) ਬੱਚੇ ਨੂੰ ਵੇਖ ਕੇ ਮਾਂ ਖ਼ੁਸ਼ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "увидев своего ребёнка, мать радуется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50645,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨ ਜੀਵਹਿ ਜਪਿ ਗੋਬਿੰਦ ॥੨॥",
          "roman": "tiu har jan jīvah jap gobind ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਆਤਮਕ ਹੁਲਾਰੇ ਵਿਚ ਆਉਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так и преданные Параматмы, повторяя имя Параматмы, приходят в духовный подъём ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50646,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਘ ਰੁਚੈ ਸਦ ਭੋਜਨੁ ਮਾਸ ॥",
          "roman": "singh ruchē sad bhojan mās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਸ ਦਾ ਭੋਜਨ ਮਿਲੇ ਤਾਂ ਸ਼ੇਰ ਸਦਾ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда появляется пища из мяса, лев всегда радуется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50647,
          "is_rahao": false,
          "gurmukhi": "ਰਣੁ ਦੇਖਿ ਸੂਰੇ ਚਿਤ ਉਲਾਸ ॥",
          "roman": "raṇ dēkh sūrē chit ulās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੁੱਧ ਵੇਖ ਕੇ ਸੂਰਮੇ ਦੇ ਚਿੱਤ ਨੂੰ ਜੋਸ਼ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "увидев битву, в сердце воина поднимается воодушевление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50648,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਨ ਕਉ ਅਤਿ ਧਨ ਪਿਆਰੁ ॥",
          "roman": "kirpan kau at dhan piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ੂਮ ਨੂੰ ਧਨ ਦਾ ਬਹੁਤ ਲੋਭ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "скупец испытывает сильную алчность к богатству."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50649,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਨ ਕਉ ਹਰਿ ਹਰਿ ਆਧਾਰੁ ॥੩॥",
          "roman": "har jan kau har har ādhār ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਵੇਂ) ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Так и преданный Параматмы имеет опору в имени Параматмы ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50650,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਰੰਗ ਇਕ ਰੰਗ ਮਾਹਿ ॥",
          "roman": "sarab rang ik rang māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, (ਦੁਨੀਆ ਦੇ) ਸਾਰੇ ਸੁਆਦ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੇ ਸੁਆਦ ਦੇ ਵਿਚ ਹੀ ਆ ਜਾਂਦੇ ਹਨ (ਨਾਮ-ਰਸ ਨਾਲੋਂ ਘਟੀਆ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Но все вкусы мира входят в один вкус имени Параматмы, то есть они ниже вкуса имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50651,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਸੁਖ ਹਰਿ ਕੈ ਨਾਇ ॥",
          "roman": "sarab sukhā sukh har kē nāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਵੱਡੇ ਤੋਂ ਵੱਡੇ ਸੁਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਹੀ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все величайшие радости находятся только в имени Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50652,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਪਰਾਪਤਿ ਇਹੁ ਨਿਧਾਨੁ ॥",
          "roman": "tisah parāpat ih nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ ਉਸ ਮਨੁੱਖ ਨੂੰ ਹੀ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Это сокровище имени получает только тот человек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50653,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰੁ ਜਿਸੁ ਕਰੇ ਦਾਨੁ ॥੪॥੨॥",
          "roman": "nānak gur jis karē dān ||4||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਨੂੰ ਗੁਰੂ ਦੇਂਦਾ ਹੈ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кому его дарует Гуру ॥4॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4199,
      "rahao_verse_id": 50660,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50654,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50655,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਸੰਤੁ ਜਿਸੁ ਪ੍ਰਭੁ ਕ੍ਰਿਪਾਲੁ ॥",
          "roman": "tis basant jis prabh kripāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਖਿੜਾਉ ਉਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ, ਜਿਸ ਉੱਤੇ ਪ੍ਰਭੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Духовный расцвет получает тот человек, к кому Прабху милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50656,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਸੰਤੁ ਜਿਸੁ ਗੁਰੁ ਦਇਆਲੁ ॥",
          "roman": "tis basant jis gur daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਖਿੜਾਉ ਉਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ, ਜਿਸ ਉਤੇ ਗੁਰੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "духовный расцвет получает тот человек, к кому Гуру милостив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50657,
          "is_rahao": false,
          "gurmukhi": "ਮੰਗਲੁ ਤਿਸ ਕੈ ਜਿਸੁ ਏਕੁ ਕਾਮੁ ॥",
          "roman": "mangal tis kē jis ēk kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਖ਼ੁਸ਼ੀ ਪੈਦਾ ਹੁੰਦੀ ਹੈ, ਜਿਸ ਨੂੰ ਇਕ ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਦਾ ਸਦਾ ਆਹਰ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В сердце того человека возникает радость, у кого всегда есть одно занятие — памятование Хар-нама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50658,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸਦ ਬਸੰਤੁ ਜਿਸੁ ਰਿਦੈ ਨਾਮੁ ॥੧॥",
          "roman": "tis sad basant jis ridē nām ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਖਿੜਾਉ ਸਦਾ ਹੀ ਮਿਲਿਆ ਰਹਿੰਦਾ ਹੈ ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку всегда достаётся расцвет, в чьём сердце пребывает имя Параматмы ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50659,
          "is_rahao": true,
          "gurmukhi": "ਗ੍ਰਿਹਿ ਤਾ ਕੇ ਬਸੰਤੁ ਗਨੀ ॥",
          "roman": "grih tā kē basant ganī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤਾਂ ਉਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਖਿੜਾਉ (ਪੈਦਾ ਹੋਇਆ) ਸਮਝਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я считаю, что расцвет возник в сердце того человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50660,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੈ ਕੀਰਤਨੁ ਹਰਿ ਧੁਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā kē kīrtan har dhunī ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਟਿਕੀ ਹੋਈ ਹੈ, ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦੀ ਲਗਨ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце утвердилась хвала Прабху, в чьём сердце есть привязанность к имени Параматмы ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50661,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੀਤਿ ਪਾਰਬ੍ਰਹਮ ਮਉਲਿ ਮਨਾ ॥",
          "roman": "prīt pārbraham maul manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰਮਾਤਮਾ (ਦੇ ਚਰਨਾਂ) ਨਾਲ ਪ੍ਰੀਤ ਪਾ ਕੇ ਸਦਾ ਖਿੜਿਆ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Возлюби стопы Параматмы и всегда оставайся расцветшим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50662,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨੁ ਕਮਾਈਐ ਪੂਛਿ ਜਨਾਂ ॥",
          "roman": "giān kamāīai pūchh janā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਸੰਤ ਜਨਾਂ ਨੂੰ ਪੁੱਛ ਕੇ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਹਾਸਲ ਕਰੀਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Спрашивая святых людей, обретают понимание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50663,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਤਪਸੀ ਜਿਸੁ ਸਾਧਸੰਗੁ ॥",
          "roman": "so tapsī jis sādhsang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ) ਤਪਸ੍ਵੀ ਉਹ ਮਨੁੱਖ ਹੈ ਜਿਸ ਨੂੰ ਗੁਰੂ ਦੀ ਸੰਗਤ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Настоящий подвижник — тот человек, кому достаётся общество Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50664,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਧਿਆਨੀ ਜਿਸੁ ਗੁਰਹਿ ਰੰਗੁ ॥੨॥",
          "roman": "sad dhiānī jis gurah rang ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਜੁੜੀ ਸੁਰਤ ਵਾਲਾ ਜਾਣੋ, ਜਿਸ ਦੇ ਅੰਦਰ ਗੁਰ (-ਚਰਨਾਂ) ਦਾ ਪਿਆਰ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "считай всегда сосредоточенным того человека, внутри которого есть любовь к стопам Гуру ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50665,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਨਿਰਭਉ ਜਿਨੑ ਭਉ ਪਇਆ ॥",
          "roman": "sē nirbhau jinh bhau paiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੰਦੇ (ਦੁਨੀਆ ਦੇ) ਡਰਾਂ ਤੋਂ ਉਤਾਂਹ ਹਨ ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਡਰ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди выше мирских страхов, в чьём уме пребывает страх перед Параматмой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50666,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੀਆ ਜਿਸੁ ਭ੍ਰਮੁ ਗਇਆ ॥",
          "roman": "so sukhīā jis bhram gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੁਖੀ ਜੀਵਨ ਵਾਲਾ ਹੈ ਜਿਸ (ਦੇ ਮਨ) ਦੀ ਭਟਕਣਾ ਦੂਰ ਹੋ ਗਈ।"
            },
            "sahib_singh_ru": {
              "main": "Счастливой жизнью обладает тот человек, чьё блуждание ума ушло."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50667,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਇਕਾਂਤੀ ਜਿਸੁ ਰਿਦਾ ਥਾਇ ॥",
          "roman": "so ikāntī jis ridā thāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਉਹ ਮਨੁੱਖ ਇਕਾਂਤ ਥਾਂ ਵਿਚ ਰਹਿੰਦਾ ਹੈ ਜਿਸ ਦਾ ਹਿਰਦਾ ਸ਼ਾਂਤ ਹੈ (ਇਕ ਥਾਂ ਟਿਕਿਆ ਹੋਇਆ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек живёт в уединённом месте, чьё сердце спокойно, устойчиво на одном месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50668,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਨਿਹਚਲੁ ਸਾਚ ਠਾਇ ॥੩॥",
          "roman": "soī nihchal sāch ṭhāi ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਅਡੋਲ ਚਿੱਤ ਵਾਲਾ ਹੈ, ਜਿਹੜਾ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек обладает неподвижным сердцем, кто постоянно остаётся соединённым со стопами вечно пребывающего Параматмы ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50669,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਖੋਜੈ ਏਕ ਪ੍ਰੀਤਿ ॥",
          "roman": "ēkā khojē ēk prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ (ਹਰ ਥਾਂ) ਇਕ ਪਰਮਾਤਮਾ ਨੂੰ ਹੀ ਭਾਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто повсюду ищет только одного Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50670,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨ ਪਰਸਨ ਹੀਤ ਚੀਤਿ ॥",
          "roman": "darsan parsan hīt chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਹੀ ਪਿਆਰ ਹੈ, ਜਿਸ ਦੇ ਚਿੱਤ ਵਿਚ ਇਕ ਪ੍ਰਭੂ ਦੇ ਦਰਸਨ ਦੀ ਛੁਹ ਦੀ ਤਾਂਘ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в чьём уме любовь только к одному Параматме, в чьём сердце есть жажда прикосновения к даршану одного Прабху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50671,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰੰਗ ਰੰਗਾ ਸਹਜਿ ਮਾਣੁ ॥",
          "roman": "har rang rangā sahaj māṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਸਭ ਰਸਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਹਰਿ-ਨਾਮ-ਰਸ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тот человек, пребывая в духовной устойчивости, наслаждается высшим среди всех вкусов — вкусом Хар-нама,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50672,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤਿਸੁ ਜਨ ਕੁਰਬਾਣੁ ॥੪॥੩॥",
          "roman": "nānak dās tis jan kurbāṇ ||4||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਆਖਦਾ ਹੈ- ਮੈਂ ਉਸ ਮਨੁੱਖ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "слуга Нанак говорит: я иду в жертву тому человеку ॥4॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
