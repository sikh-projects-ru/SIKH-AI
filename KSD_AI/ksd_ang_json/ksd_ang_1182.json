{
  "ang": 1182,
  "shabads": [
    {
      "shabad_id": 4203,
      "rahao_verse_id": 50736,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50736,
          "is_rahao": true,
          "gurmukhi": "ਤੂ ਕਰਿ ਗਤਿ ਮੇਰੀ ਪ੍ਰਭ ਦਇਆਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tū kar gat merī prabh daiār. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਿਹਰ ਕਰ) ਮੈਨੂੰ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਦੇਹ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Окажи милость и дай мне высокое духовное состояние. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50737,
          "is_rahao": false,
          "gurmukhi": "ਜਾਪ ਨ ਤਾਪ ਨ ਕਰਮ ਕੀਤਿ ॥",
          "roman": "jāp na tāp na karam kīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਕੋਈ ਜਪ ਨਹੀਂ ਕੀਤੇ, ਮੈਂ ਕੋਈ ਤਪ ਨਹੀਂ ਕੀਤੇ, ਮੈਂ (ਤੀਰਥ-ਇਸ਼ਨਾਨ ਆਦਿਕ ਮਿਥੇ ਹੋਏ ਕੋਈ ਧਾਰਮਿਕ) ਕਰਮ ਨਹੀਂ ਕੀਤੇ;"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Я не совершал никакого джапа, не совершал никакой аскезы, не совершал никаких предписанных религиозных действий, таких как омовения в тиртхах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50738,
          "is_rahao": false,
          "gurmukhi": "ਆਵੈ ਨਾਹੀ ਕਛੂ ਰੀਤਿ ॥",
          "roman": "āvē nāhī kachhū rīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਧਾਰਮਿਕ ਰੀਤ-ਰਸਮ ਕਰਨੀ ਭੀ ਮੈਨੂੰ ਨਹੀਂ ਆਉਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Я не умею исполнять никакой религиозный обряд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50739,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਰਾਖਉ ਆਸ ਏਕ ॥",
          "roman": "man meh rākhau ās ek.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਆਪਣੇ ਮਨ ਵਿਚ ਸਿਰਫ਼ ਇਹ ਆਸ ਰੱਖੀ ਬੈਠਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Но, о Прабху! В своём уме я держу только одну надежду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50740,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਤੇਰੇ ਕੀ ਤਰਉ ਟੇਕ ॥੨॥",
          "roman": "nām tere kī tarau ṭek. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਤੇਰੇ ਨਾਮ ਦੇ ਆਸਰੇ ਮੈਂ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਵਾਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Что с опорой на Твоё Имя я переправлюсь через океан мира. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50741,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਾ ਪ੍ਰਭ ਤੁਮੑ ਪ੍ਰਬੀਨ ॥",
          "roman": "sarab kalā prabh tum prabīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਾਰੀਆਂ ਹੀ ਤਾਕਤਾਂ ਵਿਚ ਪੂਰਨ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Ты совершенен во всех силах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50742,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤੁ ਨ ਪਾਵਹਿ ਜਲਹਿ ਮੀਨ ॥",
          "roman": "ant na pāveh jaleh mīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸੀਂ ਜੀਵ ਤੇਰਾ ਅੰਤ ਨਹੀਂ ਪਾ ਸਕਦੇ, ਜਿਵੇਂ ਸਮੁੰਦਰ ਦੇ) ਪਾਣੀ ਦੀਆਂ ਮੱਛੀਆਂ (ਸਮੁੰਦਰ ਦਾ) ਅੰਤ ਨਹੀਂ ਪਾ ਸਕਦੀਆਂ।"
            },
            "sahib_singh_ru": {
              "main": "Мы, живые существа, не можем постичь Твой предел, как рыбы в воде океана не могут постичь предел океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50743,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗਮ ਊਚਹ ਤੇ ਊਚ ॥",
          "roman": "agam agam ūchah te ūch.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਅਪਹੁੰਚ ਹੈਂ, ਤੂੰ ਅਪਹੁੰਚ ਹੈਂ, ਤੂੰ ਉੱਚਿਆਂ ਤੋਂ ਉੱਚਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Ты недостижим, Ты недостижим, Ты выше высочайших."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50744,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਥੋਰੇ ਤੁਮ ਬਹੁਤ ਮੂਚ ॥੩॥",
          "roman": "ham thore tum bahut mūch. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਜੀਵ ਥੋੜ-ਵਿਤੇ ਹਾਂ, ਤੂੰ ਵੱਡੇ ਜਿਗਰੇ ਵਾਲਾ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Мы, живые существа, малы и ограниченны; Ты — великодушный. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50745,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਤੂ ਧਿਆਇਆ ਸੇ ਗਨੀ ॥",
          "roman": "jin tū dhiāiā se ganī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਤੇਰਾ ਨਾਮ ਸਿਮਰਿਆ ਹੈ, ਉਹ (ਅਸਲ) ਧਨਾਢ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Те люди, которые вспоминали Твоё Имя, являются по-настоящему богатыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50746,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਤੂ ਪਾਇਆ ਸੇ ਧਨੀ ॥",
          "roman": "jin tū pāiā se dhanī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੇ ਤੈਨੂੰ ਲੱਭ ਲਿਆ ਉਹ ਅਸਲ ਦੌਲਤਮੰਦ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кто нашёл Тебя, являются по-настоящему состоятельными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50747,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਤੂ ਸੇਵਿਆ ਸੁਖੀ ਸੇ ॥",
          "roman": "jin tū seviā sukhī se.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਨੇ ਤੇਰੀ ਭਗਤੀ ਕੀਤੀ, ਉਹ ਸਭ ਸੁਖੀ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Каждый человек, который совершал Твою бхагти, счастлив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50748,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਰਣਿ ਨਾਨਕ ਪਰੇ ॥੪॥੭॥",
          "roman": "sant saraṇ Nānak pare. 4. 7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Они пребывают в прибежище Твоих святых людей. 4. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4204,
      "rahao_verse_id": 50755,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50749,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50750,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਤੂ ਸੇਵਿ ਜਿਨਿ ਤੂ ਕੀਆ ॥",
          "roman": "tis tū sēv jin tū kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਤੈਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ, ਉਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Служи и совершай преданное поклонение тому परमਾਤме, который создал тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50751,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਅਰਾਧਿ ਜਿਨਿ ਜੀਉ ਦੀਆ ॥",
          "roman": "tis arādh jin jīo dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਤੈਨੂੰ ਜਿੰਦ ਦਿੱਤੀ ਹੈ ਉਸ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Повторяй Имя того, кто дал тебе жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50752,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਚਾਕਰੁ ਹੋਹਿ ਫਿਰਿ ਡਾਨੁ ਨ ਲਾਗੈ ॥",
          "roman": "tis kā chākar hoh phir ḍān na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਉਸ (ਪਰਮਾਤਮਾ) ਦਾ ਦਾਸ ਬਣਿਆ ਰਹੇਂ, ਤਾਂ ਤੈਨੂੰ (ਜਮ ਆਦਿਕ ਕਿਸੇ ਵਲੋਂ ਭੀ) ਡੰਨ ਨਹੀਂ ਲੱਗ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Если ты остаёшься слугой того परमਾਤмы, тогда никакое наказание, даже от Джама и подобных ему, не может коснуться тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50753,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਕਰਿ ਪੋਤਦਾਰੀ ਫਿਰਿ ਦੂਖੁ ਨ ਲਾਗੈ ॥੧॥",
          "roman": "tis kī kar potdārī phir dūkh na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬੇਅੰਤ ਭੰਡਾਰਿਆਂ ਦੇ ਮਾਲਕ) ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਸਿਰਫ਼ ਭੰਡਾਰੀ ਬਣਿਆ ਰਹੁ (ਫਿਰ ਉਸ ਦੇ ਦਿੱਤੇ ਕਿਸੇ ਪਦਾਰਥ ਦੇ ਖੁੱਸ ਜਾਣ ਤੇ) ਤੈਨੂੰ ਕੋਈ ਦੁੱਖ ਨਹੀਂ ਵਿਆਪੇਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Оставайся лишь хранителем кладовых того परमਾਤмы, владыки бесконечных сокровищ; тогда, если какой-либо данный Им предмет будет утрачен, тебя не охватит никакая боль. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50754,
          "is_rahao": true,
          "gurmukhi": "ਏਵਡ ਭਾਗ ਹੋਹਿ ਜਿਸੁ ਪ੍ਰਾਣੀ ॥",
          "roman": "ēvaḍ bhāg hoh jis prāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਬੜੇ ਵੱਡੇ ਭਾਗ ਹੋਣ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, у которого есть очень великая удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50755,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਪਾਏ ਇਹੁ ਪਦੁ ਨਿਰਬਾਣੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "so pāē ih pad nirbāṇī rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਉਹ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ ਜਿੱਥੇ ਕੋਈ ਵਾਸਨਾ ਪੋਹ ਨਹੀਂ ਸਕਦੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "получает то духовное состояние, где никакое желание не может его коснуться. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50756,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੀ ਸੇਵਾ ਜੀਵਨੁ ਬਿਰਥਾ ॥",
          "roman": "dūjī sēvā jīvan birthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਨੂੰ ਛੱਡ ਕੇ) ਕਿਸੇ ਹੋਰ ਦੀ ਖ਼ਿਦਮਤ ਵਿਚ ਜ਼ਿੰਦਗੀ ਵਿਅਰਥ ਚਲੀ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Оставив परमਾਤму, жизнь в служении кому-либо другому проходит впустую,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50757,
          "is_rahao": false,
          "gurmukhi": "ਕਛੂ ਨ ਹੋਈ ਹੈ ਪੂਰਨ ਅਰਥਾ ॥",
          "roman": "kachhū na hoī hē pūran arthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਲੋੜ ਭੀ ਕੋਈ ਪੂਰੀ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "и никакая нужда также не исполняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50758,
          "is_rahao": false,
          "gurmukhi": "ਮਾਣਸ ਸੇਵਾ ਖਰੀ ਦੁਹੇਲੀ ॥",
          "roman": "māṇas sēvā kharī duhēlī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਦੀ ਖ਼ਿਦਮਤ ਬਹੁਤ ਦੁਖਦਾਈ ਹੋਇਆ ਕਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Служение человеку бывает очень мучительным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50759,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੇਵਾ ਸਦਾ ਸੁਹੇਲੀ ॥੨॥",
          "roman": "sādh kī sēvā sadā suhēlī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੇਵਾ ਸਦਾ ਹੀ ਸੁਖ ਦੇਣ ਵਾਲੀ ਹੁੰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Служение Гуру всегда дарует покой. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50760,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਲੋੜਹਿ ਸਦਾ ਸੁਖੁ ਭਾਈ ॥",
          "roman": "jē loṛeh sadā sukh bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇ ਤੂੰ ਚਾਹੁੰਦਾ ਹੈਂ ਕਿ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਿਲਿਆ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Если ты хочешь, чтобы всегда пребывал духовный आनंद,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50761,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਤਿ ਗੁਰਹਿ ਬਤਾਈ ॥",
          "roman": "sādhū sangat gureh batāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ, ਗੁਰੂ ਨੇ ਦੱਸਿਆ ਹੈ ਕਿ ਸਾਧ ਸੰਗਤ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "то Гуру указал: пребывай в Садх Сангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50762,
          "is_rahao": false,
          "gurmukhi": "ਊਹਾ ਜਪੀਐ ਕੇਵਲ ਨਾਮ ॥",
          "roman": "ūhā japīai kēval nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В Садх Сангат повторяется только Имя परमਾਤмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50763,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਤਿ ਪਾਰਗਰਾਮ ॥੩॥",
          "roman": "sādhū sangat pārgarām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਟਿਕ ਕੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਣ ਜੋਗਾ ਹੋ ਜਾਈਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и, утвердившись в Садх Сангат, человек становится способным переправиться через мирской океан. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50764,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਤ ਮਹਿ ਤਤੁ ਗਿਆਨੁ ॥",
          "roman": "sagal tat meh tat giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਬਣਾਣੀ ਸਭ ਵਿਚਾਰਾਂ ਨਾਲੋਂ ਸ੍ਰੇਸ਼ਟ ਵਿਚਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Установить знакомство с परमਾਤмой — это высшая мысль среди всех размышлений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50765,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਧਿਆਨ ਮਹਿ ਏਕੁ ਧਿਆਨੁ ॥",
          "roman": "sarab dhiān meh ēk dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਵਿਚ ਸੁਰਤ ਟਿਕਾਈ ਰੱਖਣੀ ਹੋਰ ਸਾਰੀਆਂ ਸਮਾਧੀਆਂ ਨਾਲੋਂ ਵਧੀਆ ਸਮਾਧੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Держать сознание сосредоточенным на परमਾਤме — лучшая самадхи среди всех самадхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50766,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਨ ਮਹਿ ਊਤਮ ਧੁਨਾ ॥",
          "roman": "har kīrtan meh ūtam dhunā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਿਚ ਸੁਰਤ ਜੋੜਨੀ ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਕੰਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Соединять сознание с восхвалением परमਾਤмы — самое превосходное дело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50767,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਮਿਲਿ ਗਾਇ ਗੁਨਾ ॥੪॥੮॥",
          "roman": "nānak gur mil gāē gunā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਗੁਣ ਗਾਂਦਾ ਰਿਹਾ ਕਰ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Встретив Гуру, продолжай петь Его достоинства. ॥4॥8॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4205,
      "rahao_verse_id": 50774,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50768,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50769,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਬੋਲਤ ਮੁਖੁ ਪਵਿਤੁ ਹੋਇ ॥",
          "roman": "jis bolat mukh pavit hoē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਹਰਿ-ਨਾਮ ਉਚਾਰਿਆ ਕਰ) ਜਿਸ ਨੂੰ ਉਚਾਰਦਿਆਂ ਮੂੰਹ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Произноси то Хар-Нам, при произнесении которого уста становятся чистыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50770,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਨਿਰਮਲ ਹੈ ਸੋਇ ॥",
          "roman": "jis simrat nirmal hē soē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਸਿਮਰਦਿਆਂ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਬੇ-ਦਾਗ਼ ਸੋਭਾ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "при памятовании которого человек получает незапятнанную славу в этом мире и в мире ином,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50771,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਅਰਾਧੇ ਜਮੁ ਕਿਛੁ ਨ ਕਹੈ ॥",
          "roman": "jis arādhē jam kichh na kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਅਰਾਧਦਿਆਂ ਜਮ-ਰਾਜ ਕੁਝ ਨਹੀਂ ਆਖਦਾ (ਡਰਾ ਨਹੀਂ ਸਕਦਾ),"
            },
            "sahib_singh_ru": {
              "main": "при поклонении которому Джам-радж ничего не говорит, то есть не может устрашить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50772,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੀ ਸੇਵਾ ਸਭੁ ਕਿਛੁ ਲਹੈ ॥੧॥",
          "roman": "jis kī sēvā sabh kichh lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਨਾਲ (ਮਨੁੱਖ) ਹਰੇਕ (ਲੋੜੀਂਦੀ) ਚੀਜ਼ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "через служение и преданное поклонение которому человек получает всё необходимое. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50773,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਰਾਮ ਬੋਲਿ ਰਾਮ ਰਾਮ ॥",
          "roman": "rām rām bol rām rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ (ਉਸ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਿਆ ਕਰ, ਹਰਿ-ਨਾਮ ਉਚਾਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда произноси Имя того परमਾਤмы, произноси Хар-Нам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50774,
          "is_rahao": true,
          "gurmukhi": "ਤਿਆਗਹੁ ਮਨ ਕੇ ਸਗਲ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tiāgah man kē sagal kām rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੀਆਂ ਹੋਰ ਸਾਰੀਆਂ ਵਾਸ਼ਨਾਂ ਛੱਡ ਦੇਹ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Оставь все прочие желания своего ума. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50775,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੇ ਧਾਰੇ ਧਰਣਿ ਅਕਾਸੁ ॥",
          "roman": "jis kē dhārē dharaṇ akās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ) ਧਰਤੀ ਤੇ ਆਕਾਸ਼ ਜਿਸ ਦੇ ਟਿਕਾਏ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Вспоминай Имя того परमਾਤмы, на чьей опоре стоят земля и небо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50776,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਜਿਸ ਕਾ ਹੈ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "ghaṭ ghaṭ jis kā hē pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨੂਰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "чей свет пребывает в каждом теле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50777,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਪਤਿਤ ਪੁਨੀਤ ਹੋਇ ॥",
          "roman": "jis simrat patit punīt hoē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਸਿਮਰਦਿਆਂ ਵਿਕਾਰੀ ਮਨੁੱਖ (ਭੀ) ਸੁੱਚੇ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "при памятовании которого даже порочный человек становится живущим чистой жизнью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50778,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤ ਕਾਲਿ ਫਿਰਿ ਫਿਰਿ ਨ ਰੋਇ ॥੨॥",
          "roman": "ant kāl phir phir na roē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ, ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਅੰਤ ਸਮੇ (ਮਨੁੱਖ) ਮੁੜ ਮੁੜ ਦੁਖੀ ਨਹੀਂ ਹੁੰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и благодаря которому в последний час человек не страдает снова и снова. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50779,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਧਰਮ ਮਹਿ ਊਤਮ ਧਰਮ ॥",
          "roman": "sagal dharam meh ūtam dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ) ਸਾਰੇ ਧਰਮਾਂ ਵਿਚੋਂ (ਨਾਮ-ਸਿਮਰਨ ਹੀ) ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਧਰਮ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Вспоминай Имя परमਾਤмы: среди всех дхарм памятование Имени — высшая дхарма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50780,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਕਰਤੂਤਿ ਕੈ ਊਪਰਿ ਕਰਮ ॥",
          "roman": "karam kartūt kē ūpar karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੀ ਕਰਮ ਹੋਰ ਸਾਰੇ ਧਾਰਮਿਕ ਕਰਮਾਂ ਨਾਲੋਂ ਉੱਤਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "именно это действие выше всех прочих религиозных действий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50781,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਉ ਚਾਹਹਿ ਸੁਰਿ ਨਰ ਦੇਵ ॥",
          "roman": "jis kau chāheh sur nar dēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਯਾਦ ਕਰਿਆ ਕਰ) ਜਿਸ ਨੂੰ (ਮਿਲਣ ਲਈ) ਦੈਵੀ ਗੁਣਾਂ ਵਾਲੇ ਮਨੁੱਖ ਅਤੇ ਦੇਵਤੇ ਭੀ ਲੋਚਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Помни того परमਾਤму, которого стремятся обрести даже люди с божественными качествами и дэвы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50782,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਭਾ ਕੀ ਲਗਹੁ ਸੇਵ ॥੩॥",
          "roman": "sant sabhā kī lagah sēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਦੀ ਸੇਵਾ ਕਰਿਆ ਕਰ (ਸਾਧ ਸੰਗਤ ਵਿਚੋਂ ਹੀ ਨਾਮ-ਸਿਮਰਨ ਦੀ ਦਾਤ ਮਿਲਦੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Служи Садх Сангат; именно в Садх Сангат обретается дар памятования Имени. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50783,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖਿ ਜਿਸੁ ਕੀਆ ਦਾਨੁ ॥",
          "roman": "ād purakh jis kīā dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੇ ਮੂਲ ਅਤੇ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਦਾਤ ਬਖ਼ਸ਼ੀ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, которому изначальный и всепроникающий Господь даровал дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50784,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਉ ਮਿਲਿਆ ਹਰਿ ਨਿਧਾਨੁ ॥",
          "roman": "tis kau miliā har nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰਿ-ਨਾਮ ਦਾ ਖ਼ਜ਼ਾਨਾ ਮਿਲ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "получил сокровище Хар-Нама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50785,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਗਤਿ ਮਿਤਿ ਕਹੀ ਨ ਜਾਇ ॥",
          "roman": "tis kī gat mit kahī na jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਬਾਬਤ ਇਹ ਨਹੀਂ ਦੱਸਿਆ ਜਾ ਸਕਦਾ ਕਿ ਉਹ ਕਿਹੋ ਜਿਹਾ ਹੈ ਅਤੇ ਕੇਡਾ ਵੱਡਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О нём невозможно сказать, каков он и насколько велик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50786,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਨ ਹਰਿ ਹਰਿ ਧਿਆਇ ॥੪॥੯॥",
          "roman": "nānak jan har har dhiāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ ॥੪॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! Всегда вспоминай Имя परमਾਤмы. ॥4॥9॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4206,
      "rahao_verse_id": 50793,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50787,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50788,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਭੀਤਰਿ ਲਾਗੀ ਪਿਆਸ ॥",
          "roman": "man tan bhītar lāgī piās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ) ਮੇਰੇ ਮਨ ਵਿਚ ਮੇਰੇ ਤਨ ਵਿਚ (ਹਰਿ-ਨਾਮ ਦੀ) ਲਗਨ ਬਣ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь в моём уме и в моём теле возникло стремление к Хар-Наму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50789,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਦਇਆਲਿ ਪੂਰੀ ਮੇਰੀ ਆਸ ॥",
          "roman": "gur daiāl pūrī mērī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆਵਾਨ ਗੁਰੂ ਨੇ ਮੇਰੀ (ਚਿਰਾਂ ਦੀ) ਆਸ ਪੂਰੀ ਕਰ ਦਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Милостивый Гуру исполнил мою давнюю надежду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50790,
          "is_rahao": false,
          "gurmukhi": "ਕਿਲਵਿਖ ਕਾਟੇ ਸਾਧਸੰਗਿ ॥",
          "roman": "kilvikh kāṭē sādhsang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ (ਮੇਰੇ ਸਾਰੇ) ਪਾਪ ਕੱਟੇ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру были отсечены все мои грехи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50791,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਿਓ ਹਰਿ ਨਾਮ ਰੰਗਿ ॥੧॥",
          "roman": "nām japiō har nām rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਂ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਟਿਕ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਰਿਹਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "потому что по милости Гуру я, пребывая в цвете любви, повторяю Имя परमਾਤмы. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50792,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਬਸੰਤੁ ਬਨਾ ॥",
          "roman": "gur parsād basant banā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਮੇਰੇ ਅੰਦਰ) ਬਸੰਤ (ਰੁੱਤ ਵਾਲਾ ਖਿੜਾਉ) ਬਣ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру внутри меня настала весна, расцвет весенней поры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50793,
          "is_rahao": true,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਉਰਿ ਧਾਰੇ ਸਦਾ ਸਦਾ ਹਰਿ ਜਸੁ ਸੁਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "charan kamal hirdē ur dhārē sadā sadā har jas sunā rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ) ਮੈਂ ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਦਿਲ ਵਿਚ ਵਸਾ ਲਏ ਹਨ। ਹੁਣ ਮੈਂ ਹਰ ਵੇਲੇ ਸਦਾ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру я поселил прекрасные стопы परमਾਤмы в своём сердце. Теперь я всегда, во всякое время, слушаю восхваление परमਾਤмы. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
