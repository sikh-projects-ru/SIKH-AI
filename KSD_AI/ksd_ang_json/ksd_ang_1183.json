{
  "ang": 1183,
  "shabads": [
    {
      "shabad_id": 4206,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50794,
          "is_rahao": false,
          "gurmukhi": "ਸਮਰਥ ਸੁਆਮੀ ਕਾਰਣ ਕਰਣ ॥",
          "roman": "samrath suāmī kāraṇ karaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਤਾਕਤਾਂ ਦੇ ਮਾਲਕ! ਹੇ ਸੁਆਮੀ! ਹੇ ਜਗਤ ਦੇ ਮੂਲ!"
            },
            "sahib_singh_ru": {
              "main": "О Владыка всех сил! О Суами! О источник мира!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50795,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਅਨਾਥ ਪ੍ਰਭ ਤੇਰੀ ਸਰਣ ॥",
          "roman": "moh anāth prabh tērī saraṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਅਨਾਥ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Я, беззащитный, пришёл под Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50796,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਤੇਰੇ ਆਧਾਰਿ ॥",
          "roman": "jīa jant tērē ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਜੀਅ ਜੰਤ ਤੇਰੇ ਹੀ ਆਸਰੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Все живые существа опираются только на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50797,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਲੇਹਿ ਨਿਸਤਾਰਿ ॥੨॥",
          "roman": "kar kirpā prabh lēh nistār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ (ਇਹਨਾਂ ਨੂੰ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Прояви милость и переправь их через мирской океан. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50798,
          "is_rahao": false,
          "gurmukhi": "ਭਵ ਖੰਡਨ ਦੁਖ ਨਾਸ ਦੇਵ ॥",
          "roman": "bhav khaṇḍan dukh nās dēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਜੋ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਕੱਟਣ ਵਾਲਾ ਹੈ, ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਅਤੇ ਚਾਨਣ-ਰੂਪ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Параматма, который разрывает круг рождения и смерти, уничтожает страдания и является образом света,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50799,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਿ ਨਰ ਮੁਨਿ ਜਨ ਤਾ ਕੀ ਸੇਵ ॥",
          "roman": "sur nar mun jan tā kī sēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੈਵੀ ਗੁਣਾਂ ਵਾਲੇ ਮਨੁੱਖ ਅਤੇ ਮੁਨੀ ਲੋਕ ਉਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "люди с божественными качествами и муни совершают Его служение и преданное поклонение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50800,
          "is_rahao": false,
          "gurmukhi": "ਧਰਣਿ ਅਕਾਸੁ ਜਾ ਕੀ ਕਲਾ ਮਾਹਿ ॥",
          "roman": "dharaṇ akās jā kī kalā māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਤੀ ਅਤੇ ਆਕਾਸ਼ ਜਿਸ (ਪਰਮਾਤਮਾ) ਦੀ ਸੱਤਿਆ ਦੇ ਆਸਰੇ ਟਿਕੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Земля и небо стоят на опоре силы того परमਾਤмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50801,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਦੀਆ ਸਭਿ ਜੰਤ ਖਾਹਿ ॥੩॥",
          "roman": "tērā dīā sabh jant khāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਜੀਵ ਤੇਰਾ ਦਿੱਤਾ (ਅੰਨ) ਖਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Все существа едят пищу, данную Тобой. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50802,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਪ੍ਰਭ ਦਇਆਲ ॥",
          "roman": "antarjāmī prabh daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੇ ਦਿਲਾਂ ਦੀ ਜਾਣਨ ਵਾਲੇ ਦਇਆਲ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О милостивый Прабху, знающий сердца всех!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50803,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੇ ਦਾਸ ਕਉ ਨਦਰਿ ਨਿਹਾਲਿ ॥",
          "roman": "apṇē dās kau nadar nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਦਾਸ ਨੂੰ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਵੇਖ।"
            },
            "sahib_singh_ru": {
              "main": "Посмотри на своего слугу взглядом милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50804,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਦੇਹੁ ਦਾਨੁ ॥",
          "roman": "kar kirpā moh dēh dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ (ਇਹ) ਦਾਨ ਦੇਹ,"
            },
            "sahib_singh_ru": {
              "main": "Прояви милость и дай мне этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50805,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜੀਵੈ ਨਾਨਕੁ ਤੇਰੋ ਨਾਮੁ ॥੪॥੧੦॥",
          "roman": "jap jīvē nānak tēro nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ (ਤੇਰਾ ਦਾਸ) ਨਾਨਕ ਤੇਰਾ ਨਾਮ ਜਪ ਕੇ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰੇ ॥੪॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Твой слуга Нанак, повторяя Твоё Имя, обрёл духовную жизнь. ॥4॥10॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4207,
      "rahao_verse_id": 50812,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50806,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50807,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰੰਗਿ ਸਭ ਗਏ ਪਾਪ ॥",
          "roman": "rām raṅg sabh gaye pāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਪਿਆਰ ਵਿਚ (ਟਿਕਿਆਂ) ਸਾਰੇ ਪਾਪ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В любви к परमात्मе все грехи исчезают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50808,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਜਪਤ ਕਛੁ ਨਹੀ ਸੰਤਾਪ ॥",
          "roman": "rām japat kachh nahī santāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ ਕੋਈ ਦੁੱਖ ਕਲੇਸ਼ ਪੋਹ ਨਹੀਂ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "когда повторяют Имя परमात्मы, никакое страдание и мучение не могут коснуться,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50809,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਜਪਤ ਸਭਿ ਮਿਟੇ ਅੰਧੇਰ ॥",
          "roman": "gobind japat sabh miṭe andher ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਸਾਰੇ ਹਨੇਰੇ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "когда повторяют Имя Гобинда, вся тьма привязанности к майе исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50810,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਕਛੁ ਨਾਹਿ ਫੇਰ ॥੧॥",
          "roman": "har simrat kachh nāh pher ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਸਿਮਰਦਿਆਂ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਨਹੀਂ ਰਹਿ ਜਾਂਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "когда вспоминают Хар-Имя, круговорот рождения и смерти больше не остаётся ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50811,
          "is_rahao": true,
          "gurmukhi": "ਬਸੰਤੁ ਹਮਾਰੈ ਰਾਮ ਰੰਗੁ ॥",
          "roman": "basant hamārē rām raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ) ਮੇਰੇ ਅੰਦਰ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦਾ ਪਿਆਰ ਬਣ ਗਿਆ ਹੈ, ਮੇਰੇ ਹਿਰਦੇ ਵਿਚ ਖਿੜਾਉ ਪੈਦਾ ਹੋ ਗਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь во мне возникла любовь к परमात्मе, к Его Имени; в моём сердце появилось цветение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50812,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਸਿਉ ਸਦਾ ਸੰਗੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sant janā siu sadā saṅg ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਸੰਤ ਜਨਾਂ ਨਾਲ (ਮੇਰਾ) ਸਦਾ ਸਾਥ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру у меня всегда сохраняется общение со святыми людьми ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50813,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨੀ ਕੀਆ ਉਪਦੇਸੁ ॥",
          "roman": "sant janī kīā updes ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਨੇ ਇਹ ਸਿੱਖਿਆ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Святые люди дали такое наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50814,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਗੋਬਿੰਦ ਭਗਤੁ ਸੋ ਧੰਨਿ ਦੇਸੁ ॥",
          "roman": "jah gobind bhagat so dhann des ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਜਿੱਥੇ ਪਰਮਾਤਮਾ ਦਾ ਭਗਤ ਵੱਸਦਾ ਹੈ ਉਹ ਦੇਸ ਭਾਗਾਂ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что страна, где живёт преданный परमात्मы, благословенна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50815,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਭਗਤਿਹੀਨ ਉਦਿਆਨ ਥਾਨੁ ॥",
          "roman": "har bhagtihīn udiān thān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਤੋਂ ਸੱਖਣਾ ਥਾਂ ਉਜਾੜ (ਬਰਾਬਰ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "А место, лишённое преданности परमात्मе, подобно пустыне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50816,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਘਟਿ ਘਟਿ ਪਛਾਨੁ ॥੨॥",
          "roman": "gur prasād ghaṭ ghaṭ pachhān ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ) ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਸਮਝ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру пойми, что Он пребывает в каждом теле ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50817,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਨ ਰਸ ਭੋਗ ਰੰਗੁ ॥",
          "roman": "har kīrtan ras bhog raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨੂੰ ਹੀ ਦੁਨੀਆ ਦੇ ਰਸਾਂ ਭੋਗਾਂ ਦੀ ਮੌਜ-ਬਹਾਰ ਸਮਝ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Считай прославление परमात्मы самой радостью и наслаждением всех мирских вкусов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50818,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਪਾਪ ਕਰਤ ਤੂ ਸਦਾ ਸੰਗੁ ॥",
          "roman": "man pāp karat tū sadā saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪਾਪ ਕਰਦਿਆਂ ਸਦਾ ਝਿਜਕਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Совершая грех, всегда стыдись и сдерживайся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50819,
          "is_rahao": false,
          "gurmukhi": "ਨਿਕਟਿ ਪੇਖੁ ਪ੍ਰਭੁ ਕਰਣਹਾਰ ॥",
          "roman": "nikaṭ pekh prabh karṇahār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਕੁਝ ਕਰ ਸਕਣ ਵਾਲੇ ਪ੍ਰਭੂ ਨੂੰ (ਆਪਣੇ) ਨੇੜੇ ਵੱਸਦਾ ਵੇਖ।"
            },
            "sahib_singh_ru": {
              "main": "Видь Господа, способного всё совершить, пребывающим рядом с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50820,
          "is_rahao": false,
          "gurmukhi": "ਈਤ ਊਤ ਪ੍ਰਭ ਕਾਰਜ ਸਾਰ ॥੩॥",
          "roman": "īt ūt prabh kāraj sār ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਅਤੇ ਪਰਲੋਕ ਦੇ ਸਾਰੇ ਕੰਮ ਪ੍ਰਭੂ ਹੀ ਸੰਵਾਰਨ ਵਾਲਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И в этом мире, и в мире ином все дела устраивает Господь ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50821,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਗੋ ਧਿਆਨੁ ॥",
          "roman": "charan kamal siu lago dhiān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਸੁਰਤ ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "Сознание того человека соединилось с прекрасными стопами Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50822,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਕੀਨੋ ਦਾਨੁ ॥",
          "roman": "kar kirpā prabh kīno dān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਮਿਹਰ ਕਰ ਕੇ (ਜਿਸ ਉੱਤੇ) ਬਖ਼ਸ਼ਸ਼ ਕੀਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "к кому Господь, проявив милость, сделал дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50823,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਿਆ ਸੰਤ ਜਨਾ ਕੀ ਬਾਛਉ ਧੂਰਿ ॥",
          "roman": "teriā sant janā kī bāchhau dhūr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу пыли стоп Твоих святых людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50824,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਨਾਨਕ ਸੁਆਮੀ ਸਦ ਹਜੂਰਿ ॥੪॥੧੧॥",
          "roman": "jap nānak suāmī sad hajūr ॥4॥11॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾ ਕਿ) ਹੇ ਸੁਆਮੀ! (ਉਹਨਾਂ ਦੀ ਸੰਗਤ ਦੀ ਬਰਕਤਿ ਨਾਲ ਤੈਨੂੰ) (ਦਾਸ) ਨਾਨਕ ਸਦਾ ਅੰਗ-ਸੰਗ ਸਮਝ ਕੇ ਜਪਦਾ ਰਹੇ ॥੪॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы, о Владыка, по благословению их общения слуга Нанак всегда повторял Тебя, считая Тебя близко пребывающим рядом ॥4॥11॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4208,
      "rahao_verse_id": 50831,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50825,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50826,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਪਰਮੇਸਰੁ ਨਿਤ ਨਵਾ ॥",
          "roman": "sach parmesar nit navā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, (ਫਿਰ ਉਹ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ ਕਿਉਂਕਿ ਉਹ) ਸਦਾ ਹੀ ਨਵਾਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "परमात्मा вечно пребывающий; и Он дорог, потому что Он всегда новый."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50827,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਨਿਤ ਚਵਾ ॥",
          "roman": "gur kirpā te nit chavā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਮੈਂ ਸਦਾ (ਉਸ ਦਾ ਨਾਮ) ਉਚਾਰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру я всегда произношу Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50828,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਰਖਵਾਲੇ ਮਾਈ ਬਾਪ ॥",
          "roman": "prabh rakhvāle māī bāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਮਾਪੇ (ਆਪਣੇ ਬੱਚੇ ਦਾ ਸਦਾ ਧਿਆਨ ਰੱਖਦੇ ਹਨ, ਤਿਵੇਂ) ਪ੍ਰਭੂ ਜੀ ਸਦਾ (ਮੇਰੇ) ਰਾਖੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Как родители всегда заботятся о своём ребёнке, так Господь всегда является моим защитником,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50829,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਣਿ ਨਹੀ ਸੰਤਾਪ ॥੧॥",
          "roman": "jā kē simraṇ nahī santāp ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਪ੍ਰਭੂ ਐਸਾ ਹੈ) ਕਿ ਉਸ ਦੇ ਸਿਮਰਨ ਨਾਲ ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ ਪੋਹ ਨਹੀਂ ਸਕਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "этот Господь таков, что при Его памятовании никакое страдание и мучение не могут коснуться ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50830,
          "is_rahao": true,
          "gurmukhi": "ਖਸਮੁ ਧਿਆਈ ਇਕ ਮਨਿ ਇਕ ਭਾਇ ॥",
          "roman": "khasam dhiāī ik man ik bhāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ) ਮੈਂ ਇਕਾਗ੍ਰ ਮਨ ਨਾਲ ਉਸੇ ਦੇ ਪਿਆਰ ਵਿਚ ਟਿਕ ਕੇ ਉਸ ਖਸਮ-ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹਾ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь я с сосредоточенным умом, пребывая в Его любви, продолжаю вспоминать того Хозяина-Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50831,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਸਦਾ ਸਰਣਾਈ ਸਾਚੈ ਸਾਹਿਬਿ ਰਖਿਆ ਕੰਠਿ ਲਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūre kī sadā sarṇāī sāchē sāhib rakhiā kaṇṭh lāi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਦਾ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹਾਂ (ਉਸ ਦੀ ਮਿਹਰ ਨਾਲ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੇ (ਮੈਨੂੰ) ਆਪਣੇ ਗਲ ਨਾਲ ਲਾ ਕੇ ਰੱਖਿਆ ਕੀਤੀ ਹੋਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "я всегда остаюсь в прибежище совершенного Гуру; по его милости вечно пребывающий Владыка-Господь прижал меня к Своей груди и защитил ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50832,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣੇ ਜਨ ਪ੍ਰਭਿ ਆਪਿ ਰਖੇ ॥",
          "roman": "apṇe jan prabh āp rakhe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਸਦਾ ਆਪ ਰੱਖਿਆ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь всегда Сам защищал Своих служителей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50833,
          "is_rahao": false,
          "gurmukhi": "ਦੁਸਟ ਦੂਤ ਸਭਿ ਭ੍ਰਮਿ ਥਕੇ ॥",
          "roman": "dusaṭ dūt sabh bhram thake ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕਾਂ ਦੇ) ਭੈੜੇ ਵੈਰੀ ਸਾਰੇ ਭਟਕ ਭਟਕ ਕੇ ਹਾਰ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все злые враги служителей, блуждая снова и снова, устают и терпят поражение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50834,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਸਾਚੇ ਨਹੀ ਜਾਇ ॥",
          "roman": "bin gur sāche nahī jāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕਾਂ ਨੂੰ) ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਰੂਪ ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਆਸਰਾ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "У служителей нет иной опоры, кроме Гуру, образа вечно устойчивого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50835,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਦੇਸ ਦਿਸੰਤਰਿ ਰਹੇ ਧਾਇ ॥੨॥",
          "roman": "dukh des disantar rahe dhāi ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਨੂੰ ਛੱਡ ਕੇ) ਹੋਰ ਹੋਰ ਥਾਂ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ, ਉਹਨਾਂ ਨੂੰ ਦੁੱਖ (ਵਾਪਰਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тех людей, которые, оставив Гуру, блуждают по разным местам, постигает страдание ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50836,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਤੁ ਓਨੑਾ ਕਾ ਮਿਟਸਿ ਨਾਹਿ ॥",
          "roman": "kirat onhā kā miṭas nāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੂੰ ਛੱਡ ਕੇ ਹੋਰ ਹੋਰ ਥਾਂ ਭਟਕਣ ਵਾਲੇ) ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਦਾ (ਇਹ) ਕੀਤਾ ਹੋਇਆ ਕੰਮ (ਕੀਤੇ ਇਹਨਾਂ ਕੰਮਾਂ ਦਾ ਸੰਸਕਾਰ-ਸਮੂਹ ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਮਿਟਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "У тех людей, которые, оставив Гуру, блуждают по разным местам, это сделанное ими дело, совокупность следов этих поступков, не исчезает изнутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50837,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਅਪਣਾ ਬੀਜਿਆ ਆਪਿ ਖਾਹਿ ॥",
          "roman": "oi apṇā bījiā āp khāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਕੀਤੇ ਕਰਮਾਂ ਦਾ ਫਲ ਉਹ ਆਪ ਹੀ ਖਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Плод посеянных ими самими поступков они сами и вкушают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50838,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਾ ਰਖਵਾਲਾ ਆਪਿ ਸੋਇ ॥",
          "roman": "jan kā rakhvālā āp soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸੇਵਕ ਦਾ ਰਾਖਾ ਪ੍ਰਭੂ ਆਪ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам становится защитником Своего служителя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50839,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਉ ਪਹੁਚਿ ਨ ਸਕਸਿ ਕੋਇ ॥੩॥",
          "roman": "jan kau pahuch na sakas koi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਹੋਰ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Никакой другой человек не может сравниться со служителем Господа ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50840,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਦਾਸ ਰਖੇ ਕਰਿ ਜਤਨੁ ਆਪਿ ॥",
          "roman": "prabh dās rakhe kar jatan āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੇ (ਉਚੇਚਾ) ਜਤਨ ਕਰ ਕੇ ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਸਦਾ ਆਪ ਰਾਖੀ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь, приложив особое старание, всегда Сам защищал Своих служителей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50841,
          "is_rahao": false,
          "gurmukhi": "ਅਖੰਡ ਪੂਰਨ ਜਾ ਕੋ ਪ੍ਰਤਾਪੁ ॥",
          "roman": "akhaṇḍ pūran jā ko pratāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਅਤੁੱਟ ਅਤੇ ਪੂਰਨ ਪਰਤਾਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чья слава непрерывна и совершенна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50842,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗੋਬਿੰਦ ਨਿਤ ਰਸਨ ਗਾਇ ॥",
          "roman": "guṇ gobind nit rasan gāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੋਬਿੰਦ ਦੇ ਗੁਣ ਸਦਾ ਆਪਣੀ ਜੀਭ ਨਾਲ ਗਾਇਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда пой своим языком достоинства того Гобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50843,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜੀਵੈ ਹਰਿ ਚਰਣ ਧਿਆਇ ॥੪॥੧੨॥",
          "roman": "nānak jīvē har charaṇ dhiāi ॥4॥12॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ (ਭੀ) ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак тоже, удерживая внимание на стопах того परमात्मы, продолжает обретать духовную жизнь ॥4॥12॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4209,
      "rahao_verse_id": 50850,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50844,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50845,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚਰਣ ਸਰੇਵਤ ਦੁਖੁ ਗਇਆ ॥",
          "roman": "gur charaṇ sarevat dukh gaiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨ ਹਿਰਦੇ ਵਿਚ ਵਸਾਂਦਿਆਂ ਉਸ ਮਨੁੱਖ ਦਾ ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек поселяeт стопы Гуру в сердце, всякое его страдание уходит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50846,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮਿ ਪ੍ਰਭਿ ਕਰੀ ਮਇਆ ॥",
          "roman": "pārbraham prabh karī maiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉਤੇ) ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਨੇ ਮਿਹਰ ਕੀਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "если Парбрахм-Господь проявил к нему милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50847,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਮਨੋਰਥ ਪੂਰਨ ਕਾਮ ॥",
          "roman": "sarab manorath pūran kām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀਆਂ ਸਾਰੀਆਂ ਮੁਰਾਦਾਂ ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все его желания и все его дела достигают завершения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50848,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜੀਵੈ ਨਾਨਕੁ ਰਾਮ ਨਾਮ ॥੧॥",
          "roman": "jap jīvē nānak rām nām ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ (ਭੀ) ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак тоже, повторяя Имя того परमात्मы, обретает духовную жизнь ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50849,
          "is_rahao": true,
          "gurmukhi": "ਸਾ ਰੁਤਿ ਸੁਹਾਵੀ ਜਿਤੁ ਹਰਿ ਚਿਤਿ ਆਵੈ ॥",
          "roman": "sā rut suhāvī jit har chit āvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ ਵਾਸਤੇ) ਉਹ ਰੁੱਤ ਸੋਹਣੀ ਹੁੰਦੀ ਹੈ ਜਦੋਂ ਪਰਮਾਤਮਾ ਉਸ ਦੇ ਚਿੱਤ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Для человека прекрасна та пора, когда परमात्मा приходит и поселяется в его сознании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50850,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਸਤਿਗੁਰ ਦੀਸੈ ਬਿਲਲਾਂਤੀ ਸਾਕਤੁ ਫਿਰਿ ਫਿਰਿ ਆਵੈ ਜਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bin satigur dīsē billāntī sākat phir phir āvē jāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਬਿਨਾ (ਲੁਕਾਈ) ਵਿਲਕਦੀ ਦਿੱਸਦੀ ਹੈ। ਪਰਮਾਤਮਾ ਤੋਂ ਟੁੱਟਾ ਹੋਇਆ ਮਨੁੱਖ ਮੁੜ ਮੁੜ ਜੰਮਦਾ ਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без прибежища Гуру люди видятся плачущими и мучающимися. Человек, оторванный от परमात्मы, снова и снова рождается и умирает ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
