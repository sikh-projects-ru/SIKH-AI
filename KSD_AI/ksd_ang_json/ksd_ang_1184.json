              "main": ""
            }
          }
        },
        {
          "verse_id": 50901,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮੁ ਧਰਮੁ ਮੇਰਾ ਕਛੁ ਨ ਬੀਚਾਰਿਓ ॥",
          "roman": "karam dharam mērā kachh na bīchāriō",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
