        {
          "verse_id": 50897,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਕਰਿ ਕੀਨੑੇ ਨਿਹਾਲ ॥",
          "roman": "hukam kar kīnhē nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪਣੇ ਹੁਕਮ ਅਨੁਸਾਰ (ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ) ਪ੍ਰਸੰਨ-ਚਿੱਤ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог по Своему повелению держит Своих слуг в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50898,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕਉ ਭਇਆ ਦਇਆਲੁ ॥੧॥",
          "roman": "apnē sēvak kau bhaiā daiāl. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣੇ ਸੇਵਕਾਂ ਉੱਤੇ (ਸਦਾ) ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он всегда милостив к Своим слугам. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50899,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਸਭੁ ਪੂਰਾ ਕੀਆ ॥",
          "roman": "gur pūrē sabh pūrā kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ (ਉਸ ਮਨੁੱਖ ਦਾ) ਹਰੇਕ ਕੰਮ ਸਿਰੇ ਚਾੜ੍ਹ ਦਿੱਤਾ (ਉਸ ਦਾ ਸਾਰਾ ਜੀਵਨ ਸਫਲ ਕਰ ਦਿੱਤਾ)"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру довёл до завершения каждое дело того человека, сделал всю его жизнь успешной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50900,
          "is_rahao": true,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਰਿਦ ਮਹਿ ਦੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "amrit nām rid meh dīā. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
