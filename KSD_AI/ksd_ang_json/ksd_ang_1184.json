{
  "ang": 1184,
  "shabads": [
    {
      "shabad_id": 4209,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50851,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਧਨਵੰਤ ਜਿਨ ਹਰਿ ਪ੍ਰਭੁ ਰਾਸਿ ॥",
          "roman": "se dhanvant jin har prabh rās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਸਰਮਾਇਆ ਮੌਜੂਦ ਹੈ ਉਹ ਧਨ ਵਾਲੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди богаты, внутри которых находится капитал Имени परमात्मы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50852,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਗੁਰ ਸਬਦਿ ਨਾਸਿ ॥",
          "roman": "kām krodh gur sabad nās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ ਕਾਮ ਕ੍ਰੋਧ (ਆਦਿਕ ਵਿਕਾਰ) ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "По благословению Слова Гуру изнутри них исчезают похоть, гнев и другие пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50853,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਬਿਨਸੇ ਨਿਰਭੈ ਪਦੁ ਪਾਇਆ ॥",
          "roman": "bhē binse nirbhē pad pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਸਾਰੇ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਹ ਐਸਾ ਆਤਮਕ ਦਰਜਾ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦੇ ਹਨ ਜਿੱਥੇ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Все их страхи исчезают; они достигают такого духовного состояния, где никакой страх не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50854,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਨਾਨਕਿ ਖਸਮੁ ਧਿਆਇਆ ॥੨॥",
          "roman": "gur mil nānak khasam dhiāiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਨਾਨਕ ਨੇ (ਭੀ) ਉਸ ਖਸਮ-ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, Нанак тоже вспоминал того Хозяина-Господа ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50855,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਪ੍ਰਭਿ ਕੀਓ ਨਿਵਾਸ ॥",
          "roman": "sādhasaṅgat prabh kīo nivās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਜਿਸ ਮਨੁੱਖ ਦਾ ਟਿਕਾਣਾ ਸਾਧ ਸੰਗਤ ਵਿਚ ਬਣਾ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, чьё место пребывания परमात्मा устроил в Садх Сангат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50856,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਪਿ ਜਪਿ ਹੋਈ ਪੂਰਨ ਆਸ ॥",
          "roman": "har jap jap hoī pūran ās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਉਸ ਦੀ ਹਰੇਕ ਆਸ ਪੂਰੀ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "повторяя и повторяя Имя परमात्मы, всякая его надежда исполняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50857,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਰਵਿ ਰਹਿਆ ॥",
          "roman": "jal thal mahīal rav rahiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਪਾਣੀ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ (ਹਰ ਥਾਂ) ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь пронизывает воду, землю и небо — Он повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50858,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਨਾਨਕਿ ਹਰਿ ਹਰਿ ਕਹਿਆ ॥੩॥",
          "roman": "gur mil nānak har har kahiā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਨਾਨਕ ਨੇ (ਭੀ) ਉਸੇ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, Нанак тоже вспоминал Его же ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50859,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟ ਸਿਧਿ ਨਵ ਨਿਧਿ ਏਹ ॥ ਕਰਮਿ ਪਰਾਪਤਿ ਜਿਸੁ ਨਾਮੁ ਦੇਹ ॥",
          "roman": "asaṭ sidh nav nidh eh ॥ karam parāpat jis nām deh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਹਰਿ-ਨਾਮ ਹੀ (ਸਿੱਧਾਂ ਦੀਆਂ) ਅੱਠ ਆਤਮਕ ਤਾਕਤਾਂ ਹੈ (ਕੁਬੇਰ ਦੇ) ਨੌ ਖ਼ਜ਼ਾਨੇ ਹੈ। ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਇਹ ਨਾਮ ਦੇਂਦਾ ਹੈ ਉਸੇ ਨੂੰ ਉਸ ਦੀ ਮਿਹਰ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это Хар-Имя и есть восемь духовных сил сиддхов и девять сокровищ Куберы. Тот человек, кому Господь даёт это Имя, получает его по Его милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50860,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਜਪਿ ਜਪਿ ਜੀਵਹਿ ਤੇਰੇ ਦਾਸ ॥",
          "roman": "prabh jap jap jīvah tere dās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਦਾਸ (ਤੇਰਾ ਨਾਮ) ਜਪ ਜਪ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои слуги, повторяя и повторяя Твоё Имя, обретают духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50861,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਨਾਨਕ ਕਮਲ ਪ੍ਰਗਾਸ ॥੪॥੧੩॥",
          "roman": "gur mil nānak kamal pragās ॥4॥13॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹਨਾਂ ਦਾ) ਹਿਰਦਾ-ਕੌਲ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Встретив Гуру, по благословению Имени их сердце-лотос остаётся раскрытым ॥4॥13॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4210,
      "rahao_verse_id": 50867,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50862,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ਘਰੁ ੧ ਇਕ ਤੁਕੇ",
          "roman": "basant mahalā 5 ghar 1 ik tukē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਸੰਤੁ, ਘਰ ੧ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਇਕ-ਤੁਕੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Басант, дом 1, одноcтрочная бани Гуру Арджандев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50863,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх един, и Он обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50864,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਇਛਾ ਜਪਿ ਪੁੰਨੀਆ ॥",
          "roman": "sagal ichhā jap punnīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੇ ਸਿਮਰਨ ਕੀਤਾ, ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਜਪ ਕੇ ਉਹਨਾਂ ਦੀਆਂ ਸਾਰੀਆਂ ਮੁਰਾਦਾਂ ਪੂਰੀਆਂ ਹੋ ਗਈਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "У тех, кто совершал симран, через повторение имени Бога исполнились все желания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50865,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਮੇਲੇ ਚਿਰੀ ਵਿਛੁੰਨਿਆ ॥੧॥",
          "roman": "prabh mēlē chirī vichhuṅniā. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿਰ ਦੇ ਵਿਛੁੜੇ ਹੋਇਆਂ ਨੂੰ (ਭੀ) ਪ੍ਰਭੂ ਨੇ (ਆਪਣੇ ਚਰਨਾਂ ਦੇ ਨਾਲ) ਮਿਲਾ ਲਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "даже давно разлучённых Господь соединил со Своими стопами. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50866,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮ ਰਵਹੁ ਗੋਬਿੰਦੈ ਰਵਣ ਜੋਗੁ ॥",
          "roman": "tum ravah gobindē ravaṇ jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੁਸੀਂ ਸਿਮਰਨ-ਜੋਗ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Вы вспоминайте имя Гобинда, достойного воспоминания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50867,
          "is_rahao": true,
          "gurmukhi": "ਜਿਤੁ ਰਵਿਐ ਸੁਖ ਸਹਜ ਭੋਗੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jit raviē sukh sahaj bhog. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਉਸ ਦਾ ਨਾਮ) ਸਿਮਰਿਆ ਜਾਏ, ਤਾਂ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖਾਂ ਦਾ ਸੁਆਦ (ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если вспоминать Его имя, обретается вкус радостей духовной устойчивости. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50868,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਨਦਰਿ ਨਿਹਾਲਿਆ ॥",
          "roman": "kar kirpā nadar nihāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਦਾਸ ਦੀ (ਸਦਾ) ਆਪ ਸੰਭਾਲ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам всегда заботился о Своём слуге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50869,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਦਾਸੁ ਆਪਿ ਸਮੑਾਲਿਆ ॥੨॥",
          "roman": "apṇā dās āp samhāliā. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਕਰ ਕੇ (ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਦਾਸ ਨੂੰ ਸਦਾ) ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਨਾਲ ਤੱਕਿਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Оказав милость, Господь всегда смотрел на Своего слугу взглядом благодати. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50870,
          "is_rahao": false,
          "gurmukhi": "ਸੇਜ ਸੁਹਾਵੀ ਰਸਿ ਬਨੀ ॥",
          "roman": "sēj suhāvī ras banī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ-ਮਿਲਾਪ ਦੇ) ਸੁਆਦ ਨਾਲ ਉਹਨਾਂ ਦੀ ਹਿਰਦਾ-ਸੇਜ ਸੋਹਣੀ ਬਣ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "От вкуса встречи с Господом ложе их сердца становится прекрасным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50871,
          "is_rahao": false,
          "gurmukhi": "ਆਇ ਮਿਲੇ ਪ੍ਰਭ ਸੁਖ ਧਨੀ ॥੩॥",
          "roman": "āe milē prabh sukh dhanī. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਆ ਕੇ ਸੁਖਾਂ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਜੀ ਮਿਲ ਪੈਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "когда к человеку приходит и встречается с ним Господь, владыка радостей. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50872,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਗੁਣੁ ਅਵਗਣੁ ਨ ਬੀਚਾਰਿਆ ॥",
          "roman": "mērā guṇ avguṇ na bīchāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਮੇਰਾ ਕੋਈ ਗੁਣ ਨਹੀਂ ਵਿਚਾਰਿਆ, ਕੋਈ ਔਗੁਣ ਨਹੀਂ ਵਿਚਾਰਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Господь не стал рассматривать ни моих достоинств, ни моих недостатков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50873,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਨਾਨਕ ਚਰਣ ਪੂਜਾਰਿਆ ॥੪॥੧॥੧੪॥",
          "roman": "prabh Nānak charaṇ pūjāriā. 4. 1. 14.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਮਿਹਰ ਕਰ ਕੇ ਉਸ ਨੇ ਮੈਨੂੰ) ਆਪਣੇ ਚਰਨਾਂ ਦਾ ਪੁਜਾਰੀ ਬਣਾ ਲਿਆ ਹੈ ॥੪॥੧॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, по милости Он сделал меня почитателем Своих стоп. 4. 1. 14."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4211,
      "rahao_verse_id": 50878,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50874,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50875,
          "is_rahao": false,
          "gurmukhi": "ਕਿਲਬਿਖ ਬਿਨਸੇ ਗਾਇ ਗੁਨਾ ॥",
          "roman": "kilbikh binsē gāe gunā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੋਈ ਭੀ ਮਨੁੱਖ ਹੋਵੇ, ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾ ਕੇ ਉਸ ਦੇ ਸਾਰੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Каким бы ни был человек, воспевая качества Бога, все его грехи уничтожаются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50876,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨ ਉਪਜੀ ਸਹਜ ਧੁਨਾ ॥੧॥",
          "roman": "andin upjī sahaj dhunā. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਹਰ ਵੇਲੇ ਆਤਮਕ ਅਡੋਲਤਾ ਦੀ ਰੌ ਪੈਦਾ ਹੋਈ ਰਹਿੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "внутри него всё время возникает поток духовной устойчивости. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50877,
          "is_rahao": true,
          "gurmukhi": "ਮਨੁ ਮਉਲਿਓ ਹਰਿ ਚਰਨ ਸੰਗਿ ॥",
          "roman": "man mauliō har charan sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸੇਵਕ ਦਾ ਮਨ ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ (ਜੁੜ ਕੇ) ਆਤਮਕ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того слуги ум, соединившись со стопами Господа, становится наполненным духовной жизнью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50878,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਸਾਧੂ ਜਨ ਭੇਟੇ ਨਿਤ ਰਾਤੌ ਹਰਿ ਨਾਮ ਰੰਗਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā sādhū jan bhēṭē nit rātau har nām rang. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸੇਵਕ ਨੂੰ ਪਰਮਾਤਮਾ ਮਿਹਰ ਕਰ ਕੇ ਗੁਰੂ ਮਿਲਾਂਦਾ ਹੈ। ਉਹ ਸੇਵਕ ਸਦਾ ਹਰਿ-ਨਾਮ ਦੇ ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "того слугу, которому Бог по милости даёт встретить Гуру. Этот слуга всегда окрашивается любовью к имени Хари. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50879,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਗਟੇ ਗੋੁਪਾਲ ॥",
          "roman": "kar kirpā pragṭē gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਗੋਪਾਲ-ਪ੍ਰਭੂ (ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਪਰਗਟ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда по милости Гопал-Господь проявляется в сердце человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50880,
          "is_rahao": false,
          "gurmukhi": "ਲੜਿ ਲਾਇ ਉਧਾਰੇ ਦੀਨ ਦਇਆਲ ॥੨॥",
          "roman": "laṛ lāe udhārē dīn daiāl. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਉਸ ਨੂੰ ਆਪਣੇ ਲੜ ਲਾ ਕੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Господь, милостивый к смиренным, принимает его под Свою защиту и переправляет через океан мира. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50881,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਹੋਆ ਸਾਧ ਧੂਰਿ ॥",
          "roman": "ih man hoā sādh dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਇਹ ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей ум становится пылью у стоп Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50882,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਦੇਖੈ ਸੁਆਮੀ ਹਜੂਰਿ ॥੩॥",
          "roman": "nit dēkhē suāmī hajūr. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੁਆਮੀ-ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਵੇਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "всегда видит Владыку-Господа пребывающим рядом с собой. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50883,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਤ੍ਰਿਸਨਾ ਗਈ ॥",
          "roman": "kām krodh trisnā gaī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਕਾਮ ਕ੍ਰੋਧ ਤ੍ਰਿਸ਼ਨਾ (ਆਦਿਕ ਵਿਕਾਰ) ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Изнутри него уходят похоть, гнев, жажда и подобные пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50884,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਕਿਰਪਾ ਭਈ ॥੪॥੨॥੧੫॥",
          "roman": "Nānak prabh kirpā bhaī. 4. 2. 15.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਦੀ ਮਿਹਰ ਹੁੰਦੀ ਹੈ ॥੪॥੨॥੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, у того человека, на кого приходит милость Господа. 4. 2. 15."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4212,
      "rahao_verse_id": 50889,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50885,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50886,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗ ਮਿਟਾਏ ਪ੍ਰਭੂ ਆਪਿ ॥",
          "roman": "rog miṭāē prabhū āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਮਨੁੱਖ ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਂਦੇ ਹਨ) ਪਰਮਾਤਮਾ ਆਪ (ਉਹਨਾਂ ਦੇ ਸਾਰੇ) ਰੋਗ ਮਿਟਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тем людям, которые приходят под защиту совершенного Гуру, Бог Сам устраняет все болезни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50887,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲਕ ਰਾਖੇ ਅਪਨੇ ਕਰ ਥਾਪਿ ॥੧॥",
          "roman": "bālak rākhē apnē kar thāp. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਬੱਚਿਆਂ ਨੂੰ ਆਪਣੇ ਹੱਥਾਂ ਨਾਲ ਥਾਪਣਾ ਦੇ ਕੇ ਉਹਨਾਂ ਦੀ ਰੱਖਿਆ ਕਰਦਾ ਹੈ (ਜਿਵੇਂ ਮਾਪੇ ਆਪਣੇ ਬੱਚਿਆਂ ਦੀ ਸੰਭਾਲ ਕਰਦੇ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "этих детей Он поддерживает Своими руками и охраняет их, как родители заботятся о своих детях. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50888,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਸਹਜ ਗ੍ਰਿਹਿ ਸਦ ਬਸੰਤੁ ॥",
          "roman": "sānt sahaj grih sad basant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਹਿਰਦੇ-) ਘਰ ਵਿਚ ਆਤਮਕ ਅਡੋਲਤਾ ਵਾਲੀ ਸ਼ਾਂਤੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ, ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਖਿੜਾਉ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В доме их сердца сохраняется мир духовной устойчивости, всегда пребывает непреходящее цветение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50889,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਸਰਣੀ ਆਏ ਕਲਿਆਣ ਰੂਪ ਜਪਿ ਹਰਿ ਹਰਿ ਮੰਤੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrē kī sarṇī āē kaliāṇ rūp jap har har mant. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਮਨੁੱਖ) ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਆਉਂਦੇ ਹਨ, ਸੁਖ-ਸਰੂਪ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਮੰਤ੍ਰ ਜਪ ਕੇ (ਨਾਮ-ਸਿਮਰਨ ਦੀਆਂ ਬਰਕਤਾਂ ਹਾਸਲ ਕਰਦੇ ਹਨ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "те люди, которые приходят под защиту совершенного Гуру, повторяя мантр имени Хари, Хари, образа блага, обретают благословения именного симрана. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50890,
          "is_rahao": false,
          "gurmukhi": "ਸੋਗ ਸੰਤਾਪ ਕਟੇ ਪ੍ਰਭਿ ਆਪਿ ॥",
          "roman": "sog santāp kaṭē prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਮਨੁੱਖ ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਆ ਗਏ) ਪ੍ਰਭੂ ਨੇ ਆਪ (ਉਹਨਾਂ ਦੇ ਸਾਰੇ) ਚਿੰਤਾ-ਫ਼ਿਕਰ ਅਤੇ ਦੁੱਖ-ਕਲੇਸ਼ ਮਿਟਾ ਦਿੱਤੇ।"
            },
            "sahib_singh_ru": {
              "main": "У тех людей, которые пришли под защиту совершенного Гуру, Господь Сам устранил все тревоги, заботы, страдания и мучения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50891,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਅਪੁਨੇ ਕਉ ਨਿਤ ਨਿਤ ਜਾਪਿ ॥੨॥",
          "roman": "gur apunē kau nit nit jāp. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੂੰ ਭੀ ਸਦਾ ਹੀ ਸਦਾ ਹੀ ਆਪਣੇ ਗੁਰੂ ਨੂੰ ਯਾਦ ਕਰਦਾ ਰਹੁ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат, и ты постоянно, всегда помни своего Гуру. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50892,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨੁ ਤੇਰਾ ਜਪੇ ਨਾਉ ॥",
          "roman": "jo jan tērā japē nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਹੜਾ ਮਨੁੱਖ ਤੇਰਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, тот человек, который повторяет Твоё имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50893,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਫਲ ਪਾਏ ਨਿਹਚਲ ਗੁਣ ਗਾਉ ॥੩॥",
          "roman": "sabh phal pāē nihchal guṇ gāu. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਤੇਰੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਗੁਣਾਂ ਦਾ ਗਾਇਨ ਕਰ ਕੇ ਸਾਰੇ ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "воспевая Твои вечно пребывающие качества, получает все плоды. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50894,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤਾ ਭਲੀ ਰੀਤਿ ॥",
          "roman": "Nānak bhagtā bhalī rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਭਗਤ ਜਨਾਂ ਦੀ ਇਹ ਸੋਹਣੀ ਜੀਵਨ-ਮਰਯਾਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, таков прекрасный жизненный уклад преданных людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50895,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖਦਾਤਾ ਜਪਦੇ ਨੀਤ ਨੀਤਿ ॥੪॥੩॥੧੬॥",
          "roman": "sukhdātā japdē nīt nīt. 4. 3. 16.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਹ ਸਦਾ ਹੀ ਸੁਖਾਂ ਦੇ ਦੇਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੩॥੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "что они постоянно повторяют имя Бога, дарующего радости. 4. 3. 16."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
