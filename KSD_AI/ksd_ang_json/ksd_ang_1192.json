{
  "ang": 1192,
  "shabads": [
    {
      "shabad_id": 4232,
      "rahao_verse_id": 51247,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 51240,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ਘਰੁ ੧ ਦੁਤੁਕੀਆ",
          "roman": "basant mahalā 5 ghar 1 dutukīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਸੰਤੁ, ਘਰ ੧ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਦੋ-ਤੁਕੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Басант, дом 1, двухстрочная бани Гуру Арджандева Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51241,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вечный Господь один, и Он обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51242,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸਾਖੀ ਮਨ ਜਪਿ ਪਿਆਰ ॥",
          "roman": "suṇ sākhī man jap piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਗੁਰੂ ਦੀ) ਸਿੱਖਿਆ ਸੁਣ ਕੇ ਪ੍ਰੇਮ ਨਾਲ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Услышав наставление Гуру, с любовью повторяй Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51243,
          "is_rahao": false,
          "gurmukhi": "ਅਜਾਮਲੁ ਉਧਰਿਆ ਕਹਿ ਏਕ ਬਾਰ ॥",
          "roman": "ajāmāl udhariā kah ek bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜਾਮਲ (ਪ੍ਰਭੂ ਦਾ ਨਾਮ) ਜਪ ਕੇ ਸਦਾ ਲਈ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Аджамал, повторив Имя Господа, навсегда переправился через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51244,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲਮੀਕੈ ਹੋਆ ਸਾਧਸੰਗੁ ॥",
          "roman": "bālmīkē hoā sādhasaṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਲਮੀਕ ਨੂੰ ਗੁਰੂ ਦੀ ਸੰਗਤ ਪ੍ਰਾਪਤ ਹੋਈ (ਉਸ ਨੇ ਭੀ ਹਰਿ-ਨਾਮ ਜਪਿਆ, ਤੇ, ਉਸ ਦਾ ਪਾਰ-ਉਤਾਰਾ ਹੋ ਗਿਆ)।"
            },
            "sahib_singh_ru": {
              "main": "Балмик получил общество Гуру; он тоже повторял Хар-нам, и был переправлен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51245,
          "is_rahao": false,
          "gurmukhi": "ਧ੍ਰੂ ਕਉ ਮਿਲਿਆ ਹਰਿ ਨਿਸੰਗ ॥੧॥",
          "roman": "dhrū kau miliā har nisaṅg ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਜਪਣ ਦੀ ਹੀ ਬਰਕਤਿ ਨਾਲ) ਧ੍ਰੂ ਨੂੰ ਪਰਮਾਤਮਾ ਪ੍ਰਤੱਖ ਹੋ ਕੇ ਮਿਲ ਪਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Именно благодаря повторению Имени Дхру явно встретил Бога. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51246,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰਿਆ ਸੰਤਾ ਜਾਚਉ ਚਰਨ ਰੇਨ ॥",
          "roman": "teriā santā jāchau charan ren",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я прошу пыли стоп Твоих святых людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51247,
          "is_rahao": true,
          "gurmukhi": "ਲੇ ਮਸਤਕਿ ਲਾਵਉ ਕਰਿ ਕ੍ਰਿਪਾ ਦੇਨ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "le mastak lāvau kar kripā den ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੇਣ ਦੀ ਕਿਰਪਾ ਕਰ (ਉਹ ਚਰਨ-ਧੂੜ ਲੈ ਕੇ) ਮੈਂ ਆਪਣੇ ਮੱਥੇ ਤੇ ਲਾਵਾਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "прояви милость даровать её; взяв эту пыль стоп, я приложу её к своему лбу. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51248,
          "is_rahao": false,
          "gurmukhi": "ਗਨਿਕਾ ਉਧਰੀ ਹਰਿ ਕਹੈ ਤੋਤ ॥",
          "roman": "ganikā udharī har kahē tot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਜਿਉਂ ਜਿਉਂ) ਤੋਤਾ ਰਾਮ-ਨਾਮ ਉਚਾਰਦਾ ਸੀ (ਉਸ ਨੂੰ ਰਾਮ-ਨਾਮ ਸਿਖਾਲਣ ਲਈ ਗਨਿਕਾ ਭੀ ਰਾਮ-ਨਾਮ ਉਚਾਰਦੀ ਸੀ, ਤੇ, ਨਾਮ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਗਨਿਕਾ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਗਈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Когда попугай произносил Рам-нам, Ганика, чтобы учить его Рам-наму, тоже произносила Рам-нам; и благодаря памятованию Имени Ганика переправилась через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51249,
          "is_rahao": false,
          "gurmukhi": "ਗਜਇੰਦ੍ਰ ਧਿਆਇਓ ਹਰਿ ਕੀਓ ਮੋਖ ॥",
          "roman": "gajindra dhiāio har kīo mokh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਰਾਪ ਦੇ ਕਾਰਨ ਗੰਧਰਬ ਤੋਂ ਬਣੇ ਹੋਏ) ਵੱਡੇ ਹਾਥੀ ਨੇ (ਸਰੋਵਰ ਵਿਚ ਤੰਦੂਏ ਦੀ ਫਾਹੀ ਵਿਚ ਫਸ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਿਆ, ਪਰਮਾਤਮਾ ਨੇ ਉਸ ਨੂੰ (ਤੰਦੂਏ ਦੀ) ਫਾਹੀ ਵਿਚੋਂ ਬਚਾ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Большой слон, ставший из гандхарва из-за проклятия, попав в озере в петлю крокодила, сосредоточился на Боге; Бог спас его из этой петли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51250,
          "is_rahao": false,
          "gurmukhi": "ਬਿਪ੍ਰ ਸੁਦਾਮੇ ਦਾਲਦੁ ਭੰਜ ॥",
          "roman": "bipr sudāme dālad bhañj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਦਾਮੇ ਬ੍ਰਾਹਮਣ ਦੀ (ਕ੍ਰਿਸ਼ਨ ਜੀ ਨੇ) ਗਰੀਬੀ ਕੱਟੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бедность брахмана Судамы Кришна Джи устранил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51251,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਤੂ ਭੀ ਭਜੁ ਗੋਬਿੰਦ ॥੨॥",
          "roman": "re man tū bhī bhaj gobind ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਭੀ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰਿਆ ਕਰ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Ты тоже совершай бхаджан Бога. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51252,
          "is_rahao": false,
          "gurmukhi": "ਬਧਿਕੁ ਉਧਾਰਿਓ ਖਮਿ ਪ੍ਰਹਾਰ ॥",
          "roman": "badhik udhārio kham prahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਕ੍ਰਿਸ਼ਨ ਜੀ ਨੂੰ) ਤੀਰ ਨਾਲ ਮਾਰਨ ਵਾਲੇ ਸ਼ਿਕਾਰੀ ਨੂੰ (ਕ੍ਰਿਸ਼ਨ ਜੀ ਨੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Охотника, ранившего Кришну Джи стрелой, Кришна Джи переправил через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51253,
          "is_rahao": false,
          "gurmukhi": "ਕੁਬਿਜਾ ਉਧਰੀ ਅੰਗੁਸਟ ਧਾਰ ॥",
          "roman": "kubijā udharī aṅgusṭ dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕ੍ਰਿਸ਼ਨ ਜੀ ਦੇ) ਅੰਗੂਠੇ ਦੀ ਛੁਹ ਨਾਲ ਕੁਬਿਜਾ ਪਾਰ ਲੰਘ ਗਈ।"
            },
            "sahib_singh_ru": {
              "main": "От прикосновения большого пальца Кришны Джи Кубиджа была переправлена."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51254,
          "is_rahao": false,
          "gurmukhi": "ਬਿਦਰੁ ਉਧਾਰਿਓ ਦਾਸਤ ਭਾਇ ॥",
          "roman": "bidar udhārio dāsat bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਿਦਰ ਨੂੰ (ਉਸ ਦੇ) ਸੇਵਾ ਭਾਵ ਦੇ ਕਾਰਨ (ਕ੍ਰਿਸ਼ਨ ਜੀ ਨੇ) ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Бидара Кришна Джи переправил благодаря его духу служения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51255,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਤੂ ਭੀ ਹਰਿ ਧਿਆਇ ॥੩॥",
          "roman": "re man tū bhī har dhiāe ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਭੀ ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਿਆ ਕਰ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Ты тоже сосредоточивайся на Боге. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51256,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਹਲਾਦ ਰਖੀ ਹਰਿ ਪੈਜ ਆਪ ॥",
          "roman": "prahlād rakhī har pēj āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਪ੍ਰਹਲਾਦ ਦੀ ਇੱਜ਼ਤ ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਰੱਖੀ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Честь Прахлада Бог Сам сохранил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51257,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤ੍ਰ ਛੀਨਤ ਦ੍ਰੋਪਤੀ ਰਖੀ ਲਾਜ ॥",
          "roman": "basatr chhīnat dropatī rakhī lāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਰਜੋਧਨ ਦੀ ਸਭਾ ਵਿਚ ਦ੍ਰੋਪਤੀ ਨੂੰ ਨਗਨ ਕਰਨ ਲਈ ਜਦੋਂ) ਦ੍ਰੋਪਤੀ ਦੇ ਬਸਤ੍ਰ ਲਾਹੇ ਜਾ ਰਹੇ ਸਨ, ਤਦੋਂ (ਕ੍ਰਿਸ਼ਨ ਜੀ ਨੇ ਉਸ ਦੀ) ਇੱਜ਼ਤ ਬਚਾਈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда в собрании Дурьодханы с Драупади снимали одежды, чтобы обнажить её, тогда Кришна Джи спас её честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51258,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਿਨਿ ਸੇਵਿਆ ਅੰਤ ਬਾਰ ॥",
          "roman": "jin jin seviā ant bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ ਜਿਸ ਨੇ ਭੀ ਔਖੇ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦਾ ਪੱਲਾ ਫੜਿਆ (ਪਰਮਾਤਮਾ ਨੇ ਉਸ ਦੀ ਲਾਜ ਰੱਖੀ)।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Кто бы в трудное время ни ухватился за край одежды Бога, Бог сохранил его честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51259,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਸੇਵਿ ਤੂ ਪਰਹਿ ਪਾਰ ॥੪॥",
          "roman": "re man sev tū pareh pār ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਭੀ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਉ, (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਹਿਂਗਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Ты тоже приди под защиту Бога, и переправишься через мирской океан. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51260,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੈ ਸੇਵਿਆ ਬਾਲ ਬੁਧਿ ॥",
          "roman": "dhannē seviā bāl budh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਧੰਨੇ ਨੇ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਬਾਲਾਂ ਵਾਲੀ (ਨਿਰਵੈਰ) ਬੁੱਧੀ ਪ੍ਰਾਪਤ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕੀਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Дханна, придя под защиту Гуру, обрёл детскую, свободную от вражды, мудрость и поклонялся Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51261,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਲੋਚਨ ਗੁਰ ਮਿਲਿ ਭਈ ਸਿਧਿ ॥",
          "roman": "trilochan gur mil bhaī sidh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਤ੍ਰਿਲੋਚਨ ਨੂੰ ਭੀ ਆਤਮਕ ਜੀਵਨ ਵਿਚ ਸਫਲਤਾ ਪ੍ਰਾਪਤ ਹੋਈ।"
            },
            "sahib_singh_ru": {
              "main": "Встретив Гуру, Трилочан тоже достиг успеха в духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51262,
          "is_rahao": false,
          "gurmukhi": "ਬੇਣੀ ਕਉ ਗੁਰਿ ਕੀਓ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "beṇī kau gur kīo pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਭਗਤ) ਬੇਣੀ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਦਾ ਚਾਨਣ ਬਖ਼ਸ਼ਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру даровал Бхагату Бени свет духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51263,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਤੂ ਭੀ ਹੋਹਿ ਦਾਸੁ ॥੫॥",
          "roman": "re man tū bhī hoh dās ||5||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਭੀ ਪਰਮਾਤਮਾ ਦਾ ਭਗਤ (ਇਸੇ ਤਰ੍ਹਾਂ) ਬਣ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Ты тоже стань преданным Бога таким же образом. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51264,
          "is_rahao": false,
          "gurmukhi": "ਜੈਦੇਵ ਤਿਆਗਿਓ ਅਹੰਮੇਵ ॥",
          "roman": "jēdev tiāgio ahaṅmev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ) ਜੈਦੇਵ ਨੇ (ਆਪਣੇ ਬ੍ਰਾਹਮਣ ਹੋਣ ਦਾ) ਮਾਣ ਛੱਡਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Встретив Гуру, Джайдев оставил гордость тем, что он брахман."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51265,
          "is_rahao": false,
          "gurmukhi": "ਨਾਈ ਉਧਰਿਓ ਸੈਨੁ ਸੇਵ ॥",
          "roman": "nāī udhario sēn sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੈਣ ਨਾਈ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਭਗਤੀ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Сэйн-цирюльник, придя под защиту Гуру, благодаря преданности переправился через мирской океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51266,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਡੀਗਿ ਨ ਡੋਲੈ ਕਹੂੰ ਜਾਇ ॥",
          "roman": "man ḍīg na ḍolē kahū jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੈਣ ਦਾ) ਮਨ ਕਿਸੇ ਭੀ ਥਾਂ (ਮਾਇਆ ਦੇ ਠੇਡਿਆਂ ਨਾਲ) ਡਿੱਗ ਕੇ ਡੋਲਦਾ ਨਹੀਂ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "ум Сэйна нигде не падал и не колебался от толчков Майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51267,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤੂ ਭੀ ਤਰਸਹਿ ਸਰਣਿ ਪਾਇ ॥੬॥",
          "roman": "man tū bhī tarseh saraṇ pāe ||6||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਗੁਰੂ ਦੀ) ਸਰਨ ਪੈ ਕੇ ਤੂੰ ਭੀ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਹਿਂਗਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Придя под защиту Гуру, ты тоже переправишься через мирской океан. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51268,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਅਨੁਗ੍ਰਹੁ ਠਾਕੁਰਿ ਕੀਓ ਆਪਿ ॥",
          "roman": "jih anugrah ṭhākur kīo āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਨ੍ਹਾਂ ਭਗਤ ਜਨਾਂ ਉਤੇ ਤੈਂ ਠਾਕੁਰ ਨੇ ਆਪ ਮਿਹਰ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! К тем преданным людям, на кого Ты, Владыка, Сам проявил милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51269,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਤੈਂ ਲੀਨੇ ਭਗਤ ਰਾਖਿ ॥",
          "roman": "se tēṅ līne bhagat rākh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਤੂੰ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ) ਬਚਾ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "тех Ты спас из мирского океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51270,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕਾ ਗੁਣੁ ਅਵਗਣੁ ਨ ਬੀਚਾਰਿਓ ਕੋਇ ॥",
          "roman": "tin kā guṇ avaguṇ na bīchārio koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਉਹਨਾਂ ਦਾ ਨਾਹ ਕੋਈ ਗੁਣ ਤੇ ਨਾਹ ਕੋਈ ਔਗੁਣ ਵਿਚਾਰਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Ты не рассматривал у них ни достоинств, ни недостатков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51271,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਬਿਧਿ ਦੇਖਿ ਮਨੁ ਲਗਾ ਸੇਵ ॥੭॥",
          "roman": "ih bidh dekh man lagā sev ||7||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਇਸ ਕਿਸਮ ਦੀ ਦਇਆਲਤਾ ਵੇਖ ਕੇ (ਮੇਰਾ ਭੀ) ਮਨ (ਤੇਰੀ) ਭਗਤੀ ਵਿਚ ਲੱਗ ਪਿਆ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Увидев такую Твою милостивость, мой ум тоже привязался к Твоей преданности. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51272,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰਿ ਧਿਆਇਓ ਏਕ ਰੰਗ ॥",
          "roman": "kabīr dhiāio ek raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਕਬੀਰ ਨੇ ਇਕ-ਰਸ ਪਿਆਰ ਵਿਚ ਟਿਕ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Кабир, пребывая в ровной любви, сосредоточивался на Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51273,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਦੇਵ ਹਰਿ ਜੀਉ ਬਸਹਿ ਸੰਗਿ ॥",
          "roman": "nāmdev har jīo baseh saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਨਾਮਦੇਵ ਜੀ ਦੇ ਭੀ ਨਾਲ ਵੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Прабху Джи обитает также вместе с Намдевом Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51274,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿਦਾਸ ਧਿਆਏ ਪ੍ਰਭ ਅਨੂਪ ॥",
          "roman": "ravidās dhiāe prabh anūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਵਿਦਾਸ ਨੇ ਭੀ ਸੋਹਣੇ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕੀਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Равидас тоже вспоминал прекрасного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51275,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਨਾਨਕ ਦੇਵ ਗੋਵਿੰਦ ਰੂਪ ॥੮॥੧॥",
          "roman": "gur nānak dev govind rūp ||8||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਸਭਨਾਂ ਉੱਤੇ ਗੁਰੂ ਨੇ ਹੀ ਕਿਰਪਾ ਕੀਤੀ)। ਹੇ ਨਾਨਕ! ਗੁਰੂ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਹੈ (ਤੂੰ ਭੀ ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹੁ) ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "На всех них именно Гуру проявил милость. О Нанак! Гуру — образ Бога; ты тоже оставайся под защитой Гуру. ॥8॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4233,
      "rahao_verse_id": 51282,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 51276,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51277,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਨਮ ਭ੍ਰਮੇ ਜੋਨਿ ਮਾਹਿ ॥",
          "roman": "anik janam bhrame jon māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਅਨੇਕਾਂ ਜੂਨਾਂ ਅਨੇਕਾਂ ਜਨਮਾਂ ਵਿਚ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Люди блуждают во множестве утроб, во множестве рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51278,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨ ਬਿਨੁ ਨਰਕਿ ਪਾਹਿ ॥",
          "roman": "har simran bin narak pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਨਰਕ ਵਿਚ ਪਏ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Бога они остаются в аду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51279,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਬਿਹੂਨਾ ਖੰਡ ਖੰਡ ॥",
          "roman": "bhagat bihūnā khaṇḍ khaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ ਤੋਂ ਬਿਨਾ (ਉਹਨਾਂ ਦਾ ਮਨ ਅਨੇਕਾਂ ਦੌੜਾਂ-ਭੱਜਾਂ ਵਿਚ) ਟੋਟੇ ਟੋਟੇ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Без преданности их ум остаётся раздробленным на куски во множестве беготни и суеты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51280,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਜਮੁ ਦੇਤ ਡੰਡ ॥੧॥",
          "roman": "bin būjhe jam det ḍaṇḍ ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਤੋਂ ਬਿਨਾ ਜਮਰਾਜ ਭੀ ਉਹਨਾਂ ਨੂੰ ਸਜ਼ਾ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Без понимания духовной жизни Джамрадж тоже даёт им наказание. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51281,
          "is_rahao": true,
          "gurmukhi": "ਗੋਬਿੰਦ ਭਜਹੁ ਮੇਰੇ ਸਦਾ ਮੀਤ ॥",
          "roman": "gobind bhajah mere sadā mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਿੱਤਰ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой друг! Всегда совершай бхаджан Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51282,
          "is_rahao": true,
          "gurmukhi": "ਸਾਚ ਸਬਦ ਕਰਿ ਸਦਾ ਪ੍ਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sāch sabad kar sadā prīt ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨਾਲ ਸਦਾ ਪਿਆਰ ਬਣਾਈ ਰੱਖ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Всегда сохраняй любовь к восхвалению вечно пребывающего Бога. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51283,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤੋਖੁ ਨ ਆਵਤ ਕਹੂੰ ਕਾਜ ॥",
          "roman": "santokh na āvat kahūṅ kāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਭੀ ਕੰਮਾਂ ਵਿਚ (ਉਸ ਮਨੁੱਖ ਨੂੰ) ਮਾਇਆ ਵਲੋਂ ਤ੍ਰਿਪਤੀ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Ни в каких делах у такого человека не появляется удовлетворения от Майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51284,
          "is_rahao": false,
          "gurmukhi": "ਧੂੰਮ ਬਾਦਰ ਸਭਿ ਮਾਇਆ ਸਾਜ ॥",
          "roman": "dhūm bādar sabh māiā sāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਇਹ ਸਮਝ ਨਹੀਂ ਆਉਂਦੀ ਕਿ) ਮਾਇਆ ਦੇ ਸਾਰੇ ਕੌਤਕ-ਤਮਾਸ਼ੇ ਧੂੰਏ ਦੇ ਬੱਦਲ (ਹੀ) ਹਨ (ਹਵਾ ਦੇ ਇੱਕੋ ਬੁੱਲੇ ਨਾਲ ਉੱਡ ਜਾਣ ਵਾਲੇ)।"
            },
            "sahib_singh_ru": {
              "main": "Он не понимает, что все чудеса и зрелища Майи — лишь облака дыма, разлетающиеся от одного порыва ветра."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51285,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਕਰੰਤੌ ਨਹ ਸੰਗਾਇ ॥",
          "roman": "pāp karantau nah saṅgāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਵਿਚ ਮਸਤ ਮਨੁੱਖ) ਪਾਪ ਕਰਦਾ ਭੀ ਝਿਜਕਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Опьянённый Майей человек не стесняется даже совершать грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51286,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੁ ਕਾ ਮਾਤਾ ਆਵੈ ਜਾਇ ॥੨॥",
          "roman": "bikh kā mātā āvē jāe ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਮੌਤ ਲਿਆਉਣ ਵਾਲੀ ਮਾਇਆ-ਜ਼ਹਰ ਦਾ ਮੱਤਾ ਹੋਇਆ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Опьянённый ядом Майи, приносящим духовную смерть, человек остаётся в круге рождений и смертей. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51287,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਹਉ ਕਰਤ ਬਧੇ ਬਿਕਾਰ ॥",
          "roman": "hau hau karat badhe bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਮੈਂ ਕਰਦਿਆਂ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਵਿਕਾਰ ਵਧਦੇ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек говорит ‘я, я’, внутри него всё больше растут пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51288,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹ ਲੋਭ ਡੂਬੌ ਸੰਸਾਰ ॥",
          "roman": "moh lobh ḍūbau sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਦੇ ਮੋਹ ਅਤੇ ਲੋਭ ਵਿਚ ਉਹ ਸਦਾ ਡੁੱਬਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он всегда погружён в мирскую привязанность и жадность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51289,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਕ੍ਰੋਧਿ ਮਨੁ ਵਸਿ ਕੀਆ ॥",
          "roman": "kām krodh man vas kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ-ਵਾਸਨਾ ਨੇ ਕ੍ਰੋਧ ਨੇ (ਉਸ ਦਾ) ਮਨ ਸਦਾ ਆਪਣੇ ਕਾਬੂ ਵਿਚ ਕੀਤਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "похоть и гнев всегда держат его ум в своей власти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51290,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨੈ ਨਾਮੁ ਨ ਹਰਿ ਲੀਆ ॥੩॥",
          "roman": "supnē nām na har līā ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਕਦੇ ਸੁਪਨੇ ਵਿਚ ਭੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਸਿਮਰਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если этот человек даже во сне никогда не вспоминал Имя Бога. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51291,
          "is_rahao": false,
          "gurmukhi": "ਕਬ ਹੀ ਰਾਜਾ ਕਬ ਮੰਗਨਹਾਰੁ ॥",
          "roman": "kab hī rājā kab maṅganhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਤੋਂ ਸੱਖਣਾ ਮਨੁੱਖ) ਚਾਹੇ ਕਦੇ ਰਾਜਾ ਹੈ ਚਾਹੇ ਮੰਗਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Лишённый Имени человек, будь он когда-либо царём или нищим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51292,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਸੂਖ ਬਾਧੌ ਸੰਸਾਰ ॥",
          "roman": "dūkh sūkh bādhau sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਜਗਤ ਦੇ ਦੁੱਖਾਂ ਸੁਖਾਂ ਵਿਚ ਜਕੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всегда остаётся связанным мирскими страданиями и удовольствиями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51293,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਉਧਰਣ ਕਾ ਸਾਜੁ ਨਾਹਿ ॥",
          "roman": "man udharaṇ kā sāj nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਨੂੰ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਦੇ ਵਿਕਾਰਾਂ ਵਿਚ ਡੁੱਬਣ ਤੋਂ) ਬਚਾਣ ਦਾ ਉਹ ਕੋਈ ਉੱਦਮ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он не предпринимает никакого усилия, чтобы спасти свой ум от погружения в пороки мирского океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51294,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਬੰਧਨ ਨਿਤ ਪਉਤ ਜਾਹਿ ॥੪॥",
          "roman": "pāp bandhan nit paut jāh ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਾਪਾਂ ਦੀਆਂ ਫਾਹੀਆਂ ਉਸ ਨੂੰ ਸਦਾ ਪੈਂਦੀਆਂ ਜਾਂਦੀਆਂ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Петли грехов постоянно всё больше ложатся на него. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51295,
          "is_rahao": false,
          "gurmukhi": "ਈਠ ਮੀਤ ਕੋਊ ਸਖਾ ਨਾਹਿ ॥",
          "roman": "īṭh mīt koū sakhā nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰੇ ਮਿੱਤਰਾਂ ਵਿਚੋਂ ਕੋਈ ਭੀ (ਤੋੜ ਤਕ ਸਾਥ ਨਿਬਾਹੁਣ ਵਾਲਾ) ਸਾਥੀ ਨਹੀਂ ਬਣ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Из дорогих друзей никто не может стать спутником, который поддержит до конца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51296,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬੀਜਿ ਆਪੇ ਹੀ ਖਾਂਹਿ ॥",
          "roman": "āp bīj āpe hī khāṅh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੇ ਜੀਵ ਚੰਗੇ ਮੰਦੇ) ਕਰਮ ਆਪ ਕਰ ਕੇ ਆਪ ਹੀ (ਉਹਨਾਂ ਕੀਤੇ ਕਰਮਾਂ ਦਾ) ਫਲ ਭੋਗਦੇ ਹਨ (ਕੋਈ ਮਿੱਤਰ ਮਦਦ ਨਹੀਂ ਕਰ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Все существа сами совершают хорошие и плохие дела и сами пожинают плод совершённых дел; никакой друг не может помочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
