{
  "ang": 1236,
  "shabads": [
    {
      "shabad_id": 4414,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 52890,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪੁਰਖ ਅੰਸਾ ਅਵਤਾਰ ॥",
          "roman": "anik purakh aṅsā avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਅਨੇਕਾਂ ਹੀ ਛੋਟੇ ਛੋਟੇ ਉਸ ਦੇ ਅਵਤਾਰ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "и есть многие другие, малые Его аватары,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52891,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਇੰਦ੍ਰ ਊਭੇ ਦਰਬਾਰ ॥੩॥",
          "roman": "anik indr ūbhe darbār. 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀ ਇੰਦਰ ਦੇਵਤੇ ਉਸ ਦੇ ਦਰ ਤੇ ਖਲੋਤੇ ਰਹਿੰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "многие Индры-девы стоят у Его двери. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52892,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪਵਨ ਪਾਵਕ ਅਰੁ ਨੀਰ ॥",
          "roman": "anik pavan pāvak ar nīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਸ ਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਅਨੇਕਾਂ ਹੀ ਹਵਾ ਪਾਣੀ ਅਤੇ ਅੱਗ (ਆਦਿਕ) ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Двор Бога изумителен: Им создано множество видов воздуха, воды и огня и прочего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52893,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰਤਨ ਸਾਗਰ ਦਧਿ ਖੀਰ ॥",
          "roman": "anik ratan sāgar dadh khīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਅਨੇਕਾਂ ਹੀ ਰਤਨਾਂ ਦੇ, ਦਹੀਂ ਦੇ, ਦੁੱਧ ਦੇ ਸਮੁੰਦਰ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Им созданы многие океаны драгоценностей, творога и молока."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52894,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਸੂਰ ਸਸੀਅਰ ਨਖਿਆਤਿ ॥",
          "roman": "anik sūr sasīar nakhiāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਬਣਾਏ ਹੋਏ) ਅਨੇਕਾਂ ਹੀ ਸੂਰਜ ਚੰਦ੍ਰਮਾ ਅਤੇ ਤਾਰੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Им созданы многие солнца, луны и звёзды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52895,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਦੇਵੀ ਦੇਵਾ ਬਹੁ ਭਾਂਤਿ ॥੪॥",
          "roman": "anik devī devā bah bhāṅt. 4",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਈ ਕਿਸਮਾਂ ਦੇ ਅਨੇਕਾਂ ਹੀ ਦੇਵੀਆਂ ਦੇਵਤੇ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и множество богинь и богов многих видов. 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52896,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਸੁਧਾ ਅਨਿਕ ਕਾਮਧੇਨ ॥",
          "roman": "anik basudhā anik kāmdhen",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ ਅਸਚਰਜ ਹੈ, ਉਸ ਦੀਆਂ ਪੈਦਾ ਕੀਤੀਆਂ) ਅਨੇਕਾਂ ਧਰਤੀਆਂ ਅਤੇ ਅਨੇਕਾਂ ਹੀ ਮਨੋ-ਕਾਮਨਾ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲੀਆਂ ਸੁਵਰਗ ਦੀਆਂ ਗਾਂਈਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Двор Бога удивителен: Им созданы многие земли и многие небесные коровы, исполняющие желания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52897,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪਾਰਜਾਤ ਅਨਿਕ ਮੁਖਿ ਬੇਨ ॥",
          "roman": "anik pārjāt anik mukh ben",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀ ਪਾਰਜਾਤ ਰੁੱਖ ਅਤੇ ਅਨੇਕਾਂ ਹੀ ਕ੍ਰਿਸ਼ਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "многие деревья париджата и многие Кришны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52898,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਅਕਾਸ ਅਨਿਕ ਪਾਤਾਲ ॥",
          "roman": "anik akās anik pātāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀ ਆਕਾਸ਼ ਅਤੇ ਅਨੇਕਾਂ ਹੀ ਪਾਤਾਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "многие небеса и многие подземные миры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52899,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਮੁਖੀ ਜਪੀਐ ਗੋਪਾਲ ॥੫॥",
          "roman": "anik mukhī japīai gopāl. 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਸ ਗੋਪਾਲ ਨੂੰ ਅਨੇਕਾਂ ਮੂੰਹਾਂ ਦੀ ਰਾਹੀਂ ਜਪਿਆ ਜਾ ਰਿਹਾ ਹੈ। (ਅਨੇਕਾਂ ਜੀਵ ਉਸ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ) ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тот Гопал воспевается множеством уст; многие существа повторяют Его Имя. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52900,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਸਾਸਤ੍ਰ ਸਿਮ੍ਰਿਤਿ ਪੁਰਾਨ ॥",
          "roman": "anik sāsatr simrit purān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਹੈ) ਅਨੇਕਾਂ ਸ਼ਾਸਤ੍ਰਾਂ ਸਿਮ੍ਰਿਤੀਆਂ ਅਤੇ ਪੁਰਾਣਾਂ ਦੀ ਰਾਹੀਂ-"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Двор Бога изумителен: посредством многих шастр, смрити и пуран,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52901,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੁਗਤਿ ਹੋਵਤ ਬਖਿਆਨ ॥",
          "roman": "anik jugat hovat bakhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ (ਉਸ ਦੇ ਗੁਣਾਂ ਦਾ) ਉਪਦੇਸ਼ ਹੋ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "многими способами происходит наставление о Его качествах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52902,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਸਰੋਤੇ ਸੁਨਹਿ ਨਿਧਾਨ ॥",
          "roman": "anik sarote suneh nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਅਨੇਕਾਂ ਹੀ ਸੁਣਨ ਵਾਲੇ ਉਸ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦੀਆਂ ਸਿਫ਼ਤਾਂ ਸੁਣ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Многие слушатели слушают восхваления того Господа, сокровищницы качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52903,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਜੀਅ ਪੂਰਨ ਭਗਵਾਨ ॥੬॥",
          "roman": "sarab jīa pūran bhagvān. 6",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਹ ਭਗਵਾਨ ਸਾਰੇ ਹੀ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тот Бхагаван пронизывает всех существ. 6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52904,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਧਰਮ ਅਨਿਕ ਕੁਮੇਰ ॥",
          "roman": "anik dharam anik kumer",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਅਨੇਕਾਂ ਧਰਮਰਾਜ ਹਨ ਅਨੇਕਾਂ ਹੀ ਧਨ ਦੇ ਦੇਵਤੇ ਕੁਬੇਰ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тем Богом созданы многие Дхармараджи и многие Куберы, божества богатства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52905,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਰਨ ਅਨਿਕ ਕਨਿਕ ਸੁਮੇਰ ॥",
          "roman": "anik baran anik kanik sumer",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਸਮੁੰਦਰ ਦੇ ਦੇਵਤੇ ਵਰਣ ਹਨ ਅਤੇ ਅਨੇਕਾਂ ਹੀ ਸੋਨੇ ਦੇ ਸੁਮੇਰ ਪਰਬਤ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "многие Варуны, божества океана, и многие золотые горы Сумеру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52906,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਸੇਖ ਨਵਤਨ ਨਾਮੁ ਲੇਹਿ ॥",
          "roman": "anik sekh navtan nām leh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀ ਉਸ ਦੇ ਬਣਾਏ ਹੋਏ ਸ਼ੇਸ਼ਨਾਗ ਹਨ ਜੋ (ਹਰ ਰੋਜ਼ ਸਦਾ ਉਸ ਦਾ) ਨਵਾਂ ਹੀ ਨਾਮ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "многие созданные Им Шешнаги, которые каждый день всегда берут Его всё новое Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52907,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕਾ ਅੰਤੁ ਨ ਤੇਹਿ ॥੭॥",
          "roman": "pārbraham kā ant na teh. 7",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਹਨਾਂ ਵਿਚੋਂ ਕਿਸੇ ਨੇ ਉਸ (ਦੇ ਗੁਣਾਂ) ਦਾ ਅੰਤ ਨਹੀਂ ਲੱਭਾ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Никто из них не нашёл предела Его качествам. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52908,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪੁਰੀਆ ਅਨਿਕ ਤਹ ਖੰਡ ॥",
          "roman": "anik purīā anik tah khaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਸ ਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ) ਅਨੇਕਾਂ ਖੰਡ ਹਨ ਅਤੇ ਅਨੇਕਾਂ ਪੁਰੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Двор Бога изумителен: Им созданы многие области и многие города."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52909,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰੂਪ ਰੰਗ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "anik rūp raṅg brahamaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਬਣਾਏ ਅਨੇਕਾਂ ਰੂਪਾਂ ਰੰਗਾਂ ਦੇ ਬ੍ਰਹਮੰਡ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Им созданы вселенные многих форм и цветов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52910,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਨਾ ਅਨਿਕ ਫਲ ਮੂਲ ॥",
          "roman": "anik banā anik phal mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸਦੇ ਪੈਦਾ ਕੀਤੇ ਹੋਏ ਅਨੇਕਾਂ ਜੰਗਲ ਤੇ ਉਹਨਾਂ ਵਿਚ ਉੱਗਣ ਵਾਲੇ ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਫਲ ਅਤੇ ਕੰਦ ਮੂਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Им созданы многие леса, а в них растут многие виды плодов, корней и клубней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52911,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਸੂਖਮ ਆਪਹਿ ਅਸਥੂਲ ॥੮॥",
          "roman": "āpeh sūkham āpeh asthūl. 8",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਅਦ੍ਰਿਸ਼ਟ ਰੂਪ ਵਾਲਾ ਹੈ, ਉਹ ਆਪ ਹੀ ਇਹ ਦਿੱਸਦਾ ਜਗਤ-ਤਮਾਸ਼ਾ ਹੈ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог Сам имеет невидимую тонкую форму, и Он Сам есть эта видимая игра мира. 8."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52912,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੁਗਾਦਿ ਦਿਨਸ ਅਰੁ ਰਾਤਿ ॥",
          "roman": "anik jugād dinas ar rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਬਣਾਏ ਹੋਏ ਅਨੇਕਾਂ ਹੀ ਜੁਗ ਆਦਿਕ ਹਨ, ਅਨੇਕਾਂ ਹੀ ਦਿਨ ਹਨ ਅਤੇ ਅਨੇਕਾਂ ਹੀ ਰਾਤਾਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тем Богом созданы многие юги и прочее, многие дни и многие ночи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52913,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪਰਲਉ ਅਨਿਕ ਉਤਪਾਤਿ ॥",
          "roman": "anik parlau anik utpāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਨੇਕਾਂ ਵਾਰੀ ਜਗਤ ਦਾ ਨਾਸ ਕਰਦਾ ਹੈ ਅਨੇਕਾਂ ਵਾਰੀ ਜਗਤ-ਉਤਪੱਤੀ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он много раз разрушает мир и много раз создаёт мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52914,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੀਅ ਜਾ ਕੇ ਗ੍ਰਿਹ ਮਾਹਿ ॥",
          "roman": "anik jīa jā ke grih māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਉਹ ਪਰਮਾਤਮਾ ਐਸਾ ਗ੍ਰਿਹਸਤੀ ਹੈ) ਕਿ ਉਸ ਦੇ ਘਰ ਵਿਚ ਅਨੇਕਾਂ ਹੀ ਜੀਵ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Бог такой домохозяин, что в Его доме множество существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52915,
          "is_rahao": false,
          "gurmukhi": "ਰਮਤ ਰਾਮ ਪੂਰਨ ਸ੍ਰਬ ਠਾਂਇ ॥੯॥",
          "roman": "ramat rām pūran srab ṭhāe. 9",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਭ ਥਾਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ ਸਭ ਥਾਵਾਂ ਵਿਚ ਮੌਜੂਦ ਹੈ ॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "Он пронизывает все места, присутствует во всех местах. 9."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52916,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਮਾਇਆ ਜਾ ਕੀ ਲਖੀ ਨ ਜਾਇ ॥",
          "roman": "anik māiā jā kī lakhī na jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਪਰਮਾਤਮਾ ਦਾ ਦਰਬਾਰ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਹੈ) ਜਿਸ ਦੀ (ਰਚੀ ਹੋਈ) ਅਨੇਕਾਂ ਰੰਗਾਂ ਦੀ ਮਾਇਆ ਸਮਝੀ ਨਹੀਂ ਜਾ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Двор Бога изумителен: Его созданная многоцветная майя не может быть понята,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52917,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਕਲਾ ਖੇਲੈ ਹਰਿ ਰਾਇ ॥",
          "roman": "anik kalā khelē har rāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਅਨੇਕਾਂ ਕੌਤਕ ਰਚਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот Господь-Патишах творит множество чудесных игр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52918,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਧੁਨਿਤ ਲਲਿਤ ਸੰਗੀਤ ॥",
          "roman": "anik dhunit lalit saṅgīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਦਰ ਤੇ) ਅਨੇਕਾਂ ਸੁਰੀਲੇ ਰਾਗਾਂ ਦੀ ਧੁਨੀ ਹੋ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У Его двери звучат мелодии многих прекрасных рагов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52919,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਗੁਪਤ ਪ੍ਰਗਟੇ ਤਹ ਚੀਤ ॥੧੦॥",
          "roman": "anik gupat pragṭe tah chīt. 10",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਅਨੇਕਾਂ ਹੀ ਚਿੱਤਰ ਗੁਪਤ ਪ੍ਰਤੱਖ ਦਿੱਸਦੇ ਹਨ ॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "Там многие Читра-Гупты видны явно. 10."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52920,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਭਗਤ ਜਾ ਕੈ ਸੰਗਿ ॥",
          "roman": "sabh te ūch bhagat jā kē saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਹ ਪਰਮਾਤਮਾ ਸਭ ਤੋਂ ਉੱਚਾ ਹੈ ਜਿਸ ਦੇ ਦਰ ਤੇ ਅਨੇਕਾਂ ਭਗਤ-"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тот Бог выше всех; у Его двери многие преданные,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52921,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਗੁਨ ਗਾਵਹਿ ਰੰਗਿ ॥",
          "roman": "āṭh pahar gun gāveh raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰੇਮ ਨਾਲ ਅੱਠੇ ਪਹਰ ਉਸ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "с любовью все восемь страж дня и ночи продолжают петь песни Его восхваления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52922,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਅਨਾਹਦ ਆਨੰਦ ਝੁਨਕਾਰ ॥",
          "roman": "anik anāhad ānand jhuṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਦਰ ਤੇ ਬਿਨਾ ਵਜਾਏ ਵੱਜ ਰਹੇ ਸਾਜਾਂ ਦੀ ਮਿੱਠੀ ਸੁਰ ਦਾ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У Его двери пребывает наслаждение сладким звуком инструментов, играющих без прикосновения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52923,
          "is_rahao": false,
          "gurmukhi": "ਉਆ ਰਸ ਕਾ ਕਛੁ ਅੰਤੁ ਨ ਪਾਰ ॥੧੧॥",
          "roman": "uā ras kā kachh ant na pār. 11",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਆਨੰਦ ਦਾ ਅੰਤ ਜਾਂ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ (ਉਹ ਆਨੰਦ ਅਮੁੱਕ ਹੈ) ॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "у того наслаждения невозможно найти ни конца, ни дальнего берега; это наслаждение неисчерпаемо. 11."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52924,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਪੁਰਖੁ ਸਤਿ ਅਸਥਾਨੁ ॥",
          "roman": "sat purakh sat asthān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਉਹ ਪਰਮਾਤਮਾ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਉਸ ਦਾ ਅਸਥਾਨ ਭੀ ਅਟੱਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О святые люди! Тот Бог вечно пребывает, и Его место тоже неизменно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52925,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਤੇ ਊਚ ਨਿਰਮਲ ਨਿਰਬਾਨੁ ॥",
          "roman": "ūch te ūch nirmal nirbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਉੱਚਿਆਂ ਤੋਂ ਉੱਚਾ ਹੈ, ਪਵਿੱਤਰ-ਸਰੂਪ ਹੈ, ਵਾਸਨਾ-ਰਹਿਤ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он выше высочайших, имеет чистую природу и свободен от желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52926,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨਾ ਕੀਆ ਜਾਨਹਿ ਆਪਿ ॥",
          "roman": "apunā kīā jāneh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਆਪਣੇ ਰਚੇ (ਜਗਤ) ਨੂੰ ਤੂੰ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Своё созданное творение Ты Сам знаешь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52927,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਘਟਿ ਘਟਿ ਰਹਿਓ ਬਿਆਪਿ ॥",
          "roman": "āpe ghaṭ ghaṭ rahio biāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪ ਹੀ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты Сам присутствуешь в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52928,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਨਾਨਕ ਦਇਆਲ ॥",
          "roman": "kripā nidhān Nānak daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਇਆ ਦੇ ਖ਼ਜ਼ਾਨੇ! ਹੇ ਦਇਆ ਦੇ ਸੋਮੇ!"
            },
            "sahib_singh_ru": {
              "main": "О сокровищница милости! О источник сострадания!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52929,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਪਿਆ ਨਾਨਕ ਤੇ ਭਏ ਨਿਹਾਲ ॥੧੨॥੧॥੨॥੨॥੩॥੭॥",
          "roman": "jin japiā Nānak te bhae nihāl. 12. 1. 2. 2. 3. 7",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ, ਜਿਸ ਜਿਸ ਨੇ (ਤੇਰਾ ਨਾਮ) ਜਪਿਆ ਹੈ, ਉਹ ਸਭ ਪ੍ਰਸੰਨ-ਚਿੱਤ ਰਹਿੰਦੇ ਹਨ ॥੧੨॥੧॥੨॥੨॥੩॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: все те, кто повторял Твоё Имя, пребывают радостными духом. 12. 1. 2. 2. 3. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4415,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 52930,
          "is_rahao": false,
          "gurmukhi": "ਸਾਰਗ ਛੰਤ ਮਹਲਾ ੫",
          "roman": "sārag chhant mėhlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸਾਰੰਗ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ 'ਛੰਤ' (ਛੰਦ)।"
            },
            "sahib_singh_ru": {
              "main": "В раге Саранг — бани Гуру Арджандева Джи, «чхант»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52931,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх един, и Он обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52932,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਦੇਖੀਐ ਅਨਭੈ ਕਾ ਦਾਤਾ ॥",
          "roman": "sabh dekhīē anbhē kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਰਭੈਤਾ ਦੀ ਅਵਸਥਾ ਦੇਣ ਵਾਲਾ ਪ੍ਰਭੂ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ ਵੱਸਦਾ ਦਿੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь, дарующий состояние бесстрашия, видится пребывающим во всём творении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52933,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਪੂਰਨ ਹੈ ਅਲਿਪਾਤਾ ॥",
          "roman": "ghaṭ ghaṭ pūran hē alipātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪਕ ਹੈ, ਫਿਰ ਭੀ ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь пронизывает каждое тело, но всё же остаётся непривязанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52934,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਪੂਰਨੁ ਕਰਿ ਬਿਸਥੀਰਨੁ ਜਲ ਤਰੰਗ ਜਿਉ ਰਚਨੁ ਕੀਆ ॥",
          "roman": "ghaṭ ghaṭ pūran kar bisthīran jal taraṅg jiu rachan kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਦੀਆਂ ਲਹਿਰਾਂ (ਵਿਚ ਪਾਣੀ ਮੌਜੂਦ ਹੈ) ਪਰਮਾਤਮਾ ਜਗਤ-ਰਚਨਾ ਦਾ ਖਿਲਾਰਾ ਰਚ ਕੇ ਆਪ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Как вода присутствует в волнах воды, так Параматма, развернув сотворённый мир, Сам пронизывает каждое тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52935,
          "is_rahao": false,
          "gurmukhi": "ਹਭਿ ਰਸ ਮਾਣੇ ਭੋਗ ਘਟਾਣੇ ਆਨ ਨ ਬੀਆ ਕੋ ਥੀਆ ॥",
          "roman": "habh ras māṇe bhog ghaṭāṇe ān na bīā ko thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ ਉਹ ਸਾਰੇ ਰਸ ਮਾਣਦਾ ਹੈ ਸਾਰੇ ਭੋਗ ਭੋਗਦਾ ਹੈ, (ਉਸ ਤੋਂ ਬਿਨਾ ਕਿਤੇ ਭੀ) ਕੋਈ ਦੂਜਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пронизывая каждое тело, Он наслаждается всеми вкусами и испытывает все удовольствия; кроме Него, нигде нет другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52936,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰੰਗੀ ਇਕ ਰੰਗੀ ਠਾਕੁਰੁ ਸੰਤਸੰਗਿ ਪ੍ਰਭੁ ਜਾਤਾ ॥",
          "roman": "har raṅgī ik raṅgī ṭhākur satsang prabh jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਰੰਗਾਂ ਦਾ ਰਚਣ ਵਾਲਾ ਉਹ ਮਾਲਕ-ਹਰੀ ਇਕ-ਰਸ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ। ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤ ਵਿਚ ਟਿੱਕ ਕੇ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਸਾਂਝ ਪੈ ਸਕਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Владыка-Хари, Творец всех красок, единым ровным образом пронизывает всё. Утвердившись в обществе святых, можно войти в связь с этим Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52937,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਸਿ ਲੀਨਾ ਜਿਉ ਜਲ ਮੀਨਾ ਸਭ ਦੇਖੀਐ ਅਨਭੈ ਕਾ ਦਾਤਾ ॥੧॥",
          "roman": "nānak daras līnā jiu jal mīnā sabh dekhīē anbhē kā dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮੈਂ ਉਸ ਦੇ ਦਰਸਨ ਵਿਚ ਇਉਂ ਲੀਨ ਰਹਿੰਦਾ ਹਾਂ ਜਿਵੇਂ ਮੱਛੀ ਪਾਣੀ ਵਿਚ। ਨਿਰਭੈਤਾ ਦਾ ਦੇਣ ਵਾਲਾ ਉਹ ਪ੍ਰਭੂ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ ਦਿੱਸ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Я остаюсь погружённым в Его даршан так, как рыба — в воде. Этот Господь, дарующий бесстрашие, видится во всём творении ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52938,
          "is_rahao": false,
          "gurmukhi": "ਕਉਨ ਉਪਮਾ ਦੇਉ ਕਵਨ ਬਡਾਈ ॥",
          "roman": "kaun upmā deu kavan baḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਮੈਂ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਬਰਾਬਰੀ ਦਾ ਕੋਈ ਭੀ ਦੱਸ ਨਹੀਂ ਸਕਦਾ। ਉਹ ਕੇਡਾ ਵੱਡਾ ਹੈ-ਇਹ ਭੀ ਨਹੀਂ ਦੱਸ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! Я не могу назвать никого равного этому Параматме. И насколько Он велик — этого тоже не могу сказать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52939,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹਿਓ ਸ੍ਰਬ ਠਾਈ ॥",
          "roman": "pūran pūr rahio srab ṭhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਰਬ-ਵਿਆਪਕ ਹੈ, ਉਹ ਸਭਨੀਂ ਥਾਈਂ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он всепроникающий, Он присутствует во всех местах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 52940,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਮਨਮੋਹਨ ਘਟ ਘਟ ਸੋਹਨ ਜਬ ਖਿੰਚੈ ਤਬ ਛਾਈ ॥",
          "roman": "pūran manmohan ghaṭ ghaṭ sohan jab khiñchē tab chhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਰਬ-ਵਿਆਪਕ ਹੈ, ਸਭ ਦੇ ਮਨਾਂ ਨੂੰ ਖਿੱਚ ਪਾਣ ਵਾਲਾ ਹੈ, ਸਭ ਸਰੀਰਾਂ ਨੂੰ (ਆਪਣੀ ਜੋਤਿ ਨਾਲ) ਸੋਹਣਾ ਬਣਾਣ ਵਾਲਾ ਹੈ। ਜਦੋਂ ਉਹ ਆਪਣੀ ਜੋਤਿ ਖਿੱਚ ਲੈਂਦਾ ਹੈ, ਤਦੋਂ ਕੁਝ ਭੀ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь всепроникающий, притягивающий умы всех, украшающий все тела Своим светом. Когда Он оттягивает Свой свет, тогда ничего не остаётся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
