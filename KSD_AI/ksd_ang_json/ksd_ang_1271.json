{
  "ang": 1271,
  "shabads": [
    {
      "shabad_id": 4584,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 54345,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਕੈ ਸਦ ਕੁਰਬਾਣੇ ॥੪॥੨॥੨੦॥",
          "roman": "nānak tin kē sad kurbāṇe ॥4॥2॥20॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮੈਂ ਉਹਨਾਂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੪॥੨॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Я всегда становлюсь жертвой им. ॥4॥2॥20॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4585,
      "rahao_verse_id": 54352,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 54346,
          "is_rahao": false,
          "gurmukhi": "ਮਲਾਰ ਮਹਲਾ ੫ ॥",
          "roman": "malār mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54347,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮੇਸਰੁ ਹੋਆ ਦਇਆਲੁ ॥",
          "roman": "parmesar hoā daiāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ) ਪਰਮਾਤਮਾ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "К тому человеку, к кому Всевышний становится милостивым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54348,
          "is_rahao": false,
          "gurmukhi": "ਮੇਘੁ ਵਰਸੈ ਅੰਮ੍ਰਿਤ ਧਾਰ ॥",
          "roman": "megh varsē amrit dhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼) ਬੱਦਲ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਨਾਮ-ਜਲ ਦੀਆਂ ਧਾਰਾਂ ਦੀ ਵਰਖਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в его сердце наставление Гуру, словно облако, проливает потоки воды Имени, дающей духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54349,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਜੀਅ ਜੰਤ ਤ੍ਰਿਪਤਾਸੇ ॥",
          "roman": "sagle jīa jant triptāse ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਉੱਤੇ ਇਹ ਵਰਖਾ ਹੁੰਦੀ ਹੈ, ਉਹ) ਸਾਰੇ ਜੀਵ (ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਵਲੋਂ) ਰੱਜ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все существа, на кого проливается этот дождь, насыщаются и освобождаются от жажды майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54350,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜ ਆਏ ਪੂਰੇ ਰਾਸੇ ॥੧॥",
          "roman": "kāraj āe pūre rāse ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Все их дела успешно завершаются ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54351,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਮਨ ਨਾਮੁ ਸਮੑਾਲਿ ॥",
          "roman": "sadā sadā man nām samhāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਸਦਾ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਯਾਦ ਕਰਦਾ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Всегда, всегда помни Имя Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54352,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਸੇਵਾ ਪਾਇਆ ਐਥੈ ਓਥੈ ਨਿਬਹੈ ਨਾਲਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūre kī sevā pāiā ēthē othē nibhē nāl ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਨਾਮ) ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਮਿਲਦਾ ਹੈ, ਅਤੇ ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ (ਜੀਵ ਦੇ ਨਾਲ) ਸਾਥ ਦੇਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Это Имя обретается, когда человек приходит под защиту совершенного Гуру, и оно сопровождает живое существо и в этом мире, и в мире ином ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54353,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਭੰਨਾ ਭੈ ਭੰਜਨਹਾਰ ॥",
          "roman": "dukh bhannā bhē bhañjanhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੇ) ਸਾਰੇ ਡਰ ਨਾਸ ਕਰ ਸਕਣ ਵਾਲੇ ਉਸ ਪ੍ਰਭੂ ਨੇ-"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь, способный уничтожить все страхи живых существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54354,
          "is_rahao": false,
          "gurmukhi": "ਆਪਣਿਆ ਜੀਆ ਕੀ ਕੀਤੀ ਸਾਰ ॥",
          "roman": "āpṇiā jīā kī kītī sār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਪੈਦਾ ਕੀਤੇ ਜੀਵਾਂ ਦੀ ਸਦਾ ਸੰਭਾਲ ਕੀਤੀ ਹੈ, ਤੇ (ਜੀਵਾਂ ਦਾ) ਹਰੇਕ ਦੁੱਖ ਦੂਰ ਕੀਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всегда заботился о сотворённых Им существах и устранял всякое их страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54355,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਸਦਾ ਮਿਹਰਵਾਨ ॥",
          "roman": "rākhṇhār sadā miharvān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਖਿਆ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲਾ ਪਰਮਾਤਮਾ (ਜੀਵਾਂ ਉੱਤੇ) ਸਦਾ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Всевышний, обладающий силой защищать, всегда остаётся милостивым к живым существам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54356,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਾਈਐ ਕੁਰਬਾਨ ॥੨॥",
          "roman": "sadā sadā jāīai kurbān ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ (ਚਰਨਾਂ) ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ради Его стоп следует всегда, всегда жертвовать собой ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54357,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੁ ਗਵਾਇਆ ਕਰਤੈ ਆਪਿ ॥",
          "roman": "kāl gavāiā kartē āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੇ ਭੀ ਨਾਮ ਜਪਿਆ ਹੈ) ਕਰਤਾਰ ਨੇ (ਉਸ ਦੇ ਸਿਰ ਤੋਂ ਆਤਮਕ) ਮੌਤ ਦੂਰ ਕਰ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "У того, кто повторял Имя, Творец Сам удалил с его головы духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54358,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਮਨ ਤਿਸ ਨੋ ਜਾਪਿ ॥",
          "roman": "sadā sadā man tis no jāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੇ ਮਨ! ਸਦਾ ਹੀ ਸਦਾ ਹੀ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о ум! Всегда, всегда повторяй Имя того Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54359,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿਸਟਿ ਧਾਰਿ ਰਾਖੇ ਸਭਿ ਜੰਤ ॥",
          "roman": "drisaṭ dhār rākhe sabh jant ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਭਗਵਾਨ ਨੇ) ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਕਰ ਕੇ ਸਾਰੇ ਜੀਵਾਂ ਦੀ (ਸਦਾ) ਰੱਖਿਆ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Бхагван, бросив взгляд милости, всегда защищал всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54360,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵਹੁ ਨਿਤ ਨਿਤ ਭਗਵੰਤ ॥੩॥",
          "roman": "guṇ gāvhu nit nit bhagvant ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਵਾਨ ਦੇ ਗੁਣ ਸਦਾ ਹੀ ਗਾਂਦੇ ਰਹੋ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Всегда пойте достоинства Бхагвана ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54361,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਕਰਤਾ ਆਪੇ ਆਪ ॥",
          "roman": "eko kartā āpe āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਆਪ ਹੀ ਆਪ (ਹਰ ਥਾਂ ਮੌਜੂਦ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Творец Сам по Себе присутствует повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54362,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਭਗਤ ਜਾਣਹਿ ਪਰਤਾਪ ॥",
          "roman": "har ke bhagat jāṇeh partāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸਦੇ ਭਗਤ ਉਸ ਦਾ ਤੇਜ-ਪਰਤਾਪ ਜਾਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Его преданные знают Его сияние и величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54363,
          "is_rahao": false,
          "gurmukhi": "ਨਾਵੈ ਕੀ ਪੈਜ ਰਖਦਾ ਆਇਆ ॥",
          "roman": "nāvē kī pēj rakhdā āiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਸਰਨ-ਜੋਗ ਹੈ, ਸਰਨ ਪਿਆਂ ਦੀ ਬਾਂਹ ਫੜਦਾ ਹੈ, ਆਪਣੇ ਇਸ) ਨਾਮ ਦੀ ਲਾਜ ਉਹ (ਸਦਾ ਹੀ) ਰੱਖਦਾ ਆ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он достоин прибежища, Он поддерживает тех, кто приходит под Его защиту; эту честь Своего Имени Он всегда сохранял."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54364,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਬੋਲੈ ਤਿਸ ਕਾ ਬੋਲਾਇਆ ॥੪॥੩॥੨੧॥",
          "roman": "nānak bolē tis kā bolāiā ॥4॥3॥21॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਦਾਸ ਨਾਨਕ ਉਸ (ਕਰਤਾਰ) ਦਾ ਪਰੇਰਿਆ ਹੋਇਆ ਹੀ (ਉਸਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਬੋਲ) ਬੋਲਦਾ ਹੈ ॥੪॥੩॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "Его слуга Нанак говорит слово Его восхваления только по побуждению того Творца ॥4॥3॥21॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4586,
      "rahao_verse_id": 54371,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 54365,
          "is_rahao": false,
          "gurmukhi": "ਮਲਾਰ ਮਹਲਾ ੫ ॥",
          "roman": "malār mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54366,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਰਣਾਈ ਸਗਲ ਨਿਧਾਨ ॥",
          "roman": "gur sarṇāī sagal nidhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਰਿਹਾਂ ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ (ਮਿਲ ਜਾਂਦੇ ਹਨ);"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь под защитой Гуру, обретаются все сокровища;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54367,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਦਰਗਹਿ ਪਾਈਐ ਮਾਨੁ ॥",
          "roman": "sāchī dargah pāīai mān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਰੱਬੀ ਦਰਗਾਹ ਵਿਚ ਆਦਰ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в вечно пребывающем Божественном дворе обретается почёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54368,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮੁ ਭਉ ਦੂਖੁ ਦਰਦੁ ਸਭੁ ਜਾਇ ॥",
          "roman": "bhram bhau dūkh darad sabh jāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗਾਂਦਾ ਹੈ, ਉਸ ਦਾ) ਭਰਮ; ਡਰ, ਹਰੇਕ ਦੁੱਖ-ਦਰਦ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У человека, который поёт о Всевышнем, заблуждение, страх и всякая боль-страдание уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54369,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸਦ ਹਰਿ ਗੁਣ ਗਾਇ ॥੧॥",
          "roman": "sādhasaṅg sad har guṇ gāe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, оставаясь в обществе Гуру, всегда пой достоинства Всевышнего ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54370,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਮੇਰੇ ਗੁਰੁ ਪੂਰਾ ਸਾਲਾਹਿ ॥",
          "roman": "man mere gur pūrā sālāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪੂਰੇ ਗੁਰੂ ਦੀ (ਸਦਾ) ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Всегда восхваляй совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54371,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੁ ਨਿਧਾਨੁ ਜਪਹੁ ਦਿਨੁ ਰਾਤੀ ਮਨ ਚਿੰਦੇ ਫਲ ਪਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām nidhān japah din rātī man chinde phal pāe ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਦਿਨ ਰਾਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ (ਇਹੀ ਹੈ ਸਾਰੇ ਸੁਖਾਂ ਦਾ) ਖ਼ਜ਼ਾਨਾ। (ਜਿਹੜਾ ਮਨੁੱਖ ਜਪਦਾ ਹੈ, ਉਹ) ਮਨ-ਮੰਗੇ ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Придя под защиту Гуру, день и ночь повторяй Имя Всевышнего; это и есть сокровище всех благ. Человек, который повторяет его, получает желанные плоды ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54372,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਜੇਵਡੁ ਅਵਰੁ ਨ ਕੋਇ ॥",
          "roman": "satigur jevaḍ avar na koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬਖ਼ਸ਼ਸ਼ਾਂ ਕਰਨ ਵਿਚ) ਗੁਰੂ ਦੇ ਬਰਾਬਰ ਦਾ ਹੋਰ ਕੋਈ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "В даровании милостей нет никого равного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54373,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਾਰਬ੍ਰਹਮੁ ਪਰਮੇਸਰੁ ਸੋਇ ॥",
          "roman": "gur pārbraham parmesar soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ ਪਾਰਬ੍ਰਹਮ ਹੈ, ਗੁਰੂ ਪਰਮੇਸਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Гуру есть Парабрахм, Гуру есть Всевышний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54374,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਦੂਖ ਤੇ ਰਾਖੈ ॥",
          "roman": "janam maraṇ dūkh te rākhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਜੰਮਣ ਮਰਨ ਦੇ ਗੇੜ ਦੇ ਦੁੱਖਾਂ ਤੋਂ ਬਚਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру спасает от страданий круговорота рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54375,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਬਿਖੁ ਫਿਰਿ ਬਹੁੜਿ ਨ ਚਾਖੈ ॥੨॥",
          "roman": "māiā bikh phir bahuṛ na chākhē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ, ਉਹ) ਆਤਮਕ ਮੌਤ ਲਿਆਉਣ ਵਾਲੀ ਮਾਇਆ ਦੇ ਜ਼ਹਰ ਨੂੰ ਮੁੜ ਮੁੜ ਸੁਆਦ ਲਾ ਲਾ ਕੇ ਨਹੀਂ ਚੱਖਦਾ ਰਹਿੰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Человек, который приходит под защиту Гуру, не продолжает снова и снова с наслаждением пробовать яд майи, несущий духовную смерть ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54376,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਮਹਿਮਾ ਕਥਨੁ ਨ ਜਾਇ ॥",
          "roman": "gur kī mahimā kathan na jāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਵਡਿਆਈ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Величие Гуру невозможно выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54377,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਸਾਚੈ ਨਾਇ ॥",
          "roman": "gur parmesar sāchē nāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਪਰਮੇਸਰ (ਦਾ ਰੂਪ) ਹੈ, ਗੁਰੂ (ਪਰਮਾਤਮਾ ਦੇ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਨਾਮ ਵਿਚ (ਲੀਨ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — образ Всевышнего; Гуру пребывает в вечно устойчивом Имени Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54378,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸੰਜਮੁ ਕਰਣੀ ਸਭੁ ਸਾਚੀ ॥",
          "roman": "sach sañjam karṇī sabh sāchī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਰਹਿਣਾ-ਇਹੀ ਹੈ ਗੁਰੂ ਦਾ ਸੰਜਮ। ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦੇ ਰਹਿਣਾ-ਇਹੀ ਹੈ ਗੁਰੂ ਦੀ ਕਰਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помнить Имя Всевышнего — это и есть сдержанность Гуру. Постоянно совершать восхваление Всевышнего — это и есть поведение Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54379,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮਨੁ ਨਿਰਮਲੁ ਜੋ ਗੁਰ ਸੰਗਿ ਰਾਚੀ ॥੩॥",
          "roman": "so man nirmal jo gur saṅg rāchī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨ ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ ਉਹ ਮਨ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тот ум, который погружён в общество Гуру, становится чистым ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54380,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪਾਈਐ ਵਡ ਭਾਗਿ ॥",
          "roman": "gur pūrā pāīai vaḍ bhāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰਾ ਗੁਰੂ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру встречается по великой удаче,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54381,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਲੋਭੁ ਮਨ ਤੇ ਤਿਆਗਿ ॥",
          "roman": "kām krodh lobh man te tiāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੂੰ ਮਿਲਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਆਪਣੇ) ਮਨ ਵਿਚੋਂ ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ (ਆਦਿਕ ਵਿਕਾਰ) ਦੂਰ ਕਰ ਕੇ (ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и тот, кому он встречается, удалив из своего ума похоть, гнев, жадность и прочие пороки, остаётся под защитой Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54382,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਗੁਰ ਚਰਣ ਨਿਵਾਸਿ ॥",
          "roman": "kar kirpā gur charaṇ nivās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮਿਹਰ ਕਰ ਕੇ (ਮੈਨੂੰ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਾਈ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! По милости удержи меня у стоп Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54383,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਪ੍ਰਭ ਸਚੁ ਅਰਦਾਸਿ ॥੪॥੪॥੨੨॥",
          "roman": "nānak kī prabh sach ardās ॥4॥4॥22॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਨਾਨਕ ਦੀ ਇਹ ਅਰਦਾਸ ਹੈ, (ਸੇਵਕ ਨੂੰ) ਆਪਣਾ ਸਦਾ-ਥਿਰ ਨਾਮ ਬਖ਼ਸ਼ ॥੪॥੪॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Такова молитва Нанака: даруй слуге Своё вечно неизменное Имя ॥4॥4॥22॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4587,
      "rahao_verse_id": 54389,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 54384,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਮਲਾਰ ਮਹਲਾ ੫ ਪੜਤਾਲ ਘਰੁ ੩",
          "roman": "rāg malār mahalā 5 paṛtāl ghar 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਮਲਾਰ, ਘਰ ੩ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ 'ਪੜਤਾਲ'।"
            },
            "sahib_singh_ru": {
              "main": "Раг Маляр, в доме 3, бани Гуру Арджандева Джи, ‘пар̣та̄л’."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54385,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вечный Пурух един и обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54386,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਮਨਾਰਿ ਪ੍ਰਿਅ ਦਇਆਰ ਸਿਉ ਰੰਗੁ ਕੀਆ ॥",
          "roman": "gur manār pria daiār siu raṅg kīā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! (ਜਿਸ ਜੀਵ-ਇਸਤ੍ਰੀ ਨੇ ਆਪਣੇ) ਗੁਰੂ ਦੀ ਪ੍ਰਸੰਨਤਾ ਹਾਸਲ ਕਰ ਕੇ ਦਇਆ ਦੇ ਸੋਮੇ ਪਿਆਰੇ ਪ੍ਰਭੂ ਨਾਲ ਆਤਮਕ ਅਨੰਦ ਮਾਨਣਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Та душа-женщина, которая, получив довольство своего Гуру, начала наслаждаться духовной радостью с возлюбленным Господом, источником милости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54387,
          "is_rahao": true,
          "gurmukhi": "ਕੀਨੋ ਰੀ ਸਗਲ ਸਂੀਗਾਰ ॥",
          "roman": "kīno rī sagal sīṅgār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਸਾਰੇ (ਆਤਮਕ) ਸਿੰਗਾਰ ਕਰ ਲਏ (ਭਾਵ, ਉਸ ਦੇ ਅੰਦਰ ਉੱਚੇ ਆਤਮਕ ਗੁਣ ਪੈਦਾ ਹੋ ਗਏ),"
            },
            "sahib_singh_ru": {
              "main": "совершила все духовные украшения, то есть в ней возникли высокие духовные качества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54388,
          "is_rahao": true,
          "gurmukhi": "ਤਜਿਓ ਰੀ ਸਗਲ ਬਿਕਾਰ ॥",
          "roman": "tajio rī sagal bikār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਸਾਰੇ ਵਿਕਾਰ ਤਿਆਗ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "она оставила все пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54389,
          "is_rahao": true,
          "gurmukhi": "ਧਾਵਤੋ ਅਸਥਿਰੁ ਥੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dhāvto asthir thīā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ (ਪਹਿਲਾ) ਭਟਕਦਾ ਮਨ ਡੋਲਣੋਂ ਹਟ ਗਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "её прежде блуждающий ум перестал колебаться ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54390,
          "is_rahao": false,
          "gurmukhi": "ਐਸੇ ਰੇ ਮਨ ਪਾਇ ਕੈ ਆਪੁ ਗਵਾਇ ਕੈ ਕਰਿ ਸਾਧਨ ਸਿਉ ਸੰਗੁ ॥",
          "roman": "ēse re man pāe kē āp gavāe kē kar sādhan siu saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਭੀ ਇਸੇ ਤਰ੍ਹਾਂ (ਪ੍ਰਭੂ ਦਾ ਮਿਲਾਪ) ਹਾਸਲ ਕਰ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰ ਕੇ ਸੰਤ ਜਨਾਂ ਨਾਲ ਸੰਗਤ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! И ты так же, обретя встречу с Господом, удалив изнутри чувство самости, пребывай в обществе святых людей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54391,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜੇ ਬਜਹਿ ਮ੍ਰਿਦੰਗ ਅਨਾਹਦ ਕੋਕਿਲ ਰੀ ਰਾਮ ਨਾਮੁ ਬੋਲੈ ਮਧੁਰ ਬੈਨ ਅਤਿ ਸੁਹੀਆ ॥੧॥",
          "roman": "bāje bajeh mridaṅg anāhad kokil rī rām nām bolē madhur bēn at suhīā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰੇ ਅੰਦਰ ਐਸਾ ਆਨੰਦ ਬਣਿਆ ਰਹੇਗਾ, ਜਿਵੇਂ) ਇਕ-ਰਸ ਢੋਲ ਆਦਿਕ ਸਾਜ਼ ਵੱਜ ਰਹੇ ਹਨ, (ਤੇਰੀ ਜੀਭ ਇਉਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਉਚਾਰਿਆ ਕਰੇਗੀ, ਜਿਵੇਂ) ਕੋਇਲ ਮਿੱਠੇ ਅਤੇ ਬੜੇ ਸੁੰਦਰ ਬੋਲ ਬੋਲਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Внутри тебя будет пребывать такая радость, словно непрерывно звучат барабаны и другие инструменты; твой язык будет произносить Имя Всевышнего так, как кукушка говорит сладкие и очень прекрасные слова ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54392,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਤੇਰੇ ਦਰਸਨ ਕੀ ਸੋਭ ਅਤਿ ਅਪਾਰ ਪ੍ਰਿਅ ਅਮੋਘ ਤੈਸੇ ਹੀ ਸੰਗਿ ਸੰਤ ਬਨੇ ॥",
          "roman": "ēsī tere darsan kī sobh at apār pria amogh tēse hī saṅg sant bane ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਿਆਰੇ ਪ੍ਰਭੂ! ਹੇ ਬਹੁਤ ਬੇਅੰਤ ਪ੍ਰਭੂ! ਤੇਰੇ ਦਰਸਨ ਦੀ ਵਡਿਆਈ ਅਜਿਹੀ ਹੈ ਕਿ ਸਫਲਤਾ ਦੇ ਨਿਸ਼ਾਨੇ ਤੋਂ ਉੱਕਦੀ ਨਹੀਂ। ਤੇਰੇ ਸੰਤ ਭੀ ਤੇਰੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਕੇ (ਤੇਰੇ ਵਰਗੇ) ਬਣ ਜਾਂਦੇ ਹਨ"
            },
            "sahib_singh_ru": {
              "main": "О возлюбленный Господь! О бесконечно беспредельный Господь! Величие Твоего даршана таково, что оно не уклоняется от цели успеха. Твои святые, соединяясь с Твоими стопами, тоже становятся подобными Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54393,
          "is_rahao": false,
          "gurmukhi": "ਭਵ ਉਤਾਰ ਨਾਮ ਭਨੇ ॥",
          "roman": "bhav utār nām bhane ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਕਰਨ ਵਾਲਾ ਤੇਰਾ ਨਾਮ ਜਪ ਜਪ ਕੇ-"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Твоё Имя, которое переправляет через океан мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 54394,
          "is_rahao": false,
          "gurmukhi": "ਰਮ ਰਾਮ ਰਾਮ ਮਾਲ ॥",
          "roman": "ram rām rām māl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਸੇਵਕ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਸੁੰਦਰ ਮਾਲਾ-"
            },
            "sahib_singh_ru": {
              "main": "те слуги, которые прекрасную чётку Имени Всевышнего"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
