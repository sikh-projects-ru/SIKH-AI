{
  "ang": 1339,
  "shabads": [
    {
      "shabad_id": 4866,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56966,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪਾਰਬ੍ਰਹਮੁ ਧਿਆਈ ਸਦਾ ਸਦਾ ਗੁਨ ਗਾਇਆ ॥",
          "roman": "āṭh pahar pārbrahm dhiāī sadā sadā gun gāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਅੱਠੇ ਪਹਰ ਉਸ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹਾਂ ਸਦਾ ਹੀ ਉਸ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь я все восемь страж суток вспоминаю Его Имя и всегда продолжаю воспевать Его достоинства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56967,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਮੇਰੇ ਪੂਰੇ ਮਨੋਰਥ ਪਾਰਬ੍ਰਹਮੁ ਗੁਰੁ ਪਾਇਆ ॥੪॥੪॥",
          "roman": "kah nānak mērē pūrē manorath pārbrahm gur pāiā ॥4॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਮੈਨੂੰ ਗੁਰੂ ਮਿਲ ਪਿਆ ਹੈ (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਮਿਲ ਪਿਆ ਹੈ, ਮੇਰੀਆਂ ਸਾਰੀਆਂ ਮਨੋ-ਕਾਮਨਾਂ ਪੂਰੀਆਂ ਹੋ ਗਈਆਂ ਹਨ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: я обрёл Гуру; по милости Гуру я обрёл Бога, и все мои желания исполнились ॥4॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4867,
      "rahao_verse_id": 56974,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56968,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56969,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮੁ ਕਿਲਬਿਖ ਸਭਿ ਨਾਸੇ ॥",
          "roman": "simrat nām kilbikh sabh nāse ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਸਾਰੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "При памятовании Имени Бога все грехи уничтожаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56970,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਨਾਮੁ ਗੁਰਿ ਦੀਨੀ ਰਾਸੇ ॥",
          "roman": "sach nām gur dīnī rāse ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੂੰ) ਗੁਰੂ ਨੇ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਦਾ ਸਰਮਾਇਆ ਬਖ਼ਸ਼ਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кому Гуру даровал богатство вечно-устойчивого Имени Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56971,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਦਰਗਹ ਸੋਭਾਵੰਤੇ ॥",
          "roman": "prabh kī dargah sobhāvante ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਦਰਗਾਹ ਵਿਚ ਉਹ ਇੱਜ਼ਤ ਵਾਲੇ ਬਣੇ।"
            },
            "sahib_singh_ru": {
              "main": "стали почтенными в Дворе Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56972,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਸੇਵਿ ਸਦਾ ਸੋਹੰਤੇ ॥੧॥",
          "roman": "sevak sev sadā sohante ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ (ਪਰਮਾਤਮਾ ਦੀ) ਭਗਤੀ ਕਰ ਕੇ ਸਦਾ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਸੋਹਣੇ ਲੱਗਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Слуги Бога, совершая служение Ему, всегда выглядят прекрасными и в этом мире, и в ином ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56973,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਹੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "har har nām japah mere bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਭਾਈ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Всегда повторяй Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56974,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲੇ ਰੋਗ ਦੋਖ ਸਭਿ ਬਿਨਸਹਿ ਅਗਿਆਨੁ ਅੰਧੇਰਾ ਮਨ ਤੇ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sagle rog dokh sabh binseh agiān andherā man te jāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨ ਦੇ) ਸਾਰੇ ਰੋਗ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਸਾਰੇ ਪਾਪ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ, ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਬੇ-ਸਮਝੀ ਦਾ ਹਨੇਰਾ ਮਨ ਤੋਂ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию все болезни ума уходят, все грехи уничтожаются, тьма непонимания духовной жизни удаляется из ума ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56975,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਨ ਗੁਰਿ ਰਾਖੇ ਮੀਤ ॥",
          "roman": "janam maran gur rākhe mīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਗੁਰੂ ਨੇ (ਉਹਨਾਂ ਦੇ) ਜਨਮ ਮਰਨ (ਦੇ ਗੇੜ) ਮੁਕਾ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! Гуру прекратил их круг рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56976,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "har ke nām siu lāgī prīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦਾ) ਪਿਆਰ ਬਣਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "у тех людей, у которых, придя под защиту Гуру, возникла любовь к Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56977,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਕੇ ਗਏ ਕਲੇਸ ॥",
          "roman": "koṭ janam ke gaye kales ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰਿ-ਨਾਮ ਨਾਲ ਪ੍ਰੀਤ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹਨਾਂ ਦੇ) ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਦੇ ਦੁੱਖ-ਕਲੇਸ਼ ਦੂਰ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря любви к Имени Хари ушли страдания и мучения их миллионов рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56978,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਭਲ ਹੋਸ ॥੨॥",
          "roman": "jo tis bhāvē so bhal hos ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਨੂੰ) ਉਹ ਕੁਝ ਭਲਾ ਜਾਪਦਾ ਹੈ ਜੋ ਪਰਮਾਤਮਾ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Им кажется благим то, что нравится Богу ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56979,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਗੁਰ ਕਉ ਹਉ ਸਦ ਬਲਿ ਜਾਈ ॥",
          "roman": "tis gur kau hau sad bal jāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я всегда приношу себя в жертву тому Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56980,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਹਰਿ ਨਾਮੁ ਧਿਆਈ ॥",
          "roman": "jis prasād har nām dhiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "по чьей милости я продолжаю памятовать Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56981,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਗੁਰੁ ਪਾਈਐ ਵਡਭਾਗੀ ॥",
          "roman": "aisā gur pāīai vaḍbhāgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੋ ਜਿਹਾ ਗੁਰੂ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਹੀ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такого Гуру можно обрести только по великой удаче,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56982,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਿਲਤੇ ਰਾਮ ਲਿਵ ਲਾਗੀ ॥੩॥",
          "roman": "jis milte rām liv lāgī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਿਲਿਆਂ ਪਰਮਾਤਮਾ ਨਾਲ ਪਿਆਰ ਬਣਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "при встрече с которым возникает любовь к Богу ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56983,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪਾਰਬ੍ਰਹਮ ਸੁਆਮੀ ॥",
          "roman": "kar kirpā pārbrahm suāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ! ਹੇ ਸੁਆਮੀ! (ਮੇਰੇ ਉਤੇ) ਮਿਹਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Парбрахм! О Владыка! Прояви ко мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56984,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "sagal ghaṭā ke antarjāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О Знающий сердца всех существ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56985,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਅਪੁਨੀ ਲਿਵ ਲਾਇ ॥",
          "roman": "āṭh pahar apunī liv lāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ ਅੰਦਰ) ਅੱਠੇ ਪਹਰ ਆਪਣੀ ਲਗਨ ਲਾਈ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "Все восемь страж дня и ночи поддерживай во мне устремлённость к Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56986,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਨਾਨਕੁ ਪ੍ਰਭ ਕੀ ਸਰਨਾਇ ॥੪॥੫॥",
          "roman": "jan nānak prabh kī sarnāi ॥4॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ) ਦਾਸ ਨਾਨਕ ਤੇਰੀ ਸਰਨ ਪਿਆ ਰਹੇ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "пусть Твой слуга Нанак остаётся в Твоём прибежище ॥4॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4868,
      "rahao_verse_id": 56993,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56987,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56988,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪੁਨੇ ਪ੍ਰਭਿ ਕੀਏ ॥",
          "roman": "kar kirpā apune prabh kīe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ) ਪ੍ਰਭੂ ਨੇ (ਉਹਨਾਂ ਨੂੰ) ਮਿਹਰ ਕਰ ਕੇ ਆਪਣੇ ਬਣਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тех людей, которые пришли под защиту Гуру, Господь по милости сделал Своими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56989,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਪਨ ਕਉ ਦੀਏ ॥",
          "roman": "har kā nām japan kau dīe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਗੁਰੂ ਨੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਵਾਸਤੇ ਉਹਨਾਂ ਨੂੰ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "потому что Гуру дал им Имя Бога для повторения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56990,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਗੁਨ ਗਾਇ ਗੁਬਿੰਦ ॥",
          "roman": "āṭh pahar gun gāi gubind ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਅੱਠੇ ਪਹਰ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Придя под защиту Гуру, все восемь страж дня и ночи пой добродетели Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56991,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਬਿਨਸੇ ਉਤਰੀ ਸਭ ਚਿੰਦ ॥੧॥",
          "roman": "bhē binse utrī sabh chind ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਸਾਰੇ ਡਰ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ, ਸਾਰੀ ਚਿੰਤਾ ਦੂਰ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так все страхи уничтожаются, вся тревога уходит ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56992,
          "is_rahao": true,
          "gurmukhi": "ਉਬਰੇ ਸਤਿਗੁਰ ਚਰਨੀ ਲਾਗਿ ॥",
          "roman": "ubre satigur charnī lāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦੀ ਚਰਨੀਂ ਲੱਗ ਕੇ (ਅਨੇਕਾਂ ਪ੍ਰਾਣੀ ਵਿਕਾਰਾਂ ਵਿਚ ਡੁੱਬਣੋਂ) ਬਚ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Припав к стопам Сатгуру, многие существа спасаются от утопания в пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56993,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਗੁਰੁ ਕਹੈ ਸੋਈ ਭਲ ਮੀਠਾ ਮਨ ਕੀ ਮਤਿ ਤਿਆਗਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo gur kahē soī bhal mīṭhā man kī mat tiāg ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੀ ਚਤੁਰਾਈ ਛੱਡ ਕੇ (ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ) ਜੋ ਕੁਝ ਗੁਰੂ ਦੱਸਦਾ ਹੈ, ਉਹ ਚੰਗਾ ਤੇ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Оставив хитроумие своего ума и придя под защиту Гуру, всё, что говорит Гуру, кажется благим и сладким ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56994,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਵਸਿਆ ਹਰਿ ਪ੍ਰਭੁ ਸੋਈ ॥",
          "roman": "man tan vasiā har prabh soī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ) ਮਨ ਵਿਚ ਤਨ ਵਿਚ ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਵੱਸਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Придя под защиту Гуру, в уме и теле пребывает только тот Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56995,
          "is_rahao": false,
          "gurmukhi": "ਕਲਿ ਕਲੇਸ ਕਿਛੁ ਬਿਘਨੁ ਨ ਹੋਈ ॥",
          "roman": "kal kales kichh bighan na hoī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ (ਆਦਿਕ ਜ਼ਿੰਦਗੀ ਦੇ ਰਸਤੇ ਵਿਚ) ਰੁਕਾਵਟ ਨਹੀਂ ਪੈਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "и никакие страдания, мучения и тому подобное не становятся препятствием на пути жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56996,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਪ੍ਰਭੁ ਜੀਅ ਕੈ ਸੰਗਿ ॥",
          "roman": "sadā sadā prabh jīa kē saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਹਰ ਵੇਲੇ ਹੀ ਜਿੰਦ ਦੇ ਨਾਲ (ਵੱਸਦਾ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда ощущается пребывающим вместе с жизнью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56997,
          "is_rahao": false,
          "gurmukhi": "ਉਤਰੀ ਮੈਲੁ ਨਾਮ ਕੈ ਰੰਗਿ ॥੨॥",
          "roman": "utrī mēl nām kē raṅg ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨਾਮ ਦੇ ਪਿਆਰ-ਰੰਗ ਵਿਚ ਟਿਕੇ ਰਿਹਾਂ (ਵਿਕਾਰਾਂ ਦੀ) ਸਾਰੀ ਮੈਲ (ਮਨ ਤੋਂ) ਲਹਿ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, оставаясь в цвете любви к Имени Бога, вся грязь пороков смывается с ума ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56998,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੋ ਪਿਆਰੁ ॥",
          "roman": "charan kamal siu lāgo piār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ) ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ ਪਿਆਰ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Придя под защиту Гуру, возникает любовь к прекрасным стопам Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56999,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੇ ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ ॥",
          "roman": "binse kām krodh ahaṅkār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ (ਆਦਿਕ ਵਿਕਾਰ ਅੰਦਰੋਂ) ਮੁੱਕ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "вожделение, гнев, гордыня и другие пороки исчезают изнутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57000,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਮਿਲਨ ਕਾ ਮਾਰਗੁ ਜਾਨਾਂ ॥",
          "roman": "prabh milan kā mārag jānāṅ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਪਰਮਾਤਮਾ ਦੇ ਮਿਲਾਪ ਦਾ ਰਸਤਾ ਸਮਝ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, придя под защиту Гуру, понял путь соединения с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57001,
          "is_rahao": false,
          "gurmukhi": "ਭਾਇ ਭਗਤਿ ਹਰਿ ਸਿਉ ਮਨੁ ਮਾਨਾਂ ॥੩॥",
          "roman": "bhāi bhagat har siu man mānāṅ ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰ ਦੀ ਬਰਕਤਿ ਨਾਲ ਭਗਤੀ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦਾ ਮਨ ਪ੍ਰਭੂ ਦੀ ਯਾਦ ਵਿਚ ਗਿੱਝ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "благодаря любви и благодаря преданности его ум привыкает пребывать в памятовании Господа ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57002,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸਜਣ ਸੰਤ ਮੀਤ ਸੁਹੇਲੇ ॥",
          "roman": "suṇ sajaṇ sant mīt suhele ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਜਣ! ਹੇ ਸੰਤ! ਹੇ ਮਿੱਤਰ! ਸੁਣ, ਉਹ ਸਦਾ ਸੁਖੀ ਜੀਵਨ ਵਾਲੇ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! О святой! О приятель! Слушай: они стали обладателями всегда счастливой жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57003,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਰਤਨੁ ਹਰਿ ਅਗਹ ਅਤੋਲੇ ॥",
          "roman": "nām ratan har agah atole ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਜਿਨ੍ਹਾਂ ਨੇ) ਅਪਹੁੰਚ ਅਤੇ ਅਤੋਲ ਹਰੀ ਦਾ ਕੀਮਤੀ ਨਾਮ ਹਾਸਲ ਕਰ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "те, кто, придя под защиту Гуру, обрели драгоценное Имя недостижимого и неизмеримого Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57004,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਪ੍ਰਭੁ ਗੁਣ ਨਿਧਿ ਗਾਈਐ ॥",
          "roman": "sadā sadā prabh guṇ nidh gāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਹੀ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Всегда следует воспевать хвалу Господа, сокровищницы добродетелей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57005,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਵਡਭਾਗੀ ਪਾਈਐ ॥੪॥੬॥",
          "roman": "kah nānak vaḍbhāgī pāīai ॥4॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਨਾਨਕ ਆਖਦਾ ਹੈ- ਇਹ ਦਾਤ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਮਿਲਦੀ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "но, говорит Нанак, этот дар обретается по великой удаче ॥4॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4869,
      "rahao_verse_id": 57010,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57006,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57007,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਧਨਵੰਤ ਸੇਈ ਸਚੁ ਸਾਹਾ ॥",
          "roman": "se dhanvant seī sach sāhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਯਕੀਨੀ ਤੌਰ ਤੇ ਸ਼ਾਹੂਕਾਰ (ਸਮਝੇ ਜਾਂਦੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "Именно те люди воистину считаются богатыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57008,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਦਰਗਹ ਨਾਮੁ ਵਿਸਾਹਾ ॥੧॥",
          "roman": "har kī dargah nām visāhā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਜਿਨ੍ਹਾਂ ਨੇ ਇਥੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਸੌਦਾ ਖ਼ਰੀਦਿਆ, ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਮਨੁੱਖ ਧਨਾਢ (ਗਿਣੇ ਜਾਂਦੇ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "которые, придя под защиту Гуру, здесь купили товар Имени Бога; в присутствии Бога такие люди считаются состоятельными ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57009,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਹੁ ਮਨ ਮੀਤ ॥",
          "roman": "har har nām japah man mīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਹੇ ਮਨ! (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О друг! О ум! Придя под защиту Гуру, всегда повторяй Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57010,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪਾਈਐ ਵਡਭਾਗੀ ਨਿਰਮਲ ਪੂਰਨ ਰੀਤਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrā pāīai vaḍbhāgī nirmal pūran rīt ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਨਾਮ ਜਪਣ ਵਾਲੀ) ਪਵਿੱਤਰ ਤੇ ਮੁਕੰਮਲ ਮਰਯਾਦਾ (ਚਲਾਣ ਵਾਲਾ) ਪੂਰਾ ਗੁਰੂ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ (ਹੀ) ਮਿਲਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Полный Гуру, устанавливающий чистую и совершенную марьаду повторения Имени, обретается только по великой удаче ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57011,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇਆ ਲਾਭੁ ਵਜੀ ਵਾਧਾਈ ॥",
          "roman": "pāiā lābh vajī vādhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹੀ ਮਨੁੱਖ ਇਥੇ ਅਸਲ) ਨਫ਼ਾ ਖੱਟਦਾ ਹੈ, (ਉਸ ਦੇ ਅੰਦਰ) ਆਤਮਕ ਉਤਸ਼ਾਹ ਵਾਲੀ ਅਵਸਥਾ ਪ੍ਰਬਲ ਬਣੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек получает здесь истинную прибыль, и в нём остаётся сильным состояние духовного воодушевления,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57012,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਹਰਿ ਕੇ ਗੁਨ ਗਾਈ ॥੨॥",
          "roman": "sant prasād har ke gun gāī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "кто по милости Гуру поёт добродетели Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57013,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਜਨਮੁ ਜੀਵਨ ਪਰਵਾਣੁ ॥",
          "roman": "safal janam jīvan parvāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਜਪਣ ਵਾਲੇ ਦਾ) ਮਨੁੱਖਾ ਜਨਮ ਕਾਮਯਾਬ ਹੈ, ਜੀਵਨ (ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਕਬੂਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человеческое рождение повторяющего Имя успешно, его жизнь принята в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57014,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਰਿ ਰੰਗੁ ਮਾਣੁ ॥੩॥",
          "roman": "gur parsādī har raṅg māṇ ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਨੰਦ ਮਾਣਦਾ ਰਹੁ  ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому по милости Гуру продолжай наслаждаться любовной радостью Имени Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57015,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੇ ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ ॥",
          "roman": "binse kām krodh ahaṅkār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਜਪਣ ਵਾਲਿਆਂ ਦੇ ਅੰਦਰੋਂ) ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ (ਆਦਿਕ ਵਿਕਾਰ) ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "У тех, кто повторяет Имя, изнутри уничтожаются вожделение, гнев, гордыня и другие пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57016,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਉਤਰਹਿ ਪਾਰਿ ॥੪॥੭॥",
          "roman": "nānak gurmukh utareh pār ॥4॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਨਾਮ ਜਪਣ ਵਾਲੇ ਮਨੁੱਖ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Придя под защиту Гуру, люди, повторяющие Имя, переправляются через мирской океан ॥4॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
