        {
          "verse_id": 57018,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪੂਰੀ ਤਾ ਕੀ ਕਲਾ ॥",
          "roman": "gur pūrā pūrī tā kī kalā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ (ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ) ਪੂਰਨ ਹੈ, ਗੁਰੂ ਦੀ (ਆਤਮਕ) ਸ਼ਕਤੀ ਹਰੇਕ ਸਮਰਥਾ ਵਾਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру полон всеми добродетелями; духовная сила Гуру обладает всякой способностью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
