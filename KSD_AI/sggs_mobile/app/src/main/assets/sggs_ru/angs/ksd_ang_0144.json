{
  "ang": 144,
  "shabads": [
    {
      "shabad_id": 401,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5887,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਤੁਈ ਏਕ ਤੁਈ ॥੨॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ, ਹੇ ਪ੍ਰਭੂ!) ਇਕ ਤੂੰ ਹੀ ਹੈਂ, ਇਕ ਤੂੰ ਹੀ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты один, только Ты один пребываешь вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 402,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5888,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "Maḥ 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5889,
          "is_rahao": false,
          "gurmukhi": "ਨ ਦਾਦੇ ਦਿਹੰਦ ਆਦਮੀ ॥ ਨ ਸਪਤ ਜੇਰ ਜਿਮੀ ॥",
          "roman": "na dāde dihand ādmī, na sapt jer jimī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਹੀ ਇਨਸਾਫ਼ ਕਰਨ ਵਾਲੇ (ਭਾਵ, ਦੂਜਿਆਂ ਦੇ ਝਗੜੇ ਨਿਬੇੜਨ ਵਾਲੇ) ਆਦਮੀ ਸਦਾ ਟਿਕੇ ਰਹਿਣ ਵਾਲੇ ਹਨ, ਨਾਹ ਹੀ ਧਰਤੀ ਦੇ ਹੇਠਲੇ ਸੱਤ (ਪਤਾਲ ਹੀ) ਸਦਾ ਰਹਿ ਸਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Ни люди, вершившие правосудие, то есть разбиравшие чужие споры, не вечны, ни семь нижних миров под землёй не могут пребывать вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5890,
          "is_rahao": false,
          "gurmukhi": "ਅਸਤਿ ਏਕ ਦਿਗਰਿ ਕੁਈ ॥",
          "roman": "ast ek digar kuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਰਹਿਣ ਵਾਲਾ ਹੋਰ ਦੂਜਾ ਕੌਣ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Кто ещё другой остаётся навечно?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5891,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਤੁਈ ਏਕ ਤੁਈ ॥੩॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ) ਇਕ ਤੂੰ ਹੀ ਹੈ ਇਕ ਤੂੰ ਹੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты один, только Ты один пребываешь вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 403,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5892,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "Maḥ 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5893,
          "is_rahao": false,
          "gurmukhi": "ਨ ਸੂਰ ਸਸਿ ਮੰਡਲੋ ॥ ਨ ਸਪਤ ਦੀਪ ਨਹ ਜਲੋ ॥ ਅੰਨ ਪਉਣ ਥਿਰੁ ਨ ਕੁਈ ॥",
          "roman": "na sūr sas maṇḍalo, na sapt dīp nah jalo, ann paun thir na kuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾ ਸੂਰਜ, ਨਾਹ ਚੰਦਰਮਾ, ਨਾਹ ਇਹ ਦਿੱਸਦਾ ਆਕਾਸ਼, ਨਾਹ ਧਰਤੀ ਦੇ ਸੱਤ ਦੀਪ, ਨਾਹ ਪਾਣੀ, ਨ ਅੰਨ, ਨਾਹ ਹਵਾ-ਕੋਈ ਭੀ ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ни солнце, ни луна, ни это видимое небо, ни семь островов земли, ни вода, ни пища, ни воздух — ничто не остаётся постоянным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5894,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਤੁਈ ਏਕੁ ਤੁਈ ॥੪॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਦਾ ਰਹਿਣ ਵਾਲਾ, ਹੇ ਪ੍ਰਭੂ!) ਇਕ ਤੂੰ ਹੀ ਹੈਂ, ਇਕ ਤੂੰ ਹੀ ਹੈਂ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты один, только Ты один пребываешь вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 404,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5895,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "Maḥ 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5896,
          "is_rahao": false,
          "gurmukhi": "ਨ ਰਿਜਕੁ ਦਸਤ ਆ ਕਸੇ ॥",
          "roman": "na rijak dast ā kase",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦਾ) ਰਿਜ਼ਕ (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ) ਕਿਸੇ ਹੋਰ ਦੇ ਹੱਥ ਵਿਚ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пропитание существ не находится в чьих-либо руках, кроме Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5897,
          "is_rahao": false,
          "gurmukhi": "ਹਮਾ ਰਾ ਏਕੁ ਆਸ ਵਸੇ ॥",
          "roman": "hamā rā ek ās vase",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਨੂੰ, ਬੱਸ, ਇਕ ਪ੍ਰਭੂ ਦੀ ਆਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У всех существ есть лишь надежда на одного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5898,
          "is_rahao": false,
          "gurmukhi": "ਅਸਤਿ ਏਕੁ ਦਿਗਰ ਕੁਈ ॥",
          "roman": "ast ek digar kuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਸਦਾ-ਥਿਰ) ਹੋਰ ਹੈ ਹੀ ਕੋਈ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что другого вечно пребывающего вообще нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5899,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਤੁਈ ਏਕੁ ਤੁਈ ॥੫॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਰਹਿਣ ਵਾਲਾ, ਹੇ ਪ੍ਰਭੂ! ਇਕ ਤੂੰ ਹੀ ਹੈਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты один пребываешь вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 405,
      "rahao_verse_id": null,
