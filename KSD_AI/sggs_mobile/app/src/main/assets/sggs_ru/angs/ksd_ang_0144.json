      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5900,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "Maḥ 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5901,
          "is_rahao": false,
          "gurmukhi": "ਪਰੰਦਏ ਨ ਗਿਰਾਹ ਜਰ ॥",
          "roman": "parandae na girāh jar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੰਛੀਆਂ ਦੇ ਗੰਢੇ-ਪੱਲੇ ਧਨ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У птиц нет привязанного к узлу богатства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5902,
          "is_rahao": false,
          "gurmukhi": "ਦਰਖਤ ਆਬ ਆਸ ਕਰ ॥",
          "roman": "drakhat āb ās kar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਪ੍ਰਭੂ ਦੇ ਬਣਾਏ ਹੋਏ) ਰੁੱਖਾਂ ਤੇ ਪਾਣੀ ਦਾ ਆਸਰਾ ਹੀ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они полагаются лишь на деревья и воду, созданные Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5903,
          "is_rahao": false,
          "gurmukhi": "ਦਿਹੰਦ ਸੁਈ ॥",
          "roman": "dihand suī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਰੋਜ਼ੀ ਦੇਣ ਵਾਲਾ ਉਹੀ ਪ੍ਰਭੂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Дающий им пропитание — только Он, Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5904,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਤੁਈ ਏਕ ਤੁਈ ॥੬॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਇਹਨਾਂ ਦਾ ਰਿਜ਼ਕ-ਦਾਤਾ) ਇਕ ਤੂੰ ਹੀ ਹੈਂ ਇਕ ਤੂੰ ਹੀ ਹੈਂ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, их Даритель пропитания — только Ты один, только Ты один."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 406,
