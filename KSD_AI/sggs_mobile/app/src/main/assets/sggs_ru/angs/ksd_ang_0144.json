      "lines": [
        {
          "verse_id": 5910,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5911,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਤੇਰਾ ਹੁਕਮੁ ਗੁਰਮੁਖਿ ਜਾਣਿਆ ॥",
          "roman": "sachā terā hukam gurmukh jāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰਾ ਹੁਕਮ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋਇਆਂ ਇਸ ਦੀ ਸਮਝ ਪੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твой хукам вечен, и только став обращённым к Гуру, человек понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5912,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤੀ ਆਪੁ ਗਵਾਇ ਸਚੁ ਪਛਾਣਿਆ ॥",
          "roman": "gurmatī āp gavāe sach pachhāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਗੁਰੂ ਦੀ ਮਤਿ ਲੈ ਕੇ ਆਪਾ-ਭਾਵ ਦੂਰ ਕੀਤਾ ਹੈ, ਉਸ ਨੇ ਤੈਨੂੰ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто, приняв наставление Гуру, устранил своё эго, тот познал Тебя как вечно пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5913,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਤੇਰਾ ਦਰਬਾਰੁ ਸਬਦੁ ਨੀਸਾਣਿਆ ॥",
          "roman": "sach terā darbār sabad nīsāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਦਰਬਾਰ ਸਦਾ-ਥਿਰ ਹੈ, (ਇਸ ਤਕ ਅੱਪੜਨ ਲਈ ਗੁਰੂ ਦਾ) ਸ਼ਬਦ ਰਾਹਦਾਰੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твой двор вечен, а Слово Гуру — путь, ведущий к нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5914,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਸਬਦੁ ਵੀਚਾਰਿ ਸਚਿ ਸਮਾਣਿਆ ॥",
          "roman": "sachā sabad vīchār sach samāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੇ ਸੱਚੇ ਸ਼ਬਦ ਨੂੰ ਵਿਚਾਰਿਆ ਹੈ, ਉਹ ਸੱਚ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кто размышлял над истинным Словом, сливаются с Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5915,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਸਦਾ ਕੂੜਿਆਰ ਭਰਮਿ ਭੁਲਾਣਿਆ ॥",
          "roman": "manmukh sadā kūṛiār bharam bhulāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਕੂੜ (ਹੀ) ਵਿਹਾਝਦੇ ਹਨ, ਭਟਕਣਾ ਵਿਚ ਖੁੰਝੇ ਫਿਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "А идущие вслед за своим умом всегда торгуют ложью и, сбившись, блуждают в заблуждении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5916,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਟਾ ਅੰਦਰਿ ਵਾਸੁ ਸਾਦੁ ਨ ਜਾਣਿਆ ॥",
          "roman": "visṭā andar vās sād na jāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦਾ ਵਸੇਬਾ ਗੰਦ ਵਿਚ ਹੀ ਰਹਿੰਦਾ ਹੈ, (ਸ਼ਬਦ ਦਾ) ਆਨੰਦ ਉਹ ਨਹੀਂ ਸਮਝ ਸਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "Их обитание остаётся в нечистоте, и они не смогли познать вкус блаженства Слова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5917,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਨਾਵੈ ਦੁਖੁ ਪਾਇ ਆਵਣ ਜਾਣਿਆ ॥",
          "roman": "viṇ nāvē dukh pāe āvaṇ jāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਦੁੱਖ ਪਾ ਕੇ ਜਨਮ ਮਰਨ (ਦੇ ਚੱਕਰ ਵਿਚ ਪਏ ਰਹਿੰਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога они терпят страдание и остаются в круге рождений и смертей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5918,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਰਖੁ ਆਪਿ ਜਿਨਿ ਖੋਟਾ ਖਰਾ ਪਛਾਣਿਆ ॥੧੩॥",
          "roman": "Nānak pārakh āp jin khoṭā kharā pachhāṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਖਣ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪ ਹੀ ਹੈ, ਜਿਸ ਨੇ ਖੋਟੇ ਖਰੇ ਨੂੰ ਪਛਾਣਿਆ ਹੈ (ਭਾਵ, ਪ੍ਰਭੂ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ ਕਿ ਖੋਟਾ ਕੌਣ ਹੈ ਤੇ ਖਰਾ ਕੌਣ ਹੈ) ॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, испытывающий — Сам Бог: Он и распознаёт, кто фальшив, а кто подлинен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 408,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5919,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mah 1 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5920,
          "is_rahao": false,
          "gurmukhi": "ਸੀਹਾ ਬਾਜਾ ਚਰਗਾ ਕੁਹੀਆ ਏਨਾ ਖਵਾਲੇ ਘਾਹ ॥",
          "roman": "sīhā bājā chargā kuhīā enā khavāle ghāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਸ਼ੇਰਾਂ, ਬਾਜਾਂ, ਚਰਗਾਂ, ਕੁਹੀਆ (ਆਦਿਕ ਮਾਸਾਹਾਰੀਆਂ ਨੂੰ ਜੇ ਚਾਹੇ ਤਾਂ) ਘਾਹ ਖਵਾ ਦੇਂਦਾ ਹੈ (ਭਾਵ, ਉਹਨਾਂ ਦੀ ਮਾਸ ਖਾਣ ਦੀ ਵਾਦੀ ਤਬਦੀਲ ਕਰ ਦੇਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Господь львам, соколам, чаргам, кухиям и прочим мясоедам, если пожелает, даёт есть траву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5921,
          "is_rahao": false,
          "gurmukhi": "ਘਾਹੁ ਖਾਨਿ ਤਿਨਾ ਮਾਸੁ ਖਵਾਲੇ ਏਹਿ ਚਲਾਏ ਰਾਹ ॥",
          "roman": "ghāh khān tinā mās khavāle eh chalāe rāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਘਾਹ ਖਾਂਦੇ ਹਨ ਉਹਨਾਂ ਨੂੰ ਮਾਸ ਖਵਾ ਦੇਂਦਾ ਹੈ-ਸੋ, ਪ੍ਰਭੂ ਇਹੋ ਜਿਹੇ ਰਾਹ ਤੋਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тем, кто ест траву, Он даёт есть мясо; так Господь направляет по таким путям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5922,
          "is_rahao": false,
          "gurmukhi": "ਨਦੀਆ ਵਿਚਿ ਟਿਬੇ ਦੇਖਾਲੇ ਥਲੀ ਕਰੇ ਅਸਗਾਹ ॥",
          "roman": "nadīā vich ṭibe dekhāle thalī kare asgāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ (ਵਗਦੀਆਂ) ਨਦੀਆਂ ਵਿਚ ਟਿੱਬੇ ਵਿਖਾਲ ਦੇਂਦਾ ਹੈ, ਰੇਤਲੇ ਥਾਵਾਂ ਨੂੰ ਡੂੰਘੇ ਪਾਣੀ ਬਣਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь показывает холмы посреди рек, а песчаные места делает глубокими водами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5923,
          "is_rahao": false,
          "gurmukhi": "ਕੀੜਾ ਥਾਪਿ ਦੇਇ ਪਾਤਿਸਾਹੀ ਲਸਕਰ ਕਰੇ ਸੁਆਹ ॥",
          "roman": "kīṛā thāp dei pātisāhī laskar kare suāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੀੜੇ ਨੂੰ ਬਾਦਸ਼ਾਹੀ (ਤਖ਼ਤ) ਉੱਤੇ ਥਾਪ ਦੇਂਦਾ ਹੈ (ਬਿਠਾ ਦੇਂਦਾ ਹੈ), (ਤੇ ਬਾਦਸ਼ਾਹਾਂ ਦੇ) ਲਸ਼ਕਰਾਂ ਨੂੰ ਸੁਆਹ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Червя Он возводит на царский трон, а войска царей обращает в пепел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5924,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਜੀਅ ਜੀਵਹਿ ਲੈ ਸਾਹਾ ਜੀਵਾਲੇ ਤਾ ਕਿ ਅਸਾਹ ॥",
          "roman": "jete jīa jīvah lē sāhā jīvāle tā k asāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨੇ ਭੀ ਜੀਵ (ਜਗਤ ਵਿਚ) ਜੀਊਂਦੇ ਹਨ, ਸਾਹ ਲੈ ਕੇ ਜੀਊਂਦੇ ਹਨ, (ਭਾਵ, ਤਦ ਤਕ ਜੀਊਂਦੇ ਹਨ ਜਦ ਤਕ ਸਾਹ ਲੈਂਦੇ ਹਨ, (ਪਰ ਜੇ ਪ੍ਰਭੂ) ਜੀਊਂਦੇ ਰੱਖਣੇ ਚਾਹੇ, ਤਾਂ 'ਸਾਹ' ਦੀ ਭੀ ਕੀਹ ਮੁਥਾਜੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Сколько ни живёт существ в мире, все живут, дыша; но если Господь захочет сохранить живым, то какая уж тут зависимость даже от самого дыхания?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5925,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਉ ਜਿਉ ਸਚੇ ਭਾਵੈ ਤਿਉ ਤਿਉ ਦੇਇ ਗਿਰਾਹ ॥੧॥",
          "roman": "nānak jiu jiu sache bhāvē tiu tiu dei girāh ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਵੇਂ ਜਿਵੇਂ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਹੈ, ਤਿਵੇਂ ਤਿਵੇਂ (ਜੀਵਾਂ) ਨੂੰ ਰੋਜ਼ੀ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Какова воля Господа, так Он и даёт существам пропитание. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 409,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5926,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mah 1 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5927,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਮਾਸਹਾਰੀ ਇਕਿ ਤ੍ਰਿਣੁ ਖਾਹਿ ॥",
          "roman": "ik māsahārī ik triṇ khāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜੀਵ ਮਾਸ ਖਾਣ ਵਾਲੇ ਹਨ, ਕਈ ਘਾਹ ਖਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Одни существа едят мясо, другие едят траву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5928,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨਾ ਛਤੀਹ ਅੰਮ੍ਰਿਤ ਪਾਹਿ ॥",
          "roman": "iknā chhatīh aṃmrit pāhi ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਪ੍ਰਣੀਆਂ ਨੂੰ ਕਈ ਕਿਸਮਾਂ ਦੇ ਸੁਆਦਲੇ ਭੋਜਨ ਮਿਲਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Некоторым существам достаются разнообразные вкусные яства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5929,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਮਿਟੀਆ ਮਹਿ ਮਿਟੀਆ ਖਾਹਿ ॥",
          "roman": "ik miṭīā mah miṭīā khāh ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਕਈ ਮਿੱਟੀ ਵਿਚ (ਰਹਿ ਕੇ) ਮਿੱਟੀ ਖਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "а другие, живя в земле, едят землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5930,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਪਉਣ ਸੁਮਾਰੀ ਪਉਣ ਸੁਮਾਰਿ ॥",
          "roman": "ik pauṇ sumārī pauṇ sumār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਪ੍ਰਾਣਾਯਾਮ ਦੇ ਅੱਭਿਆਸੀ ਪ੍ਰਾਣਾਯਾਮ ਵਿਚ ਲੱਗੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Некоторые упражняющиеся в пранаяме всё время заняты пранаямой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5931,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਨਿਰੰਕਾਰੀ ਨਾਮ ਆਧਾਰਿ ॥",
          "roman": "ik niraṅkārī nām ādhār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਨਿਰੰਕਾਰ ਦੇ ਉਪਾਸ਼ਕ (ਉਸ ਦੇ) ਨਾਮ ਦੇ ਆਸਰੇ ਜੀਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "некоторые почитатели Нираṅкара живут, опираясь на Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5932,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵੈ ਦਾਤਾ ਮਰੈ ਨ ਕੋਇ ॥",
          "roman": "jīvē dātā marē na koi ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ (ਇਹ ਮੰਨਦਾ ਹੈ ਕਿ) ਸਿਰ ਤੇ ਦਾਤਾ ਰਾਖਾ ਹੈ ਉਹ (ਪ੍ਰਭੂ ਨੂੰ ਵਿਸਾਰ ਕੇ ਆਤਮਕ ਮੌਤ) ਨਹੀਂ ਮਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, который верит, что над ним есть Дающий-Защитник, не умирает духовной смертью, забыв Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5933,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮੁਠੇ ਜਾਹਿ ਨਾਹੀ ਮਨਿ ਸੋਇ ॥੨॥",
          "roman": "nānak muṭhe jāhi nāhī man soi ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਜੀਵ ਠੱਗੇ ਜਾਂਦੇ ਹਨ, ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ ਉਹ ਪ੍ਰਭੂ ਨਹੀਂ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Обманутыми уходят те существа, в чьём уме нет этого Господа. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 410,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5934,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5935,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕੀ ਕਾਰ ਕਰਮਿ ਕਮਾਈਐ ॥",
          "roman": "pūre gur kī kār karam kamāīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਸਤਿਗੁਰੂ ਦੀ ਦੱਸੀ ਹੋਈ ਕਾਰ (ਪ੍ਰਭੂ ਦੀ) ਮਿਹਰ ਨਾਲ ਹੀ ਕੀਤੀ ਜਾ ਸਕਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Дело, указанное совершенным Сатгуру, можно исполнять только по милости Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5936,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤੀ ਆਪੁ ਗਵਾਇ ਨਾਮੁ ਧਿਆਈਐ ॥",
          "roman": "gurmatī āp gavāi nām dhiāīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮਤਿ ਨਾਲ ਆਪਾ-ਭਾਵ ਗਵਾ ਕੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по наставлению Гуру, избавившись от самости, можно созерцать Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5937,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੀ ਕਾਰੈ ਲਗਿ ਜਨਮੁ ਗਵਾਈਐ ॥",
          "roman": "dūjī kārē lag janam gavāīē ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਬੰਦਗੀ ਵਿਸਾਰ ਕੇ) ਹੋਰ ਕੰਮ ਵਿਚ ਰੁੱਝਿਆਂ ਮਨੁੱਖਾ-ਜਨਮ ਵਿਅਰਥ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если, забыв о бхагти Господу, увязнуть в других делах, человеческая жизнь проходит напрасно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5938,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਨਾਵੈ ਸਭ ਵਿਸੁ ਪੈਝੈ ਖਾਈਐ ॥",
          "roman": "viṇ nāvē sabh vis pējhē khāīē ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਨਾਮ ਨੂੰ ਵਿਸਾਰ ਕੇ ਜੋ ਕੁਝ ਪਹਿਨੀ ਖਾਈਦਾ ਹੈ, ਉਹ (ਆਤਮਕ ਜੀਵਨ ਵਾਸਤੇ) ਜ਼ਹਿਰ (ਸਮਾਨ) ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что без Имени всё, что носят и едят, становится ядом для духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5939,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਸਬਦੁ ਸਾਲਾਹਿ ਸਚਿ ਸਮਾਈਐ ॥",
          "roman": "sachā sabad sālāh sach samāīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦਾ ਸੱਚਾ ਸ਼ਬਦ ਗਾਵਿਆਂ ਸੱਚੇ ਪ੍ਰਭੂ ਵਿਚ ਜੁੜੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Воспевая истинное Слово Сатгуру, соединяются с Истинным Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5940,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਸਤਿਗੁਰੁ ਸੇਵੇ ਨਾਹੀ ਸੁਖਿ ਨਿਵਾਸੁ ਫਿਰਿ ਫਿਰਿ ਆਈਐ ॥",
          "roman": "viṇ satigur seve nāhī sukh nivās phir phir āīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਦੱਸੀ ਕਾਰ ਕਰਨ ਤੋਂ ਬਿਨਾ ਸੁਖ ਵਿਚ (ਮਨ ਦਾ) ਟਿਕਾਉ ਨਹੀਂ ਹੋ ਸਕਦਾ, ਮੁੜ ਮੁੜ ਜਨਮ (ਮਰਨ) ਵਿਚ ਆਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Без следования делу, указанному Сатгуру, нет устойчивости ума в покое; снова и снова приходится приходить в рождение и смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5941,
          "is_rahao": false,
          "gurmukhi": "ਦੁਨੀਆ ਖੋਟੀ ਰਾਸਿ ਕੂੜੁ ਕਮਾਈਐ ॥",
          "roman": "dunīā khoṭī rās kūṛ kamāīai ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ (ਦਾ ਪਿਆਰ) ਖੋਟੀ ਪੂੰਜੀ ਹੈ, ਇਹ ਕਮਾਈ ਕੂੜ (ਦਾ ਵਪਾਰ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Мирская любовь — фальшивый капитал, такой заработок есть ложная торговля."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5942,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਚੁ ਖਰਾ ਸਾਲਾਹਿ ਪਤਿ ਸਿਉ ਜਾਈਐ ॥੧੪॥",
          "roman": "nānak sach kharā sālāh pat siu jāīai ||14||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਨਿਰੋਲ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰ ਕੇ (ਏਥੋਂ) ਇੱਜ਼ਤ ਨਾਲ ਜਾਈਦਾ ਹੈ ॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Воспевая совершенно истинного, вечно пребывающего Господа, отсюда уходят с честью. ||14||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 411,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 5943,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mah 1 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5944,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਤਾ ਵਾਵਹਿ ਗਾਵਹਿ ਤੁਧੁ ਭਾਵੈ ਜਲਿ ਨਾਵਹਿ ॥",
          "roman": "tudh bhāvē tā vāvah gāvah tudh bhāvē jal nāvah ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੇਰੀ ਰਜ਼ਾ ਹੁੰਦੀ ਹੈ (ਭਾਵ, ਇਹ ਤੇਰੀ ਰਜ਼ਾ ਹੈ ਕਿ ਕਈ ਜੀਵ ਸਾਜ਼) ਵਜਾਂਦੇ ਹਨ ਤੇ ਗਾਉਂਦੇ ਹਨ, (ਤੀਰਥਾਂ ਦੇ) ਜਲ ਵਿਚ ਇਸ਼ਨਾਨ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда такова Твоя воля, существа играют на инструментах и поют, омываются в водах мест паломничества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
