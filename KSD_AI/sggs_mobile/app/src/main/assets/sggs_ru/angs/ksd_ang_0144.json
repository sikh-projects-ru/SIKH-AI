          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "Maḥ 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5906,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਲਿਲਾਰਿ ਲਿਖਿਆ ਸੋਇ ॥",
          "roman": "Nānak lilār likhiā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੀਵ ਦੇ) ਮੱਥੇ ਉਤੇ (ਜੋ ਕੁਝ ਕਰਤਾਰ ਵਲੋਂ) ਲਿਖਿਆ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, что записано на челе существа Творцом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5907,
          "is_rahao": false,
          "gurmukhi": "ਮੇਟਿ ਨ ਸਾਕੈ ਕੋਇ ॥",
          "roman": "meṭ na sākē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕੋਈ ਮਿਟਾ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "того никто не может стереть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5908,
          "is_rahao": false,
          "gurmukhi": "ਕਲਾ ਧਰੈ ਹਿਰੈ ਸੁਈ ॥",
          "roman": "kalā dharē hirē suī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਦੇ ਅੰਦਰ) ਉਹੀ ਸੱਤਿਆ ਪਾਂਦਾ ਹੈ, ਉਹੀ ਖੋਹ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Именно Он вкладывает силу внутрь существа и Он же отнимает её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 5909,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਤੁਈ ਏਕੁ ਤੁਈ ॥੭॥",
          "roman": "ek tuī ek tuī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜੀਵਾਂ ਨੂੰ ਸੱਤਿਆ ਦੇਣ ਤੇ ਖੋਹ ਲੈਣ ਵਾਲਾ) ਇਕ ਤੂੰ ਹੀ ਹੈਂ ਇਕ ਤੂੰ ਹੀ ਹੈਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты один даёшь существам силу и только Ты один отнимаешь её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
