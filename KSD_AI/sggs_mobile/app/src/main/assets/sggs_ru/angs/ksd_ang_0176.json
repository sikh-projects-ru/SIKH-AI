{
  "ang": 176,
  "shabads": [
    {
      "shabad_id": 521,
      "rahao_verse_id": 7288,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7278,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤੀ ਘੋੜੇ ਦੇਖਿ ਵਿਗਾਸਾ ॥",
          "roman": "Hastī ghoṛē dēkh vigāsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਹਾਥੀ ਘੋੜੇ ਵੇਖ ਕੇ ਖ਼ੁਸ਼ੀ (ਮਹਿਸੂਸ ਕਰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Человек радуется, видя слонов и коней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7279,
          "is_rahao": false,
          "gurmukhi": "ਲਸਕਰ ਜੋੜੇ ਨੇਬ ਖਵਾਸਾ ॥",
          "roman": "Laskar joṛē nēb khavāsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫ਼ੌਜਾਂ ਇਕੱਠੀਆਂ ਕਰਦਾ ਹੈ, ਮੰਤਰੀ ਤੇ ਸ਼ਾਹੀ ਨੌਕਰ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "собирает войска, держит министров и царских слуг,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7280,
          "is_rahao": false,
          "gurmukhi": "ਗਲਿ ਜੇਵੜੀ ਹਉਮੈ ਕੇ ਫਾਸਾ ॥੨॥",
          "roman": "Gal jēvṛī haumē kē phāsā.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦੇ ਗਲ ਵਿਚ ਹਉਮੈ ਦੀ ਰੱਸੀ ਹਉਮੈ ਦੇ ਫਾਹੇ ਹੀ ਪੈਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но на его шее затягиваются верёвка и петли Хоумэ. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7281,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜੁ ਕਮਾਵੈ ਦਹ ਦਿਸ ਸਾਰੀ ॥",
          "roman": "Rāj kamāvē dah dis sārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰਾਜਾ ਬਣ ਕੇ ਮਨੁੱਖ) ਦਸੀਂ ਪਾਸੀਂ ਸਾਰੀ ਧਰਤੀ ਦਾ ਰਾਜ ਕਮਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Став царём, человек правит всей землёй во всех десяти направлениях,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7282,
          "is_rahao": false,
          "gurmukhi": "ਮਾਣੈ ਰੰਗ ਭੋਗ ਬਹੁ ਨਾਰੀ ॥",
          "roman": "Māṇē rang bhog bah nārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੌਜਾਂ ਮਾਣਦਾ ਹੈ, ਇਸਤ੍ਰੀਆਂ ਭੋਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "наслаждается удовольствиями, предаётся женщинам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7283,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਨਰਪਤਿ ਸੁਪਨੈ ਭੇਖਾਰੀ ॥੩॥",
          "roman": "Jiũ narpat supnē bhēkhārī.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਸਭ ਕੁਝ ਇਉਂ ਹੀ ਹੈ) ਜਿਵੇਂ ਕੋਈ ਰਾਜਾ ਮੰਗਤਾ ਬਣ ਜਾਂਦਾ ਹੈ (ਤੇ ਦੁਖੀ ਹੁੰਦਾ ਹੈ, ਆਤਮਕ ਸੁਖ ਦੇ ਥਾਂ ਰਾਜ ਵਿਚ ਤੇ ਭੋਗਾਂ ਵਿਚ ਭੀ ਦੁੱਖ ਹੀ ਦੁੱਖ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но всё это — как если бы царь стал нищим во сне: вместо духовного счастья и в царстве, и в наслаждениях есть лишь страдание. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7284,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਕੁਸਲੁ ਮੋ ਕਉ ਸਤਿਗੁਰੂ ਬਤਾਇਆ ॥",
          "roman": "Ēk kusal mo kau satigur batāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਨੇ ਮੈਨੂੰ ਅਸਲ ਆਤਮਕ ਸੁਖ (ਦਾ ਮੂਲ) ਦੱਸਿਆ ਹੈ (ਉਹ ਹੈ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਵਿਚ ਰਾਜ਼ੀ ਰਹਿਣਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру открыл мне источник истинного духовного счастья: это — быть довольным волей Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7285,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੋ ਕਿਛੁ ਕਰੇ ਸੁ ਹਰਿ ਕਿਆ ਭਗਤਾ ਭਾਇਆ ॥",
          "roman": "Har jo kichh karē su har kiā bhagtā bhāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ ਉਸ ਦੇ ਭਗਤਾਂ ਨੂੰ ਉਹ ਮਿੱਠਾ ਲੱਗਦਾ ਹੈ (ਤੇ ਉਹ ਇਸ ਤਰ੍ਹਾਂ ਆਤਮਕ ਸੁਖ ਮਾਣਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что делает Параматма, Его бхагатам кажется сладостным, и так они вкушают духовное счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7286,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਹਉਮੈ ਮਾਰਿ ਸਮਾਇਆ ॥੪॥",
          "roman": "Jan Nānak haumē mār samāiā.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! ਹਉਮੈ ਮਾਰ ਕੇ (ਵਡ-ਭਾਗੀ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਵਿਚ ਹੀ) ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О слуга Нанак! Убив Хоумэ, удачливый человек остаётся слитым с Параматмой. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7287,
          "is_rahao": true,
          "gurmukhi": "ਇਨਿ ਬਿਧਿ ਕੁਸਲ ਹੋਤ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "In bidh kusal hot mērē bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਇਸ ਤਰੀਕੇ ਨਾਲ (ਭਾਵ, ਰਜ਼ਾ ਵਿਚ ਰਾਜ਼ੀ ਰਹਿਣ ਨਾਲ) ਆਤਮਕ ਆਨੰਦ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Именно так возникает духовное блаженство — через согласие с Божественной волей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7288,
          "is_rahao": true,
          "gurmukhi": "ਇਉ ਪਾਈਐ ਹਰਿ ਰਾਮ ਸਹਾਈ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥",
          "roman": "Iu pāīai har rām sahāī.1. Rahāu dūjā.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ (ਹੀ) ਅਸਲ ਮਿੱਤਰ ਹਰੀ-ਪਰਮਾਤਮਾ ਮਿਲਦਾ ਹੈ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Именно так и встречается Хари-Параматма, истинный Друг. ॥1॥ Рахау дӯджā॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 522,
      "rahao_verse_id": 7294,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7289,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7290,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਭ੍ਰਮੀਐ ਭ੍ਰਮੁ ਕਿਸ ਕਾ ਹੋਈ ॥",
          "roman": "kiu bharmīai bhram kis kā hoī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਮਨ ਭਟਕਣੋਂ ਹਟ ਜਾਂਦਾ ਹੈ ਕਿਉਂਕਿ ਕਿਸੇ ਮਾਇਕ ਪਦਾਰਥ ਦੀ ਖ਼ਾਤਰ ਭਟਕਣਾ ਰਹਿੰਦੀ ਹੀ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда ум перестаёт блуждать, потому что уже не остаётся блуждания ради каких-либо майических вещей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7291,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਰਵਿਆ ਸੋਈ ॥",
          "roman": "jā jal thal mahīal raviā soī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਇਹ ਯਕੀਨ ਬਣ ਜਾਏ ਕਿ) ਉਹ ਪ੍ਰਭੂ ਹੀ ਜਲ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "когда становится твёрдой уверенность, что именно этот Бог пронизывает и воду, и землю, и небо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7292,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਉਬਰੇ ਮਨਮੁਖ ਪਤਿ ਖੋਈ ॥੧॥",
          "roman": "gurmukh ubre manmukh pat khoī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਤ੍ਰਿਸ਼ਨਾ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ) ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲੇ ਮਨੁੱਖ (ਹੀ) ਬਚਦੇ ਹਨ, ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮਨੁੱਖ (ਤ੍ਰਿਸ਼ਨਾ ਵਿਚ ਫਸ ਕੇ ਆਪਣੀ) ਇੱਜ਼ਤ ਗਵਾ ਲੈਂਦੇ ਹਨ (ਕਿਉਂਕਿ ਉਹ ਆਤਮਕ ਜੀਵਨ ਦੀ ਪੱਧਰ ਤੋਂ ਨੀਵੇਂ ਹੋ ਜਾਂਦੇ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но от воздействия жажды спасаются только те люди, которые обращены к Гуру; а те, кто идёт за своим умом, теряют честь, потому что опускаются ниже уровня духовной жизни ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7293,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਰਾਖੈ ਆਪਿ ਰਾਮੁ ਦਇਆਰਾ ॥",
          "roman": "jis rākhē āp rām dēārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਦਇਆਲ ਪ੍ਰਭੂ ਆਪ (ਤ੍ਰਿਸ਼ਨਾ ਤੋਂ) ਬਚਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, которого милосердный Господь Сам спасает от жажды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7294,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸੁ ਨਹੀ ਦੂਜਾ ਕੋ ਪਹੁਚਨਹਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tis nahī dūjā ko pahuchanhārā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦਾ ਜੀਵਨ ਇਤਨਾ ਉੱਚਾ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ) ਕੋਈ ਹੋਰ ਮਨੁੱਖ ਉਸ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "не может превзойти никто другой: его жизнь становится настолько высокой, что никто не может сравниться с ним ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7295,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਵਰਤੈ ਏਕੁ ਅਨੰਤਾ ॥",
          "roman": "sabh meh vartē ek anantā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਦੋਂ ਤੈਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਹੋ ਜਾਵੇ ਕਿ) ਇਕ ਬੇਅੰਤ ਪ੍ਰਭੂ ਹੀ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда у тебя утвердится уверенность, что во всём пребывает один бесконечный Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7296,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੂੰ ਸੁਖਿ ਸੋਉ ਹੋਇ ਅਚਿੰਤਾ ॥",
          "roman": "tā tū sukh soū hoi achintā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਤਦੋਂ ਹੀ ਚਿੰਤਾ-ਰਹਿਤ ਹੋ ਕੇ ਆਤਮਕ ਆਨੰਦ ਵਿਚ ਲੀਨ ਰਹਿ ਸਕਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "тогда ты сможешь, став свободным от тревоги, пребывать в духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7297,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਸਭੁ ਕਿਛੁ ਜਾਣੈ ਜੋ ਵਰਤੰਤਾ ॥੨॥",
          "roman": "ohu sabh kichh jāṇē jo vartantā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਜੋ ਕੁਝ ਜਗਤ ਵਿਚ ਵਾਪਰਦਾ ਹੈ ਉਹ ਪਰਮਾਤਮਾ ਸਭ ਕੁਝ ਜਾਣਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "И всё, что происходит в мире, Бог знает целиком ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7298,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਮੁਏ ਜਿਨ ਦੂਜੀ ਪਿਆਸਾ ॥",
          "roman": "manmukh muē jin dūjī piāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਚੰਬੜੀ ਰਹਿੰਦੀ ਹੈ, ਉਹ ਆਪਣੇ ਮਨ ਦੇ ਮੁਰੀਦ ਮਨੁੱਖ ਆਤਮਕ ਮੌਤੇ ਮਰੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, к которым прилипла жажда майи, эти последователи собственного ума, пребывают мёртвыми духовной смертью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7299,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਜੋਨੀ ਭਵਹਿ ਧੁਰਿ ਕਿਰਤਿ ਲਿਖਿਆਸਾ ॥",
          "roman": "bah jonī bhavah dhur kirat likhiāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਉਹਨਾਂ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ ਧੁਰੋਂ ਹੀ ਉਹਨਾਂ ਦੇ ਮੱਥੇ ਉਤੇ ਅਜੇਹਾ ਲੇਖ ਲਿਖਿਆ ਹੁੰਦਾ ਹੈ ਕਿ ਉਹ ਅਨੇਕਾਂ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что согласно совершённым ими деяниям, изначально им на челе написано такое предначертание, по которому они скитаются во множестве рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7300,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਬੀਜਹਿ ਤੈਸਾ ਖਾਸਾ ॥੩॥",
          "roman": "jēsā bījahi tēsā khāsā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਿਹੋ ਜਿਹਾ (ਕਰਮ-ਬੀਜ) ਬੀਜਦੇ ਹਨ ਉਹੋ ਜਿਹਾ (ਫਲ) ਖਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Какое семя деяний они сеют, такой плод и вкушают ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7301,
          "is_rahao": false,
          "gurmukhi": "ਦੇਖਿ ਦਰਸੁ ਮਨਿ ਭਇਆ ਵਿਗਾਸਾ ॥",
          "roman": "dekh daras man bahiā vigāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰ ਥਾਂ) ਪਰਮਾਤਮਾ ਦਾ ਦਰਸਨ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਖਿੜਾਉ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём уме при созерцании Божьего видения повсюду возникает расцвет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7302,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਨਦਰੀ ਆਇਆ ਬ੍ਰਹਮੁ ਪਰਗਾਸਾ ॥",
          "roman": "sabh nadrī āiā brahm pargāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਪਰਮਾਤਮਾ ਹੀ ਪ੍ਰਕਾਸ਼ ਕਰ ਰਿਹਾ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "видит, что везде сияет один только Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7303,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਕੀ ਹਰਿ ਪੂਰਨ ਆਸਾ ॥੪॥੨॥੭੧॥",
          "roman": "jan Nānak kī har pūran āsā ॥4॥2॥71॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦਾਸ ਦੀ ਪਰਮਾਤਮਾ (ਹਰੇਕ) ਆਸ ਪੂਰੀ ਕਰਦਾ ਹੈ ॥੪॥੨॥੭੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! У этого слуги Бог исполняет всякую надежду ॥4॥2॥71॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 523,
      "rahao_verse_id": 7310,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7304,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7305,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਭਏ ਕੀਟ ਪਤੰਗਾ ॥",
          "roman": "kaī janam bhaē kīṭ patangā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੂੰ ਕਈ ਜਨਮਾਂ ਵਿਚ ਕੀੜੇ ਪਤੰਗੇ ਬਣਦਾ ਰਿਹਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Во многих рождениях ты был насекомым и мотыльком,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7306,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਗਜ ਮੀਨ ਕੁਰੰਗਾ ॥",
          "roman": "kaī janam gaj mīn kurangā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜਨਮਾਂ ਵਿਚ ਹਾਥੀ ਮੱਛ ਹਿਰਨ ਬਣਦਾ ਰਿਹਾ।"
            },
            "sahib_singh_ru": {
              "main": "во многих рождениях ты был слоном, рыбой и оленем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7307,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਪੰਖੀ ਸਰਪ ਹੋਇਓ ॥",
          "roman": "kaī janam pankhī sarp hoiō ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜਨਮਾਂ ਵਿਚ ਤੂੰ ਪੰਛੀ ਤੇ ਸੱਪ ਬਣਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Во многих рождениях ты был птицей и змеёй,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7308,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਹੈਵਰ ਬ੍ਰਿਖ ਜੋਇਓ ॥੧॥",
          "roman": "kaī janam hēvar brikh joiō ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜਨਮਾਂ ਵਿਚ ਤੂੰ ਘੋੜੇ ਬਲਦ ਬਣ ਕੇ ਜੋਇਆ ਗਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "во многих рождениях тебя запрягали как коня и быка ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7309,
          "is_rahao": true,
          "gurmukhi": "ਮਿਲੁ ਜਗਦੀਸ ਮਿਲਨ ਕੀ ਬਰੀਆ ॥",
          "roman": "mil jagdīs milan kī barīā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਗਤ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਨੂੰ (ਹੁਣ) ਮਿਲ, (ਇਹੀ ਮਨੁੱਖਾ ਜਨਮ ਪ੍ਰਭੂ ਨੂੰ) ਮਿਲਣ ਦਾ ਸਮਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Встреться теперь с Владыкой мира: именно это человеческое рождение — время встречи с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7310,
          "is_rahao": true,
          "gurmukhi": "ਚਿਰੰਕਾਲ ਇਹ ਦੇਹ ਸੰਜਰੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "chirankāl ih dēh sanjarīā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿਰ ਪਿੱਛੋਂ ਤੈਨੂੰ ਇਹ (ਮਨੁੱਖਾ-) ਸਰੀਰ ਮਿਲਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь спустя долгое время ты получил это человеческое тело ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7311,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਸੈਲ ਗਿਰਿ ਕਰਿਆ ॥",
          "roman": "kaī janam sēl gir kariā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਕਈ ਜਨਮਾਂ ਵਿਚ ਤੈਨੂੰ ਪੱਥਰ ਚਿਟਾਨਾਂ ਬਣਾਇਆ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Во многих рождениях тебя делали камнем и скалой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7312,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਗਰਭ ਹਿਰਿ ਖਰਿਆ ॥",
          "roman": "kaī janam garabh hir khariā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜਨਮਾਂ ਵਿਚ (ਤੇਰੀ ਮਾਂ ਦਾ) ਗਰਭ ਹੀ ਛਣਦਾ ਰਿਹਾ।"
            },
            "sahib_singh_ru": {
              "main": "во многих рождениях даже утроба матери у тебя срывалась."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7313,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜਨਮ ਸਾਖ ਕਰਿ ਉਪਾਇਆ ॥",
          "roman": "kaī janam sākh kar upāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਜਨਮਾਂ ਵਿਚ ਤੈਨੂੰ (ਕਿਸਮ ਕਿਸਮ ਦਾ) ਰੁੱਖ ਬਣਾ ਕੇ ਪੈਦਾ ਕੀਤਾ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Во многих рождениях тебя создавали в виде разных деревьев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7314,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਚਉਰਾਸੀਹ ਜੋਨਿ ਭ੍ਰਮਾਇਆ ॥੨॥",
          "roman": "lakh chaurāsīh jon bhramāiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਇਸ ਤਰ੍ਹਾਂ) ਚੌਰਾਸੀ ਲੱਖ ਜੂਨਾਂ ਵਿਚ ਤੈਨੂੰ ਭਵਾਇਆ ਗਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и так тебя водили по восьмидесяти четырём лакхам форм жизни ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7315,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭਇਓ ਜਨਮੁ ਪਰਾਪਤਿ ॥",
          "roman": "sādhsang bhaio janam parāpat ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਹੁਣ ਤੈਨੂੰ) ਮਨੁੱਖਾ ਜਨਮ ਮਿਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Теперь ты получил человеческое рождение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7316,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਸੇਵਾ ਭਜੁ ਹਰਿ ਹਰਿ ਗੁਰਮਤਿ ॥",
          "roman": "kar sēvā bhaj har har gurmat ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਆ), ਗੁਰੂ ਦੀ ਮਤਿ ਲੈ ਕੇ (ਖ਼ਲਕਤਿ ਦੀ) ਸੇਵਾ ਕਰ ਤੇ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "приди в садх сангат, прими наставление Гуру, служи творению и совершай бхажан Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7317,
          "is_rahao": false,
          "gurmukhi": "ਤਿਆਗਿ ਮਾਨੁ ਝੂਠੁ ਅਭਿਮਾਨੁ ॥",
          "roman": "tiāg mān jhūṭh abhimān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਣ, ਝੂਠ ਤੇ ਅਹੰਕਾਰ ਛੱਡ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "Оставь гордость, ложь и эгоизм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7318,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਮਰਹਿ ਦਰਗਹ ਪਰਵਾਨੁ ॥੩॥",
          "roman": "jīvat marahi dargah parvān ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਪਰਮਾਤਮਾ ਦੀ) ਦਰਗਾਹ ਵਿਚ (ਤਦੋਂ ਹੀ) ਕਬੂਲ ਹੋਵੇਂਗਾ ਜੇ ਤੂੰ ਇਹ ਜੀਵਨ ਜੀਊਂਦਾ ਹੀ ਆਪਾ-ਭਾਵ ਵਲੋਂ ਮਰੇਂਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ты будешь принят в Божьем дворе только тогда, когда ещё при жизни умрёшь для самоутверждения ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7319,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਹੋਆ ਸੁ ਤੁਝ ਤੇ ਹੋਗੁ ॥",
          "roman": "jo kichh hoā su tujh te hog ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਸਿਮਰਨ ਕਰਨ ਦੀ ਜੀਵ ਨੂੰ ਕੀਹ ਸਮਰੱਥਾ ਹੋ ਸਕਦੀ ਹੈ?) ਜੋ ਕੁਝ (ਜਗਤ ਵਿਚ) ਹੁੰਦਾ ਹੈ ਉਹ ਤੇਰੇ (ਹੁਕਮ) ਤੋਂ ਹੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Какая у существа может быть сила, чтобы помнить Тебя? Всё, что происходит в мире, происходит только по Твоему повелению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7320,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰੁ ਨ ਦੂਜਾ ਕਰਣੈ ਜੋਗੁ ॥",
          "roman": "avar na dūjā karṇē jog ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੈਥੋਂ ਬਿਨਾ) ਹੋਰ ਕੋਈ ਭੀ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਵਾਲਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя нет никого другого, кто был бы способен что-либо совершать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7321,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਮਿਲੀਐ ਜਾ ਲੈਹਿ ਮਿਲਾਇ ॥",
          "roman": "tā milīē jā lēh milāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਨੂੰ ਤਦੋਂ ਹੀ ਮਿਲਿਆ ਜਾ ਸਕਦਾ ਹੈ ਜੇ ਤੂੰ ਆਪ ਜੀਵ ਨੂੰ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਮਿਲਾ ਲਏਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Тебя можно встретить только тогда, когда Ты Сам соединяешь существо со Своими стопами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7322,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਹਰਿ ਹਰਿ ਗੁਣ ਗਾਇ ॥੪॥੩॥੭੨॥",
          "roman": "kah Nānak har har guṇ gāi ॥4॥3॥72॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਤਦੋਂ ਹੀ ਜੀਵ ਹਰਿ-ਗੁਣ ਗਾ ਸਕਦਾ ਹੈ ॥੪॥੩॥੭੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Только тогда существо может петь качества Хари ॥4॥3॥72॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 524,
      "rahao_verse_id": 7329,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7323,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7324,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਭੂਮਿ ਮਹਿ ਬੋਅਹੁ ਨਾਮੁ ॥",
          "roman": "karam bhūm meh boah nām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਕਰਮ ਬੀਜਣ ਵਾਲੀ ਧਰਤੀ ਵਿਚ (ਮਨੁੱਖਾ ਸਰੀਰ ਵਿਚ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਬੀਜ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Посей Имя Бога в земле, где сеются деяния, то есть в человеческом теле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7325,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਇ ਤੁਮਾਰਾ ਕਾਮੁ ॥",
          "roman": "pūran hoi tumārā kām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਤੇਰਾ (ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ) ਮਨੋਰਥ ਸਿਰੇ ਚੜ੍ਹ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и так завершится цель твоей человеческой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7326,
          "is_rahao": false,
          "gurmukhi": "ਫਲ ਪਾਵਹਿ ਮਿਟੈ ਜਮ ਤ੍ਰਾਸ ॥",
          "roman": "phal pāvah miṭē jam trās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤਾਂ ਇਸ ਦਾ ਇਹ ਫਲ ਹਾਸਲ ਕਰੇਂਗਾ ਕਿ ਤੇਰਾ ਆਤਮਕ ਮੌਤ ਦਾ ਖ਼ਤਰਾ ਮਿਟੇਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тогда ты получишь такой плод: исчезнет страх духовной смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7327,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਗਾਵਹਿ ਹਰਿ ਹਰਿ ਗੁਣ ਜਾਸ ॥੧॥",
          "roman": "nit gāvahi har har guṇ jās ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਨਿੱਤ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਵੇਂ, ਜੇ ਨਿੱਤ ਪਰਮਾਤਮਾ ਦਾ ਜਸ ਗਾਵੇਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если ты ежедневно будешь петь качества Бога, если ежедневно будешь воспевать Его славу ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7328,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਅੰਤਰਿ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "har har nām antar ur dhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਣੇ ਅੰਦਰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸੰਭਾਲ ਕੇ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Храни Имя Бога внутри, в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7329,
          "is_rahao": true,
          "gurmukhi": "ਸੀਘਰ ਕਾਰਜੁ ਲੇਹੁ ਸਵਾਰਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sīghar kāraj leh savār ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਇਸ ਤਰ੍ਹਾਂ) ਆਪਣਾ ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ ਮਨੋਰਥ ਸਵਾਰ ਲੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и так устрой цель своей человеческой жизни ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7330,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਪ੍ਰਭ ਸਿਉ ਹੋਹੁ ਸਾਵਧਾਨੁ ॥",
          "roman": "apne prabh siu hoh sāvadhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਣੇ ਪਰਮਾਤਮਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਵਿਚ) ਸੁਚੇਤ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Будь бдителен со своим Богом, пребывай в памяти о Нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7331,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੂੰ ਦਰਗਹ ਪਾਵਹਿ ਮਾਨੁ ॥",
          "roman": "tā tū dargah pāvah mān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੂੰ ਇਹ ਉੱਦਮ ਕਰੇਂਗਾ) ਤਦੋਂ ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ-ਮਾਣ ਪ੍ਰਾਪਤ ਕਰੇਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Когда ты станешь совершать это усилие, тогда получишь честь и уважение в присутствии Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
