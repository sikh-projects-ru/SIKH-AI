{
  "ang": 179,
  "shabads": [
    {
      "shabad_id": 530,
      "rahao_verse_id": 7445,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7444,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਮੇਰੇ ਗਹੁ ਹਰਿ ਨਾਮ ਕਾ ਓਲਾ ॥",
          "roman": "man mērē gah har nām kā ōlā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ ਫੜ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Держись за опору Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7445,
          "is_rahao": true,
          "gurmukhi": "ਤੁਝੈ ਨ ਲਾਗੈ ਤਾਤਾ ਝੋਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tujhē na lāgē tātā jhōlā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ (ਦੁਨੀਆ ਦੇ ਦੁਖ ਕਲੇਸ਼ਾਂ ਦੀ) ਤੱਤੀ ਹਵਾ ਦਾ ਬੁੱਲਾ ਪੋਹ ਨਹੀਂ ਸਕੇਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тогда тебя не коснётся обжигающий порыв ветра мирских страданий и бедствий ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7446,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਬੋਹਿਥੁ ਭੈ ਸਾਗਰ ਮਾਹਿ ॥",
          "roman": "jiu bōhith bhē sāgar māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਵੇਂ ਡਰਾਵਣੇ ਸਮੁੰਦਰ ਵਿਚ ਜਹਾਜ਼ (ਮਨੁੱਖ ਨੂੰ ਡੁੱਬਣੋਂ ਬਚਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Как корабль в страшном море спасает человека от утопления,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7447,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਕਾਰ ਦੀਪਕ ਦੀਪਾਹਿ ॥",
          "roman": "andhkār dīpak dīpāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹਨੇਰੇ ਵਿਚ ਦੀਵੇ ਚਾਨਣ ਕਰਦੇ ਹਨ (ਤੇ ਠੇਡਾ ਖਾਣ ਤੋਂ ਬਚਾਂਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "как светильники освещают во тьме и спасают от падения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7448,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਸੀਤ ਕਾ ਲਾਹਸਿ ਦੂਖ ॥",
          "roman": "agan sīt kā lāhas dūkh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ, ਅੱਗ ਪਾਲੇ ਦਾ ਦੁੱਖ ਦੂਰ ਕਰ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как огонь устраняет страдание от холода,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7449,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਮਨਿ ਹੋਵਤ ਸੂਖ ॥੨॥",
          "roman": "nām japat man hōvat sūkh ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਮਨ ਵਿਚ ਆਨੰਦ ਪੈਦਾ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так и при памятовании Имени Бога в уме возникает блаженство ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7450,
          "is_rahao": false,
          "gurmukhi": "ਉਤਰਿ ਜਾਇ ਤੇਰੇ ਮਨ ਕੀ ਪਿਆਸ ॥",
          "roman": "utar jāe tērē man kī piās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਤੇਰੇ ਮਨ ਦੀ (ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਲਹਿ ਜਾਏਗੀ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря силе Имени жажда майи в твоём уме уйдёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7451,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਵੈ ਸਗਲੀ ਆਸ ॥",
          "roman": "pūran hōvē saglī ās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਸਾਰੀ ਹੀ ਆਸ ਪੂਰੀ ਹੋ ਜਾਇਗੀ (ਦੁਨੀਆ ਦੀਆਂ ਆਸਾਂ ਸਤਾਣੋਂ ਹਟ ਜਾਣਗੀਆਂ),"
            },
            "sahib_singh_ru": {
              "main": "Все твои надежды исполнятся, то есть мирские надежды перестанут мучить тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7452,
          "is_rahao": false,
          "gurmukhi": "ਡੋਲੈ ਨਾਹੀ ਤੁਮਰਾ ਚੀਤੁ ॥",
          "roman": "ḍōlē nāhī tumrā chīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਤੇਰਾ ਮਨ (ਮਾਇਆ ਦੀ ਲਾਲਸਾ ਵਿਚ) ਡੋਲੇਗਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "и твой ум больше не будет колебаться в жажде майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7453,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਜਪਿ ਗੁਰਮੁਖਿ ਮੀਤ ॥੩॥",
          "roman": "amrit nām jap gurmukh mīt ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੇ ਮਿੱਤਰ! ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਜਪ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о друг, припав к защите Гуру, повторяй дарующее духовную жизнь Имя Хари ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7454,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਅਉਖਧੁ ਸੋਈ ਜਨੁ ਪਾਵੈ ॥",
          "roman": "nām aukhadh sōī jan pāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ) ਹਰਿ-ਨਾਮ ਦਵਾਈ ਉਹੀ ਮਨੁੱਖ ਹਾਸਲ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но это лекарство Имени Хари получает только тот человек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7455,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਆਪਿ ਦਿਵਾਵੈ ॥",
          "roman": "kar kirpā jis āp divāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਮਿਹਰ ਕਰਕੇ ਆਪ (ਗੁਰੂ ਪਾਸੋਂ) ਦਿਵਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "кому Господь по Своей милости Сам даёт его получить от Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7456,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਾ ਕੈ ਹਿਰਦੈ ਵਸੈ ॥",
          "roman": "har har nām jā kē hirdē vasē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਵੱਸ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! В сердце того человека, в ком поселяется Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7457,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਤਿਹ ਨਾਨਕ ਨਸੈ ॥੪॥੧੦॥੭੯॥",
          "roman": "dūkh darad tih Nānak nasē ॥4॥10॥79॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਸਾਰਾ ਦੁਖ-ਦਰਦ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੪॥੧੦॥੭੯॥"
            },
            "sahib_singh_ru": {
              "main": "исчезает всякая боль и страдание ॥4॥10॥79॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 531,
      "rahao_verse_id": 7464,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7458,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7459,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਦਰਬੁ ਕਰਿ ਮਨੁ ਨ ਅਘਾਨਾ ॥",
          "roman": "bahut darab kar man na aghānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤਾ ਧਨ ਜੋੜ ਕੇ (ਭੀ) ਮਨ ਰੱਜਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Собрав много богатства, ум всё равно не насыщается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7460,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰੂਪ ਦੇਖਿ ਨਹ ਪਤੀਆਨਾ ॥",
          "roman": "anik rūp dēkh nah patīānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ (ਸੁੰਦਰ ਇਸਤ੍ਰੀਆਂ ਦੇ) ਰੂਪ ਵੇਖ ਕੇ ਭੀ ਮਨ ਦੀ ਤਸੱਲੀ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Даже увидев множество прекрасных обликов, ум не получает удовлетворения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7461,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਉਰਝਿਓ ਜਾਨਿ ਮੇਰੀ ॥",
          "roman": "putra kalatra urjhiō jān merī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ, ਇਹ ਸਮਝ ਕੇ ਕਿ ਇਹ ਮੇਰੀ ਇਸਤ੍ਰੀ ਹੈ ਇਹ ਮੇਰਾ ਪੁਤ੍ਰ ਹੈ, ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Считая: это моя жена, это мой сын, человек остаётся запутанным в привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7462,
          "is_rahao": false,
          "gurmukhi": "ਓਹ ਬਿਨਸੈ ਓਇ ਭਸਮੈ ਢੇਰੀ ॥੧॥",
          "roman": "oh binsē oi bhasmē ḍhērī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸਤ੍ਰੀਆਂ ਦੀ) ਸੁੰਦਰਤਾ ਨਾਸ ਹੋ ਜਾਂਦੀ ਹੈ, (ਉਹ ਆਪਣੇ ਮਿਥੇ ਹੋਏ) ਇਸਤ੍ਰੀ ਪੁੱਤਰ ਸੁਆਹ ਦੀ ਢੇਰੀ ਹੋ ਜਾਂਦੇ ਹਨ (ਕਿਸੇ ਨਾਲ ਭੀ ਸਾਥ ਨਹੀਂ ਨਿਭਦਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Красота исчезает, а эти мнимые жена и сын становятся кучей пепла; ни с кем не бывает настоящего спутничества ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7463,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਭਜਨ ਦੇਖਉ ਬਿਲਲਾਤੇ ॥",
          "roman": "bin har bhajan dēkhau billātē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਵੇਖਦਾ ਹਾਂ ਕਿ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰਨ ਤੋਂ ਬਿਨਾ ਜੀਵ ਵਿਲਕਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Я вижу, что без бхажана Богу существа плачут и страдают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7464,
          "is_rahao": true,
          "gurmukhi": "ਧ੍ਰਿਗੁ ਤਨੁ ਧ੍ਰਿਗੁ ਧਨੁ ਮਾਇਆ ਸੰਗਿ ਰਾਤੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dhṛig tan dhṛig dhan māiā saṅg rātē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ ਉਹਨਾਂ ਦਾ ਸਰੀਰ ਫਿਟਕਾਰ-ਜੋਗ ਹੈ ਉਹਨਾਂ ਦਾ ਧਨ ਫਿਟਕਾਰ-ਜੋਗ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тела тех людей, что опьянены привязанностью к майе, достойны порицания, и их богатство достойно порицания ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7465,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਬਿਗਾਰੀ ਕੈ ਸਿਰਿ ਦੀਜਹਿ ਦਾਮ ॥",
          "roman": "jiu bigārī kē sir dījeh dām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕਿਸੇ ਵਿਗਾਰੀ ਦੇ ਸਿਰ ਉਤੇ ਪੈਸੇ-ਰੁਪਏ ਰੱਖੇ ਜਾਣ,"
            },
            "sahib_singh_ru": {
              "main": "Как если на голову носильщику кладут деньги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7466,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਖਸਮੈ ਕੈ ਗ੍ਰਿਹਿ ਉਨ ਦੂਖ ਸਹਾਮ ॥",
          "roman": "oi khasmē kē grih un dūkh sahām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੈਸੇ-ਰੁਪਏ ਮਾਲਕ ਦੇ ਘਰ ਵਿਚ ਜਾ ਪਹੁੰਚਦੇ ਹਨ, ਉਸ ਵਿਗਾਰੀ ਨੇ (ਭਾਰ ਚੁੱਕਣ ਦਾ) ਦੁੱਖ ਹੀ ਸਹਾਰਿਆ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "эти деньги доходят до дома хозяина, а носильщик лишь переносит страдание от ноши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7467,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਸੁਪਨੈ ਹੋਇ ਬੈਸਤ ਰਾਜਾ ॥",
          "roman": "jiu supnē hoi bēsat rājā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਮਨੁੱਖ ਸੁਪਨੇ ਵਿਚ ਰਾਜਾ ਬਣ ਕੇ ਬੈਠ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как если человек во сне становится царём,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7468,
          "is_rahao": false,
          "gurmukhi": "ਨੇਤ੍ਰ ਪਸਾਰੈ ਤਾ ਨਿਰਾਰਥ ਕਾਜਾ ॥੨॥",
          "roman": "nētra pasārē tā nirārath kājā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜਦੋਂ ਨੀਂਦ ਮੁੱਕ ਜਾਣ ਤੇ) ਅੱਖਾਂ ਖੋਲ੍ਹਦਾ ਹੈ, ਤਾਂ (ਸੁਪਨੇ ਵਿਚ ਮਿਲੇ ਰਾਜ ਦਾ ਸਾਰਾ) ਕੰਮ ਚੌੜ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но когда открывает глаза, всё дело того царства, полученного во сне, оказывается пустым ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7469,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਰਾਖਾ ਖੇਤ ਊਪਰਿ ਪਰਾਏ ॥",
          "roman": "jiu rākhā khēt ūpar parāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਰਾਖਾ ਕਿਸੇ ਹੋਰ ਦੇ ਖੇਤ ਉਤੇ (ਰਾਖੀ ਕਰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Как если сторож стоит над чужим полем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7470,
          "is_rahao": false,
          "gurmukhi": "ਖੇਤੁ ਖਸਮ ਕਾ ਰਾਖਾ ਉਠਿ ਜਾਏ ॥",
          "roman": "khēt khasam kā rākhā uṭh jāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫ਼ਸਲ ਪੱਕਣ ਤੇ) ਫ਼ਸਲ ਮਾਲਕ ਦੀ ਮਲਕੀਅਤ ਹੋ ਜਾਂਦਾ ਹੈ ਤੇ ਰਾਖਾ ਉੱਠ ਕੇ ਚਲਾ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "урожай становится собственностью хозяина, а сторож уходит прочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7471,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਖੇਤ ਕਾਰਣਿ ਰਾਖਾ ਕੜੈ ॥",
          "roman": "us khēt kāraṇ rākhā kaṛē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਖਾ ਉਸ (ਪਰਾਏ) ਖੇਤ ਦੀ (ਰਾਖੀ ਦੀ) ਖ਼ਾਤਰ ਦੁਖੀ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сторож страдает ради охраны этого чужого поля,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7472,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੈ ਪਾਲੈ ਕਛੂ ਨ ਪੜੈ ॥੩॥",
          "roman": "tis kē pālē kachhū na paṛē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਨੂੰ (ਆਖ਼ਰ) ਕੁਝ ਭੀ ਨਹੀਂ ਮਿਲਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но в конце ему не достаётся ничего ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7473,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਰਾਜੁ ਤਿਸੈ ਕਾ ਸੁਪਨਾ ॥",
          "roman": "jis kā rāj tisē kā supnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵ ਦੇ ਕੀਹ ਵੱਸ? ਸੁਪਨੇ ਵਿਚ) ਜਿਸ ਪ੍ਰਭੂ ਦਾ (ਦਿੱਤਾ ਹੋਇਆ) ਰਾਜ ਮਿਲਦਾ ਹੈ, ਉਸੇ ਦਾ ਹੀ ਦਿੱਤਾ ਹੋਇਆ ਸੁਪਨਾ ਭੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но что во власти существа? И царство, полученное во сне, принадлежит тому же Господу, и сам сон тоже дан Им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7474,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਮਾਇਆ ਦੀਨੀ ਤਿਨਿ ਲਾਈ ਤ੍ਰਿਸਨਾ ॥",
          "roman": "jin māiā dīnī tin lāī trisanā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਮਨੁੱਖ ਨੂੰ ਮਾਇਆ ਦਿੱਤੀ ਹੈ, ਉਸੇ ਨੇ ਹੀ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਚੰਬੋੜੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь, Который дал человеку майю, Сам же и прилепил к ней жажду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7475,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬਿਨਾਹੇ ਆਪਿ ਕਰੇ ਰਾਸਿ ॥",
          "roman": "āp bināhē āp karē rās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ (ਤ੍ਰਿਸ਼ਨਾ ਚੰਬੋੜ ਕੇ) ਆਤਮਕ ਮੌਤ ਦੇਂਦਾ ਹੈ, ਆਪ ਹੀ (ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਦੇ ਕੇ) ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ ਮਨੋਰਥ ਸਫਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Он даёт духовную смерть, прилепляя жажду, и Сам же делает человеческую жизнь успешной, даруя Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7476,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਆਗੈ ਅਰਦਾਸਿ ॥੪॥੧੧॥੮੦॥",
          "roman": "nānak prabh āgē ardās ॥4॥11॥80॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਹੀ (ਸਦਾ ਨਾਮ ਦੀ  ਦਾਤ ਵਾਸਤੇ) ਅਰਦਾਸ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ ॥੪॥੧੧॥੮੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Следует возносить мольбу только перед Господом, прося дар Имени ॥4॥11॥80॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 532,
      "rahao_verse_id": 7483,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7477,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārērī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7478,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਰੰਗ ਮਾਇਆ ਬਹੁ ਬਿਧਿ ਪੇਖੀ ॥",
          "roman": "bah raṅg māiā bah bidh pēkhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਬਹੁਤ ਰੰਗਾਂ ਵਾਲੀ ਮਾਇਆ ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਮੋਂਹਦੀ ਵੇਖੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Я видел, как многоцветная майя прельщает множеством способов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7479,
          "is_rahao": false,
          "gurmukhi": "ਕਲਮ ਕਾਗਦ ਸਿਆਨਪ ਲੇਖੀ ॥",
          "roman": "kalam kāgad siānap lēkhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਗ਼ਜ਼ ਕਲਮ (ਲੈ ਕੇ ਕਈਆਂ ਨੇ) ਅਨੇਕਾਂ ਵਿਦਵਤਾ ਵਾਲੇ ਲੇਖ ਲਿਖੇ ਹਨ (ਮਾਇਆ ਉਹਨਾਂ ਨੂੰ ਵਿਦਵਤਾ ਦੇ ਰੂਪ ਵਿਚ ਮੋਹ ਰਹੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Взяв бумагу и перо, многие писали учёные сочинения; майя прельщает их в образе учёности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7480,
          "is_rahao": false,
          "gurmukhi": "ਮਹਰ ਮਲੂਕ ਹੋਇ ਦੇਖਿਆ ਖਾਨ ॥",
          "roman": "mahar malūk hoi dēkhiā khān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਈਆਂ ਨੇ) ਚੌਧਰੀ ਸੁਲਤਾਨ ਖਾਨ ਬਣ ਕੇ ਵੇਖ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Многие становились вельможами, султанами, ханами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7481,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇ ਨਾਹੀ ਮਨੁ ਤ੍ਰਿਪਤਾਨ ॥੧॥",
          "roman": "tā tē nāhī man triptān ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਨਾਲ (ਕਿਸੇ ਦਾ) ਮਨ ਤ੍ਰਿਪਤ ਨਹੀਂ ਹੋ ਸਕਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но ни у кого от этого ум не стал удовлетворённым ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7482,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਸੁਖੁ ਮੋ ਕਉ ਸੰਤ ਬਤਾਵਹੁ ॥",
          "roman": "so sukh mo kau sant batāvh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਮੈਨੂੰ ਉਹ ਆਤਮਕ ਆਨੰਦ ਦੱਸੋ (ਜਿਸ ਨਾਲ ਮੇਰੀ ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਮਿਟ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! Скажите мне о том духовном блаженстве, которое погасит мою жажду майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7483,
          "is_rahao": true,
          "gurmukhi": "ਤ੍ਰਿਸਨਾ ਬੂਝੈ ਮਨੁ ਤ੍ਰਿਪਤਾਵਹੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "trisanā būjhē man triptāvhu ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਮੇਰੇ ਮਨ ਨੂੰ ਸੰਤੋਖੀ ਬਣਾ ਦਿਓ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О святые! Сделайте мой ум удовлетворённым ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7484,
          "is_rahao": false,
          "gurmukhi": "ਅਸੁ ਪਵਨ ਹਸਤਿ ਅਸਵਾਰੀ ॥",
          "roman": "as pavan hast asvārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਾਥੀਆਂ ਦੀ ਤੇ ਹਵਾ ਵਰਗੇ ਤੇਜ਼ ਘੋੜਿਆਂ ਦੀ ਸਵਾਰੀ (ਕਈਆਂ ਨੇ ਕਰ ਵੇਖੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Многие ездили на слонах и на конях, быстрых как ветер,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7485,
          "is_rahao": false,
          "gurmukhi": "ਚੋਆ ਚੰਦਨੁ ਸੇਜ ਸੁੰਦਰਿ ਨਾਰੀ ॥",
          "roman": "choā chandan sēj sundar nārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤਰ ਤੇ ਚੰਦਨ (ਵਰਤ ਵੇਖਿਆ ਹੈ), ਸੁੰਦਰ ਇਸਤ੍ਰੀ ਦੀ ਸੇਜ (ਮਾਣ ਵੇਖੀ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "пользовались благовониями и сандалом, наслаждались ложем прекрасной женщины,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7486,
          "is_rahao": false,
          "gurmukhi": "ਨਟ ਨਾਟਿਕ ਆਖਾਰੇ ਗਾਇਆ ॥",
          "roman": "naṭ nāṭik ākhārē gāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਰੰਗ-ਭੂਮੀ ਵਿਚ ਨਟਾਂ ਦੇ ਨਾਟਕ ਵੇਖੇ ਹਨ, ਤੇ ਉਹਨਾਂ ਦੇ ਗੀਤ ਗਾਏ ਹੋਏ ਸੁਣੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "я видел представления актёров на сцене и слышал, как пели их песни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7487,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਮਹਿ ਮਨਿ ਸੰਤੋਖੁ ਨ ਪਾਇਆ ॥੨॥",
          "roman": "tā mahi man santokh na pāiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਵਿਚ ਰੁੱਝ ਕੇ ਭੀ (ਕਿਸੇ ਦੇ) ਮਨ ਨੇ ਸ਼ਾਂਤੀ ਪ੍ਰਾਪਤ ਨਹੀਂ ਕੀਤੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но даже погрузившись во всё это, ум не обретал покоя ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7488,
          "is_rahao": false,
          "gurmukhi": "ਤਖਤੁ ਸਭਾ ਮੰਡਨ ਦੋਲੀਚੇ ॥",
          "roman": "takhat sabhā maṇḍan dōlīchē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜ-ਦਰਬਾਰ ਦੀਆਂ ਸਜਾਵਟਾਂ, ਤਖ਼ਤ (ਉਤੇ ਬੈਠਣਾ), ਦੁਲੀਚੇ,"
            },
            "sahib_singh_ru": {
              "main": "Украшения царского двора, трон, ковры,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7489,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮੇਵੇ ਸੁੰਦਰ ਬਾਗੀਚੇ ॥",
          "roman": "sagal mēvē sundar bāgīchē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਕਿਸਮਾਂ ਦੇ ਫਲ, ਸੁੰਦਰ ਫੁਲਵਾੜੀਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "всякие плоды, красивые сады,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7490,
          "is_rahao": false,
          "gurmukhi": "ਆਖੇੜ ਬਿਰਤਿ ਰਾਜਨ ਕੀ ਲੀਲਾ ॥",
          "roman": "ākhēṛ birat rājan kī līlā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ਿਕਾਰ ਖੇਡਣ ਵਾਲੀ ਰੁਚੀ, ਰਾਜਿਆਂ ਦੀਆਂ ਖੇਡਾਂ-"
            },
            "sahib_singh_ru": {
              "main": "страсть к охоте, царские забавы —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7491,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਨ ਸੁਹੇਲਾ ਪਰਪੰਚੁ ਹੀਲਾ ॥੩॥",
          "roman": "man na suhēlā parpanch hīlā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਸਭਨਾਂ ਨਾਲ ਭੀ) ਮਨ ਸੁਖੀ ਨਹੀਂ ਹੁੰਦਾ। ਇਹ ਸਾਰਾ ਜਤਨ ਛਲ ਹੀ ਸਾਬਤ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "даже от всего этого ум не становится счастливым; всё это в конце оказывается лишь обманом ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7492,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਸੰਤਨ ਸਚੁ ਕਹਿਆ ॥",
          "roman": "kar kirpā santan sach kahiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੇ ਰੰਗ-ਤਮਾਸ਼ਿਆਂ ਵਿਚੋਂ ਸੁਖ ਭਾਲਦੇ ਨੂੰ) ਸੰਤਾਂ ਨੇ ਮੇਹਰ ਕਰ ਕੇ ਸੱਚ ਦੱਸਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кто искал счастье среди мирских зрелищ, святые по милости сказали истину:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7493,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਇਹੁ ਆਨੰਦੁ ਲਹਿਆ ॥",
          "roman": "sarab sūkh ihu ānand lahiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਮੂਲ ਇਹ ਆਤਮਕ ਆਨੰਦ ਤਾਂ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "источник всех благ — это духовное блаженство — обретается"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7494,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੀਰਤਨੁ ਗਾਈਐ ॥",
          "roman": "sādhasaṅg har kīrtan gāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਣੇ ਜਾਣ।"
            },
            "sahib_singh_ru": {
              "main": "если в святом собрании поют песни хвалы Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7495,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਵਡਭਾਗੀ ਪਾਈਐ ॥੪॥",
          "roman": "kah nānak vaḍbhāgī pāīai ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਨਾਨਕ ਆਖਦਾ ਹੈ- ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਇਹ  ਦਾਤ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: этот дар хвалы обретается великим счастьем ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7496,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੈ ਹਰਿ ਧਨੁ ਸੋਈ ਸੁਹੇਲਾ ॥",
          "roman": "jā kē har dhan soī suhēlā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਧਨ ਮੌਜੂਦ ਹੈ ਉਹੀ ਸੌਖਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По-настоящему счастлив лишь тот человек, в чьём сердце есть богатство Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7497,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਸਾਧਸੰਗਿ ਮੇਲਾ ॥੧॥ ਰਹਾਉ ਦੂਜਾ ॥੧੨॥੮੧॥",
          "roman": "prabh kirpā tē sādhasaṅg mēlā ॥1॥ rahāu dūjā ॥12॥81॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਬੈਠਣਾ ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ ਨਸੀਬ ਹੁੰਦਾ ਹੈ ॥੧॥ਰਹਾਉ ਦੂਜਾ॥"
            },
            "sahib_singh_ru": {
              "main": "Лишь по милости Бога человеку выпадает встреча со священным собранием ॥1॥ Вторая пауза ॥12॥81॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
