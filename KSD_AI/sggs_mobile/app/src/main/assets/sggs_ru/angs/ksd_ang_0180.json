{
  "ang": 180,
  "shabads": [
    {
      "shabad_id": 533,
      "rahao_verse_id": 7504,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7499,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਣੀ ਜਾਣੈ ਇਹੁ ਤਨੁ ਮੇਰਾ ॥",
          "roman": "prāṇī jāṇē ihu tan mērā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ) ਮਨੁੱਖ ਸਮਝਦਾ ਹੈ ਕਿ ਇਹ ਸਰੀਰ (ਸਦਾ) ਮੇਰਾ (ਆਪਣਾ ਹੀ ਰਹਿਣਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, попавший в привязанность к майе, думает, что это тело всегда будет его собственным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7500,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਬਹੁਰਿ ਉਆਹੂ ਲਪਟੇਰਾ ॥",
          "roman": "bahur bahur uāhū lapaṭērā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁੜ ਮੁੜ ਇਸ ਸਰੀਰ ਨਾਲ ਹੀ ਚੰਬੜਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И снова и снова цепляется только за это тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7501,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਗਿਰਸਤ ਕਾ ਫਾਸਾ ॥",
          "roman": "putra kalatra girast kā fāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਚਿਰ ਪੁੱਤਰ ਇਸਤ੍ਰੀ ਗ੍ਰਿਹਸਤ (ਦੇ ਮੋਹ) ਦਾ ਫਾਹਾ (ਗਲ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока на шее висит петля привязанности к сыну, жене и домашней жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7502,
          "is_rahao": false,
          "gurmukhi": "ਹੋਨੁ ਨ ਪਾਈਐ ਰਾਮ ਕੇ ਦਾਸਾ ॥੧॥",
          "roman": "hon na pāīai rām kē dāsā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਸੇਵਕ ਬਣ ਨਹੀਂ ਸਕੀਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "нельзя стать слугой Бога ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7503,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨ ਸੁ ਬਿਧਿ ਜਿਤੁ ਰਾਮ ਗੁਣ ਗਾਇ ॥",
          "roman": "kavan su bidh jit rām guṇ gāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਕੇਹੜਾ ਤਰੀਕਾ ਹੈ ਜਿਸ ਨਾਲ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каков тот способ, которым человек может петь качества Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7504,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨ ਸੁ ਮਤਿ ਜਿਤੁ ਤਰੈ ਇਹ ਮਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kavan su mat jit tarē ih māi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕੇਹੜੀ ਸਿੱਖ-ਮਤਿ ਹੈ ਜਿਸ ਦੀ ਰਾਹੀਂ ਮਨੁੱਖ ਇਸ ਮਾਇਆ (ਦੇ ਪ੍ਰਭਾਵ) ਤੋਂ ਪਾਰ ਲੰਘ ਸਕਦਾ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Каково то учение, посредством которого человек может переправиться через влияние этой майи? ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7505,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਭਲਾਈ ਸੋ ਬੁਰਾ ਜਾਨੈ ॥",
          "roman": "jo bhalāī so burā jānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕੰਮ ਇਸ ਦੀ ਭਲਾਈ (ਦਾ) ਹੈ ਉਸ ਨੂੰ ਭੈੜਾ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "То, что было бы ему во благо, он считает плохим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7506,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੁ ਕਹੈ ਸੋ ਬਿਖੈ ਸਮਾਨੈ ॥",
          "roman": "sāch kahē so bikhē samānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਇਸ ਨੂੰ ਸੱਚ ਆਖੇ, ਉਹ ਇਸ ਨੂੰ ਜ਼ਹਰ ਵਰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то говорит ему истину, она кажется ему ядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7507,
          "is_rahao": false,
          "gurmukhi": "ਜਾਣੈ ਨਾਹੀ ਜੀਤ ਅਰੁ ਹਾਰ ॥",
          "roman": "jāṇē nāhī jīt aru hār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਹੀਂ ਸਮਝਦਾ ਹੈ ਕਿ ਕੇਹੜਾ ਕੰਮ ਜੀਵਨ-ਬਾਜ਼ੀ ਦੀ ਜਿੱਤ ਵਾਸਤੇ ਹੈ ਤੇ ਕੇਹੜਾ ਹਾਰ ਵਾਸਤੇ।"
            },
            "sahib_singh_ru": {
              "main": "Он не понимает, какое дело ведёт к победе в жизненной игре, а какое — к поражению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7508,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਵਲੇਵਾ ਸਾਕਤ ਸੰਸਾਰ ॥੨॥",
          "roman": "ihu valēvā sākat sansār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ-ਵੇੜ੍ਹੇ ਸੰਸਾਰ ਦਾ ਇਹ ਵਰਤਣ-ਵਿਹਾਰ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Таков образ действий мира, охваченного майей ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7509,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਹਲਾਹਲ ਸੋ ਪੀਵੈ ਬਉਰਾ ॥",
          "roman": "jo halāhal so pīvē baurā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਜ਼ਹਰ ਹੈ ਉਸ ਨੂੰ ਮਾਇਆ-ਗ੍ਰਸਿਆ ਮਨੁੱਖ (ਖ਼ੁਸ਼ੀ ਨਾਲ) ਪੀਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "То, что есть яд, человек, поражённый майей, пьёт с удовольствием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7510,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਨਾਮੁ ਜਾਨੈ ਕਰਿ ਕਉਰਾ ॥",
          "roman": "aṃmritu nām jānē kar kaurā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹੈ, ਇਸ ਨੂੰ ਮਨੁੱਖ ਕੌੜਾ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "А Имя Бога, которое даёт духовную жизнь, он считает горьким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7511,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗ ਕੈ ਨਾਹੀ ਨੇਰਿ ॥",
          "roman": "sādhasaṅg kē nāhī nēr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ-ਗ੍ਰਸਿਆ ਮਨੁੱਖ) ਸਾਧ ਸੰਗਤਿ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, охваченный майей, не приближается к святому собранию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7512,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਚਉਰਾਸੀਹ ਭ੍ਰਮਤਾ ਫੇਰਿ ॥੩॥",
          "roman": "lakh chaurāsīh bhramtā phēr ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਚੌਰਾਸੀ ਲੱਖ ਜੂਨਾਂ ਦੇ ਗੇੜ ਵਿਚ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Так он блуждает в круге восьмидесяти четырёх лакхов жизней ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7513,
          "is_rahao": false,
          "gurmukhi": "ਏਕੈ ਜਾਲਿ ਫਹਾਏ ਪੰਖੀ ॥",
          "roman": "ēkē jāl fahāē paṅkhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ-ਪੰਛੀ ਇਕ ਮਾਇਆ ਦੇ ਜਾਲ ਵਿਚ ਹੀ (ਪਰਮਾਤਮਾ ਨੇ) ਫਸਾਏ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Птицы-души пойманы Господом в одну и ту же сеть майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7514,
          "is_rahao": false,
          "gurmukhi": "ਰਸਿ ਰਸਿ ਭੋਗ ਕਰਹਿ ਬਹੁ ਰੰਗੀ ॥",
          "roman": "ras ras bhog karah bah raṅgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਆਦ ਲਾ ਲਾ ਕੇ ਇਹ ਅਨੇਕਾਂ ਰੰਗਾਂ ਦੇ ਭੋਗ ਭੋਗਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Смакуя, они продолжают предаваться многим разноцветным наслаждениям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7515,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਸੁ ਭਏ ਕ੍ਰਿਪਾਲ ॥ ਗੁਰਿ ਪੂਰੈ ਤਾ ਕੇ ਕਾਟੇ ਜਾਲ ॥੪॥੧੩॥੮੨॥",
          "roman": "kah nānak jis bhaē kṛipāl ॥ gur pūrē tā kē kāṭē jāl ॥4॥13॥82॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਕਿਰਪਾਲ ਹੁੰਦਾ ਹੈ, ਪੂਰੇ ਗੁਰੂ ਨੇ ਉਸ ਮਨੁੱਖ ਦੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਫਾਹੇ ਕੱਟ ਦਿੱਤੇ ਹਨ ॥੪॥੧੩॥੮੨॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: над кем Бог становится милостив, тому совершенный Гуру разрезает сети привязанности к майе ॥4॥13॥82॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 534,
      "rahao_verse_id": 7522,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7516,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārerī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7517,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕਿਰਪਾ ਤੇ ਮਾਰਗੁ ਪਾਈਐ ॥",
          "roman": "tau kirpā te mārag pāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੀ ਕਿਰਪਾ ਨਾਲ (ਜੀਵਨ ਦਾ ਸਹੀ) ਰਸਤਾ ਲੱਭਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! По Твоей милости находится верный путь жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7518,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਨਾਮੁ ਧਿਆਈਐ ॥",
          "roman": "prabh kirpā te nām dhiāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਸਿਮਰੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Господа совершается памятование Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7519,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਬੰਧਨ ਛੁਟੈ ॥",
          "roman": "prabh kirpā te bandhan chhuṭē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਾਇਆ ਦੇ ਬੰਧਨਾਂ ਦਾ ਜਾਲ ਟੁੱਟ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Так, по милости Господа разрывается сеть уз майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7520,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕਿਰਪਾ ਤੇ ਹਉਮੈ ਤੁਟੈ ॥੧॥",
          "roman": "tau kirpā te haumē tuṭē ॥੧॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਕਿਰਪਾ ਨਾਲ (ਸਾਡੀ ਜੀਵਾਂ ਦੀ) ਹਉਮੈ ਦੂਰ ਹੁੰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! По Твоей милости Хоумэ у нас исчезает ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7521,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮ ਲਾਵਹੁ ਤਉ ਲਾਗਹ ਸੇਵ ॥",
          "roman": "tum lāvah tau lāgah sev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਕਾਸ਼-ਰੂਪ ਪ੍ਰਭੂ! ਸਾਥੋਂ (ਜੀਵਾਂ ਪਾਸੋਂ ਸਾਡੇ ਆਪਣੇ ਉੱਦਮ ਨਾਲ ਤੇਰੀ ਸੇਵਾ-ਭਗਤੀ) ਕੁਝ ਭੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Светоносный! От нас самих, нашими собственными усилиями, ничто не может совершиться в служении и бхакти Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7522,
          "is_rahao": true,
          "gurmukhi": "ਹਮ ਤੇ ਕਛੂ ਨ ਹੋਵੈ ਦੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ham te kachhū na hovē dev ॥੧॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਆਪ ਹੀ ਸਾਨੂੰ) ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਲਾਵੇਂ ਤਾਂ ਅਸੀਂ ਲੱਗ ਸਕਦੇ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если Ты Сам вводишь нас в служение и бхакти, тогда мы можем в них пребывать ॥੧॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7523,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਤਾ ਗਾਵਾ ਬਾਣੀ ॥",
          "roman": "tudh bhāvē tā gāvā bāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜੇ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗੇ ਤਾਂ ਮੈਂ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਗਾ ਸਕਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Если Тебе угодно, тогда я могу петь речь Твоей хвалы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7524,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਤਾ ਸਚੁ ਵਖਾਣੀ ॥",
          "roman": "tudh bhāvē tā sach vakhāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਪਸੰਦ ਆਵੇ ਤਾਂ ਮੈਂ ਤੇਰਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਨਾਮ ਉਚਾਰ ਸਕਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Если Тебе угодно, тогда я могу произносить Твоё вечно-пребывающее Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7525,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਤਾ ਸਤਿਗੁਰ ਮਇਆ ॥",
          "roman": "tudh bhāvē tā satgur mēā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੈਨੂੰ ਚੰਗਾ ਲੱਗੇ ਤਾਂ (ਜੀਵਾਂ ਉਤੇ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Если Тебе угодно, тогда на существа нисходит милость Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7526,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਪ੍ਰਭ ਤੇਰੀ ਦਇਆ ॥੨॥",
          "roman": "sarab sukhā prabh terī daiā ॥੨॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਸੁਖ ਤੇਰੀ ਮਿਹਰ ਵਿਚ ਹੀ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Все блага заключены только в Твоей милости ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7527,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਵੈ ਸੋ ਨਿਰਮਲ ਕਰਮਾ ॥",
          "roman": "jo tudh bhāvē so nirmal karmā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜੇਹੜਾ ਕੰਮ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗ ਜਾਏ ਉਹੀ ਪਵਿਤ੍ਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Чисто лишь то деяние, которое угодно Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7528,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਵੈ ਸੋ ਸਚੁ ਧਰਮਾ ॥",
          "roman": "jo tudh bhāvē so sach dharmā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਵਨ-ਮਰਯਾਦਾ ਤੈਨੂੰ ਪਸੰਦ ਆ ਜਾਏ ਉਹੀ ਅਟੱਲ ਮਰਯਾਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот жизненный уклад, который Тебе угоден, один только и есть непреложный уклад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7529,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਗੁਣ ਤੁਮ ਹੀ ਪਾਸਿ ॥",
          "roman": "sarab nidhān guṇ tum hī pās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਸਾਰੇ ਗੁਣ ਤੇਰੇ ਹੀ ਵੱਸ ਵਿਚ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Все сокровища и все добродетели находятся только у Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7530,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਸਾਹਿਬੁ ਸੇਵਕ ਅਰਦਾਸਿ ॥੩॥",
          "roman": "tū sāhib sevak ardās ॥੩॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹੀ ਮੇਰਾ ਮਾਲਕ ਹੈਂ, ਮੈਂ ਸੇਵਕ ਦੀ (ਤੇਰੇ ਅੱਗੇ ਹੀ) ਅਰਦਾਸ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — мой Владыка; я — слуга, и моя молитва обращена только к Тебе ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7531,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਨਿਰਮਲੁ ਹੋਇ ਹਰਿ ਰੰਗਿ ॥",
          "roman": "man tan nirmal hoi har rang ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਪਿਆਰ ਵਿਚ (ਟਿਕੇ ਰਿਹਾਂ) ਮਨ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пребывая в любви к Богу, ум становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7532,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਪਾਵਉ ਸਤਸੰਗਿ ॥",
          "roman": "sarab sukhā pāvau satsang ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਟਿਕੇ ਰਿਹਾਂ (ਮੈਨੂੰ ਇਉਂ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ ਕਿ) ਮੈਂ ਸਾਰੇ ਸੁਖ ਲੱਭ ਲੈਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Садхсангате, я, как мне кажется, нахожу все блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7533,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਤੇਰੈ ਰਹੈ ਮਨੁ ਰਾਤਾ ॥",
          "roman": "nām terē rahē man rātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਦਾ) ਮਨ ਤੇਰੇ ਨਾਮ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Чей ум окрашивается в Твоё Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7534,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਕਲਿਆਣੁ ਨਾਨਕ ਕਰਿ ਜਾਤਾ ॥੪॥੧੪॥੮੩॥",
          "roman": "ihu kalyāṇ nānak kar jātā ॥੪॥੧੪॥੮੩॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਇਸੇ ਨੂੰ ਹੀ ਸ੍ਰੇਸ਼ਟ ਆਨੰਦ ਕਰ ਕੇ ਸਮਝਦਾ ਹੈ ॥੪॥੧੪॥੮੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот считает именно это высшим блаженством ॥੪॥੧੪॥੮੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 535,
      "rahao_verse_id": 7541,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7535,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārerī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7536,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਰਸਾ ਜੇਤੇ ਤੈ ਚਾਖੇ ॥",
          "roman": "ān rasā jete tē chākhe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੀ ਜੀਭ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰਸ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਜਿਤਨੇ ਭੀ ਰਸ ਤੂੰ ਚੱਖਦੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой язык! Все прочие вкусы, которые ты продолжаешь вкушать помимо вкуса Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7537,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨ ਤ੍ਰਿਸਨਾ ਤੇਰੀ ਲਾਥੇ ॥",
          "roman": "nimakh na trisnā terī lāthe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਨਾਲ) ਤੇਰੀ ਤ੍ਰਿਸ਼ਨਾ ਅੱਖ ਦੇ ਝਮਕਣ ਸਮੇ ਤਕ ਭੀ ਨਹੀਂ ਦੂਰ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "ими твоя жажда не уходит даже на миг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7538,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸ ਕਾ ਤੂੰ ਚਾਖਹਿ ਸਾਦੁ ॥",
          "roman": "har ras kā tū chākhah sād ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰਸ ਦਾ ਸੁਆਦ ਚੱਖੇਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы ты вкусил вкус Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7539,
          "is_rahao": false,
          "gurmukhi": "ਚਾਖਤ ਹੋਇ ਰਹਹਿ ਬਿਸਮਾਦੁ ॥੧॥",
          "roman": "chākhat hoi rahahi bismād ॥੧॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੱਖਦਿਆਂ ਹੀ ਤੂੰ (ਉਸ ਵਿਚ) ਮਸਤ ਹੋ ਜਾਏਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "то, вкусив его, ты сразу опьянел бы им ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7540,
          "is_rahao": true,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਰਸਨਾ ਪੀਉ ਪਿਆਰੀ ॥",
          "roman": "amrit rasnā pīu piārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੀ) ਪਿਆਰੀ ਜੀਭ! ਤੂੰ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਰਸ ਪੀ।"
            },
            "sahib_singh_ru": {
              "main": "О мой дорогой язык! Пей нектар Имени, дающий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7541,
          "is_rahao": true,
          "gurmukhi": "ਇਹ ਰਸ ਰਾਤੀ ਹੋਇ ਤ੍ਰਿਪਤਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ih ras rātī hoi triptārī ॥੧॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਭ ਇਸ ਨਾਮ-ਰਸ ਵਿਚ ਮਸਤ ਹੋ ਜਾਂਦੀ ਹੈ, ਉਹ (ਹੋਰ ਰਸਾਂ ਵਲੋਂ) ਸੰਤੁਸ਼ਟ ਹੋ ਜਾਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Язык, опьяневший этим вкусом Имени, становится удовлетворённым и уже не тянется к прочим вкусам ॥੧॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7542,
          "is_rahao": false,
          "gurmukhi": "ਹੇ ਜਿਹਵੇ ਤੂੰ ਰਾਮ ਗੁਣ ਗਾਉ ॥",
          "roman": "he jihve tū rām guṇ gāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੀ) ਜੀਭ! ਤੂੰ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ, ਪਲ ਪਲ ਹਰ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой язык! Пой качества Бога, каждое мгновение, всегда помни Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7543,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨਿਮਖ ਹਰਿ ਹਰਿ ਹਰਿ ਧਿਆਉ ॥",
          "roman": "nimakh nimakh har har har dhiāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਦੁਨੀਆ ਦੇ ਰਸਾਂ ਵਲੋਂ ਸੰਤੁਸ਼ਟ ਹੋਣਾ ਹੈ, ਤਾਂ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਤੋਂ ਬਿਨਾ) ਹੋਰ (ਫਿੱਕੇ ਬੋਲ) ਨਹੀਂ ਸੁਣਨੇ ਚਾਹੀਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Если хочешь насытиться по отношению к мирским вкусам, не следует слушать ничего иного, кроме хвалы Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7544,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਨ ਸੁਨੀਐ ਕਤਹੂੰ ਜਾਈਐ ॥",
          "roman": "ān na suṇīai katahū̃ jāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਕਿਤੇ (ਵਿਕਾਰ ਪੈਦਾ ਕਰਨ ਵਾਲੇ ਥਾਂਵਾਂ ਤੇ) ਨਹੀਂ ਜਾਣਾ ਚਾਹੀਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Не следует идти куда-либо ещё, в места, порождающие пороки, кроме как в Садхсангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7545,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਵਡਭਾਗੀ ਪਾਈਐ ॥੨॥",
          "roman": "sādhsangat vaḍbhāgī pāīai ॥੨॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਸਾਧ ਸੰਗਤਿ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਹੀ ਮਿਲਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но Садхсангат обретается только по великой удаче ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7546,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਜਿਹਵੇ ਆਰਾਧਿ ॥ ਪਾਰਬ੍ਰਹਮ ਠਾਕੁਰ ਆਗਾਧਿ ॥",
          "roman": "āṭh pahar jihve ārādh ॥ pārbraham ṭhākur āgādh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੀ) ਜੀਭ! ਅੱਠੇ ਪਹਰ ਸਿਮਰਨ ਕਰ, ਅਥਾਹ (ਗੁਣਾਂ ਵਾਲੇ) ਠਾਕੁਰ ਪਾਰਬ੍ਰਹਮ ਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О мой язык! Все восемь прахаров помни Непостижимого Парбрахма, Владыку бездонных достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7547,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਸਦਾ ਸੁਹੇਲੀ ॥",
          "roman": "īhā ūhā sadā suhēlī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਕਰਨ ਵਾਲੇ ਦੀ ਜ਼ਿੰਦਗੀ) ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਸਦਾ ਸੁਖੀ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Жизнь того, кто помнит, и здесь, и в ином мире всегда становится счастливой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7548,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵਤ ਰਸਨ ਅਮੋਲੀ ॥੩॥",
          "roman": "har guṇ gāvat rasan amolī ॥੩॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਜੀਭ ਬੜੀ ਕੀਮਤ ਵਾਲੀ ਬਣ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда язык поёт качества Бога, он становится бесценным ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7549,
          "is_rahao": false,
          "gurmukhi": "ਬਨਸਪਤਿ ਮਉਲੀ ਫਲ ਫੁਲ ਪੇਡੇ ॥",
          "roman": "banaspat maulī phal phul peḍe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਠੀਕ ਹੈ ਕਿ ਪਰਮਾਤਮਾ ਦੀ ਕੁਦਰਤਿ ਵਿਚ ਸਾਰੀ) ਬਨਸਪਤੀ ਖਿੜੀ ਰਹਿੰਦੀ ਹੈ, ਰੁੱਖਾਂ ਬੂਟਿਆਂ ਨੂੰ ਫੁੱਲ ਫਲ ਲੱਗੇ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Да, в творении Бога вся растительность цветёт, деревья и растения покрыты цветами и плодами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7550,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਰਸ ਰਾਤੀ ਬਹੁਰਿ ਨ ਛੋਡੇ ॥",
          "roman": "ih ras rātī bahur na chhoḍe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਿਸ ਮਨੁੱਖ ਦੀ ਜੀਭ ਨਾਮ-ਰਸ ਵਿਚ ਮਸਤ ਹੈ ਉਹ (ਬਾਹਰ-ਦਿੱਸਦੀ ਸੁੰਦਰਤਾ ਨੂੰ ਤੱਕ ਕੇ ਨਾਮ-ਰਸ ਨੂੰ) ਕਦੇ ਨਹੀਂ ਛੱਡਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "но человек, чей язык опьянён вкусом Имени, никогда не оставляет его даже при виде внешней красоты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7551,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਨ ਰਸ ਕਸ ਲਵੈ ਨ ਲਾਈ ॥",
          "roman": "ān na ras kas lavē na lāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ ਦੁਨੀਆ ਵਾਲੇ) ਹੋਰ ਕਿਸਮ ਕਿਸਮ ਦੇ ਰਸ (ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰਸ ਦੀ) ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "В его глазах никакие другие, самые разные вкусы не могут сравниться со вкусом Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7552,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰ ਭਏ ਹੈ ਸਹਾਈ ॥੪॥੧੫॥੮੪॥",
          "roman": "kah nānak gur bhae hē sahāī ॥੪॥੧੫॥੮੪॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦਾ ਸਹਾਈ ਸਤਿਗੁਰੂ ਬਣਦਾ ਹੈ ॥੪॥੧੫॥੮੪॥"
            },
            "sahib_singh_ru": {
              "main": "говорит Нанак: таков тот человек, чьим помощником становится Сатгуру ॥੪॥੧੫॥੮੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 536,
      "rahao_verse_id": null,
      "rahao_theme": "",
