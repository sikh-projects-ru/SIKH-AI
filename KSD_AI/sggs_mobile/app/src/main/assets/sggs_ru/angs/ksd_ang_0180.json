      "lines": [
        {
          "verse_id": 7553,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਗੁਆਰੇਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī guārerī mahlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7554,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮੰਦਰੁ ਤਨੁ ਸਾਜੀ ਬਾਰਿ ॥",
          "roman": "man mandar tan sājī bār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਸ਼ਾਹ ਨੇ ਆਪਣੇ ਰਹਿਣ ਵਾਸਤੇ ਮਨੁੱਖ ਦੇ) ਮਨ ਨੂੰ ਸੋਹਣਾ ਘਰ ਬਣਾਇਆ ਹੋਇਆ ਹੈ ਤੇ ਮਨੁੱਖਾ ਸਰੀਰ ਨੂੰ (ਭਾਵ, ਗਿਆਨ-ਇੰਦ੍ਰਰਿਆਂ ਨੂੰ, ਉਸ ਘਰ ਦੀ ਰਾਖੀ ਲਈ) ਵਾੜ ਬਣਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Царь-Бог устроил человеческий ум как прекрасный дом для Своего пребывания, а человеческое тело, то есть органы чувств, сделал оградой для охраны этого дома."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
