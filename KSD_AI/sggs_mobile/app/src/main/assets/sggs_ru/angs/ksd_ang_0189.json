{
  "ang": 189,
  "shabads": [
    {
      "shabad_id": 566,
      "rahao_verse_id": 7992,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7990,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਜਨਮ ਮਰਣ ਤੇ ਛੋਟ ॥੧॥",
          "roman": "sant prasād janam maraṇ te chhoṭ ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਸੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਮਨੁੱਖ ਨੂੰ) ਜਨਮ ਮਰਨ (ਦੇ ਚੱਕਰ) ਤੋਂ ਖ਼ਲਾਸੀ ਮਿਲ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру-святого человек освобождается от круга рождений и смертей ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7991,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਕਾ ਦਰਸੁ ਪੂਰਨ ਇਸਨਾਨੁ ॥",
          "roman": "sant kā daras pūran isnān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ-ਸੰਤ ਦਾ ਦਰਸਨ (ਹੀ) ਮੁਕੰਮਲ (ਤੀਰਥ-) ਇਸ਼ਨਾਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Видение Гуру-святого и есть полное омовение в тиртхах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7992,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤ ਕ੍ਰਿਪਾ ਤੇ ਜਪੀਐ ਨਾਮੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sant kirpā te japīai nām ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਸੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру-святого становится возможным повторять Божье Имя ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7993,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੈ ਸੰਗਿ ਮਿਟਿਆ ਅਹੰਕਾਰੁ ॥",
          "roman": "sant kē saṅg miṭiā ahaṅkār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ-ਸੰਤ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਿਹਾਂ) ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) В общении с Гуру-святым исчезает гордыня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7994,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿਸਟਿ ਆਵੈ ਸਭੁ ਏਕੰਕਾਰੁ ॥੨॥",
          "roman": "drisṭ āvē sabh ekaṅkār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿਣ ਵਾਲੇ ਮਨੁੱਖ ਨੂੰ) ਹਰ ਥਾਂ ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਨਜ਼ਰੀਂ ਆਉਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "(и человеку, пребывающему в обществе Гуру,) повсюду видится один Единый Бог ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7995,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸੁਪ੍ਰਸੰਨ ਆਏ ਵਸਿ ਪੰਚਾ ॥",
          "roman": "sant suprasaṅn āe vas pañchā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ-ਸੰਤ ਮਿਹਰਬਾਨ ਹੋ ਜਾਏ, (ਕਾਮਾਦਿਕ) ਪੰਜੇ (ਦੂਤ) ਉਸ ਦੇ ਵੱਸ ਵਿਚ ਆ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Если Гуру-святой становится милостив к человеку, то пятеро (внутренних врагов, начиная с похоти) оказываются у него под властью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7996,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਨਾਮੁ ਰਿਦੈ ਲੈ ਸੰਚਾ ॥੩॥",
          "roman": "amrit nām ridē lē sañchā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਇਕੱਠਾ ਕਰ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "такой человек собирает в своём сердце нектарное Имя Хари, дарующее духовную жизнь ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7997,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕਾ ਪੂਰਾ ਕਰਮ ॥",
          "roman": "kaho nānak jā kā pūrā karam ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਦੀ ਵੱਡੀ (ਚੰਗੀ) ਕਿਸਮਤਿ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "(Но) Нанак говорит: только у того, чья судьба по-настоящему велика,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 7998,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਭੇਟੇ ਸਾਧੂ ਕੇ ਚਰਨ ॥੪॥੪੬॥੧੧੫॥",
          "roman": "tis bheṭe sādhū ke charan ॥4॥46॥115॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ (ਹੀ) ਗੁਰੂ ਦੇ ਚਰਨ (ਪਰਸਣੇ) ਮਿਲਦੇ ਹਨ ॥੪॥੪੬॥੧੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "тому человеку и дано припасть к стопам Гуру ॥4॥੪੬॥੧੧੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 567,
      "rahao_verse_id": 8003,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 7999,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8000,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਜਪਤ ਕਮਲੁ ਪਰਗਾਸੈ ॥",
          "roman": "har guṇ japat kamal pargāsē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ (ਹਿਰਦਾ-) ਕੌਲ-ਫੁੱਲ ਖਿੜ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда поют качества-гуны Всевышнего, лотос сердца расцветает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8001,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਤ੍ਰਾਸ ਸਭ ਨਾਸੈ ॥੧॥",
          "roman": "har simrat trās sabh nāsē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Имя Всевышнего, всякий страх исчезает. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8002,
          "is_rahao": true,
          "gurmukhi": "ਸਾ ਮਤਿ ਪੂਰੀ ਜਿਤੁ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥",
          "roman": "sā mat pūrī jit har guṇ gāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹੀ ਅਕਲ ਉਕਾਈ ਕਰਨ ਤੋਂ ਬਚੀ ਹੋਈ ਸਮਝੋ, ਜਿਸ ਅਕਲ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Только тот разум считай по-настоящему цельным и не сбивающимся с пути, благодаря которому человек поёт качества Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8003,
          "is_rahao": true,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਸਾਧੂ ਸੰਗੁ ਪਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "vaḍē bhāg sādhū sang pāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਅਕਲ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਪੈਦਾ ਹੁੰਦੀ ਹੈ ਜੋ) ਵੱਡੀ ਕਿਸਮਤਿ ਨਾਲ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но такой разум возникает в человеке, который по великой удаче обретает общение с Гуру. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8004,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਪਾਈਐ ਨਿਧਿ ਨਾਮਾ ॥",
          "roman": "sādhsang pāīai nidh nāmā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿੱਚ ਰਿਹਾਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਖ਼ਜ਼ਾਨਾ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В общении с Гуру обретается сокровище Имени Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8005,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਪੂਰਨ ਸਭਿ ਕਾਮਾ ॥੨॥",
          "roman": "sādhsang pūran sabh kāmā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿੱਚ ਰਿਹਾਂ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и в общении с Гуру все дела завершаются успешно. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8006,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਜਨਮੁ ਪਰਵਾਣੁ ॥",
          "roman": "har kī bhagat janam parvāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕੀਤਿਆਂ ਮਨੁੱਖਾ ਜਨਮ ਸਫਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Через преданность Всевышнему человеческая жизнь становится успешной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8007,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਨਾਮੁ ਵਖਾਣੁ ॥੩॥",
          "roman": "gur kirpā tē nām vakhāṇ ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਨਾ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਹੀ) ਮਿਲਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но такая преданность, такое произнесение Имени Всевышнего, приходит только по милости Гуру. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8008,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸੋ ਜਨੁ ਪਰਵਾਨੁ ॥",
          "roman": "kah Nānak so jan parvān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਸਿਰਫ਼) ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੀ ਦਰਗਾਹ ਵਿਚ) ਕਬੂਲ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: только тот человек принимается при дворе Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8009,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਵਸੈ ਭਗਵਾਨੁ ॥੪॥੪੭॥੧੧੬॥",
          "roman": "jā kē ridē vasē bhagvān ॥4॥47॥116॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਸਦਾ) ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਵੱਸਦਾ ਹੈ ॥੪॥੪੭॥੧੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце всегда пребывает Всевышний и Его Имя. ॥4॥47॥116॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 568,
      "rahao_verse_id": 8014,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8010,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8011,
          "is_rahao": false,
          "gurmukhi": "ਏਕਸੁ ਸਿਉ ਜਾ ਕਾ ਮਨੁ ਰਾਤਾ ॥",
          "roman": "ēkas siu jā kā man rātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਹੀ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей ум по милости Гуру окрашен только одним Всевышним,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8012,
          "is_rahao": false,
          "gurmukhi": "ਵਿਸਰੀ ਤਿਸੈ ਪਰਾਈ ਤਾਤਾ ॥੧॥",
          "roman": "visrī tisē parāī tātā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹੋਰਨਾਂ ਨਾਲ ਈਰਖਾ ਕਰਨੀ ਭੁੱਲ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "забывает зависть к другим. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8013,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਗੋਬਿੰਦ ਨ ਦੀਸੈ ਕੋਈ ॥",
          "roman": "bin Gobind na dīsē koī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਹੁੰਦੀ ਹੈ, ਉਸ ਨੂੰ ਕਿਤੇ ਭੀ) ਗੋਬਿੰਦ ਤੋਂ ਬਿਨਾਂ ਹੋਰ ਕੋਈ (ਦੂਜਾ) ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тому, на ком есть милость Гуру, нигде не видится никто иной, кроме Гобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8014,
          "is_rahao": true,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਕਰਤਾ ਸੋਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karan karāvan kartā soī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਹਰ ਥਾਂ) ਉਹੀ ਕਰਤਾਰ ਦਿੱਸਦਾ ਹੈ ਜੋ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਵਾਲਾ ਹੈ ਤੇ ਸਭ ਜੀਵਾਂ ਪਾਸੋਂ ਕਰਾਣ ਦੀ ਤਾਕਤ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Ему везде виден только Творец — Тот, кто способен всё делать и даёт силу всем существам действовать. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8015,
          "is_rahao": false,
          "gurmukhi": "ਮਨਹਿ ਕਮਾਵੈ ਮੁਖਿ ਹਰਿ ਹਰਿ ਬੋਲੈ ॥",
          "roman": "manah kamāvē mukh har har bolē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਿਹੜਾ ਮਨੁੱਖ) ਮਨ ਲਾ ਕੇ ਸਿਮਰਨ ਦੀ ਕਮਾਈ ਕਰਦਾ ਹੈ ਤੇ ਮੂੰਹੋਂ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который с полной сосредоточенностью трудится в симране и устами постоянно произносит Имя Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8016,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਇਤ ਉਤ ਕਤਹਿ ਨ ਡੋਲੈ ॥੨॥",
          "roman": "so jan it ut kateh na ḍolē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਸੁੱਚੇ ਆਤਮਕ ਜੀਵਨ ਦੀ ਪੱਧਰ ਤੋਂ) ਕਦੇ ਭੀ ਨਹੀਂ ਡੋਲਦਾ, ਨਾਹ ਇਸ ਲੋਕ ਵਿਚ ਤੇ ਨਾਹ ਹੀ ਪਰਲੋਕ ਵਿਚ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "никогда не колеблется на уровне чистой духовной жизни — ни в этом мире, ни в ином. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8017,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹਰਿ ਧਨੁ ਸੋ ਸਚ ਸਾਹੁ ॥",
          "roman": "jā kē har dhan so sach sāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਪਾਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਧਨ ਹੈ, ਉਹ ਐਸਾ ਸ਼ਾਹੂਕਾਰ ਹੈ, ਜੋ ਸਦਾ ਹੀ ਸ਼ਾਹੂਕਾਰ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, у кого есть богатство Имени Всевышнего, — истинный богач, и таким богачом он остаётся всегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8018,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਕਰਿ ਦੀਨੋ ਵਿਸਾਹੁ ॥੩॥",
          "roman": "gur pūrē kar dīno visāh ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ (ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਉਸ ਦੀ) ਸਾਖ ਬਣਾ ਦਿੱਤੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру утвердил его доброе имя в присутствии Всевышнего. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8019,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਪੁਰਖੁ ਮਿਲਿਆ ਹਰਿ ਰਾਇਆ ॥",
          "roman": "jīvan purakh miliā har rāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਖ-(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਸਹਾਰਾ ਪ੍ਰਭੂ ਮਿਲ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Скажи: тот человек, которому по милости Гуру встретился Всепроникающий Господь, опора жизни всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8020,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪਰਮ ਪਦੁ ਪਾਇਆ ॥੪॥੪੮॥੧੧੭॥",
          "roman": "kah Nānak param pad pāiā ॥4॥48॥117॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸਨੇ ਸਭ ਤੋਂ ਉੱਚਾ ਆਤਮਕ ਦਰਜਾ ਹਾਸਲ ਕਰ ਲਿਆ ਹੈ ॥੪॥੪੮॥੧੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, достиг высочайшего духовного состояния. ॥4॥48॥117॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 569,
      "rahao_verse_id": 8025,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8021,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8022,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਭਗਤ ਕੈ ਪ੍ਰਾਨ ਅਧਾਰੁ ॥",
          "roman": "nām bhagat kē prān adhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ ਕਰਨ ਵਾਲੇ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਸ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਸਹਾਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В сердце преданного Имя Всевышнего — опора его жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8023,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੋ ਧਨੁ ਨਾਮੋ ਬਿਉਹਾਰੁ ॥੧॥",
          "roman": "nāmo dhan nāmo biuhār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਹੀ ਉਸ ਦੇ ਵਾਸਤੇ ਧਨ ਹੈ, ਤੇ ਨਾਮ ਹੀ ਉਸ ਦੇ ਵਾਸਤੇ (ਅਸਲੀ) ਵਣਜ-ਵਪਾਰ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Имя для него и есть богатство, и Имя для него — подлинная торговля. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8024,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਵਡਾਈ ਜਨੁ ਸੋਭਾ ਪਾਏ ॥",
          "roman": "nām vaḍāī jan sobhā pāē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਹੈ, ਉਹ ਮਨੁੱਖ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਵਡਿਆਈ ਹਾਸਲ ਕਰਦਾ ਹੈ; ਸੋਭਾ ਖੱਟਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, в чьём сердце есть Имя Всевышнего, обретает величие и заслуживает славу в этом и ином мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8025,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਆਪਿ ਦਿਵਾਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā jis āp divāē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਹਰਿ-ਨਾਮ ਉਸੇ ਮਨੁੱਖ ਨੂੰ ਮਿਲਦਾ ਹੈ) ਜਿਸ ਨੂੰ ਮਿਹਰ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਆਪ (ਗੁਰੂ ਪਾਸੋਂ) ਦਿਵਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но это Имя получает только тот, кому Сам Всевышний по Своей милости даёт его через Гуру. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8026,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਭਗਤ ਕੈ ਸੁਖ ਅਸਥਾਨੁ ॥",
          "roman": "nām bhagat kē sukh asthān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਭਗਤ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆਤਮਕ ਆਨੰਦ ਦੇਣ ਦਾ ਵਸੀਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Всевышнего в сердце преданного — средство духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8027,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਰਤੁ ਸੋ ਭਗਤੁ ਪਰਵਾਨੁ ॥੨॥",
          "roman": "nām rat so bhagat parvān ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਹੋਇਆ ਹੈ, ਉਹੀ ਭਗਤ ਹੈ। ਉਹ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਕਬੂਲ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто окрашен в цвет Имени Всевышнего, и есть истинный преданный; он принят в присутствии Всевышнего. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8028,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਨ ਕਉ ਧਾਰੈ ॥",
          "roman": "har kā nām jan kau dhārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਪਰਮਾਤਮਾ ਦੇ) ਸੇਵਕ ਨੂੰ ਸਹਾਰਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Всевышнего поддерживает Его слугу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8029,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਜਨੁ ਨਾਮੁ ਸਮਾਰੈ ॥੩॥",
          "roman": "sās sās jan nām samārē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਆਪਣੇ ਇਕ ਇਕ ਸਾਹ ਦੇ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਸਾਂਭ ਕੇ ਰੱਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и слуга с каждым дыханием хранит Имя Всевышнего в своём сердце. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8030,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਸੁ ਪੂਰਾ ਭਾਗੁ ॥",
          "roman": "kah Nānak jis pūrā bhāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦੀ ਵੱਡੀ ਕਿਸਮਤ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: у кого великая удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8031,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਸੰਗਿ ਤਾ ਕਾ ਮਨੁ ਲਾਗੁ ॥੪॥੪੯॥੧੧੮॥",
          "roman": "nām sang tā kā man lāg ॥4॥49॥118॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ (ਹੀ) ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨਾਲ ਪਰਚਦਾ ਹੈ ॥੪॥੪੯॥੧੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "только у того ум прилепляется к Имени Всевышнего. ॥4॥49॥118॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 570,
      "rahao_verse_id": 8036,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8032,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8033,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਹਰਿ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "sant prasād har nām dhiāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਦੋਂ ਤੋਂ) ਗੁਰੂ-ਸੰਤ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਰਿਹਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! С тех пор как по милости святого Гуру я созерцаю Имя Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8034,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਤੇ ਧਾਵਤੁ ਮਨੁ ਤ੍ਰਿਪਤਾਇਆ ॥੧॥",
          "roman": "tab tē dhāvat man triptāiā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਤੋਂ (ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਦੌੜਨ ਵਾਲਾ (ਮੇਰਾ) ਮਨ ਤ੍ਰਿਪਤ ਹੋ ਗਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "с тех пор мой ум, прежде бегавший за майей, насытился. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8035,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖ ਬਿਸ੍ਰਾਮੁ ਪਾਇਆ ਗੁਣ ਗਾਇ ॥",
          "roman": "sukh bisrām pāiā guṇ gāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾ ਕੇ ਮੈਂ (ਉਹ) ਆਤਮਕ ਆਨੰਦ ਦਾ ਦਾਤਾ (ਪਰਮਾਤਮਾ) ਲੱਭ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру, воспевая качества Всевышнего, я нашёл Того, кто даёт духовную радость и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8036,
          "is_rahao": true,
          "gurmukhi": "ਸ੍ਰਮੁ ਮਿਟਿਆ ਮੇਰੀ ਹਤੀ ਬਲਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sram miṭiā merī hatī balāi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਮੇਰੀ) ਦੌੜ-ਭੱਜ ਮਿਟ ਗਈ ਹੈ, (ਮੇਰੀ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਬਲਾ ਮਰ ਮੁੱਕ ਗਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь моя беготня за майей исчезла, и беда жажды майи умерла и закончилась. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8037,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਅਰਾਧਿ ਭਗਵੰਤਾ ॥",
          "roman": "charan kamal arādh bhagvantā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਭਗਵਾਨ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰ ਕੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру, сосредоточившись на прекрасных стопах Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8038,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨ ਤੇ ਮਿਟੀ ਮੇਰੀ ਚਿੰਤਾ ॥੨॥",
          "roman": "har simran tē miṭī merī chintā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਨਾਲ ਮੇਰੀ (ਹਰੇਕ ਕਿਸਮ ਦੀ) ਚਿੰਤਾ ਮਿਟ ਗਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "через памятование Имени Всевышнего вся моя тревога исчезла. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8039,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤਜਿ ਅਨਾਥੁ ਏਕ ਸਰਣਿ ਆਇਓ ॥",
          "roman": "sabh taj anāth ēk saraṇ āiō ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਦੋਂ) ਮੈਂ ਅਨਾਥ ਹੋਰ ਸਾਰੇ ਆਸਰੇ ਛੱਡ ਕੇ ਇਕ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਆ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда я, бесприютный, оставив все прочие опоры, пришёл под защиту одного Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8040,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਅਸਥਾਨੁ ਤਬ ਸਹਜੇ ਪਾਇਓ ॥੩॥",
          "roman": "ūch asthān tab sahjē pāiō ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਮੈਂ ਉਹ ਸਭ (ਟਿਕਾਣਿਆਂ ਤੋਂ) ਉੱਚਾ ਟਿਕਾਣਾ ਪਰਾਪਤ ਕਰ ਲਿਆ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тогда, утвердившись в духовной уравновешенности, я обрёл высочайшее из всех состояний. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8041,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਭਰਮੁ ਭਉ ਨਸਿਆ ॥",
          "roman": "dūkh dard bharam bhau nasiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਮੇਰਾ ਹਰੇਕ ਕਿਸਮ ਦਾ) ਦੁੱਖ-ਦਰਦ, ਭਟਕਣ ਤੇ ਡਰ ਦੂਰ ਹੋ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь всякая моя боль и страдание, блуждание и страх ушли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8042,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣਹਾਰੁ ਨਾਨਕ ਮਨਿ ਬਸਿਆ ॥੪॥੫੦॥੧੧੯॥",
          "roman": "karaṇhār Nānak man basiā ॥4॥50॥119॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਸਿਰਜਣਹਾਰ ਪਰਮਾਤਮਾ ਮੇਰੇ ਮਨ ਵਿਚ ਵੱਸ ਗਿਆ ਹੈ ॥੪॥੫੦॥੧੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, — скажи: по милости Гуру Творец поселился в моём уме. ॥4॥50॥119॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
