          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8044,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਕਰਿ ਟਹਲ ਰਸਨਾ ਗੁਣ ਗਾਵਉ ॥",
          "roman": "kar kar ṭahal rasnā guṇ gāvau ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਆਪਣੇ ਗੁਰੂ ਦੀ ਮਿਹਰ ਸਦਕਾ) ਮੈਂ ਆਪਣੇ ਹੱਥਾਂ ਨਾਲ (ਗੁਰਮੁਖਾਂ ਦੀ) ਸੇਵਾ ਕਰਦਾ ਹਾਂ ਤੇ ਜੀਭ ਨਾਲ (ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости моего Гуру я своими руками служу гурмukhам, а языком пою качества Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
