{
  "ang": 190,
  "shabads": [
    {
      "shabad_id": 571,
      "rahao_verse_id": 8047,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8045,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਠਾਕੁਰ ਕੈ ਮਾਰਗਿ ਧਾਵਉ ॥੧॥",
          "roman": "charan ṭhākur kē mārag dhāvau ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪੈਰਾਂ ਨਾਲ ਮੈਂ ਪਰਮਾਤਮਾ ਦੇ ਰਸਤੇ ਉਤੇ ਚੱਲ ਰਿਹਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а ногами иду по пути Всевышнего. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8046,
          "is_rahao": true,
          "gurmukhi": "ਭਲੋ ਸਮੋ ਸਿਮਰਨ ਕੀ ਬਰੀਆ ॥",
          "roman": "bhalo samo simran kī barīā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ! ਮਨੁੱਖਾ ਜਨਮ ਦਾ ਇਹ) ਸੋਹਣਾ ਸਮਾਂ (ਤੈਨੂੰ ਮਿਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Это прекрасное время человеческой жизни тебе даровано."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8047,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮੁ ਭੈ ਪਾਰਿ ਉਤਰੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simrat nām bhē pār utrīā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਮਨੁੱਖਾ ਜਨਮ ਹੀ ਪਰਮਾਤਮਾ ਦੇ) ਸਿਮਰਨ ਦਾ ਵੇਲਾ ਹੈ, (ਇਸ ਮਨੁੱਖਾ ਜਨਮ ਵਿਚ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ (ਸੰਸਾਰ ਦੇ ਅਨੇਕਾਂ) ਡਰਾਂ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Именно человеческая жизнь — время для памятования Всевышнего; именно в этой человеческой жизни, помня Его Имя, можно переправиться через множество страхов мира. ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8048,
          "is_rahao": false,
          "gurmukhi": "ਨੇਤ੍ਰ ਸੰਤਨ ਕਾ ਦਰਸਨੁ ਪੇਖੁ ॥",
          "roman": "nētr santan kā darsan pēkh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ ਭੀ) ਆਪਣੀਆਂ ਅੱਖਾਂ ਨਾਲ ਗੁਰਮੁਖਾਂ ਦਾ ਦਰਸਨ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Ты тоже своими глазами созерцай гурмукхов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8049,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਵਿਨਾਸੀ ਮਨ ਮਹਿ ਲੇਖੁ ॥੨॥",
          "roman": "prabh avināsī man mahi lēkh ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ) ਆਪਣੇ ਮਨ ਵਿਚ ਅਬਿਨਾਸੀ ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਦਾ ਲੇਖ ਲਿਖਦਾ ਰਹੁ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, пребывая в их обществе, пиши в своём уме запись памятования Нетленного Всевышнего. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8050,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਕੀਰਤਨੁ ਸਾਧ ਪਹਿ ਜਾਇ ॥",
          "roman": "suṇ kīrtan sādh peh jāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਜਾ ਕੇ ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਸੁਣਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Иди в общение с Гуру и слушай песни хвалы Всевышнему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8051,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਕੀ ਤ੍ਰਾਸ ਮਿਟਾਇ ॥੩॥",
          "roman": "janam maraṇ kī trās miṭāi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇਸ ਤਰ੍ਹਾਂ ਜਨਮ ਮਰਨ ਵਿਚ ਪਾਣ ਵਾਲੀ ਆਤਮਕ ਮੌਤ ਦਾ ਡਰ (ਆਪਣੇ ਅੰਦਰੋਂ) ਦੂਰ ਕਰ ਲੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и так удали изнутри страх духовной смерти, которая ведёт в круг рождения и умирания. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8052,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਠਾਕੁਰ ਉਰਿ ਧਾਰਿ ॥",
          "roman": "charaṇ kamal ṭhākur ur dhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "Храни в своём сердце прекрасные стопы Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8053,
          "is_rahao": false,
          "gurmukhi": "ਦੁਲਭ ਦੇਹ ਨਾਨਕ ਨਿਸਤਾਰਿ ॥੪॥੫੧॥੧੨੦॥",
          "roman": "dulabh dēh Nānak nistār ॥4॥51॥120॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਇਹ ਮਨੁੱਖਾ ਸਰੀਰ ਬੜੀ ਮੁਸ਼ਕਲ ਨਾਲ ਮਿਲਿਆ ਹੈ, ਇਸ ਨੂੰ (ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਦੇ ਵਿਕਾਰਾਂ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲੈ ॥੪॥੫੧॥੧੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: о брат! Это человеческое тело получено с великим трудом; переправь его через пороки мирского океана силой памятования. ॥4॥51॥120॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 572,
      "rahao_verse_id": 8058,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8054,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8055,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਅਪਨੀ ਕਿਰਪਾ ਧਾਰੈ ॥",
          "roman": "jā kau apanī kirpā dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਨਾਮ ਸਿਮਰਨਾ ਭੀ ਜੀਵਾਂ ਦੇ ਆਪਣੇ ਵੱਸ ਦੀ ਗੱਲ ਨਹੀਂ) ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਆਪਣੀ ਮਿਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(Но и помнить Имя — не дело, подвластное самим существам.) На кого человека Вахегуру простирает Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8056,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਰਸਨਾ ਨਾਮੁ ਉਚਾਰੈ ॥੧॥",
          "roman": "so jan rasnā nām uchārē ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਆਪਣੀ) ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек своими устами произносит Имя Вахегуру. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8057,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਬਿਸਰਤ ਸਹਸਾ ਦੁਖੁ ਬਿਆਪੈ ॥",
          "roman": "har bisarat sahsā dukh biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾਇਆਂ (ਦੁਨੀਆ ਦਾ) ਸਹਮ-ਦੁੱਖ (ਆਪਣਾ) ਜ਼ੋਰ ਪਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Когда забывают Вахегуру, страх и страдание (этого мира) одолевают человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8058,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮੁ ਭਰਮੁ ਭਉ ਭਾਗੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simarat nām bharam bhau bhāgē ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਸਿਮਰਿਆਂ ਹਰੇਕ ਭਟਕਣਾ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ, ਹਰੇਕ ਕਿਸਮ ਦਾ ਡਰ ਨੱਠ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но при памятовании Имени исчезает всякое блуждание, уходит всякий страх. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8059,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਰਤਨੁ ਸੁਣੈ ਹਰਿ ਕੀਰਤਨੁ ਗਾਵੈ ॥",
          "roman": "har kīrtan suṇē har kīrtan gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜੇਹੜਾ ਮਨੁੱਖ) ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਸੁਣਦਾ ਹੈ, ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(Тот человек, кому Господь явил милость,) слушает хвалу Вахегуру, поёт хвалу Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8060,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਦੂਖੁ ਨਿਕਟਿ ਨਹੀ ਆਵੈ ॥੨॥",
          "roman": "tis jan dūkh nikat nahī āvē ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੋਈ) ਦੁੱਖ ਉਸ ਮਨੁੱਖ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и никакое страдание не подходит близко к этому человеку. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8061,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਟਹਲ ਕਰਤ ਜਨੁ ਸੋਹੈ ॥",
          "roman": "har kī ṭahal karat jan sohē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਦਿਆਂ ਮਨੁੱਖ ਸੋਹਣੇ ਜੀਵਨ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Совершая служение и преданность Вахегуру, человек становится обладателем прекрасной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8062,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਮਾਇਆ ਅਗਨਿ ਨ ਪੋਹੈ ॥੩॥",
          "roman": "tā kau māiā agan na pohē ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਸ ਮਨੁੱਖ ਨੂੰ ਮਾਇਆ (ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਨਹੀਂ ਪੋਹ ਸਕਦੀ (ਉਸ ਦੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਸਾੜ ਨਹੀਂ ਸਕਦੀ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потому что огонь майи, огонь жажды, не может коснуться его, не может сжечь его духовную жизнь. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8063,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਮੁਖਿ ਹਰਿ ਨਾਮੁ ਦਇਆਲ ॥",
          "roman": "man tan mukh har nām daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦੇ ਘਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਹਿਰਦੇ ਵਿਚ ਤੇ ਮੂੰਹ ਵਿਚ ਵੱਸ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Имя милостивого Вахегуру поселяется в уме, в сердце и на устах человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8064,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਜੀਅਲੇ ਅਵਰਿ ਜੰਜਾਲ ॥੪॥੫੨॥੧੨੧॥",
          "roman": "nānak tajīale avar janjāl ||4||52||121||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਨੇ (ਆਪਣੇ ਮਨ ਵਿਚੋਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ) ਹੋਰ ਸਾਰੇ ਜੰਜਾਲ ਲਾਹ ਦਿੱਤੇ ਹੁੰਦੇ ਹਨ ॥੪॥੫੨॥੧੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, такой человек уже отбросил из своего ума все прочие путы привязанности к майе. ||4||52||121||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 573,
      "rahao_verse_id": 8069,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8065,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8066,
          "is_rahao": false,
          "gurmukhi": "ਛਾਡਿ ਸਿਆਨਪ ਬਹੁ ਚਤੁਰਾਈ ॥",
          "roman": "chhāḍ siānap bah chaturāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਖ਼ਿਆਲ ਛੱਡ ਦੇ ਕਿ ਤੂੰ ਬੜਾ ਸਿਆਣਾ ਤੇ ਚਤੁਰ ਹੈਂ (ਤੇ ਜੀਵਨ-ਮਾਰਗ ਨੂੰ ਆਪ ਹੀ ਸਮਝ ਸਕਦਾ ਹੈਂ)"
            },
            "sahib_singh_ru": {
              "main": "Оставь мысль, что ты очень умён и хитёр и сам можешь понять путь жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8067,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਟੇਕ ਟਿਕਾਈ ॥੧॥",
          "roman": "gur pūre kī ṭek ṭikāī ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ) ਪੂਰੇ ਗੁਰੂ ਦਾ ਆਸਰਾ ਲੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "(о брат!) прими опору совершенного Гуру. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8068,
          "is_rahao": true,
          "gurmukhi": "ਦੁਖ ਬਿਨਸੇ ਸੁਖ ਹਰਿ ਗੁਣ ਗਾਇ ॥",
          "roman": "dukh binse sukh har guṇ gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾ ਕੇ ਉਸ ਨੂੰ ਸੁਖ (ਹੀ ਸੁਖ) ਮਿਲਦੇ ਹਨ ਤੇ ਉਸ ਦੇ ਸਾਰੇ ਦੇ (ਸਾਰੇ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Воспевая качества Вахегуру, человек получает только радость, и все его страдания исчезают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8069,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਭੇਟਿਆ ਲਿਵ ਲਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrā bheṭiā liv lāi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ (ਤੇ ਗੁਰੂ ਦੀ ਮਿਹਰ ਨਾਲ ਜੋ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਸੁਰਤ ਜੋੜਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(если тому человеку) встречается совершенный Гуру, и по милости Гуру он соединяет своё сознание со Стопами Господа. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8070,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਦੀਓ ਗੁਰਿ ਮੰਤ੍ਰੁ ॥",
          "roman": "har kā nām dīo gur mantr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਮੰਤ੍ਰ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Тому человеку, которому Гуру дал мантру Имени Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8071,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੇ ਵਿਸੂਰੇ ਉਤਰੀ ਚਿੰਤ ॥੨॥",
          "roman": "miṭe visūre utrarī chint ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਮੰਤ੍ਰ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦੇ ਸਾਰੇ) ਝੋਰੇ ਮਿਟ ਗਏ ਹਨ ਉਸ ਦੀ (ਹਰੇਕ ਕਿਸਮ ਦੀ) ਚਿੰਤਾ ਲਹਿ ਗਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "по благодати этой мантры исчезли все его тревоги, ушла всякая забота. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8072,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਭਏ ਗੁਰ ਮਿਲਤ ਕ੍ਰਿਪਾਲ ॥",
          "roman": "anad bhae gur milat kripāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਦਇਆ ਦੇ ਸੋਮੇ ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ ਆਤਮਕ ਖੁਸ਼ੀਆਂ ਪੈਦਾ ਹੋ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) При встрече с милостивым Гуру рождаются духовные радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8073,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਕਾਟੇ ਜਮ ਜਾਲ ॥੩॥",
          "roman": "kar kirpā kāṭe jam jāl ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਕਿਰਪਾ ਕਰ ਕੇ (ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਆਤਮਕ ਮੌਤ ਲਿਆਉਣ ਵਾਲੀਆਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਫਾਹੀਆਂ ਕੱਟ ਦੇਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру по милости разрубает внутри человека петли привязанности к майе, приносящей духовную смерть. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8074,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰੁ ਪੂਰਾ ਪਾਇਆ ॥",
          "roman": "kah nānak gur pūrā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тот человек, кому встречается совершенный Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8075,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਤੇ ਬਹੁਰਿ ਨ ਬਿਆਪੈ ਮਾਇਆ ॥੪॥੫੩॥੧੨੨॥",
          "roman": "tā te bahur na biāpē māiā ||4||53||122||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੁਰੂ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਉਸ ਮਨੁੱਖ ਉਤੇ) ਮਾਇਆ (ਆਪਣਾ) ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੀ ॥੪॥੫੩॥੧੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "по благодати этого Гуру уже не подпадает под власть майи. ||4||53||122||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 574,
      "rahao_verse_id": 8080,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8076,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8077,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੀਆ ਗੁਰਿ ਪੂਰੈ ਆਪਿ ॥",
          "roman": "rākh līā gur pūrē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਅਨੁਸਾਰ ਰਹਿੰਦਾ ਹੈ) ਪੂਰੇ ਗੁਰੂ ਨੇ ਆਪ ਉਸ ਨੂੰ (ਸਦਾ ਕਾਮਾਦਿਕ ਵੈਰੀਆਂ ਤੋਂ) ਬਚਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат! Того человека, который живёт по Гуру,) совершенный Гуру Сам всегда уберёг от врагов — страстей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8078,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਕਉ ਲਾਗੋ ਸੰਤਾਪੁ ॥੧॥",
          "roman": "manmukh kau lāgo santāp ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮਨੁੱਖ ਨੂੰ (ਇਹਨਾਂ ਦਾ) ਸੇਕ ਲੱਗਦਾ ਹੀ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а человека, идущего за своим умом, их жжение продолжает поражать. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8079,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੂ ਗੁਰੂ ਜਪਿ ਮੀਤ ਹਮਾਰੇ ॥",
          "roman": "gurū gurū jap mīt hamāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਿੱਤਰੋ! ਸਦਾ (ਆਪਣੇ) ਗੁਰੂ ਨੂੰ ਚੇਤੇ ਰੱਖੋ,"
            },
            "sahib_singh_ru": {
              "main": "О мои друзья! Всегда держите в памяти своего Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8080,
          "is_rahao": true,
          "gurmukhi": "ਮੁਖ ਊਜਲ ਹੋਵਹਿ ਦਰਬਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mukh ūjal hovahi darbāre ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਚੇਤੇ ਰੱਖਿਆਂ) ਤੁਹਾਡੇ ਮੂੰਹ ਪਰਮਾਤਮਾ ਦੀ ਦਰਗਾਹ ਵਿਚ ਰੌਸ਼ਨ ਹੋਣਗੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(если держать в памяти наставление Гуру,) ваши лица будут светлы в Дворе Вахегуру. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8081,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਣ ਹਿਰਦੈ ਵਸਾਇ ॥",
          "roman": "gur ke charaṇ hirdē vasāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ ਆਪਣੇ) ਹਿਰਦੇ ਵਿਚ ਗੁਰੂ ਦੇ ਚਰਨ ਵਸਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Посели в своём сердце Стопы Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8082,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਦੁਸਮਨ ਤੇਰੀ ਹਤੈ ਬਲਾਇ ॥੨॥",
          "roman": "dukh dusman terī hatē balāi ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਤੇਰੇ ਸਾਰੇ) ਦੁੱਖ-ਕਲੇਸ਼ ਨਾਸ ਕਰੇਗਾ (ਕਾਮਾਦਿਕ ਤੇਰੇ ਸਾਰੇ) ਵੈਰੀਆਂ ਨੂੰ ਮਾਰ ਮੁਕਾਏਗਾ (ਤੇਰੇ ਉਤੇ ਦਬਾਉ ਪਾਣ ਵਾਲੀ ਮਾਇਆ-) ਚੁੜੇਲ ਨੂੰ ਮੁਕਾ ਦੇਵੇਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру уничтожит все твои страдания, истребит всех твоих врагов — страсти, и избавит тебя от ведьмы-майи, давящей на тебя. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8083,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਤੇਰੈ ਸੰਗਿ ਸਹਾਈ ॥",
          "roman": "gur kā sabad terē sang sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਹੀ ਤੇਰੇ ਨਾਲ (ਸਦਾ ਸਾਥ ਨਿਬਾਹੁਣ ਵਾਲਾ) ਸਾਥੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Шабад Гуру — вот спутник, который всегда пребывает с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8084,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਭਏ ਸਗਲੇ ਜੀਅ ਭਾਈ ॥੩॥",
          "roman": "daiāl bhae sagle jīa bhāī ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰੋ ਰੱਖਿਆਂ) ਸਾਰੇ ਲੋਕ ਦਇਆਵਾਨ ਹੋ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "(Если хранить Шабад Гуру в сердце,) все люди становятся доброжелательными. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8085,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਜਬ ਕਿਰਪਾ ਕਰੀ ॥",
          "roman": "gur pūrē jab kirpā karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪੂਰੇ ਗੁਰੂ ਨੇ (ਮੇਰੇ ਉਤੇ) ਮਿਹਰ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда совершенный Гуру явил мне милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8086,
          "is_rahao": false,
          "gurmukhi": "ਭਨਤਿ ਨਾਨਕ ਮੇਰੀ ਪੂਰੀ ਪਰੀ ॥੪॥੫੪॥੧੨੩॥",
          "roman": "bhanat nānak merī pūrī parī ||4||54||123||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-ਤਾਂ ਮੇਰੀ ਜੀਵਨ-ਘਾਲ ਸਫਲ ਹੋ ਗਈ (ਕਾਮਾਦਿਕ ਵੈਰੀ ਮੇਰੇ ਉੱਤੇ ਹੱਲਾ ਕਰਨੋਂ ਹਟ ਗਏ) ॥੪॥੫੪॥੧੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тогда мой жизненный труд стал успешным, враги-страсти перестали нападать на меня. ||4||54||123||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 575,
      "rahao_verse_id": 8091,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8087,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8088,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰਸਾ ਖਾਏ ਜੈਸੇ ਢੋਰ ॥",
          "roman": "anik rasā khāe jēse ḍhor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਸ਼ੂ (ਪੱਠਿਆਂ ਨਾਲ ਢਿੱਡ ਭਰ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Как скот набивает себе брюхо кормом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8089,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹ ਕੀ ਜੇਵਰੀ ਬਾਧਿਓ ਚੋਰ ॥੧॥",
          "roman": "moh kī jevrī bādhio chor ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਸਾਧ ਸੰਗਤਿ ਤੋਂ ਵਾਂਜਿਆ ਰਹਿ ਕੇ ਆਤਮਕ ਮੌਤ ਮਰਿਆ ਹੋਇਆ ਮਨੁੱਖ) ਅਨੇਕਾਂ ਸੁਆਦਲੇ ਪਦਾਰਥ ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ਤੇ (ਸੰਨ੍ਹ ਤੋਂ ਫੜੇ ਹੋਏ) ਚੋਰਾਂ ਵਾਂਗ (ਮਾਇਆ) ਦੇ ਮੋਹ ਦੀ ਰੱਸੀ ਨਾਲ (ਹੋਰ ਹੋਰ ਵਧੀਕ) ਜਕੜਿਆ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так и человек, лишённый Садх Сангата и мёртвый духовной смертью, продолжает есть многие вкусные вещи и, как пойманный вор, всё сильнее связывается верёвкой привязанности к майе. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8090,
          "is_rahao": true,
          "gurmukhi": "ਮਿਰਤਕ ਦੇਹ ਸਾਧਸੰਗ ਬਿਹੂਨਾ ॥",
          "roman": "mirtak deh sādhsaṅg bihūnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਸਾਧ ਸੰਗਤਿ ਤੋਂ ਵਾਂਜਿਆ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਦਾ ਸਰੀਰ ਮੁਰਦਾ ਹੈ (ਕਿਉਂਕਿ ਉਸ ਦੇ ਅੰਦਰ ਆਤਮਕ ਮੌਤੇ ਮਰੀ ਹੋਈ ਜਿੰਦ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, который лишён Садх Сангата, имеет мёртвое тело, потому что внутри него — душа, умершая духовной смертью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8091,
          "is_rahao": true,
          "gurmukhi": "ਆਵਤ ਜਾਤ ਜੋਨੀ ਦੁਖ ਖੀਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āvat jāt jonī dukh khīnā ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ, ਜੂਨਾਂ ਦੇ ਦੁੱਖਾਂ ਦੇ ਕਾਰਨ ਉਸ ਦਾ ਆਤਮਕ ਜੀਵਨ ਹੋਰ ਹੋਰ ਕਮਜ਼ੋਰ ਹੁੰਦਾ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Такой человек остаётся в круге рождений и смертей, и от страданий юн его духовная жизнь всё больше слабеет. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8092,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਸਤ੍ਰ ਸੁੰਦਰ ਪਹਿਰਾਇਆ ॥",
          "roman": "anik bastr sundar pahirāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ ਮੌਤੇ ਮਰਿਆ ਮਨੁੱਖ) ਅਨੇਕਾਂ ਸੋਹਣੇ ਸੋਹਣੇ ਕੱਪੜੇ ਪਹਿਨਦਾ ਹੈ (ਗਰੀਬ ਮੈਲੇ ਕੱਪੜਿਆਂ ਵਾਲੇ ਮਨੁੱਖ ਉਸ ਤੋਂ ਡਰਦੇ ਰਤਾ ਪਰੇ ਪਰੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "(Человек, умерший духовной смертью,) носит множество красивых одежд, и бедные люди в грязной одежде боятся его и держатся поодаль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8093,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਡਰਨਾ ਖੇਤ ਮਾਹਿ ਡਰਾਇਆ ॥੨॥",
          "roman": "jiu ḍarnā khet māhi ḍarāiā ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਗਰੀਬਾਂ ਦੇ ਵਾਸਤੇ ਉਹ ਇਉਂ ਹੀ ਹੁੰਦਾ ਹੈ) ਜਿਵੇਂ ਪੈਲੀ ਵਿਚ (ਜਾਨਵਰਾਂ ਨੂੰ) ਡਰਾਣ ਲਈ ਬਨਾਉਟੀ ਰਾਖਾ ਖੜਾ ਕੀਤਾ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому для бедных он — как поставленный в поле искусственный сторож, чтобы пугать животных. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8094,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਰੀਰ ਆਵਤ ਸਭ ਕਾਮ ॥",
          "roman": "sagal sarīr āvat sabh kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੋਰ ਪਸ਼ੂ ਆਦਿਕਾਂ ਦੇ) ਸਾਰੇ ਸਰੀਰ (ਕਿਸੇ ਨ ਕਿਸੇ) ਕੰਮ ਆ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все тела других существ так или иначе бывают полезны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8095,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਫਲ ਮਾਨੁਖੁ ਜਪੈ ਨਹੀ ਨਾਮ ॥੩॥",
          "roman": "nihphal mānukh japē nahī nām ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਜਪਦਾ, ਤਾਂ ਇਸ ਦਾ ਜਗਤ ਵਿਚ ਆਉਣਾ ਵਿਅਰਥ ਹੀ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Если человек не повторяет Имя Вахегуру, то его приход в мир проходит напрасно. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8096,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕਉ ਭਏ ਦਇਆਲਾ ॥",
          "roman": "kah nānak jā kau bhae daiālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਉਤੇ ਪਰਮਾਤਮਾ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: те люди, к кому Вахегуру становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8097,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਿਲਿ ਭਜਹਿ ਗੋੁਪਾਲਾ ॥੪॥੫੫॥੧੨੪॥",
          "roman": "sādhsaṅg mil bhajahi gopālā ||4||55||124||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਸਤ ਸੰਗੀਆਂ ਨਾਲ) ਮਿਲ ਕੇ ਜਗਤ ਦੇ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਦਾ ਭਜਨ ਕਰਦੇ ਹਨ ॥੪॥੫੫॥੧੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "соединившись в Садх Сангате со святыми, поклоняются Господу — Хранителю мира. ||4||55||124||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
