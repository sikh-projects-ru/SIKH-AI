{
  "ang": 191,
  "shabads": [
    {
      "shabad_id": 576,
      "rahao_verse_id": 8102,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8099,
          "is_rahao": false,
          "gurmukhi": "ਕਲਿ ਕਲੇਸ ਗੁਰ ਸਬਦਿ ਨਿਵਾਰੇ ॥",
          "roman": "kal kales gur sabad nivāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਪਹੁੰਚੇ ਹੋਏ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ) ਮਾਨਸਕ ਝਗੜੇ ਤੇ ਕਲੇਸ਼ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੇ ਦੂਰ ਕਰ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "У тех людей, которые достигли Садх Сангата, умственные распри и страдания были устранены Шабадом Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8100,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣ ਜਾਣ ਰਹੇ ਸੁਖ ਸਾਰੇ ॥੧॥",
          "roman": "āvaṇ jāṇ rahe sukh sāre ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਮੁੱਕ ਗਏ, ਉਹਨਾਂ ਨੂੰ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਗਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "их круг рождения и смерти прекратился, и они обрели все радости. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8101,
          "is_rahao": true,
          "gurmukhi": "ਭੈ ਬਿਨਸੇ ਨਿਰਭਉ ਹਰਿ ਧਿਆਇਆ ॥",
          "roman": "bhē binse nirbhau har dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਨ੍ਹਾਂ ਨੇ ਨਿਰਭਉ ਹਰੀ ਦਾ ਧਿਆਨ (ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਧਰਿਆ ਹੈ, ਉਹਨਾਂ ਦੇ (ਦੁਨੀਆ ਵਾਲੇ ਸਾਰੇ) ਡਰ ਦੂਰ ਹੋ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Те, кто утвердил в своём сердце созерцание Нирбхау Хари, избавились от всех мирских страхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8102,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੇ ਗੁਣ ਗਾਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhsaṅg har ke guṇ gāiā ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਜਾ ਕੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਇਆਂ (ਨਿਰਭਉ ਹੋਈਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Став в Садх Сангате и воспев песни хвалы Вахегуру, становятся бесстрашными. ||1|| rahāu ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8103,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਵਲ ਰਿਦ ਅੰਤਰਿ ਧਾਰੇ ॥",
          "roman": "charaṇ kaval rid antar dhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ) ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "(По благодати Садх Сангата те люди,) которые поселили в своём сердце прекрасные Стопы Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8104,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਸਾਗਰ ਗੁਰਿ ਪਾਰਿ ਉਤਾਰੇ ॥੨॥",
          "roman": "agan sāgar gur pār utāre ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਉਹਨਾਂ ਨੂੰ ਤ੍ਰਿਸ਼ਨਾ-ਅੱਗ ਦੇ ਸਮੁੰਦਰ ਵਿਚੋਂ ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "были переправлены Гуру через океан огня жажды. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8105,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਜਾਤ ਪੂਰੈ ਗੁਰਿ ਕਾਢੇ ॥",
          "roman": "būḍat jāt pūrē gur kāḍhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵਿਕਾਰਾਂ ਦੇ ਸਮੁੰਦਰ ਵਿਚ) ਡੁੱਬ ਰਹੇ ਮਨੁੱਖਾਂ ਨੂੰ ਪੂਰੇ ਗੁਰੂ ਨੇ (ਬਾਹੋਂ ਫੜ ਕੇ ਬਾਹਰ) ਕੱਢ ਲਿਆ (ਜਦੋਂ ਉਹ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਅੱਪੜ ਗਏ),"
            },
            "sahib_singh_ru": {
              "main": "Тех людей, которые тонули в океане пороков, совершенный Гуру вытащил наружу, взяв за руку, когда они достигли Садх Сангата,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8106,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਟੂਟੇ ਗਾਢੇ ॥੩॥",
          "roman": "janam janam ke ṭūṭe gāḍhe ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ (ਪਰਮਾਤਮਾ ਨਾਲੋਂ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਟੁੱਟਿਆਂ ਹੋਇਆਂ ਨੂੰ (ਗੁਰੂ ਨੇ ਮੁੜ ਪਰਮਾਤਮਾ ਦੇ ਨਾਲ) ਮਿਲਾ ਦਿੱਤਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и тех, кто был отделён от Вахегуру многие рождения, Гуру вновь соединил с Ним. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8107,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਿਸੁ ਗੁਰ ਬਲਿਹਾਰੀ ॥",
          "roman": "kah nānak tis gur balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਮੈਂ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: я посвящаю себя тому Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8108,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭੇਟਤ ਗਤਿ ਭਈ ਹਮਾਰੀ ॥੪॥੫੬॥੧੨੫॥",
          "roman": "jis bheṭat gat bhaī hamārī ||4||56||125||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਮਿਲਿਆਂ ਸਾਡੀ (ਜੀਵਾਂ ਦੀ) ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ ॥੪॥੫੬॥੧੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "при встрече с которым наше духовное состояние становится высоким. ||4||56||124||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 577,
      "rahao_verse_id": 8113,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8109,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8110,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਤਾ ਕੀ ਸਰਨੀ ਪਰਹੁ ॥",
          "roman": "sādhsang tā kī sarnī parah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਵੀਰ!) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਜਾ ਕੇ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) Войди в Садх-сангат и прими прибежище того Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8111,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਅਪਨਾ ਆਗੈ ਧਰਹੁ ॥੧॥",
          "roman": "man tan apnā āgē dharah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣਾ ਮਨ ਆਪਣਾ ਤਨ (ਭਾਵ, ਆਪਣਾ ਹਰੇਕ ਗਿਆਨ-ਇੰਦ੍ਰਾ) ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਹਵਾਲੇ ਕਰ ਦੇਹ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Отдай Ему свой ум и своё тело, то есть все свои органы познания. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8112,
          "is_rahao": true,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਪੀਵਹੁ ਮੇਰੇ ਭਾਈ ॥",
          "roman": "aṃmrit nām pīvah mere bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਪਰਮਾਤਮਾ ਦਾ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਪੀ (ਸੁਆਸ ਸੁਆਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Пей воду Имени, дающую духовную жизнь (то есть с каждым дыханием помни Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8113,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਭ ਤਪਤਿ ਬੁਝਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simar simar sabh tapat bujhāī rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਨਾਮ ਸਿਮਰਿਆ ਹੈ) ਉਸ ਨੇ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ ਵਿਕਾਰਾਂ ਦੀ) ਸਾਰੀ ਸੜਨ ਬੁਝਾ ਲਈ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(Тот, кто помнил Имя,) помня и помня, погасил в себе весь жар пороков. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8114,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਅਭਿਮਾਨੁ ਜਨਮ ਮਰਣੁ ਨਿਵਾਰਹੁ ॥",
          "roman": "taj abhimān janam maraṇ nivārah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਵੀਰ! ਆਪਣੇ ਅੰਦਰੋਂ) ਅਹੰਕਾਰ ਦੂਰ ਕਰ ਕੇ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਮੁਕਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) Устрани из себя гордыню и прекрати круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8115,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਦਾਸ ਕੇ ਚਰਣ ਨਮਸਕਾਰਹੁ ॥੨॥",
          "roman": "har ke dās ke charaṇ namaskārahu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਸੇਵਕ ਦੇ ਚਰਨਾਂ ਉਤੇ ਆਪਣਾ ਸਿਰ ਰੱਖ ਦੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Склони голову к стопам слуги Бога. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8116,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਪ੍ਰਭੁ ਮਨਹਿ ਸਮਾਲੇ ॥",
          "roman": "sās sās prabh maneh samāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਭਾਈ!) ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਸਾਂਭ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "(О мой брат!) С каждым дыханием храни Бога в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8117,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਨੁ ਸੰਚਹੁ ਜੋ ਚਾਲੈ ਨਾਲੇ ॥੩॥",
          "roman": "so dhan sanchahu jo chālē nāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਨਾਮ-) ਧਨ ਇਕੱਠਾ ਕਰ ਜੇਹੜਾ ਤੇਰੇ ਨਾਲ ਸਾਥ ਕਰੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Собирай то богатство Имени, которое пойдёт с тобой. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8118,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਪਰਾਪਤਿ ਜਿਸੁ ਮਸਤਕਿ ਭਾਗੁ ॥",
          "roman": "tiseh parāpat jis mastak bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਨਾਮ-ਧਨ ਇਕੱਠਾ ਕਰਨਾ ਜੀਵਾਂ ਦੇ ਵੱਸ ਦੀ ਗੱਲ ਨਹੀਂ। ਇਹ ਨਾਮ-ਧਨ) ਉਸ ਮਨੁੱਖ ਨੂੰ ਹੀ ਮਿਲਦਾ ਹੈ, ਜਿਸ ਦੇ ਮੱਥੇ ਉਤੇ ਭਾਗ ਜਾਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "(Но собрать это богатство Имени не во власти существ. Это богатство Имени) получает только тот человек, у которого на челе пробудилась удача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8119,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਾ ਕੀ ਚਰਣੀ ਲਾਗੁ ॥੪॥੫੭॥੧੨੬॥",
          "roman": "kah nānak tā kī charaṇī lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਹੇ ਮੇਰੇ ਭਾਈ!) ਤੂੰ ਉਸ ਮਨੁੱਖ ਦੀ ਚਰਨੀਂ ਲੱਗ (ਜਿਸ ਨੂੰ ਨਾਮ-ਧਨ ਮਿਲਿਆ ਹੈ) ॥੪॥੫੭॥੧੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о мой брат! Припади к стопам того человека, который получил богатство Имени. ॥4॥57॥126॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 578,
      "rahao_verse_id": 8124,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8120,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8121,
          "is_rahao": false,
          "gurmukhi": "ਸੂਕੇ ਹਰੇ ਕੀਏ ਖਿਨ ਮਾਹੇ ॥",
          "roman": "sūke hare kīe khin māhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਇਕ ਖਿਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੇ ਰਸ ਤੋਂ ਸੁੰਞੇ ਹੋ ਚੁੱਕੇ ਮਨੁੱਖਾਂ ਨੂੰ ਹਰੇ (ਭਾਵ, ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ) ਬਣਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру в одно мгновение делает зелёными, то есть духовно живыми, тех людей, которые совсем иссохли, лишившись вкуса духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8122,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਦ੍ਰਿਸਟਿ ਸੰਚਿ ਜੀਵਾਏ ॥੧॥",
          "roman": "aṃmrit driṣṭ sañch jīvāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨਾਮ-ਜਲ ਸਿੰਜ ਕੇ ਉਨ੍ਹਾਂ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਨਿਗਾਹ ਕਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਬਖ਼ਸ਼ਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Орошая их водой Имени и одаривая взглядом, дарующим духовную жизнь, Гуру наделяет их этой жизнью. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8123,
          "is_rahao": true,
          "gurmukhi": "ਕਾਟੇ ਕਸਟ ਪੂਰੇ ਗੁਰਦੇਵ ॥",
          "roman": "kāṭe kasṭ pūre gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਉਸ ਦੇ ਸਾਰੇ ਕਸ਼ਟ ਕੱਟ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру устранил все его страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8124,
          "is_rahao": true,
          "gurmukhi": "ਸੇਵਕ ਕਉ ਦੀਨੀ ਅਪੁਨੀ ਸੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sevak kau dīnī apunī sev rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸੇਵਕ ਨੂੰ (ਪਰਮਾਤਮਾ ਨੇ) ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ (ਦੀ ਦਾਤਿ) ਦਿੱਤੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тому слуге, которому Бог даровал Своё служение-преданность. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8125,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਿ ਗਈ ਚਿੰਤ ਪੁਨੀ ਮਨ ਆਸਾ ॥",
          "roman": "miṭ gaī chint punī man āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ (ਹਰੇਕ ਕਿਸਮ ਦੀ) ਚਿੰਤਾ ਮਿਟ ਗਈ, ਉਸ ਦੇ ਮਨ ਦੀ (ਹਰੇਕ) ਆਸ ਪੂਰੀ ਹੋ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "У него исчезла всякая тревога, и всякое желание его сердца исполнилось,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8126,
          "is_rahao": false,
          "gurmukhi": "ਕਰੀ ਦਇਆ ਸਤਿਗੁਰਿ ਗੁਣਤਾਸਾ ॥੨॥",
          "roman": "karī daiyā satigur guṇtāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਸਤਿਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਮਿਹਰ ਕੀਤੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "если Сатгуру, сокровищница добродетелей, явил этому человеку милость. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8127,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਨਾਠੇ ਸੁਖ ਆਇ ਸਮਾਏ ॥",
          "roman": "dukh nāṭhe sukh āe samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਦੁੱਖ ਦੂਰ ਹੋ ਗਏ, ਉਸ ਦੇ ਅੰਦਰ (ਸਾਰੇ) ਸੁਖ ਆ ਕੇ ਟਿਕ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "Все его страдания ушли, и все радости пришли и поселились в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8128,
          "is_rahao": false,
          "gurmukhi": "ਢੀਲ ਨ ਪਰੀ ਜਾ ਗੁਰਿ ਫੁਰਮਾਏ ॥੩॥",
          "roman": "ḍhīl na parī jā gur furmāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਬਖ਼ਸ਼ਸ਼ ਹੋਣ ਦਾ ਹੁਕਮ ਕੀਤਾ, ਰਤਾ ਭੀ ਢਿੱਲ ਨਾਹ ਹੋਈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Когда Гуру постановил, чтобы на человека сошла милость, не было ни малейшей задержки. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8129,
          "is_rahao": false,
          "gurmukhi": "ਇਛ ਪੁਨੀ ਪੂਰੇ ਗੁਰ ਮਿਲੇ ॥",
          "roman": "ichh punī pūre gur mile",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਪੂਰੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਪਏ, ਉਹਨਾਂ ਦੀ (ਹਰੇਕ ਕਿਸਮ ਦੀ) ਇੱਛਾ ਪੂਰੀ ਹੋ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "У тех людей, которые встретили Совершенного Гуру, исполнились все их желания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8130,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇ ਜਨ ਸੁਫਲ ਫਲੇ ॥੪॥੫੮॥੧੨੭॥",
          "roman": "nānak te jan suphal phale",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਨੂੰ ਉੱਚੇ ਆਤਮਕ ਗੁਣਾਂ ਦੇ ਸੋਹਣੇ ਫਲ ਲੱਗ ਪਏ ॥੪॥੫੮॥੧੨੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, на них выросли прекрасные плоды высоких духовных качеств. ॥4॥58॥127॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 579,
      "rahao_verse_id": 8135,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8131,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8132,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪ ਗਏ ਪਾਈ ਪ੍ਰਭਿ ਸਾਂਤਿ ॥",
          "roman": "tāp gae pāī prabh sānt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ ਉਹ ਠੰਡੇ ਜਿਗਰੇ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кому Бог даёт дар Своего Имени, становятся людьми с прохладным сердцем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8133,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਲ ਭਏ ਕੀਨੀ ਪ੍ਰਭ ਦਾਤਿ ॥੧॥",
          "roman": "sītal bhae kīnī prabh dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਐਸੀ ਆਤਮਕ ਠੰਢ ਵਰਤਾ ਦਿੱਤੀ ਹੁੰਦੀ ਹੈ ਕਿ ਉਹਨਾਂ ਦੇ ਸਾਰੇ ਤਾਪ-ਕਲੇਸ਼ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Бог водворяет в них такую внутреннюю прохладу, что все их муки и страдания исчезают. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8134,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਭਏ ਸੁਹੇਲੇ ॥",
          "roman": "prabh kirpā te bhae suhēle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ ਉਹ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸੌਖੇ (ਜੀਵਨ ਵਾਲੇ) ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(Те люди, которым Бог даёт дар Своего Имени,) по милости Бога становятся живущими легко,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8135,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਬਿਛੁਰੇ ਮੇਲੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "janam janam ke bichhuṛe mēle rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੇ ਵਿੱਛੁੜਿਆਂ ਨੂੰ ਪਰਮਾਤਮਾ (ਆਪਣੇ ਨਾਲ) ਮਿਲਾ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Бог соединяет с Собой тех, кто был от Него отделён многие рождения. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8136,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਸਿਮਰਤ ਪ੍ਰਭ ਕਾ ਨਾਉ ॥",
          "roman": "simrat simrat prabh kā nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪਣੇ ਨਾਮ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ)"
            },
            "sahib_singh_ru": {
              "main": "(У тех, кому Бог даёт дар Своего Имени,) от повторного памятования Имени Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8137,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਰੋਗ ਕਾ ਬਿਨਸਿਆ ਥਾਉ ॥੨॥",
          "roman": "sagal rog kā binsiā thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਰੋਗਾਂ ਦਾ ਨਿਸ਼ਾਨ ਹੀ ਮਿਟ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "исчезает даже след всех болезней. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8138,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਸੁਭਾਇ ਬੋਲੈ ਹਰਿ ਬਾਣੀ ॥",
          "roman": "sahaj subhāe bolē har bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਨਾਮ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ ਉਹ) ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਪ੍ਰੇਮ-ਪਿਆਰ ਵਿਚ ਲੀਨ ਹੋ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(Человек, которому Бог даёт дар Имени,) пребывая в духовной устойчивости и будучи погружён в любовь, постоянно произносит речь хвалы Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8139,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਪ੍ਰਭ ਸਿਮਰਹੁ ਪ੍ਰਾਣੀ ॥੩॥",
          "roman": "āṭh pahar prabh simarah prāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! (ਤੂੰ ਭੀ ਉਸ ਦੇ ਦਰ ਤੋਂ ਨਾਮ ਦੀ  ਦਾਤ ਮੰਗ, ਤੇ) ਅੱਠੇ ਪਹਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹੁ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О человек! Ты тоже проси у Его двери дар Имени и все восемь страж дня помни Бога. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8140,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਜਮੁ ਨੇੜਿ ਨ ਆਵੈ ॥",
          "roman": "dūkh darad jam nēṛ na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਦੁੱਖ-ਦਰਦ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਆਉਂਦਾ, ਉਸ ਨੂੰ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਪੋਂਹਦਾ (ਆਤਮਕ ਮੌਤ ਦਾ ਉਸ ਨੂੰ ਖ਼ਤਰਾ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ),"
            },
            "sahib_singh_ru": {
              "main": "Никакое страдание и боль не приближаются к нему, страх смерти его не касается, и опасности духовной смерти для него больше не остаётся,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8141,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜੋ ਹਰਿ ਗੁਨ ਗਾਵੈ ॥੪॥੫੯॥੧੨੮॥",
          "roman": "kah nānak jo har gun gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਪਰਮਾਤਮਾ ਦੀ ਮਿਹਰ ਨਾਲ) ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੫੯॥੧੨੮॥"
            },
            "sahib_singh_ru": {
              "main": "говорит Нанак, если человек по милости Бога продолжает петь качества Бога. ॥4॥59॥128॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 580,
      "rahao_verse_id": 8146,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8142,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8143,
          "is_rahao": false,
          "gurmukhi": "ਭਲੇ ਦਿਨਸ ਭਲੇ ਸੰਜੋਗ ॥",
          "roman": "bhale dinas bhale sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਦਿਨ ਸੁਹਾਵਣੇ ਹੁੰਦੇ ਹਨ ਉਹ ਮਿਲਾਪ ਦੇ ਅਵਸਰ ਸੁਖਦਾਈ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Прекрасны те дни, благоприятны те случаи встречи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8144,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਭੇਟੇ ਪਾਰਬ੍ਰਹਮ ਨਿਰਜੋਗ ॥੧॥",
          "roman": "jit bhēṭe pārbrahm nirjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਮਾਇਆ ਤੋਂ) ਨਿਰਲੇਪ ਪ੍ਰਭੂ ਜੀ ਮਿਲ ਪੈਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "когда встречается не затронутый майей Парбрахм. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8145,
          "is_rahao": true,
          "gurmukhi": "ਓਹ ਬੇਲਾ ਕਉ ਹਉ ਬਲਿ ਜਾਉ ॥",
          "roman": "oh bēlā kau hau bal jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ ਉਸ ਵੇਲੇ ਤੋਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Я жертвую собой ради того времени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8146,
          "is_rahao": true,
          "gurmukhi": "ਜਿਤੁ ਮੇਰਾ ਮਨੁ ਜਪੈ ਹਰਿ ਨਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jit merā man japē har nāu rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਵੇਲੇ ਮੇਰਾ ਮਨ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "когда мой ум повторяет Имя Бога. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8147,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਮੂਰਤੁ ਸਫਲ ਓਹ ਘਰੀ ॥",
          "roman": "saphal mūrat saphal oh gharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮਨੁੱਖ ਵਾਸਤੇ ਉਹ ਮੁਹੂਰਤ ਭਾਗਾਂ ਵਾਲਾ ਹੁੰਦਾ ਹੈ ਉਹ ਘੜੀ ਸੁਲੱਖਣੀ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Для человека счастлив тот миг, благословен тот час,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8148,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਰਸਨਾ ਉਚਰੈ ਹਰਿ ਹਰੀ ॥੨॥",
          "roman": "jit rasnā ucharē har harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਸ ਦੀ ਜੀਭ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "когда его язык произносит Имя Бога. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8149,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲੁ ਓਹੁ ਮਾਥਾ ਸੰਤ ਨਮਸਕਾਰਸਿ ॥",
          "roman": "saphal oh māthā sant namaskāras",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਮੱਥਾ ਭਾਗਾਂ ਵਾਲਾ ਹੈ ਜੇਹੜਾ ਗੁਰੂ-ਸੰਤ ਦੇ ਚਰਨਾਂ ਉਤੇ ਨਿਊਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О брат!) Благословенно то чело, которое склоняется к стопам Гуру-Санта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8150,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਪੁਨੀਤ ਚਲਹਿ ਹਰਿ ਮਾਰਗਿ ॥੩॥",
          "roman": "charaṇ punīt chaleh har mārag",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੈਰ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦੇ ਹਨ ਜੇਹੜੇ ਪਰਮਾਤਮਾ (ਦੇ ਮਿਲਾਪ) ਦੇ ਰਸਤੇ ਉਤੇ ਤੁਰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Святыми становятся те ноги, которые идут по пути к встрече с Богом. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8151,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਭਲਾ ਮੇਰਾ ਕਰਮ ॥",
          "roman": "kah nānak bhalā merā karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਮੇਰੇ ਵੱਡੇ ਭਾਗ (ਜਾਗ ਪੈਂਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: велика моя удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8152,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਭੇਟੇ ਸਾਧੂ ਕੇ ਚਰਨ ॥੪॥੬੦॥੧੨੯॥",
          "roman": "jit bhēṭe sādhū ke charaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮੈਂ ਗੁਰੂ ਦੇ ਚਰਨ ਪਰਸਦਾ ਹਾਂ ॥੪॥੬੦॥੧੨੮॥"
            },
            "sahib_singh_ru": {
              "main": "когда я касаюсь стоп Гуру. ॥4॥60॥128॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
