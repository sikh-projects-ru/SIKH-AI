{
  "ang": 200,
  "shabads": [
    {
      "shabad_id": 620,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8584,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਬੁਧਿ ਮਨ ਪੂਰਿ ਥਿਧਾਈ ॥",
          "roman": "Ahaṃbudh man pūr thidhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਵਾਲੀ ਬੁੱਧੀ ਦੇ ਕਾਰਨ (ਮਨੁੱਖ ਦੇ) ਮਨ ਨੂੰ (ਹਉਮੈ ਦੀ) ਥਿੰਧਾਈ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ (ਉਸ ਥਿੰਧਾਈ ਦੇ ਕਾਰਨ ਮਨ ਉਤੇ ਕਿਸੇ ਉਪਦੇਸ਼ ਦਾ ਅਸਰ ਨਹੀਂ ਹੁੰਦਾ, ਜਿਵੇਂ ਥਿੰਧੇ ਭਾਂਡੇ ਉਤੋਂ ਦੀ ਪਾਣੀ ਤਿਲਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Из-за эгоистического ума ум человека покрыт липкостью эго; поэтому никакое наставление не действует на него, как вода соскальзывает с жирного сосуда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8585,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਧੂਰਿ ਕਰਿ ਸੁਧ ਮੰਜਾਈ ॥੧॥",
          "roman": "Sādh dhūr kar sudh manjāī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ 'ਜਨ ਕੀ ਧੂਰਿ' ਮਿੱਠੀ ਲੱਗਦੀ ਹੈ) ਸਾਧੂ ਦੀ ਚਰਨ-ਧੂੜ ਨਾਲ ਉਸ ਦੀ ਬੁੱਧੀ ਮਾਂਜੀ ਜਾਂਦੀ ਹੈ ਤੇ ਸੁੱਧ ਹੋ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "А у того, кому сладок «jan kī dhūr», разум очищается и становится чистым от пыли стоп святого. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8586,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਲਾ ਜੇ ਧੋਵੈ ਦੇਹੀ ॥",
          "roman": "Anik jalā je dhovē dehī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮਨੁੱਖ ਅਨੇਕਾਂ (ਤੀਰਥਾਂ ਦੇ) ਪਾਣੀਆਂ ਨਾਲ ਆਪਣੇ ਸਰੀਰ ਨੂੰ ਧੋਂਦਾ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек будет омывать своё тело водами множества мест паломничества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8587,
          "is_rahao": false,
          "gurmukhi": "ਮੈਲੁ ਨ ਉਤਰੈ ਸੁਧੁ ਨ ਤੇਹੀ ॥੨॥",
          "roman": "Mēl na utrē sudh na tehī. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਉਸ ਦੇ ਮਨ ਦੀ ਮੈਲ ਨਹੀਂ ਲਹਿੰਦੀ, ਉਸ ਤਰ੍ਹਾਂ (ਭਾਵ, ਤੀਰਥ-ਇਸ਼ਨਾਨਾਂ ਨਾਲ) ਉਹ ਮਨੁੱਖ ਪਵਿਤ੍ਰ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "то всё равно грязь его ума не уйдёт; таким способом, то есть омовениями на тиртхах, он не сможет стать чистым. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8588,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟਿਓ ਸਦਾ ਕ੍ਰਿਪਾਲ ॥",
          "roman": "Satgur bheṭio sadā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਸਤਿਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ਜਿਸ ਉਤੇ ਗੁਰੂ ਸਦਾ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому человеку, которому встречается Сатгуру и к кому Гуру всегда милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8589,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਕਾਟਿਆ ਭਉ ਕਾਲ ॥੩॥",
          "roman": "Har simar simar kāṭiā bhau kāl. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਮੌਤ ਦਾ ਡਰ (ਆਤਮਕ ਮੌਤ ਦਾ ਖ਼ਤਰਾ) ਦੂਰ ਕਰ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "памятование Имени Хари устраняет изнутри страх смерти, то есть опасность духовной смерти. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8590,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਭੁਗਤਿ ਜੁਗਤਿ ਹਰਿ ਨਾਉ ॥",
          "roman": "mukt bhugat jugat har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਦਿਵਾਂਦਾ ਹੈ, ਨਾਮ ਹੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਖ਼ੁਰਾਕ ਹੈ, ਨਾਮ ਜਪਣਾ ਹੀ ਜੀਵਨ ਦੀ ਸਹੀ ਜੁਗਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари и освобождает от пороков, и является пищей духовной жизни, и само памятование Имени есть верный способ жить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8591,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਨਾਨਕ ਗੁਣ ਗਾਉ ॥੪॥੧੦੦॥੧੬੯॥",
          "roman": "Prem bhagat Nānak guṇ gāu. ||4||100||169||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰੇਮ-ਭਰੀ ਭਗਤੀ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹੁ ॥੪॥੧੦੦॥੧੬੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! С любовной бхагти продолжай петь качества Бога. ||4||100||169||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 621,
      "rahao_verse_id": 8596,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8592,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8593,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਪਦਵੀ ਹਰਿ ਕੇ ਦਾਸ ॥",
          "roman": "jīvan padvī har ke dās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਹਰੀ ਦੇ ਦਾਸ ਹਨ) ਹਰੀ ਦੇ ਦਾਸਾਂ ਨੂੰ ਉੱਚਾ ਆਤਮਕ ਦਰਜਾ ਪ੍ਰਾਪਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнит Имя Бога, — слуги Хари; слугам Хари дарован высокий духовный статус,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8594,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਮਿਲਿਆ ਆਤਮ ਪਰਗਾਸੁ ॥੧॥",
          "roman": "jin miliā ātam pargās ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ (ਹਰੀ ਦੇ ਦਾਸਾਂ) ਨੂੰ ਮਿਲਿਆਂ ਆਤਮਾ ਨੂੰ (ਗਿਆਨ ਦਾ) ਚਾਨਣ ਮਿਲ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и при встрече с ними душа получает свет знания ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8595,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕਾ ਸਿਮਰਨੁ ਸੁਨਿ ਮਨ ਕਾਨੀ ॥",
          "roman": "har kā simran sun man kānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਧਿਆਨ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸੁਣਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, слушай Имя Бога внимательно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8596,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖੁ ਪਾਵਹਿ ਹਰਿ ਦੁਆਰ ਪਰਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukh pāvahi har duār parānī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! (ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਤੂੰ ਹਰੀ ਦੇ ਦਰ ਤੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰੇਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О живое существо! По милости симрана ты обретёшь покой у врат Хари ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8597,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਧਿਆਈਐ ਗੋਪਾਲੁ ॥",
          "roman": "āṭh pahar dhiāīai gopāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਹਰੀ ਦੇ ਦਾਸਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ) ਅੱਠੇ ਪਹਿਰ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਣਹਾਰ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Пребывая в обществе слуг Хари, следует все восемь страж помнить Господа, Питателя мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8598,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਸਨੁ ਦੇਖਿ ਨਿਹਾਲੁ ॥੨॥੧੦੧॥੧੭੦॥",
          "roman": "Nānak darsan dekh nihāl ॥2॥101॥170॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹਰ ਥਾਂ ਪਰਮਾਤਮਾ ਦਾ) ਦਰਸਨ ਕਰ ਕੇ (ਮਨ) ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੨॥੧੦੧॥੧੭੦॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря симрану, созерцая явление Бога повсюду, ум остаётся цветущим и радостным ॥2॥101॥170॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 622,
      "rahao_verse_id": 8601,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8599,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8600,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਭਈ ਗੁਰ ਗੋਬਿਦਿ ਪਾਈ ॥",
          "roman": "sāṅt bhaī gur gobid pāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਗੋਬਿੰਦ ਦੇ ਰੂਪ ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਨਾਮ ਦੀ ਦਾਤਿ) ਬਖ਼ਸ਼ ਦਿੱਤੀ, ਉਸ ਦੇ ਅੰਦਰ ਠੰਢ ਪੈ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Тот, кому Гуру, образ Гобинда, даровал благодать Имени, обрёл внутри прохладу и мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8601,
          "is_rahao": true,
          "gurmukhi": "ਤਾਪ ਪਾਪ ਬਿਨਸੇ ਮੇਰੇ ਭਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tāp pāp binse mere bhāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਦੁੱਖ-ਕਲੇਸ਼ ਤੇ ਪਾਪ ਨਾਸ ਹੋ ਗਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "у него исчезли все страдания, мучения и грехи ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8602,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਨਿਤ ਰਸਨ ਬਖਾਨ ॥",
          "roman": "rām nām nit rasan bakhān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੀ ਜੀਭ ਨਾਲ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਨ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто всегда произносит языком Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8603,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੇ ਰੋਗ ਭਏ ਕਲਿਆਨ ॥੧॥",
          "roman": "binse rog bhae kalyān ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਰੋਗ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਉਸ ਦੇ ਅੰਦਰ ਆਨੰਦ ਹੀ ਆਨੰਦ ਬਣੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "у того уходят все болезни, и внутри него пребывает лишь блаженство ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8604,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਣ ਅਗਮ ਬੀਚਾਰ ॥",
          "roman": "pārbrahm guṇ agam bīchār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਅਪਹੁੰਚ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਦਾ ਵਿਚਾਰ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто размышляет о качествах Непостижимого Парбрахма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8605,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਮਿ ਹੈ ਨਿਸਤਾਰ ॥੨॥",
          "roman": "sādhū saṅgam hē nistār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਉਸ ਦਾ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ-ਉਤਾਰਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "пребывая в обществе Гуру, переправляется через мирской океан ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8606,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਗੁਣ ਗਾਵਹੁ ਨਿਤ ਨੀਤ ॥",
          "roman": "nirmal guṇ gāvah nit nīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਿੱਤਰ! ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦੇ ਰਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "О мои друзья! Всегда пойте чистые качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8607,
          "is_rahao": false,
          "gurmukhi": "ਗਈ ਬਿਆਧਿ ਉਬਰੇ ਜਨ ਮੀਤ ॥੩॥",
          "roman": "gaī biādh ubre jan mīt ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਮਨੁੱਖ ਗੁਣ ਗਾਂਦੇ ਹਨ, ਉਹਨਾਂ ਦਾ ਹਰੇਕ) ਰੋਗ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ (ਰੋਗਾਂ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚੇ ਰਹਿੰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "У тех, кто поёт эти качества, уходит всякая болезнь, и они остаются спасёнными от недугов и пороков ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8608,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਬਚ ਕ੍ਰਮ ਪ੍ਰਭੁ ਅਪਨਾ ਧਿਆਈ ॥",
          "roman": "man bach kram prabh apnā dhiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਿਹਰ ਕਰ) ਮੈਂ ਆਪਣੇ ਮਨ ਦੀ ਰਾਹੀਂ ਬਚਨਾਂ ਦੀ ਰਾਹੀਂ ਤੇ ਕਰਮਾਂ ਦੀ ਰਾਹੀਂ ਸਦਾ ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Сделай милость, чтобы я умом, речью и делами всегда помнил своего Господа-Владыку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8609,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤੇਰੀ ਸਰਣਾਈ ॥੪॥੧੦੨॥੧੭੧॥",
          "roman": "Nānak dās terī saraṇāī ॥4॥102॥171॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-ਹੇ ਪ੍ਰਭੂ!) ਮੈਂ ਤੇਰਾ ਦਾਸ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ ॥੪॥੧੦੨॥੧੭੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я, Нанак, Твой слуга, пришёл в Твоё прибежище ॥4॥102॥171॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 623,
      "rahao_verse_id": 8612,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8610,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8611,
          "is_rahao": true,
          "gurmukhi": "ਨੇਤ੍ਰ ਪ੍ਰਗਾਸੁ ਕੀਆ ਗੁਰਦੇਵ ॥",
          "roman": "netr pragās kīā gurdev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਰਦੇਵ! ਜਿਸ ਮਨੁੱਖ ਦੀਆਂ (ਆਤਮਕ) ਅੱਖਾਂ ਨੂੰ ਤੂੰ (ਗਿਆਨ ਦਾ) ਚਾਨਣ ਬਖ਼ਸ਼ਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О Гурдев! Тому человеку, чьим духовным глазам Ты даровал свет знания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8612,
          "is_rahao": true,
          "gurmukhi": "ਭਰਮ ਗਏ ਪੂਰਨ ਭਈ ਸੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bharam gae pūran bhaī sev ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਵਹਮ (ਥਾਂ ਥਾਂ ਦੇ ਭਟਕਣ) ਦੂਰ ਹੋ ਗਏ, ਤੇਰੇ ਦਰ ਤੇ ਟਿਕ ਕੇ ਕੀਤੀ ਹੋਈ ਉਸ ਦੀ) ਸੇਵਾ ਸਿਰੇ ਚੜ੍ਹ ਗਈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "у того исчезли все сомнения и скитания, и его служение, совершаемое, утвердившись у Твоих врат, стало совершенным ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8613,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਲਾ ਤੇ ਰਖਿਆ ਬਿਹਾਰੀ ॥",
          "roman": "sītlā te rakhiā bihārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੁੰਦਰ ਸਰੂਪ! ਤੂੰ ਹੀ ਸੀਤਲਾ ਤੋਂ ਬਚਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прекрасный! Это Ты сохранил от оспы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8614,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭ ਕਿਰਪਾ ਧਾਰੀ ॥੧॥",
          "roman": "pārbrahm prabh kirpā dhārī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ! ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਹੀ ਕਿਰਪਾ ਕਰ ਕੇ ਸੀਤਲਾ ਤੋਂ ਬਚਾਇਆ ਹੈ (ਹੋਰ ਕੋਈ ਦੇਵੀ ਆਦਿਕ ਤੇਰੇ ਬਰਾਬਰ ਦੀ ਨਹੀਂ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Парбрахм! О Господь! Это Ты по милости уберёг от оспы; никакая богиня и никто иной не равны Тебе ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8615,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਜਪੈ ਸੋ ਜੀਵੈ ॥",
          "roman": "Nānak nām japē so jīvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ (ਹੋਰ ਸਾਰੇ ਆਸਰੇ ਛੱਡ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ, ਉਹ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кто, оставив все прочие опоры, повторяет Имя Бога, обретает духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8616,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਅੰਮ੍ਰਿਤੁ ਪੀਵੈ ॥੨॥੧੦੩॥੧੭੨॥",
          "roman": "sādhasaṅg har amrit pīvē ॥2॥103॥172॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ-ਰਸ ਪੀਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥੧੦੩॥੧੭੨॥"
            },
            "sahib_singh_ru": {
              "main": "потому что, пребывая в обществе святых, он пьёт нектар Имени Хари, дарующий духовную жизнь ॥2॥103॥172॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 624,
      "rahao_verse_id": 8621,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8617,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8618,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਓਹੁ ਮਸਤਕੁ ਧਨੁ ਤੇਰੇ ਨੇਤ ॥",
          "roman": "dhan oh mastak dhan tere net ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਭਾਗਾਂ ਵਾਲਾ ਹੈ ਉਹ ਮੱਥਾ (ਜੇਹੜਾ ਤੇਰੇ ਦਰ ਤੇ ਨਿਉਂਦਾ ਹੈ) ਭਾਗਾਂ ਵਾਲੀਆਂ ਹਨ ਉਹ ਅੱਖਾਂ (ਜੋ) ਤੇਰੇ (ਦੀਦਾਰ ਵਿਚ ਮਸਤ ਰਹਿੰਦੀਆਂ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Благословен тот лоб, что склоняется у Твоих врат; благословенны те глаза, что погружены в созерцание Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8619,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਓਇ ਭਗਤ ਜਿਨ ਤੁਮ ਸੰਗਿ ਹੇਤ ॥੧॥",
          "roman": "dhan oi bhagat jin tum saṅg het ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਾਗਾਂ ਵਾਲੇ ਹਨ ਉਹ ਭਗਤ ਜਨ ਜਿਨ੍ਹਾਂ ਦਾ ਤੇਰੇ ਨਾਲ ਪ੍ਰੇਮ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Благословенны те преданные, чья любовь соединена с Тобой ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8620,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕੈਸੇ ਸੁਖੁ ਲਹੀਐ ॥",
          "roman": "nām binā kēse sukh lahīē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਕਦੇ ਸੁਖ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Без памятования Имени Бога покой никогда не может быть обретён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8621,
          "is_rahao": true,
          "gurmukhi": "ਰਸਨਾ ਰਾਮ ਨਾਮ ਜਸੁ ਕਹੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rasnā rām nām jas kahīai ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ ਸਦਾ) ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣਾ ਚਾਹੀਦਾ ਹੈ, ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому всегда следует языком повторять Имя Бога и возносить Его хвалу ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8622,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਊਪਰਿ ਜਾਈਐ ਕੁਰਬਾਣੁ ॥",
          "roman": "tin ūpar jāīai kurbāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਉਤੋਂ (ਸਦਾ) ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нужно всегда быть готовым отдать себя за тех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8623,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਨਿ ਜਪਿਆ ਨਿਰਬਾਣੁ ॥੨॥੧੦੪॥੧੭੩॥",
          "roman": "Nānak jin japiā nirbāṇ ॥2॥104॥173॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਜਿਸ ਜਿਸ ਨੇ ਵਾਸਨਾ-ਰਹਿਤ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਹੈ ॥੨॥੧੦੪॥੧੭੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кто повторял Имя Бесстрастного, свободного от желаний Господа ॥2॥104॥173॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 625,
      "rahao_verse_id": 8628,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8624,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8625,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰਹੈ ਮਸਲਤਿ ਤੂੰਹੈ ਨਾਲਿ ॥",
          "roman": "tūṅhē masalat tūṅhē nāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ (ਹਰ ਥਾਂ ਮੇਰਾ) ਸਲਾਹਕਾਰ ਹੈਂ, ਤੂੰ ਹੀ (ਹਰ ਥਾਂ) ਮੇਰੇ ਨਾਲ ਵੱਸਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты везде мой советник, Ты же везде пребываешь со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8626,
          "is_rahao": false,
          "gurmukhi": "ਤੂਹੈ ਰਾਖਹਿ ਸਾਰਿ ਸਮਾਲਿ ॥੧॥",
          "roman": "tūhē rākheh sār samāl ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹੀ (ਜੀਵਾਂ ਦੀ) ਸਾਰ ਲੈ ਕੇ ਸੰਭਾਲ ਕਰ ਕੇ ਰੱਖਿਆ ਕਰਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты Сам, заботясь о существах, хранишь и оберегаешь их ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8627,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਰਾਮੁ ਦੀਨ ਦੁਨੀ ਸਹਾਈ ॥",
          "roman": "aisā rām dīn dunī sahāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਵੀਰ! ਪਰਮਾਤਮਾ ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਅਜਿਹਾ ਸਾਥੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой брат! Бог — такой помощник и в этом мире, и в мире ином,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8628,
          "is_rahao": true,
          "gurmukhi": "ਦਾਸ ਕੀ ਪੈਜ ਰਖੈ ਮੇਰੇ ਭਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dās kī pēj rakhē mere bhāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਹ ਆਪਣੇ ਸੇਵਕ ਦੀ ਇੱਜ਼ਤ (ਹਰ ਥਾਂ) ਰੱਖਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что везде сохраняет честь Своего слуги ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8629,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਆਪਿ ਇਹੁ ਥਾਨੁ ਵਸਿ ਜਾ ਕੈ ॥",
          "roman": "āgē āp ihu thān vas jā kē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਵੱਸ ਵਿਚ ਸਾਡਾ ਇਹ ਲੋਕ ਹੈ, ਉਹੀ ਆਪ ਪਰਲੋਕ ਵਿਚ ਭੀ (ਸਾਡਾ ਰਾਖਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот Бог, во власти Которого находится наш этот мир, Сам же является нашим хранителем и в мире ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8630,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਮਨੁ ਹਰਿ ਕਉ ਜਾਪੈ ॥੨॥",
          "roman": "āṭh pahar man har kau jāpē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੇਰਾ ਮਨ ਤਾਂ ਅੱਠੇ ਪਹਿਰ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Мой ум все восемь страж повторяет Имя этого Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8631,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿ ਪਰਵਾਣੁ ਸਚੁ ਨੀਸਾਣੁ ॥",
          "roman": "pat parvān sach nīsāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਉਸ ਨੂੰ (ਤੇਰੇ ਦਰਬਾਰ ਵਿਚ) ਇੱਜ਼ਤ ਮਿਲਦੀ ਹੈ, ਉਹ (ਤੇਰੇ ਦਰ ਤੇ) ਕਬੂਲ ਹੁੰਦਾ ਹੈ, ਉਸ ਨੂੰ (ਜੀਵਨ-ਸਫ਼ਰ ਵਿਚ) ਤੇਰਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਨਾਮ, ਰਾਹਦਾਰੀ (ਵਜੋਂ) ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Тот получает честь в Твоём дворе, бывает принят у Тебя, и Твоё вечно-пребывающее Имя становится для него пропуском в жизненном пути,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8632,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਆਪਿ ਕਰਹਿ ਫੁਰਮਾਨੁ ॥੩॥",
          "roman": "jā kau āp karahi furmān ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਸੇਵਕ) ਦੇ ਵਾਸਤੇ ਤੂੰ ਆਪ ਹੁਕਮ ਕਰਦਾ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "для кого Ты Сам отдаёшь повеление ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8633,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਦਾਤਾ ਆਪਿ ਪ੍ਰਤਿਪਾਲਿ ॥",
          "roman": "āpe dātā āp pratipāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪ ਹੀ (ਸਭ ਜੀਵਾਂ ਨੂੰ) ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈ, ਆਪ ਹੀ (ਸਭ ਦੀ) ਪਾਲਣਾ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам дарует всем дары и Сам поддерживает всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8634,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਨਿਤ ਨਾਨਕ ਰਾਮ ਨਾਮੁ ਸਮਾਲਿ ॥੪॥੧੦੫॥੧੭੪॥",
          "roman": "nit nit Nānak rām nām samāl ॥4॥105॥174॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਤੂੰ ਸਦਾ ਹੀ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਸਾਂਭ ਕੇ ਰੱਖ ॥੪॥੧੦੫॥੧੭੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Всегда храни в своём сердце Имя этого Бога ॥4॥105॥174॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 626,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 8635,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8636,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਪੂਰਾ ਭਇਆ ਕ੍ਰਿਪਾਲੁ ॥",
          "roman": "satgur pūrā bhaīā kripāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਅਭੁੱਲ ਗੁਰੂ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда совершенный Гуру становится милостив к человеку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8637,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਵਸਿਆ ਸਦਾ ਗੁਪਾਲੁ ॥੧॥",
          "roman": "hirdē vasiā sadā gupāl ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਰੱਖਿਅਕ ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਸਦਾ ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда в его сердце всегда пребывает Имя Бога, Хранителя мира ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 8638,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮੁ ਰਵਤ ਸਦ ਹੀ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "rām ravat sad hī sukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਉਸ ਨੇ ਸਦਾ ਹੀ ਆਤਮਕ ਆਨੰਦ ਮਾਣਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Бога, он всегда вкушал духовную радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
