{
  "ang": 211,
  "shabads": [
    {
      "shabad_id": 661,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9028,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਚਾਕਰ ਸੇ ਭਲੇ ॥",
          "roman": "prabh ke chākar se bhale ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੇ ਸੇਵਕ ਬਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые становятся слугами Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9029,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਮੁਖ ਊਜਲੇ ॥੪॥੩॥੧੪੧॥",
          "roman": "nānak tin mukh ūjle ॥4॥3॥141॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਹ ਭਾਗਾਂ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ (ਪਰਮਾਤਮਾ ਦੇ ਦਰਬਾਰ ਵਿਚ) ਉਹਨਾਂ ਦੇ ਮੂੰਹ ਰੋਸ਼ਨ ਹੁੰਦੇ ਹਨ ॥੪॥੩॥੧੪੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, становятся благословенными; в Божьем дворе их лица сияют. ॥4॥3॥141॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 662,
      "rahao_verse_id": 9032,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9030,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9031,
          "is_rahao": true,
          "gurmukhi": "ਜੀਅਰੇ ਓਲੑਾ ਨਾਮ ਕਾ ॥",
          "roman": "Jīare olhā nām kā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ ਜਿੰਦੇ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ (ਹੀ) ਆਸਰਾ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਸਹਾਇਤਾ ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О моя душа! Опорой имени Всевышнего только и бывает поддержка в этом мире и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9032,
          "is_rahao": true,
          "gurmukhi": "ਅਵਰੁ ਜਿ ਕਰਨ ਕਰਾਵਨੋ ਤਿਨ ਮਹਿ ਭਉ ਹੈ ਜਾਮ ਕਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Avar ji karan karāvano tin meh bhau hē jām kā.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਤੋਂ ਬਿਨਾ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਹੋਰ ਜਿਤਨਾ ਭੀ ਉੱਦਮ-ਜਤਨ ਹੈ ਉਹਨਾਂ ਸਾਰੇ ਕੰਮਾਂ ਵਿਚ ਆਤਮਕ ਮੌਤ ਦਾ ਖ਼ਤਰਾ (ਬਣਦਾ ਜਾਂਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Кроме этого, сколько бы ни было иных усилий и стараний ради майи, во всех этих делах возрастает опасность духовной смерти. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9033,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਜਤਨਿ ਨਹੀ ਪਾਈਐ ॥",
          "roman": "Avar jatan nahī pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਭੀ) ਹੋਰ ਜਤਨ ਨਾਲ ਪਰਮਾਤਮਾ ਨਹੀਂ ਮਿਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никакими иными средствами Всевышнего не достичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9034,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਹਰਿ ਧਿਆਈਐ ॥੧॥",
          "roman": "Vaḍē bhāg har dhiāīē.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਵੱਡੀ ਕਿਸਮਤਿ ਨਾਲ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но лишь по великой удаче человек может предаваться памятованию о Хари. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9035,
          "is_rahao": false,
          "gurmukhi": "ਲਾਖ ਹਿਕਮਤੀ ਜਾਨੀਐ ॥",
          "roman": "Lākh hikmatī jānīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਜਗਤ ਵਿਚ) ਲੱਖਾਂ ਚਤੁਰਾਈਆਂ ਦੇ ਕਾਰਨ ਇੱਜ਼ਤ ਖੱਟ ਲਈਏ,"
            },
            "sahib_singh_ru": {
              "main": "Пусть даже в мире удастся приобрести почёт благодаря тысячам хитроумных уловок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9036,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਤਿਲੁ ਨਹੀ ਮਾਨੀਐ ॥੨॥",
          "roman": "Āgē til nahī mānīē.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਲੋਕ ਵਿਚ (ਇਹਨਾਂ ਹਿਕਮਤਾਂ ਦੇ ਕਾਰਨ) ਰਤਾ ਜਿਤਨਾ ਭੀ ਆਦਰ ਨਹੀਂ ਮਿਲਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "в ином мире из-за этих ухищрений не получишь и крупицы уважения. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9037,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਬੁਧਿ ਕਰਮ ਕਮਾਵਨੇ ॥ ਗ੍ਰਿਹ ਬਾਲੂ ਨੀਰਿ ਬਹਾਵਨੇ ॥੩॥",
          "roman": "Ahaṃbudh karam kamāvane. Grih bālū nīr bahāvane.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜਿੰਦੇ! ਜੇ ਆਪਣੇ ਵਲੋਂ ਧਾਰਮਿਕ) ਕੰਮ (ਭੀ) ਕੀਤੇ ਜਾਣ (ਪਰ ਉਹ) ਹਉਮੈ ਵਾਲੀ ਅਕਲ ਵਧਾਣ ਵਾਲੇ ਹੀ ਹੋਣ, ਤਾਂ ਉਹ ਅਜੇਹੇ ਕਰਮ ਰੇਤ ਦੇ ਘਰਾਂ ਵਾਂਗ ਹੀ ਹਨ ਜਿਨ੍ਹਾਂ ਨੂੰ (ਹੜ੍ਹ ਦੇ) ਪਾਣੀ ਨੇ ਰੋੜ੍ਹ ਦਿੱਤਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Если даже совершать религиозные дела, но они лишь питают разум, полный Хоумэ, тогда такие дела подобны домам из песка, которые смыло потоком воды. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9038,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਕ੍ਰਿਪਾਲੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "Prabh kirpāl kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦਾ ਸੋਮਾ ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਕਿਰਪਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда источник милости, Всевышний, оказывает человеку свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9039,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਨਾਨਕ ਸਾਧੂ ਸੰਗਿ ਮਿਲੈ ॥੪॥੪॥੧੪੨॥",
          "roman": "Nām Nānak sādhū sang milē.4.4.142.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਸ ਨੂੰ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮਿਲਦਾ ਹੈ ॥੪॥੪॥੧੪੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда, о Нанак, в обществе Гуру он обретает имя Всевышнего. 4.4.142."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 663,
      "rahao_verse_id": 9042,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9040,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9041,
          "is_rahao": true,
          "gurmukhi": "ਬਾਰਨੈ ਬਲਿਹਾਰਨੈ ਲਖ ਬਰੀਆ ॥",
          "roman": "Bārnē balihāranē lakh barīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ (ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ) ਲੱਖਾਂ ਵਾਰੀ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я сотни тысяч раз иду в жертву, иду в посвящение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9042,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੋ ਹੋ ਨਾਮੁ ਸਾਹਿਬ ਕੋ ਪ੍ਰਾਨ ਅਧਰੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Nāmo ho nām sāhib ko prān adharīā.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਲਕ-ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਨਾਮ ਜੀਵਾਂ ਦੀਆਂ ਜਿੰਦਾਂ ਦਾ ਆਸਰਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Одно лишь имя Господа-Владыки есть опора жизни всех существ. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9043,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਤੁਹੀ ਏਕ ॥",
          "roman": "Karan karāvan tuhī ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਿਰਫ਼ ਤੂੰ ਹੀ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਤਾਕਤ ਰੱਖਦਾ ਹੈਂ, ਜੀਵਾਂ ਪਾਸੋਂ ਕਰਾਣ ਦੀ ਸਮਰੱਥਾ ਰੱਖਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Только Ты один имеешь силу всё совершать и побуждать существ к действию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9044,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਕੀ ਤੁਹੀ ਟੇਕ ॥੧॥",
          "roman": "Jīa jant kī tuhī ṭek.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹੀ ਸਾਰੇ ਜੀਵਾਂ-ਜੰਤਾਂ ਦਾ ਸਹਾਰਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты один поддержка всех живых существ. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9045,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜ ਜੋਬਨ ਪ੍ਰਭ ਤੂੰ ਧਨੀ ॥ ਤੂੰ ਨਿਰਗੁਨ ਤੂੰ ਸਰਗੁਨੀ ॥੨॥",
          "roman": "Rāj joban prabh tūṃ dhanī. Tūṃ nirgun tūṃ sargunī.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਹੀ ਹਕੂਮਤ ਦਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਹੀ ਜਵਾਨੀ ਦਾ ਮਾਲਕ ਹੈਂ (ਤੈਥੋਂ ਹੀ ਜੀਵ ਦੁਨੀਆ ਵਿਚ ਹਕੂਮਤ ਕਰਨ ਦੀ  ਦਾਤ ਲੈਂਦੇ ਹਨ, ਤੈਥੋਂ ਹੀ ਜਵਾਨੀ ਪ੍ਰਾਪਤ ਕਰਦੇ ਹਨ)। (ਜਦੋਂ ਜਗਤ ਨਹੀਂ ਸੀ ਬਣਿਆ) ਮਾਇਆ ਦੇ ਤਿੰਨਾਂ ਗੁਣਾਂ ਤੋਂ ਰਹਿਤ ਭੀ ਤੂੰ ਹੈਂ, (ਹੁਣ ਤੂੰ ਜਗਤ ਰਚ ਦਿੱਤਾ ਹੈ) ਇਹ ਦਿੱਸਦਾ ਆਕਾਰ ਮਾਇਆ ਦੇ ਤਿੰਨਾਂ ਗੁਣਾਂ ਵਾਲਾ-ਇਹ ਭੀ ਤੂੰ ਆਪ ਹੀ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты владыка власти, Ты владыка молодости. От Тебя существа получают дар властвовать в мире, от Тебя получают юность. Когда мира ещё не было, Ты был вне трёх качеств майи, и теперь, когда мир сотворён, этот видимый образ, исполненный трёх качеств майи, тоже есть Ты Сам. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9046,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਤੁਮ ਰਖੇ ॥",
          "roman": "Īhā ūhā tum rakhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਇਸ ਲੋਕ ਵਿਚ ਤੇ ਪਰਲੋਕ ਵਿਚ ਤੂੰ ਹੀ ਸਭ ਦੀ ਰੱਖਿਆ ਕਰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! И в этом мире, и в мире ином Ты один хранишь всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9047,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਕੋ ਲਖੇ ॥੩॥",
          "roman": "Gur kirpā te ko lakhē.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਇਹ ਭੇਤ) ਸਮਝਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но лишь редкий человек по милости Гуру понимает эту тайну. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9048,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਪ੍ਰਭ ਸੁਜਾਨੁ ॥",
          "roman": "Antarjāmī prabh sujān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈਂ, ਤੂੰ ਹੀ ਸਿਆਣਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты знаешь сердца всех, Ты один поистине мудр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9049,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਕੀਆ ਤੁਹੀ ਤਾਣੁ ॥੪॥੫॥੧੪੩॥",
          "roman": "Nānak takīā tuhī tāṇ.4.5.143.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਦਾ ਸਹਾਰਾ ਤੂੰ ਹੀ ਹੈਂ, ਨਾਨਕ ਦਾ ਤਾਣ ਤੂੰ ਹੀ ਹੈਂ ॥੪॥੫॥੧੪੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ты один опора Нанаку, Ты один его сила. 4.5.143."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 664,
      "rahao_verse_id": 9052,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9050,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9051,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਹਰਿ ਆਰਾਧੀਐ ॥",
          "roman": "Har har har ārādhīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Следует всегда созерцать имя Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9052,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਹਰਿ ਮਨਿ ਵਸੈ ਭਰਮੁ ਮੋਹੁ ਭਉ ਸਾਧੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Santsang har man વસē bharam moh bhau sādhīē.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਹੀ) ਪਰਮਾਤਮਾ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਵੱਸ ਸਕਦਾ ਹੈ, ਭਟਕਣਾ ਨੂੰ, ਮੋਹ ਨੂੰ ਤੇ ਡਰ-ਸਹਮ ਨੂੰ ਕਾਬੂ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Только в обществе святых Всевышний может поселиться в уме человека, и только так можно обуздать блуждание, привязанность и страх. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9053,
          "is_rahao": false,
          "gurmukhi": "ਬੇਦ ਪੁਰਾਣ ਸਿਮ੍ਰਿਤਿ ਭਨੇ ॥",
          "roman": "Bed purāṇ simrit bhane",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪੰਡਤ ਲੋਕ ਭਾਵੇਂ) ਵੇਦ ਪੁਰਾਣ ਸਿਮ੍ਰਿਤੀਆਂ (ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕਾਂ) ਪੜ੍ਹਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пусть учёные и читают Веды, Пураны и Смрити,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9054,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਊਚ ਬਿਰਾਜਿਤ ਜਨ ਸੁਨੇ ॥੧॥",
          "roman": "Sabh ūch birājit jan sune.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਸੰਤ ਜਨ ਹੋਰ ਸਭ ਲੋਕਾਂ ਤੋਂ ਉੱਚੇ ਆਤਮਕ ਟਿਕਾਣੇ ਤੇ ਟਿਕੇ ਹੋਏ ਸੁਣੇ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но слышно, что святые пребывают на более высоком духовном уровне, чем все остальные. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9055,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਅਸਥਾਨ ਭੈ ਭੀਤ ਚੀਨ ॥",
          "roman": "Sagal asthān bhē bhīt chīn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਹੋਰ ਸਾਰੇ ਹਿਰਦੇ-ਥਾਂ ਡਰਾਂ ਨਾਲ ਸਹਮੇ ਹੋਏ ਵੇਖੀਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Все прочие состояния сердца видятся исполненными страха и тревоги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9056,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਸੇਵਕ ਭੈ ਰਹਤ ਕੀਨ ॥੨॥",
          "roman": "Rām sevak bhē rahat kīn.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਨੇ) ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਨੂੰ ਡਰਾਂ ਤੋਂ ਰਹਿਤ ਕਰ ਦਿੱਤਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а памятование о Всевышнем сделало Его слуг свободными от страха. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9057,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਚਉਰਾਸੀਹ ਜੋਨਿ ਫਿਰਹਿ ॥",
          "roman": "Lakh chaurāsīh jon fireh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੀਵ) ਚੌਰਾਸੀ ਲੱਖ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Живые существа блуждают по восьмидесяти четырём лакхам форм существования,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9058,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਲੋਕ ਨਹੀ ਜਨਮਿ ਮਰਹਿ ॥੩॥",
          "roman": "Gobind lok nahī janam mareh.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но преданные Всевышнего не попадают в круг рождения и смерти. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9059,
          "is_rahao": false,
          "gurmukhi": "ਬਲ ਬੁਧਿ ਸਿਆਨਪ ਹਉਮੈ ਰਹੀ ॥ ਹਰਿ ਸਾਧ ਸਰਣਿ ਨਾਨਕ ਗਹੀ ॥੪॥੬॥੧੪੪॥",
          "roman": "Bal budh siānap haumē rahī. Har sādh saraṇ Nānak gahī.4.6.144.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ) ਪਰਮਾਤਮਾ ਦਾ ਗੁਰੂ ਦਾ ਆਸਰਾ ਲੈ ਲਿਆ, ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ ਹਉਮੈ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ। ਹੇ ਨਾਨਕ! ਉਹ ਆਪਣੀ ਤਾਕਤ ਦਾ ਆਪਣੀ ਅਕਲ ਦਾ ਆਪਣੀ ਸਿਆਣਪ ਦਾ ਆਸਰਾ ਨਹੀਂ ਲੈਂਦੇ ॥੪॥੬॥੧੪੪॥"
            },
            "sahib_singh_ru": {
              "main": "У тех людей, что приняли опору Всевышнего через Гуру, Хоумэ исчезает изнутри. О Нанак! Они больше не опираются на свою силу, свой ум и свою сообразительность. 4.6.144."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 665,
      "rahao_verse_id": 9062,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9060,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9061,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਰਾਮ ਨਾਮ ਗੁਨ ਗਾਈਐ ॥",
          "roman": "Man Rām nām gun gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! (ਆ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰੀਏ, ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਇਨ ਕਰੀਏ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Давай вспоминать имя Всевышнего, давай воспевать качества Всевышнего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9062,
          "is_rahao": true,
          "gurmukhi": "ਨੀਤ ਨੀਤ ਹਰਿ ਸੇਵੀਐ ਸਾਸਿ ਸਾਸਿ ਹਰਿ ਧਿਆਈਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Nīt nīt har sevīai sās sās har dhiāīai.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਸਦਾ ਹੀ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О ум! Следует всегда предаваться служению Всевышнему. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9063,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਹਰਿ ਮਨਿ ਵਸੈ ॥",
          "roman": "Santsang har man વસē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ-ਸੰਤ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਿਹਾਂ) ਪਰਮਾਤਮਾ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В обществе Гуру-святого Всевышний поселяется в уме человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9064,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਦਰਦੁ ਅਨੇਰਾ ਭ੍ਰਮੁ ਨਸੈ ॥੧॥",
          "roman": "Dukh dard anerā bharam nasē.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਵੱਸ ਪੈਂਦਾ ਹੈ ਉਸ ਦੇ ਅੰਦਰੋਂ) ਹਰੇਕ ਕਿਸਮ ਦਾ ਦੁੱਖ ਦਰਦ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਮੋਹ ਦਾ ਹਨੇਰਾ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, (ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ) ਭਟਕਣਾ ਮੁੱਕ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "У того, в чьём уме Он поселяется, исчезают всякая боль и страдание, уходит тьма привязанности и прекращается блуждание ради майи. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9065,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਹਰਿ ਜਾਪੀਐ ॥ ਸੋ ਜਨੁ ਦੂਖਿ ਨ ਵਿਆਪੀਐ ॥੨॥",
          "roman": "Sant prasād har jāpīai. So jan dūkh na viāpīai.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਹੀ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ। (ਜੇਹੜਾ ਮਨੁੱਖ ਜਪਦਾ ਹੈ) ਉਹ ਮਨੁੱਖ ਕਿਸੇ ਕਿਸਮ ਦੇ ਦੁੱਖ ਵਿਚ ਨਹੀਂ ਘਿਰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Только по милости Гуру можно повторять имя Всевышнего. И тот, кто повторяет, не оказывается охвачен никаким страданием. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9066,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਗੁਰੁ ਹਰਿ ਮੰਤ੍ਰੁ ਦੇ ॥",
          "roman": "Jā kau gur har mantr de",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਗੁਰੂ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਮੰਤ੍ਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому человеку, кому Гуру даёт мантру имени Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9067,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਉਬਰਿਆ ਮਾਇਆ ਅਗਨਿ ਤੇ ॥੩॥",
          "roman": "So ubariā māiā agan te.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮਾਇਆ ਦੀ (ਤ੍ਰਿਸ਼ਨਾ) ਅੱਗ (ਵਿਚ ਸੜਨ) ਤੋਂ ਬਚ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "удаётся спастись от сгорания в огне жажды майи. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9068,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਮਇਆ ਕਰਿ ॥",
          "roman": "Nānak kau prabh maiā kar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਮੈਂ) ਨਾਨਕ ਉਤੇ ਕਿਰਪਾ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Окажи милость Нанаку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9069,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੈ ਮਨਿ ਤਨਿ ਵਾਸੈ ਨਾਮੁ ਹਰਿ ॥੪॥੭॥੧੪੫॥",
          "roman": "Merē man tan vāsē nām har.4.7.145.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਕਿ) ਮੇਰੇ ਮਨ ਵਿਚ ਹਿਰਦੇ ਵਿਚ, ਹੇ ਹਰੀ! ਤੇਰਾ ਨਾਮ ਵੱਸ ਪਏ ॥੪॥੭॥੧੪੫॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы в моём уме и в моём сердце поселилось Твоё имя, о Хари. 4.7.145."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 666,
      "rahao_verse_id": 9072,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 9070,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9071,
          "is_rahao": true,
          "gurmukhi": "ਰਸਨਾ ਜਪੀਐ ਏਕੁ ਨਾਮ ॥",
          "roman": "Rasnā japīai ek nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੀਭ ਨਾਲ ਹਰਿ-ਨਾਮ ਜਪਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Следует непрестанно повторять языком одно имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9072,
          "is_rahao": true,
          "gurmukhi": "ਈਹਾ ਸੁਖੁ ਆਨੰਦੁ ਘਨਾ ਆਗੈ ਜੀਅ ਕੈ ਸੰਗਿ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Īhā sukh ānand ghanā āgē jīa kē sang kām.1. Rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਹਰਿ-ਨਾਮ ਜਪਦੇ ਰਹੀਏ ਤਾਂ) ਇਸ ਲੋਕ ਵਿਚ (ਇਸ ਜੀਵਨ ਵਿਚ) ਬਹੁਤ ਸੁਖ-ਆਨੰਦ ਮਿਲਦਾ ਹੈ ਤੇ ਪਰਲੋਕ ਵਿਚ (ਇਹ ਹਰਿ-ਨਾਮ) ਜਿੰਦ ਦੇ ਕੰਮ ਆਉਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если повторять имя Хари, то в этом мире приходит великое счастье и радость, а в мире ином это имя служит душе на пользу. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9073,
          "is_rahao": false,
          "gurmukhi": "ਕਟੀਐ ਤੇਰਾ ਅਹੰ ਰੋਗੁ ॥",
          "roman": "Kaṭīai terā ahaṃ rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਤੇਰਾ ਹਉਮੈ ਦਾ ਰੋਗ ਕੱਟਿਆ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Благодатью имени Хари может быть отсечена твоя болезнь Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9074,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਗੁਰ ਪ੍ਰਸਾਦਿ ਕਰਿ ਰਾਜ ਜੋਗੁ ॥੧॥",
          "roman": "Tūṃ gur prasād kar rāj jog.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਜਪ ਜਪ ਕੇ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਤੂੰ ਗ੍ਰਿਹਸਤ ਦਾ ਸੁਖ ਭੀ ਲੈ ਸਕਦਾ ਹੈਂ, ਤੇ ਪ੍ਰਭੂ ਨਾਲ ਮਿਲਾਪ ਭੀ ਪ੍ਰਾਪਤ ਕਰ ਸਕਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя имя, по милости Гуру ты можешь и вкусить счастье домохозяйской жизни, и обрести соединение с Господом. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9075,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸੁ ਜਿਨਿ ਜਨਿ ਚਾਖਿਆ ॥",
          "roman": "Har ras jin jan chākhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਰਸ ਚੱਖ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, кто вкусил нектар имени Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9076,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਤ੍ਰਿਸਨਾ ਲਾਥੀਆ ॥੨॥",
          "roman": "Tā kī trisnā lāthīā.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ (ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਲਹਿ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "освобождается от жажды майи. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9077,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਬਿਸ੍ਰਾਮ ਨਿਧਿ ਪਾਇਆ ॥",
          "roman": "Har bisrām nidh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਹਰਿ-ਨਾਮ-ਰਸ ਚੱਖ ਲਿਆ) ਉਸ ਨੂੰ ਸ਼ਾਂਤੀ ਦਾ ਖ਼ਜ਼ਾਨਾ ਪਰਮਾਤਮਾ ਮਿਲ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто вкусил нектар имени Хари, находит Самого Всевышнего как сокровище покоя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9078,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬਹੁਰਿ ਨ ਕਤ ਹੀ ਧਾਇਆ ॥੩॥",
          "roman": "So bahur na kat hī dhāiā.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮੁੜ ਕਿਸੇ ਭੀ ਹੋਰ ਪਾਸੇ ਭਟਕਦਾ ਨਹੀਂ ਫਿਰਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и такой человек уже больше никуда не мечется и не блуждает. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9079,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਾ ਕਉ ਗੁਰਿ ਦੀਆ ॥",
          "roman": "Har har nām jā kau gur dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਬਖ਼ਸ਼ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которому Гуру даровал имя Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 9080,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕਾ ਭਉ ਗਇਆ ॥੪॥੮॥੧੪੬॥",
          "roman": "Nānak tā kā bhau gaiā.4.8.146.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਨਾਨਕ) ਉਸ ਦਾ ਹਰੇਕ ਕਿਸਮ ਦਾ ਡਰ ਦੂਰ ਹੋ ਗਿਆ ॥੪॥੮॥੧੪੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, исчез всякий страх. 4.8.146."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
