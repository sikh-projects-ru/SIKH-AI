{
  "ang": 236,
  "shabads": [
    {
      "shabad_id": 731,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10218,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਸਭੁ ਕਿਛੁ ਏਕੈ ॥",
          "roman": "karan karāvan sabh kichh ekē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਵਿਚਾਰੇ ਦੇ ਕੀਹ ਵੱਸ?) ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਹੀ (ਹਰੇਕ ਜੀਵ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ) ਸਭ ਕੁਝ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Что подвластно бедному существу? Только один Бог, пронизывая каждое существо, делает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10219,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਬੁਧਿ ਬੀਚਾਰਿ ਬਿਬੇਕੈ ॥",
          "roman": "āpe budh bīchār bibekē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ ਪ੍ਰਭੂ ਆਪ ਹੀ (ਹਰੇਕ ਜੀਵ ਨੂੰ) ਅਕਲ (ਬਖ਼ਸ਼ਦਾ ਹੈ), ਆਪ ਹੀ (ਹਰੇਕ ਜੀਵ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ) ਵਿਚਾਰ ਕੇ (ਜੀਵਨ ਜੁਗਤਿ ਨੂੰ) ਪਰਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И Сам Господь дарует разум, Сам, пребывая в каждом существе, размышляет и распознаёт жизненный путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10220,
          "is_rahao": false,
          "gurmukhi": "ਦੂਰਿ ਨ ਨੇਰੈ ਸਭ ਕੈ ਸੰਗਾ ॥",
          "roman": "dūr na nerē sabh kē saṅgā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਕਿਸੇ ਤੋਂ ਦੂਰ ਨਹੀਂ ਵੱਸਦਾ, ਸਭ ਦੇ ਨੇੜੇ ਵੱਸਦਾ ਹੈ, ਸਭ ਦੇ ਨਾਲ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Бог не пребывает далеко ни от кого: Он близок ко всем, Он со всеми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10221,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸਾਲਾਹਣੁ ਨਾਨਕ ਹਰਿ ਰੰਗਾ ॥੮॥੧॥",
          "roman": "sach sālāhaṇ nānak har raṅgā. ||8||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਪ੍ਰਭੂ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਉਹੀ ਸਭ ਚੋਜ-ਤਮਾਸ਼ੇ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਹੀ ਸਾਲਾਹਣ-ਜੋਗ ਹੈ ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Этот Господь — вечно сущий; Он же совершает все дивные игры, и Он один достоин хвалы. ||8||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 732,
      "rahao_verse_id": 10228,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10222,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10223,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਨਾਮੇ ਲਾਗਾ ॥",
          "roman": "gur sēvā tē nāmē lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਮੇਰੇ ਮਨ!) ਉਹ ਮਨੁੱਖ ਹੀ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜਦਾ ਹੈ ਜੇਹੜਾ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но, о мой ум! Только тот человек соединяется с Именем Вахегуру, кто приходит в прибежище Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10224,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਉ ਮਿਲਿਆ ਜਿਸੁ ਮਸਤਕਿ ਭਾਗਾ ॥",
          "roman": "tis kau miliā jis mastak bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਮਨੁੱਖ ਹਰਿ-ਨਾਮ ਵਿਚ ਲੱਗਦਾ ਹੈ, ਤੇ ਗੁਰੂ) ਉਸ ਮਨੁੱਖ ਨੂੰ ਮਿਲਦਾ ਹੈ ਜਿਸ ਦੇ ਮੱਥੇ ਉਤੇ ਭਾਗ ਜਾਗ ਪੈਣ।"
            },
            "sahib_singh_ru": {
              "main": "К такому человеку приходит Гуру, у которого на челе пробудилась удача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10225,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੈ ਹਿਰਦੈ ਰਵਿਆ ਸੋਇ ॥",
          "roman": "tis kē hirdē raviā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ) ਉਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਪਰਮਾਤਮਾ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда в сердце этого человека поселяется Сам Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10226,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਸੀਤਲੁ ਨਿਹਚਲੁ ਹੋਇ ॥੧॥",
          "roman": "man tan sītal nihchal hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਦਾ ਮਨ ਤੇ ਸਰੀਰ (ਹਿਰਦਾ) ਠੰਢਾ-ਠਾਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਵਿਕਾਰਾਂ ਵਲੋਂ ਅਡੋਲ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и его ум и тело, то есть сердце, становятся прохладными и спокойными, неподвижными перед пороками. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10227,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਕੀਰਤਨੁ ਕਰਿ ਮਨ ਮੇਰੇ ॥",
          "roman": "aisā kīrtan kar man mērē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਇਹੋ ਜਿਹੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Совершай такую хвалу Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10228,
          "is_rahao": true,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਜੋ ਕਾਮਿ ਤੇਰੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "īhā ūhā jo kām tērāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਤੇਰੀ ਇਸ ਜ਼ਿੰਦਗੀ ਵਿਚ ਭੀ ਕੰਮ ਆਵੇ, ਤੇ ਪਰਲੋਕ ਵਿਚ ਭੀ ਤੇਰੇ ਕੰਮ ਆਵੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "которая пригодится тебе и в этой жизни, и в мире ином. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10229,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਭਉ ਅਪਦਾ ਜਾਇ ॥",
          "roman": "jās japat bhau apdā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ! ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ) ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ਹਰੇਕ ਬਿਪਤਾ ਟਲ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Прославляй того Вахегуру, чьё Имя, будучи повторяемым, устраняет всякий страх и отводит всякую беду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10230,
          "is_rahao": false,
          "gurmukhi": "ਧਾਵਤ ਮਨੂਆ ਆਵੈ ਠਾਇ ॥",
          "roman": "dhāvat manūā āvē ṭhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਕਾਰਾਂ ਵਲ ਦੌੜਦਾ ਮਨ ਟਿਕਾਣੇ ਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и ум, бегущий к порокам, приходит к устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10231,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਫਿਰਿ ਦੂਖੁ ਨ ਲਾਗੈ ॥",
          "roman": "jās japat phir dūkh na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਫਿਰ ਕੋਈ ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, делает так, что больше никакое страдание не касается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10232,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਇਹ ਹਉਮੈ ਭਾਗੈ ॥੨॥",
          "roman": "jās japat ih haumē bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਅੰਦਰੋਂ ਹਉਮੈ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, прогоняет изнутри Хоумэ. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10233,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਵਸਿ ਆਵਹਿ ਪੰਚਾ ॥",
          "roman": "jās japat vas āvah panchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ (ਕਾਮਾਦਿਕ) ਪੰਜੇ ਵਿਕਾਰ ਕਾਬੂ ਆ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, подчиняет пять пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10234,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਰਿਦੈ ਅੰਮ੍ਰਿਤੁ ਸੰਚਾ ॥",
          "roman": "jās japat ridē amrit sanchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ ਹਿਰਦੇ ਵਿਚ ਇਕੱਠਾ ਕਰ ਸਕੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чьё Имя, будучи повторяемым, позволяет собрать в сердце нектар Имени, дающий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10235,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਇਹ ਤ੍ਰਿਸਨਾ ਬੁਝੈ ॥",
          "roman": "jās japat ih trisanā bujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਾਇਆ ਦੀ ਤ੍ਰੇਹ ਬੁੱਝ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, гасит жажду майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10236,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਹਰਿ ਦਰਗਹ ਸਿਝੈ ॥੩॥",
          "roman": "jās japat har dargah sijhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਪਰਮਾਤਮਾ ਦੀ ਦਰਗਾਹ ਵਿਚ ਭੀ ਕਾਮਯਾਬ ਹੋ ਜਾਈਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, делает человека успешным и в даргахе Вахегуру. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10237,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਕੋਟਿ ਮਿਟਹਿ ਅਪਰਾਧ ॥",
          "roman": "jās japat koṭ miṭah aprādh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ) ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ (ਪਿਛਲੇ ਕੀਤੇ ਹੋਏ) ਕ੍ਰੋੜਾਂ ਪਾਪ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Прославляй того Вахегуру, чьё Имя, будучи повторяемым, стирает миллионы прежде совершённых грехов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10238,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਹਰਿ ਹੋਵਹਿ ਸਾਧ ॥",
          "roman": "jās japat har hovah sādh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ (ਅਗਾਂਹ ਵਾਸਤੇ) ਭਲੇ ਮਨੁੱਖ ਬਣ ਜਾਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, делает человека впредь добродетельным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10239,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਮਨੁ ਸੀਤਲੁ ਹੋਵੈ ॥",
          "roman": "jās japat man sītal hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਨ (ਵਿਕਾਰਾਂ ਦੀ ਤਪਸ਼ ਵਲੋਂ) ਠੰਢਾ-ਠਾਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, охлаждает ум от жара пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10240,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਮਲੁ ਸਗਲੀ ਖੋਵੈ ॥੪॥",
          "roman": "jās japat മല saglī khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਆਪਣੇ ਅੰਦਰ ਦੀ (ਵਿਕਾਰਾਂ ਦੀ) ਸਾਰੀ ਮੈਲ ਦੂਰ ਕਰ ਲੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, удаляет всю внутреннюю грязь пороков. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10241,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਰਤਨੁ ਹਰਿ ਮਿਲੈ ॥",
          "roman": "jās japat ratan har milē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਜਾਪ ਕੀਤਿਆਂ ਮਨੁੱਖ ਨੂੰ ਹਰਿ-ਨਾਮ-ਰਤਨ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Через повторение чьего Имени человек получает драгоценность Имени Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10242,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਨ ਛੋਡੈ ਹਰਿ ਸੰਗਿ ਹਿਲੈ ॥",
          "roman": "bahur na chhoḍē har sang hilē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨਾਲ ਇਤਨਾ ਰਚ-ਮਿਚ ਜਾਂਦਾ ਹੈ ਕਿ (ਪ੍ਰਾਪਤ ਕੀਤੇ ਹੋਏ ਉਸ ਨਾਮ-ਰਤਨ ਨੂੰ) ਮੁੜ ਨਹੀਂ ਛੱਡਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и благодаря симрану так соединяется с Вахегуру, что уже не оставляет снова эту драгоценность Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10243,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਕਈ ਬੈਕੁੰਠ ਵਾਸੁ ॥",
          "roman": "jās japat kaī bēkunṭh vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਆਤਮਕ ਆਨੰਦ ਮਿਲਦਾ ਹੈ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕਾਣਾ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Через повторение чьего Имени обретается духовное блаженство и пребывание в духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10244,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਸੁਖ ਸਹਜਿ ਨਿਵਾਸੁ ॥੫॥",
          "roman": "jās japat sukh sahaj nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਾਨੋ, ਅਨੇਕਾਂ ਬੈਕੁੰਠਾਂ ਦਾ ਨਿਵਾਸ ਹਾਸਲ ਹੋ ਜਾਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и через повторение чьего Имени словно достигается обитель многих байкунтхов. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10245,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਇਹ ਅਗਨਿ ਨ ਪੋਹਤ ॥",
          "roman": "jās japat ih agan na pohat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ) ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਤ੍ਰਿਸ਼ਨਾਂ ਦੀ ਅੱਗ ਪੋਹ ਨਹੀਂ ਸਕੇਗੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Прославляй того Вахегуру, чьё Имя, будучи повторяемым, не позволяет огню желаний коснуться тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10246,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਇਹੁ ਕਾਲੁ ਨ ਜੋਹਤ ॥",
          "roman": "jās japat ihu kāl na johat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮੌਤ ਦਾ ਸਹਮ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕੇਗਾ (ਆਤਮਕ ਮੌਤ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾਇਗੀ)।"
            },
            "sahib_singh_ru": {
              "main": "чьё Имя, будучи повторяемым, не подпускает близко страх смерти, и духовная смерть не сможет проявить свою силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10247,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਤੇਰਾ ਨਿਰਮਲ ਮਾਥਾ ॥",
          "roman": "jās japat tērā nirmal māthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਹਰ ਥਾਂ ਤੂੰ ਉੱਜਲ-ਮੁਖ ਰਹੇਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, делает так, что везде ты остаёшься со светлым лицом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10248,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਸਗਲਾ ਦੁਖੁ ਲਾਥਾ ॥੬॥",
          "roman": "jās japat saglā dukh lāthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਇਗਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, удаляет всякое страдание. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10249,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਮੁਸਕਲੁ ਕਛੂ ਨ ਬਨੈ ॥",
          "roman": "jās japat muskal kachhū na banē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਰਹੁ) ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ (ਮਨੁੱਖ ਦੇ ਜੀਵਨ-ਸਫ਼ਰ ਵਿਚ) ਕੋਈ ਔਖਿਆਈ ਨਹੀਂ ਬਣਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Прославляй того Вахегуру, чьё Имя, будучи повторяемым, не оставляет никаких трудностей на жизненном пути,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10250,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਸੁਣਿ ਅਨਹਤ ਧੁਨੈ ॥",
          "roman": "jās japat suṇ anhat dhunē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਨੁੱਖ ਇਕ-ਰਸ ਆਤਮਕ ਆਨੰਦ ਦੇ ਗੀਤ ਦੀ ਧੁਨਿ ਸੁਣਦਾ ਰਹਿੰਦਾ ਹੈ (ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਹਰ ਵੇਲੇ ਆਤਮਕ ਆਨੰਦ ਦੀ ਰੌ ਚਲੀ ਰਹਿੰਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, позволяет человеку слышать мелодию неумолкающего духовного блаженства, то есть внутри всегда течёт поток духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10251,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਇਹ ਨਿਰਮਲ ਸੋਇ ॥",
          "roman": "jās japat ih nirmal soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਨੁੱਖ ਦਾ ਹਿਰਦਾ-ਕਮਲ (ਵਿਕਾਰਾਂ ਵਲੋਂ ਉਲਟ ਕੇ, ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਵਲ) ਸਿੱਧਾ ਪਰਤ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё Имя, будучи повторяемым, распрямляет сердечный лотос человека, отворачивая его от пороков к памяти о Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10252,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਜਪਤ ਕਮਲੁ ਸੀਧਾ ਹੋਇ ॥੭॥",
          "roman": "jās japat kamal sīdhā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਦਾ ਨਾਮ ਜਪਿਆਂ ਮਨੁੱਖ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਪਵਿਤ੍ਰ ਸੋਭਾ ਖੱਟਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и чьё Имя, будучи повторяемым, приносит человеку чистую славу в этом и ином мире. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10253,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਸੁਭ ਦ੍ਰਿਸਟਿ ਸਭ ਊਪਰਿ ਕਰੀ ॥",
          "roman": "gur subh drisṭ sabh ūpar karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਨੁੱਖ ਉਤੇ ਗੁਰੂ ਨੇ (ਮਾਨੋ) ਸਭ ਤੋਂ ਵਧੀਆ ਕਿਸਮ ਦੀ ਮਿਹਰ ਦੀ ਨਜ਼ਰ ਕਰ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! На того человека Гуру словно излил самый благой взгляд милости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10254,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਹਿਰਦੈ ਮੰਤ੍ਰੁ ਦੇ ਹਰੀ ॥",
          "roman": "jis kē hirdē mantr dē harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਦਾ ਉਪਦੇਸ਼ ਵਸਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в сердце которого он поселяет наставление повторять Имя Вахегуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10255,
          "is_rahao": false,
          "gurmukhi": "ਅਖੰਡ ਕੀਰਤਨੁ ਤਿਨਿ ਭੋਜਨੁ ਚੂਰਾ ॥",
          "roman": "akhaṇḍ kīrtan tin bhojan chūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਪਰਮਾਤਮਾ ਦੀ ਇਕ-ਰਸ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨੂੰ ਆਪਣੇ ਆਤਮਾ ਵਾਸਤੇ ਸੁਆਦਲਾ ਭੋਜਨ ਬਣਾ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек сделал непрерывную хвалу Вахегуру вкусной пищей для своей души,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10256,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਸੁ ਸਤਿਗੁਰੁ ਪੂਰਾ ॥੮॥੨॥",
          "roman": "kah Nānak jis satgur pūrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ, ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪਿਆ ॥੮॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "говорит Нанак, тот человек встретил Совершенного Сатгуру. ॥8॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 733,
      "rahao_verse_id": 10263,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10257,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "gaurī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10258,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਿਦ ਅੰਤਰਿ ਧਾਰੈ ॥",
          "roman": "gur kā sabad rid antar dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਹੁੰਦੀ ਹੈ) ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਵਸਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на которого нисходит милость Вахегуру, помещает в своё сердце Шабад Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10259,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਜਨਾ ਸਿਉ ਸੰਗੁ ਨਿਵਾਰੈ ॥",
          "roman": "panch janā siu sang nivārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਨਾਲੋਂ ਆਪਣਾ ਸਾਥ ਹਟਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и отстраняет себя от общения с пятью пороками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10260,
          "is_rahao": false,
          "gurmukhi": "ਦਸ ਇੰਦ੍ਰੀ ਕਰਿ ਰਾਖੈ ਵਾਸਿ ॥",
          "roman": "das indrī kar rākhē vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਸਾਂ ਹੀ ਇੰਦ੍ਰੀਆਂ ਨੂੰ ਆਪਣੇ ਕਾਬੂ ਵਿਚ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он подчиняет себе все десять чувств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10261,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਆਤਮੈ ਹੋਇ ਪਰਗਾਸੁ ॥੧॥",
          "roman": "tā kē ātmāi hoi pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਦੇ ਆਤਮਾ ਵਿਚ ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ (ਉਸ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਪੈ ਜਾਂਦੀ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и в его душе возникает свет, то есть приходит понимание духовной жизни. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10262,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਦ੍ਰਿੜਤਾ ਤਾ ਕੈ ਹੋਇ ॥",
          "roman": "ēsī driṛhtā tā kē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਅਜੇਹਾ ਆਤਮਕ ਬਲ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Такая духовная твёрдость возникает в сердце того человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10263,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕਉ ਦਇਆ ਮਇਆ ਪ੍ਰਭ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā kau daiyā maiā prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਦਇਆ ਹੁੰਦੀ ਹੈ, ਕਿਰਪਾ ਹੁੰਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "на которого есть сострадание и милость Самого Вахегуру. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10264,
          "is_rahao": false,
          "gurmukhi": "ਸਾਜਨੁ ਦੁਸਟੁ ਜਾ ਕੈ ਏਕ ਸਮਾਨੈ ॥",
          "roman": "sājan dusṭ jā kē ēk samānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਮਿੱਤਰ ਤੇ ਵੈਰੀ ਇਕੋ ਜਿਹਾ ਜਾਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому человеку, которому в сердце друг и враг кажутся одинаковыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10265,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤਾ ਬੋਲਣੁ ਤੇਤਾ ਗਿਆਨੈ ॥",
          "roman": "jētā bolaṇ tētā giānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਕੁਝ ਉਹ ਬੋਲਦਾ ਹੈ, ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਬਾਰੇ ਬੋਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "сколько бы он ни говорил, он говорит только о понимании духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10266,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤਾ ਸੁਨਣਾ ਤੇਤਾ ਨਾਮੁ ॥",
          "roman": "jētā suṇṇā tētā nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਕੁਝ ਸੁਣਦਾ ਹੈ, ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਹੀ ਸੁਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сколько бы он ни слушал, он слушает только хвалу Вахегуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10267,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤਾ ਪੇਖਨੁ ਤੇਤਾ ਧਿਆਨੁ ॥੨॥",
          "roman": "jētā pēkhan tētā dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਕੁਝ ਵੇਖਦਾ ਹੈ, ਪਰਮਾਤਮਾ ਵਿਚ ਸੁਰਤ ਜੋੜਨ ਦਾ ਕਾਰਣ ਹੀ ਬਣਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и всё, что он видит, становится причиной для сосредоточения на Вахегуру. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10268,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਜਾਗਣੁ ਸਹਜੇ ਸੋਇ ॥",
          "roman": "sahjē jāgaṇ sahjē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਚਾਹੇ ਜਾਗਦਾ ਹੈ, ਚਾਹੇ ਸੁੱਤਾ ਹੋਇਆ ਹੈ, ਉਹ ਸਦਾ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਹੀ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Бодрствует ли он или спит, он всегда пребывает в духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10269,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਹੋਤਾ ਜਾਇ ਸੁ ਹੋਇ ॥",
          "roman": "sahjē hotā jāi su hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਵਿਚ ਜੋ ਕੁਝ ਹੁੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਠੀਕ ਮੰਨਦਾ ਹੈ, ਤੇ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਹੀ ਲੀਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё, что происходит по воле Вахегуру, он принимает как правильное, оставаясь погружённым в эту устойчивость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10270,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਬੈਰਾਗੁ ਸਹਜੇ ਹੀ ਹਸਨਾ ॥",
          "roman": "sahaj bērāg sahjē hī hasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਗ਼ਮੀ ਦੀ ਘਟਨਾ ਹੋ ਜਾਏ, ਚਾਹੇ ਖ਼ੁਸ਼ੀ ਦਾ ਕਾਰਣ ਬਣੇ, ਉਹ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਹੀ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Случится ли печаль или появится причина для радости, он остаётся в духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10271,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਚੂਪ ਸਹਜੇ ਹੀ ਜਪਨਾ ॥੩॥",
          "roman": "sahjē chūp sahjē hī japnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਚੁਪ ਬੈਠਾ ਹੈ ਤਾਂ ਭੀ ਅਡੋਲਤਾ ਵਿਚ ਹੈ ਤੇ ਜੇ ਬੋਲ ਰਿਹਾ ਹੈ ਤਾਂ ਭੀ ਅਡੋਲਤਾ ਵਿਚ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "молчит ли он, он в устойчивости, и говорит ли он, он тоже в устойчивости. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10272,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਭੋਜਨੁ ਸਹਜੇ ਭਾਉ ॥",
          "roman": "sahjē bhojan sahjē bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕਿਆ ਹੋਇਆ ਹੀ ਉਹ ਖਾਣ-ਪੀਣ ਦਾ ਵਿਹਾਰ ਕਰਦਾ ਹੈ, ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਹੀ ਉਹ ਦੂਜਿਆਂ ਨਾਲ ਪ੍ਰੇਮ ਦਾ ਸਲੂਕ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Даже в еде и питье он пребывает в духовной устойчивости, и в этой же устойчивости проявляет любовь к другим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10273,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਮਿਟਿਓ ਸਗਲ ਦੁਰਾਉ ॥",
          "roman": "sahjē miṭio sagal durāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿਣ ਕਰਕੇ ਉਸ ਦੇ ਅੰਦਰੋਂ ਸਾਰਾ ਕਪਟ-ਭਾਵ ਮਿਟ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "и благодаря пребыванию в этой устойчивости из него исчезает всякое коварство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10274,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਹੋਆ ਸਾਧੂ ਸੰਗੁ ॥",
          "roman": "sahjē hoā sādhū sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਹੀ ਉਸ ਨੂੰ ਗੁਰੂ ਦਾ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В этой духовной устойчивости ему происходит встреча с Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10275,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਮਿਲਿਓ ਪਾਰਬ੍ਰਹਮੁ ਨਿਸੰਗੁ ॥੪॥",
          "roman": "sahaj miliō pārbrahm nisang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਤੱਖ ਤੌਰ ਤੇ ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и явно ему встречается Парабрахм. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10276,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਗ੍ਰਿਹ ਮਹਿ ਸਹਜਿ ਉਦਾਸੀ ॥",
          "roman": "sahjē grih mah sahaj udāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਘਰ ਵਿਚ ਹੈ ਤਾਂ ਭੀ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ, ਜੇ ਉਹ ਦੁਨੀਆ ਤੋਂ ਉਪਰਾਮ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если он дома, то и там он в духовной устойчивости, и если странствует отрешённо от мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
