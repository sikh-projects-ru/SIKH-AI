{
  "ang": 237,
  "shabads": [
    {
      "shabad_id": 733,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10277,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਦੁਬਿਧਾ ਤਨ ਕੀ ਨਾਸੀ ॥",
          "roman": "sahjē dubidhā tan kī nāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿਣ ਕਰਕੇ ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚੋਂ ਮੇਰ-ਤੇਰ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то тоже благодаря пребыванию в духовной устойчивости из его сердца исчезает двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10278,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਹਜਿ ਮਨਿ ਭਇਆ ਅਨੰਦੁ ॥",
          "roman": "jā kē sahaj man bhiā ānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਕਾਰਨ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਆਨੰਦ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В чьём уме благодаря духовной устойчивости рождается радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10279,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਭੇਟਿਆ ਪਰਮਾਨੰਦੁ ॥੫॥",
          "roman": "tā kau bhēṭiā parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਪਰਮਾਤਮਾ ਮਿਲ ਪੈਂਦਾ ਹੈ ਜੋ ਸਭ ਤੋਂ ਉੱਚੇ ਆਤਮਕ ਆਨੰਦ ਦਾ ਮਾਲਕ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "тому встречается Вахегуру, владыка высшего духовного блаженства. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10280,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਅੰਮ੍ਰਿਤੁ ਪੀਓ ਨਾਮੁ ॥",
          "roman": "sahjē amrit pīo nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਪੀਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек, пребывая в духовной устойчивости, пьёт нектар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10281,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਕੀਨੋ ਜੀਅ ਕੋ ਦਾਨੁ ॥",
          "roman": "sahjē kīno jīa ko dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਆਤਮਕ ਅਡੋਲਤਾ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ (ਹੋਰਨਾਂ ਨੂੰ ਭੀ) ਆਤਮਕ ਜੀਵਨ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "и благодаря этой духовной устойчивости даёт другим дар духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10282,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਕਥਾ ਮਹਿ ਆਤਮੁ ਰਸਿਆ ॥",
          "roman": "sahaj kathā mah ātm rasiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਕਰਨ ਵਾਲੀਆਂ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀਆਂ ਗੱਲਾਂ ਵਿਚ ਉਸ ਦੀ ਜਿੰਦ ਰਚੀ-ਮਿਚੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его душа пропитана речами хвалы Вахегуру, которые рождают духовную устойчивость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10283,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਸੰਗਿ ਅਬਿਨਾਸੀ ਵਸਿਆ ॥੬॥",
          "roman": "tā kē sang abināsī vasiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਅਬਿਨਾਸੀ ਪਰਮਾਤਮਾ ਆ ਵੱਸਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и в его сердце поселяется Нетленный Вахегуру. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10284,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਆਸਣੁ ਅਸਥਿਰੁ ਭਾਇਆ ॥",
          "roman": "sahjē āsaṇ asthir bhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਉਸ ਦਾ ਸਦਾ-ਟਿਕਵਾਂ ਟਿਕਾਣਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ਤੇ ਉਸ ਨੂੰ ਉਹ ਟਿਕਾਣਾ ਚੰਗਾ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В духовной устойчивости его место пребывания становится постоянным и непоколебимым, и это место ему любо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10285,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਅਨਹਤ ਸਬਦੁ ਵਜਾਇਆ ॥",
          "roman": "sahjē anhat sabad vajāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਹੀ ਉਹ ਆਪਣੇ ਅੰਦਰ ਇਕ-ਰਸ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਪ੍ਰਬਲ ਕਰੀ ਰੱਖਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "и, пребывая в духовной устойчивости, он поддерживает внутри себя звучание непрерывной хвалы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10286,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਰੁਣ ਝੁਣਕਾਰੁ ਸੁਹਾਇਆ ॥",
          "roman": "sahjē ruṇ jhuṇkār suhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਕਾਰਨ ਹੀ ਉਸ ਦੇ ਅੰਦਰ ਆਤਮਕ ਆਨੰਦ ਦੀ ਇਕ-ਰਸ ਰੌ ਸੁਹਾਵਣੀ ਬਣੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря духовной устойчивости внутри него сохраняется прекрасный непрерывный поток духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10287,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੈ ਘਰਿ ਪਾਰਬ੍ਰਹਮੁ ਸਮਾਇਆ ॥੭॥",
          "roman": "tā kē ghar pārbrahm samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਸਦਾ ਪਰਗਟ ਰਹਿੰਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! В его сердце постоянно явлен Парабрахм. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10288,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਜਾ ਕਉ ਪਰਿਓ ਕਰਮਾ ॥",
          "roman": "sahjē jā kau pariō karmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਦੀ ਕਿਰਪਾ ਹੁੰਦੀ ਹੈ ਉਹ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот человек, на которого нисходит милость Вахегуру, утверждается в духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10289,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਗੁਰੁ ਭੇਟਿਓ ਸਚੁ ਧਰਮਾ ॥",
          "roman": "sahjē gur bhēṭiō sach dharmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਗੁਰੂ ਮਿਲਦਾ ਹੈ, ਸਦਾ-ਥਿਰ ਨਾਮ ਦੇ ਸਿਮਰਨ ਨੂੰ ਉਹ ਆਪਣਾ ਧਰਮ ਬਣਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ему встречается Гуру, и он делает своим дхармом памятование Вечного Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10290,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਹਜੁ ਭਇਆ ਸੋ ਜਾਣੈ ॥",
          "roman": "jā kē sahaj bhiā so jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਸਹਜ ਅਵਸਥਾ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਇਹ ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਹੁੰਦੀ ਹੈ, ਉਹੀ ਮਨੁੱਖ ਉਸ ਨੂੰ ਸਮਝ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но это состояние sahaj невозможно выразить словами. Лишь тот человек, в котором оно возникло, может его понять,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10291,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤਾ ਕੈ ਕੁਰਬਾਣੈ ॥੮॥੩॥",
          "roman": "Nānak dās tā kē kurbāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਉਸ (ਵਡ-ਭਾਗੀ ਮਨੁੱਖ) ਤੋਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹੈ ॥੮॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и слуга Нанак отдаёт себя этому велико-счастливому человеку. ॥8॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 734,
      "rahao_verse_id": 10297,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10292,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10293,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਥਮੇ ਗਰਭ ਵਾਸ ਤੇ ਟਰਿਆ ॥",
          "roman": "Prathmey garabh vās te ṭariā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੀਵ ਪਹਿਲਾਂ ਮਾਂ ਦੇ ਪੇਟ ਵਿਚ ਵੱਸਣ ਤੋਂ ਖ਼ਲਾਸੀ ਹਾਸਲ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Сначала живое существо освобождается от пребывания в материнской утробе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10294,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਕਲਤ੍ਰ ਕੁਟੰਬ ਸੰਗਿ ਜੁਰਿਆ ॥",
          "roman": "Putra kalatra kuṭaṃb saṅg juriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ ਜਨਮ ਲੈ ਕੇ ਫਿਰ ਸਹਜੇ ਸਹਜੇ ਜਵਾਨੀ ਤੇ ਪਹੁੰਚ ਕੇ) ਪੁੱਤ੍ਰ ਇਸਤ੍ਰੀ ਆਦਿਕ ਪਰਵਾਰ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "а затем, родившись в мире и постепенно достигнув юности, остаётся опутанным привязанностью к детям, жене и семье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10295,
          "is_rahao": false,
          "gurmukhi": "ਭੋਜਨੁ ਅਨਿਕ ਪ੍ਰਕਾਰ ਬਹੁ ਕਪਰੇ ॥ ਸਰਪਰ ਗਵਨੁ ਕਰਹਿਗੇ ਬਪੁਰੇ ॥੧॥",
          "roman": "Bhojan anik prakār bah kaprey ॥ sarpar gavan karahigey bāpurey ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਕਿਸਮ ਦਾ ਖਾਣਾ ਖਾਂਦਾ ਹੈ, ਕਈ ਕਿਸਮਾਂ ਦੇ ਕੱਪੜੇ ਪਹਿਨਦਾ ਹੈ (ਸਾਰੀ ਉਮਰ ਇਹਨਾਂ ਰੰਗਾਂ ਵਿਚ ਹੀ ਮਸਤ ਰਹਿ ਕੇ ਕੁਰਾਹੇ ਪਿਆ ਰਹਿੰਦਾ ਹੈ, ਪਰ ਅਜੇਹੇ ਬੰਦੇ ਭੀ) ਜ਼ਰੂਰ ਯਤੀਮਾਂ ਵਾਂਗ ਹੀ (ਜਗਤ ਤੋਂ) ਕੂਚ ਕਰ ਜਾਣਗੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ест многообразную пищу, носит разные одежды. Всю жизнь, опьянённый этими красками, он так и остаётся на ложном пути, но и такие люди непременно уйдут из мира, словно сироты ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10296,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨੁ ਅਸਥਾਨੁ ਜੋ ਕਬਹੁ ਨ ਟਰੈ ॥",
          "roman": "Kavan asthān jo kabah na ṭarē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਹ ਕੇਹੜਾ ਥਾਂ ਹੈ ਜੇਹੜਾ ਸਦਾ ਅਟੱਲ ਰਹਿੰਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каково то место, которое всегда остаётся неколебимым?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10297,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨੁ ਸਬਦੁ ਜਿਤੁ ਦੁਰਮਤਿ ਹਰੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Kavan sabad jit durmat harē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕੇਹੜਾ ਸ਼ਬਦ ਹੈ ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਮਨੁੱਖ ਦੀ) ਖੋਟੀ ਮਤਿ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Каково то Слово, по благодати которого дурной ум человека исчезает? ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10298,
          "is_rahao": false,
          "gurmukhi": "ਇੰਦ੍ਰ ਪੁਰੀ ਮਹਿ ਸਰਪਰ ਮਰਣਾ ॥",
          "roman": "Indra purī meh sarpar marṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਹੋਰਨਾਂ ਦੀ ਤਾਂ ਗੱਲ ਹੀ ਕੀਹ ਹੈ?) ਇੰਦ੍ਰ-ਪੁਰੀ ਵਿਚ ਭੀ ਮੌਤ ਜ਼ਰੂਰ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Что уж говорить о прочих: даже в обители Индры смерть непременно приходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10299,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਪੁਰੀ ਨਿਹਚਲੁ ਨਹੀ ਰਹਣਾ ॥",
          "roman": "Braham purī nihachal nahī rahṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਾ ਦੀ ਪੁਰੀ ਭੀ ਸਦਾ ਅਟੱਲ ਨਹੀਂ ਰਹਿ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Даже обитель Брахмы не может оставаться вечной и неколебимой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10300,
          "is_rahao": false,
          "gurmukhi": "ਸਿਵ ਪੁਰੀ ਕਾ ਹੋਇਗਾ ਕਾਲਾ ॥",
          "roman": "Siv purī kā hoigā kālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ਿਵ ਦੀ ਪੁਰੀ ਦਾ ਭੀ ਨਾਸ ਹੋ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Даже обитель Шивы будет разрушена."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10301,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਗੁਣ ਮਾਇਆ ਬਿਨਸਿ ਬਿਤਾਲਾ ॥੨॥",
          "roman": "Trē guṇ māiā binas bitālā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜਗਤ) ਤਿੰਨਾਂ ਗੁਣਾਂ ਵਾਲੀ ਮਾਇਆ ਦੇ ਅਸਰ ਹੇਠ ਜੀਵਨ ਦੇ ਸਹੀ ਰਾਹ ਤੋਂ ਖੁੰਝ ਕੇ ਆਤਮਕ ਮੌਤ ਸਹੇੜਦਾ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но мир под воздействием майи трёх гун, сбившись с истинного жизненного пути, продолжает терпеть духовную смерть ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10302,
          "is_rahao": false,
          "gurmukhi": "ਗਿਰਿ ਤਰ ਧਰਣਿ ਗਗਨ ਅਰੁ ਤਾਰੇ ॥",
          "roman": "Gir tar dharaṇ gagan ar tārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਹਾੜ, ਰੁੱਖ, ਧਰਤੀ, ਆਕਾਸ਼ ਅਤੇ ਤਾਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "О брат! Горы, деревья, земля, небо и звёзды;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10303,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿ ਸਸਿ ਪਵਣੁ ਪਾਵਕੁ ਨੀਰਾਰੇ ॥",
          "roman": "Rav sas pavaṇ pāvak nīrārey ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੂਰਜ, ਚੰਦ, ਹਵਾ, ਅੱਗ, ਪਾਣੀ, ਦਿਨ ਤੇ ਰਾਤ;"
            },
            "sahib_singh_ru": {
              "main": "солнце, луна, воздух, огонь, вода, день и ночь;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10304,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨਸੁ ਰੈਣਿ ਬਰਤ ਅਰੁ ਭੇਦਾ ॥",
          "roman": "Dinas rēṇ barat ar bhedā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਰਤ ਆਦਿਕ ਵਖ ਵਖ ਕਿਸਮ ਦੀਆਂ ਮਰਯਾਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "посты и прочие разные обрядовые установления;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10305,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਤ ਸਿੰਮ੍ਰਿਤਿ ਬਿਨਸਹਿਗੇ ਬੇਦਾ ॥੩॥",
          "roman": "Sāsat sṃmrit binsahigey bēdā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਦ, ਸਿਮ੍ਰਿਤੀਆਂ, ਸ਼ਾਸਤ੍ਰ-ਇਹ ਸਭ ਕੁਝ ਆਖ਼ਰ ਨਾਸ ਹੋ ਜਾਣਗੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Веды, смрити, шастры — всё это в конце концов исчезнет ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10306,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥ ਦੇਵ ਦੇਹੁਰਾ ਪੋਥੀ ॥",
          "roman": "Tīrath dev dehurā pothī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੀਰਥ, ਦੇਵਤੇ, ਮੰਦਰ, (ਧਰਮ-) ਪੁਸਤਕਾਂ;"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тиртхи, божества, храмы, религиозные книги;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10307,
          "is_rahao": false,
          "gurmukhi": "ਮਾਲਾ ਤਿਲਕੁ ਸੋਚ ਪਾਕ ਹੋਤੀ ॥",
          "roman": "Mālā tilak soch pāk hotī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਲਾ, ਤਿਲਕ, ਸੁੱਚੀ ਰਸੋਈ, ਹਵਨ ਕਰਨ ਵਾਲੇ;"
            },
            "sahib_singh_ru": {
              "main": "чётки, тилак, чистая кухня, совершающие хаван;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10308,
          "is_rahao": false,
          "gurmukhi": "ਧੋਤੀ ਡੰਡਉਤਿ ਪਰਸਾਦਨ ਭੋਗਾ ॥",
          "roman": "Dhotī ḍaṇḍaut parasādan bhogā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨੇਤੀ-) ਧੋਤੀ ਤੇ ਡੰਡਉਤ-ਨਮਸਕਾਰਾਂ;"
            },
            "sahib_singh_ru": {
              "main": "очищающие омовения и земные поклоны;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10309,
          "is_rahao": false,
          "gurmukhi": "ਗਵਨੁ ਕਰੈਗੋ ਸਗਲੋ ਲੋਗਾ ॥੪॥",
          "roman": "Gavan karēgo saglo logā ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੂਜੇ ਪਾਸੇ) ਮਹਲਾਂ ਦੇ ਭੋਗ-ਬਿਲਾਸ-ਸਾਰਾ ਜਗਤ ਹੀ (ਆਖ਼ਰ) ਕੂਚ ਕਰ ਜਾਇਗਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "а с другой стороны, дворцовые наслаждения и роскошь — весь мир в конце концов уйдёт ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10310,
          "is_rahao": false,
          "gurmukhi": "ਜਾਤਿ ਵਰਨ ਤੁਰਕ ਅਰੁ ਹਿੰਦੂ ॥",
          "roman": "Jāt varaṇ turak ar hindū ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵਖ ਵਖ) ਜਾਤਾਂ, (ਬ੍ਰਾਹਮਣ, ਖੱਤ੍ਰੀ ਆਦਿਕ) ਵਰਨ, ਮੁਸਲਮਾਨ ਅਤੇ ਹਿੰਦੂ;"
            },
            "sahib_singh_ru": {
              "main": "Разные касты, варны — брахманы, кшатрии и другие, мусульмане и индуисты;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10311,
          "is_rahao": false,
          "gurmukhi": "ਪਸੁ ਪੰਖੀ ਅਨਿਕ ਜੋਨਿ ਜਿੰਦੂ ॥",
          "roman": "Pas paṅkhī anik jon jindū ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਸ਼ੂ, ਪੰਛੀ, ਅਨੇਕਾਂ ਜੂਨਾਂ ਦੇ ਜੀਵ;"
            },
            "sahib_singh_ru": {
              "main": "животные, птицы, существа множества рождений;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10312,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਪਾਸਾਰੁ ਦੀਸੈ ਪਾਸਾਰਾ ॥",
          "roman": "Sagal pāsār dīsē pāsārā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰਾ ਜਗਤ-ਖਿਲਾਰਾ ਜੋ ਦਿੱਸ ਰਿਹਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "весь этот видимый разлив мира —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10313,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸਿ ਜਾਇਗੋ ਸਗਲ ਆਕਾਰਾ ॥੫॥",
          "roman": "Binas jāigo sagal ākārā ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰਾ ਦ੍ਰਿਸ਼ਟ-ਮਾਨ ਸੰਸਾਰ (ਆਖ਼ਰ) ਨਾਸ ਹੋ ਜਾਇਗਾ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "весь этот зримый мир в конце концов погибнет ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10314,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸਿਫਤਿ ਭਗਤਿ ਤਤੁ ਗਿਆਨਾ ॥",
          "roman": "Sehaj sifat bhagat tat giānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਭਾਈ!) ਉਹ (ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ-) ਥਾਂ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਹੈ ਅਟੱਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но, о брат, то место высокой духовной устойчивости пребывает вечно и неколебимо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10315,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਅਨੰਦੁ ਨਿਹਚਲੁ ਸਚੁ ਥਾਨਾ ॥",
          "roman": "Sadā anand nihachal sach thānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਥੇ ਸਦਾ ਹੀ ਆਨੰਦ ਭੀ ਹੈ, ਜਿਥੇ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇਣ ਵਾਲੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਹੋ ਰਹੀ ਹੈ ਜਿਥੇ ਭਗਤੀ ਹੋ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и там всегда есть блаженство, где совершается хвала, дарующая духовную устойчивость, где совершается преданность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10316,
          "is_rahao": false,
          "gurmukhi": "ਤਹਾ ਸੰਗਤਿ ਸਾਧ ਗੁਣ ਰਸੈ ॥",
          "roman": "Tahā saṅgat sādh guṇ rasē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਜਗਤ ਦੇ ਮੂਲ-ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪੈ ਰਹੀ ਹੈ, ਉਥੇ ਸਾਧ ਸੰਗਤਿ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦਾ ਆਨੰਦ ਮਾਣਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где возникает глубокая связь с Изначальным Господом мира, там святая сангат вкушает радость Божьих качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10317,
          "is_rahao": false,
          "gurmukhi": "ਅਨਭਉ ਨਗਰੁ ਤਹਾ ਸਦ ਵਸੈ ॥੬॥",
          "roman": "Anabhau nagar tahā sad vasē ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਸਦਾ ਇਕ ਐਸਾ ਨਗਰ ਵੱਸਿਆ ਰਹਿੰਦਾ ਹੈ ਜਿਥੇ ਕਿਸੇ ਕਿਸਮ ਦਾ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Там вечно пребывает такой град, куда не может проникнуть никакой страх ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10318,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਭਉ ਭਰਮਾ ਸੋਗੁ ਨ ਚਿੰਤਾ ॥",
          "roman": "Tah bhau bharamā sog na chintā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਉਸ (ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ-) ਥਾਂ ਵਿਚ ਕੋਈ ਡਰ, ਕੋਈ ਭਰਮ, ਕੋਈ ਗ਼ਮ, ਕੋਈ ਚਿੰਤਾ ਪੋਹ ਨਹੀਂ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В том месте высокой духовной устойчивости не могут коснуться ни страх, ни заблуждение, ни скорбь, ни забота,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10319,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣੁ ਜਾਵਣੁ ਮਿਰਤੁ ਨ ਹੋਤਾ ॥",
          "roman": "Āvaṇ jāvaṇ mrit na hotā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਰਹਿੰਦਾ, ਉਥੇ ਆਤਮਕ ਮੌਤ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "там нет круга рождения и смерти, там не бывает духовной смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10320,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਸਦਾ ਅਨੰਦ ਅਨਹਤ ਆਖਾਰੇ ॥",
          "roman": "Tah sadā anand anhat ākhārey ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਸਦਾ ਇਕ-ਰਸ ਆਤਮਕ ਆਨੰਦ ਦੇ (ਮਾਨੋ) ਅਖਾੜੇ ਲੱਗੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Там всегда словно устроены арены ровного духовного блаженства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10321,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਵਸਹਿ ਕੀਰਤਨ ਆਧਾਰੇ ॥੭॥",
          "roman": "Bhagat vaseh kīrtan ādhārey ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਭਗਤ-ਜਨ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਆਸਰੇ ਵੱਸਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "там преданные живут, опираясь на восхваление Бога ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10322,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕਾ ਅੰਤੁ ਨ ਪਾਰੁ ॥",
          "roman": "Pārbrahm kā ant na pār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਇਹ ਰਚਨਾ ਰਚੀ ਹੋਈ ਹੈ) ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ, ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! У Парабрахма, создавшего это творение, нет предела Его качествам, нельзя найти их дальний берег."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10323,
          "is_rahao": false,
          "gurmukhi": "ਕਉਣੁ ਕਰੈ ਤਾ ਕਾ ਬੀਚਾਰੁ ॥",
          "roman": "Ka-uṇ karē tā kā bīchār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ) ਕੋਈ ਐਸਾ ਮਨੁੱਖ ਨਹੀਂ ਹੈ, ਜੋ ਉਸ ਦੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਪਾਣ ਦਾ ਵਿਚਾਰ ਕਰ ਸਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "Нет в мире такого человека, который мог бы помыслить постичь предел Его качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10324,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਿਸੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "Kah Nānak jis kirpā karē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਕਿਰਪਾ ਕਰਦਾ ਹੈ ਉਸ ਨੂੰ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਥਾਂ ਸਾਧ ਸੰਗਤਿ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: тому человеку, на кого Бог проливает милость, даруется садх сангат — место, пребывающее вечно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10325,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲ ਥਾਨੁ ਸਾਧਸੰਗਿ ਤਰੈ ॥੮॥੪॥",
          "roman": "Nihachal thān sādhasaṅg tarē ॥8॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਉਹ ਮਨੁੱਖ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੮॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и, пребывая в садх сангат, этот человек переправляется через мирской океан ॥8॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 735,
      "rahao_verse_id": 10332,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 10326,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10327,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਸੁ ਮਾਰੇ ਸੋਈ ਸੂਰਾ ॥",
          "roman": "Jo is mārey soī sūrā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਇਸ (ਮੇਰ-ਤੇਰ ਨੂੰ) ਮੁਕਾ ਲੈਂਦਾ ਹੈ, ਉਹੀ (ਵਿਕਾਰਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਬਲੀ ਸੂਰਮਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто уничтожает это чувство «моё и твоё», тот и есть могучий герой в противостоянии порокам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10328,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਸੁ ਮਾਰੇ ਸੋਈ ਪੂਰਾ ॥",
          "roman": "Jo is mārey soī pūrā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਇਸ (ਮੇਰ-ਤੇਰ ਨੂੰ) ਮੁਕਾ ਲੈਂਦਾ ਹੈ, ਉਹੀ ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਮਾਲਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, кто уничтожает это чувство «моё и твоё», тот и есть совершенный, владеющий всеми добродетелями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10329,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਸੁ ਮਾਰੇ ਤਿਸਹਿ ਵਡਿਆਈ ॥",
          "roman": "Jo is mārey tiseh vaḍiāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਇਸ ਦੁਬਿਧਾ ਨੂੰ ਮਾਰ ਲੈਂਦਾ ਹੈ, ਉਸ ਨੂੰ (ਹਰ ਥਾਂ) ਆਦਰ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто убивает эту двойственность, получает почёт повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10330,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਸੁ ਮਾਰੇ ਤਿਸ ਕਾ ਦੁਖੁ ਜਾਈ ॥੧॥",
          "roman": "Jo is mārey tis kā dukh jāī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਇਸ (ਮੇਰ-ਤੇਰ ਨੂੰ) ਮੁਕਾ ਲੈਂਦਾ ਹੈ, ਉਸ ਮਨੁੱਖ ਦਾ (ਹਰੇਕ ਕਿਸਮ ਦਾ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот, кто уничтожает это «моё и твоё», освобождается от всякого страдания ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10331,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਕੋਇ ਜਿ ਦੁਬਿਧਾ ਮਾਰਿ ਗਵਾਵੈ ॥",
          "roman": "Ēsā ko-e j dubidhā mār gavāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਗਤ ਵਿਚ) ਅਜੇਹਾ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਹੈ, ਜੇਹੜਾ ਆਪਣੇ ਅੰਦਰੋਂ ਮੇਰ-ਤੇਰ ਨੂੰ ਮਾਰ ਮੁਕਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В мире лишь редкий человек таков, что убивает и искореняет в себе это «моё и твоё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 10332,
          "is_rahao": true,
          "gurmukhi": "ਇਸਹਿ ਮਾਰਿ ਰਾਜ ਜੋਗੁ ਕਮਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Iseh mār rāj jog kamāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਇਸ ਮੇਰ-ਤੇਰ ਨੂੰ ਮਾਰ ਲੈਂਦਾ ਹੈ, ਉਹ ਗ੍ਰਿਹਸਤ ਵਿਚ ਰਹਿੰਦਾ ਹੋਇਆ ਹੀ ਪਰਮਾਤਮਾ ਨਾਲ ਜੋੜ ਪੈਦਾ ਕਰਨ ਦਾ ਅੱਭਿਆਸੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто убивает это «моё и твоё», даже живя в доме, упражняется в соединении с Богом ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
