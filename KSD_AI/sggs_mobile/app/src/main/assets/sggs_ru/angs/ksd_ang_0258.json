{
  "ang": 258,
  "shabads": [
    {
      "shabad_id": 831,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11255,
          "is_rahao": false,
          "gurmukhi": "ਨਿਧਿ ਨਿਧਾਨ ਹਰਿ ਅੰਮ੍ਰਿਤ ਪੂਰੇ ॥",
          "roman": "nidh nidhān har amrit pūre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਹਿਰਦੇ ਸਭ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਹਰੀ-ਨਾਮ ਅੰਮ੍ਰਿਤ ਨਾਲ ਭਰੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те сердца, которые наполнены нектаром Имени Хари, сокровищем всех достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11256,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬਾਜੇ ਨਾਨਕ ਅਨਹਦ ਤੂਰੇ ॥੩੬॥",
          "roman": "tah bāje nānak anhad tūre ॥36॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਇਕ ਐਸਾ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ਜਿਵੇਂ ਇਕ-ਰਸ ਸਭ ਕਿਸਮਾਂ ਦੇ ਵਾਜੇ ਮਿਲਵੀਂ ਸੁਰ ਵਿਚ ਵੱਜ ਰਹੇ ਹੋਣ ॥੩੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Внутри них непрестанно пребывает такое блаженство, словно в согласном ладе без конца звучат все виды инструментов ॥36॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 832,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11257,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11258,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿ ਰਾਖੀ ਗੁਰਿ ਪਾਰਬ੍ਰਹਮ ਤਜਿ ਪਰਪੰਚ ਮੋਹ ਬਿਕਾਰ ॥",
          "roman": "pat rākhī gur pārbraham taj parpanch moh bikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੀ ਇੱਜ਼ਤ ਗੁਰੂ ਪਾਰਬ੍ਰਹਮ ਨੇ ਰੱਖ ਲਈ, ਉਸ ਨੇ ਠੱਗੀ ਮੋਹ ਵਿਕਾਰ (ਆਦਿਕ) ਤਿਆਗ ਦਿੱਤੇ।"
            },
            "sahib_singh_ru": {
              "main": "Чью честь Гуру-Парбрахм сохранил, тот оставил обман, привязанность и пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11259,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋਊ ਆਰਾਧੀਐ ਅੰਤੁ ਨ ਪਾਰਾਵਾਰੁ ॥੧॥",
          "roman": "Nānak soū ārādhīai ant na pārāvār.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਵਾਸਤੇ) ਉਸ ਪਾਰਬ੍ਰਹਮ ਨੂੰ ਸਦਾ ਅਰਾਧਣਾ ਚਾਹੀਦਾ ਹੈ ਜਿਸ ਦੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ, ਜਿਸ ਦੀ ਹਸਤੀ ਦਾ ਉਰਲਾ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, поэтому следует всегда созерцать того Парбрахма, чьим качествам невозможно найти предела и чьё бытие не имеет ни ближнего, ни дальнего берега. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 833,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11260,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉੜੀ"
            },
            "sahib_singh_ru": {
              "main": "Паури"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11261,
          "is_rahao": false,
          "gurmukhi": "ਪਪਾ ਪਰਮਿਤਿ ਪਾਰੁ ਨ ਪਾਇਆ ॥",
          "roman": "papā paramit pār na pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੀ ਪ੍ਰਭੂ ਦੀ ਹਸਤੀ ਦਾ ਅੰਦਾਜ਼ਾ ਨਹੀਂ ਲੱਗ ਸਕਦਾ, ਅੰਤ ਨਹੀਂ ਪੈ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Невозможно измерить бытие Хари-Прабху, невозможно достигнуть его предела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11262,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨ ਅਗਮ ਹਰਿ ਰਾਇਆ ॥",
          "roman": "patit pāvan agam har rāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਪਹੁੰਚ ਹੈ, ਵਿਕਾਰਾਂ ਵਿਚ ਡਿੱਗੇ ਬੰਦਿਆਂ ਨੂੰ ਪਵਿਤ੍ਰ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он непостижим и очищает тех, кто пал в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11263,
          "is_rahao": false,
          "gurmukhi": "ਹੋਤ ਪੁਨੀਤ ਕੋਟ ਅਪਰਾਧੂ ॥",
          "roman": "hot punīt koṭ aprādhū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਹੀ ਉਹ ਅਪਰਾਧੀ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Даже миллионы грешников становятся чистыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11264,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਜਪਹਿ ਮਿਲਿ ਸਾਧੂ ॥",
          "roman": "amrit nām japeh mil sādhū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਪ੍ਰਭੂ ਦਾ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ ਜਪਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "если, встретив Гуру, они повторяют Имя, дарующее духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11265,
          "is_rahao": false,
          "gurmukhi": "ਪਰਪਚ ਧ੍ਰੋਹ ਮੋਹ ਮਿਟਨਾਈ ॥",
          "roman": "parpach dhroh moh miṭnāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ ਠੱਗੀ ਫ਼ਰੇਬ ਮੋਹ ਆਦਿਕ ਵਿਕਾਰ ਮਿਟ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Твоего восхваления в человеке исчезают обман, коварство, привязанность и другие пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11266,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਰਾਖਹੁ ਆਪਿ ਗੁਸਾਈ ॥",
          "roman": "jā kau rākhah āp gusāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਮਾਲਕ! ਜਿਸ ਦੀ ਤੂੰ ਆਪ ਰੱਖਿਆ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "о Владыка мира, того, кого Ты Сам оберегаешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11267,
          "is_rahao": false,
          "gurmukhi": "ਪਾਤਿਸਾਹੁ ਛਤ੍ਰ ਸਿਰ ਸੋਊ ॥",
          "roman": "pātisāh chhatr sir soū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਸ਼ਾਹਾਂ ਦਾ ਸ਼ਾਹ ਹੈ, ਉਹੀ ਅਸਲ ਛੱਤਰ-ਧਾਰੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь — шах среди шахов, только Он есть истинный носитель царского зонта,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11268,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੂਸਰ ਅਵਰੁ ਨ ਕੋਊ ॥੩੭॥",
          "roman": "Nānak dūsar avar na koū.37.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਕੋਈ ਹੋਰ ਦੂਜਾ ਉਸ ਦੀ ਬਰਾਬਰੀ ਕਰਨ ਜੋਗਾ ਨਹੀਂ ਹੈ ॥੩੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, нет другого, кто был бы способен сравниться с Ним. ॥37॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 834,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11269,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11270,
          "is_rahao": false,
          "gurmukhi": "ਫਾਹੇ ਕਾਟੇ ਮਿਟੇ ਗਵਨ ਫਤਿਹ ਭਈ ਮਨਿ ਜੀਤ ॥",
          "roman": "fāhe kāṭe miṭe gavan fateh bhaī man jīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਆਪਣੇ ਮਨ ਨੂੰ ਜਿੱਤ ਲਈਏ, (ਵੱਸ ਵਿਚ ਕਰ ਲਈਏ) ਤਾਂ (ਵਿਕਾਰਾਂ ਉਤੇ) ਜਿੱਤ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੀ ਹੈ, ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਬੰਧਨ ਕੱਟੇ ਜਾਂਦੇ ਹਨ, ਤੇ (ਮਾਇਆ ਪਿਛੇ) ਭਟਕਣਾ ਮੁੱਕ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если победить свой ум, подчинить его себе, тогда достигается победа над пороками, разрубаются путы привязанности к майе и прекращается блуждание вслед за ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11271,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਤੇ ਥਿਤ ਪਾਈ ਫਿਰਨ ਮਿਟੇ ਨਿਤ ਨੀਤ ॥੧॥",
          "roman": "Nānak gur te thit pāī phiran miṭe nit nīt.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਪਾਸੋਂ ਮਨ ਦੀ ਅਡੋਲਤਾ ਮਿਲ ਜਾਂਦੀ ਹੈ, ਉਸ ਦੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਸਦਾ ਲਈ ਮੁੱਕ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто получает от Гуру устойчивость ума, навсегда выходит из кругов рождения и смерти. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 835,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11272,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉੜੀ"
            },
            "sahib_singh_ru": {
              "main": "Паури"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11273,
          "is_rahao": false,
          "gurmukhi": "ਫਫਾ ਫਿਰਤ ਫਿਰਤ ਤੂ ਆਇਆ ॥",
          "roman": "phaphā phirat phirat tū āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੂੰ ਅਨੇਕਾਂ ਜੂਨਾਂ ਵਿਚ ਭਟਕਦਾ ਆਇਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, ты блуждал через множество жизней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11274,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰੁਲਭ ਦੇਹ ਕਲਿਜੁਗ ਮਹਿ ਪਾਇਆ ॥",
          "roman": "drulabh deh kalijug meh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਤੈਨੂੰ ਸੰਸਾਰ ਵਿਚ ਇਹ ਮਨੁੱਖਾ ਜਨਮ ਮਿਲਿਆ ਹੈ ਜੋ ਬੜੀ ਮੁਸ਼ਕਲ ਨਾਲ ਹੀ ਮਿਲਿਆ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а теперь получил в мире это человеческое рождение, которое достаётся с великим трудом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11275,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਇਆ ਅਉਸਰੁ ਚਰੈ ਨ ਹਾਥਾ ॥",
          "roman": "phir iā ausar charē na hāthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਤੂੰ ਹੁਣ ਭੀ ਵਿਕਾਰਾਂ ਦੇ ਬੰਧਨਾਂ ਵਿਚ ਹੀ ਫਸਿਆ ਰਿਹਾ, ਤਾਂ) ਅਜੇਹਾ (ਸੋਹਣਾ) ਮੌਕਾ ਫਿਰ ਨਹੀਂ ਮਿਲੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Если и теперь ты останешься связанным пороками, такой прекрасный случай больше не придёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11276,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਹੁ ਤਉ ਕਟੀਅਹਿ ਫਾਸਾ ॥",
          "roman": "nām japah tau kaṭīah fāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇ ਤੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪੇਂਗਾ, ਤਾਂ ਮਾਇਆ ਵਾਲੇ ਸਾਰੇ ਬੰਧਨ ਕੱਟੇ ਜਾਣਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, если ты будешь повторять Имя Бога, все путы майи будут разрублены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11277,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਫਿਰਿ ਆਵਨ ਜਾਨੁ ਨ ਹੋਈ ॥",
          "roman": "phir phir āvan jān na hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁੜ ਮੁੜ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਰਹਿ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда больше не останется круга повторных рождений и смертей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11278,
          "is_rahao": false,
          "gurmukhi": "ਏਕਹਿ ਏਕ ਜਪਹੁ ਜਪੁ ਸੋਈ ॥",
          "roman": "ekah ek japah jap soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੇਵਲ ਇਕ ਪਰਮਾਤਮਾ ਦਾ ਜਾਪ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Повторяй только одного Единого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11279,
          "is_rahao": false,
          "gurmukhi": "ਕਰਹੁ ਕ੍ਰਿਪਾ ਪ੍ਰਭ ਕਰਨੈਹਾਰੇ ॥",
          "roman": "karah kirpā prabh karṇēhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਹੇ ਸਿਰਜਣਹਾਰ ਪ੍ਰਭੂ! (ਮਾਇਆ-ਗ੍ਰਸੇ ਜੀਵ ਦੇ ਵੱਸ ਦੀ ਗੱਲ ਨਹੀਂ), ਤੂੰ ਆਪ ਕਿਰਪਾ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Но, о Творец-Прабху, сам человек, поражённый майей, этого сделать не может — Ты Сам прояви милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11280,
          "is_rahao": false,
          "gurmukhi": "ਮੇਲਿ ਲੇਹੁ ਨਾਨਕ ਬੇਚਾਰੇ ॥੩੮॥",
          "roman": "mel leh Nānak bechāre.38.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਅੱਗੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) ਇਸ ਵਿਚਾਰੇ ਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਲੈ ॥੩੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись и говори: соедини этого бедного с Твоими стопами. ॥38॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 836,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11281,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11282,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਉ ਸੁਨਹੁ ਤੁਮ ਪਾਰਬ੍ਰਹਮ ਦੀਨ ਦਇਆਲ ਗੁਪਾਲ ॥",
          "roman": "binau sunah tum pārbraham dīn daiāl gupāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ! ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ! ਹੇ ਧਰਤੀ ਦੇ ਪਾਲਣਹਾਰ! ਮੇਰੀ ਬੇਨਤੀ ਸੁਣ।"
            },
            "sahib_singh_ru": {
              "main": "О Парбрахм, о Милостивый к бедным, о Хранитель земли, услышь мою молитву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11283,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਸੰਪੈ ਬਹੁ ਭੋਗ ਰਸ ਨਾਨਕ ਸਾਧ ਰਵਾਲ ॥੧॥",
          "roman": "sukh sampē bah bhog ras Nānak sādh ravāl.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) (ਮੈਨੂੰ ਸੁਮਤਿ ਦੇਹ ਕਿ) ਗੁਰਮੁਖਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਹੀ ਮੈਨੂੰ ਅਨੇਕਾਂ ਸੁਖਾਂ ਧਨ-ਪਦਾਰਥ ਤੇ ਅਨੇਕਾਂ ਰਸਾਂ ਦੇ ਭੋਗ ਦੇ ਬਰਾਬਰ ਜਾਪੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись и говори: даруй мне добрый разум, чтобы прах у стоп гурмукхов казался мне равным множеству радостей, богатств и всевозможных наслаждений. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 837,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11284,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉੜੀ"
            },
            "sahib_singh_ru": {
              "main": "Паури"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11285,
          "is_rahao": false,
          "gurmukhi": "ਬਬਾ ਬ੍ਰਹਮੁ ਜਾਨਤ ਤੇ ਬ੍ਰਹਮਾ ॥",
          "roman": "babā braham jānat te brahmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਬ੍ਰਾਹਮਣ ਉਹ ਹਨ ਜੋ ਬ੍ਰਹਮ (ਪਰਮਾਤਮਾ) ਨਾਲ ਸਾਂਝ ਪਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Истинные брахманы — это те, кто соединяется с Брахмом, с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11286,
          "is_rahao": false,
          "gurmukhi": "ਬੈਸਨੋ ਤੇ ਗੁਰਮੁਖਿ ਸੁਚ ਧਰਮਾ ॥",
          "roman": "bēsno te gurmukh such dharmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਵੈਸ਼ਨੋ ਉਹ ਹਨ ਜੋ ਗੁਰੂ ਦੀ ਸ਼ਰਨ ਪੈ ਕੇ ਆਤਮਕ ਪਵਿਤ੍ਰਤਾ ਦੇ ਫ਼ਰਜ਼ ਨੂੰ ਪਾਲਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "а истинные вайшнавы — те, кто, припав к защите Гуру, исполняют долг внутренней чистоты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11287,
          "is_rahao": false,
          "gurmukhi": "ਬੀਰਾ ਆਪਨ ਬੁਰਾ ਮਿਟਾਵੈ ॥",
          "roman": "bīrā āpan burā miṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੂਰਮਾ ਜਾਣੋ ਜੇਹੜਾ (ਮਿਥੇ ਹੋਏ ਵੈਰੀਆਂ ਦਾ ਖੁਰਾ-ਖੋਜ ਮਿਟਾਣ ਦੇ ਥਾਂ) ਆਪਣੇ ਅੰਦਰੋਂ ਦੂਜਿਆਂ ਦਾ ਬੁਰਾ ਮੰਗਣ ਦੇ ਸੁਭਾਵ ਦਾ ਨਿਸ਼ਾਨ ਮਿਟਾ ਦੇਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "Считай героем того человека, который вместо того, чтобы уничтожать мнимых врагов, стирает в себе привычку желать другим зла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11288,
          "is_rahao": false,
          "gurmukhi": "ਤਾਹੂ ਬੁਰਾ ਨਿਕਟਿ ਨਹੀ ਆਵੈ ॥",
          "roman": "tāhū burā nikaṭ nahī āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੇ ਇਹ ਕਰ ਲਿਆ) ਦੂਜਿਆਂ ਵਲੋਂ ਚਿਤਵੀ ਬੁਰਾਈ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "К тому, кто это сделал, не приближается зло, задуманное другими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11289,
          "is_rahao": false,
          "gurmukhi": "ਬਾਧਿਓ ਆਪਨ ਹਉ ਹਉ ਬੰਧਾ ॥",
          "roman": "bādhio āpan hau hau bandhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਮਨੁੱਖ) ਆਪ ਹੀ ਆਪਣੀ ਹਉਮੈ ਦੇ ਬੰਧਨਾਂ ਵਿਚ ਬੱਝਾ ਰਹਿੰਦਾ ਹੈ (ਤੇ ਦੂਜਿਆਂ ਨਾਲ ਖਹਿੰਦਾ ਹੈ, ਆਪਣੀ ਕੀਤੀ ਵਧੀਕੀ ਦਾ ਖ਼ਿਆਲ ਤਕ ਨਹੀਂ ਆਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Но человек сам связан узами своей хоумэ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11290,
          "is_rahao": false,
          "gurmukhi": "ਦੋਸੁ ਦੇਤ ਆਗਹ ਕਉ ਅੰਧਾ ॥",
          "roman": "dos det āgah kau andhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਵਿਗਾੜ ਦਾ) ਦੋਸ ਇਹ ਅੰਨ੍ਹਾ ਮਨੁੱਖ ਹੋਰਨਾਂ ਤੇ ਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и этот слепой человек возлагает вину за беду на других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11291,
          "is_rahao": false,
          "gurmukhi": "ਬਾਤ ਚੀਤ ਸਭ ਰਹੀ ਸਿਆਨਪ ॥",
          "roman": "bāt chīt sabh rahī siānap",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਅਜੇਹਾ ਸੁਭਾਵ ਬਨਾਣ ਲਈ) ਨਿਰੀਆਂ ਗਿਆਨ ਦੀਆਂ ਗੱਲਾਂ ਤੇ ਸਿਆਣਪਾਂ ਦੀ ਪੇਸ਼ ਨਹੀਂ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Но одними разговорами о знании и умными рассуждениями такого состояния не достичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11292,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਜਨਾਵਹੁ ਸੋ ਜਾਨੈ ਨਾਨਕ ॥੩੯॥",
          "roman": "jiseh janāvah so jānē Nānak.39.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਅਗੇ ਅਰਦਾਸ ਕਰ, ਤੇ ਆਖ-) ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਨੂੰ ਤੂੰ ਇਸ ਸੁਚੱਜੇ ਜੀਵਨ ਦੀ ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈਂ ਉਹੀ ਸਮਝਦਾ ਹੈ ॥੩੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись перед Богом и говори: о Господь, только тот понимает этот прекрасный путь жизни, кому Ты Сам даруешь это понимание. ॥39॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 838,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11293,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11294,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਭੰਜਨ ਅਘ ਦੂਖ ਨਾਸ ਮਨਹਿ ਅਰਾਧਿ ਹਰੇ ॥",
          "roman": "bhē bhanjan agh dūkh nās maneh arādh hare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਭ ਪਾਪਾਂ ਦੇ) ਹਰਨ ਵਾਲੇ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਯਾਦ ਰੱਖ। ਉਹੀ ਸਾਰੇ ਡਰਾਂ ਦਾ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਹੀ ਸਾਰੇ ਪਾਪਾਂ ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, удерживай в уме Того, кто уничтожает все грехи. Только Он разрушает все страхи, только Он уничтожает все грехи и страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11295,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗ ਜਿਹ ਰਿਦ ਬਸਿਓ ਨਾਨਕ ਤੇ ਨ ਭ੍ਰਮੇ ॥੧॥",
          "roman": "santsang jih rid basiō Nānak te na bhrame.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਤਸੰਗ ਵਿਚ ਰਹਿ ਕੇ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਹਰੀ ਆ ਟਿਕਦਾ ਹੈ, ਉਹ ਪਾਪਾਂ ਵਿਕਾਰਾਂ ਦੀ ਭਟਕਣਾ ਵਿਚ ਨਹੀਂ ਪੈਂਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те люди, в чьих сердцах Он поселяется через пребывание в сатсанге, не впадают в блуждание среди грехов и пороков. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 839,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11296,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉੜੀ"
            },
            "sahib_singh_ru": {
              "main": "Паури"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11297,
          "is_rahao": false,
          "gurmukhi": "ਭਭਾ ਭਰਮੁ ਮਿਟਾਵਹੁ ਅਪਨਾ ॥",
          "roman": "bhabhā bharam miṭāvah apnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਇਸ ਸੰਸਾਰ ਦੇ ਪਿਛੇ ਭਟਕਣ ਦੀ ਬਾਣ ਮਿਟਾ ਦਿਓ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, уничтожьте в себе привычку блуждать вслед за этим миром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11298,
          "is_rahao": false,
          "gurmukhi": "ਇਆ ਸੰਸਾਰੁ ਸਗਲ ਹੈ ਸੁਪਨਾ ॥",
          "roman": "iā sansār sagal hē supnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਸੁਪਨਾ ਹੈ (ਜਿਵੇਂ ਸੁਪਨੇ ਵਿਚ ਕਈ ਪਦਾਰਥਾਂ ਨਾਲ ਵਾਹ ਪੈਂਦਾ ਹੈ, ਪਰ ਜਾਗਦਿਆਂ ਹੀ ਉਹ ਸਾਥ ਮੁੱਕ ਜਾਂਦਾ ਹੈ), ਤਿਵੇਂ ਹੀ ਇਸ ਸਾਰੇ ਸੰਸਾਰ ਦਾ ਸਾਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Весь этот мир подобен сну: как во сне встречаются разные вещи, а при пробуждении всё это исчезает, таков и союз с этим миром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11299,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮੇ ਸੁਰਿ ਨਰ ਦੇਵੀ ਦੇਵਾ ॥",
          "roman": "bharame sur nar devī devā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਮਾਇਆ ਦੇ ਚੋਜ-ਤਮਾਸ਼ਿਆਂ ਦੀ ਖ਼ਾਤਰ) ਸੁਰਗੀ ਜੀਵ, ਮਨੁੱਖ, ਦੇਵੀ ਦੇਵਤੇ ਖ਼ੁਆਰ ਹੁੰਦੇ (ਸੁਣੀਦੇ ਰਹੇ)।"
            },
            "sahib_singh_ru": {
              "main": "Из-за забав и зрелищ этой майи страдали и небесные существа, и люди, и божества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11300,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮੇ ਸਿਧ ਸਾਧਿਕ ਬ੍ਰਹਮੇਵਾ ॥",
          "roman": "bharame sidh sādhik brahmevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੱਡੇ ਵੱਡੇ ਸਾਧਨਾਂ ਵਿਚ ਪੁੱਗੇ ਹੋਏ ਜੋਗੀ, ਸਾਧਨ ਕਰਨ ਵਾਲੇ ਜੋਗੀ, ਬ੍ਰਹਮਾ ਵਰਗੇ ਭੀ (ਇਹਨਾਂ ਪਿਛੇ) ਭਟਕਦੇ (ਸੁਣੀਦੇ) ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Даже йоги, достигшие великих практик, йоги-подвижники и подобные Брахме тоже блуждали вслед за этим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11301,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਿ ਭਰਮਿ ਮਾਨੁਖ ਡਹਕਾਏ ॥",
          "roman": "bharam bharam mānukh ḍahkāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਧਰਤੀ ਦੇ) ਬੰਦੇ (ਮਾਇਕ ਪਦਾਰਥਾਂ ਦੀ ਖ਼ਾਤਰ) ਭਟਕ ਭਟਕ ਕੇ ਧੋਖੇ ਵਿਚ ਆਉਂਦੇ ਚਲੇ ਆ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди на земле, блуждая ради материальных вещей, всё время приходят в заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11302,
          "is_rahao": false,
          "gurmukhi": "ਦੁਤਰ ਮਹਾ ਬਿਖਮ ਇਹ ਮਾਏ ॥",
          "roman": "dutar mahā bikham ih māe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਮਾਇਆ ਇਕ ਐਸਾ ਮਹਾਨ ਔਖਾ (ਸਮੁੰਦਰ) ਹੈ (ਜਿਸ ਵਿਚੋਂ) ਤਰਨਾ ਬਹੁਤ ਹੀ ਕਠਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Эта майя — такой великий и трудный океан, что переплыть его крайне тяжело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11303,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਭ੍ਰਮ ਭੈ ਮੋਹ ਮਿਟਾਇਆ ॥",
          "roman": "gurmukh bhram bhē moh miṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਬੰਦਿਆਂ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਮਾਇਆ ਪਿਛੇ) ਭਟਕਣਾ, ਸਹਮ ਤੇ ਮੋਹ (ਆਪਣੇ ਅੰਦਰੋਂ) ਮਿਟਾ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто, придя под защиту Гуру, уничтожили в себе блуждание, страх и привязанность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11304,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇਹ ਪਰਮ ਸੁਖ ਪਾਇਆ ॥੪੦॥",
          "roman": "Nānak teh param sukh pāiā.40.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਨੇ ਸਭ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਆਤਮਕ ਆਨੰਦ ਹਾਸਲ ਕਰ ਲਿਆ ਹੈ ॥੪੦॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, обрели высшее духовное блаженство. ॥40॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 840,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11305,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11306,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਡੋਲੈ ਬਹੁ ਬਿਧੀ ਮਨੁ ਲਪਟਿਓ ਤਿਹ ਸੰਗ ॥",
          "roman": "māiā ḍolē bah bidhī man lapaṭio tih sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਦਾ ਮਨ ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਹੀ ਡੋਲਦਾ ਰਹਿੰਦਾ ਹੈ, ਮਾਇਆ ਦੇ ਨਾਲ ਹੀ ਚੰਬੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ум человека колеблется многими способами только ради майи и остаётся прилеплённым к ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11307,
          "is_rahao": false,
          "gurmukhi": "ਮਾਗਨ ਤੇ ਜਿਹ ਤੁਮ ਰਖਹੁ ਸੁ ਨਾਨਕ ਨਾਮਹਿ ਰੰਗ ॥੧॥",
          "roman": "māgan te jih tum rakhah su Nānak nāmeh rang.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਅਗੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-) ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਤੂੰ ਨਿਰੀ ਮਾਇਆ ਹੀ ਮੰਗਣ ਤੋਂ ਵਰਜ ਲੈਂਦਾ ਹੈਂ ਉਹ ਤੇਰੇ ਨਾਮ ਵਿਚ ਪਿਆਰ ਪਾ ਲੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись перед Богом и говори: о Господь, того человека, которого Ты удерживаешь от просьб лишь о майе, Ты окрашиваешь любовью к Твоему Имени. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 841,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11308,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਉੜੀ"
            },
            "sahib_singh_ru": {
              "main": "Паури"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11309,
          "is_rahao": false,
          "gurmukhi": "ਮਮਾ ਮਾਗਨਹਾਰ ਇਆਨਾ ॥",
          "roman": "mamā māganhār iānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇ-ਸਮਝ ਜੀਵ ਹਰ ਵੇਲੇ (ਮਾਇਆ ਹੀ ਮਾਇਆ) ਮੰਗਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Неразумное существо всё время просит только майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11310,
          "is_rahao": false,
          "gurmukhi": "ਦੇਨਹਾਰ ਦੇ ਰਹਿਓ ਸੁਜਾਨਾ ॥",
          "roman": "denhār de rahiō sujānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਨਹੀਂ ਸਮਝਦਾ ਕਿ) ਸਭ ਦੇ ਦਿਲਾਂ ਦੀ ਜਾਣਨ ਵਾਲਾ ਦਾਤਾਰ (ਸਭ ਪਦਾਰਥ) ਦੇਈ ਜਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Оно не понимает, что мудрый Даритель, знающий сердца всех, и так непрестанно даёт всё необходимое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11311,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੀਨੋ ਸੋ ਏਕਹਿ ਬਾਰ ॥",
          "roman": "jo dīno so ekah bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀਆਂ ਦਿੱਤੀਆਂ ਦਾਤਾਂ ਤਾਂ ਕਦੇ ਮੁੱਕਣ ਵਾਲੀਆਂ ਹੀ ਨਹੀਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Его дары никогда не иссякают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11312,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮੂਰਖ ਕਹ ਕਰਹਿ ਪੁਕਾਰ ॥",
          "roman": "man mūrakh kah kareh pukār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ ਮਨ! ਤੂੰ ਕਿਉਂ ਸਦਾ ਮਾਇਆ ਵਾਸਤੇ ਹੀ ਤਰਲੇ ਲੈ ਰਿਹਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О глупый ум, почему ты всё время вопиешь только ради майи?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11313,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਮਾਗਹਿ ਤਉ ਮਾਗਹਿ ਬੀਆ ॥",
          "roman": "jau māgeh tau māgeh bīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੂਰਖ!) ਤੂੰ ਜਦੋਂ ਭੀ ਮੰਗਦਾ ਹੈਂ (ਨਾਮ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਹੋਰ ਚੀਜ਼ਾਂ ਹੀ ਮੰਗਦਾ ਰਹਿੰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О глупец, когда ты просишь, ты всё время просишь чего-то иного, не Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11314,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਤੇ ਕੁਸਲ ਨ ਕਾਹੂ ਥੀਆ ॥",
          "roman": "jā te kusal na kāhū thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਤੋਂ ਕਦੇ ਕਿਸੇ ਨੂੰ ਭੀ ਆਤਮਕ ਸੁਖ ਨਹੀਂ ਮਿਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "хотя от этого никто никогда не получил духовного блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11315,
          "is_rahao": false,
          "gurmukhi": "ਮਾਗਨਿ ਮਾਗ ਤ ਏਕਹਿ ਮਾਗ ॥",
          "roman": "māgan māg ta ekah māg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੂਰਖ ਮਨ!) ਜੇ ਤੂੰ ਮੰਗ ਮੰਗਣੀ ਹੀ ਹੈ ਤਾਂ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਮੰਗ,"
            },
            "sahib_singh_ru": {
              "main": "О глупый ум, если уж просить, то проси только Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11316,
