{
  "ang": 263,
  "shabads": [
    {
      "shabad_id": 874,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11533,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੈ ਲਾਗਉ ਪਾਏ ॥੩॥",
          "roman": "Nānak tā kē lāgau pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ, ਆਖ) ਹੇ ਨਾਨਕ! ਮੈਂ ਉਹਨਾਂ (ਸਿਮਰਨ ਕਰਨ ਵਾਲਿਆਂ) ਦੀ ਪੈਰੀਂ ਲੱਗਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потому, говорит Нанак, я припаду к стопам тех, кто помнит ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 875,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11534,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਾ ਸਿਮਰਨੁ ਸਭ ਤੇ ਊਚਾ ॥",
          "roman": "prabh kā simran sabh te ūchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨਾ (ਹੋਰ) ਸਾਰੇ (ਆਹਰਾਂ) ਨਾਲੋਂ ਚੰਗਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге выше всех прочих усилий;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11535,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਉਧਰੇ ਮੂਚਾ ॥",
          "roman": "prabh kē simran udhre mūchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ ਬਹੁਤ ਸਾਰੇ (ਜੀਵ) (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "благодаря памятованию о Боге очень многие спасаются от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11536,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਤ੍ਰਿਸਨਾ ਬੁਝੈ ॥",
          "roman": "prabh kē simran trisanā bujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ (ਮਾਇਆ ਦੀ) ਤ੍ਰਿਹ ਮਿਟ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге гасит жажду майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11537,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਸਭੁ ਕਿਛੁ ਸੁਝੈ ॥",
          "roman": "prabh kē simran sabh kichh sujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਮਾਇਆ ਦੇ) ਹਰੇਕ (ਕੇਲ) ਦੀ ਸਮਝ ਪੈ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что тогда становится понятной вся игра майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11538,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਨਾਹੀ ਜਮ ਤ੍ਰਾਸਾ ॥",
          "roman": "prabh kē simran nāhī jam trāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ ਜਮਾਂ ਦਾ ਡਰ ਮੁੱਕ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге уничтожает страх перед ямами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11539,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਪੂਰਨ ਆਸਾ ॥",
          "roman": "prabh kē simran pūran āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਜੀਵ ਦੀ) ਆਸ ਪੂਰਨ ਹੋ ਜਾਂਦੀ ਹੈ (ਭਾਵ, ਆਸਾਂ ਵੱਲੋਂ ਮਨ ਰੱਜ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и надежда существа исполняется, то есть ум насыщается и успокаивается относительно желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11540,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਮਨ ਕੀ ਮਲੁ ਜਾਇ ॥",
          "roman": "prabh kē simran man kī mal jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਮਨ ਦੀ (ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда помнят Бога, грязь пороков с ума сходит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11541,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਰਿਦ ਮਾਹਿ ਸਮਾਇ ॥",
          "roman": "amrit nām rid māh samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਪ੍ਰਭੂ ਦਾ) ਅਮਰ ਕਰਨ ਵਾਲਾ ਨਾਮ ਟਿਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и в сердце человека утверждается бессмертворящее Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11542,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਜੀ ਬਸਹਿ ਸਾਧ ਕੀ ਰਸਨਾ ॥",
          "roman": "prabh jī basah sādh kī rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਗੁਰਮੁਖ ਮਨੁੱਖਾਂ ਦੀ ਜੀਭ ਉਤੇ ਵੱਸਦੇ ਹਨ (ਭਾਵ, ਸਾਧ ਜਨ ਸਦਾ ਪ੍ਰਭੂ ਨੂੰ ਜਪਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Господь пребывает на языке гурмукхов, то есть садх-джаны всегда повторяют Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11543,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਨ ਕਾ ਦਾਸਨਿ ਦਸਨਾ ॥੪॥",
          "roman": "Nānak jan kā dāsan dasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਖ) ਹੇ ਨਾਨਕ! (ਮੈਂ) ਗੁਰਮੁਖਾਂ ਦੇ ਸੇਵਕਾਂ ਦਾ ਸੇਵਕ (ਬਣਾਂ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: стать бы мне слугой слуг гурмукхов ॥੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 876,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11544,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਧਨਵੰਤੇ ॥",
          "roman": "prabh kau simrah se dhanvante",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਧਨਾਢ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, по-настоящему богаты,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11545,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਪਤਿਵੰਤੇ ॥",
          "roman": "prabh kau simrah se pativante",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਉਹ ਇੱਜ਼ਤ ਵਾਲੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и они обладают честью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11546,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਜਨ ਪਰਵਾਨ ॥",
          "roman": "prabh kau simrah se jan parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਮੰਨੇ-ਪ੍ਰਮੰਨੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, признаны и одобрены,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11547,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਪੁਰਖ ਪ੍ਰਧਾਨ ॥",
          "roman": "prabh kau simrah se purakh pradhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ (ਸਭ ਮਨੁੱਖਾਂ ਤੋਂ) ਚੰਗੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и они — лучшие среди людей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11548,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸਿ ਬੇਮੁਹਤਾਜੇ ॥",
          "roman": "prabh kau simrah s bemuhtāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ ਉਹ ਕਿਸੇ ਦੇ ਮੁਥਾਜ ਨਹੀਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, ни в ком не нуждаются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11549,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸਿ ਸਰਬ ਕੇ ਰਾਜੇ ॥",
          "roman": "prabh kau simrah s sarab ke rāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਤਾਂ ਸਗੋਂ) ਸਭ ਦੇ ਬਾਦਸ਼ਾਹ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они — цари над всеми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11550,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਸੁਖਵਾਸੀ ॥",
          "roman": "prabh kau simrah se sukhvāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ ਉਹ ਸੁਖੀ ਵੱਸਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, живут в покое,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11551,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸਦਾ ਅਬਿਨਾਸੀ ॥",
          "roman": "prabh kau simrah sadā abināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਦਾ ਲਈ ਜਨਮ ਮਰਨ ਤੋਂ ਰਹਿਤ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и навсегда выходят из круга рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11552,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਨ ਤੇ ਲਾਗੇ ਜਿਨ ਆਪਿ ਦਇਆਲਾ ॥",
          "roman": "simran te lāge jin āp daiālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪ੍ਰਭ-ਸਿਮਰਨ ਵਿਚ ਉਹੀ ਮਨੁੱਖ ਲੱਗਦੇ ਹਨ ਜਿਨ੍ਹਾਂ ਉਤੇ ਪ੍ਰਭੂ ਆਪਿ ਮੇਹਰਬਾਨ (ਹੁੰਦਾ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Но к памятованию о Боге приступают лишь те, к кому Сам Бог милостив;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11553,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਨ ਕੀ ਮੰਗੈ ਰਵਾਲਾ ॥੫॥",
          "roman": "Nānak jan kī maṅgē ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਕੋਈ ਵਡ-ਭਾਗੀ) ਇਹਨਾਂ ਗੁਰਮੁਖਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਮੰਗਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кто-то по великой удаче просит пыль со стоп этих гурмукхов ॥੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 877,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11554,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਪਰਉਪਕਾਰੀ ॥",
          "roman": "prabh kau simrah se paraupkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਦੂਜਿਆਂ ਨਾਲ ਭਲਾਈ ਕਰਨ ਵਾਲੇ ਬਣ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, становятся благодетелями для других,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11555,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਤਿਨ ਸਦ ਬਲਿਹਾਰੀ ॥",
          "roman": "prabh kau simrah tin sad balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਤੋਂ (ਮੈਂ) ਸਦਾ ਸਦਕੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и я всегда жертвенно предан им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11556,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਸੇ ਮੁਖ ਸੁਹਾਵੇ ॥",
          "roman": "prabh kau simrah se mukh suhāve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ ਉਹਨਾਂ ਦੇ ਮੂੰਹ ਸੋਹਣੇ (ਲੱਗਦੇ) ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Лица тех, кто помнит Бога, прекрасны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11557,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਤਿਨ ਸੂਖਿ ਬਿਹਾਵੈ ॥",
          "roman": "prabh kau simrah tin sūkh bihāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੀ (ਉਮਰ) ਸੁਖ ਵਿਚ ਗੁਜ਼ਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и жизнь их проходит в счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11558,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਤਿਨ ਆਤਮੁ ਜੀਤਾ ॥",
          "roman": "prabh kau simrah tin ātam jītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹ ਆਪਣੇ ਆਪ ਨੂੰ ਜਿੱਤ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, побеждают самих себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11559,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਤਿਨ ਨਿਰਮਲ ਰੀਤਾ ॥",
          "roman": "prabh kau simrah tin nirmal rītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਹਨਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਗੁਜ਼ਾਰਨ ਦਾ ਤਰੀਕਾ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и образ их жизни становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11560,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਤਿਨ ਅਨਦ ਘਨੇਰੇ ॥",
          "roman": "prabh kau simrah tin anad ghanere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦੇ ਹਨ, ਉਹਨਾਂ ਨੂੰ ਖ਼ੁਸ਼ੀਆਂ ਹੀ ਖ਼ੁਸ਼ੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто помнят Бога, исполнены радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11561,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਉ ਸਿਮਰਹਿ ਬਸਹਿ ਹਰਿ ਨੇਰੇ ॥",
          "roman": "prabh kau simrah basah har nere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਵੱਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что пребывают в близости к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11562,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕ੍ਰਿਪਾ ਤੇ ਅਨਦਿਨੁ ਜਾਗਿ ॥",
          "roman": "sant kripā te andin jāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਹੀ ਇਹ ਹਰ ਵੇਲੇ (ਸਿਮਰਨ ਦੀ) ਜਾਗ ਆ ਸਕਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Лишь по милости святых может прийти это постоянное бодрствование памятования;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11563,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਿਮਰਨੁ ਪੂਰੈ ਭਾਗਿ ॥੬॥",
          "roman": "Nānak simran pūrē bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਿਮਰਨ (ਦੀ ਦਾਤਿ) ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ (ਮਿਲਦੀ ਹੈ) ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, дар памятования обретается великой удачей ॥੬॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 878,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11564,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਕਾਰਜ ਪੂਰੇ ॥",
          "roman": "prabh kē simran kāraj pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ ਮਨੁੱਖ ਦੇ (ਸਾਰੇ) ਕੰਮ ਪੂਰੇ ਹੋ ਜਾਂਦੇ ਹਨ (ਭਾਵ, ਉਹ ਲੋੜਾਂ ਦੇ ਅਧੀਨ ਨਹੀਂ ਰਹਿੰਦਾ)"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге завершает все дела человека, то есть он перестаёт быть подвластным нуждам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11565,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਕਬਹੁ ਨ ਝੂਰੇ ॥",
          "roman": "prabh kē simran kabah na jhūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਦੇ ਚਿੰਤਾ ਦੇ ਵੱਸ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и никогда не оказывается во власти тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11566,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਹਰਿ ਗੁਨ ਬਾਨੀ ॥",
          "roman": "prabh kē simran har gun bānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ, ਮਨੁੱਖ ਅਕਾਲ ਪੁਰਖ ਦੇ ਗੁਣ ਹੀ ਉਚਾਰਦਾ ਹੈ (ਭਾਵ, ਉਸ ਨੂੰ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਆਦਤ ਪੈ ਜਾਂਦੀ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге приводит к тому, что человек произносит только качества Вечного Пурукха, то есть привыкает к восхвалению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11567,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਸਹਜਿ ਸਮਾਨੀ ॥",
          "roman": "prabh kē simran sahaj samānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਹਜ ਅਵਸਥਾ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И он пребывает в состоянии сахадж."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11568,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਨਿਹਚਲ ਆਸਨੁ ॥",
          "roman": "prabh kē simran nihchal āsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ ਮਨੁੱਖ ਦਾ (ਮਨ ਰੂਪੀ) ਆਸਨ ਡੋਲਦਾ ਨਹੀਂ"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге делает сиденье ума неподвижным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11569,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਕਮਲ ਬਿਗਾਸਨੁ ॥",
          "roman": "prabh kē simran kamal bigāsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਦੇ (ਹਿਰਦੇ ਦਾ) ਕਉਲ-ਫੁੱਲ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и лотос сердца остаётся раскрытым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11570,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਸਿਮਰਨਿ ਅਨਹਦ ਝੁਨਕਾਰ ॥",
          "roman": "prabh kē simran anhad jhunkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨ ਨਾਲ (ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਇਕ-ਰਸ ਸੰਗੀਤ (ਜਿਹਾ) (ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге вызывает внутри человека непрерывную, как бы музыкальную, вибрацию,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11571,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਪ੍ਰਭ ਸਿਮਰਨ ਕਾ ਅੰਤੁ ਨ ਪਾਰ ॥",
          "roman": "sukh prabh simran kā ant na pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ) ਪ੍ਰਭੂ ਦੇ ਸਿਮਰਨ ਤੋਂ ਜੋ ਸੁਖ (ਉਪਜਦਾ) ਹੈ ਉਹ (ਕਦੇ) ਮੁੱਕਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "и блаженству, рождаемому памятованием о Боге, нет конца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11572,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਸੇ ਜਨ ਜਿਨ ਕਉ ਪ੍ਰਭ ਮਇਆ ॥",
          "roman": "simrah se jan jin kau prabh maiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਪ੍ਰਭੂ ਨੂੰ) ਸਿਮਰਦੇ ਹਨ, ਜਿਨ੍ਹਾਂ ਉਤੇ ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਹੁੰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Лишь те люди помнят Бога, на кого нисходит Его милость;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11573,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਜਨ ਸਰਨੀ ਪਇਆ ॥੭॥",
          "roman": "Nānak tin jan sarnī paiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਕੋਈ ਵਡਭਾਗੀ) ਉਹਨਾਂ (ਸਿਮਰਨ ਕਰਨ ਵਾਲੇ) ਜਨਾਂ ਦੀ ਸਰਣੀ ਪੈਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кто-то по великой удаче приходит под защиту этих людей, помнящих Бога ॥੭॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 879,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11574,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨੁ ਕਰਿ ਭਗਤ ਪ੍ਰਗਟਾਏ ॥",
          "roman": "har simran kar bhagat pragaṭāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰ ਕੇ ਭਗਤ (ਜਗਤ ਵਿਚ) ਮਸ਼ਹੂਰ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Благодаря памятованию о Боге бхагаты становятся известны в мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11575,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨਿ ਲਗਿ ਬੇਦ ਉਪਾਏ ॥",
          "roman": "har simran lag bed upāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਮਰਨ ਵਿਚ ਹੀ ਜੁੜ ਕੇ (ਰਿਸ਼ੀਆਂ ਨੇ) ਵੇਦ (ਆਦਿਕ ਧਰਮ ਪੁਸਤਕ) ਰਚੇ।"
            },
            "sahib_singh_ru": {
              "main": "и, погрузившись в памятование, риши создали Веды и другие священные книги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11576,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨਿ ਭਏ ਸਿਧ ਜਤੀ ਦਾਤੇ ॥",
          "roman": "har simran bhae sidh jatī dāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸਿਮਰਨ ਦੁਆਰਾ ਹੀ ਮਨੁੱਖ ਸਿੱਧ ਬਣ ਗਏ, ਜਤੀ ਬਣ ਗਏ, ਦਾਤੇ ਬਣ ਗਏ;"
            },
            "sahib_singh_ru": {
              "main": "Через памятование о Боге люди становились сиддхами, джати и щедрыми подвижниками;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11577,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨਿ ਨੀਚ ਚਹੁ ਕੁੰਟ ਜਾਤੇ ॥",
          "roman": "har simran nīch chah kuṇṭ jāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਨੀਚ ਮਨੁੱਖ ਸਾਰੇ ਸੰਸਾਰ ਵਿਚ ਪਰਗਟ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "по благодати памятования низкие люди прославлялись по всему миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11578,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨਿ ਧਾਰੀ ਸਭ ਧਰਨਾ ॥",
          "roman": "har simran dhārī sabh dharnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸਿਮਰਨ ਨੇ ਸਾਰੀ ਧਰਤੀ ਨੂੰ ਆਸਰਾ ਦਿੱਤਾ ਹੋਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Памятование о Боге поддерживает всю землю;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11579,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਹਰਿ ਕਾਰਨ ਕਰਨਾ ॥",
          "roman": "simar simar har kāran karnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ ਹੇ ਭਾਈ!) ਜਗਤ ਦੇ ਕਰਤਾ ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "потому, брат, всегда помни Бога, Творца мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11580,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨਿ ਕੀਓ ਸਗਲ ਅਕਾਰਾ ॥",
          "roman": "har simran kīo sagal ākārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਸਿਮਰਨ ਵਾਸਤੇ ਸਾਰਾ ਜਗਤ ਬਣਾਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Бог создал весь мир ради памятования;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11581,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨ ਮਹਿ ਆਪਿ ਨਿਰੰਕਾਰਾ ॥",
          "roman": "har simran meh āp nirankārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਸਿਮਰਨ ਹੈ ਓਥੇ ਨਿਰੰਕਾਰ ਆਪ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "где есть памятование, там Сам Ниранкар пребывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11582,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਆਪਿ ਬੁਝਾਇਆ ॥",
          "roman": "kar kirpā jis āp bujhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਸਿਮਰਨ ਕਰਨ ਦੀ) ਸਮਝ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кому по милости Он Сам даёт понимание памятования,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11583,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਹਰਿ ਸਿਮਰਨੁ ਤਿਨਿ ਪਾਇਆ ॥੮॥੧॥",
          "roman": "Nānak gurmukh har simran tin pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੁਆਰਾ ਸਿਮਰਨ (ਦੀ ਦਾਤ) ਪ੍ਰਾਪਤ ਕਰ ਲਈ ਹੈ ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот человек через Гуру обретает дар памятования о Хари ॥੮॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
