        },
        {
          "verse_id": 11585,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਰਦ ਦੁਖ ਭੰਜਨਾ ਘਟਿ ਘਟਿ ਨਾਥ ਅਨਾਥ ॥",
          "roman": "dīn darad dukh bhanjnā ghaṭ ghaṭ nāth anāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਨਾਂ ਦੇ ਦਰਦ ਤੇ ਦੁੱਖ ਨਾਸ ਕਰਨ ਵਾਲੇ ਹੇ ਪ੍ਰਭੂ! ਹੇ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪਕ ਹਰੀ! ਹੇ ਅਨਾਥਾਂ ਦੇ ਨਾਥ!"
            },
            "sahib_singh_ru": {
              "main": "О Господь, уничтожающий боль и страдания бедных! О Хари, присутствующий в каждом теле! О Владыка беззащитных!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11586,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਤੁਮੑਾਰੀ ਆਇਓ ਨਾਨਕ ਕੇ ਪ੍ਰਭ ਸਾਥ ॥੧॥",
          "roman": "saraṇ tumhārī āio Nānak ke prabh sāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਗੁਰੂ ਨਾਨਕ ਦਾ ਪੱਲਾ ਫੜ ਕੇ ਮੈਂ ਤੇਰੀ ਸਰਣ ਆਇਆ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Держась за полу Гуру Нанака, я пришёл в Твоё прибежище ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
