{
  "ang": 265,
  "shabads": [
    {
      "shabad_id": 886,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11644,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਨ ਕਉ ਭੋਗ ਜੋਗ ॥",
          "roman": "har kā nām jan kau bhog jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਆਗੀ ਦਾ) ਜੋਗ (-ਸਾਧਨ) ਤੇ ਗ੍ਰਿਹਸਤੀ ਦਾ ਮਾਇਆ ਦਾ ਭੋਗ ਭਗਤ ਜਨ ਵਾਸਤੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਹੀ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для преданного и йога отречения, и наслаждение домохозяина — это Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11645,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਜਪਤ ਕਛੁ ਨਾਹਿ ਬਿਓਗੁ ॥",
          "roman": "har nām japat kachh nāh biog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਉਸ ਨੂੰ) ਕੋਈ ਦੁੱਖ ਕਲੇਸ਼ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и, повторяя Имя Господа, он не испытывает никакого страдания и боли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11646,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਰਾਤਾ ਹਰਿ ਨਾਮ ਕੀ ਸੇਵਾ ॥",
          "roman": "jan rātā har nām kī sevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ) ਭਗਤ (ਸਦਾ) ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਸੇਵਾ (ਸਿਮਰਨ) ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Преданный всегда погружён в служение Имени Господа, то есть в памятование,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11647,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪੂਜੈ ਹਰਿ ਹਰਿ ਦੇਵਾ ॥੬॥",
          "roman": "Nānak pūjē har har devā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਭਗਤ ਸਦਾ) ਪ੍ਰਭੂ-ਦੇਵ ਨੂੰ ਪੂਜਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, он постоянно поклоняется Богу-Господу ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 887,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11648,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਜਨ ਕੈ ਮਾਲੁ ਖਜੀਨਾ ॥",
          "roman": "har har jan kē māl khajīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਭਗਤ ਦੇ ਵਾਸਤੇ ਮਾਲ ਧਨ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Господа — имущество и богатство преданного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11649,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਧਨੁ ਜਨ ਕਉ ਆਪਿ ਪ੍ਰਭਿ ਦੀਨਾ ॥",
          "roman": "har dhan jan kau āp prabh dīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਨਾਮ-ਰੂਪੀ ਧਨ ਪ੍ਰਭੂ ਨੇ ਆਪ ਆਪਣੇ ਭਗਤ ਨੂੰ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "это богатство Имени Сам Господь дал Своему преданному."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11650,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਜਨ ਕੈ ਓਟ ਸਤਾਣੀ ॥",
          "roman": "har har jan kē oṭ satāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤ ਵਾਸਤੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਹੀ) ਤਕੜਾ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для преданного Имя Господа — крепкая опора,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11651,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪ੍ਰਤਾਪਿ ਜਨ ਅਵਰ ਨ ਜਾਣੀ ॥",
          "roman": "har pratāp jan avar na jāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤਾਂ ਨੇ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰਤਾਪ ਨਾਲ ਕਿਸੇ ਹੋਰ ਆਸਰੇ ਨੂੰ ਨਹੀਂ ਤੱਕਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "и силой Господа преданные не ищут никакой иной поддержки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11652,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਜਨ ਹਰਿ ਰਸਿ ਰਾਤੇ ॥",
          "roman": "ot pot jan har ras rāte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤ ਜਨ ਪ੍ਰਭੂ-ਨਾਮ-ਰਸ ਵਿਚ ਪੂਰੇ ਤੌਰ ਤੇ ਭਿੱਜੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Преданные насквозь пропитаны вкусом Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11653,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਮਾਧਿ ਨਾਮ ਰਸ ਮਾਤੇ ॥",
          "roman": "sunn samādh nām ras māte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ) ਨਾਮ-ਰਸ ਦੇ ਮੱਤੇ ਹੋਏ (ਮਨ ਦਾ ਉਹ) ਟਿਕਾਉ (ਮਾਣਦੇ ਹਨ) ਜਿਥੇ ਕੋਈ ਫੁਰਨਾ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и, опьянённые этим вкусом Имени, пребывают в таком покое ума, где нет никаких мыслей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11654,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਜਨੁ ਹਰਿ ਹਰਿ ਜਪੈ ॥",
          "roman": "āṭh pahar jan har har japē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ) ਭਗਤ ਅੱਠੇ ਪਹਰ ਪ੍ਰਭੂ ਨੂੰ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Преданный все восемь страж суток повторяет Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11655,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਭਗਤੁ ਪ੍ਰਗਟ ਨਹੀ ਛਪੈ ॥",
          "roman": "har kā bhagat pragaṭ nahī chhapē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਿਚ) ਭਗਤ ਉੱਘਾ (ਹੋ ਜਾਂਦਾ ਹੈ) ਲੁਕਿਆ ਨਹੀਂ ਰਹਿੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и преданный Господа становится явным в мире, не остаётся скрытым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11656,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਮੁਕਤਿ ਬਹੁ ਕਰੇ ॥",
          "roman": "har kī bhagat mukt bah kare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਬੇਅੰਤ ਜੀਵਾਂ ਨੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਖ਼ਲਾਸੀ ਦਿਵਾਉਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Преданность Господу освобождает бесчисленные существа от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11657,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਨ ਸੰਗਿ ਕੇਤੇ ਤਰੇ ॥੭॥",
          "roman": "Nānak jan sang kete tare",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਭਗਤ ਦੀ ਸੰਗਤਿ ਵਿਚ ਕਈ ਹੋਰ (ਭੀ) ਤਰ ਜਾਂਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, в обществе преданного переправляются и многие другие ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 888,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11658,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਜਾਤੁ ਇਹੁ ਹਰਿ ਕੋ ਨਾਮ ॥",
          "roman": "pārjāt ih har ko nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਇਹ ਨਾਮ (ਹੀ) 'ਪਾਰਜਾਤ' ਰੁੱਖ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Это Имя Господа — дерево Парджат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11659,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਧੇਨ ਹਰਿ ਹਰਿ ਗੁਣ ਗਾਮ ॥",
          "roman": "kāmdhen har har guṇ gām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਣੇ (ਹੀ ਇੱਛਾ-ਪੂਰਕ) 'ਕਾਮਧੇਨ' ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а воспевание качеств Господа — это Камдхен, исполняющая желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11660,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਤਮ ਹਰਿ ਕੀ ਕਥਾ ॥",
          "roman": "sabh te ūtam har kī kathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀਆਂ (ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀਆਂ) ਗੱਲਾਂ (ਹੋਰ) ਸਭ (ਗੱਲਾਂ) ਤੋਂ ਚੰਗੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Речи о славе Господа — лучше всех прочих речей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11661,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਸੁਨਤ ਦਰਦ ਦੁਖ ਲਥਾ ॥",
          "roman": "nām sunat darad dukh lathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਸੁਣਿਆਂ ਸਾਰੇ ਦੁਖ ਦਰਦ ਲਹਿ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что, слушая Имя Господа, уходят все боли и страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11662,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੀ ਮਹਿਮਾ ਸੰਤ ਰਿਦ ਵਸੈ ॥",
          "roman": "nām kī mahimā sant rid vasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ) ਨਾਮ ਦੀ ਵਡਿਆਈ ਸੰਤਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Величие Имени Господа живёт в сердцах святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11663,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਤਾਪਿ ਦੁਰਤੁ ਸਭੁ ਨਸੈ ॥",
          "roman": "sant pratāp durat sabh nasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ) ਸੰਤਾਂ ਦੇ ਪ੍ਰਤਾਪ ਨਾਲ ਸਾਰਾ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и силой святых исчезает весь грех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11664,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕਾ ਸੰਗੁ ਵਡਭਾਗੀ ਪਾਈਐ ॥",
          "roman": "sant kā sang vaḍbhāgī pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Общество святых обретается великой удачей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11665,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਕੀ ਸੇਵਾ ਨਾਮੁ ਧਿਆਈਐ ॥",
          "roman": "sant kī sevā nām dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ) ਸੰਤਾਂ ਦੀ ਸੇਵਾ (ਕੀਤਿਆਂ) (ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਸਿਮਰੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, служа святым, человек помнит Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11666,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਤੁਲਿ ਕਛੁ ਅਵਰੁ ਨ ਹੋਇ ॥",
          "roman": "nām tul kachh avar na hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ-ਨਾਮ ਦੇ ਬਰਾਬਰ ਹੋਰ ਕੋਈ (ਪਦਾਰਥ) ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Нет ничего, что могло бы сравниться с Именем Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11667,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਪਾਵੈ ਜਨੁ ਕੋਇ ॥੮॥੨॥",
          "roman": "Nānak gurmukh nām pāvē jan koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਨਾਮ (ਦੀ ਦਾਤਿ) ਲੱਭਦਾ ਹੈ ॥੮॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только редкий человек, обратившись лицом к Гуру, обретает дар Имени ॥8॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 889,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11668,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11669,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਸਾਸਤ੍ਰ ਬਹੁ ਸਿਮ੍ਰਿਤੀ ਪੇਖੇ ਸਰਬ ਢਢੋਲਿ ॥",
          "roman": "bah sāstr bah simritī pekhe sarab dhaḍhol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤ ਸ਼ਾਸਤ੍ਰ ਤੇ ਬਹੁ ਸਿੰਮ੍ਰਿਤੀਆਂ, ਸਾਰੇ (ਅਸਾਂ) ਖੋਜ ਕੇ ਵੇਖੇ ਹਨ; (ਇਹ ਪੁਸਤਕ ਕਈ ਤਰ੍ਹਾਂ ਦੀ ਗਿਆਨ-ਚਰਚਾ ਤੇ ਕਈ ਧਾਰਮਿਕ ਤੇ ਭਾਈਚਾਰਕ ਰਸਮਾਂ ਸਿਖਾਉਂਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "Много шастр и много смрити мы исследовали и просмотрели все; эти книги учат многим видам рассуждений о знании, а также многим религиозным и общинным обрядам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11670,
          "is_rahao": false,
          "gurmukhi": "ਪੂਜਸਿ ਨਾਹੀ ਹਰਿ ਹਰੇ ਨਾਨਕ ਨਾਮ ਅਮੋਲ ॥੧॥",
          "roman": "pūjas nāhī har harē Nānak nām amol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ) ਅਕਾਲ ਪੁਰਖ ਦੇ ਨਾਮ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦੇ। ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਦੇ) ਨਾਮ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но они не могут сравниться с Именем Акал Пуракха. О Нанак, цену Имени Господа невозможно определить. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 890,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11671,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11672,
          "is_rahao": false,
          "gurmukhi": "ਜਾਪ ਤਾਪ ਗਿਆਨ ਸਭਿ ਧਿਆਨ ॥",
          "roman": "jāp tāp giān sabh dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਕੋਈ) (ਵੇਦ-ਮੰਤ੍ਰਾਂ ਦੇ) ਜਾਪ ਕਰੇ, (ਸਰੀਰ ਨੂੰ ਧੂਣੀਆਂ ਨਾਲ) ਤਪਾਏ, (ਹੋਰ) ਕਈ ਗਿਆਨ (ਦੀਆਂ ਗੱਲਾਂ ਕਰੇ) ਤੇ (ਦੇਵਤਿਆਂ ਦੇ) ਧਿਆਨ ਧਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то совершает джап ведических мантр, истязает тело аскезой, рассуждает о многих знаниях и сосредотачивается на богах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11673,
          "is_rahao": false,
          "gurmukhi": "ਖਟ ਸਾਸਤ੍ਰ ਸਿਮ੍ਰਿਤਿ ਵਖਿਆਨ ॥",
          "roman": "khaṭ sāstr simrit vakhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਛੇ ਸ਼ਾਸਤ੍ਰਾਂ ਤੇ ਸਿਮ੍ਰਿਤੀਆਂ ਦਾ ਉਪਦੇਸ਼ ਕਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "даёт наставления по шести шастрам и смрити;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11674,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗ ਅਭਿਆਸ ਕਰਮ ਧ੍ਰਮ ਕਿਰਿਆ ॥",
          "roman": "jog abhiās karam dharam kiriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗ ਦੇ ਸਾਧਨ ਕਰੇ, ਕਰਮ ਕਾਂਡੀ ਧਰਮ ਦੀ ਕ੍ਰਿਆ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "занимается йогическими практиками, совершает обрядовые действия карма-кандного дхарма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11675,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਿਆਗਿ ਬਨ ਮਧੇ ਫਿਰਿਆ ॥",
          "roman": "sagal tiāg ban madhē phiriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਾਂ) ਸਾਰੇ (ਕੰਮ) ਛੱਡ ਕੇ ਜੰਗਲਾਂ ਵਿਚ ਭਉਂਦਾ ਫਿਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "или, оставив все дела, скитается по лесам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11676,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪ੍ਰਕਾਰ ਕੀਏ ਬਹੁ ਜਤਨਾ ॥",
          "roman": "anik prakār kīē bah jatnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਬੜੇ ਜਤਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "совершает множество великих усилий разного рода,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11677,
          "is_rahao": false,
          "gurmukhi": "ਪੁੰਨ ਦਾਨ ਹੋਮੇ ਬਹੁ ਰਤਨਾ ॥",
          "roman": "puṇn dān homē bah ratnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੁੰਨਦਾਨ ਕਰੇ ਤੇ ਬਹੁਤ ਸਾਰਾ ਘਿਉ ਹਵਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "творит благотворительные подаяния и совершает много огненных жертв с гхи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11678,
          "is_rahao": false,
          "gurmukhi": "ਸਰੀਰੁ ਕਟਾਇ ਹੋਮੈ ਕਰਿ ਰਾਤੀ ॥",
          "roman": "sarīr kaṭāe homē kar rātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸਰੀਰ ਨੂੰ ਰਤੀ ਰਤੀ ਕਰ ਕੇ ਕਟਾਵੇ ਤੇ ਅੱਗ ਵਿਚ ਸਾੜ ਦੇਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "режет своё тело на частицы и сжигает в огне,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11679,
          "is_rahao": false,
          "gurmukhi": "ਵਰਤ ਨੇਮ ਕਰੈ ਬਹੁ ਭਾਤੀ ॥",
          "roman": "varat nem karē bah bhātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਕਿਸਮਾਂ ਦੇ ਵਰਤਾਂ ਦੇ ਬੰਧੇਜ ਕਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "соблюдает множество различных постов и обетов;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11680,
          "is_rahao": false,
          "gurmukhi": "ਨਹੀ ਤੁਲਿ ਰਾਮ ਨਾਮ ਬੀਚਾਰ ॥",
          "roman": "nahī tul rām nām bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਸਾਰੇ ਹੀ) ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਵਿਚਾਰ ਦੇ ਬਰਾਬਰ ਨਹੀਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "всё это не равно размышлению о Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11681,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਜਪੀਐ ਇਕ ਬਾਰ ॥੧॥",
          "roman": "Nānak gurmukh nām japīai ik bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵੇਂ) ਹੇ ਨਾਨਕ! ਇਹ ਨਾਮ ਇਕ ਵਾਰੀ (ਭੀ) ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਜਪਿਆ ਜਾਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "пусть даже, о Нанак, это Имя будет произнесено хотя бы один раз, обратившись лицом к Гуру. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 891,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11682,
          "is_rahao": false,
          "gurmukhi": "ਨਉ ਖੰਡ ਪ੍ਰਿਥਮੀ ਫਿਰੈ ਚਿਰੁ ਜੀਵੈ ॥",
          "roman": "nau khaṇḍ prithmī phirē chir jīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਕੋਈ ਮਨੁੱਖ) ਸਾਰੀ ਧਰਤੀ ਤੇ ਫਿਰੇ, ਲੰਮੀ ਉਮਰ ਤਕ ਜੀਊਂਦਾ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек обойдёт всю землю и проживёт очень долгую жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11683,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਉਦਾਸੁ ਤਪੀਸਰੁ ਥੀਵੈ ॥",
          "roman": "mahā udās tapīsar thīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਵਲੋਂ) ਬਹੁਤ ਉਪਰਾਮ ਹੋ ਕੇ ਵੱਡਾ ਤਪੀ ਬਣ ਜਾਏ;"
            },
            "sahib_singh_ru": {
              "main": "станет великим отшельником, полностью отрешённым от мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11684,
          "is_rahao": false,
          "gurmukhi": "ਅਗਨਿ ਮਾਹਿ ਹੋਮਤ ਪਰਾਨ ॥",
          "roman": "agan māh homat parān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਗ ਵਿਚ (ਆਪਣੀ) ਜਿੰਦ ਹਵਨ ਕਰ ਦੇਵੇ;"
            },
            "sahib_singh_ru": {
              "main": "принесёт свою жизнь в жертву огню,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11685,
          "is_rahao": false,
          "gurmukhi": "ਕਨਿਕ ਅਸ੍ਵ ਹੈਵਰ ਭੂਮਿ ਦਾਨ ॥",
          "roman": "kanik asv hēvar bhūm dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋਨਾ, ਘੋੜੇ, ਵਧੀਆ ਘੋੜੇ ਤੇ ਜ਼ਿਮੀਂ ਦਾਨ ਕਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "пожертвует золото, коней, породистых коней и землю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11686,
          "is_rahao": false,
          "gurmukhi": "ਨਿਉਲੀ ਕਰਮ ਕਰੈ ਬਹੁ ਆਸਨ ॥",
          "roman": "niulī karam karē bah āsan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਉਲੀ ਕਰਮ ਤੇ ਹੋਰ ਬਹੁਤ ਸਾਰੇ (ਯੋਗ) ਆਸਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "будет выполнять практику ниули и многие другие йогические асаны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11687,
          "is_rahao": false,
          "gurmukhi": "ਜੈਨ ਮਾਰਗ ਸੰਜਮ ਅਤਿ ਸਾਧਨ ॥",
          "roman": "jēn mārag sanjam at sāḍhan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੈਨੀਆਂ ਦੇ ਰਸਤੇ (ਚੱਲ ਕੇ) ਬੜੇ ਕਠਿਨ ਸਾਧਨ ਤੇ ਸੰਜਮ ਕਰੇ;"
            },
            "sahib_singh_ru": {
              "main": "пойдёт путём джайнов, соблюдая крайне трудные дисциплины и воздержания;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11688,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨਿਮਖ ਕਰਿ ਸਰੀਰੁ ਕਟਾਵੈ ॥",
          "roman": "nimakh nimakh kar sarīr kaṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰੀਰ ਨੂੰ ਰਤਾ ਰਤਾ ਕਰ ਕੇ ਕਟਾ ਦੇਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "разрежет своё тело по крупицам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11689,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਭੀ ਹਉਮੈ ਮੈਲੁ ਨ ਜਾਵੈ ॥",
          "roman": "tau bhī haumē mēl na jāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ (ਮਨ ਦੀ) ਹਉਮੈ ਦੀ ਮੈਲ ਦੂਰ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "и всё же грязь Хоумэ из ума не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11690,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਸਮਸਰਿ ਕਛੁ ਨਾਹਿ ॥",
          "roman": "har kē nām samsar kachh nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਜੇਹਾ) ਕੋਈ (ਉੱਦਮ) ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੇ ਬਰਾਬਰ ਨਹੀਂ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Ничто не сравнится с Именем Господа;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11691,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਜਪਤ ਗਤਿ ਪਾਹਿ ॥੨॥",
          "roman": "Nānak gurmukh nām japat gat pāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਨਾਮ ਜਪਦੇ ਹਨ ਉਹ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਹਾਸਲ ਕਰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, те, кто повторяют Имя, обратившись к Гуру, достигают высокого духовного состояния. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 892,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11692,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾਮਨਾ ਤੀਰਥ ਦੇਹ ਛੁਟੈ ॥",
          "roman": "man kāmnā tīrath dēh chhuṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਈ ਪ੍ਰਾਣੀਆਂ ਦੇ) ਮਨ ਦੀ ਇੱਛਾ (ਹੁੰਦੀ ਹੈ ਕਿ) ਤੀਰਥਾਂ ਤੇ (ਜਾ ਕੇ) ਸਰੀਰਕ ਚੋਲਾ ਛੱਡਿਆ ਜਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "У многих существ есть желание оставить телесный покров в местах паломничества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11693,
          "is_rahao": false,
          "gurmukhi": "ਗਰਬੁ ਗੁਮਾਨੁ ਨ ਮਨ ਤੇ ਹੁਟੈ ॥",
          "roman": "garab gumān na man tē huṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਸ ਤਰ੍ਹਾਂ ਭੀ) ਹਉਮੈ ਅਹੰਕਾਰ ਮਨ ਵਿਚੋਂ ਘਟਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "но и так Хоумэ и гордыня не уходят из ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11694,
          "is_rahao": false,
          "gurmukhi": "ਸੋਚ ਕਰੈ ਦਿਨਸੁ ਅਰੁ ਰਾਤਿ ॥",
          "roman": "soch karē dinas ar rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਨੁੱਖ) ਦਿਨ ਤੇ ਰਾਤ (ਭਾਵ, ਸਦਾ) (ਤੀਰਥਾਂ ਤੇ) ਇਸ਼ਨਾਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Человек может омываться днём и ночью, то есть постоянно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11695,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕੀ ਮੈਲੁ ਨ ਤਨ ਤੇ ਜਾਤਿ ॥",
          "roman": "man kī mēl na tan tē jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫੇਰ ਭੀ) ਮਨ ਦੀ ਮੈਲ ਸਰੀਰ ਧੋਤਿਆਂ ਨਹੀਂ ਜਾਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "но грязь ума не смывается омовением тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11696,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਦੇਹੀ ਕਉ ਬਹੁ ਸਾਧਨਾ ਕਰੈ ॥",
          "roman": "is dēhī kau bah sāḍhnā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ) ਇਸ ਸਰੀਰ ਨੂੰ (ਸਾਧਨ ਦੀ ਖ਼ਾਤਰ) ਕਈ ਜਤਨ ਭੀ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если он и для этого тела совершает множество аскетических усилий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11697,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤੇ ਕਬਹੂ ਨ ਬਿਖਿਆ ਟਰੈ ॥",
          "roman": "man tē kabhū na bikhiā ṭarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਭੀ) ਕਦੇ ਮਨ ਤੋਂ ਮਾਇਆ (ਦਾ ਪ੍ਰਭਾਵ) ਨਹੀਂ ਟਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "всё равно влияние майи никогда не отступает от ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11698,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਧੋਵੈ ਬਹੁ ਦੇਹ ਅਨੀਤਿ ॥",
          "roman": "jal dhovē bah dēh anīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ) ਇਸ ਨਾਸਵੰਤ ਸਰੀਰ ਨੂੰ ਕਈ ਵਾਰ ਪਾਣੀ ਨਾਲ ਭੀ ਧੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если этот бренный телесный состав многократно мыть водой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11699,
          "is_rahao": false,
          "gurmukhi": "ਸੁਧ ਕਹਾ ਹੋਇ ਕਾਚੀ ਭੀਤਿ ॥",
          "roman": "sudh kahā hoi kāchī bhīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਭੀ ਇਹ ਸਰੀਰ ਰੂਪੀ) ਕੱਚੀ ਕੰਧ ਕਿਥੇ ਪਵਿਤ੍ਰ ਹੋ ਸਕਦੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "как может стать чистой эта непрочная стена?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11700,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਮਹਿਮਾ ਊਚ ॥",
          "roman": "man har kē nām kī mahimā ūch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਵਡਿਆਈ ਬਹੁਤ ਵੱਡੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум, величие Имени Господа очень высоко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11701,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਉਧਰੇ ਪਤਿਤ ਬਹੁ ਮੂਚ ॥੩॥",
          "roman": "Nānak nām udharē patit bah mūch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਅਣਗਿਣਤ ਮੰਦ-ਕਰਮੀ ਜੀਵ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, по милости Имени бесчисленные падшие и грешные существа спасаются от пороков. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 893,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11702,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਸਿਆਣਪ ਜਮ ਕਾ ਭਉ ਬਿਆਪੈ ॥",
          "roman": "bahut siāṇap jam kā bhau biāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਦੀ) ਬਹੁਤੀ ਚਤੁਰਾਈ (ਦੇ ਕਾਰਣ) ਜਮਾਂ ਦਾ ਡਰ (ਜੀਵ ਨੂੰ) ਆ ਦਬਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за большой хитроумности на существо наваливается страх перед ямами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
