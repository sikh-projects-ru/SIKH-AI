{
  "ang": 266,
  "shabads": [
    {
      "shabad_id": 893,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11703,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਤਨ ਕਰਿ ਤ੍ਰਿਸਨ ਨਾ ਧ੍ਰਾਪੈ ॥",
          "roman": "anik jatan kar trisan na dhrāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਚਤੁਰਾਈ ਦੇ) ਅਨੇਕਾਂ ਜਤਨ ਕੀਤਿਆਂ (ਮਾਇਆ ਦੀ) ਤ੍ਰਿਹ ਨਹੀਂ ਮੁੱਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "потому что множеством таких ухищрений жажда майи не утоляется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11704,
          "is_rahao": false,
          "gurmukhi": "ਭੇਖ ਅਨੇਕ ਅਗਨਿ ਨਹੀ ਬੁਝੈ ॥",
          "roman": "bhekh anek agan nahī bujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ (ਧਾਰਮਿਕ) ਭੇਖ ਕੀਤਿਆਂ (ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਨਹੀਂ ਬੁੱਝਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "От множества религиозных одежд огонь жажды не гаснет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11705,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਉਪਾਵ ਦਰਗਹ ਨਹੀ ਸਿਝੈ ॥",
          "roman": "koṭ upāv dargah nahī sijhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਜਿਹੇ) ਕ੍ਰੋੜਾਂ ਤਰੀਕੇ (ਵਰਤਿਆਂ ਭੀ ਪ੍ਰਭੂ ਦੀ) ਦਰਗਾਹ ਵਿਚ ਸੁਰਖ਼ਰੂ ਨਹੀਂ ਹੋਈਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и даже миллионы способов не делают человека одобренным в Божественном дворе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11706,
          "is_rahao": false,
          "gurmukhi": "ਛੂਟਸਿ ਨਾਹੀ ਊਭ ਪਇਆਲਿ ॥",
          "roman": "chhūṭas nāhī ūbh paiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਜਤਨਾਂ ਨਾਲ) ਜੀਵ ਚਾਹੇ ਅਕਾਸ਼ ਤੇ ਚੜ੍ਹ ਜਾਏ, ਚਾਹੇ ਪਤਾਲ ਵਿਚ ਲੁਕ ਜਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "Этими усилиями существо не освободится, даже если поднимется в небо или скроется в подземных мирах;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11707,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਬਿਆਪਹਿ ਮਾਇਆ ਜਾਲਿ ॥",
          "roman": "moh biāpeh māiā jāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਤੋਂ) ਬਚ ਨਹੀਂ ਸਕਦਾ, (ਸਗੋਂ) ਜੀਵ ਮਾਇਆ ਦੇ ਜਾਲ ਵਿਚ ਤੇ ਮੋਹ ਵਿਚ ਫਸਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "напротив, существа запутываются в сети майи и в привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11708,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਕਰਤੂਤਿ ਸਗਲੀ ਜਮੁ ਡਾਨੈ ॥",
          "roman": "avar kartūt saglī jam dānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਸਾਰੀਆਂ ਕਰਤੂਤਾਂ ਨੂੰ ਜਮਰਾਜ ਡੰਨ ਲਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Все прочие действия без Имени Ямараджа отвергает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11709,
          "is_rahao": false,
          "gurmukhi": "ਗੋਵਿੰਦ ਭਜਨ ਬਿਨੁ ਤਿਲੁ ਨਹੀ ਮਾਨੈ ॥",
          "roman": "Govind bhajan bin til nahī mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਭਜਨ ਤੋਂ ਬਿਨਾਂ ਰਤਾ ਭੀ ਨਹੀਂ ਪਤੀਜਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "без прославления Господа он не удовлетворяется даже на йоту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11710,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਪਤ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "har kā nām japat dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਮਨੁੱਖ) ਹਰਿ-ਨਾਮ ਉਚਾਰਦਾ ਹੈ ਉਸ ਦਾ ਦੁੱਖ (ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਿਆਂ) ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "У того, кто произносит Имя Хари, страдание исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11711,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬੋਲੈ ਸਹਜਿ ਸੁਭਾਇ ॥੪॥",
          "roman": "Nānak bolē sahaj subhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜਦੋਂ ਉਹ) ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ ਪ੍ਰੇਮ ਨਾਲ (ਹਰਿ-ਨਾਮ) ਉਚਾਰਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда он, пребывая в духовной устойчивости, с любовью произносит Имя Хари. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 894,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11712,
          "is_rahao": false,
          "gurmukhi": "ਚਾਰਿ ਪਦਾਰਥ ਜੇ ਕੋ ਮਾਗੈ ॥",
          "roman": "chār padārath jē ko māgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ (ਧਰਮ, ਅਰਥ, ਕਾਮ, ਮੋਖ) ਚਾਰ ਪਦਾਰਥਾਂ ਦਾ ਲੋੜਵੰਦ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то желает четырёх благ — дхармы, артхи, камы и мокши,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11713,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੀ ਸੇਵਾ ਲਾਗੈ ॥",
          "roman": "sādh janā kī sēvā lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਉਸ ਨੂੰ ਚਾਹੀਦਾ ਹੈ ਕਿ) ਗੁਰਮੁਖਾਂ ਦੀ ਸੇਵਾ ਵਿਚ ਲੱਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "пусть посвятит себя служению гурмухам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11714,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਆਪੁਨਾ ਦੂਖੁ ਮਿਟਾਵੈ ॥",
          "roman": "jē ko āpṇā dūkh miṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਆਪਣਾ ਦੁੱਖ ਮਿਟਾਣਾ ਚਾਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то хочет устранить своё страдание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11715,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਰਿਦੈ ਸਦ ਗਾਵੈ ॥",
          "roman": "har har nām ridē sad gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਦਾ ਹਿਰਦੇ ਵਿਚ ਸਿਮਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "пусть всегда хранит в сердце Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11716,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਅਪੁਨੀ ਸੋਭਾ ਲੋਰੈ ॥",
          "roman": "jē ko apunī sobhā lorē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਆਪਣੀ ਸੋਭਾ ਚਾਹੁੰਦਾ ਹੋਵੇ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то желает себе славы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11717,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਇਹ ਹਉਮੈ ਛੋਰੈ ॥",
          "roman": "sādhsang ih haumē chhorē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਸਤਸੰਗ ਵਿਚ (ਰਹਿ ਕੇ) ਇਸ ਹਉਮੈ ਦਾ ਤਿਆਗ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "пусть в сатсанге оставит эту Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11718,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਜਨਮ ਮਰਣ ਤੇ ਡਰੈ ॥",
          "roman": "jē ko janam maraṇ tē ḍarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਜਨਮ ਮਰਨ (ਦੇ ਗੇੜ) ਤੋਂ ਡਰਦਾ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то боится круга рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11719,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੀ ਸਰਨੀ ਪਰੈ ॥",
          "roman": "sādh janā kī sarnī parē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਹ ਸੰਤਾਂ ਦੀ ਚਰਨੀਂ ਲੱਗੇ।"
            },
            "sahib_singh_ru": {
              "main": "пусть припадёт к стопам святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11720,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਜਨ ਕਉ ਪ੍ਰਭ ਦਰਸ ਪਿਆਸਾ ॥",
          "roman": "jis jan kau prabh daras piāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਦੇ ਦੀਦਾਰ ਦੀ ਤਾਂਘ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, у которого есть жажда видения Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11721,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੈ ਬਲਿ ਬਲਿ ਜਾਸਾ ॥੫॥",
          "roman": "Nānak tā kē bal bal jāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ ਕਿ) ਮੈਂ ਉਸ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਵਾਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, скажи: я снова и снова отдаю себя ему. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 895,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11722,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਪੁਰਖ ਮਹਿ ਪੁਰਖੁ ਪ੍ਰਧਾਨੁ ॥",
          "roman": "sagal purakh mah purakh pradhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ) ਮਨੁੱਖ ਸਾਰੇ ਮਨੁੱਖਾਂ ਵਿਚੋਂ ਵੱਡਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек — величайший среди всех людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11723,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਾ ਕਾ ਮਿਟੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "sādhsang jā kā miṭē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤ ਸੰਗ ਵਿਚ (ਰਹਿ ਕੇ) ਜਿਸ ਮਨੁੱਖ ਦਾ ਅਹੰਕਾਰ ਮਿਟ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, чья гордыня исчезает в святом собрании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11724,
          "is_rahao": false,
          "gurmukhi": "ਆਪਸ ਕਉ ਜੋ ਜਾਣੈ ਨੀਚਾ ॥",
          "roman": "āpas kau jo jāṇē nīchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਆਪਣੇ ਆਪ ਨੂੰ (ਸਾਰਿਆਂ ਨਾਲੋਂ) ਮੰਦ-ਕਰਮੀ ਖ਼ਿਆਲ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто считает себя ниже всех и дурнее всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11725,
          "is_rahao": false,
          "gurmukhi": "ਸੋਊ ਗਨੀਐ ਸਭ ਤੇ ਊਚਾ ॥",
          "roman": "soū gaṇīai sabh tē ūchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਾਰਿਆਂ ਨਾਲੋਂ ਚੰਗਾ ਸਮਝਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "должен считаться выше всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11726,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਮਨੁ ਹੋਇ ਸਗਲ ਕੀ ਰੀਨਾ ॥",
          "roman": "jā kā man hoi sagal kī rīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਸਭਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਹੁੰਦਾ ਹੈ (ਭਾਵ, ਜੋ ਸਭ ਨਾਲ ਗਰੀਬੀ-ਸੁਭਾਉ ਵਰਤਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Тот, чей ум становится пылью у ног всех, то есть кто ведёт себя со всеми смиренно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11727,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਤਿਨਿ ਘਟਿ ਘਟਿ ਚੀਨਾ ॥",
          "roman": "har har nām tin ghaṭ ghaṭ chīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਪ੍ਰਭੂ ਦੀ ਸੱਤਾ ਪਛਾਣ ਲਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот распознал присутствие Господа в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11728,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਅਪੁਨੇ ਤੇ ਬੁਰਾ ਮਿਟਾਨਾ ॥",
          "roman": "man apunē tē burā miṭānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਆਪਣੇ ਮਨ ਵਿਚੋਂ ਬੁਰਾਈ ਮਿਟਾ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто устранил зло из собственного ума,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11729,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖੈ ਸਗਲ ਸ੍ਰਿਸਟਿ ਸਾਜਨਾ ॥",
          "roman": "pekhē sagal srisṭ sājnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ (ਦੇ ਜੀਵਾਂ ਨੂੰ ਆਪਣਾ) ਮਿਤ੍ਰ ਵੇਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "видит всю вселенную своими друзьями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11730,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਦੂਖ ਜਨ ਸਮ ਦ੍ਰਿਸਟੇਤਾ ॥",
          "roman": "sūkh dūkh jan sam drisṭētā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਜਿਹੇ) ਮਨੁੱਖ ਸੁਖਾਂ ਤੇ ਦੁਖਾਂ ਨੂੰ ਇਕੋ ਜਿਹਾ ਸਮਝਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Такие люди считают радость и страдание одинаковыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11731,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਪ ਪੁੰਨ ਨਹੀ ਲੇਪਾ ॥੬॥",
          "roman": "Nānak pāp puṇn nahī lēpā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਤਾਹੀਏਂ) ਪਾਪ ਤੇ ਪੁੰਨ ਦਾ ਉਹਨਾਂ ਉਤੇ ਅਸਰ ਨਹੀਂ ਹੁੰਦਾ (ਭਾਵ, ਨਾਹ ਕੋਈ ਮੰਦਾ ਕਰਮ ਉਹਨਾਂ ਦੇ ਮਨ ਨੂੰ ਫਸਾ ਸਕਦਾ ਹੈ, ਤੇ ਨਾਹ ਹੀ ਸੁਰਗ ਆਦਿਕ ਦਾ ਲਾਲਚ ਕਰ ਕੇ ਜਾਂ ਦੁੱਖ ਕਲੇਸ਼ ਤੋਂ ਡਰ ਕੇ ਉਹ ਪੁੰਨ ਕਰਮ ਕਰਦੇ ਹਨ, ਉਹਨਾਂ ਦਾ ਸੁਭਾਵ ਹੀ ਨੇਕੀ ਕਰਨਾ ਬਣ ਜਾਂਦਾ ਹੈ) ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и потому, о Нанак, грех и заслуга не прилипают к ним; ни дурное действие не связывает их ум, ни благочестивые дела они не совершают из жажды небес или страха перед бедой — добродетель становится их природой. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 896,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11732,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਧਨ ਕਉ ਧਨੁ ਤੇਰੋ ਨਾਉ ॥",
          "roman": "nirdhan kau dhan tēro nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ) ਕੰਗਾਲ ਵਾਸਤੇ ਤੇਰਾ ਨਾਮ ਹੀ ਧਨ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, для бедного Твоё Имя — богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11733,
          "is_rahao": false,
          "gurmukhi": "ਨਿਥਾਵੇ ਕਉ ਨਾਉ ਤੇਰਾ ਥਾਉ ॥",
          "roman": "nithāvē kau nāu tērā thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਆਸਰੇ ਨੂੰ ਤੇਰਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "для безопорного Твоё Имя — опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11734,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਾਨੇ ਕਉ ਪ੍ਰਭ ਤੇਰੋ ਮਾਨੁ ॥",
          "roman": "nimāṇē kau prabh tēro mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਮਾਣੇ ਵਾਸਤੇ ਤੇਰਾ (ਨਾਮ), ਹੇ ਪ੍ਰਭੂ! ਆਦਰ ਮਾਣ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для униженного, о Господь, Твоё Имя — честь и достоинство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11735,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕਉ ਦੇਵਹੁ ਦਾਨੁ ॥",
          "roman": "sagal ghaṭā kau dēvh dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਰੇ ਜੀਵਾਂ ਨੂੰ ਦਾਤਾਂ ਦੇਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты даруешь дары всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11736,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨਹਾਰ ਸੁਆਮੀ ॥",
          "roman": "karan karāvanhār suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪ ਹੀ ਸਭ ਕੁਝ ਕਰਦਾ ਹੈਂ, ਤੇ, ਆਪ ਹੀ ਕਰਾਉਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты Сам всё совершаешь и Сам побуждаешь к совершению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11737,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "sagal ghaṭā kē antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੁਆਮੀ! ਹੇ ਸਾਰੇ ਪ੍ਰਾਣੀਆਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О Владыка, Ты знаешь сердца всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11738,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਗਤਿ ਮਿਤਿ ਜਾਨਹੁ ਆਪੇ ॥",
          "roman": "apnī gat mit jānh āpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਆਪਣੀ ਹਾਲਤ ਤੇ ਆਪਣੀ (ਵਡਿਆਈ ਦੀ) ਮਰਯਾਦਾ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты Сам знаешь Своё состояние и меру Своего величия;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11739,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਸੰਗਿ ਆਪਿ ਪ੍ਰਭ ਰਾਤੇ ॥",
          "roman": "āpan sang āp prabh rātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਆਪਣੇ ਆਪ ਵਿਚ ਆਪ ਹੀ ਮਗਨ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты Сам погружён в Самого Себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11740,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮੑਰੀ ਉਸਤਤਿ ਤੁਮ ਤੇ ਹੋਇ ॥",
          "roman": "tumrī ustat tum tē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੇਰੀ ਵਡਿਆਈ ਤੈਥੋਂ ਹੀ (ਬਿਆਨ) ਹੋ ਸਕਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твоя хвала может быть высказана только Тобой Самим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11741,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਵਰੁ ਨ ਜਾਨਸਿ ਕੋਇ ॥੭॥",
          "roman": "Nānak avar na jānas koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ, ਕਿ) ਕੋਈ ਹੋਰ ਤੇਰੀ ਵਡਿਆਈ ਨਹੀਂ ਜਾਣਦਾ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, никто другой не знает Твоего величия. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 897,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11742,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਧਰਮ ਮਹਿ ਸ੍ਰੇਸਟ ਧਰਮੁ ॥",
          "roman": "sarab dharam mah sresṭ dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਇਹ ਧਰਮ ਸਾਰੇ ਧਰਮਾਂ ਨਾਲੋਂ ਚੰਗਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "О ум, эта дхарма лучше всех других дхарм:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11743,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੋ ਨਾਮੁ ਜਪਿ ਨਿਰਮਲ ਕਰਮੁ ॥",
          "roman": "har ko nām jap nirmal karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ (ਤੇ) ਪਵਿਤ੍ਰ ਆਚਰਣ (ਬਣਾ)।"
            },
            "sahib_singh_ru": {
              "main": "повторяй Имя Господа и делай своё поведение чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11744,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਕ੍ਰਿਆ ਮਹਿ ਊਤਮ ਕਿਰਿਆ ॥",
          "roman": "sagal kiriā mah ūtam kiriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਕੰਮ ਹੋਰ ਸਾਰੀਆਂ ਧਾਰਮਿਕ ਰਸਮਾਂ ਨਾਲੋਂ ਉੱਤਮ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Это действие выше всех прочих религиозных обрядов:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11745,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਦੁਰਮਤਿ ਮਲੁ ਹਿਰਿਆ ॥",
          "roman": "sādhsang durmat mal hiriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਸੰਗ ਵਿਚ (ਰਹਿ ਕੇ) ਭੈੜੀ ਮਤਿ (ਰੂਪ) ਮੈਲ ਦੂਰ ਕੀਤੀ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "в святом собрании устраняй грязь дурного ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11746,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਉਦਮ ਮਹਿ ਉਦਮੁ ਭਲਾ ॥",
          "roman": "sagal udam mah udam bhalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਉੱਦਮ (ਹੋਰ) ਸਾਰੇ ਉੱਦਮਾਂ ਨਾਲੋਂ ਭਲਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Это усилие лучше всех других усилий:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11747,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਪਹੁ ਜੀਅ ਸਦਾ ॥",
          "roman": "har kā nām japah jīa sadā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਸਦਾ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ।"
            },
            "sahib_singh_ru": {
              "main": "О ум, всегда повторяй Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11748,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਬਾਨੀ ਮਹਿ ਅੰਮ੍ਰਿਤ ਬਾਨੀ ॥",
          "roman": "sagal bānī mah amrit bānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ ਜਸ ਦੀ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਬਾਣੀ ਹੋਰ ਸਭ ਬਾਣੀਆਂ ਨਾਲੋਂ ਸੁੰਦਰ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "Среди всей речи та Бани, что даёт духовную жизнь, прекраснее всех прочих:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11749,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੋ ਜਸੁ ਸੁਨਿ ਰਸਨ ਬਖਾਨੀ ॥",
          "roman": "har ko jas sun rasan bakhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਜਸ (ਕੰਨਾਂ ਨਾਲ) ਸੁਣ (ਤੇ) ਜੀਭ ਨਾਲ ਬੋਲ।"
            },
            "sahib_singh_ru": {
              "main": "слушай славу Господа ушами и произноси её языком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11750,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਥਾਨ ਤੇ ਓਹੁ ਊਤਮ ਥਾਨੁ ॥",
          "roman": "sagal thān tē oh ūtam thān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਹਿਰਦਾ-ਰੂਪ) ਥਾਂ ਹੋਰ ਸਾਰੇ (ਤੀਰਥ) ਅਸਥਾਨਾਂ ਤੋਂ ਪਵਿਤ੍ਰ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "То место, подобное сердцу, чище всех прочих мест паломничества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11751,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਹ ਘਟਿ ਵਸੈ ਹਰਿ ਨਾਮੁ ॥੮॥੩॥",
          "roman": "Nānak jih ghaṭ vasē har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ ॥੮॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, в котором обитает Имя Господа. ॥8॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 898,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11752,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11753,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਗੁਨੀਆਰ ਇਆਨਿਆ ਸੋ ਪ੍ਰਭੁ ਸਦਾ ਸਮਾਲਿ ॥",
          "roman": "nirgunīār iāniā so prabh sadā samāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਞਾਣ! ਹੇ ਗੁਣ-ਹੀਨ (ਮਨੁੱਖ)! ਉਸ ਮਾਲਕ ਨੂੰ ਸਦਾ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О невежественный, о лишённый добродетелей человек, всегда помни того Владыку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11754,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕੀਆ ਤਿਸੁ ਚੀਤਿ ਰਖੁ ਨਾਨਕ ਨਿਬਹੀ ਨਾਲਿ ॥੧॥",
          "roman": "jin kīā tis chīt rakh Nānak nibahī nāl.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਨੇ ਤੈਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ, ਉਸ ਨੂੰ ਚਿੱਤ ਵਿਚ (ਪ੍ਰੋ) ਰੱਖ, ਉਹੀ (ਤੇਰੇ) ਨਾਲ ਸਾਥ ਨਿਬਾਹੇਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, держи в сердце Того, Кто создал тебя; только Он и будет с тобой до конца.1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 899,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11755,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11756,
          "is_rahao": false,
          "gurmukhi": "ਰਮਈਆ ਕੇ ਗੁਨ ਚੇਤਿ ਪਰਾਨੀ ॥",
          "roman": "ramaīā kē gun chet parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੀਵ! ਸੋਹਣੇ ਰਾਮ ਦੇ ਗੁਣ ਯਾਦ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О живое существо, вспоминай качества Прекрасного Рама,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11757,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਮੂਲ ਤੇ ਕਵਨ ਦ੍ਰਿਸਟਾਨੀ ॥",
          "roman": "kavan mūl tē kavan drishṭānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖ) ਕਿਸ ਮੁੱਢ ਤੋਂ (ਤੈਨੂੰ) ਕੇਹਾ (ਸੋਹਣਾ ਬਣਾ ਕੇ ਉਸ ਨੇ) ਵਿਖਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "посмотри, из какого истока и каким прекрасным образом Он явил тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11758,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਤੂੰ ਸਾਜਿ ਸਵਾਰਿ ਸੀਗਾਰਿਆ ॥",
          "roman": "jin tū̃ sāj savār sīgāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਬਣਾ ਸਵਾਰ ਕੇ ਸੋਹਣਾ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, Кто создал, украсил и сделал тебя прекрасным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11759,
          "is_rahao": false,
          "gurmukhi": "ਗਰਭ ਅਗਨਿ ਮਹਿ ਜਿਨਹਿ ਉਬਾਰਿਆ ॥",
          "roman": "garabh agan meh jinah ubāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਤੈਨੂੰ ਪੇਟ ਦੀ ਅੱਗ ਵਿਚ (ਭੀ) ਬਚਾਇਆ;"
            },
            "sahib_singh_ru": {
              "main": "Тот, Кто спас тебя даже в огне утробы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11760,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰ ਬਿਵਸਥਾ ਤੁਝਹਿ ਪਿਆਰੈ ਦੂਧ ॥",
          "roman": "bār bivasthā tujhah piārē dūdh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਬਾਲ ਉਮਰ ਵਿਚ ਤੈਨੂੰ ਦੁੱਧ ਪਿਆਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто в детском возрасте поит тебя молоком,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11761,
          "is_rahao": false,
          "gurmukhi": "ਭਰਿ ਜੋਬਨ ਭੋਜਨ ਸੁਖ ਸੂਧ ॥",
          "roman": "bhar joban bhojan sukh sūdh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਰ-ਜੁਆਨੀ ਵਿਚ ਭੋਜਨ ਤੇ ਸੁਖਾਂ ਦੀ ਸੂਝ (ਦੇਂਦਾ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "в расцвете юности даёт пищу и понимание наслаждений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11762,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਧਿ ਭਇਆ ਊਪਰਿ ਸਾਕ ਸੈਨ ॥ ਮੁਖਿ ਅਪਿਆਉ ਬੈਠ ਕਉ ਦੈਨ ॥",
          "roman": "biradh bhēā ūpar sāk sēn. mukh apiāu bēṭh kau dēn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਤੂੰ) ਬੁੱਢਾ ਹੋ ਜਾਂਦਾ ਹੈਂ (ਤਾਂ) ਸੇਵਾ ਕਰਨ ਨੂੰ ਸਾਕ-ਸੱਜਣ (ਤਿਆਰ ਕਰ ਦੇਂਦਾ ਹੈਂ) ਜੋ ਬੈਠੇ ਹੋਏ ਨੂੰ ਮੂੰਹ ਵਿਚ ਚੰਗੇ ਭੋਜਨ ਦੇਂਦੇ ਹਨ, (ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਚੇਤੇ ਕਰ)।"
            },
            "sahib_singh_ru": {
              "main": "а когда ты стареешь, готовит родных и близких для служения тебе, так что сидящему подают хорошую пищу прямо в рот, — помни того Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
