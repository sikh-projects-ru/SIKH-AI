{
  "ang": 267,
  "shabads": [
    {
      "shabad_id": 899,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11763,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਨਿਰਗੁਨੁ ਗੁਨੁ ਕਛੂ ਨ ਬੂਝੈ ॥",
          "roman": "ihu nirgun gun kachhū na būjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) (ਹੇ ਪ੍ਰਭੂ!) ਇਹ ਗੁਣ-ਹੀਣ ਜੀਵ (ਤੇਰਾ) ਕੋਈ ਉਪਕਾਰ ਨਹੀਂ ਸਮਝਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Но этот лишённый добродетелей человек не понимает ни одного Твоего благодеяния,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11764,
          "is_rahao": false,
          "gurmukhi": "ਬਖਸਿ ਲੇਹੁ ਤਉ ਨਾਨਕ ਸੀਝੈ ॥੧॥",
          "roman": "bakhas leh tau Nānak sījhē.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ) (ਜੇ) ਤੂੰ ਆਪਿ ਮੇਹਰ ਕਰੇਂ, ਤਾਂ (ਇਹ ਜਨਮ-ਮਨੋਰਥ ਵਿਚ) ਸਫਲ ਹੋਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: если Ты Сам даруешь милость, тогда он достигнет успеха в цели человеческой жизни.1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 900,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11765,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਧਰ ਊਪਰਿ ਸੁਖਿ ਬਸਹਿ ॥",
          "roman": "jih prasād dhar ūpar sukh baseh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੀਵ!) ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਧਰਤੀ ਉਤੇ ਸੁਖੀ ਵੱਸਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О живое существо, по милости Того, благодаря Кому ты счастливо живёшь на земле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11766,
          "is_rahao": false,
          "gurmukhi": "ਸੁਤ ਭ੍ਰਾਤ ਮੀਤ ਬਨਿਤਾ ਸੰਗਿ ਹਸਹਿ ॥",
          "roman": "sut bhrāt mīt banitā sang haseh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੁਤ੍ਰ ਭਰਾ ਮਿਤ੍ਰ ਇਸਤ੍ਰੀ ਨਾਲ ਹੱਸਦਾ ਹੈਂ;"
            },
            "sahib_singh_ru": {
              "main": "ты смеёшься вместе с сыном, братом, другом и женой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11767,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਪੀਵਹਿ ਸੀਤਲ ਜਲਾ ॥",
          "roman": "jih prasād pīveh sītal jalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਤੂੰ ਠੰਢਾ ਪਾਣੀ ਪੀਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "по Его милости ты пьёшь прохладную воду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11768,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖਦਾਈ ਪਵਨੁ ਪਾਵਕੁ ਅਮੁਲਾ ॥",
          "roman": "sukhdāī pavan pāvak amulā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਖ ਦੇਣ ਵਾਲੀ ਹਵਾ ਤੇ ਅਮੋਲਕ ਅੱਗ (ਵਰਤਦਾ ਹੈਂ);"
            },
            "sahib_singh_ru": {
              "main": "пользуешься дающим облегчение воздухом и драгоценным огнём,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11769,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਭੋਗਹਿ ਸਭਿ ਰਸਾ ॥",
          "roman": "jih prasād bhogeh sabh rasā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸਾਰੇ ਰਸ ਭੋਗਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "по Его милости вкушаешь все наслаждения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11770,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਸੰਗਿ ਸਾਥਿ ਬਸਾ ॥",
          "roman": "sagal samagrī sang sāth basā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਪਦਾਰਥਾਂ ਦੇ ਨਾਲ ਤੂੰ ਰਹਿੰਦਾ ਹੈਂ (ਭਾਵ, ਸਾਰੇ ਪਦਾਰਥ ਵਰਤਣ ਲਈ ਤੈਨੂੰ ਮਿਲਦੇ ਹਨ);"
            },
            "sahib_singh_ru": {
              "main": "живёшь среди всех предметов и благ, то есть всё это даётся тебе для пользования,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11771,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨੇ ਹਸਤ ਪਾਵ ਕਰਨ ਨੇਤ੍ਰ ਰਸਨਾ ॥",
          "roman": "dīnē hast pāv karan nētr rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੇ) ਤੈਨੂੰ ਹੱਥ ਪੈਰ ਕੰਨ ਅੱਖਾਂ ਜੀਭ ਦਿੱਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Он дал тебе руки, ноги, уши, глаза и язык,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11772,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਤਿਆਗਿ ਅਵਰ ਸੰਗਿ ਰਚਨਾ ॥",
          "roman": "tiseh tiāg avar sang rachnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਪ੍ਰਭੂ) ਨੂੰ ਵਿਸਾਰ ਕੇ (ਹੇ ਜੀਵ!) ਤੂੰ ਹੋਰਨਾਂ ਨਾਲ ਮਗਨ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "но, забыв Его, ты увлечён другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11773,
          "is_rahao": false,
          "gurmukhi": "ਐਸੇ ਦੋਖ ਮੂੜ ਅੰਧ ਬਿਆਪੇ ॥",
          "roman": "aise dokh mūṛh andh biāpe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ) ਮੂਰਖ ਅੰਨ੍ਹੇ ਜੀਵ (ਭਲਾਈ ਵਿਸਾਰਨ ਵਾਲੇ) ਇਹੋ ਜਿਹੇ ਔਗੁਣਾਂ ਵਿਚ ਫਸੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Такие пороки овладели этими глупыми и слепыми существами, забывающими добро."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11774,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਾਢਿ ਲੇਹੁ ਪ੍ਰਭ ਆਪੇ ॥੨॥",
          "roman": "Nānak kāḍh leh prabh āpe.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਹਨਾਂ ਜੀਵਾਂ ਵਾਸਤੇ ਅਰਦਾਸ ਕਰ, ਤੇ ਆਖ)-ਹੇ ਪ੍ਰਭੂ! (ਇਹਨਾਂ ਨੂੰ) ਆਪ (ਇਹਨਾਂ ਔਗੁਣਾਂ ਵਿਚੋਂ) ਕੱਢ ਲੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись за этих существ и говори: о Бог, Сам выведи их из этих пороков.2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 901,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11775,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਅੰਤਿ ਜੋ ਰਾਖਨਹਾਰੁ ॥",
          "roman": "ād ant jo rākhanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਇਸ ਦੇ) ਜਨਮ ਤੋਂ ਲੈ ਕੇ ਮਰਨ ਸਮੇਂ ਤਕ (ਇਸ ਦੀ) ਰਾਖੀ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, Кто хранит его от рождения до самой смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11776,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਸਿਉ ਪ੍ਰੀਤਿ ਨ ਕਰੈ ਗਵਾਰੁ ॥",
          "roman": "tis siu prīt na karē gavār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਪਿਆਰ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "с Тем не любит связываться глупый человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11777,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਸੇਵਾ ਨਵ ਨਿਧਿ ਪਾਵੈ ॥",
          "roman": "jā kī sēvā nav nidh pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਸੇਵਾ ਕੀਤਿਆਂ (ਇਸ ਨੂੰ ਸ੍ਰਿਸ਼ਟੀ ਦੇ) ਨੌ ਹੀ ਖ਼ਜ਼ਾਨੇ ਮਿਲ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Служением Кому обретаются все девять сокровищ мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11778,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਸਿਉ ਮੂੜਾ ਮਨੁ ਨਹੀ ਲਾਵੈ ॥",
          "roman": "tā siu mūṛā man nahī lāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਜੀਵ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਚਿੱਤ ਨਹੀਂ ਜੋੜਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "с Тем глупое существо не соединяет своё сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11779,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਠਾਕੁਰੁ ਸਦ ਸਦਾ ਹਜੂਰੇ ॥",
          "roman": "jo ṭhākur sad sadā hajūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਹਰ ਵੇਲੇ ਇਸ ਦੇ ਅੰਗ-ਸੰਗ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Владыка, Кто всегда и во всякое время рядом с ним,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11780,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਅੰਧਾ ਜਾਨਤ ਦੂਰੇ ॥",
          "roman": "tā kau andhā jānat dūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹਾ ਮਨੁੱਖ ਉਸ ਠਾਕੁਰ ਨੂੰ (ਕਿਤੇ) ਦੂਰ (ਬੈਠਾ) ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "слепой человек считает сидящим где-то далеко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11781,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਟਹਲ ਪਾਵੈ ਦਰਗਹ ਮਾਨੁ ॥",
          "roman": "jā kī ṭahal pāvē dargah mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਟਹਲ ਕੀਤਿਆਂ ਇਸ ਨੂੰ (ਪ੍ਰਭੂ ਦੀ) ਦਰਗਾਹ ਵਿਚ ਆਦਰ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Служением Кому он получает честь в Божественном дворе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11782,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਬਿਸਾਰੈ ਮੁਗਧੁ ਅਜਾਨੁ ॥",
          "roman": "tiseh bisārē mugadh ajān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਤੇ ਅੰਞਾਣ ਜੀਵ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਵਿਸਾਰ ਬੈਠਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того Бога забывает глупое и невежественное существо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11783,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਇਹੁ ਭੂਲਨਹਾਰੁ ॥",
          "roman": "sadā sadā ihu bhūlanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਕੇਹੜਾ ਕੇਹੜਾ ਔਗੁਣ ਚਿਤਾਰੀਏ?) ਇਹ ਜੀਵ (ਤਾਂ) ਸਦਾ ਹੀ ਭੁੱਲਾਂ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Но какие пороки все перечислить? Это существо постоянно ошибается;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11784,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਖਨਹਾਰੁ ਅਪਾਰੁ ॥੩॥",
          "roman": "Nānak rākhanhār apār.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਰੱਖਿਆ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਬੇਅੰਤ ਹੈ (ਉਹ ਇਸ ਜੀਵ ਦੇ ਔਗੁਣਾਂ ਵਲ ਨਹੀਂ ਤੱਕਦਾ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Хранитель безграничен, и Он не смотрит на пороки этого существа.3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 902,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11785,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨੁ ਤਿਆਗਿ ਕਉਡੀ ਸੰਗਿ ਰਚੈ ॥",
          "roman": "ratan tiāg kauṛī sang rachē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ-ਧਾਰੀ ਜੀਵ) (ਨਾਮ-) ਰਤਨ ਛੱਡ ਕੇ (ਮਾਇਆ-ਰੂਪ) ਕਉਡੀ ਨਾਲ ਖ਼ੁਸ਼ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Одержимый майей человек оставляет драгоценность Имени и радуется дешёвой ракушке майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11786,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੁ ਛੋਡਿ ਝੂਠ ਸੰਗਿ ਮਚੈ ॥",
          "roman": "sāch chhoḍ jhūṭh sang machē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੱਚੇ (ਪ੍ਰਭੂ) ਨੂੰ ਛੱਡ ਕੇ ਨਾਸਵੰਤ (ਪਦਾਰਥਾਂ) ਨਾਲ ਭੂਹੇ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Оставив Истинного Бога, он кипит в увлечении тленными вещами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11787,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਛਡਨਾ ਸੁ ਅਸਥਿਰੁ ਕਰਿ ਮਾਨੈ ॥",
          "roman": "jo chhaḍnā so asthir kar mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਮਾਇਆ) ਛੱਡ ਜਾਣੀ ਹੈ, ਉਸ ਨੂੰ ਸਦਾ ਅਟੱਲ ਸਮਝਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "То, что придётся оставить, он считает вечным и неизменным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11788,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਹੋਵਨੁ ਸੋ ਦੂਰਿ ਪਰਾਨੈ ॥",
          "roman": "jo hovan so dūr parānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਮੌਤ) ਜ਼ਰੂਰ ਵਾਪਰਨੀ ਹੈ, ਉਸ ਨੂੰ (ਕਿਤੇ) ਦੂਰ (ਬੈਠੀ) ਖ਼ਿਆਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а то, что непременно случится, то есть смерть, считает чем-то далёким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11789,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਜਾਇ ਤਿਸ ਕਾ ਸ੍ਰਮੁ ਕਰੈ ॥",
          "roman": "chhoḍ jāi tis kā sram karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਧਨ ਪਦਾਰਥ) ਦੀ ਖ਼ਾਤਰ (ਨਿੱਤ) ਖੇਚਲ ਕਰਦਾ (ਫਿਰਦਾ) ਹੈ ਜੋ (ਅੰਤ) ਛੱਡ ਜਾਣੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно хлопочет ради того богатства и вещей, которые в конце придётся оставить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11790,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਸਹਾਈ ਤਿਸੁ ਪਰਹਰੈ ॥",
          "roman": "sang sahāī tis parharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਪ੍ਰਭੂ) (ਇਸ) ਨਾਲ ਰਾਖਾ ਹੈ ਉਸ ਨੂੰ ਵਿਸਾਰ ਬੈਠਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а Того, Кто является его Защитником и спутником, забывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11791,
          "is_rahao": false,
          "gurmukhi": "ਚੰਦਨ ਲੇਪੁ ਉਤਾਰੈ ਧੋਇ ॥",
          "roman": "chandan lēp utārē dhoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਖੋਤਾ) ਚੰਦਨ ਦਾ ਲੇਪ ਧੋ ਕੇ ਲਾਹ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как осёл смывает и счищает с себя сандаловую мазь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11792,
          "is_rahao": false,
          "gurmukhi": "ਗਰਧਬ ਪ੍ਰੀਤਿ ਭਸਮ ਸੰਗਿ ਹੋਇ ॥",
          "roman": "gardhab prīt bhasam sang hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਖੋਤੇ ਦਾ ਪਿਆਰ (ਸਦਾ) ਸੁਆਹ ਨਾਲ (ਹੀ) ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что любовь осла всегда к пеплу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11793,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਕੂਪ ਮਹਿ ਪਤਿਤ ਬਿਕਰਾਲ ॥",
          "roman": "andh kūp meh patit bikrāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਮਾਇਆ ਦੇ ਪਿਆਰ ਕਰ ਕੇ) ਹਨੇਰੇ ਭਿਆਨਕ ਖੂਹ ਵਿਚ ਡਿੱਗੇ ਪਏ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "так и существа из-за любви к майе лежат упавшими в тёмном и страшном колодце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11794,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਾਢਿ ਲੇਹੁ ਪ੍ਰਭ ਦਇਆਲ ॥੪॥",
          "roman": "Nānak kāḍh leh prabh daiāl.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ) ਹੇ ਦਿਆਲ ਪ੍ਰਭੂ! (ਇਹਨਾਂ ਨੂੰ ਆਪ ਇਸ ਖੂਹ ਵਿਚੋਂ) ਕੱਢ ਲੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись и говори: о Милостивый Бог, Сам выведи их из этого колодца.4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 903,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11795,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤੂਤਿ ਪਸੂ ਕੀ ਮਾਨਸ ਜਾਤਿ ॥",
          "roman": "kartūt pasū kī mānas jāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਾਤਿ ਮਨੁੱਖ ਦੀ ਹੈ (ਭਾਵ, ਮਨੁੱਖ-ਸ਼੍ਰੇਣੀ ਵਿਚੋਂ ਜੰਮਿਆ ਹੈ) ਪਰ ਕੰਮ ਪਸ਼ੂਆਂ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По рождению он человек, то есть родился в человеческом виде, но дела у него животные,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11796,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕ ਪਚਾਰਾ ਕਰੈ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "lok pachārā karē din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਂਞ) ਦਿਨ ਰਾਤ ਲੋਕਾਂ ਵਾਸਤੇ ਵਿਖਾਵਾ ਕਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё же день и ночь он устраивает показуху перед людьми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11797,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਭੇਖ ਅੰਤਰਿ ਮਲੁ ਮਾਇਆ ॥",
          "roman": "bāhar bhekh antar mal māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਹਰ (ਸਰੀਰ ਉਤੇ) ਧਾਰਮਿਕ ਪੁਸ਼ਾਕ ਹੈ ਪਰ ਮਨ ਵਿਚ ਮਾਇਆ ਦੀ ਮੈਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Снаружи на теле у него религиозное одеяние, а внутри ума — грязь майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11798,
          "is_rahao": false,
          "gurmukhi": "ਛਪਸਿ ਨਾਹਿ ਕਛੁ ਕਰੈ ਛਪਾਇਆ ॥",
          "roman": "chhapas nāh kachh karē chhapāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬਾਹਰਲੇ ਭੇਖ ਨਾਲ) ਛਪਾਉਣ ਦਾ ਜਤਨ ਕੀਤਿਆਂ (ਮਨ ਦੀ ਮੈਲ) ਲੁਕਦੀ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "и сколько ни пытайся это скрыть внешним видом, внутренняя нечистота не скрывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11799,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਗਿਆਨ ਧਿਆਨ ਇਸਨਾਨ ॥",
          "roman": "bāhar giān dhiān isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਹਰ (ਵਿਖਾਵੇ ਵਾਸਤੇ) (ਤੀਰਥ) ਇਸ਼ਨਾਨ ਤੇ ਗਿਆਨ ਦੀਆਂ ਗੱਲਾਂ ਕਰਦਾ ਹੈ, ਸਮਾਧੀਆਂ ਭੀ ਲਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Снаружи, напоказ, он говорит о знании, совершает омовения и даже входит в медитации,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11800,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਿਆਪੈ ਲੋਭੁ ਸੁਆਨੁ ॥",
          "roman": "antar biāpē lobh suān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮਨ ਵਿਚ ਲੋਭ (-ਰੂਪ) ਕੁੱਤਾ ਜ਼ੋਰ ਪਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но внутри ума с силой действует пёс-жадность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11801,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਅਗਨਿ ਬਾਹਰਿ ਤਨੁ ਸੁਆਹ ॥",
          "roman": "antar agan bāhar tan suāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ (ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਹੈ, ਬਾਹਰ ਸਰੀਰ ਸੁਆਹ (ਨਾਲ ਲਿਬੇੜਿਆ ਹੋਇਆ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Внутри ума горит огонь жажды, а снаружи тело обмазано пеплом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11802,
          "is_rahao": false,
          "gurmukhi": "ਗਲਿ ਪਾਥਰ ਕੈਸੇ ਤਰੈ ਅਥਾਹ ॥",
          "roman": "gal pāthar kēse tarē athāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ) ਗਲ ਵਿਚ (ਵਿਕਾਰਾਂ ਦੇ) ਪੱਥਰ (ਹੋਣ ਤਾਂ) ਅਥਾਹ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਨੂੰ ਜੀਵ) ਕਿਵੇਂ ਤਰੇ?"
            },
            "sahib_singh_ru": {
              "main": "и если на шее висят камни пороков, как существу переплыть бездонный мирской океан?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11803,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਅੰਤਰਿ ਬਸੈ ਪ੍ਰਭੁ ਆਪਿ ॥",
          "roman": "jā kē antar basē prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В чьё сердце Сам Бог поселяется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11804,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇ ਜਨ ਸਹਜਿ ਸਮਾਤਿ ॥੫॥",
          "roman": "Nānak tē jan sahaj samāt.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹੀ ਅਡੋਲ ਅਵਸਥਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только те люди пребывают в естественной устойчивой уравновешенности.5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 904,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11805,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਅੰਧਾ ਕੈਸੇ ਮਾਰਗੁ ਪਾਵੈ ॥",
          "roman": "sun andhā kēse mārag pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹਾ ਮਨੁੱਖ (ਨਿਰਾ) ਸੁਣ ਕੇ ਕਿਵੇਂ ਰਾਹ ਲੱਭ ਲਏ?"
            },
            "sahib_singh_ru": {
              "main": "Как слепой человек, лишь услышав, найдёт путь?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11806,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਗਹਿ ਲੇਹੁ ਓੜਿ ਨਿਬਹਾਵੈ ॥",
          "roman": "kar gah leh oṛ nibhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਆਪ ਇਸ ਦਾ) ਹੱਥ ਫੜ ਲਵੋ (ਤਾਕਿ ਇਹ) ਅਖ਼ੀਰ ਤਕ (ਪ੍ਰੀਤ) ਨਿਬਾਹ ਸਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "О Бог, Сам возьми его за руку, чтобы он смог сохранить верность до конца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11807,
          "is_rahao": false,
          "gurmukhi": "ਕਹਾ ਬੁਝਾਰਤਿ ਬੂਝੈ ਡੋਰਾ ॥",
          "roman": "kahā bujhārat būjhē ḍorā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੋਲਾ ਮਨੁੱਖ (ਨਿਰੀ) ਸੈਨਤ ਨੂੰ ਕੀਹ ਸਮਝੇ?"
            },
            "sahib_singh_ru": {
              "main": "Что поймёт немой человек из одного только знака?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11808,
          "is_rahao": false,
          "gurmukhi": "ਨਿਸਿ ਕਹੀਐ ਤਉ ਸਮਝੈ ਭੋਰਾ ॥",
          "roman": "nis kahīē tau samjhē bhorā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੈਨਤ ਨਾਲ ਜੇ) ਆਖੀਏ (ਇਹ) ਰਾਤ ਹੈ ਤਾਂ ਉਹ ਸਮਝ ਲੈਂਦਾ ਹੈ (ਇਹ) ਦਿਨ (ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Если знаком показать, что сейчас ночь, он поймёт, что это день."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11809,
          "is_rahao": false,
          "gurmukhi": "ਕਹਾ ਬਿਸਨਪਦ ਗਾਵੈ ਗੁੰਗ ॥",
          "roman": "kahā bisanpad gāvē guṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੂੰਗਾ ਕਿਵੇਂ ਬਿਸ਼ਨ-ਪਦੇ ਗਾ ਸਕੇ?"
            },
            "sahib_singh_ru": {
              "main": "Как немой сможет петь гимны Бишну?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11810,
          "is_rahao": false,
          "gurmukhi": "ਜਤਨ ਕਰੈ ਤਉ ਭੀ ਸੁਰ ਭੰਗ ॥",
          "roman": "jatan karē tau bhī sur bhang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਈ) ਜਤਨ (ਭੀ) ਕਰੇ ਤਾਂ ਭੀ ਉਸ ਦੀ ਸੁਰ ਟੁੱਟੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Даже если будет стараться, его мелодия всё равно останется сломанной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11811,
          "is_rahao": false,
          "gurmukhi": "ਕਹ ਪਿੰਗੁਲ ਪਰਬਤ ਪਰ ਭਵਨ ॥",
          "roman": "kah piṅgul parbat par bhavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲੂਲ੍ਹਾ ਕਿਥੇ ਪਹਾੜਾਂ ਤੇ ਭਉਂ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Где хромой сможет ходить по горам?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11812,
          "is_rahao": false,
          "gurmukhi": "ਨਹੀ ਹੋਤ ਊਹਾ ਉਸੁ ਗਵਨ ॥",
          "roman": "nahī hot ūhā us gavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਥੇ ਉਸ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Туда он не может добраться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11813,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤਾਰ ਕਰੁਣਾ ਮੈ ਦੀਨੁ ਬੇਨਤੀ ਕਰੈ ॥",
          "roman": "kartār karuṇā mē dīn bēntī karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਰਤਾਰ! ਹੇ ਦਇਆ ਦੇ ਸਾਗਰ! (ਇਹ) ਨਿਮਾਣਾ ਦਾਸ ਬੇਨਤੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Творец, о Океан милости, этот смиренный раб молится,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11814,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੁਮਰੀ ਕਿਰਪਾ ਤਰੈ ॥੬॥",
          "roman": "Nānak tumrī kirpā tarē.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਹਾਲਤ ਵਿਚ ਕੇਵਲ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ) ਤੇਰੀ ਮੇਹਰ ਨਾਲ (ਹੀ) ਤਰ ਸਕਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только по Твоей милости он может переправиться.6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 905,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11815,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਸਹਾਈ ਸੁ ਆਵੈ ਨ ਚੀਤਿ ॥",
          "roman": "sang sahāī su āvē na chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪ੍ਰਭੂ (ਇਸ ਮੂਰਖ ਦਾ) ਸੰਗੀ ਸਾਥੀ ਹੈ, ਉਸ ਨੂੰ (ਇਹ) ਚੇਤੇ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Того Бога, Кто является спутником и помощником этого глупца, он не вспоминает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11816,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਬੈਰਾਈ ਤਾ ਸਿਉ ਪ੍ਰੀਤਿ ॥",
          "roman": "jo bērāī tā siu prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜੋ ਵੈਰੀ ਹੈ ਉਸ ਨਾਲ ਪਿਆਰ ਕਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а любит того, кто ему враг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11817,
          "is_rahao": false,
          "gurmukhi": "ਬਲੂਆ ਕੇ ਗ੍ਰਿਹ ਭੀਤਰਿ ਬਸੈ ॥",
          "roman": "balūā kē grih bhītar basē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੇਤ ਦੇ ਘਰ ਵਿਚ ਵੱਸਦਾ ਹੈ (ਭਾਵ ਰੇਤ ਦੇ ਕਿਣਕਿਆਂ ਵਾਂਗ ਉਮਰ ਛਿਨ ਛਿਨ ਕਰ ਕੇ ਕਿਰ ਰਹੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Он живёт в доме из песка, то есть жизнь его сыплется по крупицам, как песчинки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11818,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਕੇਲ ਮਾਇਆ ਰੰਗਿ ਰਸੈ ॥",
          "roman": "anad kēl māiā rang rasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ ਭੀ) ਮਾਇਆ ਦੀ ਮਸਤੀ ਵਿਚ ਆਨੰਦ ਮੌਜਾਂ ਮਾਣ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё же в опьянении майей наслаждается весельем и играми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11819,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿੜੁ ਕਰਿ ਮਾਨੈ ਮਨਹਿ ਪ੍ਰਤੀਤਿ ॥",
          "roman": "driṛh kar mānē manah pratīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੇ ਆਪ ਨੂੰ) ਅਮਰ ਸਮਝੀ ਬੈਠਾ ਹੈ, ਮਨ ਵਿਚ (ਇਹੀ) ਯਕੀਨ ਬਣਿਆ ਹੋਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Он сидит, считая себя бессмертным, и в уме у него крепко утвердилось именно это убеждение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11820,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੁ ਨ ਆਵੈ ਮੂੜੇ ਚੀਤਿ ॥",
          "roman": "kāl na āvē mūṛē chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੂਰਖ ਦੇ ਚਿਤ ਵਿਚ (ਕਦੇ) ਮੌਤ (ਦਾ ਖ਼ਿਆਲ ਭੀ) ਨਹੀਂ ਆਉਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "но мысль о смерти никогда не приходит в сердце глупца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11821,
          "is_rahao": false,
          "gurmukhi": "ਬੈਰ ਬਿਰੋਧ ਕਾਮ ਕ੍ਰੋਧ ਮੋਹ ॥",
          "roman": "bēr biroDh kām kroDh moh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੈਰ ਵਿਰੋਧ, ਕਾਮ, ਗੁੱਸਾ, ਮੋਹ,"
            },
            "sahib_singh_ru": {
              "main": "Вражда, противостояние, похоть, гнев, привязанность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11822,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠ ਬਿਕਾਰ ਮਹਾ ਲੋਭ ਧ੍ਰੋਹ ॥",
          "roman": "jhūṭh bikār mahā lobh dhroh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਝੂਠ, ਮੰਦੇ ਕਰਮ, ਭਾਰੀ ਲਾਲਚ ਤੇ ਦਗ਼ਾ-"
            },
            "sahib_singh_ru": {
              "main": "ложь, дурные поступки, великая жадность и обман —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
