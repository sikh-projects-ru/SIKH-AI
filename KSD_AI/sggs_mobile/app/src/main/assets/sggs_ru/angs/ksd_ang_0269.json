{
  "ang": 269,
  "shabads": [
    {
      "shabad_id": 912,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11880,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਨੇਤ੍ਰ ਪੇਖਤ ਪਰ ਤ੍ਰਿਅ ਰੂਪਾਦ ॥",
          "roman": "mithiā netr pekhat par tri-a rūpād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖਾਂ ਵਿਅਰਥ ਹਨ (ਜੋ ਇਹ) ਪਰਾਈ ਜ਼ਨਾਨੀ ਦਾ ਰੂਪ ਤੱਕਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Глаза тщетны, если они смотрят на красоту чужой женщины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11881,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਰਸਨਾ ਭੋਜਨ ਅਨ ਸ੍ਵਾਦ ॥",
          "roman": "mithiā rasnā bhojan an svād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਵਿਅਰਥ ਹੈ (ਜੇ ਇਹ) ਖਾਣੇ ਤੇ ਹੋਰ ਸੁਆਦਾਂ ਵਿਚ (ਲੱਗੀ ਹੋਈ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Язык тщетен, если он погружён в пищу и прочие вкусы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11882,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਚਰਨ ਪਰ ਬਿਕਾਰ ਕਉ ਧਾਵਹਿ ॥",
          "roman": "mithiā charan par bikār kau dhāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੈਰ ਵਿਅਰਥ ਹਨ (ਜੇ ਇਹ) ਪਰਾਏ ਨੁਕਸਾਨ ਵਾਸਤੇ ਦੌੜ-ਭੱਜ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Ноги тщетны, если они бегут причинять вред другому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11883,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਮਨ ਪਰ ਲੋਭ ਲੁਭਾਵਹਿ ॥",
          "roman": "mithiā man par lobh lubhāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੂੰ ਭੀ ਵਿਅਰਥ ਹੈਂ (ਜੇ ਤੂੰ) ਪਰਾਏ ਧਨ ਦਾ ਲੋਭ ਕਰ ਰਿਹਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О ум, и ты тщетен, если соблазняешься чужим богатством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11884,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਤਨ ਨਹੀ ਪਰਉਪਕਾਰਾ ॥",
          "roman": "mithiā tan nahī par-upkārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ) ਸਰੀਰ ਵਿਅਰਥ ਹਨ ਜੋ ਦੂਜਿਆਂ ਨਾਲ ਭਲਾਈ ਨਹੀਂ ਕਰਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Тщетно то тело, которое не делает добра другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11885,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਬਾਸੁ ਲੇਤ ਬਿਕਾਰਾ ॥",
          "roman": "mithiā bās let bikārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨੱਕ) ਵਿਅਰਥ ਹੈ (ਜੋ) ਵਿਕਾਰਾਂ ਦੀ ਵਾਸ਼ਨਾ ਲੈ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тщетен и нос, если он вдыхает запах порока."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11886,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਬੂਝੇ ਮਿਥਿਆ ਸਭ ਭਏ ॥",
          "roman": "bin būjhe mithiā sabh bhae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪੋ ਆਪਣੀ ਹੋਂਦ ਦਾ ਮਨੋਰਥ) ਸਮਝਣ ਤੋਂ ਬਿਨਾ (ਇਹ) ਸਾਰੇ (ਅੰਗ) ਵਿਅਰਥ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Не поняв назначения собственного бытия, все эти члены оказываются тщетными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11887,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਦੇਹ ਨਾਨਕ ਹਰਿ ਹਰਿ ਨਾਮ ਲਏ ॥੫॥",
          "roman": "safal deh Nānak har har nām lae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸਰੀਰ ਸਫਲ ਹੈ ਜੋ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, плодотворно лишь то тело, которое повторяет Имя Бога. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 913,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11888,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥੀ ਸਾਕਤ ਕੀ ਆਰਜਾ ॥",
          "roman": "birthī sākat kī ārjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰੱਬ ਨਾਲੋਂ) ਟੁੱਟੇ ਹੋਏ ਮਨੁੱਖ ਦੀ ਉਮਰ ਵਿਅਰਥ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Жизнь человека, оторванного от Бога, проходит напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11889,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਬਿਨਾ ਕਹ ਹੋਵਤ ਸੂਚਾ ॥",
          "roman": "sāch binā kah hovat sūchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸੱਚੇ ਪ੍ਰਭੂ (ਦੇ ਨਾਮ) ਤੋਂ ਬਿਨਾ ਉਹ ਕਿਵੇਂ ਸੁੱਚਾ ਹੋ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Ибо как он может стать чистым без Истинного Бога и Его Имени?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11890,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥਾ ਨਾਮ ਬਿਨਾ ਤਨੁ ਅੰਧ ॥",
          "roman": "birthā nām binā tan andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਤੋਂ ਬਿਨਾ ਅੰਨ੍ਹੇ (ਸਾਕਤ) ਦਾ ਸਰੀਰ (ਹੀ) ਕਿਸੇ ਕੰਮ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Без Имени даже тело слепого саката ни на что не годно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11891,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖਿ ਆਵਤ ਤਾ ਕੈ ਦੁਰਗੰਧ ॥",
          "roman": "mukh āvat tā kē durgandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਸ ਦੇ ਮੂੰਹ ਵਿਚੋਂ (ਨਿੰਦਾ ਆਦਿਕ) ਬਦ-ਬੂ ਆਉਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что из его уст исходит зловоние, вроде клеветы и прочего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11892,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਿਮਰਨ ਦਿਨੁ ਰੈਨਿ ਬ੍ਰਿਥਾ ਬਿਹਾਇ ॥",
          "roman": "bin simran din rēn brithā bihāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਵਰਖਾ ਤੋਂ ਬਿਨਾ ਪੈਲੀ ਨਿਸਫਲ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Без симрана дни и ночи проходят бесплодно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11893,
          "is_rahao": false,
          "gurmukhi": "ਮੇਘ ਬਿਨਾ ਜਿਉ ਖੇਤੀ ਜਾਇ ॥",
          "roman": "megh binā jiu khetī jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਵੇਂ) ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ (ਸਾਕਤ ਦੇ) ਦਿਨ ਰਾਤ ਅੱਫਲ ਚਲੇ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "как гибнет посев без дождя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11894,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿਦ ਭਜਨ ਬਿਨੁ ਬ੍ਰਿਥੇ ਸਭ ਕਾਮ ॥",
          "roman": "Gobid bhajan bin brithe sabh kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਭਜਨ ਤੋਂ ਸੱਖਣਾ ਰਹਿਣ ਕਰਕੇ (ਮਨੁੱਖ ਦੇ) ਸਾਰੇ ਹੀ ਕੰਮ ਕਿਸੇ ਅਰਥ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Без бхаджана Гобинда все дела человека лишены смысла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11895,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਕਿਰਪਨ ਕੇ ਨਿਰਾਰਥ ਦਾਮ ॥",
          "roman": "jiu kirpan ke nirārath dām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਇਹ ਕੰਮ ਇਸ ਦਾ ਆਪਣਾ ਕੁਝ ਨਹੀਂ ਸਵਾਰਦੇ) ਜਿਵੇਂ ਕੰਜੂਸ ਦਾ ਧਨ ਉਸ ਦੇ ਆਪਣੇ ਕਿਸੇ ਕੰਮ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Они ничего в нём самом не исправляют, как богатство скупца не служит ему ни в чём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11896,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨਿ ਧੰਨਿ ਤੇ ਜਨ ਜਿਹ ਘਟਿ ਬਸਿਓ ਹਰਿ ਨਾਉ ॥",
          "roman": "dhann dhann te jan jih ghaṭ basiō har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮੁਬਾਰਿਕ ਹਨ, ਜਿਨ੍ਹਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Благословенны те люди, в чьём сердце обитает Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11897,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੈ ਬਲਿ ਬਲਿ ਜਾਉ ॥੬॥",
          "roman": "Nānak tā kē bal bal jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ ਕਿ) ਮੈਂ ਉਹਨਾਂ (ਗੁਰਮੁਖਾਂ) ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я снова и снова жертвую собой ради них. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 914,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11898,
          "is_rahao": false,
          "gurmukhi": "ਰਹਤ ਅਵਰ ਕਛੁ ਅਵਰ ਕਮਾਵਤ ॥",
          "roman": "rahat avar kachh avar kamāvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਮ ਦੇ ਬਾਹਰਲੇ ਧਾਰੇ ਹੋਏ ਚਿੰਨ੍ਹ ਹੋਰ ਹਨ ਤੇ ਅਮਲੀ ਜ਼ਿੰਦਗੀ ਕੁਝ ਹੋਰ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Внешние религиозные знаки у такого человека одни, а настоящая жизнь совсем иная."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11899,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਨਹੀ ਪ੍ਰੀਤਿ ਮੁਖਹੁ ਗੰਢ ਲਾਵਤ ॥",
          "roman": "man nahī prīt mukhah gaṇḍh lāvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ (ਤਾਂ) ਪ੍ਰਭੂ ਨਾਲ ਪਿਆਰ ਨਹੀਂ, ਮੂੰਹ ਦੀਆਂ ਗੱਲਾਂ ਨਾਲ ਘਰ ਪੂਰਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В сердце нет любви к Богу, а словами он лишь создаёт видимость завершённости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11900,
          "is_rahao": false,
          "gurmukhi": "ਜਾਨਨਹਾਰ ਪ੍ਰਭੂ ਪਰਬੀਨ ॥",
          "roman": "jānanhār prabhū parbīn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਦਿਲ ਦੀਆਂ) ਜਾਣਨ ਵਾਲਾ ਪ੍ਰਭੂ ਸਿਆਣਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но Бог, знающий сердца, мудр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11901,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਭੇਖ ਨ ਕਾਹੂ ਭੀਨ ॥",
          "roman": "bāhar bhekh na kāhū bhīn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਕਦੇ) ਕਿਸੇ ਦੇ ਬਾਹਰਲੇ ਭੇਖ ਨਾਲ ਪ੍ਰਸੰਨ ਨਹੀਂ ਹੋਇਆ।"
            },
            "sahib_singh_ru": {
              "main": "Его никогда не удовлетворял ничей внешний облик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11902,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਉਪਦੇਸੈ ਆਪਿ ਨ ਕਰੈ ॥",
          "roman": "avar updesē āp na karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਮਨੁੱਖ) ਹੋਰਨਾਂ ਨੂੰ ਮੱਤਾਂ ਦੇਂਦਾ ਹੈ (ਪਰ) ਆਪ ਨਹੀਂ ਕਮਾਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Кто поучает других, но сам не живёт так,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11903,
          "is_rahao": false,
          "gurmukhi": "ਆਵਤ ਜਾਵਤ ਜਨਮੈ ਮਰੈ ॥",
          "roman": "āvat jāvat janmē marē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот остаётся в круге рождений и смертей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11904,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਅੰਤਰਿ ਬਸੈ ਨਿਰੰਕਾਰੁ ॥",
          "roman": "jis kē antar basē Nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਨਿਰੰਕਾਰ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "А в чьём сердце обитает Ниранкар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11905,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਸੀਖ ਤਰੈ ਸੰਸਾਰੁ ॥",
          "roman": "tis kī sīkh tarē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਸਿੱਖਿਆ ਨਾਲ ਜਗਤ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "через его наставление мир спасается от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11906,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਮ ਭਾਨੇ ਤਿਨ ਪ੍ਰਭੁ ਜਾਤਾ ॥",
          "roman": "jo tum bhāne tin prabh jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਜੋ (ਭਗਤ) ਤੈਨੂੰ ਪਿਆਰੇ ਲੱਗਦੇ ਹਨ ਉਹਨਾਂ ਨੇ ਤੈਨੂੰ ਪਛਾਣਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху, те бхагаты, кто Тебе угоден, Тебя и познали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11907,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਨ ਜਨ ਚਰਨ ਪਰਾਤਾ ॥੭॥",
          "roman": "Nānak un jan charan parātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ)-ਮੈਂ ਉਹਨਾਂ (ਭਗਤਾਂ) ਦੇ ਚਰਨਾਂ ਤੇ ਪੈਂਦਾ ਹਾਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я припадаю к стопам этих людей. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 915,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11908,
          "is_rahao": false,
          "gurmukhi": "ਕਰਉ ਬੇਨਤੀ ਪਾਰਬ੍ਰਹਮੁ ਸਭੁ ਜਾਨੈ ॥",
          "roman": "karau benatī Pārbrahm sabh jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਜੋ) ਬੇਨਤੀ ਮੈਂ ਕਰਦਾ ਹਾਂ, ਪ੍ਰਭੂ ਸਭ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Какую бы молитву я ни возносил, Парбрахм всё знает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11909,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਕੀਆ ਆਪਹਿ ਮਾਨੈ ॥",
          "roman": "apnā kīā āpah mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਪੈਦਾ ਕੀਤੇ ਜੀਵ ਨੂੰ ਉਹ ਆਪ ਹੀ ਮਾਣ ਬਖ਼ਸ਼ਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Своему же созданному существу Он Сам дарует честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11910,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਆਪ ਆਪਿ ਕਰਤ ਨਿਬੇਰਾ ॥",
          "roman": "āpah āp āp karat niberā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੇ ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ) ਪ੍ਰਭੂ ਆਪ ਹੀ ਨਿਖੇੜਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сообразно делам существ Бог Сам и производит различение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11911,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੈ ਦੂਰਿ ਜਨਾਵਤ ਕਿਸੈ ਬੁਝਾਵਤ ਨੇਰਾ ॥",
          "roman": "kisē dūr janāvat kisē bujhāvat nerā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ) ਕਿਸੇ ਨੂੰ ਇਹ ਬੁਧਿ ਬਖ਼ਸ਼ਦਾ ਹੈ ਕਿ ਪ੍ਰਭੂ ਸਾਡੇ ਨੇੜੇ ਹੈ ਤੇ ਕਿਸੇ ਨੂੰ ਜਣਾਉਂਦਾ ਹੈ ਕਿ ਪ੍ਰਭੂ ਕਿਤੇ ਦੂਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кому-то Он внушает, что Бог далёк, а кому-то даёт понимание, что Он близко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11912,
          "is_rahao": false,
          "gurmukhi": "ਉਪਾਵ ਸਿਆਨਪ ਸਗਲ ਤੇ ਰਹਤ ॥",
          "roman": "upāv siānap sagal te rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਹੀਲਿਆਂ ਤੇ ਚਤੁਰਾਈਆਂ ਤੋਂ (ਪ੍ਰਭੂ) ਪਰੇ ਹੈ (ਭਾਵ, ਕਿਸੇ ਹੀਲੇ ਚਤੁਰਾਈ ਨਾਲ ਪ੍ਰਸੰਨ ਨਹੀਂ ਹੁੰਦਾ)"
            },
            "sahib_singh_ru": {
              "main": "Он превыше всех ухищрений и всей хитрости, и никакими уловками нельзя Ему угодить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11913,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਛੁ ਜਾਨੈ ਆਤਮ ਕੀ ਰਹਤ ॥",
          "roman": "sabh kachh jānē ātam kī rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਉਹ ਜੀਵ ਦੀ) ਆਤਮਕ ਰਹਿਣੀ ਦੀ ਹਰੇਕ ਗੱਲ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что Он знает всё о внутреннем состоянии души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11914,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਲਏ ਲੜਿ ਲਾਇ ॥",
          "roman": "jis bhāvē tis lae laṛ lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਜੀਵ) ਉਸ ਨੂੰ ਭਾਉਂਦਾ ਹੈ ਉਸ ਨੂੰ ਆਪਣੇ ਲੜ ਲਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кто Ему по душе, Он привязывает к Своему подолу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11915,
          "is_rahao": false,
          "gurmukhi": "ਥਾਨ ਥਨੰਤਰਿ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "thān thanantar rahiā samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11916,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਜਿਸੁ ਕਿਰਪਾ ਕਰੀ ॥",
          "roman": "so sevak jis kirpā karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਅਸਲੀ) ਸੇਵਕ ਬਣਦਾ ਹੈ ਜਿਸ ਉਤੇ ਪ੍ਰਭੂ ਮੇਹਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Истинным слугой становится лишь тот, на кого Бог пролил милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11917,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨਿਮਖ ਜਪਿ ਨਾਨਕ ਹਰੀ ॥੮॥੫॥",
          "roman": "nimakh nimakh jap Nānak harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਐਸੇ) ਪ੍ਰਭੂ ਨੂੰ ਦਮ-ਬ-ਦਮ ਯਾਦ ਕਰ ॥੮॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, вспоминай такого Хари миг за мигом. ॥8॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 916,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11918,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11919,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਅਰੁ ਲੋਭ ਮੋਹ ਬਿਨਸਿ ਜਾਇ ਅਹੰਮੇਵ ॥",
          "roman": "kām krodh ar lobh moh binas jāe ahaṃmev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰਾ) ਕਾਮ, ਕ੍ਰੋਧ, ਲੋਭ, ਮੋਹ ਅਤੇ ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਏ-"
            },
            "sahib_singh_ru": {
              "main": "Пусть мои кам, кродх, лобх, मोह и аханкар исчезнут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11920,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਗਤੀ ਕਰਿ ਪ੍ਰਸਾਦੁ ਗੁਰਦੇਵ ॥੧॥",
          "roman": "Nānak prabh saraṇāgatī kar prasād gurdev.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਬੇਨਤੀ ਕਰ ਤੇ ਆਖ)-ਹੇ ਗੁਰਦੇਵ! ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਸਰਣ ਆਇਆ ਹਾਂ (ਮੇਰੇ ਉਤੇ) ਮੇਹਰ ਕਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Моли и скажи: о Гурдев! о Прабху! я пришёл в Твоё прибежище, окажи мне милость. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 917,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11921,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11922,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਛਤੀਹ ਅੰਮ੍ਰਿਤ ਖਾਹਿ ॥",
          "roman": "jih prasād chhatīh aṃmrit khāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਕਈ ਕਿਸਮਾਂ ਦੇ ਸੁਆਦਲੇ ਖਾਣੇ ਖਾਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Того, благодаря Кому ты ешь многие виды вкусной пищи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11923,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਠਾਕੁਰ ਕਉ ਰਖੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "tis ṭhākur kau rakh man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਮਨ ਵਿਚ (ਚੇਤੇ) ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "держи Его в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11924,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੁਗੰਧਤ ਤਨਿ ਲਾਵਹਿ ॥",
          "roman": "jih prasād sugaṅdhat tan lāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਆਪਣੇ ਸਰੀਰ ਉਤੇ ਤੂੰ ਸੁਗੰਧੀਆਂ ਲਾਉਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты умащаешь своё тело благовониями,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11925,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਉ ਸਿਮਰਤ ਪਰਮ ਗਤਿ ਪਾਵਹਿ ॥",
          "roman": "tis kau simrat param gat pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਯਾਦ ਕੀਤਿਆਂ ਤੂੰ ਉੱਚਾ ਦਰਜਾ ਹਾਸਲ ਕਰ ਲਏਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "помня Его, ты обретёшь высшее состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11926,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਬਸਹਿ ਸੁਖ ਮੰਦਰਿ ॥",
          "roman": "jih prasād basah sukh mandar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਦਇਆ ਨਾਲ ਤੂੰ ਸੁਖ-ਮਹਲਾਂ ਵਿਚ ਵੱਸਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты живёшь в дворцах наслаждения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11927,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਧਿਆਇ ਸਦਾ ਮਨ ਅੰਦਰਿ ॥",
          "roman": "tiseh dhiāe sadā man andar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਦਾ ਮਨ ਵਿਚ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "всегда помни Его в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11928,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਗ੍ਰਿਹ ਸੰਗਿ ਸੁਖ ਬਸਨਾ ॥",
          "roman": "jih prasād grih saṅg sukh basnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਘਰ ਮੌਜਾਂ ਨਾਲ ਵੱਸ ਰਿਹਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому ты живёшь дома в радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11929,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਸਿਮਰਹੁ ਤਿਸੁ ਰਸਨਾ ॥",
          "roman": "āṭh pahar simrah tis rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਜੀਭ ਨਾਲ ਅੱਠੇ ਪਹਰ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "вспоминай Его языком все восемь страж."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11930,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਰੰਗ ਰਸ ਭੋਗ ॥",
          "roman": "jih prasād raṅg ras bhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਬਖ਼ਸ਼ਸ਼ ਕਰਕੇ ਚੋਜ-ਤਮਾਸ਼ੇ, ਸੁਆਦਲੇ ਖਾਣੇ ਤੇ ਪਦਾਰਥ (ਨਸੀਬ ਹੁੰਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "По щедрому дару Того достаются забавы, развлечения, вкусная пища и вещества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11931,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਦਾ ਧਿਆਈਐ ਧਿਆਵਨ ਜੋਗ ॥੧॥",
          "roman": "Nānak sadā dhiāīai dhiāvan jog.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਧਿਆਉਣ-ਜੋਗ ਨੂੰ ਸਦਾ ਹੀ ਧਿਆਉਣਾ ਚਾਹੀਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Того, Кто достоин созерцания, следует созерцать всегда. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 918,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11932,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਪਾਟ ਪਟੰਬਰ ਹਢਾਵਹਿ ॥",
          "roman": "jih prasād pāṭ paṭambar haḍhāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਜਿਸ (ਪ੍ਰਭੂ) ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਤੂੰ ਰੇਸ਼ਮੀ ਕੱਪੜੇ ਹੰਢਾਉਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! По милости Того, благодаря Кому ты носишь шёлковые одежды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11933,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਤਿਆਗਿ ਕਤ ਅਵਰ ਲੁਭਾਵਹਿ ॥",
          "roman": "tiseh tiāg kat avar lubhāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਵਿਸਾਰ ਕੇ ਹੋਰ ਕਿੱਥੇ ਲੋਭ ਕਰ ਰਿਹਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "забыв Его, где ещё ты ищешь приманку для жадности?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11934,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਸੁਖਿ ਸੇਜ ਸੋਈਜੈ ॥",
          "roman": "jih prasād sukh sej soījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਿਹਰ ਨਾਲ ਸੇਜ ਉੱਤੇ ਸੁਖੀ ਸਵੀਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому сладко спится на ложе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11935,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਆਠ ਪਹਰ ਤਾ ਕਾ ਜਸੁ ਗਾਵੀਜੈ ॥",
          "roman": "man āṭh pahar tā kā jas gāvījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਸ ਪ੍ਰਭੂ ਦਾ ਜਸ ਅੱਠੇ ਪਹਰ ਗਾਉਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "о ум! славу Того Прабху следует петь все восемь страж."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11936,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਪ੍ਰਸਾਦਿ ਤੁਝੁ ਸਭੁ ਕੋਊ ਮਾਨੈ ॥",
          "roman": "jih prasād tujh sabh koū mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਹਰੇਕ ਮਨੁੱਖ ਤੇਰਾ ਆਦਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Того, благодаря Кому каждый человек почитает тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
