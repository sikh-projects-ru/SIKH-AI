{
  "ang": 271,
  "shabads": [
    {
      "shabad_id": 924,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 11994,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਿਰਪਾ ਤੇ ਹੋਇ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "prabh kirpā te hoi pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ (ਮਨ ਵਿਚ ਗਿਆਨ ਦਾ) ਪ੍ਰਕਾਸ਼ ਹੁੰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "По милости Прабху в уме возникает свет знания;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11995,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੂ ਦਇਆ ਤੇ ਕਮਲ ਬਿਗਾਸੁ ॥",
          "roman": "prabhū daiā te kamal bigās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਦਇਆ ਨਾਲ ਹਿਰਦਾ-ਰੂਪ ਕਉਲ ਫੁੱਲ ਖਿੜਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по Его состраданию расцветает лотос сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11996,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸੁਪ੍ਰਸੰਨ ਬਸੈ ਮਨਿ ਸੋਇ ॥",
          "roman": "prabh suprasaṃn basē man soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ (ਉਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਵੱਸਦਾ ਹੈ ਜਿਸ ਉਤੇ ਉਹ ਤ੍ਰੁੱਠਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Прабху обитает в уме того человека, кем Он доволен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11997,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਇਆ ਤੇ ਮਤਿ ਊਤਮ ਹੋਇ ॥",
          "roman": "prabh daiā te mat ūtam hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਨਾਲ (ਮਨੁੱਖ ਦੀ) ਮੱਤ ਚੰਗੀ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и по милости Прабху ум человека становится добрым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11998,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਪ੍ਰਭ ਤੇਰੀ ਮਇਆ ॥",
          "roman": "sarab nidhān prabh terī maiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਮੇਹਰ ਦੀ ਨਜ਼ਰ ਵਿਚ ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! в Твоём милостивом взгляде заключены все сокровища,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 11999,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹੁ ਕਛੂ ਨ ਕਿਨਹੂ ਲਇਆ ॥",
          "roman": "āpah kachhū na kinhū laiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਜਤਨ ਨਾਲ ਕਿਸੇ ਨੇ ਭੀ ਕੁਝ ਨਹੀਂ ਲੱਭਾ (ਭਾਵ, ਜੀਵ ਦਾ ਉੱਦਮ ਤਦੋਂ ਹੀ ਸਫਲ ਹੁੰਦਾ ਹੈ ਜਦੋਂ ਤੂੰ ਸਵੱਲੀ ਨਜ਼ਰ ਕਰਦਾ ਹੈਂ)।"
            },
            "sahib_singh_ru": {
              "main": "сам по себе никто ничего не обрёл; усилие живого становится успешным лишь тогда, когда Ты смотришь благосклонно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12000,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਜਿਤੁ ਲਾਵਹੁ ਤਿਤੁ ਲਗਹਿ ਹਰਿ ਨਾਥ ॥",
          "roman": "jit jit lāvah tit lagah har nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਹੇ ਨਾਥ! ਜਿਧਰ ਤੂੰ ਲਾਉਂਦਾ ਹੈਂ ਉਧਰ ਇਹ ਜੀਵ ਲੱਗਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Хари! о Натх! куда Ты направляешь, туда эти существа и обращаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12001,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਇਨ ਕੈ ਕਛੂ ਨ ਹਾਥ ॥੮॥੬॥",
          "roman": "Nānak in kē kachhū na hāth.8.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਇਹਨਾਂ ਜੀਵਾਂ ਦੇ ਵੱਸ ਕੁਝ ਨਹੀਂ ॥੮॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! в руках этих существ ничего нет. ॥8॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 925,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12002,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12003,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗਾਧਿ ਪਾਰਬ੍ਰਹਮੁ ਸੋਇ ॥",
          "roman": "agam agādh pārbrahm soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੇਅੰਤ ਪ੍ਰਭੂ (ਜੀਵ ਦੀ) ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ ਤੇ ਅਥਾਹ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Безграничный Парабрахм — недосягаем и бездонен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12004,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਕਹੈ ਸੁ ਮੁਕਤਾ ਹੋਇ ॥",
          "roman": "jo jo kahē su muktā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੋ (ਮਨੁੱਖ ਉਸ ਨੂੰ) ਸਿਮਰਦਾ ਹੈ ਉਹ (ਵਿਕਾਰਾਂ ਦੇ ਜਾਲ ਤੋਂ) ਖ਼ਲਾਸੀ ਪਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто бы ни помнил Его, тот освобождается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12005,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਮੀਤਾ ਨਾਨਕੁ ਬਿਨਵੰਤਾ ॥ ਸਾਧ ਜਨਾ ਕੀ ਅਚਰਜ ਕਥਾ ॥੧॥",
          "roman": "sun mītā Nānak binvantā, sādh janā kī acharaj kathā. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿਤ੍ਰ! ਸੁਣ, ਨਾਨਕ ਬੇਨਤੀ ਕਰਦਾ ਹੈ: (ਸਿਮਰਨ ਕਰਨ ਵਾਲੇ) ਗੁਰਮੁਖਾਂ (ਦੇ ਗੁਣਾਂ) ਦਾ ਜ਼ਿਕਰ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਹੈ (ਭਾਵ, ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਭਗਤ ਜਨਾਂ ਵਿਚ ਇਤਨੇ ਗੁਣ ਪੈਦਾ ਹੋ ਜਾਂਦੇ ਹਨ ਕਿ ਉਹਨਾਂ ਗੁਣਾਂ ਦੀ ਗੱਲ ਛੇੜਿਆਂ ਅਚਰਜ ਰਹਿ ਜਾਈਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Слушай, друг: Нанак молит — рассказ о качествах гурмукхов, совершающих симран, поистине изумителен. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 926,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12006,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12007,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਮੁਖ ਊਜਲ ਹੋਤ ॥",
          "roman": "sādh kē sang mukh ūjal hot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਮੂੰਹ ਉਜਲੇ ਹੁੰਦੇ ਹਨ (ਭਾਵ, ਇੱਜ਼ਤ ਬਣ ਆਉਂਦੀ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "В общении с гурмукхами лицо становится светлым, то есть приходит честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12008,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਲੁ ਸਗਲੀ ਖੋਤ ॥",
          "roman": "sādhsang mal saglī khot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਧੂ ਜਨਾਂ ਦੇ ਪਾਸ ਰਿਹਾਂ (ਵਿਕਾਰਾਂ ਦੀ) ਸਾਰੀ ਮੈਲ ਮਿਟ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что рядом со святыми людьми исчезает вся скверна пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12009,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਮਿਟੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "sādh kē sang miṭē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂਆਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਅਹੰਕਾਰ ਦੂਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых уходит гордыня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12010,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਪ੍ਰਗਟੈ ਸੁਗਿਆਨੁ ॥",
          "roman": "sādh kē sang pragaṭē sugiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸ੍ਰੇਸ਼ਟ ਗਿਆਨ ਪਰਗਟ ਹੁੰਦਾ ਹੈ (ਭਾਵ, ਚੰਗੀ ਮਤਿ ਆਉਂਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и раскрывается высшее знание, то есть приходит добрая мудрость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12011,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਬੁਝੈ ਪ੍ਰਭੁ ਨੇਰਾ ॥",
          "roman": "sādh kē sang bujhē prabh nerā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤ ਵਿਚ ਪ੍ਰਭੂ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਜਾਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых Господь ощущается как пребывающий рядом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12012,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸਭੁ ਹੋਤ ਨਿਬੇਰਾ ॥",
          "roman": "sādhsang sabh hot nibērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ ਮੰਦੇ ਸੰਸਕਾਰਾਂ ਜਾਂ ਵਾਸਨਾ ਦਾ) ਸਾਰਾ ਨਿਬੇੜਾ ਹੋ ਜਾਂਦਾ ਹੈ (ਭਾਵ, ਮੰਦੇ ਪਾਸੇ ਜੀਵ ਪੈਂਦਾ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "и потому всякий расчёт с дурными склонностями и желаниями завершается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12013,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਪਾਏ ਨਾਮ ਰਤਨੁ ॥",
          "roman": "sādh kē sang pāe nām ratan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖ ਨਾਮ-ਰੂਪ ਰਤਨ ਲੱਭ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов человек обретает драгоценность Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12014,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਏਕ ਊਪਰਿ ਜਤਨੁ ॥",
          "roman": "sādh kē sang ek ūpar jatan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਇੱਕ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲਣ ਦਾ ਜਤਨ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и старается встретиться с Единым Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12015,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਮਹਿਮਾ ਬਰਨੈ ਕਉਨੁ ਪ੍ਰਾਨੀ ॥",
          "roman": "sādh kī mahimā barnē kaun prānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂਆਂ ਦੀ ਵਡਿਆਈ ਕਿਹੜਾ ਮਨੁੱਖ ਬਿਆਨ ਕਰ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Какой человек способен описать величие святых?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12016,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧ ਕੀ ਸੋਭਾ ਪ੍ਰਭ ਮਾਹਿ ਸਮਾਨੀ ॥੧॥",
          "roman": "Nānak sādh kī sobhā prabh māhi samānī. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਸਾਧ ਜਨਾਂ ਦੀ ਸੋਭਾ ਪ੍ਰਭੂ ਦੀ ਸੋਭਾ ਦੇ ਬਰਾਬਰ ਹੋ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ведь, о Нанак, слава святых становится равной славе Бога. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 927,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12017,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਅਗੋਚਰੁ ਮਿਲੈ ॥",
          "roman": "sādh kē sang agochar milē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਮਨੁੱਖ ਨੂੰ) ਉਹ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ਜੋ ਸਰੀਰਕ ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов обретается тот Господь, Который вне досягаемости телесных чувств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12018,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸਦਾ ਪਰਫੁਲੈ ॥",
          "roman": "sādh kē sang sadā parfulē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਨੁੱਖ ਸਦਾ ਖਿੜੇ ਮੱਥੇ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и человек всегда остаётся с цветущим сердцем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12019,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਆਵਹਿ ਬਸਿ ਪੰਚਾ ॥",
          "roman": "sādh kē sang āvah bas panchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਕਾਮਾਦਿਕ ਪੰਜ ਵਿਕਾਰ ਕਾਬੂ ਵਿਚ ਆ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых пять пороков, начиная с похоти, приходят под контроль,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12020,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਅੰਮ੍ਰਿਤ ਰਸੁ ਭੁੰਚਾ ॥",
          "roman": "sādhsang amrit ras bhunchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਮਨੁੱਖ) ਨਾਮ ਰੂਪ ਅੰਮ੍ਰਿਤ ਦਾ ਰਸ ਚੱਖ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что человек вкушает нектарный вкус Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12021,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹੋਇ ਸਭ ਕੀ ਰੇਨ ॥",
          "roman": "sādhsang hoi sabh kī ren",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਕੀਤਿਆਂ (ਮਨੁੱਖ) ਸਭ (ਪ੍ਰਾਣੀਆਂ) ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых человек становится прахом у ног всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12022,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਮਨੋਹਰ ਬੈਨ ॥",
          "roman": "sādh kē sang manohar bēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਸਭ ਨਾਲ) ਮਿੱਠੇ ਬਚਨ ਬੋਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и говорит со всеми сладостные слова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12023,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨ ਕਤਹੂੰ ਧਾਵੈ ॥",
          "roman": "sādh kē sang na katahū̃ dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੇ ਸੰਗ ਰਿਹਾਂ (ਮਨੁੱਖ ਦਾ) ਮਨ ਕਿਸੇ ਪਾਸੇ ਨਹੀਂ ਦੌੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя рядом со святыми, ум никуда не мечется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12024,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਅਸਥਿਤਿ ਮਨੁ ਪਾਵੈ ॥",
          "roman": "sādhsang asthit man pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ) ਟਿਕਾਉ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и достигает устойчивости в стопах Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12025,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਮਾਇਆ ਤੇ ਭਿੰਨ ॥",
          "roman": "sādh kē sang māiā te bhinn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਟਿਕਿਆਂ (ਮਨੁੱਖ) ਮਾਇਆ (ਦੇ ਅਸਰ) ਤੋਂ ਬੇ-ਦਾਗ਼ ਰਹਿੰਦਾ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Утвердившись в обществе гурмукхов, человек остаётся незапятнанным влиянием майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12026,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਨਾਨਕ ਪ੍ਰਭ ਸੁਪ੍ਰਸੰਨ ॥੨॥",
          "roman": "sādhsang Nānak prabh suprasann. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਹੇ ਨਾਨਕ! ਅਕਾਲ ਪੁਰਖ ਇਸ ਉਤੇ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, Вечный Пурукх становится к нему милостив. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 928,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12027,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਦੁਸਮਨ ਸਭਿ ਮੀਤ ॥",
          "roman": "sādhsang dusman sabh mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਸਾਰੇ ਵੈਰੀ (ਭੀ) ਮਿਤ੍ਰ (ਦਿੱਸਣ ਲੱਗ ਜਾਂਦੇ ਹਨ),"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов даже все враги начинают казаться друзьями,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12028,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਮਹਾ ਪੁਨੀਤ ॥",
          "roman": "sādhū kē sang mahā punīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤ ਵਿਚ (ਮਨੁੱਖ ਦਾ ਆਪਣਾ ਹਿਰਦਾ) ਬਹੁਤ ਸਾਫ਼ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что в обществе святых собственное сердце человека становится очень чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12029,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਕਿਸ ਸਿਉ ਨਹੀ ਬੈਰੁ ॥",
          "roman": "sādhsang kis siu nahī bēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਬੈਠਿਆਂ ਕਿਸੇ ਨਾਲ ਵੈਰ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Сидя в обществе святых, человек уже ни с кем не враждует,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12030,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨ ਬੀਗਾ ਪੈਰੁ ॥",
          "roman": "sādh kē sang na bīgā pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਿਸੇ ਮੰਦੇ ਪਾਸੇ ਪੈਰ ਨਹੀਂ ਪੁੱਟੀਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и не ступает на дурной путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12031,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨਾਹੀ ਕੋ ਮੰਦਾ ॥",
          "roman": "sādh kē sang nāhī ko mandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਲਿਆਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਕੋਈ ਮਨੁੱਖ ਭੈੜਾ ਨਹੀਂ ਦਿੱਸਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе благих никто не кажется дурным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12032,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਾਨੇ ਪਰਮਾਨੰਦਾ ॥",
          "roman": "sādhsang jāne parmānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਹਰ ਥਾਂ ਮਨੁੱਖ) ਉੱਚੇ ਸੁਖ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਨੂੰ ਹੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что повсюду человек узнаёт только Господа, Владыку высшего блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12033,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨਾਹੀ ਹਉ ਤਾਪੁ ॥",
          "roman": "sādh kē sang nāhī hau tāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖ ਸਾਰੀ ਅਪਣੱਤ ਛੱਡ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В обществе святого человек избавляется от жара Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12034,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਤਜੈ ਸਭੁ ਆਪੁ ॥",
          "roman": "sādh kē sang tajē sabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖ ਦੀ ਸੰਗਤਿ ਕੀਤਿਆਂ ਹਉਮੈ ਰੂਪ ਤਾਪ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "В общении с гурмукхом он оставляет всё самоутверждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12035,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਜਾਨੈ ਸਾਧ ਬਡਾਈ ॥",
          "roman": "āpe jānē sādh baḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਦੀ ਵਡਿਆਈ ਪ੍ਰਭੂ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Величие святого знает только Сам Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12036,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧ ਪ੍ਰਭੂ ਬਨਿ ਆਈ ॥੩॥",
          "roman": "Nānak sādh prabhū ban āī. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਸਾਧ ਤੇ ਪ੍ਰਭੂ ਦਾ ਪੱਕਾ ਪਿਆਰ ਪੈ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ибо, о Нанак, между святым и Богом возникает прочная любовь. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 929,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12037,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨ ਕਬਹੂ ਧਾਵੈ ॥",
          "roman": "sādh kē sang na kabahū dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਮਨੁੱਖ ਦਾ ਮਨ ਕਦੇ ਭਟਕਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов ум человека никогда не блуждает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12038,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸਦਾ ਸੁਖੁ ਪਾਵੈ ॥",
          "roman": "sādh kē sang sadā sukh pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਮਨੁੱਖ) ਸਦਾ ਸੁਖ ਮਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что в обществе святых он всегда наслаждается покоем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12039,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਬਸਤੁ ਅਗੋਚਰ ਲਹੈ ॥",
          "roman": "sādhsang bast agochar lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਰੂਪ ਅਗੋਚਰ ਵਸਤ ਮਿਲ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых обретается незримое сокровище — Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12040,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਅਜਰੁ ਸਹੈ ॥",
          "roman": "sādhū kē sang ajar sahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਤੇ ਮਨੁੱਖ) ਇਹ ਨਾਹ ਜਰਿਆ ਜਾਣ ਵਾਲਾ ਮਰਤਬਾ ਜਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и человек выносит это неистощимое достоинство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12041,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਬਸੈ ਥਾਨਿ ਊਚੈ ॥",
          "roman": "sādh kē sang basē thān ūchē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਮਨੁੱਖ ਉਚੇ (ਆਤਮਕ) ਟਿਕਾਣੇ ਤੇ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе гурмукхов, человек обитает на высоком духовном месте,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12042,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਮਹਲਿ ਪਹੂਚੈ ॥",
          "roman": "sādhū kē sang mahal pahūchē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਅਕਾਲ ਪੁਰਖ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и пребывает соединённым со стопами Вечного Пурукха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12043,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਦ੍ਰਿੜੈ ਸਭਿ ਧਰਮ ॥",
          "roman": "sādh kē sang driṛhē sabh dharam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ (ਮਨੁੱਖ) ਸਾਰੇ ਧਰਮਾਂ (ਫ਼ਰਜ਼ਾਂ) ਨੂੰ ਚੰਗੀ ਤਰ੍ਹਾਂ ਸਮਝ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе святых, человек хорошо понимает все дхармы, все обязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12044,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਕੇਵਲ ਪਾਰਬ੍ਰਹਮ ॥",
          "roman": "sādh kē sang keval pārbrahm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਿਰਫ਼ ਅਕਾਲ ਪੁਰਖ ਨੂੰ (ਹਰ ਥਾਂ ਵੇਖਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и видит повсюду только одного Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12045,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਪਾਏ ਨਾਮ ਨਿਧਾਨ ॥",
          "roman": "sādh kē sang pāe nām nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਮਨੁੱਖ) ਨਾਮ ਖ਼ਜ਼ਾਨਾ ਲੱਭ ਲੈਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых человек находит сокровище Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12046,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧੂ ਕੈ ਕੁਰਬਾਨ ॥੪॥",
          "roman": "Nānak sādhū kē kurbān. 4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੇ ਨਾਨਕ! (ਆਖ-) ਮੈਂ ਸਾਧ ਜਨਾਂ ਤੋਂ ਸਦਕੇ ਹਾਂ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "потому, о Нанак, я жертвую собой ради святых. 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 930,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12047,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸਭ ਕੁਲ ਉਧਾਰੈ ॥",
          "roman": "sādh kē sang sabh kul udhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ (ਮਨੁੱਖ ਆਪਣੀਆਂ) ਸਾਰੀਆਂ ਕੁਲਾਂ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе гурмукхов, человек спасает все свои роды от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12048,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸਾਜਨ ਮੀਤ ਕੁਟੰਬ ਨਿਸਤਾਰੈ ॥",
          "roman": "sādhsang sājan mīt kuṭamb nistārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ (ਆਪਣੇ) ਸੱਜਣਾਂ ਮਿੱਤ੍ਰਾਂ ਤੇ ਪਰਵਾਰ ਨੂੰ ਤਾਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и переправляет своих близких, друзей и семью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12049,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਸੋ ਧਨੁ ਪਾਵੈ ॥",
          "roman": "sādhū kē sang so dhan pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖ ਨੂੰ ਉਹ ਧਨ ਲੱਭ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых человек находит то богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12050,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਧਨ ਤੇ ਸਭੁ ਕੋ ਵਰਸਾਵੈ ॥",
          "roman": "jis dhan te sabh ko varsāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਧਨ ਦੇ ਮਿਲਣ ਨਾਲ ਹਰੇਕ ਮਨੁੱਖ ਨਾਮਣੇ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "обретя которое, всякий становится достойным почёта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12051,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਧਰਮ ਰਾਇ ਕਰੇ ਸੇਵਾ ॥",
          "roman": "sādhsang dharam rāi kre sevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਧਰਮਰਾਜ (ਭੀ) ਸੇਵਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых даже Дхарм Рай служит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12052,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸੋਭਾ ਸੁਰਦੇਵਾ ॥",
          "roman": "sādh kē sang sobhā surdevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਦੇਵਤੇ ਭੀ) ਸੋਭਾ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и боги тоже воздают славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12053,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਪਾਪ ਪਲਾਇਨ ॥",
          "roman": "sādhū kē sang pāp palāin",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов грехи уходят прочь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12054,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਅੰਮ੍ਰਿਤ ਗੁਨ ਗਾਇਨ ॥",
          "roman": "sādhsang amrit gun gāin",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਓਥੇ) ਪ੍ਰਭੂ ਦੇ ਅਮਰ ਕਰਨ ਵਾਲੇ ਗੁਣ (ਮਨੁੱਖ) ਗਾਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что там поют животворящие качества Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12055,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸ੍ਰਬ ਥਾਨ ਗੰਮਿ ॥",
          "roman": "sādh kē sang srab thān gamm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਸਭ ਥਾਈਂ ਪਹੁੰਚ ਹੋ ਜਾਂਦੀ ਹੈ (ਭਾਵ, ਉੱਚੀ ਆਤਮਕ ਸਮਰੱਥਾ ਆ ਜਾਂਦੀ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе святых, человек обретает достижимость всех мест, то есть высокую духовную силу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
