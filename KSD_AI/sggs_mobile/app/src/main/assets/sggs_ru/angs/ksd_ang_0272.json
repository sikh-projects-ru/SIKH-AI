{
  "ang": 272,
  "shabads": [
    {
      "shabad_id": 930,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12056,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧ ਕੈ ਸੰਗਿ ਸਫਲ ਜਨੰਮ ॥੫॥",
          "roman": "Nānak sādh kē sang safal janamm. 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਾਧੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖਾ ਜਨਮ ਦਾ ਫਲ ਮਿਲ ਜਾਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, в обществе святого человеческая жизнь получает свой плод. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 931,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12057,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨਹੀ ਕਛੁ ਘਾਲ ॥",
          "roman": "sādh kē sang nahī kachh ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਤਪ ਆਦਿਕ ਤਪਨ ਦੀ ਲੋੜ ਨਹੀਂ ਰਹਿੰਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых уже не нужна аскеза и иные истязания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12058,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਭੇਟਤ ਹੋਤ ਨਿਹਾਲ ॥",
          "roman": "darsan bheṭat hot nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਉਹਨਾਂ) ਦਾ ਦਰਸ਼ਨ ਹੀ ਕਰ ਕੇ ਹਿਰਦਾ ਖਿੜ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что уже один их даршан наполняет сердце радостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12059,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਕਲੂਖਤ ਹਰੈ ॥",
          "roman": "sādh kē sang kalūkhat harē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਮਨੁੱਖ ਆਪਣੇ) ਪਾਪ ਨਾਸ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе гурмукхов человек уничтожает свои грехи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12060,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨਰਕ ਪਰਹਰੈ ॥",
          "roman": "sādh kē sang narak parharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਇਸ ਤਰ੍ਹਾਂ) ਨਰਕਾਂ ਤੋਂ ਬਚ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и так спасается от адов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12061,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਈਹਾ ਊਹਾ ਸੁਹੇਲਾ ॥",
          "roman": "sādh kē sang īhā ūhā suhēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ (ਮਨੁੱਖ) ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਸੌਖਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Живя в обществе святых, человек обретает лёгкость и здесь, и в ином мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12062,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਬਿਛੁਰਤ ਹਰਿ ਮੇਲਾ ॥",
          "roman": "sādhsang bichhurat har melā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪ੍ਰਭੂ ਤੋਂ ਵਿਛੁੜਿਆ ਹੋਇਆ (ਮੁੜ) ਉਸ ਨੂੰ ਮਿਲ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, будучи разлучённым с Господом, вновь встречает Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12063,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਛੈ ਸੋਈ ਫਲੁ ਪਾਵੈ ॥",
          "roman": "jo ichhē soī phal pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚੋਂ (ਮਨੁੱਖ) ਜੋ ਇੱਛਾ ਕਰਦਾ ਹੈ, ਓਹੀ ਫਲ ਪਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Что бы человек ни пожелал в обществе гурмукхов, тот плод он и получает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12064,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨ ਬਿਰਥਾ ਜਾਵੈ ॥",
          "roman": "sādh kē sang na birthā jāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇ-ਮੁਰਾਦ ਹੋ ਕੇ ਨਹੀਂ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "он не уходит ни с чем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12065,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਸਾਧ ਰਿਦ ਬਸੈ ॥",
          "roman": "pārbrahm sādh rid basē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਸੰਤ ਜਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਵੱਸਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Парабрахм пребывает в сердце святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12066,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੈ ਸਾਧ ਸੁਨਿ ਰਸੈ ॥੬॥",
          "roman": "Nānak udharē sādh sun rasē. 6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਮਨੁੱਖ) ਸਾਧੂ ਜਨਾਂ ਦੀ ਰਸਨਾ ਤੋਂ (ਉਪਦੇਸ਼) ਸੁਣ ਕੇ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਜਾਂਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, слушая наставление с уст святых, человек спасается от пороков. 6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 932,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12067,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਸੁਨਉ ਹਰਿ ਨਾਉ ॥",
          "roman": "sādh kē sang sunau har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸੁਣਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Пусть я, пребывая в обществе гурмукхов, слушаю Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12068,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੇ ਗੁਨ ਗਾਉ ॥",
          "roman": "sādhsang har ke gun gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਵਾਂ (ਇਹ ਮੇਰੀ ਕਾਮਨਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и пою качества Господа — таково моё желание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12069,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਨ ਮਨ ਤੇ ਬਿਸਰੈ ॥",
          "roman": "sādh kē sang na man te bisrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਪ੍ਰਭੂ ਮਨ ਤੋਂ ਭੁੱਲਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых Господь не забывается умом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12070,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਸਰਪਰ ਨਿਸਤਰੈ ॥",
          "roman": "sādhsang sarpar nistarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਨੁੱਖ ਜ਼ਰੂਰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਨਿਕਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и в обществе святых человек непременно спасается от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12071,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਲਗੈ ਪ੍ਰਭੁ ਮੀਠਾ ॥",
          "roman": "sādh kē sang lagē prabh mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਲਿਆਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਪ੍ਰਭੂ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе благих Господь начинает казаться сладостным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12072,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੈ ਸੰਗਿ ਘਟਿ ਘਟਿ ਡੀਠਾ ॥",
          "roman": "sādhū kē sang ghaṭ ghaṭ ḍīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਹ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਦਿਖਾਈ ਦੇਣ ਲੱਗ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и становится видимым в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12073,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭਏ ਆਗਿਆਕਾਰੀ ॥",
          "roman": "sādhsang bhae āgiākārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂਆਂ ਦੀ ਸੰਗਤਿ ਕੀਤਿਆਂ (ਅਸੀ) ਪ੍ਰਭੂ ਦਾ ਹੁਕਮ ਮੰਨਣ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых мы становимся послушными Воле Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12074,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਗਤਿ ਭਈ ਹਮਾਰੀ ॥",
          "roman": "sādhsang gat bhaī hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਾਡੀ ਆਤਮਕ ਅਵਸਥਾ ਸੁਧਰ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и наше духовное состояние улучшается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12075,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੈ ਸੰਗਿ ਮਿਟੇ ਸਭਿ ਰੋਗ ॥",
          "roman": "sādh kē sang miṭe sabh rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਸੁਹਬਤ ਵਿਚ (ਵਿਕਾਰ ਆਦਿਕ) ਸਾਰੇ ਰੋਗ ਮਿਟ ਜਾਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "В общении со святыми исчезают все болезни, то есть пороки и всё подобное,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12076,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧ ਭੇਟੇ ਸੰਜੋਗ ॥੭॥",
          "roman": "Nānak sādh bheṭe sanjog. 7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਵੱਡੇ) ਭਾਗਾਂ ਨਾਲ ਸਾਧ ਜਨ ਮਿਲਦੇ ਹਨ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, святые встречаются по великой удаче. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 933,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12077,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਮਹਿਮਾ ਬੇਦ ਨ ਜਾਨਹਿ ॥",
          "roman": "sādh kī mahimā bed na jānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਦੀ ਵਡਿਆਈ ਵੇਦ (ਭੀ) ਨਹੀਂ ਜਾਣਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Даже Веды не знают величия святого,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12078,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤਾ ਸੁਨਹਿ ਤੇਤਾ ਬਖਿਆਨਹਿ ॥",
          "roman": "jetā sunah tetā bakhiānah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਤਾਂ ਜਿਤਨਾ ਸੁਣਦੇ ਹਨ, ਉਤਨਾ ਹੀ ਬਿਆਨ ਕਰਦੇ ਹਨ (ਪਰ ਸਾਧ ਦੀ ਮਹਿਮਾ ਬਿਆਨ ਤੋਂ ਪਰੇ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "они излагают лишь столько, сколько сами услышали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12079,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਉਪਮਾ ਤਿਹੁ ਗੁਣ ਤੇ ਦੂਰਿ ॥",
          "roman": "sādh kī upmā tih guṇ te dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਦੀ ਸਮਾਨਤਾ ਤਿੰਨਾਂ ਗੁਣਾਂ ਤੋਂ ਪਰੇ ਹੈ (ਭਾਵ, ਜਗਤ ਦੀ ਰਚਨਾ ਵਿਚ ਕੋਈ ਅਜੇਹੀ ਹਸਤੀ ਨਹੀਂ ਜਿਸ ਨੂੰ ਸਾਧ ਵਰਗਾ ਕਿਹਾ ਜਾ ਸਕੇ; ਹਾਂ)"
            },
            "sahib_singh_ru": {
              "main": "Подобие святому находится за пределами трёх гун."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12080,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਉਪਮਾ ਰਹੀ ਭਰਪੂਰਿ ॥",
          "roman": "sādh kī upmā rahī bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਦੀ ਸਮਾਨਤਾ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਹੀ ਹੋ ਸਕਦੀ ਹੈ ਜੋ ਸਾਰੇ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Подобием святому может быть только тот Господь, Который наполняет всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12081,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਕਾ ਨਾਹੀ ਅੰਤ ॥",
          "roman": "sādh kī sobhā kā nāhī ant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਦੀ ਸੋਭਾ ਦਾ ਅੰਦਾਜ਼ਾ ਨਹੀਂ ਲੱਗ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Славу святого невозможно измерить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12082,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਸਦਾ ਬੇਅੰਤ ॥",
          "roman": "sādh kī sobhā sadā beant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ (ਇਸ ਨੂੰ) ਬੇਅੰਤ ਹੀ (ਕਿਹਾ ਜਾ ਸਕਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "её можно назвать лишь беспредельной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12083,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਊਚ ਤੇ ਊਚੀ ॥",
          "roman": "sādh kī sobhā ūch te ūchī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਦੀ ਸੋਭਾ ਹੋਰ ਸਭ ਦੀ ਸੋਭਾ ਤੋਂ ਬਹੁਤ ਉੱਚੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слава святого выше всякой иной славы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12084,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਮੂਚ ਤੇ ਮੂਚੀ ॥",
          "roman": "sādh kī sobhā mūch te mūchī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਬਹੁਤ ਵੱਡੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и она чрезвычайно велика."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12085,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਸਾਧ ਬਨਿ ਆਈ ॥",
          "roman": "sādh kī sobhā sādh ban āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧੂ ਦੀ ਸੋਭਾ ਸਾਧੂ ਨੂੰ ਹੀ ਫਬਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слава святого подобает только святому,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12086,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਧ ਪ੍ਰਭ ਭੇਦੁ ਨ ਭਾਈ ॥੮॥੭॥",
          "roman": "Nānak sādh prabh bhed na bhāī. 8. 7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਭਾਈ! ਸਾਧੂ ਤੇ ਪ੍ਰਭੂ ਵਿਚ (ਕੋਈ) ਫ਼ਰਕ ਨਹੀਂ ਹੈ ॥੮॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "ибо, о Нанак, скажи, брат: между святым и Господом нет различия. 8. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 934,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12087,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12088,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਸਾਚਾ ਮੁਖਿ ਸਾਚਾ ਸੋਇ ॥",
          "roman": "man sachā mukh sachā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ (ਵੱਸਦਾ ਹੈ), (ਜੋ) ਮੂੰਹੋਂ (ਭੀ) ਉਸੇ ਪ੍ਰਭੂ ਨੂੰ (ਜਪਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "У кого в уме пребывает вечно-истинный Господь и кто устами тоже повторяет лишь Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12089,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰੁ ਨ ਪੇਖੈ ਏਕਸੁ ਬਿਨੁ ਕੋਇ ॥",
          "roman": "avar na pekhē ekas bin koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਮਨੁੱਖ) ਇਕ ਅਕਾਲ ਪੁਰਖ ਤੋਂ ਬਿਨਾ (ਕਿਤੇ ਭੀ) ਕਿਸੇ ਹੋਰ ਨੂੰ ਨਹੀਂ ਵੇਖਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "кто, кроме Единого Акаал Пуракха, нигде никого другого не видит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12090,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਇਹ ਲਛਣ ਬ੍ਰਹਮ ਗਿਆਨੀ ਹੋਇ ॥੧॥",
          "roman": "Nānak ih lachhaṇ brahm giānī hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਹ ਮਨੁੱਖ) ਇਹਨਾਂ ਗੁਣਾਂ ਦੇ ਕਾਰਣ ਬ੍ਰਹਮਗਿਆਨੀ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, по этим признакам человек становится брахмгьяни ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 935,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12091,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12092,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਦਾ ਨਿਰਲੇਪ ॥",
          "roman": "brahm giānī sadā nirlep",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਮਨੁੱਖ ਵਿਕਾਰਾਂ ਵਲੋਂ) ਸਦਾ-ਬੇਦਾਗ਼ (ਰਹਿੰਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни всегда остаются незапятнанными со стороны пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12093,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਜਲ ਮਹਿ ਕਮਲ ਅਲੇਪ ॥",
          "roman": "jēse jal mah kamal alep",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਵਿਚ (ਉੱਗੇ ਹੋਏ) ਕਉਲ ਫੁੱਲ (ਚਿੱਕੜ ਤੋਂ) ਸਾਫ਼ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "как лотос, выросший в воде, остаётся чистым от грязи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12094,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਦਾ ਨਿਰਦੋਖ ॥",
          "roman": "brahm giānī sadā nirdokh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਮਨੁੱਖ) (ਸਾਰੇ ਪਾਪਾਂ ਨੂੰ ਸਾੜ ਦੇਂਦੇ ਹਨ) ਪਾਪਾਂ ਤੋਂ ਬਚੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни остаётся свободным от грехов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12095,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਸੂਰੁ ਸਰਬ ਕਉ ਸੋਖ ॥",
          "roman": "jēse sūr sarab kau sokh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਸੂਰਜ ਸਾਰੇ (ਰਸਾਂ) ਨੂੰ ਸੁਕਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "как солнце высушивает все соки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12096,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਦ੍ਰਿਸਟਿ ਸਮਾਨਿ ॥",
          "roman": "brahm giānī kē drisaṭ samān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਅੰਦਰ (ਸਭ ਵਲ) ਇਕੋ ਜਿਹੀ ਨਜ਼ਰ (ਨਾਲ ਤੱਕਣ ਦਾ ਸੁਭਾਉ ਹੁੰਦਾ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У брахмгьяни внутри есть одинаковый взгляд на всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12097,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਰਾਜ ਰੰਕ ਕਉ ਲਾਗੈ ਤੁਲਿ ਪਵਾਨ ॥",
          "roman": "jēse rāj rank kau lāgē tul pavān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹਵਾ ਰਾਜੇ ਤੇ ਕੰਗਾਲ ਨੂੰ ਇਕੋ ਜਿਹੀ ਲੱਗਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "как ветер одинаково касается и царя, и нищего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12098,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਧੀਰਜੁ ਏਕ ॥",
          "roman": "brahm giānī kē dhīraj ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੋਈ ਭਲਾ ਕਹੇ ਭਾਵੇਂ ਬੁਰਾ, ਪਰ) ਬ੍ਰਹਮਗਿਆਨੀ ਮਨੁੱਖਾਂ ਦੇ ਅੰਦਰ ਇਕ-ਤਾਰ ਹੌਸਲਾ (ਕਾਇਮ ਰਹਿੰਦਾ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У брахмгьяни внутри постоянно сохраняется ровная стойкость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12099,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਬਸੁਧਾ ਕੋਊ ਖੋਦੈ ਕੋਊ ਚੰਦਨ ਲੇਪ ॥",
          "roman": "jio basudhā koū khodē koū chandan lep",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਧਰਤੀ ਨੂੰ ਕੋਈ ਤਾਂ ਖੋਤਰਦਾ ਹੈ, ਤੇ ਕੋਈ ਚੰਦਨ ਦੇ ਲੇਪਣ ਕਰਦਾ ਹੈ (ਪਰ ਧਰਤੀ ਨੂੰ ਪਰਵਾਹ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "как землю один роет, а другой покрывает сандалом, но земле всё равно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12100,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕਾ ਇਹੈ ਗੁਨਾਉ ॥",
          "roman": "brahm giānī kā ihē guṇāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਮਨੁੱਖਾਂ ਦਾ (ਭੀ) ਇਹੀ ਗੁਣ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Таково и это качество брахмгьяни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12101,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਉ ਪਾਵਕ ਕਾ ਸਹਜ ਸੁਭਾਉ ॥੧॥",
          "roman": "Nānak jio pāvak kā sahaj subhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਵੇਂ ਅੱਗ ਦਾ ਕੁਦਰਤੀ ਸੁਭਾਉ ਹੈ (ਹਰੇਕ ਚੀਜ਼ ਦੀ ਮੈਲ ਸਾੜ ਦੇਣੀ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, каков естественный нрав огня — сжигать всякую нечистоту ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 936,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12102,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਨਿਰਮਲ ਤੇ ਨਿਰਮਲਾ ॥",
          "roman": "brahm giānī nirmal te nirmalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਮਨੁੱਖ (ਵਿਕਾਰਾਂ ਦੀ ਮੈਲ ਤੋਂ ਸਦਾ ਬਚਿਆ ਰਹਿ ਕੇ) ਮਹਾ ਨਿਰਮਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни, всегда оставаясь свободным от грязи пороков, предельно чист,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12103,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਮੈਲੁ ਨ ਲਾਗੈ ਜਲਾ ॥",
          "roman": "jēse mēl na lāgē jalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਨੂੰ ਕਦੇ ਮੈਲ ਨਹੀਂ ਰਹਿ ਸਕਦੀ (ਬੁਖ਼ਾਰਾਤ ਆਦਿਕ ਬਣ ਕੇ ਮੁੜ ਸਾਫ਼ ਦਾ ਸਾਫ਼।)"
            },
            "sahib_singh_ru": {
              "main": "как к воде никогда не пристаёт грязь и она снова становится совсем чистой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12104,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਮਨਿ ਹੋਇ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "brahm giānī kē man hoi pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੇ ਮਨ ਵਿਚ (ਇਹ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ (ਕਿ ਪ੍ਰਭੂ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "В уме брахмгьяни возникает свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12105,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਧਰ ਊਪਰਿ ਆਕਾਸੁ ॥",
          "roman": "jēse dhar ūpar ākās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਧਰਤੀ ਉਤੇ ਆਕਾਸ਼ (ਸਭ ਥਾਂ ਵਿਆਪਕ ਹੈ।)"
            },
            "sahib_singh_ru": {
              "main": "как небо простирается над всей землёй."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12106,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਮਿਤ੍ਰ ਸਤ੍ਰੁ ਸਮਾਨਿ ॥",
          "roman": "brahm giānī kē mitr satr samān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਨੂੰ ਸੱਜਣ ਤੇ ਵੈਰੀ ਇਕੋ ਜਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Для брахмгьяни друг и враг одинаковы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12107,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੈ ਨਾਹੀ ਅਭਿਮਾਨ ॥",
          "roman": "brahm giānī kē nāhī abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕ) ਉਸ ਦੇ ਅੰਦਰ ਅਹੰਕਾਰ ਨਹੀਂ ਹੈ (ਕਿਸੇ ਦੇ ਚੰਗੇ ਮੰਦੇ ਸਲੂਕ ਦਾ ਹਰਖ ਸੋਗ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "потому что в нём нет гордыни и нет ни радости, ни скорби от чьего-либо доброго или дурного обращения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12108,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਊਚ ਤੇ ਊਚਾ ॥",
          "roman": "brahm giānī ūch te ūchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ (ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ) ਸਭ ਤੋਂ ਉੱਚਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни выше всех в духовном состоянии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12109,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਅਪਨੈ ਹੈ ਸਭ ਤੇ ਨੀਚਾ ॥",
          "roman": "man apnē hē sabh te nīchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਆਪਣੇ ਮਨ ਵਿਚ (ਆਪਣੇ ਆਪ ਨੂੰ) ਸਭ ਤੋਂ ਨੀਵਾਂ (ਜਾਣਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "но в своём уме считает себя ниже всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12110,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸੇ ਜਨ ਭਏ ॥",
          "roman": "brahm giānī se jan bhae",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਬ੍ਰਹਮਗਿਆਨੀ ਬਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни становятся только те люди,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12111,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਨ ਪ੍ਰਭੁ ਆਪਿ ਕਰੇਇ ॥੨॥",
          "roman": "Nānak jin prabh āp karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਨ੍ਹਾਂ ਨੂੰ ਪ੍ਰਭੂ ਆਪ ਬਣਾਉਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "которых Сам Господь делает такими, о Нанак ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 937,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12112,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਗਲ ਕੀ ਰੀਨਾ ॥",
          "roman": "brahm giānī sagal kī rīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਸਾਰੇ (ਬੰਦਿਆਂ) ਦੇ ਪੈਰਾਂ ਦੀ ਖ਼ਾਕ (ਹੋ ਕੇ ਰਹਿੰਦਾ) ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни становится пылью у ног всех людей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12113,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮ ਰਸੁ ਬ੍ਰਹਮ ਗਿਆਨੀ ਚੀਨਾ ॥",
          "roman": "ātam ras brahm giānī chīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਨੇ ਆਤਮਕ ਆਨੰਦ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ибо он познал духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12114,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਕੀ ਸਭ ਊਪਰਿ ਮਇਆ ॥",
          "roman": "brahm giānī kī sabh ūpar maiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਦੀ ਸਭ ਉਤੇ ਖ਼ੁਸ਼ੀ ਹੁੰਦੀ ਹੈ (ਭਾਵ, ਬ੍ਰਹਮ-ਗਿਆਨੀ ਸਭ ਨਾਲ ਹੱਸਦੇ-ਮੱਥੇ ਰਹਿੰਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни радуется всем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12115,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਤੇ ਕਛੁ ਬੁਰਾ ਨ ਭਇਆ ॥",
          "roman": "brahm giānī te kachh burā na bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਹ ਕੋਈ ਮੰਦਾ ਕੰਮ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и он не делает ничего дурного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12116,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਗਿਆਨੀ ਸਦਾ ਸਮਦਰਸੀ ॥",
          "roman": "brahm giānī sadā samdarsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਹਮਗਿਆਨੀ ਸਦਾ ਸਭ ਵਲ ਇਕੋ ਜਿਹੀ ਨਜ਼ਰ ਨਾਲ ਤੱਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Брахмгьяни всегда смотрит на всех одинаковым взглядом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
