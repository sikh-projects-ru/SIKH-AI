{
  "ang": 276,
  "shabads": [
    {
      "shabad_id": 955,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12289,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਦੇਵ ਦਾਨਵ ਇੰਦ੍ਰ ਸਿਰਿ ਛਤ੍ਰ ॥",
          "roman": "kaī koṭ dēv dānav indra sir chhatr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਦੇਵਤੇ ਤੇ ਇੰਦ੍ਰ ਹਨ ਜਿਨ੍ਹਾਂ ਦੇ ਸਿਰ ਉਤੇ ਛਤ੍ਰ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "миллионы богов и индр, над головами которых зонты власти;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12290,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸਮਗ੍ਰੀ ਅਪਨੈ ਸੂਤਿ ਧਾਰੈ ॥",
          "roman": "sagal samagrī apnē sūt dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ) ਸਾਰੇ (ਜੀਅ ਜੰਤਾਂ ਤੇ) ਪਦਾਰਥਾਂ ਨੂੰ (ਪ੍ਰਭੂ ਨੇ) ਆਪਣੇ (ਹੁਕਮ ਦੇ) ਧਾਗੇ ਵਿਚ ਪਰੋਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Все эти существа и все эти предметы Бог нанизал на нить Своего Хукама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12291,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸੁ ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਤਿਸੁ ਨਿਸਤਾਰੈ ॥੩॥",
          "roman": "Nānak jis jis bhāvē tis tis nistārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਜੋ ਉਸ ਨੂੰ ਭਾਉਂਦਾ ਹੈ, ਉਸ ਉਸ ਨੂੰ (ਪ੍ਰਭੂ) ਤਾਰ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Кого Он пожелает, того Он и спасает. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 956,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12292,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਰਾਜਸ ਤਾਮਸ ਸਾਤਕ ॥",
          "roman": "kaī koṭ rājas tāmas sātak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ (ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ) ਰਜੋ, ਤਮੋ ਤੇ ਸਤੋ ਵਿਚ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ пребывают в трёх качествах майи: раджас, тамас и саттв,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12293,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਬੇਦ ਪੁਰਾਨ ਸਿਮ੍ਰਿਤਿ ਅਰੁ ਸਾਸਤ ॥",
          "roman": "kaī koṭ bēd purān simrit ar sāsat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ (ਬੰਦੇ) ਵੇਦ ਪੁਰਾਨ ਸਿਮ੍ਰਿਤੀਆਂ ਤੇ ਸ਼ਾਸਤ੍ਰਾਂ (ਦੇ ਪੜ੍ਹਨ ਵਾਲੇ) ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "миллионы людей являются читателями Вед, Пуран, Смрити и Шастр;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12294,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਕੀਏ ਰਤਨ ਸਮੁਦ ॥",
          "roman": "kaī koṭ kīe ratan samud",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਮੁੰਦਰ ਵਿਚ ਕਰੋੜਾਂ ਰਤਨ ਪੈਦਾ ਕਰ ਦਿੱਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В океане сотворены миллионы драгоценностей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12295,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਨਾਨਾ ਪ੍ਰਕਾਰ ਜੰਤ ॥",
          "roman": "kaī koṭ nānā prakār jant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਈ ਕਿਸਮਾਂ ਦੇ ਜੀਅ ਜੰਤ ਬਣਾ ਦਿੱਤੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и созданы многие виды живых существ;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12296,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਕੀਏ ਚਿਰ ਜੀਵੇ ॥",
          "roman": "kaī koṭ kīe chir jīve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ ਲੰਮੀਆਂ ਉਮਰਾਂ ਵਾਲੇ ਪੈਦਾ ਕੀਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Созданы миллионы существ с долгой жизнью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12297,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਗਿਰੀ ਮੇਰ ਸੁਵਰਨ ਥੀਵੇ ॥",
          "roman": "kaī koṭ girī mer suvaran thīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਹੀ ਸੋਨੇ ਦੇ ਸੁਮੇਰ ਪਰਬਤ ਬਣ ਗਏ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и миллионы золотых гор Сумер стали существовать;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12298,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਜਖੵ ਕਿੰਨਰ ਪਿਸਾਚ ॥",
          "roman": "kaī koṭ jakh kinnar pisāch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਹੀ ਜੱਖ ਕਿੰਨਰ ਤੇ ਪਿਸ਼ਾਚ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Есть миллионы якшей, киннаров и пишачей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12299,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਭੂਤ ਪ੍ਰੇਤ ਸੂਕਰ ਮ੍ਰਿਗਾਚ ॥",
          "roman": "kaī koṭ bhūt pret sūkar mrigāch",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਰੋੜਾਂ ਹੀ ਭੂਤ ਪ੍ਰੇਤ ਸੂਰ ਤੇ ਸ਼ੇਰ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и миллионы духов, привидений, свиней и львов;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12300,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਨੇਰੈ ਸਭਹੂ ਤੇ ਦੂਰਿ ॥",
          "roman": "sabh te nērē sabhhū te dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ) ਇਹਨਾਂ ਸਭਨਾਂ ਦੇ ਨੇੜੇ ਭੀ ਹੈ ਤੇ ਦੂਰ ਭੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бог близок ко всем этим и в то же время далёк от всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12301,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਪਿ ਅਲਿਪਤੁ ਰਹਿਆ ਭਰਪੂਰਿ ॥੪॥",
          "roman": "Nānak āp alipat rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਸਭ ਥਾਈਂ ਵਿਆਪਕ ਭੀ ਹੈ ਤੇ ਹੈ ਭੀ ਨਿਰਲੇਪ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Бог всюду присутствует и при этом остаётся непричастным. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 957,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12302,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਪਾਤਾਲ ਕੇ ਵਾਸੀ ॥",
          "roman": "kaī koṭ pātāl ke vāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ ਪਾਤਾਲ ਵਿਚ ਵੱਸਣ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ обитают в нижних мирах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12303,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਨਰਕ ਸੁਰਗ ਨਿਵਾਸੀ ॥",
          "roman": "kaī koṭ narak surag nivāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਰੋੜਾਂ ਹੀ ਨਰਕਾਂ ਤੇ ਸੁਰਗਾਂ ਵਿਚ ਵੱਸਦੇ ਹਨ (ਭਾਵ, ਦੁਖੀ ਤੇ ਸੁਖੀ ਹਨ);"
            },
            "sahib_singh_ru": {
              "main": "и миллионы живут в адах и небесах, то есть пребывают в страдании или в счастье;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12304,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਜਨਮਹਿ ਜੀਵਹਿ ਮਰਹਿ ॥",
          "roman": "kaī koṭ janmah jīvah marah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ ਜੰਮਦੇ ਹਨ, ਜਿਉਂਦੇ ਹਨ ਅਤੇ ਮਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ рождаются, живут и умирают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12305,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਬਹੁ ਜੋਨੀ ਫਿਰਹਿ ॥",
          "roman": "kaī koṭ bah jonī firah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਰੋੜਾਂ ਜੀਵ ਕਈ ਜੂਨਾਂ ਵਿਚ ਭਟਕ ਰਹੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и миллионы скитаются по многим формам существования;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12306,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਬੈਠਤ ਹੀ ਖਾਹਿ ॥",
          "roman": "kaī koṭ bēṭhat hī khāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ ਬੈਠੇ ਹੀ ਖਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ едят сидя без труда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12307,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਘਾਲਹਿ ਥਕਿ ਪਾਹਿ ॥",
          "roman": "kaī koṭ ghālah thak pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਰੋੜਾਂ (ਐਸੇ ਹਨ ਜੋ ਰੋਟੀ ਦੀ ਖ਼ਾਤਰ) ਮੇਹਨਤ ਕਰਦੇ ਹਨ ਤੇ ਥੱਕ ਟੁੱਟ ਜਾਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "а миллионы ради куска хлеба трудятся и изнемогают;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12308,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਕੀਏ ਧਨਵੰਤ ॥",
          "roman": "kaī koṭ kīe dhanvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ (ਪ੍ਰਭੂ ਨੇ) ਧਨ ਵਾਲੇ ਬਣਾਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ Бог сделал богатыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12309,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਮਾਇਆ ਮਹਿ ਚਿੰਤ ॥",
          "roman": "kaī koṭ māiā mah chint",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਰੋੜਾਂ (ਐਸੇ ਹਨ ਜਿਨ੍ਹਾਂ ਨੂੰ) ਮਾਇਆ ਦਾ ਫ਼ਿਕਰ ਲੱਗਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а миллионы охвачены заботой о майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12310,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜਹ ਭਾਣਾ ਤਹ ਤਹ ਰਾਖੇ ॥",
          "roman": "jah jah bhāṇā tah tah rākhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਜਿਥੇ ਚਾਹੁੰਦਾ ਹੈ, ਜੀਵਾਂ ਨੂੰ ਓਥੇ ਓਥੇ ਹੀ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где Ему угодно, там Он и держит живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12311,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਭੁ ਕਿਛੁ ਪ੍ਰਭ ਕੈ ਹਾਥੇ ॥੫॥",
          "roman": "Nānak sabh kichh prabh kē hāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਹਰੇਕ ਗੱਲ ਪ੍ਰਭੂ ਦੇ ਆਪਣੇ ਹੱਥ ਵਿਚ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Всё находится в руке Бога. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 958,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12312,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਭਏ ਬੈਰਾਗੀ ॥",
          "roman": "kaī koṭ bhaē bērāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਰਚਨਾ ਵਿਚ) ਕਰੋੜਾਂ ਜੀਵ ਵੈਰਾਗ ਵਾਲੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В этом творении миллионы существ стали отрешёнными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12313,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਸੰਗਿ ਤਿਨਿ ਲਿਵ ਲਾਗੀ ॥",
          "roman": "rām nām sang tin liv lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੀ ਸੁਰਤ ਅਕਾਲ ਪੁਰਖ ਦੇ ਨਾਮ ਨਾਲ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "их сознание прилеплено к Имени Акал Пуракха;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12314,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਪ੍ਰਭ ਕਉ ਖੋਜੰਤੇ ॥",
          "roman": "kaī koṭ prabh kau khojante",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਬੰਦੇ ਪ੍ਰਭੂ ਨੂੰ ਖੋਜਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы людей ищут Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12315,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮ ਮਹਿ ਪਾਰਬ੍ਰਹਮੁ ਲਹੰਤੇ ॥",
          "roman": "ātam mah pārabrahm lahante",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਆਪਣੇ ਅੰਦਰ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਭਾਲਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и находят Акал Пуракха внутри себя;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12316,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਦਰਸਨ ਪ੍ਰਭ ਪਿਆਸ ॥",
          "roman": "kaī koṭ darsan prabh piās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵਾਂ ਨੂੰ ਪ੍ਰਭੂ ਦੇ ਦੀਦਾਰ ਦੀ ਤਾਂਘ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ томятся жаждой узреть Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12317,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕਉ ਮਿਲਿਓ ਪ੍ਰਭੁ ਅਬਿਨਾਸ ॥",
          "roman": "tin kau miliō prabh abinās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਅਬਿਨਾਸੀ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и им является нетленный Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12318,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਮਾਗਹਿ ਸਤਸੰਗੁ ॥",
          "roman": "kaī koṭ māgah satsang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਮਨੁੱਖ ਸਤ-ਸੰਗ ਮੰਗਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы людей просят сатсанг,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12319,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਤਿਨ ਲਾਗਾ ਰੰਗੁ ॥",
          "roman": "pārabrahm tin lāgā rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਅਕਾਲ ਪੁਰਖ ਦਾ ਇਸ਼ਕ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и в них живёт любовь к Акал Пуракху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12320,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕਉ ਹੋਏ ਆਪਿ ਸੁਪ੍ਰਸੰਨ ॥",
          "roman": "jin kau hoē āp suprasann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਉਤੇ ਪ੍ਰਭੂ ਆਪ ਤ੍ਰੁੱਠਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Сам Бог бывает доволен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12321,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇ ਜਨ ਸਦਾ ਧਨਿ ਧੰਨਿ ॥੬॥",
          "roman": "Nānak te jan sadā dhan dhann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਸਦਾ ਭਾਗਾਂ ਵਾਲੇ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, те люди всегда поистине благословенны. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 959,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12322,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਖਾਣੀ ਅਰੁ ਖੰਡ ॥",
          "roman": "kaī koṭ khāṇī ar khaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਧਰਤੀ ਦੇ ਨੌ) ਖੰਡਾਂ (ਚਹੁੰਆਂ) ਖਾਣੀਆਂ ਦੀ ਰਾਹੀਂ ਕਰੋੜਾਂ ਹੀ ਜੀਵ ਉਤਪੰਨ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Через четыре источника рождения и в девяти частях земли возникли многие миллионы существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12323,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਅਕਾਸ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "kaī koṭ akās brahmaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਆਕਾਸ਼ਾਂ ਬ੍ਰਹਮੰਡਾਂ ਵਿਚ ਕਰੋੜਾਂ ਹੀ ਜੀਵ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "и во всех небесах и вселенных есть многие миллионы существ;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12324,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਹੋਏ ਅਵਤਾਰ ॥",
          "roman": "kaī koṭ hoē avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਹੀ ਪ੍ਰਾਣੀ ਪੈਦਾ ਹੋ ਰਹੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Многие миллионы существ продолжают рождаться;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12325,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਜੁਗਤਿ ਕੀਨੋ ਬਿਸਥਾਰ ॥",
          "roman": "kaī jugat kīno bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਪ੍ਰਭੂ ਨੇ ਜਗਤ ਦੀ ਰਚਨਾ ਕੀਤੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "многими способами Бог создал развёрнутое творение мира;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12326,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਬਾਰ ਪਸਰਿਓ ਪਾਸਾਰ ॥",
          "roman": "kaī bār pasariō pāsār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨੇ) ਕਈ ਵਾਰੀ ਜਗਤ-ਰਚਨਾ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Много раз Бог разворачивал творение мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12327,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਇਕੁ ਏਕੰਕਾਰ ॥",
          "roman": "sadā sadā ik ekankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੁੜ ਇਸ ਨੂੰ ਸਮੇਟ ਕੇ) ਸਦਾ-ਇਕ ਆਪ ਹੀ ਹੋ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "а затем, свернув его обратно, вечно остаётся Один Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12328,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਕੀਨੇ ਬਹੁ ਭਾਤਿ ॥",
          "roman": "kaī koṭ kīne bah bhāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਕਈ ਕਿਸਮਾਂ ਦੇ ਕਰੋੜਾਂ ਹੀ ਜੀਵ ਪੈਦਾ ਕੀਤੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Бог создал многие миллионы существ разных видов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12329,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਤੇ ਹੋਏ ਪ੍ਰਭ ਮਾਹਿ ਸਮਾਤਿ ॥",
          "roman": "prabh te hoē prabh māh samāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪ੍ਰਭੂ ਤੋਂ ਪੈਦਾ ਹੋ ਕੇ ਫਿਰ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они выходят из Бога и снова сливаются в Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12330,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਅੰਤੁ ਨ ਜਾਨੈ ਕੋਇ ॥",
          "roman": "tā kā ant na jānē kōi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਦਾ ਅੰਤ ਕੋਈ ਬੰਦਾ ਨਹੀਂ ਜਾਣਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "Предела этого Бога не знает ни один человек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12331,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਨਾਨਕ ਪ੍ਰਭੁ ਸੋਇ ॥੭॥",
          "roman": "āpe āp Nānak prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਉਹ ਪ੍ਰਭੂ (ਆਪਣੇ ਵਰਗਾ) ਆਪ ਹੀ ਆਪ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "потому что, о Нанак, этот Бог Сам подобен только Самому Себе. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 960,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12332,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਪਾਰਬ੍ਰਹਮ ਕੇ ਦਾਸ ॥",
          "roman": "kaī koṭ pārabrahm ke dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਜਗਤ-ਰਚਨਾ ਵਿਚ) ਕਰੋੜਾਂ ਜੀਵ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ (ਭਗਤ) ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В этом творении мира миллионы существ являются слугами, то есть бхагатами Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12333,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਹੋਵਤ ਆਤਮ ਪਰਗਾਸ ॥",
          "roman": "tin hovat ātam pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਆਤਮ ਵਿਚ (ਪ੍ਰਭੂ ਦਾ) ਪਰਕਾਸ਼ ਹੋ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "и в их душе раскрывается свет Бога;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12334,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਤਤ ਕੇ ਬੇਤੇ ॥",
          "roman": "kaī koṭ tat ke bēte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਜੀਵ (ਜਗਤ ਦੇ) ਅਸਲੇ (ਅਕਾਲ ਪੁਰਖ) ਦੇ ਮਹਰਮ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы существ являются знающими сущность мира, то есть Акал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12335,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਨਿਹਾਰਹਿ ਏਕੋ ਨੇਤ੍ਰੇ ॥",
          "roman": "sadā nihārah eko nētre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਦਾ ਇੱਕ ਪ੍ਰਭੂ ਨੂੰ ਅੱਖਾਂ ਨਾਲ (ਹਰ ਥਾਂ) ਵੇਖਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "они всегда видят одного Бога своими глазами повсюду;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12336,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਨਾਮ ਰਸੁ ਪੀਵਹਿ ॥",
          "roman": "kaī koṭ nām ras pīvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੋੜਾਂ ਬੰਦੇ ਪ੍ਰਭੂ-ਨਾਮ ਦਾ ਆਨੰਦ ਮਾਣਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы людей пьют нектар Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12337,
          "is_rahao": false,
          "gurmukhi": "ਅਮਰ ਭਏ ਸਦ ਸਦ ਹੀ ਜੀਵਹਿ ॥",
          "roman": "amar bhaē sad sad hī jīvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਨਮ ਮਰਨ ਤੋਂ ਰਹਿਤ ਹੋ ਕੇ ਸਦਾ ਹੀ ਜੀਊਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они становятся бессмертными, освобождаясь от рождения и смерти, и живут вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12338,
          "is_rahao": false,
          "gurmukhi": "ਕਈ ਕੋਟਿ ਨਾਮ ਗੁਨ ਗਾਵਹਿ ॥",
          "roman": "kaī koṭ nām gun gāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕ੍ਰੋੜਾਂ ਮਨੁੱਖ ਪ੍ਰਭੂ-ਨਾਮ ਦੇ ਗੁਣ ਗਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Миллионы людей поют достоинства Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12339,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮ ਰਸਿ ਸੁਖਿ ਸਹਜਿ ਸਮਾਵਹਿ ॥",
          "roman": "ātam ras sukh sahaj samāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਤਮਕ ਆਨੰਦ ਵਿਚ ਸੁਖ ਵਿਚ ਤੇ ਅਡੋਲ ਅਵਸਥਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они пребывают в духовном блаженстве, в покое и в естественной уравновешенности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12340,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਜਨ ਕਉ ਸਾਸਿ ਸਾਸਿ ਸਮਾਰੇ ॥",
          "roman": "apune jan kau sās sās samāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਭਗਤਾਂ ਨੂੰ ਦਮ-ਬ-ਦਮ ਚੇਤੇ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог каждое дыхание помнит Своих преданных,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12341,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਓਇ ਪਰਮੇਸੁਰ ਕੇ ਪਿਆਰੇ ॥੮॥੧੦॥",
          "roman": "Nānak oi parmēsar ke piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੇ ਨਾਨਕ! ਉਹ ਭਗਤ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰੇ ਹੁੰਦੇ ਹਨ ॥੮॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "потому что, о Нанак, эти преданные дороги Богу. ॥8॥10॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 961,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12342,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12343,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਪ੍ਰਭੁ ਏਕੁ ਹੈ ਦੂਸਰ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "karaṇ kāraṇ prabh ek hē dūsar nāhī koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਸਾਰੇ) ਜਗਤ ਦਾ (ਮੂਲ-) ਕਾਰਣ (ਭਾਵ, ਬਣਾਉਣ ਵਾਲਾ) ਇਕ ਅਕਾਲ ਪੁਰਖ ਹੀ ਹੈ, ਕੋਈ ਦੂਜਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Причина причин всего этого мира — только один Акал Пуракх, другого нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12344,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਬਲਿਹਾਰਣੈ ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਸੋਇ ॥੧॥",
          "roman": "Nānak tis balihāraṇē jal thal mahīal soe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਮੈਂ) ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਸਦਕੇ (ਹਾਂ), ਜੋ ਜਲ ਵਿਚ ਥਲ ਵਿਚ ਤੇ ਧਰਤੀ ਦੇ ਤਲ ਉਤੇ (ਭਾਵ, ਆਕਾਸ਼ ਵਿਚ ਮੌਜੂਦ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Я жертвую себя Тому Господу, Который присутствует в воде, на суше и над землёй, то есть в небе. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 962,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12345,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12346,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਕਰਨੈ ਜੋਗੁ ॥",
          "roman": "karan karāvan karnē jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ (ਸਭ ਕੁਝ) ਕਰਨ ਦੀ ਸਮਰੱਥਾ ਰੱਖਦਾ ਹੈ, ਤੇ (ਜੀਆਂ ਨੂੰ) ਕੰਮ ਕਰਨ ਲਈ ਪ੍ਰੇਰਨ ਜੋਗਾ ਭੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь способен всё делать и также способен побуждать живых существ к действию,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12347,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋਈ ਹੋਗੁ ॥",
          "roman": "jo tis bhāvē soe hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਹੀ ਕੁਝ ਹੁੰਦਾ ਹੈ ਜੋ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и происходит только то, что Ему угодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12348,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਥਾਪਿ ਉਥਾਪਨਹਾਰਾ ॥",
          "roman": "khin mah thāp uthāpanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖ ਦੇ ਫੋਰ ਵਿਚ ਜਗਤ ਨੂੰ ਪੈਦਾ ਕਰ ਕੇ ਨਾਸ ਭੀ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в мгновение ока Он создаёт мир и также уничтожает его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
