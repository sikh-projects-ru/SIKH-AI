{
  "ang": 277,
  "shabads": [
    {
      "shabad_id": 962,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12349,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤੁ ਨਹੀ ਕਿਛੁ ਪਾਰਾਵਾਰਾ ॥",
          "roman": "ant nahī kichh pārāvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਤਾਕਤ) ਦਾ ਕੋਈ ਹੱਦ-ਬੰਨਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у Его силы нет никакого предела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12350,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਧਾਰਿ ਅਧਰ ਰਹਾਵੈ ॥",
          "roman": "hukme dhār adhar rahāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸ੍ਰਿਸ਼ਟੀ ਨੂੰ ਆਪਣੇ) ਹੁਕਮ ਵਿਚ ਪੈਦਾ ਕਰ ਕੇ ਬਿਨਾ ਕਿਸੇ ਆਸਰੇ ਟਿਕਾ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По Своему Хукаму Он создаёт творение и держит его без всякой опоры,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12351,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਉਪਜੈ ਹੁਕਮਿ ਸਮਾਵੈ ॥",
          "roman": "hukme upjē hukam samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਉਸ ਦੇ) ਹੁਕਮ ਵਿਚ ਪੈਦਾ ਹੁੰਦਾ ਹੈ ਤੇ ਹੁਕਮ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по Хукаму мир возникает и по Хукаму растворяется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12352,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਊਚ ਨੀਚ ਬਿਉਹਾਰ ॥",
          "roman": "hukme ūch nīch biuhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉੱਚੇ ਤੇ ਨੀਵੇਂ ਬੰਦਿਆਂ ਦੀ ਵਰਤੋਂ ਭੀ ਉਸ ਦੇ ਹੁਕਮ ਵਿਚ ਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "И положение высоких и низких людей тоже существует по Его Хукаму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12353,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਅਨਿਕ ਰੰਗ ਪਰਕਾਰ ॥",
          "roman": "hukme anik raṅg parkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਖੇਡ-ਤਮਾਸ਼ੇ ਉਸ ਦੇ ਹੁਕਮ ਵਿਚ ਹੋ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и бесчисленные виды игр и зрелищ происходят по Его Хукаму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12354,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਰਿ ਦੇਖੈ ਅਪਨੀ ਵਡਿਆਈ ॥",
          "roman": "kar kar dekhē apnī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ ਬਜ਼ੁਰਗੀ (ਦੇ ਕੰਮ) ਕਰ ਕਰ ਕੇ ਆਪ ਹੀ ਵੇਖ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам, совершая Свои великие деяния, Сам же на них и смотрит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12355,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਭ ਮਹਿ ਰਹਿਆ ਸਮਾਈ ॥੧॥",
          "roman": "Nānak sabh mahi rahiā samāī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Господь пронизывает всех существ. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 963,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12356,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਭਾਵੈ ਮਾਨੁਖ ਗਤਿ ਪਾਵੈ ॥",
          "roman": "prabh bhāvē mānukh gat pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਪ੍ਰਭੂ ਨੂੰ ਚੰਗੀ ਲੱਗੇ ਤਾਂ ਮਨੁੱਖ ਨੂੰ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если Господу угодно, Он дарует человеку высокое духовное состояние,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12357,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਭਾਵੈ ਤਾ ਪਾਥਰ ਤਰਾਵੈ ॥",
          "roman": "prabh bhāvē tā pāthar tarāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪੱਥਰ (-ਦਿਲਾਂ) ਨੂੰ ਭੀ ਤਾਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и даже каменные сердцем переправляет через мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12358,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਭਾਵੈ ਬਿਨੁ ਸਾਸ ਤੇ ਰਾਖੈ ॥",
          "roman": "prabh bhāvē bin sās te rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਪ੍ਰਭੂ ਚਾਹੇ ਤਾਂ ਸੁਆਸਾਂ ਤੋਂ ਬਿਨਾ ਭੀ ਪ੍ਰਾਣੀ ਨੂੰ (ਮੌਤ ਤੋਂ) ਬਚਾ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если Господь пожелает, Он хранит живое существо от смерти даже без дыхания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12359,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਭਾਵੈ ਤਾ ਹਰਿ ਗੁਣ ਭਾਖੈ ॥",
          "roman": "prabh bhāvē tā har guṇ bhākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਮੇਹਰ ਹੋਵੇ ਤਾਂ ਜੀਵ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если приходит Его милость, живое существо воспевает качества Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12360,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਭਾਵੈ ਤਾ ਪਤਿਤ ਉਧਾਰੈ ॥",
          "roman": "prabh bhāvē tā patit udhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਅਕਾਲ ਪੁਰਖ ਦੀ ਰਜ਼ਾ ਹੋਵੇ ਤਾਂ ਗਿਰੇ ਹੋਏ ਚਲਨ ਵਾਲਿਆਂ ਨੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲੈਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Если такова воля Акал Пуракха, Он спасает от пороков даже падших по своему поведению;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12361,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਕਰੈ ਆਪਨ ਬੀਚਾਰੈ ॥",
          "roman": "āp karē āpan bīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ, ਆਪਣੀ ਸਲਾਹ ਅਨੁਸਾਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что бы Он ни делал, делает по Своему собственному замыслу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12362,
          "is_rahao": false,
          "gurmukhi": "ਦੁਹਾ ਸਿਰਿਆ ਕਾ ਆਪਿ ਸੁਆਮੀ ॥",
          "roman": "duhā siriā kā āp suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਲੋਕ ਪਰਲੋਕ ਦਾ ਮਾਲਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам — Владыка и этого мира, и мира иного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12363,
          "is_rahao": false,
          "gurmukhi": "ਖੇਲੈ ਬਿਗਸੈ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "khelē bigsē antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਆਪ ਜਗਤ-ਖੇਡ ਖੇਡਦਾ ਹੈ ਤੇ (ਇਸ ਨੂੰ ਵੇਖ ਕੇ) ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он, Знающий сердца всех, Сам играет в мировую игру и, глядя на неё, радуется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12364,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਭਾਵੈ ਸੋ ਕਾਰ ਕਰਾਵੈ ॥",
          "roman": "jo bhāvē so kār karāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ਉਹੀ ਕੰਮ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что Ему нравится, то дело Он и совершает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12365,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦ੍ਰਿਸਟੀ ਅਵਰੁ ਨ ਆਵੈ ॥੨॥",
          "roman": "Nānak drisṭī avar na āvē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਸ ਵਰਗਾ) ਕੋਈ ਹੋਰ ਨਹੀਂ ਦਿੱਸਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Другого, подобного Ему, не видно. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 964,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12366,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਮਾਨੁਖ ਤੇ ਕਿਆ ਹੋਇ ਆਵੈ ॥",
          "roman": "kah mānukh te kiā hoe āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ, ਮਨੁੱਖ ਪਾਸੋਂ (ਆਪਣੇ ਆਪ) ਕੇਹੜਾ ਕੰਮ ਹੋ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Скажите, что человек может сделать сам по себе?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12367,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋਈ ਕਰਾਵੈ ॥",
          "roman": "jo tis bhāvē soe karāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪ੍ਰਭੂ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ, ਉਹੀ (ਜੀਵ ਪਾਸੋਂ) ਕਰਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что Господу угодно, то Он и заставляет живое существо делать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12368,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਕੈ ਹਾਥਿ ਹੋਇ ਤਾ ਸਭੁ ਕਿਛੁ ਲੇਇ ॥",
          "roman": "is kē hāth hoe tā sabh kichh lei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਮਨੁੱਖ) ਦੇ ਵੱਸ ਹੋਵੇ ਤਾਂ ਹਰੇਕ ਚੀਜ਼ ਸਾਂਭ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Будь это во власти человека, он удержал бы всякую вещь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12369,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋਈ ਕਰੇਇ ॥",
          "roman": "jo tis bhāvē soe karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪ੍ਰਭੂ ਉਹੀ ਕੁਝ ਕਰਦਾ ਹੈ ਜੋ ਉਸ ਨੂੰ ਭਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но Господь делает только то, что Ему по нраву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12370,
          "is_rahao": false,
          "gurmukhi": "ਅਨਜਾਨਤ ਬਿਖਿਆ ਮਹਿ ਰਚੈ ॥",
          "roman": "anjānat bikhiā mah rachē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖਤਾ ਦੇ ਕਾਰਣ ਮਨੁੱਖ ਮਾਇਆ ਵਿਚ ਰੁੱਝ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По своей глупости человек запутывается в майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12371,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਜਾਨਤ ਆਪਨ ਆਪ ਬਚੈ ॥",
          "roman": "je jānat āpan āp bachē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਸਮਝ ਵਾਲਾ ਹੋਵੇ ਤਾਂ ਆਪਣੇ ਆਪ (ਇਸ ਤੋਂ) ਬਚਿਆ ਰਹੇ;"
            },
            "sahib_singh_ru": {
              "main": "а если бы был разумен, то сам бы уберёгся от этого;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12372,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮੇ ਭੂਲਾ ਦਹ ਦਿਸਿ ਧਾਵੈ ॥",
          "roman": "bharme bhūlā dah dis dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਸ ਦਾ ਮਨ) ਭੁਲੇਖੇ ਵਿਚ ਭੁੱਲਾ ਹੋਇਆ (ਮਾਇਆ ਦੀ ਖ਼ਾਤਿਰ) ਦਸੀਂ ਪਾਸੀਂ ਦੌੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но его ум, заблудившись в обмане, мечется ради майи во все десять сторон,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12373,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਮਾਹਿ ਚਾਰਿ ਕੁੰਟ ਫਿਰਿ ਆਵੈ ॥",
          "roman": "nimakh māh chār kuṇṭ phir āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖ ਦੇ ਫੋਰ ਵਿਚ ਚਹੁੰ ਕੂਟਾਂ ਵਿਚ ਭੱਜ ਦੌੜ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в мгновение ока носится по четырём сторонам света."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12374,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਅਪਨੀ ਭਗਤਿ ਦੇਇ ॥",
          "roman": "kar kirpā jis apnī bhagat dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ) ਮੇਹਰ ਕਰ ਕੇ ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੀ ਭਗਤੀ ਬਖ਼ਸ਼ਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кому Господь по милости дарует Своё бхагти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12375,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੇ ਜਨ ਨਾਮਿ ਮਿਲੇਇ ॥੩॥",
          "roman": "Nānak te jan nām milei ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਨਾਮ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, те люди пребывают в Имени. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 965,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12376,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਨੀਚ ਕੀਟ ਕਉ ਰਾਜ ॥",
          "roman": "khin mah nīch kīṭ kau rāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਖਿਣ ਵਿਚ ਪ੍ਰਭੂ ਕੀੜੇ (ਵਰਗੇ) ਨੀਵੇਂ (ਮਨੁੱਖ) ਨੂੰ ਰਾਜ ਦੇ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В миг Господь может дать царство даже низкому человеку, подобному червю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12377,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗਰੀਬ ਨਿਵਾਜ ॥",
          "roman": "Pārbrahm garīb nivāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਗ਼ਰੀਬਾਂ ਤੇ ਮੇਹਰ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ведь Господь милостив к бедным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12378,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਦ੍ਰਿਸਟਿ ਕਛੂ ਨ ਆਵੈ ॥",
          "roman": "jā kā drisṭ kachhū na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਕੋਈ ਗੁਣ ਨਹੀਂ ਦਿੱਸ ਆਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, в ком не видно никаких достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12379,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਤਤਕਾਲ ਦਹ ਦਿਸ ਪ੍ਰਗਟਾਵੈ ॥",
          "roman": "tis tatkāl dah dis pragaṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਪਲਕ ਵਿਚ ਦਸੀਂ ਪਾਸੀਂ ਉੱਘਾ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "может в одно мгновение стать прославленным во всех десяти направлениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12380,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਅਪੁਨੀ ਕਰੈ ਬਖਸੀਸ ॥",
          "roman": "jā kau apunī karē bakhsīs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਤੇ ਜਗਤ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਆਪਣੀ ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "На кого Владыка мира изливает Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12381,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਲੇਖਾ ਨ ਗਨੈ ਜਗਦੀਸ ॥",
          "roman": "tā kā lekhā na ganē Jagdīs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ (ਕਰਮਾਂ ਦਾ) ਲੇਖਾ ਨਹੀਂ ਗਿਣਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "того счета его деяниям Владыка мира не ведёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12382,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਸਭ ਤਿਸ ਕੀ ਰਾਸਿ ॥",
          "roman": "jīu piṇḍ sabh tis kī rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਿੰਦ ਤੇ ਸਰੀਰ ਸਭ ਉਸ ਪ੍ਰਭੂ ਦੀ ਦਿੱਤੀ ਹੋਈ ਪੂੰਜੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Эта душа и это тело — всё капитал, данный тем Господом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12383,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਪੂਰਨ ਬ੍ਰਹਮ ਪ੍ਰਗਾਸ ॥",
          "roman": "ghaṭ ghaṭ pūran brahm pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪਕ ਪ੍ਰਭੂ ਦਾ ਹੀ ਜਲਵਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в каждом теле сияет только вездесущий Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12384,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਬਣਤ ਆਪਿ ਬਨਾਈ ॥",
          "roman": "apnī baṇat āp banāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ (ਜਗਤ-) ਰਚਨਾ ਉਸ ਨੇ ਆਪ ਰਚੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это мироздание Он Сам создал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12385,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੀਵੈ ਦੇਖਿ ਬਡਾਈ ॥੪॥",
          "roman": "Nānak jīvē dekhi baḍāī ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਆਪਣੀ (ਇਸ) ਬਜ਼ੁਰਗੀ ਨੂੰ ਆਪ ਵੇਖ ਕੇ ਖ਼ੁਸ਼ ਹੋ ਰਿਹਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Видя это Своё величие, Он Сам радуется. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 966,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12386,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਕਾ ਬਲੁ ਨਾਹੀ ਇਸੁ ਹਾਥ ॥",
          "roman": "is kā bal nāhī is hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਜੀਵ) ਦੀ ਤਾਕਤ ਇਸ ਦੇ ਆਪਣੇ ਹੱਥ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сила этого существа не находится в его собственных руках,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12387,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਸਰਬ ਕੋ ਨਾਥ ॥",
          "roman": "karan karāvan sarab ko nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਆਪ ਸਭ ਕੁਝ ਕਰਨ ਕਰਾਉਣ ਦੇ ਸਮਰੱਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Владыка всех существ Сам способен всё делать и побуждать ко всему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12388,
          "is_rahao": false,
          "gurmukhi": "ਆਗਿਆਕਾਰੀ ਬਪੁਰਾ ਜੀਉ ॥",
          "roman": "āgiākārī bapurā jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਚਾਰਾ ਜੀਵ ਪ੍ਰਭੂ ਦੇ ਹੁਕਮ ਵਿਚ ਹੀ ਤੁਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бедное живое существо лишь следует Хукаму Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12389,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋਈ ਫੁਨਿ ਥੀਉ ॥",
          "roman": "jo tis bhāvē soe phun thīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਹੁੰਦਾ ਓਹੀ ਹੈ ਜੋ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਭਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что происходит только то, что угодно тому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12390,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਊਚ ਨੀਚ ਮਹਿ ਬਸੈ ॥",
          "roman": "kabhū ūch nīch mah basē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਆਪ) ਕਦੇ ਉੱਚਿਆਂ ਵਿਚ ਕਦੇ ਨੀਵਿਆਂ ਵਿਚ ਪ੍ਰਗਟ ਹੋ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иногда Сам Господь проявляется среди высоких, а иногда среди низких,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12391,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਸੋਗ ਹਰਖ ਰੰਗਿ ਹਸੈ ॥",
          "roman": "kabhū sog harakh raṅg hasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਚਿੰਤਾ ਵਿਚ ਹੈ ਤੇ ਕਦੇ ਖੁਸ਼ੀ ਦੀ ਮੌਜ ਵਿਚ ਹੱਸ ਰਿਹਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "иногда пребывает в печали, а иногда смеётся в радости и веселье;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12392,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਨਿੰਦ ਚਿੰਦ ਬਿਉਹਾਰ ॥",
          "roman": "kabhū nind chind biuhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ (ਦੂਜਿਆਂ ਦੀ) ਨਿੰਦਿਆ ਵਿਚਾਰਨ ਦਾ ਵਿਹਾਰ ਬਣਾਈ ਬੈਠਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "иногда занят разбором и осуждением других,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12393,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਊਭ ਅਕਾਸ ਪਇਆਲ ॥",
          "roman": "kabhū ūbh akās paiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ (ਖ਼ੁਸ਼ੀ ਦੇ ਕਾਰਣ) ਅਕਾਸ਼ ਵਿਚ ਉੱਚਾ (ਚੜ੍ਹਦਾ ਹੈ) (ਕਦੇ ਚਿੰਤਾ ਦੇ ਕਾਰਣ) ਪਤਾਲ ਵਿਚ (ਡਿੱਗਾ ਪਿਆ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "иногда поднимается высоко до неба, а иногда падает в подземный мир;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12394,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਬੇਤਾ ਬ੍ਰਹਮ ਬੀਚਾਰ ॥",
          "roman": "kabhū betā brahm bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਆਪ ਹੀ ਰੱਬੀ ਵਿਚਾਰ ਦਾ ਮਹਰਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "иногда Сам является знатоком божественного размышления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12395,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਪਿ ਮਿਲਾਵਣਹਾਰ ॥੫॥",
          "roman": "Nānak āp milāvaṇhār ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੀਵਾਂ ਨੂੰ ਆਪਣੇ ਵਿਚ ਮੇਲਣ ਵਾਲਾ ਆਪ ਹੀ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Он Сам соединяет живых существ с Собой. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 967,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12396,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਨਿਰਤਿ ਕਰੈ ਬਹੁ ਭਾਤਿ ॥",
          "roman": "kabhū nirat karē bah bhāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ) ਕਦੇ ਕਈ ਕਿਸਮਾਂ ਦੇ ਨਾਚ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иногда, пронизывая живых существ, Он совершает множество разных танцев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12397,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਸੋਇ ਰਹੈ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "kabhū soe rahē din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਦਿਨੇ ਰਾਤ ਸੁੱਤਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "иногда день и ночь спит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12398,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਮਹਾ ਕ੍ਰੋਧ ਬਿਕਰਾਲ ॥",
          "roman": "kabhū mahā krodh bikrāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਕ੍ਰੋਧ (ਵਿਚ ਆ ਕੇ) ਬੜਾ ਡਰਾਉਣਾ (ਲੱਗਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Иногда в гневе выглядит очень страшным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12399,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂੰ ਸਰਬ ਕੀ ਹੋਤ ਰਵਾਲ ॥",
          "roman": "kabhūṅ sarab kī hot ravāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਜੀਵਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ (ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "иногда становится пылью у ног всех живых существ;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12400,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਹੋਇ ਬਹੈ ਬਡ ਰਾਜਾ ॥",
          "roman": "kabhū hoe bahē baḍ rājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਵੱਡਾ ਰਾਜਾ ਬਣ ਬੈਠਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "иногда восседает как великий царь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12401,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੁ ਭੇਖਾਰੀ ਨੀਚ ਕਾ ਸਾਜਾ ॥",
          "roman": "kabh bhekhārī nīch kā sājā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਇਕ ਨੀਵੀਂ ਜਾਤਿ ਦੇ ਮੰਗਤੇ ਦਾ ਸਾਂਗ (ਬਣਾ ਰੱਖਿਆ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "иногда принимает облик нищего из низкой касты;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12402,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਅਪਕੀਰਤਿ ਮਹਿ ਆਵੈ ॥",
          "roman": "kabhū apkīrat mah āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਆਪਣੀ ਬਦਨਾਮੀ ਕਰਾ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "иногда сам навлекает на себя дурную славу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12403,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਭਲਾ ਭਲਾ ਕਹਾਵੈ ॥",
          "roman": "kabhū bhalā bhalā kahāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਚੰਗਾ ਅਖਵਾ ਰਿਹਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "иногда даёт называть себя хорошим;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12404,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪ੍ਰਭੁ ਰਾਖੈ ਤਿਵ ਹੀ ਰਹੈ ॥",
          "roman": "jiu prabh rākhē tiv hī rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਉਸੇ ਤਰ੍ਹਾਂ ਜੀਵਨ ਬਿਤੀਤ ਕਰਦਾ ਹੈ ਜਿਵੇਂ ਪ੍ਰਭੂ ਕਰਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Живое существо проводит жизнь так, как Господь велит ему жить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12405,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਸਚੁ ਕਹੈ ॥੬॥",
          "roman": "gur prasād Nānak sach kahē ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Лишь редкий человек по милости Гуру помнит Господа. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 968,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12406,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਹੋਇ ਪੰਡਿਤੁ ਕਰੇ ਬਖੵਾਨੁ ॥",
          "roman": "kabhū hoe paṇḍit kre bakhyān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਰਬ-ਵਿਆਪੀ ਪ੍ਰਭੂ) ਕਦੇ ਪੰਡਤ ਬਣ ਕੇ (ਦੂਜਿਆਂ ਨੂੰ) ਉਪਦੇਸ਼ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иногда всепроникающий Господь, став пандитом, наставляет других,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12407,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਮੋਨਿਧਾਰੀ ਲਾਵੈ ਧਿਆਨੁ ॥",
          "roman": "kabhū monidhārī lāvē dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਮੋਨੀ ਸਾਧੂ ਹੋ ਕੇ ਸਮਾਧੀ ਲਾਈ ਬੈਠਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "иногда, став безмолвным садху, сидит в самадхи;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12408,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਤਟ ਤੀਰਥ ਇਸਨਾਨ ॥",
          "roman": "kabhū taṭ tīrath isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਤੀਰਥਾਂ ਦੇ ਕਿਨਾਰੇ ਇਸ਼ਨਾਨ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "иногда совершает омовение на берегах святых мест,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12409,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਸਿਧ ਸਾਧਿਕ ਮੁਖਿ ਗਿਆਨ ॥",
          "roman": "kabhū sidh sādhik mukh giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਸਿੱਧ ਤੇ ਸਾਧਿਕ (ਦੇ ਰੂਪ ਵਿਚ) ਮੂੰਹੋਂ ਗਿਆਨ ਦੀਆਂ ਗੱਲਾਂ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "иногда в образе сиддха и садхака говорит устами слова знания;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12410,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਕੀਟ ਹਸਤਿ ਪਤੰਗ ਹੋਇ ਜੀਆ ॥",
          "roman": "kabhū kīṭ hast pataṅg hoe jīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਕੀੜੇ ਹਾਥੀ ਭੰਬਟ (ਆਦਿਕ) ਜੀਵ ਬਣਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "иногда бывает живым существом — червём, слоном, мотыльком и прочими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12411,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੋਨਿ ਭਰਮੈ ਭਰਮੀਆ ॥",
          "roman": "anik jon bharmē bharmīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਆਪਣਾ ਹੀ) ਭਵਾਇਆ ਹੋਇਆ ਕਈ ਜੂਨਾਂ ਵਿਚ ਭਉਂ ਰਿਹਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "и, Сам введя в скитание, блуждает во множестве рождений;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
