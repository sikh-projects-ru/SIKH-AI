{
  "ang": 281,
  "shabads": [
    {
      "shabad_id": 987,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12592,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਕ੍ਰਿਪਾ ਕਰੈ ਤਿਸੁ ਆਪਨ ਨਾਮੁ ਦੇਇ ॥",
          "roman": "jis no kirpā karē tis āpan nām dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਜੀਵ ਉਤੇ ਮੇਹਰ ਕਰਦਾ ਹੈ ਉਸ ਉਸ ਨੂੰ ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Тому живому существу, на кого Он проливает милость, Он дарует Своё Имя;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12593,
          "is_rahao": false,
          "gurmukhi": "ਬਡਭਾਗੀ ਨਾਨਕ ਜਨ ਸੇਇ ॥੮॥੧੩॥",
          "roman": "badbhāgī nānak jan sei ॥8॥13॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ) ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ ॥੮॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, такие люди становятся очень счастливыми по своей великой удаче ॥8॥13॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 988,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12594,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12595,
          "is_rahao": false,
          "gurmukhi": "ਤਜਹੁ ਸਿਆਨਪ ਸੁਰਿ ਜਨਹੁ ਸਿਮਰਹੁ ਹਰਿ ਹਰਿ ਰਾਇ ॥",
          "roman": "tajah siānap sur janah simrah har har rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਲੇ ਮਨੁੱਖੋ! ਚਤੁਰਾਈ ਛੱਡੋ ਤੇ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਸਿਮਰੋ;"
            },
            "sahib_singh_ru": {
              "main": "О добрые люди! Оставьте хитроумие и помните Акал Пуракха;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12596,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਆਸ ਹਰਿ ਮਨਿ ਰਖਹੁ ਨਾਨਕ ਦੂਖੁ ਭਰਮੁ ਭਉ ਜਾਇ ॥੧॥",
          "roman": "ek ās har man rakhah nānak dūkh bharam bhau jāi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੇਵਲ ਪ੍ਰਭੂ ਦੀ ਆਸ ਮਨ ਵਿਚ ਰੱਖੋ। ਹੇ ਨਾਨਕ! (ਇਸ ਤਰ੍ਹਾਂ) ਦੁੱਖ ਵਹਮ ਤੇ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Держите в сердце только надежду на Бога. О Нанак! Тогда уходят страдание, сомнение и страх ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 989,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12597,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12598,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੁਖ ਕੀ ਟੇਕ ਬ੍ਰਿਥੀ ਸਭ ਜਾਨੁ ॥",
          "roman": "mānukh kī ṭek brithī sabh jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) (ਕਿਸੇ) ਮਨੁੱਖ ਦਾ ਆਸਰਾ ਉੱਕਾ ਹੀ ਵਿਅਰਥ ਸਮਝ,"
            },
            "sahib_singh_ru": {
              "main": "О ум! Считай опору на человека совершенно напрасной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12599,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵਨ ਕਉ ਏਕੈ ਭਗਵਾਨੁ ॥",
          "roman": "devan kau ekē bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਅਕਾਲ ਪੁਰਖ ਹੀ (ਸਭ ਜੀਆਂ ਨੂੰ) ਦੇਣ ਜੋਗਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "только один Акал Пуракх способен давать всем существам;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12600,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਦੀਐ ਰਹੈ ਅਘਾਇ ॥",
          "roman": "jis kē dīē rahē aghāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਦਿੱਤਿਆਂ (ਮਨੁੱਖ) ਰੱਜਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "от того, что даёт Он, человек остаётся насыщенным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12601,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਨ ਤ੍ਰਿਸਨਾ ਲਾਗੈ ਆਇ ॥",
          "roman": "bahur na trisanā lāgē āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੁੜ ਉਸ ਨੂੰ ਲਾਲਚ ਆ ਕੇ ਦਬਾਉਂਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "и жадность больше не приходит и не давит его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12602,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੈ ਰਾਖੈ ਏਕੋ ਆਪਿ ॥",
          "roman": "mārē rākhē eko āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ (ਜੀਵਾਂ ਨੂੰ) ਮਾਰਦਾ ਹੈ (ਜਾਂ) ਪਾਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог и убивает, и хранит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12603,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੁਖ ਕੈ ਕਿਛੁ ਨਾਹੀ ਹਾਥਿ ॥",
          "roman": "mānukh kē kichh nāhī hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਦੇ ਵੱਸ ਕੁਝ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в руках человека ничего нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12604,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਹੁਕਮੁ ਬੂਝਿ ਸੁਖੁ ਹੋਇ ॥",
          "roman": "tis kā hukam būjh sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਉਸ ਮਾਲਕ ਦਾ ਹੁਕਮ ਸਮਝ ਕੇ ਸੁਖ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому счастье приходит, когда понимают Его Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12605,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਨਾਮੁ ਰਖੁ ਕੰਠਿ ਪਰੋਇ ॥",
          "roman": "tis kā nām rakh kaṇṭh paroi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਉਸ ਦਾ ਨਾਮ ਹਰ ਵੇਲੇ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Всегда помни Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12606,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "simar simar simar prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помни того Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12607,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਿਘਨੁ ਨ ਲਾਗੈ ਕੋਇ ॥੧॥",
          "roman": "nānak bighan na lāgē koi ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) (ਜ਼ਿੰਦਗੀ ਦੇ ਸਫ਼ਰ ਵਿਚ) ਕੋਈ ਰੁਕਾਵਟ ਨਹੀਂ ਪੈਂਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! По благодати такого симрана на жизненном пути не возникает никаких преград ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 990,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12608,
          "is_rahao": false,
          "gurmukhi": "ਉਸਤਤਿ ਮਨ ਮਹਿ ਕਰਿ ਨਿਰੰਕਾਰ ॥",
          "roman": "ustat man mah kar nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਅੰਦਰ ਅਕਾਲ ਪੁਰਖ ਦੀ ਵਡਿਆਈ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри себя прославляй Акал Пуракха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12609,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਮਨ ਮੇਰੇ ਸਤਿ ਬਿਉਹਾਰ ॥",
          "roman": "kar man mere sat biuhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਇਹ ਸੱਚਾ ਵਿਹਾਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Совершай этот истинный образ жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12610,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਰਸਨਾ ਅੰਮ੍ਰਿਤੁ ਪੀਉ ॥",
          "roman": "nirmal rasnā amrit pīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਨਾਲ ਮਿੱਠਾ (ਨਾਮ-) ਅੰਮ੍ਰਿਤ ਪੀ,"
            },
            "sahib_singh_ru": {
              "main": "Языком пей сладкий амрит Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12611,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸੁਹੇਲਾ ਕਰਿ ਲੇਹਿ ਜੀਉ ॥",
          "roman": "sadā suhelā kar leh jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਆਪਣੀ ਜਿੰਦ ਨੂੰ ਸਦਾ ਲਈ ਸੁਖੀ ਕਰ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "и так навсегда сделай свою душу счастливой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12612,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨਹੁ ਪੇਖੁ ਠਾਕੁਰ ਕਾ ਰੰਗੁ ॥",
          "roman": "nēnah pekh ṭhākur kā raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖਾਂ ਨਾਲ ਅਕਾਲ ਪੁਰਖ ਦਾ (ਜਗਤ-) ਤਮਾਸ਼ਾ ਵੇਖ,"
            },
            "sahib_singh_ru": {
              "main": "Глазами смотри на игру Акал Пуракха в мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12613,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਬਿਨਸੈ ਸਭ ਸੰਗੁ ॥",
          "roman": "sādhsang binsē sabh saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਲਿਆਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਟਿਕਿਆਂ) ਹੋਰ (ਕੁਟੰਬ ਆਦਿਕ ਦਾ) ਮੋਹ ਮਿਟ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в сангате добрых людей исчезает всякая другая привязанность, к семье и прочему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12614,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਚਲਉ ਮਾਰਗਿ ਗੋਬਿੰਦ ॥",
          "roman": "charan chalau mārag gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੈਰਾਂ ਨਾਲ ਰੱਬ ਦੇ ਰਾਹ ਤੇ ਤੁਰ।"
            },
            "sahib_singh_ru": {
              "main": "Ногами иди по пути Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12615,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਹਿ ਪਾਪ ਜਪੀਐ ਹਰਿ ਬਿੰਦ ॥",
          "roman": "miṭah pāp japīai har bind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੂੰ ਰਤਾ ਭਰ ਭੀ ਜਪੀਏ ਤਾਂ ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Если помнить Бога хотя бы самую малость, грехи уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12616,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਹਰਿ ਕਰਮ ਸ੍ਰਵਨਿ ਹਰਿ ਕਥਾ ॥",
          "roman": "kar har karam sravan har kathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੱਥਾਂ ਨਾਲ ਪ੍ਰਭੂ (ਦੇ ਰਾਹ) ਦੇ ਕੰਮ ਕਰ ਤੇ ਕੰਨ ਨਾਲ ਉਸ ਦੀ ਵਡਿਆਈ (ਸੁਣ);"
            },
            "sahib_singh_ru": {
              "main": "Руками совершай дела Божьего пути, а ушами слушай Его хвалу;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12617,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਰਗਹ ਨਾਨਕ ਊਜਲ ਮਥਾ ॥੨॥",
          "roman": "har dargah nānak ūjal mathā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਸੁਰਖ਼-ਰੂ ਹੋ ਜਾਈਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так, о Нанак, в Божьем даргахе человек становится светлоликим, с честью ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 991,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12618,
          "is_rahao": false,
          "gurmukhi": "ਬਡਭਾਗੀ ਤੇ ਜਨ ਜਗ ਮਾਹਿ ॥",
          "roman": "baḍbhāgī te jan jag māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਗਤ ਵਿਚ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди в мире поистине велико-счастливы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12619,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਹਰਿ ਕੇ ਗੁਨ ਗਾਹਿ ॥",
          "roman": "sadā sadā har ke gun gāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ) ਸਦਾ ਹੀ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "которые всегда поют качества Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12620,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਜੋ ਕਰਹਿ ਬੀਚਾਰ ॥",
          "roman": "rām nām jo karah bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਅਕਾਲ ਪੁਰਖ ਦੇ ਨਾਮ ਦਾ ਧਿਆਨ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто размышляют над Именем Акал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12621,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਧਨਵੰਤ ਗਨੀ ਸੰਸਾਰ ॥",
          "roman": "se dhanvant ganī sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਗਤ ਵਿਚ ਧਨੀ ਹਨ ਤੇ ਰੱਜੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "те в мире поистине богаты и удовлетворены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12622,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਮੁਖਿ ਬੋਲਹਿ ਹਰਿ ਮੁਖੀ ॥",
          "roman": "man tan mukh bolah har mukhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਭਲੇ ਲੋਕ ਮਨ ਤਨ ਤੇ ਮੂੰਹ ਤੋਂ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਉਚਾਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те благие люди, которые умом, телом и устами произносят Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12623,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਾਨਹੁ ਤੇ ਸੁਖੀ ॥",
          "roman": "sadā sadā jānh te sukhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਸਦਾ ਸੁਖੀ ਜਾਣੋ।"
            },
            "sahib_singh_ru": {
              "main": "знайте: они всегда счастливы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12624,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਏਕੁ ਏਕੁ ਪਛਾਨੈ ॥",
          "roman": "eko ek ek pachhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਕੇਵਲ ਇਕ ਪ੍ਰਭੂ ਨੂੰ (ਹਰ ਥਾਂ) ਪਛਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто узнаёт только одного Бога повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12625,
          "is_rahao": false,
          "gurmukhi": "ਇਤ ਉਤ ਕੀ ਓਹੁ ਸੋਝੀ ਜਾਨੈ ॥",
          "roman": "it ut kī oh sojhī jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਲੋਕ ਪਰਲੋਕ ਦੀ (ਭਾਵ, ਜੀਵਨ ਦੇ ਸਾਰੇ ਸਫ਼ਰ ਦੀ) ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот постигает этот мир и тот мир, то есть весь путь жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12626,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਸੰਗਿ ਜਿਸ ਕਾ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "nām saṅg jis kā man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਨਾਲ ਰਚ ਮਿਚ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чьё сердце прониклось Именем Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12627,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨਹਿ ਨਿਰੰਜਨੁ ਜਾਨਿਆ ॥੩॥",
          "roman": "nānak tinhi nirañjan jāniā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੇ ਪ੍ਰਭੂ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тот, о Нанак, познал Ниранджана, Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 992,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12628,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਆਪਨ ਆਪੁ ਸੁਝੈ ॥",
          "roman": "gur prasād āpan āp sujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਆਪਣਾ ਆਪ ਸੁੱਝ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, которому по милости Гуру открывается собственное я,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12629,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਜਾਨਹੁ ਤ੍ਰਿਸਨਾ ਬੁਝੈ ॥",
          "roman": "tis kī jānh trisanā bujhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਾਣ ਲਵੋ ਕਿ ਉਸ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਮਿਟ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "знайте: его жажда угасает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12630,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਹਰਿ ਜਸੁ ਕਹਤ ॥",
          "roman": "sādhsang har har jas kahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਰੱਬ ਦਾ ਪਿਆਰਾ ਸਤਸੰਗ ਵਿਚ ਅਕਾਲ ਪੁਰਖ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот любящий Бога, кто в сатсанге славит Акал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12631,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਰੋਗ ਤੇ ਓਹੁ ਹਰਿ ਜਨੁ ਰਹਤ ॥",
          "roman": "sarab rog te oh har jan rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਾਰੇ ਰੋਗਾਂ ਤੋਂ ਬਚ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "избавляется от всех болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12632,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਕੀਰਤਨੁ ਕੇਵਲ ਬਖੵਾਨੁ ॥",
          "roman": "andin kīrtan keval bakhyān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਹਰ ਰੋਜ਼ ਪ੍ਰਭੂ ਦਾ ਕੀਰਤਨ ਹੀ ਉੱਚਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто каждый день произносит только киртан Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12633,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹਸਤ ਮਹਿ ਸੋਈ ਨਿਰਬਾਨੁ ॥",
          "roman": "grihast mah soī nirbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗ੍ਰਿਹਸਤ ਵਿਚ (ਰਹਿੰਦਾ ਹੋਇਆ) ਨਿਰਲੇਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот и в доме живёт непривязанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12634,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਊਪਰਿ ਜਿਸੁ ਜਨ ਕੀ ਆਸਾ ॥",
          "roman": "ek ūpar jis jan kī āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੀ ਆਸ ਇਕ ਅਕਾਲ ਪੁਰਖ ਉੱਤੇ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чья надежда только на одного Акал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12635,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਕਟੀਐ ਜਮ ਕੀ ਫਾਸਾ ॥",
          "roman": "tis kī kaṭīai jam kī phāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਜਮਾਂ ਵਾਲੀ ਫਾਹੀ ਕੱਟੀ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "освобождается от петли ямы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12636,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਜਿਸੁ ਮਨਿ ਭੂਖ ॥",
          "roman": "pārbrahm kī jis man bhūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਪ੍ਰਭੂ (ਦੇ ਮਿਲਣ) ਦੀ ਤਾਂਘ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём сердце есть жажда встречи с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12637,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸਹਿ ਨ ਲਾਗਹਿ ਦੂਖ ॥੪॥",
          "roman": "nānak tisahi na lāgahi dūkh ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਦੁੱਖ ਨਹੀਂ ਪੋਂਹਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "того, о Нанак, не касаются страдания ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 993,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12638,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਉ ਹਰਿ ਪ੍ਰਭੁ ਮਨਿ ਚਿਤਿ ਆਵੈ ॥",
          "roman": "jis kau har prabh man chit āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਹਰੀ ਪ੍ਰਭੂ ਮਨ ਵਿਚ ਸਦਾ ਯਾਦ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, которому Харь-Прабх всегда помнится в уме и сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12639,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੰਤੁ ਸੁਹੇਲਾ ਨਹੀ ਡੁਲਾਵੈ ॥",
          "roman": "so sant suhelā nahī ḍulāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੰਤ ਹੈ, ਸੁਖੀ ਹੈ (ਉਹ ਕਦੇ) ਘਾਬਰਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "тот святой, тот счастливый, и он никогда не колеблется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12640,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਭੁ ਅਪੁਨਾ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "jis prabh apunā kirpā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਆਪਣੀ ਮੇਹਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Бог простирает Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12641,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਕਹੁ ਕਿਸ ਤੇ ਡਰੈ ॥",
          "roman": "so sevak kah kis te ḍarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ (ਪ੍ਰਭੂ ਦਾ) ਉਹ ਸੇਵਕ (ਹੋਰ) ਕਿਸ ਤੋਂ ਡਰ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "скажите, кого ещё может бояться такой слуга Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12642,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਸਾ ਤੈਸਾ ਦ੍ਰਿਸਟਾਇਆ ॥",
          "roman": "jēsā sā tēsā drisṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਉਹੋ ਜਿਹਾ ਹੀ ਦਿੱਸ ਪੈਂਦਾ ਹੈ, ਜਿਹੋ ਜਿਹਾ ਉਹ (ਅਸਲ ਵਿਚ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Потому что ему Бог видится таким, каков Он есть на самом деле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12643,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਕਾਰਜ ਮਹਿ ਆਪਿ ਸਮਾਇਆ ॥",
          "roman": "apune kāraj mah āp samāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ ਇਹ ਦਿੱਸ ਪੈਂਦਾ ਹੈ ਕਿ) ਪ੍ਰਭੂ ਆਪਣੇ ਰਚੇ ਹੋਏ ਜਗਤ ਵਿਚ ਆਪ ਵਿਆਪਕ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "то есть видно, что Бог Сам пронизывает созданный Им мир;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12644,
          "is_rahao": false,
          "gurmukhi": "ਸੋਧਤ ਸੋਧਤ ਸੋਧਤ ਸੀਝਿਆ ॥",
          "roman": "sodhat sodhat sodhat sījhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿੱਤ ਵਿਚਾਰ ਕਰਦਿਆਂ (ਉਸ ਸੇਵਕ ਨੂੰ ਵਿਚਾਰ ਵਿਚ) ਸਫਲਤਾ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "постоянно размышляя, такой слуга достигает успеха в этом размышлении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12645,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਤਤੁ ਸਭੁ ਬੂਝਿਆ ॥",
          "roman": "gur prasād tat sabh būjhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਉਸ ਨੂੰ) ਸਾਰੀ ਅਸਲੀਅਤ ਦੀ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то есть по милости Гуру ему открывается понимание всей сущности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12646,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਦੇਖਉ ਤਬ ਸਭੁ ਕਿਛੁ ਮੂਲੁ ॥",
          "roman": "jab dekhau tab sabh kichh mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ ਉਤੇ ਭੀ ਗੁਰੂ ਦੀ ਮੇਹਰ ਹੋਈ ਹੈ, ਹੁਣ) ਮੈਂ ਜਦੋਂ ਤੱਕਦਾ ਹਾਂ ਤਾਂ ਹਰੇਕ ਚੀਜ਼ ਉਸ ਸਭ ਦੇ ਮੁਢ (-ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਦਿੱਸਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Теперь и на мне есть милость Гуру: когда я смотрю, каждая вещь видится мне образом Того, Кто есть корень всего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12647,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਸੂਖਮੁ ਸੋਈ ਅਸਥੂਲੁ ॥੫॥",
          "roman": "nānak so sūkham soī asthūl ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਇਹ ਦਿੱਸਦਾ ਸੰਸਾਰ ਭੀ ਉਹ ਆਪ ਹੈ ਤੇ ਸਭ ਵਿਚ ਵਿਆਪਕ ਜੋਤਿ ਭੀ ਆਪਿ ਹੀ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! И этот зримый мир есть Он Сам, и всепронизывающий свет во всём тоже Он Сам ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 994,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12648,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਕਿਛੁ ਜਨਮੈ ਨਹ ਕਿਛੁ ਮਰੈ ॥",
          "roman": "nah kichh janmē nah kichh marē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਕੁਝ ਜੰਮਦਾ ਹੈ ਨਾਹ ਕੁਝ ਮਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Ничто не рождается и ничто не умирает;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12649,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਚਲਿਤੁ ਆਪ ਹੀ ਕਰੈ ॥",
          "roman": "āpan chalit āp hī karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਜਨਮ ਮਰਣ ਦਾ ਤਾਂ) ਪ੍ਰਭੂ ਆਪ ਹੀ ਖੇਲ ਕਰ ਰਿਹਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "это Сам Бог ведёт такую игру рождения и смерти;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12650,
          "is_rahao": false,
          "gurmukhi": "ਆਵਨੁ ਜਾਵਨੁ ਦ੍ਰਿਸਟਿ ਅਨਦ੍ਰਿਸਟਿ ॥",
          "roman": "āvan jāvan drisṭ anaḍrisṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੰਮਣਾ, ਮਰਣਾ, ਦਿੱਸਦਾ ਤੇ ਅਣ-ਦਿੱਸਦਾ-"
            },
            "sahib_singh_ru": {
              "main": "рождение, смерть, видимое и невидимое,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12651,
          "is_rahao": false,
          "gurmukhi": "ਆਗਿਆਕਾਰੀ ਧਾਰੀ ਸਭ ਸ੍ਰਿਸਟਿ ॥",
          "roman": "āgiākārī dhārī sabh srisṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰਾ ਸੰਸਾਰ ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਹੁਕਮ ਵਿਚ ਤੁਰਨ ਵਾਲਾ ਬਣਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "весь этот мир Бог устроил идущим по Его повелению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
