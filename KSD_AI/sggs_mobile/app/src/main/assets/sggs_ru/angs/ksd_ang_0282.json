{
  "ang": 282,
  "shabads": [
    {
      "shabad_id": 994,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12652,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਸਗਲ ਮਹਿ ਆਪਿ ॥",
          "roman": "āpe āp sagal mah āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵਾਂ ਵਿਚ ਕੇਵਲ ਆਪ ਹੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Во всех существах есть только Он Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12653,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜੁਗਤਿ ਰਚਿ ਥਾਪਿ ਉਥਾਪਿ ॥",
          "roman": "anik jugat rach thāp uthāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਤਰੀਕਿਆਂ ਨਾਲ (ਜਗਤ ਨੂੰ) ਬਣਾ ਬਣਾ ਕੇ ਨਾਸ ਭੀ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и множеством способов Он творит мир и затем разрушает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12654,
          "is_rahao": false,
          "gurmukhi": "ਅਬਿਨਾਸੀ ਨਾਹੀ ਕਿਛੁ ਖੰਡ ॥",
          "roman": "abināsī nāhī kichh khaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਅਬਿਨਾਸ਼ੀ ਹੈ; ਉਸ ਦਾ ਕੁਝ ਨਾਸ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог неразрушим; в Нём ничто не погибает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12655,
          "is_rahao": false,
          "gurmukhi": "ਧਾਰਣ ਧਾਰਿ ਰਹਿਓ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "dhāraṇ dhār rahiō brahmaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਬ੍ਰਹਮੰਡ ਦੀ ਰਚਨਾ ਭੀ ਆਪ ਹੀ ਰਚ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё мироздание Он Сам продолжает удерживать в бытии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12656,
          "is_rahao": false,
          "gurmukhi": "ਅਲਖ ਅਭੇਵ ਪੁਰਖ ਪਰਤਾਪ ॥",
          "roman": "alakh abhev purakh partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਵਿਆਪਕ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰਤਾਪ ਦਾ ਭੇਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ, ਬਿਆਨ ਨਹੀਂ ਹੋ ਸਕਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "Тайну величия этого всепроникающего Бога нельзя постичь и нельзя выразить;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12657,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਜਪਾਏ ਤ ਨਾਨਕ ਜਾਪ ॥੬॥",
          "roman": "āp japāe ta nānak jāp ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੇ ਉਹ ਆਪ ਆਪਣਾ ਜਾਪ ਕਰਾਏ ਤਾਂ ਹੀ ਜੀਵ ਜਾਪ ਕਰਦੇ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Только если Он Сам побуждает к Своему памятованию, тогда существа и помнят Его ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 995,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12658,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਪ੍ਰਭੁ ਜਾਤਾ ਸੁ ਸੋਭਾਵੰਤ ॥",
          "roman": "jin prabh jātā su sobhāvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਬੰਦਿਆਂ ਨੇ ਪ੍ਰਭੂ ਨੂੰ ਪਛਾਣ ਲਿਆ, ਉਹ ਸੋਭਾ ਵਾਲੇ ਹੋ ਗਏ;"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые познали Бога, стали исполненными славы;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12659,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਸੰਸਾਰੁ ਉਧਰੈ ਤਿਨ ਮੰਤ ॥",
          "roman": "sagal sansār udharē tin mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰਾ ਜਗਤ ਉਹਨਾਂ ਦੇ ਉਪਦੇਸ਼ਾਂ ਨਾਲ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "весь мир спасается от пороков через их наставления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12660,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਸਗਲ ਉਧਾਰਨ ॥",
          "roman": "prabh ke sevak sagal udhāran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੀ ਦੇ ਭਗਤ ਸਭ (ਜੀਵਾਂ) ਨੂੰ ਬਚਾਉਣ ਜੋਗੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Слуги Бога способны спасать всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12661,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਦੂਖ ਬਿਸਾਰਨ ॥",
          "roman": "prabh ke sevak dūkh bisāran",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਦੇ) ਦੁੱਖ ਦੂਰ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "они способны устранять страдания всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12662,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਮੇਲਿ ਲਏ ਕਿਰਪਾਲ ॥",
          "roman": "āpe mel lae kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕਾਂ ਨੂੰ) ਕਿਰਪਾਲ ਪ੍ਰਭੂ ਆਪ (ਆਪਣੇ ਨਾਲ) ਮਿਲਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Милостивый Бог Сам соединяет Своих слуг с Собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12663,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਜਪਿ ਭਏ ਨਿਹਾਲ ॥",
          "roman": "gur kā sabad jap bhae nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਦਾ ਸ਼ਬਦ ਜਪ ਕੇ ਉਹ (ਫੁੱਲ ਵਾਂਗ) ਖਿੜ ਆਉਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и, повторяя Шабд Сатгуру, они расцветают, словно цветок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12664,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਕੀ ਸੇਵਾ ਸੋਈ ਲਾਗੈ ॥",
          "roman": "un kī sevā soī lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਉਹਨਾਂ (ਸੇਵਕਾਂ) ਦੀ ਸੇਵਾ ਵਿਚ ਰੁੱਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек вовлекается в служение таким слугам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12665,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਕ੍ਰਿਪਾ ਕਰਹਿ ਬਡਭਾਗੈ ॥",
          "roman": "jis no kripā karah baḍbhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਭਾਗਾਂ ਵਾਲੇ ਉਤੇ, (ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਆਪ ਮੇਹਰ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "на кого Ты Сам, о Бог, изливаешь милость, на того велико-счастливого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12666,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਪਾਵਹਿ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "nām japat pāvah bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਸੇਵਕ) ਨਾਮ ਜਪ ਕੇ ਅਡੋਲ ਅਵਸਥਾ ਹਾਸਲ ਕਰਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя, такие слуги достигают состояния неподвижного покоя;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12667,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਪੁਰਖ ਕਉ ਊਤਮ ਕਰਿ ਮਾਨੁ ॥੭॥",
          "roman": "nānak tin purakh kau ūtam kar mān ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਬੜੇ ਉੱਚੇ ਬੰਦੇ ਸਮਝੋ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Считайте таких людей поистине высшими ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 996,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12668,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੈ ਸੁ ਪ੍ਰਭ ਕੈ ਰੰਗਿ ॥",
          "roman": "jo kichh karē su prabh kē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ ਸੇਵਕ) ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ, ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ (ਰਹਿ ਕੇ) ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Что бы ни делал слуга Бога, он делает это, пребывая в Божьей воле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12669,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਬਸੈ ਹਰਿ ਸੰਗਿ ॥",
          "roman": "sadā sadā basē har saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਦਾ ਹੀ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всегда живёт в присутствии Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12670,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸੁਭਾਇ ਹੋਵੈ ਸੋ ਹੋਇ ॥",
          "roman": "sahaj subhāi hovē so hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਤੇ ਹੀ ਜੋ ਕੁਝ ਹੁੰਦਾ ਹੈ ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਭਾਣਾ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Что бы ни происходило само собой, он считает это Божьим изволением,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12671,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੈਹਾਰੁ ਪਛਾਣੈ ਸੋਇ ॥",
          "roman": "karṇēhār pachhāṇē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਭ ਕੁਝ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਨੂੰ ਹੀ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и понимает, что всё совершает только Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12672,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਾ ਕੀਆ ਜਨ ਮੀਠ ਲਗਾਨਾ ॥",
          "roman": "prabh kā kīā jan mīṭh lagānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ) ਸੇਵਕਾਂ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਕੀਤਾ ਹੋਇਆ ਮਿੱਠਾ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слугам Бога сладостно всё, что делает Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12673,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਸਾ ਤੈਸਾ ਦ੍ਰਿਸਟਾਨਾ ॥",
          "roman": "jēsā sā tēsā drisṭānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪ੍ਰਭੂ ਜਿਹੋ ਜਿਹਾ (ਸਰਬ-ਵਿਆਪਕ) ਹੈ ਉਹੋ ਜਿਹਾ ਉਹਨਾਂ ਨੂੰ ਨਜ਼ਰੀਂ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что Бог видится им таким, каков Он есть, всепроникающим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12674,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਤੇ ਉਪਜੇ ਤਿਸੁ ਮਾਹਿ ਸਮਾਏ ॥",
          "roman": "jis te upje tis māh samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਤੋਂ ਉਹ ਸੇਵਕ ਪੈਦਾ ਹੋਏ ਹਨ, ਉਸੇ ਵਿਚ ਲੀਨ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "От того Бога, от Которого они произошли, в Нём же они и пребывают слитыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12675,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਸੁਖ ਨਿਧਾਨ ਉਨਹੂ ਬਨਿ ਆਏ ॥",
          "roman": "oi sukh nidhān unhū ban āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੁਖਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੋ ਜਾਂਦੇ ਹਨ ਤੇ ਇਹ ਦਰਜਾ ਫੱਬਦਾ ਭੀ ਉਹਨਾਂ ਨੂੰ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "они становятся сокровищницей счастья, и этот чин идёт именно им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12676,
          "is_rahao": false,
          "gurmukhi": "ਆਪਸ ਕਉ ਆਪਿ ਦੀਨੋ ਮਾਨੁ ॥",
          "roman": "āpas kau āp dīno mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕ ਨੂੰ ਮਾਣ ਦੇ ਕੇ) ਪ੍ਰਭੂ ਆਪਣੇ ਆਪ ਨੂੰ ਆਪ ਮਾਣ ਦੇਂਦਾ ਹੈ (ਕਿਉਂਕਿ ਸੇਵਕ ਦਾ ਮਾਣ ਪ੍ਰਭੂ ਦਾ ਹੀ ਮਾਣ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Даруя честь слуге, Бог тем самым Самому Себе дарует честь, ведь честь слуги есть честь Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12677,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਜਨੁ ਏਕੋ ਜਾਨੁ ॥੮॥੧੪॥",
          "roman": "nānak prabh jan eko jān ॥8॥14॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਤੇ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਨੂੰ ਇਕ ਰੂਪ ਸਮਝੋ ॥੮॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Считай Бога и Божьего слугу единым образом ॥8॥14॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 997,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12678,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12679,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਾ ਭਰਪੂਰ ਪ੍ਰਭ ਬਿਰਥਾ ਜਾਨਨਹਾਰ ॥",
          "roman": "sarab kalā bharpūr prabh birthā jānanahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਸਾਰੀਆਂ ਸ਼ਕਤੀਆਂ ਨਾਲ ਪੂਰਨ ਹੈ, (ਸਭ ਜੀਵਾਂ ਦੇ) ਦੁੱਖ-ਦਰਦ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог полон всеми силами и знает боль и страдания всех существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12680,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਉਧਰੀਐ ਨਾਨਕ ਤਿਸੁ ਬਲਿਹਾਰ ॥੧॥",
          "roman": "jā kē simran udharīē nānak tis balihār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ (ਐਸੇ ਪ੍ਰਭੂ) ਦੇ ਸਿਮਰਨ ਨਾਲ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਸਕੀਦਾ ਹੈ, ਉਸ ਤੋਂ (ਸਦਾ) ਸਦਕੇ ਜਾਈਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тому такому Богу, чьим памятованием можно спастись от пороков, надо всегда посвящать себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 998,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12681,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asaṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12682,
          "is_rahao": false,
          "gurmukhi": "ਟੂਟੀ ਗਾਢਨਹਾਰ ਗੋੁਪਾਲ ॥",
          "roman": "ṭūṭī gāḍhanhār gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੀ ਦਿਲ ਦੀ) ਟੁੱਟੀ ਹੋਈ (ਤਾਰ) ਨੂੰ (ਆਪਣੇ ਨਾਲ) ਗੰਢਣ ਵਾਲਾ ਗੋਪਾਲ ਪ੍ਰਭੂ ਆਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Господь Гопал связывает с Собой оборванную струну сердца живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12683,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਜੀਆ ਆਪੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "sarab jīā āpe pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ ਕਰਨ ਵਾਲਾ (ਭੀ ਆਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам же и питает всех живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12684,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਕੀ ਚਿੰਤਾ ਜਿਸੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "sagal kī chintā jis man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਸਾਰਿਆਂ (ਦੀ ਰੋਜ਼ੀ) ਦਾ ਫ਼ਿਕਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, у Которого в уме забота о пропитании всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12685,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਤੇ ਬਿਰਥਾ ਕੋਈ ਨਾਹਿ ॥",
          "roman": "tis te birthā koī nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਦੇ ਦਰ) ਤੋਂ ਕੋਈ ਜੀਵ ਨਾ-ਉਮੈਦ ਨਹੀਂ (ਆਉਂਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "от Него ни одно существо не уходит без надежды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12686,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਮੇਰੇ ਸਦਾ ਹਰਿ ਜਾਪਿ ॥",
          "roman": "re man mere sadā har jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਸਦਾ ਪ੍ਰਭੂ ਨੂੰ ਜਪ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Всегда повторяй Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12687,
          "is_rahao": false,
          "gurmukhi": "ਅਬਿਨਾਸੀ ਪ੍ਰਭੁ ਆਪੇ ਆਪਿ ॥",
          "roman": "abināsī prabh āpe āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਨਾਸ-ਰਹਿਤ ਹੈ ਤੇ ਆਪਣੇ ਜਿਹਾ ਆਪ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он нетленен и Сам подобен лишь Самому Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12688,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਕੀਆ ਕਛੂ ਨ ਹੋਇ ॥",
          "roman": "āpan kīā kachhū na hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਾਣੀ ਦਾ ਆਪਣੇ ਜਤਨ ਨਾਲ ਕੀਤਾ ਹੋਇਆ ਕੋਈ ਕੰਮ ਸਿਰੇ ਨਹੀਂ ਚੜ੍ਹਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Ни одно дело, совершаемое существом собственными усилиями, не приходит к завершению,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12689,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਉ ਪ੍ਰਾਨੀ ਲੋਚੈ ਕੋਇ ॥",
          "roman": "je sau prānī lochē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਪ੍ਰਾਣੀ ਸੌ ਵਾਰੀ ਤਾਂਘ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "даже если какое-либо существо сто раз этого желает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12690,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਨਾਹੀ ਤੇਰੈ ਕਿਛੁ ਕਾਮ ॥",
          "roman": "tis bin nāhī terē kichh kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਚੀਜ਼ ਤੇਰੇ (ਅਸਲੀ) ਕੰਮ ਦੀ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Без того Бога для твоего подлинного дела нет ничего полезного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12691,
          "is_rahao": false,
          "gurmukhi": "ਗਤਿ ਨਾਨਕ ਜਪਿ ਏਕ ਹਰਿ ਨਾਮ ॥੧॥",
          "roman": "gat nānak jap ek har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਇਕ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ ਤਾਂ ਗਤਿ ਹੋਵੇਗੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Повторяй Имя одного Бога, и будет освобождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 999,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12692,
          "is_rahao": false,
          "gurmukhi": "ਰੂਪਵੰਤੁ ਹੋਇ ਨਾਹੀ ਮੋਹੈ ॥",
          "roman": "rūpvant hoi nāhī mohē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੂਪ ਵਾਲਾ ਹੋ ਕੇ ਕੋਈ ਪ੍ਰਾਣੀ (ਰੂਪ ਦਾ) ਮਾਣ ਨਾਹ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Пусть человек, обладая красотой, не гордится ею,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12693,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਜੋਤਿ ਸਗਲ ਘਟ ਸੋਹੈ ॥",
          "roman": "prabh kī jot sagal ghaṭ sohē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕ) ਸਾਰੇ ਸਰੀਰਾਂ ਵਿਚ ਪ੍ਰਭੂ ਦੀ ਹੀ ਜੋਤਿ ਸੋਭਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ведь во всех телах сияет именно свет Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12694,
          "is_rahao": false,
          "gurmukhi": "ਧਨਵੰਤਾ ਹੋਇ ਕਿਆ ਕੋ ਗਰਬੈ ॥",
          "roman": "dhanvantā hoi kiā ko garbē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਨ ਵਾਲਾ ਹੋ ਕੇ ਕੀਹ ਕੋਈ ਮਨੁੱਖ ਅਹੰਕਾਰ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "Зачем человеку гордиться, став богатым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12695,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਸਭੁ ਕਿਛੁ ਤਿਸ ਕਾ ਦੀਆ ਦਰਬੈ ॥",
          "roman": "jā sabh kichh tis kā dīā darbē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਸਾਰਾ ਧਨ ਉਸ ਪ੍ਰਭੂ ਦਾ ਹੀ ਬਖ਼ਸ਼ਿਆ ਹੋਇਆ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "когда всё богатство даровано именно тем Богом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12696,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਸੂਰਾ ਜੇ ਕੋਊ ਕਹਾਵੈ ॥",
          "roman": "at sūrā je koū kahāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ (ਆਪਣੇ ਆਪ ਨੂੰ) ਬੜਾ ਸੂਰਮਾ ਅਖਵਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если какой-либо человек называет себя великим воином,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12697,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਕਲਾ ਬਿਨਾ ਕਹ ਧਾਵੈ ॥",
          "roman": "prabh kī kalā bin kah dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਰਤਾ ਇਹ ਤਾਂ ਸੋਚੇ ਕਿ) ਪ੍ਰਭੂ ਦੀ (ਦਿੱਤੀ ਹੋਈ) ਤਾਕਤ ਤੋਂ ਬਿਨਾ ਕਿਥੇ ਦੌੜ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "пусть хотя бы немного подумает: куда он может бежать без данной Богом силы?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12698,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਹੋਇ ਬਹੈ ਦਾਤਾਰੁ ॥",
          "roman": "je ko hoi bahē dātār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਬੰਦਾ (ਧਨਾਢ ਹੋ ਕੇ) ਦਾਤਾ ਬਣ ਬੈਠੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то, став богачом, усаживается как даритель,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12699,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਦੇਨਹਾਰੁ ਜਾਨੈ ਗਾਵਾਰੁ ॥",
          "roman": "tis denhār jānē gāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਹ ਮੂਰਖ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਪਛਾਣੇ ਜੋ (ਸਭ ਜੀਵਾਂ ਨੂੰ) ਦੇਣ ਜੋਗਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "пусть этот глупец узнает того Бога, Который способен давать всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12700,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰ ਪ੍ਰਸਾਦਿ ਤੂਟੈ ਹਉ ਰੋਗੁ ॥",
          "roman": "jis gur prasād ṭūṭē hau rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਅਹੰਕਾਰ ਰੂਪੀ ਰੋਗ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਦੂਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, у кого по милости Гуру уходит болезнь в виде эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12701,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਜਨੁ ਸਦਾ ਅਰੋਗੁ ॥੨॥",
          "roman": "nānak so jan sadā arog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਸਦਾ ਨਿਰੋਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот человек всегда здоров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1000,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12702,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮੰਦਰ ਕਉ ਥਾਮੈ ਥੰਮਨੁ ॥",
          "roman": "jiu mandar kau thāmē thammhan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਘਰ (ਦੇ ਛੱਤ) ਨੂੰ ਥੰਮ੍ਹ ਸਹਾਰਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как столб поддерживает дом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12703,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਗੁਰ ਕਾ ਸਬਦੁ ਮਨਹਿ ਅਸਥੰਮਨੁ ॥",
          "roman": "tiu gur kā sabad manah asthamman",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਮਨ ਦਾ ਸਹਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так и Слово Гуру является опорой ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12704,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪਾਖਾਣੁ ਨਾਵ ਚੜਿ ਤਰੈ ॥",
          "roman": "jiu pākhāṇ nāv chaṛ tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪੱਥਰ ਬੇੜੀ ਵਿਚ ਚੜ੍ਹ ਕੇ (ਨਦੀ ਆਦਿਕ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как камень, взойдя на лодку, переправляется на другой берег,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12705,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਣੀ ਗੁਰ ਚਰਣ ਲਗਤੁ ਨਿਸਤਰੈ ॥",
          "roman": "prānī gur charaṇ lagat nistarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਗੁਰੂ ਦੀ ਚਰਨੀਂ ਲੱਗਾ ਹੋਇਆ ਬੰਦਾ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਤਰ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так и человек, припав к стопам Гуру, переплывает через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12706,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਅੰਧਕਾਰ ਦੀਪਕ ਪਰਗਾਸੁ ॥",
          "roman": "jiu andhkār dīpak pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਦੀਵਾ ਹਨੇਰਾ (ਦੂਰ ਕਰ ਕੇ) ਚਾਨਣ ਕਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как лампа, устраняя тьму, даёт свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12707,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਦਰਸਨੁ ਦੇਖਿ ਮਨਿ ਹੋਇ ਬਿਗਾਸੁ ॥",
          "roman": "gur darsan dekh man hoi bigās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਗੁਰੂ ਦਾ ਦੀਦਾਰ ਕਰ ਕੇ ਮਨ ਵਿਚ ਖਿੜਾਉ (ਪੈਦਾ) ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так и при созерцании Гуру в уме возникает расцвет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12708,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮਹਾ ਉਦਿਆਨ ਮਹਿ ਮਾਰਗੁ ਪਾਵੈ ॥ ਤਿਉ ਸਾਧੂ ਸੰਗਿ ਮਿਲਿ ਜੋਤਿ ਪ੍ਰਗਟਾਵੈ ॥",
          "roman": "jiu mahā udiān mah mārag pāvē, tiu sādhū sang mil jot pragaṭāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਕਿਸੇ) ਵੱਡੇ ਜੰਗਲ ਵਿਚ (ਖੁੰਝੇ ਹੋਏ ਨੂੰ) ਰਾਹ ਲੱਭ ਪਏ, ਤਿਵੇਂ ਸਾਧੂ ਦੀ ਸੰਗਤ ਵਿਚ ਬੈਠਿਆਂ (ਅਕਾਲ ਪੁਰਖ ਦੀ) ਜੋਤਿ (ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਪ੍ਰਗਟਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Как в большом лесу заблудившийся находит дорогу, так и в обществе святого внутри человека проявляется свет Акаал Пуракха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12709,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਸੰਤਨ ਕੀ ਬਾਛਉ ਧੂਰਿ ॥",
          "roman": "tin santan kī bāchhau dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਹਨਾਂ ਸੰਤਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я прошу пыль от стоп тех святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12710,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਹਰਿ ਲੋਚਾ ਪੂਰਿ ॥੩॥",
          "roman": "nānak kī har lochā pūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਨਾਨਕ ਦੀ ਇਹ ਖ਼ਾਹਸ਼ ਪੂਰੀ ਕਰ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Бог! Исполни это желание Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1001,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12711,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮੂਰਖ ਕਾਹੇ ਬਿਲਲਾਈਐ ॥",
          "roman": "man mūrakh kāhe billāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ ਮਨ! (ਦੁੱਖ ਮਿਲਣ ਤੇ) ਕਿਉਂ ਵਿਲਕਦਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О глупый ум! Почему ты рыдаешь, когда приходит страдание?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
