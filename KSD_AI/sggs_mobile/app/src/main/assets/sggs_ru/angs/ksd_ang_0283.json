{
  "ang": 283,
  "shabads": [
    {
      "shabad_id": 1001,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12712,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਬ ਲਿਖੇ ਕਾ ਲਿਖਿਆ ਪਾਈਐ ॥",
          "roman": "purab likhe kā likhiā pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਛਲੇ ਬੀਜੇ ਦਾ ਫਲ ਹੀ ਖਾਣਾ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Приходится вкушать плод того, что было посеяно прежде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12713,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਸੂਖ ਪ੍ਰਭ ਦੇਵਨਹਾਰੁ ॥",
          "roman": "dūkh sūkh prabh devanahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਖ ਸੁਖ ਦੇਣ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "И страдание, и счастье даёт Сам Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12714,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਤਿਆਗਿ ਤੂ ਤਿਸਹਿ ਚਿਤਾਰੁ ॥",
          "roman": "avar tiāg tū tiseh chitār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੋਰ (ਆਸਰੇ) ਛੱਡ ਕੇ ਤੂੰ ਉਸੇ ਨੂੰ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "поэтому оставь прочие опоры и помни только Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12715,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਛੁ ਕਰੈ ਸੋਈ ਸੁਖੁ ਮਾਨੁ ॥",
          "roman": "jo kachh karē soī sukh mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪ੍ਰਭੂ ਕਰਦਾ ਹੈ ਉਸੇ ਨੂੰ ਸੁਖ ਸਮਝ।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что Бог делает, считай благом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12716,
          "is_rahao": false,
          "gurmukhi": "ਭੂਲਾ ਕਾਹੇ ਫਿਰਹਿ ਅਜਾਨ ॥",
          "roman": "bhūlā kāhe phirah ajān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਞਾਣ! ਕਿਉ ਭੁੱਲਿਆਂ ਫਿਰਦਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О невежественный! Почему ты бродишь в заблуждении?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12717,
          "is_rahao": false,
          "gurmukhi": "ਕਉਨ ਬਸਤੁ ਆਈ ਤੇਰੈ ਸੰਗ ॥",
          "roman": "kaun bast āī terē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੱਸ) ਕੇਹੜੀ ਚੀਜ਼ ਤੇਰੇ ਨਾਲ ਆਈ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "Скажи, какая вещь пришла вместе с тобой?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12718,
          "is_rahao": false,
          "gurmukhi": "ਲਪਟਿ ਰਹਿਓ ਰਸਿ ਲੋਭੀ ਪਤੰਗ ॥",
          "roman": "lapaṭ rahiō ras lobhī pataṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਲੋਭੀ ਭੰਬਟ! ਤੂੰ (ਮਾਇਆ ਦੇ) ਸੁਆਦ ਵਿਚ ਮਸਤ ਹੋ ਰਿਹਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О жадный мотылёк! Ты упиваешься вкусом майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12719,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਜਪਿ ਹਿਰਦੇ ਮਾਹਿ ॥",
          "roman": "rām nām jap hirde māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяй в сердце Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12720,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਤਿ ਸੇਤੀ ਘਰਿ ਜਾਹਿ ॥੪॥",
          "roman": "nānak pat setī ghar jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸੇ ਤਰ੍ਹਾਂ) ਇੱਜ਼ਤ ਨਾਲ (ਪਰਲੋਕ ਵਾਲੇ) ਘਰ ਵਿਚ ਜਾਵਹਿਂਗਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, и тогда ты войдёшь в тот дом с честью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1002,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12721,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਵਖਰ ਕਉ ਲੈਨਿ ਤੂ ਆਇਆ ॥",
          "roman": "jis vakhar kau lēn tū āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਸੌਦਾ ਖ਼ਰੀਦਣ ਵਾਸਤੇ ਤੂੰ (ਜਗਤ ਵਿਚ) ਆਇਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Товар, за которым ты пришёл в этот мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12722,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਸੰਤਨ ਘਰਿ ਪਾਇਆ ॥",
          "roman": "rām nām santan ghar pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਰਾਮ ਨਾਮ (-ਰੂਪੀ ਸੌਦਾ) ਸੰਤਾਂ ਦੇ ਘਰ ਵਿਚ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот товар в виде Имени Бога находится в доме святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12723,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਅਭਿਮਾਨੁ ਲੇਹੁ ਮਨ ਮੋਲਿ ॥ ਰਾਮ ਨਾਮੁ ਹਿਰਦੇ ਮਹਿ ਤੋਲਿ ॥",
          "roman": "taj abhimān leh man mol, rām nām hirde mah tol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਅਹੰਕਾਰ ਛੱਡ ਦੇਹ, ਤੇ ਮਨ ਦੇ ਵੱਟੇ (ਇਹ ਵੱਖਰ) ਖ਼ਰੀਦ ਲੈ, ਅਤੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹਿਰਦੇ ਵਿਚ ਪਰਖ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому оставь гордыню, купи этот товар ценой своего ума и проверь Имя Бога внутри сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12724,
          "is_rahao": false,
          "gurmukhi": "ਲਾਦਿ ਖੇਪ ਸੰਤਹ ਸੰਗਿ ਚਾਲੁ ॥",
          "roman": "lād khep santah sang chāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦੇ ਸੰਗ ਤੁਰ ਤੇ ਰਾਮ ਨਾਮ ਦਾ ਇਹ ਸੌਦਾ ਲੱਦ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иди вместе со святыми и погрузи этот товар Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12725,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਤਿਆਗਿ ਬਿਖਿਆ ਜੰਜਾਲ ॥",
          "roman": "avar tiāg bikhiā janjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਹੋਰ ਧੰਧੇ ਛੱਡ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "а прочие занятия майи оставь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12726,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨਿ ਧੰਨਿ ਕਹੈ ਸਭੁ ਕੋਇ ॥",
          "roman": "dhann dhann kahē sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਇਹ ਉੱਦਮ ਕਰਹਿਂਗਾ ਤਾਂ) ਹਰੇਕ ਜੀਵ ਤੈਨੂੰ ਸ਼ਾਬਾਸ਼ੇ ਆਖੇਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Если будешь так поступать, всякое существо будет тебя хвалить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12727,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖ ਊਜਲ ਹਰਿ ਦਰਗਹ ਸੋਇ ॥",
          "roman": "mukh ūjal har dargeh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਵਿਚ ਭੀ ਤੇਰਾ ਮੂੰਹ ਉਜਲਾ ਹੋਵੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и в Божественном дворе твоё лицо тоже будет светлым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12728,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਵਾਪਾਰੁ ਵਿਰਲਾ ਵਾਪਾਰੈ ॥",
          "roman": "ih vāpār virlā vāpārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਇਹ ਵਪਾਰ ਕੋਈ ਵਿਰਲਾ ਬੰਦਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но такой торговлей занимается лишь редкий человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12729,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੈ ਸਦ ਬਲਿਹਾਰੈ ॥੫॥",
          "roman": "nānak tā kē sad balihārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਜੇਹੇ (ਵਪਾਰੀ) ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਈਏ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такому торговцу надо всегда посвящать себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1003,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12730,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਸਾਧ ਕੇ ਧੋਇ ਧੋਇ ਪੀਉ ॥",
          "roman": "charaṇ sādh ke dhoi dhoi pīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸਾਧੂ ਜਨਾਂ ਦੇ ਪੈਰ ਧੋ ਧੋ ਕੇ (ਨਾਮ-ਜਲ) ਪੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Омывай стопы святых людей и пей эту воду Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12731,
          "is_rahao": false,
          "gurmukhi": "ਅਰਪਿ ਸਾਧ ਕਉ ਅਪਨਾ ਜੀਉ ॥",
          "roman": "arp sādh kau apnā jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ-ਜਨ ਤੋਂ ਆਪਣੀ ਜਿੰਦ ਭੀ ਵਾਰ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "и даже свою жизнь отдай святому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12732,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਧੂਰਿ ਕਰਹੁ ਇਸਨਾਨੁ ॥",
          "roman": "sādh kī dhūr karah isnān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖ ਮਨੁੱਖ ਦੇ ਪੈਰਾਂ ਦੀ ਖ਼ਾਕ ਵਿਚ ਇਸ਼ਨਾਨ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Омывайся в пыли от стоп гурумukhа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12733,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਊਪਰਿ ਜਾਈਐ ਕੁਰਬਾਨੁ ॥",
          "roman": "sādh ūpar jāīai kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖ ਤੋਂ ਸਦਕੇ ਹੋਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "посвящай себя гурумukhu."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12734,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਸੇਵਾ ਵਡਭਾਗੀ ਪਾਈਐ ॥",
          "roman": "sādh sevā vaḍbhāgī pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਸੇਵਾ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Служение святому обретается только по великому счастью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12735,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੀਰਤਨੁ ਗਾਈਐ ॥",
          "roman": "sādhsang har kīrtan gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਸੰਗਤਿ ਵਿਚ ਹੀ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕੀਤੀ ਜਾ ਸਕਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и лишь в обществе святого можно воспевать хвалу Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12736,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਿਘਨ ਤੇ ਸਾਧੂ ਰਾਖੈ ॥",
          "roman": "anik bighan te sādhū rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਅਨੇਕਾਂ ਔਕੜਾਂ ਤੋਂ (ਜੋ ਆਤਮਕ ਜੀਵਨ ਦੇ ਰਾਹ ਵਿਚ ਆਉਂਦੀਆਂ ਹਨ) ਬਚਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Святой спасает от множества препятствий, которые встают на пути духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12737,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਨ ਗਾਇ ਅੰਮ੍ਰਿਤ ਰਸੁ ਚਾਖੈ ॥",
          "roman": "har gun gāi amrit ras chākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ਕੇ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਦਾ ਸੁਆਦ ਮਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, воспевая качества Бога, святой вкушает нектарный вкус Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12738,
          "is_rahao": false,
          "gurmukhi": "ਓਟ ਗਹੀ ਸੰਤਹ ਦਰਿ ਆਇਆ ॥",
          "roman": "oṭ gahī santah dar āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੇ) ਸੰਤਾਂ ਦਾ ਆਸਰਾ ਫੜਿਆ ਹੈ ਜੋ ਸੰਤਾਂ ਦੇ ਦਰ ਤੇ ਆ ਡਿੱਗਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, ухватившийся за опору святых и пришедший к их двери,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12739,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਨਾਨਕ ਤਿਹ ਪਾਇਆ ॥੬॥",
          "roman": "sarab sūkh nānak tih pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ, ਹੇ ਨਾਨਕ! ਸਾਰੇ ਸੁਖ ਪਾ ਲਏ ਹਨ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "тот, о Нанак, обрёл все блага."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1004,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12740,
          "is_rahao": false,
          "gurmukhi": "ਮਿਰਤਕ ਕਉ ਜੀਵਾਲਨਹਾਰ ॥",
          "roman": "mirtak kau jīvālanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ) ਮੋਏ ਹੋਏ ਬੰਦੇ ਨੂੰ ਜਿਵਾਲਣ ਜੋਗਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог способен оживить умершего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12741,
          "is_rahao": false,
          "gurmukhi": "ਭੂਖੇ ਕਉ ਦੇਵਤ ਅਧਾਰ ॥",
          "roman": "bhūkhe kau devat adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭੁੱਖੇ ਨੂੰ ਭੀ ਆਸਰਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и даже голодному даёт опору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12742,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਜਾ ਕੀ ਦ੍ਰਿਸਟੀ ਮਾਹਿ ॥",
          "roman": "sarab nidhān jā kī drisṭī māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਖ਼ਜ਼ਾਨੇ ਉਸ ਮਾਲਕ ਦੀ ਨਜ਼ਰ ਵਿਚ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все сокровища находятся во взоре того Владыки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12743,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਬ ਲਿਖੇ ਕਾ ਲਹਣਾ ਪਾਹਿ ॥",
          "roman": "purab likhe kā lahnā pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜੀਵ) ਆਪਣੇ ਪਿਛਲੇ ਕੀਤੇ ਕਰਮਾਂ ਦਾ ਫਲ ਭੋਗਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "но существа вкушают плод своих прежних дел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12744,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤਿਸ ਕਾ ਓਹੁ ਕਰਨੈ ਜੋਗੁ ॥",
          "roman": "sabh kichh tis kā oh karnē jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਕੁਝ ਉਸ ਪ੍ਰਭੂ ਦਾ ਹੀ ਹੈ, ਤੇ ਉਹੀ ਸਭ ਕੁਝ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Всё принадлежит только тому Богу, и только Он способен всё совершить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12745,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਦੂਸਰ ਹੋਆ ਨ ਹੋਗੁ ॥",
          "roman": "tis bin dūsar hoā na hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਤੋਂ ਬਿਨਾ ਕੋਈ ਦੂਜਾ ਨਾਹ ਹੈ ਤੇ ਨਾਹ ਹੋਵੇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Него, нет и не будет никого другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12746,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਨ ਸਦਾ ਸਦਾ ਦਿਨੁ ਰੈਣੀ ॥",
          "roman": "jap jan sadā sadā din rēnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਨ! ਸਦਾ ਹੀ ਦਿਨ ਰਾਤ ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О человек! Всегда, день и ночь, помни Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12747,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਨਿਰਮਲ ਇਹ ਕਰਣੀ ॥",
          "roman": "sabh te ūch nirmal ih karṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੀਆਂ ਕਰਣੀਆਂ ਨਾਲੋਂ ਇਹੀ ਕਰਣੀ ਉੱਚੀ ਤੇ ਸੁੱਚੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "это деяние выше и чище всех прочих деяний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12748,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸ ਕਉ ਨਾਮੁ ਦੀਆ ॥",
          "roman": "kar kirpā jis kau nām dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਨਾਮ ਬਖ਼ਸ਼ਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, кому по милости Он дарует Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12749,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਜਨੁ ਨਿਰਮਲੁ ਥੀਆ ॥੭॥",
          "roman": "nānak so jan nirmal thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1005,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12750,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਗੁਰ ਕੀ ਪਰਤੀਤਿ ॥",
          "roman": "jā kē man gur kī pratīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਸਤਿਗੁਰੂ ਦੀ ਸਰਧਾ ਬਣ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, в чьём уме утвердилась вера в Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12751,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਆਵੈ ਹਰਿ ਪ੍ਰਭੁ ਚੀਤਿ ॥",
          "roman": "tis jan āvē har prabh chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਚਿੱਤ ਵਿਚ ਪ੍ਰਭੂ ਟਿਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в сознании утверждается Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12752,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤੁ ਭਗਤੁ ਸੁਨੀਐ ਤਿਹੁ ਲੋਇ ॥",
          "roman": "bhagat bhagat sunīai tih loi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਾਰੇ ਜਗਤ ਵਿਚ ਭਗਤ ਭਗਤ ਸੁਣੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О таком человеке во всём мире слышно как о преданном Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12753,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹਿਰਦੈ ਏਕੋ ਹੋਇ ॥",
          "roman": "jā kē hirdē eko hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਇਕ ਪ੍ਰਭੂ ਵੱਸਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце обитает один только Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12754,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਕਰਣੀ ਸਚੁ ਤਾ ਕੀ ਰਹਤ ॥",
          "roman": "sach karṇī sach tā kī rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਅਮਲੀ ਜ਼ਿੰਦਗੀ ਤੇ ਜ਼ਿੰਦਗੀ ਦੇ ਅਸੂਲ ਇਕ-ਰਸ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Его практическая жизнь и жизненные принципы едины в истине,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12755,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਹਿਰਦੈ ਸਤਿ ਮੁਖਿ ਕਹਤ ॥",
          "roman": "sach hirdē sat mukh kahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੱਚਾ ਪ੍ਰਭੂ ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਹੈ, ਤੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਉਹ ਮੂੰਹੋਂ ਉੱਚਾਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "истинный Бог пребывает в его сердце, и устами он произносит только Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12756,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਦ੍ਰਿਸਟਿ ਸਾਚਾ ਆਕਾਰੁ ॥",
          "roman": "sāchī drisṭ sāchā ākār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਨਜ਼ਰ ਸੱਚੇ ਪ੍ਰਭੂ ਦੇ ਰੰਗ ਵਿਚ ਰੰਗੀ ਹੋਈ ਹੈ, (ਤਾਹੀਏਂ) ਸਾਰਾ ਦ੍ਰਿਸ਼ਟਮਾਨ ਜਗਤ (ਉਸ ਨੂੰ) ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Взор такого человека окрашен истиной Бога, и потому весь видимый мир кажется ему формой Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12757,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਵਰਤੈ ਸਾਚਾ ਪਾਸਾਰੁ ॥",
          "roman": "sach vartē sāchā pāsār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਹੀ (ਸਭ ਥਾਈਂ) ਮੌਜੂਦ (ਦਿੱਸਦਾ ਹੈ, ਤੇ) ਪ੍ਰਭੂ ਦਾ ਹੀ (ਸਾਰਾ) ਖਿਲਾਰਾ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ему видится, что всюду присутствует только Бог и что всё это развёртывание принадлежит Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12758,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਿਨਿ ਸਚੁ ਕਰਿ ਜਾਤਾ ॥",
          "roman": "pārbrahm jin sach kar jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਸਮਝਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который познал Акаал Пуракха как вечно пребывающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12759,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਜਨੁ ਸਚਿ ਸਮਾਤਾ ॥੮॥੧੫॥",
          "roman": "nānak so jan sach samātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਸਦਾ ਉਸ ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦਾ ਹੈ ॥੮॥੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот человек сливается с этим вечным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1006,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12760,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12761,
          "is_rahao": false,
          "gurmukhi": "ਰੂਪੁ ਨ ਰੇਖ ਨ ਰੰਗੁ ਕਿਛੁ ਤ੍ਰਿਹੁ ਗੁਣ ਤੇ ਪ੍ਰਭ ਭਿੰਨ ॥",
          "roman": "rūp na rēkh na raṅg kichh trih guṇ tē prabh bhinn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨ ਕੋਈ ਰੂਪ ਹੈ, ਨ ਚਿਹਨ-ਚੱਕ੍ਰ ਅਤੇ ਨ ਕੋਈ ਰੰਗ। ਪ੍ਰਭੂ ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ ਤੋਂ ਬੇ-ਦਾਗ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У Бога нет ни облика, ни знака, ни цвета. Бог незапятнан тремя качествами майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12762,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਬੁਝਾਏ ਨਾਨਕਾ ਜਿਸੁ ਹੋਵੈ ਸੁਪ੍ਰਸੰਨ ॥੧॥",
          "roman": "tiseh bujhāē Nānkā jis hovē suprasann",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਆਪਣਾ ਆਪ ਉਸ ਮਨੁੱਖ ਨੂੰ ਸਮਝਾਉਂਦਾ ਹੈ ਜਿਸ ਉਤੇ ਆਪ ਤ੍ਰੁੱਠਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Бог Сам даёт понять Себя тому человеку, кем Сам бывает доволен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1007,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12763,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12764,
          "is_rahao": false,
          "gurmukhi": "ਅਬਿਨਾਸੀ ਪ੍ਰਭੁ ਮਨ ਮਹਿ ਰਾਖੁ ॥",
          "roman": "abināsī prabh man meh rākh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਣੇ ਮਨ ਵਿਚ ਅਕਾਲ ਪੁਰਖ ਨੂੰ ਪ੍ਰੋ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "Брат, храни в своём уме Бессмертного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12765,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੁਖ ਕੀ ਤੂ ਪ੍ਰੀਤਿ ਤਿਆਗੁ ॥",
          "roman": "mānukh kī tū prīt tiāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਨੁੱਖ ਦਾ ਪਿਆਰ (ਮੋਹ) ਛੱਡ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "и оставь привязанность к человеку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12766,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਤੇ ਪਰੈ ਨਾਹੀ ਕਿਛੁ ਕੋਇ ॥",
          "roman": "tis tē parē nāhī kichh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਤੋਂ ਬਾਹਰਾ ਹੋਰ ਕੋਈ ਜੀਵ ਨਹੀਂ, ਕੋਈ ਚੀਜ਼ ਨਹੀਂ"
            },
            "sahib_singh_ru": {
              "main": "Вне Его нет никакого другого существа и никакой вещи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12767,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਏਕੋ ਸੋਇ ॥",
          "roman": "sarab nirantar ēko soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਇਕ ਅਕਾਲ ਪੁਰਖ ਹੀ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "во всех существах внутри пребывает один лишь Вечный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12768,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਬੀਨਾ ਆਪੇ ਦਾਨਾ ॥",
          "roman": "āpē bīnā āpē dānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਆਪ ਹੀ (ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ) ਪਛਾਣਨ ਵਾਲਾ ਤੇ ਜਾਣਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он Сам распознаёт и Сам знает сердца живых существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12769,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿਰ ਗੰਭੀਰੁ ਗਹੀਰੁ ਸੁਜਾਨਾ ॥",
          "roman": "gahir gaṃbhīr gahīr sujānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਬੜਾ ਗੰਭੀਰ ਹੈ ਤੇ ਡੂੰਘਾ ਹੈ, ਸਿਆਣਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог очень глубок, очень серьёзен и мудр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12770,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪਰਮੇਸੁਰ ਗੋਬਿੰਦ ॥",
          "roman": "pārbrahm parmēsar Gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ! ਸਭ ਦੇ ਵੱਡੇ ਮਾਲਕ! ਤੇ ਜੀਵਾਂ ਦੇ ਪਾਲਕ!"
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман, Владыка, великий Господин всех и Хранитель существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12771,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਦਇਆਲ ਬਖਸੰਦ ॥",
          "roman": "kripā nidhān daiāl bakhsaṅd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦੇ ਖ਼ਜ਼ਾਨੇ! ਦਇਆ ਦੇ ਘਰ! ਤੇ ਬਖ਼ਸ਼ਣਹਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "сокровищница милости, дом сострадания и Дарующий прощение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12772,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਤੇਰੇ ਕੀ ਚਰਨੀ ਪਾਉ ॥",
          "roman": "sādh tērē kī charnī pāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੇ ਸਾਧਾਂ ਦੀ ਚਰਨੀਂ ਪਵਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "дай мне припасть к стопам Твоих святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
