{
  "ang": 284,
  "shabads": [
    {
      "shabad_id": 1007,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12773,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੈ ਮਨਿ ਇਹੁ ਅਨਰਾਉ ॥੧॥",
          "roman": "Nānak kē man ih anrāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਦੇ ਮਨ ਵਿਚ ਇਹ ਤਾਂਘ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "таково стремление в сердце Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1008,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12774,
          "is_rahao": false,
          "gurmukhi": "ਮਨਸਾ ਪੂਰਨ ਸਰਨਾ ਜੋਗ ॥",
          "roman": "mansā pūran sarnā jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ (ਜੀਵਾਂ ਦੇ) ਮਨ ਦੇ ਫੁਰਨੇ ਪੂਰੇ ਕਰਨ ਤੇ ਸਰਨ ਆਇਆਂ ਦੀ ਸਹਾਇਤਾ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог способен исполнять желания сердца и помогать тем, кто приходит под Его защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12775,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਰਿ ਪਾਇਆ ਸੋਈ ਹੋਗੁ ॥",
          "roman": "jo kar pāiā soi hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਉਸ ਨੇ (ਜੀਵਾਂ ਦੇ) ਹੱਥ ਉਤੇ ਲਿਖ ਦਿੱਤਾ ਹੈ, ਉਹੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что Он записал на ладони живых существ, то и происходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12776,
          "is_rahao": false,
          "gurmukhi": "ਹਰਨ ਭਰਨ ਜਾ ਕਾ ਨੇਤ੍ਰ ਫੋਰੁ ॥",
          "roman": "haran bharan jā kā nētr phor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਅੱਖ ਫਰਕਣ ਦਾ ਸਮਾ (ਜਗਤ ਦੇ) ਪਾਲਣ ਤੇ ਨਾਸ ਲਈ (ਕਾਫ਼ੀ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У Бога одно лишь мгновение движения глаза достаточно для поддержания и разрушения мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12777,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕਾ ਮੰਤ੍ਰੁ ਨ ਜਾਨੈ ਹੋਰੁ ॥",
          "roman": "tis kā mantr na jānē hor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਗੁੱਝਾ ਭੇਤ ਕੋਈ ਹੋਰ ਜੀਵ ਨਹੀਂ ਜਾਣਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и Его сокровенную тайну не знает никто иной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12778,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਰੂਪ ਮੰਗਲ ਸਦ ਜਾ ਕੈ ॥",
          "roman": "anad rūp maṅgal sad jā kē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੇ ਘਰ ਵਿਚ ਸਦਾ ਆਨੰਦ ਤੇ ਖ਼ੁਸ਼ੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В доме того Бога всегда радость и счастье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12779,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਥੋਕ ਸੁਨੀਅਹਿ ਘਰਿ ਤਾ ਕੈ ॥",
          "roman": "sarab thok sunīah ghar tā kē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਦੇ) ਸਾਰੇ ਪਦਾਰਥ ਉਸ ਦੇ ਘਰ ਵਿਚ (ਮੌਜੂਦ) ਸੁਣੀਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "говорят, что все блага находятся в Его доме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12780,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜ ਮਹਿ ਰਾਜੁ ਜੋਗ ਮਹਿ ਜੋਗੀ ॥",
          "roman": "rāj meh rāj jog meh jogī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜਿਆਂ ਵਿਚ ਪ੍ਰਭੂ ਆਪ ਹੀ ਰਾਜਾ ਹੈ, ਜੋਗੀਆਂ ਵਿਚ ਜੋਗੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Среди царей Сам Бог есть Царь, среди йогов Он Йог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12781,
          "is_rahao": false,
          "gurmukhi": "ਤਪ ਮਹਿ ਤਪੀਸਰੁ ਗ੍ਰਿਹਸਤ ਮਹਿ ਭੋਗੀ ॥",
          "roman": "tap meh tapīsar grihast meh bhogī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਪੀਆਂ ਵਿਚ ਆਪ ਹੀ ਵੱਡਾ ਤਪੀ ਹੈ ਤੇ ਗ੍ਰਿਹਸਤੀਆਂ ਵਿਚ ਭੀ ਆਪ ਹੀ ਗ੍ਰਿਹਸਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "среди подвижников Он великий подвижник, и среди домохозяев Он Сам домохозяин."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12782,
          "is_rahao": false,
          "gurmukhi": "ਧਿਆਇ ਧਿਆਇ ਭਗਤਹ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "dhiāi dhiāi bhagatah sukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤ ਜਨਾਂ ਨੇ (ਉਸ ਪ੍ਰਭੂ ਨੂੰ) ਸਿਮਰ ਸਿਮਰ ਕੇ ਸੁਖ ਪਾ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Преданные, помня Его вновь и вновь, обрели покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12783,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਪੁਰਖ ਕਾ ਕਿਨੈ ਅੰਤੁ ਨ ਪਾਇਆ ॥੨॥",
          "roman": "Nānak tis purakh kā kinē ant na pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਕਿਸੇ ਜੀਵ ਨੇ ਉਸ ਅਕਾਲ ਪੁਰਖ ਦਾ ਅੰਤ ਨਹੀਂ ਪਾਇਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, ни одно существо не постигло предела того Вечного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1009,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12784,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਲੀਲਾ ਕੀ ਮਿਤਿ ਨਾਹਿ ॥",
          "roman": "jā kī līlā kī mit nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੀ (ਜਗਤ ਰੂਪ) ਖੇਡ ਦਾ ਲੇਖਾ ਕੋਈ ਨਹੀਂ ਲਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Игру того Бога, проявленную как мир, никто не может измерить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12785,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਦੇਵ ਹਾਰੇ ਅਵਗਾਹਿ ॥",
          "roman": "sagal dēv hārē avgāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਖੋਜ ਖੋਜ ਕੇ ਸਾਰੇ ਦੇਵਤੇ (ਭੀ) ਥੱਕ ਗਏ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "все боги, разыскивая Его, утомились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12786,
          "is_rahao": false,
          "gurmukhi": "ਪਿਤਾ ਕਾ ਜਨਮੁ ਕਿ ਜਾਨੈ ਪੂਤੁ ॥",
          "roman": "pitā kā janam k jānē pūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪਿਉ ਦਾ ਜਨਮ ਪੁੱਤ੍ਰ ਕੀਹ ਜਾਣਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Ибо как сын может знать рождение отца?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12787,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਪਰੋਈ ਅਪੁਨੈ ਸੂਤਿ ॥",
          "roman": "sagal paroi apunē sūt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ ਮਾਲਾ ਦੇ ਮਣਕੇ) ਧਾਗੇ ਵਿਚ ਪਰੋਏ ਹੁੰਦੇ ਹਨ, (ਤਿਵੇਂ) ਸਾਰੀ ਰਚਨਾ ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ (ਹੁਕਮ ਰੂਪ) ਧਾਗੇ ਵਿਚ ਪ੍ਰੋ ਰੱਖੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Как бусины нанизаны на нить, так всё творение Бог нанизал на Свою нить, на Свой Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12788,
          "is_rahao": false,
          "gurmukhi": "ਸੁਮਤਿ ਗਿਆਨੁ ਧਿਆਨੁ ਜਿਨ ਦੇਇ ॥ ਜਨ ਦਾਸ ਨਾਮੁ ਧਿਆਵਹਿ ਸੇਇ ॥",
          "roman": "sumat giān dhiān jin dēi, jan dās nām dhiāvah sei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਬੰਦਿਆਂ ਨੂੰ ਪ੍ਰਭੂ ਸੋਹਣੀ ਮਤਿ ਉੱਚੀ ਸਮਝ ਤੇ ਸੁਰਤ ਜੋੜਨ ਦੀ  ਦਾਤ ਦੇਂਦਾ ਹੈ, ਉਹੀ ਸੇਵਕ ਤੇ ਦਾਸ ਉਸ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Кому Бог даёт прекрасный разум, высокое понимание и дар сосредоточения, те слуги и рабы помнят Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12789,
          "is_rahao": false,
          "gurmukhi": "ਤਿਹੁ ਗੁਣ ਮਹਿ ਜਾ ਕਉ ਭਰਮਾਏ ॥",
          "roman": "tih guṇ meh jā kau bharmāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜਿਨ੍ਹਾਂ ਨੂੰ (ਮਾਇਆ ਦੇ) ਤਿੰਨ ਗੁਣਾਂ ਵਿਚ ਭਵਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "А кого Он заставляет блуждать в трёх качествах майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12790,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਿ ਮਰੈ ਫਿਰਿ ਆਵੈ ਜਾਏ ॥",
          "roman": "janam marē phir āvē jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੰਮਦੇ ਮਰਦੇ ਰਹਿੰਦੇ ਹਨ ਤੇ ਮੁੜ ਮੁੜ (ਜਗਤ ਵਿਚ) ਆਉਂਦੇ ਤੇ ਜਾਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "те рождаются и умирают, снова и снова приходят в мир и уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12791,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਨੀਚ ਤਿਸ ਕੇ ਅਸਥਾਨ ॥",
          "roman": "ūch nīch tis kē asthān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋਹਣੀ ਮੱਤ ਵਾਲੇ ਉਚੇ ਬੰਦਿਆਂ ਦੇ ਹਿਰਦੇ ਤ੍ਰਿਗੁਣੀ ਨੀਚ ਬੰਦਿਆਂ ਦੇ ਮਨ-ਇਹ ਸਾਰੇ ਉਸ ਪ੍ਰਭੂ ਦੇ ਆਪਣੇ ਹੀ ਟਿਕਾਣੇ ਹਨ (ਭਾਵ, ਸਭ ਵਿਚ ਵੱਸਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Сердца возвышенных людей с прекрасным разумом и умы низких людей, связанных тремя гунами, все это Его собственные места пребывания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12792,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਜਨਾਵੈ ਤੈਸਾ ਨਾਨਕ ਜਾਨ ॥੩॥",
          "roman": "jēsā janāvē tēsā Nānak jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਹੋ ਜਿਹੀ ਬੁੱਧ-ਮੱਤ ਦੇਂਦਾ ਹੈ, ਤਿਹੋ ਜਿਹੀ ਸਮਝ ਵਾਲਾ ਜੀਵ ਬਣ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, какую мудрость Он даёт, таким пониманием и обладает человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1010,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12793,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਰੂਪ ਨਾਨਾ ਜਾ ਕੇ ਰੰਗ ॥",
          "roman": "nānā rūp nānā jā kē raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ, ਜਿਸ ਦੇ ਕਈ ਰੂਪ ਤੇ ਰੰਗ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Бог, у Тебя много образов и много красок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12794,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਭੇਖ ਕਰਹਿ ਇਕ ਰੰਗ ॥",
          "roman": "nānā bhēkh karah ik raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਭੇਖ ਧਾਰਦਾ ਹੈਂ (ਤੇ ਫਿਰ ਭੀ) ਇਕੋ ਤਰ੍ਹਾਂ ਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты принимаешь множество обличий и всё же остаёшься одним и тем же."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12795,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਬਿਧਿ ਕੀਨੋ ਬਿਸਥਾਰੁ ॥",
          "roman": "nānā bidh kīno bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਜਗਤ ਦਾ ਪਸਾਰਾ ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он распростёр мир множеством способов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12796,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਬਿਨਾਸੀ ਏਕੰਕਾਰੁ ॥",
          "roman": "prabh abināsī ēkaṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨਾਸ-ਰਹਿਤ ਹੈ, ਤੇ ਸਭ ਥਾਈਂ ਇਕ ਆਪ ਹੀ ਆਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог не подвержен гибели, и повсюду есть только Он Один."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12797,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਚਲਿਤ ਕਰੇ ਖਿਨ ਮਾਹਿ ॥",
          "roman": "nānā chalit karē khin māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਤਮਾਸ਼ੇ ਪ੍ਰਭੂ ਪਲਕ ਵਿਚ ਕਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Множество чудес Бог творит в одно мгновение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12798,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਿ ਰਹਿਓ ਪੂਰਨੁ ਸਭ ਠਾਇ ॥",
          "roman": "pūr rahiō pūran sabh ṭhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੂਰਨ ਪੁਰਖ ਸਭ ਥਾਈਂ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "этот Совершенный Пурукх пребывает повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12799,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਾ ਬਿਧਿ ਕਰਿ ਬਨਤ ਬਨਾਈ ॥",
          "roman": "nānā bidh kar banat banāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਦੀ ਰਚਨਾ ਪ੍ਰਭੂ ਨੇ ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਰਚੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Устройство мира Бог создал многими способами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12800,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੀ ਕੀਮਤਿ ਆਪੇ ਪਾਈ ॥",
          "roman": "apnī kīmat āpē pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ (ਵਡਿਆਈ ਦਾ) ਮੁੱਲ ਉਹ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и цену Своего величия знает только Он Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12801,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਘਟ ਤਿਸ ਕੇ ਸਭ ਤਿਸ ਕੇ ਠਾਉ ॥",
          "roman": "sabh ghaṭ tis kē sabh tis kē ṭhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਸਰੀਰ ਉਸ ਪ੍ਰਭੂ ਦੇ ਹੀ ਹਨ, ਸਾਰੇ ਥਾਂ ਉਸੇ ਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все тела принадлежат тому Богу, и все места принадлежат Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12802,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਜੀਵੈ ਨਾਨਕ ਹਰਿ ਨਾਉ ॥੪॥",
          "roman": "jap jap jīvē Nānak har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਸ ਦਾ ਦਾਸ) ਉਸ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਜੀਊਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Его слуга живёт, повторяя Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1011,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12803,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਸਗਲੇ ਜੰਤ ॥",
          "roman": "nām kē dhārē saglē jant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਆ ਜੰਤ ਅਕਾਲ ਪੁਰਖ ਦੇ ਆਸਰੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все существа держатся опорой Вечного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12804,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਖੰਡ ਬ੍ਰਹਮੰਡ ॥",
          "roman": "nām kē dhārē khaṇḍ brahmaṇḍ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਦੇ ਸਾਰੇ ਭਾਗ (ਹਿੱਸੇ) ਭੀ ਪ੍ਰਭੂ ਦੇ ਟਿਕਾਏ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "все части мироздания тоже утверждены Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12805,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਸਿਮ੍ਰਿਤਿ ਬੇਦ ਪੁਰਾਨ ॥",
          "roman": "nām kē dhārē simrit bēd purān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਦ, ਪੁਰਾਣ ਸਿਮ੍ਰਿਤੀਆਂ ਪ੍ਰਭੂ ਦੇ ਅਧਾਰ ਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Веды, Пураны и Смрити держатся на опоре Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12806,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਸੁਨਨ ਗਿਆਨ ਧਿਆਨ ॥",
          "roman": "nām kē dhārē sunan giān dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਿਆਨ ਦੀਆਂ ਗੱਲਾਂ ਸੁਣਨਾ ਤੇ ਸੁਰਤ ਜੋੜਨੀ ਭੀ ਅਕਾਲ ਪੁਰਖ ਦੇ ਆਸਰੇ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "слушание речей знания и сосредоточение тоже возможны лишь опорой Вечного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12807,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਆਗਾਸ ਪਾਤਾਲ ॥",
          "roman": "nām kē dhārē āgās pātāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਅਕਾਸ਼ ਪਤਾਲ ਪ੍ਰਭੂ-ਆਸਰੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все небеса и подземные миры держатся опорой Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12808,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਸਗਲ ਆਕਾਰ ॥",
          "roman": "nām kē dhārē sagal ākār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਸਰੀਰ ਹੀ ਪ੍ਰਭੂ ਦੇ ਆਧਾਰ ਤੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "все тела существуют на Его основании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12809,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੇ ਧਾਰੇ ਪੁਰੀਆ ਸਭ ਭਵਨ ॥",
          "roman": "nām kē dhārē purīā sabh bhavan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿੰਨੇ ਭਵਨ ਤੇ ਚੌਦਹ ਲੋਕ ਅਕਾਲ ਪੁਰਖ ਦੇ ਟਿਕਾਏ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Три мира и четырнадцать областей держатся поддержкой Вечного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12810,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਕੈ ਸੰਗਿ ਉਧਰੇ ਸੁਨਿ ਸ੍ਰਵਨ ॥",
          "roman": "nām kē saṅg udharē sun sravan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਪ੍ਰਭੂ ਵਿਚ ਜੁੜ ਕੇ ਤੇ ਉਸ ਦਾ ਨਾਮ ਕੰਨੀਂ ਸੁਣ ਕੇ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "существа, соединяясь с Богом и слушая Его Имя ушами, спасаются от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12811,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਆਪਨੈ ਨਾਮਿ ਲਾਏ ॥",
          "roman": "kar kirpā jis āpnē nām lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਮੇਹਰ ਕਰ ਕੇ ਆਪਣੇ ਨਾਮ ਵਿਚ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кого Он по милости соединяет со Своим Именем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12812,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਚਉਥੇ ਪਦ ਮਹਿ ਸੋ ਜਨੁ ਗਤਿ ਪਾਏ ॥੫॥",
          "roman": "Nānak chauthē pad meh so jan gat pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਅਸਰ ਤੋਂ ਪਰਲੇ) ਚਉਥੇ ਦਰਜੇ ਵਿਚ ਅੱਪੜ ਕੇ ਉੱਚੀ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот человек достигает высшего состояния, вступив в четвёртую ступень, лежащую за пределами власти майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1012,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12813,
          "is_rahao": false,
          "gurmukhi": "ਰੂਪੁ ਸਤਿ ਜਾ ਕਾ ਸਤਿ ਅਸਥਾਨੁ ॥",
          "roman": "rūp sat jā kā sat asthān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਤੇ ਟਿਕਾਣਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "У того Бога и образ, и обитель вечно пребывающие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12814,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਖੁ ਸਤਿ ਕੇਵਲ ਪਰਧਾਨੁ ॥",
          "roman": "purakh sat kēval pardhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੇਵਲ ਉਹੀ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਸਭ ਦੇ ਸਿਰ ਤੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "только этот всепронизывающий Господь стоит над всеми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12815,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤੂਤਿ ਸਤਿ ਸਤਿ ਜਾ ਕੀ ਬਾਣੀ ॥",
          "roman": "kartūt sat sat jā kī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸਦਾ-ਅਟੱਲ ਅਕਾਲ ਪੁਰਖ ਦੀ ਬਾਣੀ ਸਭ ਜੀਵਾਂ ਵਿਚ ਰਮੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Чья речь пронизывает всех существ, Тот Вечный неизменен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12816,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਪੁਰਖ ਸਭ ਮਾਹਿ ਸਮਾਣੀ ॥",
          "roman": "sat purakh sabh māh samāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ, ਜੋ ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਵਿਚ ਬੋਲ ਰਿਹਾ ਹੈ) ਉਸ ਦੇ ਕੰਮ ਵੀ ਅਟੱਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "истинный Пурукх пребывает во всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12817,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਕਰਮੁ ਜਾ ਕੀ ਰਚਨਾ ਸਤਿ ॥",
          "roman": "sat karam jā kī rachnā sat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੀ ਰਚਨਾ ਮੁਕੰਮਲ ਹੈ (ਭਾਵ, ਅਧੂਰੀ ਨਹੀਂ),"
            },
            "sahib_singh_ru": {
              "main": "Творение того Бога совершенно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12818,
          "is_rahao": false,
          "gurmukhi": "ਮੂਲੁ ਸਤਿ ਸਤਿ ਉਤਪਤਿ ॥",
          "roman": "mūl sat sat utpat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਸਭ ਦਾ) ਮੂਲ-(ਰੂਪ) ਸਦਾ ਅਸਥਿਰ ਹੈ, ਜਿਸ ਦੀ ਪੈਦਾਇਸ਼ ਭੀ ਮੁਕੰਮਲ ਹੈ, ਉਸ ਦੀ ਬਖ਼ਸ਼ਸ਼ ਸਦਾ ਕਾਇਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он, будучи изначальной основой, вечно устойчив; и Его проявление тоже совершенно, а Его дар пребывает всегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12819,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਕਰਣੀ ਨਿਰਮਲ ਨਿਰਮਲੀ ॥",
          "roman": "sat karṇī nirmal nirmlī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਮਹਾ ਪਵ੍ਰਿਤ ਰਜ਼ਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Воля Бога совершенно чиста,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12820,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਬੁਝਾਏ ਤਿਸਹਿ ਸਭ ਭਲੀ ॥",
          "roman": "jiseh bujhāē tiseh sabh bhalī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਨੂੰ (ਰਜ਼ਾ ਦੀ) ਸਮਝ ਦੇਂਦਾ ਹੈ, ਉਸ ਨੂੰ (ਉਹ ਰਜ਼ਾ) ਪੂਰਨ ਤੌਰ ਤੇ ਸੁਖਦਾਈ (ਲੱਗਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и кому Он даёт понять эту волю, тому она кажется во всём благой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12821,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਨਾਮੁ ਪ੍ਰਭ ਕਾ ਸੁਖਦਾਈ ॥",
          "roman": "sat nām prabh kā sukhdāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਨਾਮ ਸੁਖ-ਦਾਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вечно пребывающее Имя Бога дарует покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12822,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸ੍ਵਾਸੁ ਸਤਿ ਨਾਨਕ ਗੁਰ ਤੇ ਪਾਈ ॥੬॥",
          "roman": "bisvās sat Nānak gur tē pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੀਵ ਨੂੰ) ਇਹ ਅਟੱਲ ਸਿਦਕ ਸਤਿਗੁਰੂ ਤੋਂ ਮਿਲਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, эту непоколебимую веру человек получает от Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1013,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12823,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਬਚਨ ਸਾਧੂ ਉਪਦੇਸ ॥",
          "roman": "sat bachan sādhū updēs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਅਟੱਲ ਬਚਨ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Наставление Гуру есть неизменное слово,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12824,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਤੇ ਜਨ ਜਾ ਕੈ ਰਿਦੈ ਪ੍ਰਵੇਸ ॥",
          "roman": "sat tē jan jā kē ridē pravēs",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਇਸ ਉਪਦੇਸ਼ ਦਾ) ਪ੍ਰਵੇਸ਼ ਹੁੰਦਾ ਹੈ, ਉਹ ਭੀ ਅਟੱਲ (ਭਾਵ, ਜਨਮ ਮਰਨ ਤੋਂ ਰਹਿਤ) ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и те, в чьё сердце оно входит, тоже становятся устойчивыми, то есть выходят из круга рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12825,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਨਿਰਤਿ ਬੂਝੈ ਜੇ ਕੋਇ ॥",
          "roman": "sat nirat būjhē jē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕਿਸੇ ਮਨੁੱਖ ਨੂੰ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਦੀ ਸੂਝ ਆ ਜਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то постигнет любовь к вечно пребывающему Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12826,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਤਾ ਕੀ ਗਤਿ ਹੋਇ ॥",
          "roman": "nām japat tā kī gat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਨਾਮ ਜਪ ਕੇ ਉਹ ਉੱਚੀ ਅਵਸਥਾ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда, повторяя Имя, он достигает высокого состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12827,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਸਤਿ ਕੀਆ ਸਭੁ ਸਤਿ ॥",
          "roman": "āp sat kīā sabh sat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਉਸ ਦਾ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਜਗਤ ਭੀ ਸੱਚ ਮੁੱਚ ਹੋਂਦ ਵਾਲਾ ਹੈ, (ਭਾਵ, ਮਿਥਿਆ ਨਹੀਂ)"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам вечно пребывает, и созданный Им мир тоже действительно существует, то есть он не иллюзорен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12828,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਜਾਨੈ ਅਪਨੀ ਮਿਤਿ ਗਤਿ ॥",
          "roman": "āpē jānē apnī mit gat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੀ ਅਵਸਥਾ ਤੇ ਮਰਯਾਦਾ ਆਪ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Своё собственное состояние и меру знает только Он Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
