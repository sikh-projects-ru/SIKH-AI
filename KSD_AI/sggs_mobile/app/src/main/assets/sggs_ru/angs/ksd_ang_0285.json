{
  "ang": 285,
  "shabads": [
    {
      "shabad_id": 1013,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12829,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੀ ਸ੍ਰਿਸਟਿ ਸੁ ਕਰਣੈਹਾਰੁ ॥",
          "roman": "jis kī srisṭ su karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਇਹ ਜਗਤ ਹੈ ਉਹ ਆਪ ਇਸ ਨੂੰ ਬਨਾਉਣ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, Которому принадлежит этот мир, Сам является его Творцом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12830,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਨ ਬੂਝਿ ਕਰਤ ਬੀਚਾਰੁ ॥",
          "roman": "avar na būjh karat bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਹੋਰ ਨੂੰ ਇਸ ਜਗਤ ਦਾ ਖ਼ਿਆਲ ਰੱਖਣ ਵਾਲਾ (ਭੀ) ਨਾਹ ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "не считай, будто кто-то другой заботится об этом мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12831,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤੇ ਕੀ ਮਿਤਿ ਨ ਜਾਨੈ ਕੀਆ ॥",
          "roman": "kartē kī mit na jānē kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ (ਦੀ ਬਜ਼ੁਰਗੀ) ਦਾ ਅੰਦਾਜ਼ਾ ਉਸ ਦਾ ਪੈਦਾ ਕੀਤਾ ਬੰਦਾ ਨਹੀਂ ਲਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Созданный Им человек не может измерить величие Творца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12832,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਵਰਤੀਆ ॥੭॥",
          "roman": "Nānak jo tis bhāvē so vartīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹੀ ਕੁਝ ਵਰਤਦਾ ਹੈ ਜੋ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਭਾਉਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, происходит только то, что угодно тому Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1014,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12833,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸਮਨ ਬਿਸਮ ਭਏ ਬਿਸਮਾਦ ॥",
          "roman": "bisman bisam bhaē bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਨੇ (ਪ੍ਰਭੂ ਦੀ ਬਜ਼ੁਰਗੀ ਨੂੰ) ਸਮਝਿਆ ਹੈ, ਉਸ ਉਸ ਨੂੰ ਆਨੰਦ ਆਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто постиг величие Бога, тот исполнился радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12834,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਬੂਝਿਆ ਤਿਸੁ ਆਇਆ ਸ੍ਵਾਦ ॥",
          "roman": "jin būjhiā tis āiā svād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵਡਿਆਈ ਤੱਕ ਕੇ) ਉਹ ਬੜੇ ਹੈਰਾਨ ਤੇ ਅਸਚਰਜ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "видя эту славу, они приходят в великое изумление и восторг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12835,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੈ ਰੰਗਿ ਰਾਚਿ ਜਨ ਰਹੇ ॥",
          "roman": "prabh kē raṅg rāch jan rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਦਾਸ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Слуги Бога остаются погружёнными в любовь к Нему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12836,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਬਚਨਿ ਪਦਾਰਥ ਲਹੇ ॥",
          "roman": "gur kē bachan padārath lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਤਿਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਨਾਮ-) ਪਦਾਰਥ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и благодаря слову Сатгуру обретают сокровище Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12837,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਦਾਤੇ ਦੁਖ ਕਾਟਨਹਾਰ ॥",
          "roman": "oi dātē dukh kāṭanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਸੇਵਕ ਖ਼ੁਦ) ਨਾਮ ਦੀ  ਦਾਤ ਵੰਡਦੇ ਹਨ, ਤੇ (ਜੀਵਾਂ ਦੇ) ਦੁੱਖ ਕੱਟਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Эти слуги сами раздают дар Имени и отсекают страдания существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12838,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸੰਗਿ ਤਰੈ ਸੰਸਾਰ ॥",
          "roman": "jā kē saṅg tarē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੀ ਸੰਗਤਿ ਨਾਲ ਜਗਤ ਦੇ ਜੀਵ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਤਰ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "в их сангате мирские существа переплывают океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12839,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕਾ ਸੇਵਕੁ ਸੋ ਵਡਭਾਗੀ ॥",
          "roman": "jan kā sēvak so vaḍbhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੋ ਜਿਹੇ ਸੇਵਕਾਂ ਦਾ ਜੋ ਸੇਵਕ ਬਣਦਾ ਹੈ ਉਹ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто становится слугой таких слуг, поистине очень счастливой судьбы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12840,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੈ ਸੰਗਿ ਏਕ ਲਿਵ ਲਾਗੀ ॥",
          "roman": "jan kē saṅg ēk liv lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਿਹਾਂ ਇਕ ਅਕਾਲ ਪੁਰਖ ਨਾਲ ਸੁਰਤ ਜੁੜਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в их сангате сознание привязывается к одному Вечному."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12841,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗੋਬਿਦ ਕੀਰਤਨੁ ਜਨੁ ਗਾਵੈ ॥",
          "roman": "gun Gobid kīrtan jan gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ) ਸੇਵਕ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਉਂਦਾ ਹੈ, ਤੇ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Слуга поёт качества Бога и возносит Его хвалу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12842,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਫਲੁ ਪਾਵੈ ॥੮॥੧੬॥",
          "roman": "gur prasād Nānak phal pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਹ (ਪ੍ਰਭੂ ਦਾ ਨਾਮ-ਰੂਪੀ) ਫਲ ਪਾ ਲੈਂਦਾ ਹੈ ॥੮॥੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, по милости Сатгуру он обретает плод Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1015,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12843,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12844,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਸਚੁ ਜੁਗਾਦਿ ਸਚੁ ॥",
          "roman": "ād sach jugād sach",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਮੁੱਢ ਤੋਂ ਹੀ ਹੋਂਦ ਵਾਲਾ ਹੈ, ਜੁਗਾਂ ਦੇ ਸ਼ੁਰੂ ਤੋਂ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог существует изначально, присутствует с самого начала юг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12845,
          "is_rahao": false,
          "gurmukhi": "ਹੈ ਭਿ ਸਚੁ ਨਾਨਕ ਹੋਸੀ ਭਿ ਸਚੁ ॥੧॥",
          "roman": "hē bhī sach Nānak hosī bhī sach.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਐਸ ਵੇਲੇ ਭੀ ਮੌਜੂਦ ਹੈ, ਹੇ ਨਾਨਕ! ਅਗਾਂਹ ਨੂੰ ਭੀ ਸਦਾ ਕਾਇਮ ਰਹੇਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он существует и сейчас; о Нанак, и впредь тоже вечно будет пребывать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1016,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12846,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭapadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12847,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਸਤਿ ਸਤਿ ਪਰਸਨਹਾਰ ॥",
          "roman": "charan sat sat parsanahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਚਰਨ ਸਦਾ-ਥਿਰ ਹਨ, ਚਰਨਾਂ ਨੂੰ ਛੋਹਣ ਵਾਲੇ ਸੇਵਕ ਭੀ ਅਟੱਲ ਹੋ ਜਾਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Стопы Бога вечно-непреложны, и слуги, прикасающиеся к Его стопам, тоже становятся неколебимыми;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12848,
          "is_rahao": false,
          "gurmukhi": "ਪੂਜਾ ਸਤਿ ਸਤਿ ਸੇਵਦਾਰ ॥",
          "roman": "pūjā sat sat sevdār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਪੂਜਾ ਇਕ ਸਦਾ ਨਿਭਣ ਵਾਲਾ ਕੰਮ ਹੈ, (ਸੋ) ਪੂਜਾ ਕਰਨ ਵਾਲੇ ਸਦਾ ਲਈ ਅਟੱਲ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Поклонение Богу — дело, пребывающее вечно, и потому совершающие это поклонение навсегда становятся стойкими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12849,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਸਤਿ ਸਤਿ ਪੇਖਨਹਾਰ ॥",
          "roman": "darsan sat sat pekhanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਦੀਦਾਰ ਸਤਿ-(ਕਰਮ) ਹੈ, ਦੀਦਾਰ ਕਰਨ ਵਾਲੇ ਭੀ ਜਨਮ ਮਰਨ ਤੋਂ ਰਹਿਤ ਹੋ ਜਾਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Созерцание Бога — истинное деяние, и созерцающие тоже становятся свободными от рождения и смерти;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12850,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਸਤਿ ਸਤਿ ਧਿਆਵਨਹਾਰ ॥",
          "roman": "nām sat sat dhiāvanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਦਾ ਅਟੱਲ ਹੈ, ਸਿਮਰਨ ਵਾਲੇ ਭੀ ਥਿਰ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога вечно и непреложно, и помнящие Его тоже устойчивы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12851,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਸਤਿ ਸਤਿ ਸਭ ਧਾਰੀ ॥",
          "roman": "āp sat sat sabh dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਸਦਾ ਹੋਂਦ ਵਾਲਾ ਹੈ, ਉਸ ਦੀ ਟਿਕਾਈ ਹੋਈ ਰਚਨਾ ਭੀ ਹੋਂਦ ਵਾਲੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог вечно существует, и утверждённое Им творение тоже обладает бытием;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12852,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਗੁਣ ਆਪੇ ਗੁਣਕਾਰੀ ॥",
          "roman": "āpe guṇ āpe guṇkārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਗੁਣ (-ਰੂਪ) ਹੈ, ਆਪ ਹੀ ਗੁਣ ਪੈਦਾ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам есть добродетель, и Сам же является Творцом добродетели."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12853,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਸਤਿ ਸਤਿ ਪ੍ਰਭੁ ਬਕਤਾ ॥",
          "roman": "sabad sat sat prabh baktā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ) ਸ਼ਬਦ ਸਦਾ ਕਾਇਮ ਹੈ, ਸ਼ਬਦ ਨੂੰ ਉੱਚਾਰਨ ਵਾਲਾ ਵੀ ਥਿਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Шабад хвалы Богу пребывает вечно, и произносящий этот шабад тоже становится устойчивым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12854,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਤਿ ਸਤਿ ਸਤਿ ਜਸੁ ਸੁਨਤਾ ॥",
          "roman": "surat sat sat jas suntā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਵਿਚ ਸੁਰਤ ਜੋੜਨੀ ਸਤਿ (-ਕਰਮ ਹੈ) ਪ੍ਰਭੂ ਦਾ ਜਸ ਸੁਣਨ ਵਾਲਾ ਭੀ ਸਤਿ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Соединять сознание с Богом — истинное деяние, и слушающий славу Бога тоже истинен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12855,
          "is_rahao": false,
          "gurmukhi": "ਬੁਝਨਹਾਰ ਕਉ ਸਤਿ ਸਭ ਹੋਇ ॥",
          "roman": "bujhanhār kau sat sabh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੀ ਹੋਂਦ) ਸਮਝਣ ਵਾਲੇ ਨੂੰ ਉਸ ਦਾ ਰਚਿਆ ਜਗਤ ਭੀ ਹਸਤੀ ਵਾਲਾ ਦਿੱਸਦਾ ਹੈ (ਭਾਵ, ਮਿਥਿਆ ਨਹੀਂ ਭਾਸਦਾ);"
            },
            "sahib_singh_ru": {
              "main": "Для того, кто понял бытие Бога, и сотворённый Им мир тоже видится обладающим реальностью, то есть не кажется ложным;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12856,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਤਿ ਸਤਿ ਪ੍ਰਭੁ ਸੋਇ ॥੧॥",
          "roman": "Nānak sat sat prabh soi.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਆਪ ਸਦਾ ਹੀ ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Сам Бог вечно пребывает непреложным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1017,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12857,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਸਰੂਪੁ ਰਿਦੈ ਜਿਨਿ ਮਾਨਿਆ ॥",
          "roman": "sat sarūp ridē jin māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਅਟੱਲ ਪ੍ਰਭੂ ਦੀ ਮੂਰਤਿ ਨੂੰ ਸਦਾ ਮਨ ਵਿਚ ਟਿਕਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто утвердил в сердце образ непреложного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12858,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਤਿਨਿ ਮੂਲੁ ਪਛਾਨਿਆ ॥",
          "roman": "karan karāvan tin mūl pachhāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਸਭ ਕੁਝ ਕਰਨ ਵਾਲੇ ਤੇ (ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਉਣ ਵਾਲੇ (ਜਗਤ ਦੇ) ਮੂਲ ਨੂੰ ਪਛਾਣ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "узнал Корень мира — Того, Кто всё совершает и заставляет совершать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12859,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਬਿਸ੍ਵਾਸੁ ਪ੍ਰਭ ਆਇਆ ॥",
          "roman": "jā kē ridē bisvās prabh āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ (ਦੀ ਹਸਤੀ) ਦਾ ਯਕੀਨ ਬੱਝ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В сердце того человека, в котором утвердилась вера в бытие Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12860,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਗਿਆਨੁ ਤਿਸੁ ਮਨਿ ਪ੍ਰਗਟਾਇਆ ॥",
          "roman": "tat giān tis man pragaṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਮਨ ਵਿਚ ਸੱਚਾ ਗਿਆਨ ਪਰਗਟ ਹੋ ਗਿਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "в уме открылось истинное знание;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12861,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਤੇ ਨਿਰਭਉ ਹੋਇ ਬਸਾਨਾ ॥",
          "roman": "bhē te nirbhau hoi basānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ) (ਜਗਤ ਦੇ ਹਰੇਕ) ਡਰ ਤੋਂ (ਰਹਿਤ ਹੋ ਕੇ) ਨਿਡਰ ਹੋ ਕੇ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он живёт, став бесстрашным, свободным от всякого страха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12862,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਤੇ ਉਪਜਿਆ ਤਿਸੁ ਮਾਹਿ ਸਮਾਨਾ ॥",
          "roman": "jis te upjiā tis māh samānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਸਦਾ ਉਸ ਪ੍ਰਭੂ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ਜਿਸ ਤੋਂ ਉਹ ਪੈਦਾ ਹੋਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "потому что всегда пребывает слитым с Тем Богом, от Которого он произошёл;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12863,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤੁ ਮਾਹਿ ਲੇ ਬਸਤੁ ਗਡਾਈ ॥",
          "roman": "basat māh le basat gaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਇਕ ਚੀਜ਼ ਲੈ ਕੇ (ਉਸ ਕਿਸਮ ਦੀ) ਚੀਜ਼ ਵਿਚ ਰਲਾ ਦਿੱਤੀ ਜਾਏ (ਤੇ ਦੋਹਾਂ ਦਾ ਕੋਈ ਫ਼ਰਕ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Подобно тому как одну вещь смешивают с вещью того же рода, и между ними уже не остаётся различия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12864,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਭਿੰਨ ਨ ਕਹਨਾ ਜਾਈ ॥",
          "roman": "tā kau bhinn na kahanā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਹੈ) ਉਸ ਨੂੰ ਪ੍ਰਭੂ ਤੋਂ ਵੱਖਰਾ ਨਹੀਂ ਕਿਹਾ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "так и человека, слившегося со стопами Бога, нельзя назвать отдельным от Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12865,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝੈ ਬੂਝਨਹਾਰੁ ਬਿਬੇਕ ॥",
          "roman": "būjhē būjhanhār bibek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਇਸ ਵਿਚਾਰ ਨੂੰ ਵਿਚਾਰਨ ਵਾਲਾ (ਕੋਈ ਵਿਰਲਾ) ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но это рассуждение понимает лишь тот, кто способен по-настоящему его осмыслить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12866,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਨ ਮਿਲੇ ਨਾਨਕ ਏਕ ॥੨॥",
          "roman": "Nārāin mile Nānak ek.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਜੀਵ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਪਏ ਹਨ ਉਹ ਉਸ ਦੇ ਨਾਲ ਇਕ ਰੂਪ ਹੋ ਗਏ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те существа, что встретились с Богом, стали едиными с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1018,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12867,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਕਾ ਸੇਵਕੁ ਆਗਿਆਕਾਰੀ ॥",
          "roman": "Ṭhākur kā sevak āgiākārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸੇਵਕ ਪ੍ਰਭੂ ਦੇ ਹੁਕਮ ਵਿਚ ਤੁਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга Бога идёт в Божьем повелении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12868,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਕਾ ਸੇਵਕੁ ਸਦਾ ਪੂਜਾਰੀ ॥",
          "roman": "Ṭhākur kā sevak sadā pūjārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਦਾ ਉਸ ਦੀ ਪੂਜਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всегда поклоняется Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12869,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਕੇ ਸੇਵਕ ਕੈ ਮਨਿ ਪਰਤੀਤਿ ॥",
          "roman": "Ṭhākur ke sevak kē man partīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਦੇ ਸੇਵਕ ਦੇ ਮਨ ਵਿਚ (ਉਸ ਦੀ ਹਸਤੀ ਦਾ) ਵਿਸ਼ਵਾਸ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В уме слуги Бессмертного Пурукха пребывает вера в Его бытие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12870,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਕੇ ਸੇਵਕ ਕੀ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "Ṭhākur ke sevak kī nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ) ਉਸ ਦੀ ਜ਼ਿੰਦਗੀ ਦੀ ਸੁੱਚੀ ਮਰਯਾਦਾ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и потому образ его жизни чист."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12871,
          "is_rahao": false,
          "gurmukhi": "ਠਾਕੁਰ ਕਉ ਸੇਵਕੁ ਜਾਨੈ ਸੰਗਿ ॥",
          "roman": "Ṭhākur kau sevak jānē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ (ਹਰ ਵੇਲੇ ਆਪਣੇ) ਨਾਲ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга знает своего Господа-Бога всегда рядом с собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12872,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਾ ਸੇਵਕੁ ਨਾਮ ਕੈ ਰੰਗਿ ॥",
          "roman": "prabh kā sevak nām kē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਸ ਦੇ ਨਾਮ ਦੀ ਮੌਜ ਵਿਚ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и пребывает в радости Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12873,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਕਉ ਪ੍ਰਭ ਪਾਲਨਹਾਰਾ ॥",
          "roman": "sevak kau prabh pālanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਸਦਾ ਪਾਲਣ ਦੇ ਸਮਰੱਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда способен поддерживать Своего слугу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12874,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਕੀ ਰਾਖੈ ਨਿਰੰਕਾਰਾ ॥",
          "roman": "sevak kī rākhē nirankārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਆਪਣੇ ਸੇਵਕ ਦੀ (ਸਦਾ) ਲਾਜ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всегда сохраняет честь Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12875,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕੁ ਜਿਸੁ ਦਇਆ ਪ੍ਰਭੁ ਧਾਰੈ ॥",
          "roman": "so sevak jis dēā prabh dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਸੇਵਕ ਉਹੀ ਮਨੁੱਖ (ਬਣ ਸਕਦਾ) ਹੈ ਜਿਸ ਤੇ ਪ੍ਰਭੂ ਆਪ ਮੇਹਰ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Но слугой может стать лишь тот человек, к кому Сам Бог проявляет милость;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12876,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਸੇਵਕੁ ਸਾਸਿ ਸਾਸਿ ਸਮਾਰੈ ॥੩॥",
          "roman": "Nānak so sevak sās sās samārē.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਜੇਹਾ ਸੇਵਕ ਪ੍ਰਭੂ ਨੂੰ ਦਮ-ਬ-ਦਮ ਯਾਦ ਰੱਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой слуга помнит Бога с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1019,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12877,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਜਨ ਕਾ ਪਰਦਾ ਢਾਕੈ ॥",
          "roman": "apune jan kā pardā ḍhākē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦਾ ਪਰਦਾ ਢੱਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог покрывает стыд Своего слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12878,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕੀ ਸਰਪਰ ਰਾਖੈ ॥",
          "roman": "apne sevak kī sarpar rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਦੀ ਲਾਜ ਜ਼ਰੂਰ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и непременно сохраняет его честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12879,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਦਾਸ ਕਉ ਦੇਇ ਵਡਾਈ ॥",
          "roman": "apne dās kau dei vaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਮਾਣ ਬਖ਼ਸ਼ਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог дарует Своему слуге почёт,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12880,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕਉ ਨਾਮੁ ਜਪਾਈ ॥",
          "roman": "apne sevak kau nām japāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਸ ਨੂੰ ਆਪਣਾ ਨਾਮ ਜਪਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и побуждает его повторять Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12881,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕੀ ਆਪਿ ਪਤਿ ਰਾਖੈ ॥",
          "roman": "apne sevak kī āp pat rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦੀ ਇੱਜ਼ਤ ਆਪ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам хранит достоинство Своего слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12882,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਗਤਿ ਮਿਤਿ ਕੋਇ ਨ ਲਾਖੈ ॥",
          "roman": "tā kī gat mit koi na lākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਉੱਚ-ਅਵਸਥਾ ਤੇ ਉਸ ਦੇ ਵਡੱਪਣ ਦਾ ਅੰਦਾਜ਼ਾ ਕੋਈ ਨਹੀਂ ਲਗਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и никто не может постичь меру его высокого состояния и величия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12883,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਕਉ ਕੋ ਨ ਪਹੂਚੈ ॥",
          "roman": "prabh ke sevak kau ko na pahūchē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਦੀ ਬਰਾਬਰੀ ਨਹੀਂ ਕਰ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Никто не может сравниться со слугой Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12884,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਊਚ ਤੇ ਊਚੇ ॥",
          "roman": "prabh ke sevak ūch te ūche",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਉੱਚਿਆਂ ਤੋਂ ਉਚੇ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что слуги Бога — выше самых высоких."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12885,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਪ੍ਰਭਿ ਅਪਨੀ ਸੇਵਾ ਲਾਇਆ ॥",
          "roman": "jo prabh apnī sevā lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਆਪ ਆਪਣੀ ਸੇਵਾ ਵਿਚ ਲਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но тот, кого Сам Бог поставил на Своё служение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12886,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਸੇਵਕੁ ਦਹ ਦਿਸਿ ਪ੍ਰਗਟਾਇਆ ॥੪॥",
          "roman": "Nānak so sevak dah dis pragaṭāiā.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸੇਵਕ ਸਾਰੇ ਜਗਤ ਵਿਚ ਪਰਗਟ ਹੋਇਆ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, такой слуга становится явленным по всему миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1020,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 12887,
          "is_rahao": false,
          "gurmukhi": "ਨੀਕੀ ਕੀਰੀ ਮਹਿ ਕਲ ਰਾਖੈ ॥",
          "roman": "nīkī kīrī mah kal rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ) ਨਿੱਕੀ ਜਿਹੀ ਕੀੜੀ ਵਿਚ (ਪ੍ਰਭੂ) ਤਾਕਤ ਭਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если в крошечного червя Бог вкладывает силу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12888,
          "is_rahao": false,
          "gurmukhi": "ਭਸਮ ਕਰੈ ਲਸਕਰ ਕੋਟਿ ਲਾਖੈ ॥",
          "roman": "bhasam karē laskar koṭ lākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਕੀੜੀ) ਲੱਖਾਂ ਕਰੋੜਾਂ ਲਸ਼ਕਰਾਂ ਨੂੰ ਸੁਆਹ ਕਰ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот обращает в пепел многие миллионы войск."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 12889,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਸਾਸੁ ਨ ਕਾਢਤ ਆਪਿ ॥",
          "roman": "jis kā sās na kāḍhat āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਦਾ ਸ੍ਵਾਸ ਪ੍ਰਭੂ ਆਪ ਨਹੀਂ ਕੱਢਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "У того существа, чьё дыхание Бог Сам не отнимает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
