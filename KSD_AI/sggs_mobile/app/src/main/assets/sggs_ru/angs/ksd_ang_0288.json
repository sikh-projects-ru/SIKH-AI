{
  "ang": 288,
  "shabads": [
    {
      "shabad_id": 1032,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13007,
          "is_rahao": false,
          "gurmukhi": "ਰਚਿ ਰਚਨਾ ਅਪਨੀ ਕਲ ਧਾਰੀ ॥",
          "roman": "rach rachnā apnī kal dhārī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ੍ਰਿਸ਼ਟੀ ਰਚ ਕੇ ਪ੍ਰਭੂ ਨੇ ਆਪਣੀ ਸੱਤਿਆ (ਇਸ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ) ਟਿਕਾਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Создав творение, Бог установил в нём Свою силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13008,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਾਰ ਨਾਨਕ ਬਲਿਹਾਰੀ ॥੮॥੧੮॥",
          "roman": "anik bār Nānak balihārī ॥8॥18॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ) ਮੈਂ ਕਈ ਵਾਰ (ਐਸੇ ਪ੍ਰਭੂ ਤੋਂ) ਸਦਕੇ ਹਾਂ ॥੮॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: я многократно иду в жертву такому Богу. ॥8॥18॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1033,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13009,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13010,
          "is_rahao": false,
          "gurmukhi": "ਸਾਥਿ ਨ ਚਾਲੈ ਬਿਨੁ ਭਜਨ ਬਿਖਿਆ ਸਗਲੀ ਛਾਰੁ ॥",
          "roman": "sāth na chālē bin bhajan bikhiā saglī chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ) ਭਜਨ ਤੋਂ ਬਿਨਾ (ਹੋਰ ਕੋਈ ਸ਼ੈ ਮਨੁੱਖ ਦੇ) ਨਾਲ ਨਹੀਂ ਜਾਂਦੀ, ਸਾਰੀ ਮਾਇਆ (ਜੋ ਮਨੁੱਖ ਕਮਾਉਂਦਾ ਰਹਿੰਦਾ ਹੈ, ਜਗਤ ਤੋਂ ਤੁਰਨ ਵੇਲੇ ਇਸ ਦੇ ਵਾਸਤੇ) ਸੁਆਹ (ਸਮਾਨ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Без бхаджана Господа ничто иное не идёт с человеком вместе; вся майя, которую человек продолжает наживать, при уходе из мира для него — словно пепел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13011,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਕਮਾਵਨਾ ਨਾਨਕ ਇਹੁ ਧਨੁ ਸਾਰੁ ॥੧॥",
          "roman": "har har nām kamāvnā Nānak ih dhan sār ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਕਾਲ ਪੁਰਖ ਦਾ ਨਾਮ (ਸਿਮਰਨ) ਦੀ ਕਮਾਈ ਕਰਨਾ ਹੀ (ਸਭ ਤੋਂ) ਚੰਗਾ ਧਨ ਹੈ (ਇਹੀ ਮਨੁੱਖ ਦੇ ਨਾਲ ਨਿਭਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Зарабатывать имя Акаал Пуракха, то есть жить в симране, — это и есть лучшее богатство; именно оно остаётся с человеком. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1034,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13012,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13013,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਮਿਲਿ ਕਰਹੁ ਬੀਚਾਰੁ ॥",
          "roman": "sant janā mil karah bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਨਾਲ ਮਿਲ ਕੇ (ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਦਾ) ਵਿਚਾਰ ਕਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "Соединяясь со святыми, размышляйте о качествах Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13014,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਸਿਮਰਿ ਨਾਮ ਆਧਾਰੁ ॥",
          "roman": "ek simar nām ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇੱਕ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰੋ ਤੇ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ (ਲਵੋ)।"
            },
            "sahib_singh_ru": {
              "main": "помните одного Господа и примите опору Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13015,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰਿ ਉਪਾਵ ਸਭਿ ਮੀਤ ਬਿਸਾਰਹੁ ॥",
          "roman": "avar upāv sabh mīt bisārah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿਤ੍ਰ! ਹੋਰ ਸਾਰੇ ਹੀਲੇ ਛੱਡ ਦਿਉ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! Оставь все прочие средства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13016,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਰਿਦ ਮਹਿ ਉਰਿ ਧਾਰਹੁ ॥",
          "roman": "charan kamal rid mah ur dhārah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪ੍ਰਭੂ ਦੇ ਕਮਲ (ਵਰਗੇ ਸੋਹਣੇ) ਚਰਨ ਹਿਰਦੇ ਵਿਚ ਟਿਕਾਉ।"
            },
            "sahib_singh_ru": {
              "main": "и утверди в сердце лотосоподобные стопы Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13017,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਾਰਨ ਸੋ ਪ੍ਰਭੁ ਸਮਰਥੁ ॥",
          "roman": "karan kāran so prabh samrath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ (ਸਭ ਕੁਝ ਆਪ) ਕਰਨ (ਤੇ ਜੀਵਾਂ ਪਾਸੋਂ) ਕਰਾਉਣ ਦੀ ਤਾਕਤ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь имеет силу Сам всё делать и побуждать живых существ делать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13018,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿੜੁ ਕਰਿ ਗਹਹੁ ਨਾਮੁ ਹਰਿ ਵਥੁ ॥",
          "roman": "driṛh kar gahah nām har vath",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਦਾ ਨਾਮ-ਰੂਪੀ (ਸੋਹਣਾ) ਪਦਾਰਥ ਪੱਕਾ ਕਰ ਕੇ ਸਾਂਭ ਲਵੋ।"
            },
            "sahib_singh_ru": {
              "main": "крепко ухватись и сбереги прекрасный дар — Имя этого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13019,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਧਨੁ ਸੰਚਹੁ ਹੋਵਹੁ ਭਗਵੰਤ ॥",
          "roman": "ih dhan sanchah hovah bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) (ਨਾਮ-ਰੂਪ) ਇਹ ਧਨ ਇਕੱਠਾ ਕਰੋ ਤੇ ਭਾਗਾਂ ਵਾਲੇ ਬਣੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Собирай это богатство Имени и стань удачливым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13020,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਕਾ ਨਿਰਮਲ ਮੰਤ ॥",
          "roman": "sant janā kā nirmal mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤਾਂ ਦਾ ਇਹੀ ਪਵਿਤ੍ਰ ਉਪਦੇਸ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "таково чистое наставление святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13021,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਆਸ ਰਾਖਹੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "ek ās rākhah man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਵਿਚ ਇਕ (ਪ੍ਰਭੂ ਦੀ) ਆਸ ਰੱਖੋ,"
            },
            "sahib_singh_ru": {
              "main": "Держи в уме одну надежду — на Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13022,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਰੋਗ ਨਾਨਕ ਮਿਟਿ ਜਾਹਿ ॥੧॥",
          "roman": "sarab rog Nānak miṭ jāhi ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਸ ਤਰ੍ਹਾਂ) ਸਾਰੇ ਰੋਗ ਮਿਟ ਜਾਣਗੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда, о Нанак, все болезни исчезнут. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1035,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13023,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਧਨ ਕਉ ਚਾਰਿ ਕੁੰਟ ਉਠਿ ਧਾਵਹਿ ॥",
          "roman": "jis dhan kau chār kunṭ uṭh dhāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਿਤ੍ਰ!) ਜਿਸ ਧਨ ਦੀ ਖ਼ਾਤਰ (ਤੂੰ) ਚੌਹੀਂ ਪਾਸੀਂ ਉਠ ਦੌੜਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! Ради того богатства, за которым ты вскакиваешь и бежишь во все четыре стороны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13024,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਨੁ ਹਰਿ ਸੇਵਾ ਤੇ ਪਾਵਹਿ ॥",
          "roman": "so dhan har sevā te pāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਧਨ ਤੂੰ ਪ੍ਰਭੂ ਦੀ ਸੇਵਾ ਤੋਂ ਲਏਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "это богатство ты получишь через служение Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13025,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸੁਖ ਕਉ ਨਿਤ ਬਾਛਹਿ ਮੀਤ ॥",
          "roman": "jis sukh kau nit bāchhah mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿਤ੍ਰ! ਜਿਸ ਸੁਖ ਨੂੰ ਤੂੰ ਸਦਾ ਤਾਂਘਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! То счастье, которого ты всегда жаждешь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13026,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੁ ਸਾਧੂ ਸੰਗਿ ਪਰੀਤਿ ॥",
          "roman": "so sukh sādhū sang parīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੁਖ ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਪਿਆਰ ਕੀਤਿਆਂ (ਮਿਲਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "это счастье приходит через любовь в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13027,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸੋਭਾ ਕਉ ਕਰਹਿ ਭਲੀ ਕਰਨੀ ॥",
          "roman": "jis sobhā kau karah bhalī karnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਸੋਭਾ ਦੀ ਖ਼ਾਤਰ ਤੂੰ ਨੇਕ ਕਮਾਈ ਕਰਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ради той славы, ради которой ты совершаешь добрые дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13028,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਸੋਭਾ ਭਜੁ ਹਰਿ ਕੀ ਸਰਨੀ ॥",
          "roman": "sā sobhā bhaj har kī sarnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੋਭਾ (ਖੱਟਣ ਲਈ) ਤੂੰ ਅਕਾਲ ਪੁਰਖ ਦੀ ਸਰਣ ਪਉ।"
            },
            "sahib_singh_ru": {
              "main": "чтобы обрести её, приди в прибежище Акаал Пуракха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13029,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਉਪਾਵੀ ਰੋਗੁ ਨ ਜਾਇ ॥",
          "roman": "anik upāvī rog na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਹਉਮੈ ਦਾ) ਰੋਗ ਅਨੇਕਾਂ ਹੀਲਿਆਂ ਨਾਲ ਦੂਰ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Та болезнь Хоумэ не уходит множеством уловок,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13030,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਮਿਟੈ ਹਰਿ ਅਵਖਧੁ ਲਾਇ ॥",
          "roman": "rog miṭē har avkhaḍh lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਰੋਗ ਪ੍ਰਭੂ ਦਾ ਨਾਮ-ਰੂਪੀ ਦਵਾਈ ਵਰਤਿਆਂ ਮਿਟ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но эта болезнь исчезает, когда употребляешь лекарство — Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13031,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਮਹਿ ਹਰਿ ਨਾਮੁ ਨਿਧਾਨੁ ॥",
          "roman": "sarab nidhān mah har nām nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ (ਦੁਨੀਆਵੀ) ਖ਼ਜ਼ਾਨਿਆਂ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਵਧੀਆ) ਖ਼ਜ਼ਾਨਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Среди всех мирских сокровищ Имя Господа — лучшее сокровище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13032,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਨਾਨਕ ਦਰਗਹਿ ਪਰਵਾਨੁ ॥੨॥",
          "roman": "jap Nānak dargahi parvān ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਨਾਮ) ਜਪ, ਦਰਗਾਹ ਵਿਚ ਕਬੂਲ (ਹੋਵੇਂਗਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Повторяй Имя — и в даргахе будешь принят. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1036,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13033,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਪਰਬੋਧਹੁ ਹਰਿ ਕੈ ਨਾਇ ॥",
          "roman": "man parbodhah har kē nāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਆਪਣੇ) ਮਨ ਨੂੰ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਨਾਲ ਜਗਾਉ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Пробуди свой ум Именем Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13034,
          "is_rahao": false,
          "gurmukhi": "ਦਹ ਦਿਸਿ ਧਾਵਤ ਆਵੈ ਠਾਇ ॥",
          "roman": "dah dis dhāvat āvē ṭhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਦਸੀਂ ਪਾਸੀਂ ਦੌੜਦਾ (ਇਹ ਮਨ) ਟਿਕਾਣੇ ਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и силой Имени этот ум, мечущийся в десяти направлениях, придёт к покою."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13035,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਬਿਘਨੁ ਨ ਲਾਗੈ ਕੋਇ ॥",
          "roman": "tā kau bighan na lāgē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਔਕੜ ਨਹੀਂ ਪੋਂਹਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "Такого человека не касается никакая преграда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13036,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਬਸੈ ਹਰਿ ਸੋਇ ॥",
          "roman": "jā kē ridē basē har soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਪ੍ਰਭੂ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце обитает тот Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13037,
          "is_rahao": false,
          "gurmukhi": "ਕਲਿ ਤਾਤੀ ਠਾਂਢਾ ਹਰਿ ਨਾਉ ॥",
          "roman": "kal tātī ṭhāṇḍā har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਲਿਜੁਗ ਤੱਤੀ (ਅੱਗ) ਹੈ (ਭਾਵ, ਵਿਕਾਰ ਜੀਆਂ ਨੂੰ ਸਾੜ ਰਹੇ ਹਨ) ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਠੰਢਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кали-юг — это жгучий огонь, то есть пороки сжигают существ; Имя Господа — прохлада,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13038,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਦਾ ਸੁਖ ਪਾਉ ॥",
          "roman": "simar simar sadā sukh pāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਦਾ ਸਿਮਰੋ ਤੇ ਸੁਖ ਪਾਉ।"
            },
            "sahib_singh_ru": {
              "main": "постоянно помни Его и обретай покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13039,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਬਿਨਸੈ ਪੂਰਨ ਹੋਇ ਆਸ ॥",
          "roman": "bhau binsē pūran hoi ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਸਿਮਰਿਆਂ) ਡਰ ਉੱਡ ਜਾਂਦਾ ਹੈ, ਤੇ, ਆਸ ਪੁੱਗ ਜਾਂਦੀ ਹੈ (ਭਾਵ, ਨਾਹ ਹੀ ਮਨੁੱਖ ਆਸਾਂ ਬੰਨ੍ਹਦਾ ਫਿਰਦਾ ਹੈ ਤੇ ਨਾਹ ਹੀ ਉਹਨਾਂ ਆਸਾਂ ਦੇ ਟੁੱਟਣ ਦਾ ਕੋਈ ਡਰ ਹੁੰਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Когда Имя помнят, страх исчезает и надежда исполняется, то есть человек уже не бродит, связывая себя надеждами, и не боится, что они разрушатся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13040,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਭਾਇ ਆਤਮ ਪਰਗਾਸ ॥",
          "roman": "bhagat bhāi ātam pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਨਾਲ ਪਿਆਰ ਕੀਤਿਆਂ ਆਤਮਾ ਚਮਕ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что через любовь к преданности Господу душа озаряется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13041,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਘਰਿ ਜਾਇ ਬਸੈ ਅਬਿਨਾਸੀ ॥",
          "roman": "tit ghar jāi basē abināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਸਿਮਰਦਾ ਹੈ) ਉਸ ਦੇ (ਹਿਰਦੇ) ਘਰ ਵਿਚ ਅਬਿਨਾਸੀ ਪ੍ਰਭੂ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В дом его сердца приходит и поселяется Неразрушимый Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13042,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਕਾਟੀ ਜਮ ਫਾਸੀ ॥੩॥",
          "roman": "kah Nānak kāṭī jam fāsī ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ (ਕਿ ਨਾਮ ਜਪਿਆਂ) ਜਮਾਂ ਦੀ ਫਾਹੀ ਕੱਟੀ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: через повторение Имени петля посланцев смерти перерезается. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1037,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13043,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਬੀਚਾਰੁ ਕਹੈ ਜਨੁ ਸਾਚਾ ॥",
          "roman": "tat bīchār kahē jan sācā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪਾਰਬ੍ਰਹਮ ਦੀ ਸਿਫ਼ਤਿ-ਰੂਪ ਸੋਚ ਸੋਚਦਾ ਹੈ ਉਹ ਸਚ-ਮੁਚ ਮਨੁੱਖ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который размышляет о сущностной мысли — восхвалении Парабрахмана, поистине является настоящим человеком,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13044,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਿ ਮਰੈ ਸੋ ਕਾਚੋ ਕਾਚਾ ॥",
          "roman": "janam marē so kācho kāchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੋ ਜੰਮ ਕੇ (ਨਿਰਾ) ਮਰ ਜਾਂਦਾ ਹੈ (ਤੇ ਬੰਦਗੀ ਨਹੀਂ ਕਰਦਾ) ਉਹ ਨਿਰੋਲ ਕੱਚਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а тот, кто, родившись, просто умирает и не занимается бандги, — совершенно незрелый."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13045,
          "is_rahao": false,
          "gurmukhi": "ਆਵਾ ਗਵਨੁ ਮਿਟੈ ਪ੍ਰਭ ਸੇਵ ॥",
          "roman": "āvā gavan miṭē prabh sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕੀਤਿਆਂ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਮੁੱਕ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Через симран Господа прекращается круг рождения и смерти;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13046,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਤਿਆਗਿ ਸਰਨਿ ਗੁਰਦੇਵ ॥",
          "roman": "āp tiāg saran gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਾ-ਭਾਵ ਛੱਡ ਕੇ, ਸਤਿਗੁਰੂ ਦੀ ਸਰਨੀ ਪੈ ਕੇ (ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਮੁੱਕਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "оставив эго и придя в прибежище Сатгуру, человек выходит из круга рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13047,
          "is_rahao": false,
          "gurmukhi": "ਇਉ ਰਤਨ ਜਨਮ ਕਾ ਹੋਇ ਉਧਾਰੁ ॥",
          "roman": "iu ratan janam kā hoi udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਕੀਮਤੀ ਮਨੁੱਖਾ ਜਨਮ ਸਫਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Так драгоценное человеческое рождение становится успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13048,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਸਿਮਰਿ ਪ੍ਰਾਨ ਆਧਾਰੁ ॥",
          "roman": "har har simar prān ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ, ਹੇ ਭਾਈ!) ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰ, (ਇਹੀ) ਪ੍ਰਾਣਾਂ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о брат, помни Господа; это и есть опора жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13049,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਉਪਾਵ ਨ ਛੂਟਨਹਾਰੇ ॥",
          "roman": "anik upāv na chhūṭanhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਹੀਲੇ ਕੀਤਿਆਂ (ਆਵਾਗਵਨ ਤੋਂ) ਬਚ ਨਹੀਂ ਸਕੀਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "Множеством ухищрений невозможно спастись от круговорота рождений и смертей;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13050,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਮ੍ਰਿਤਿ ਸਾਸਤ ਬੇਦ ਬੀਚਾਰੇ ॥",
          "roman": "simmrit sāstat bed bīchāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿੰਮ੍ਰਿਤੀਆਂ ਸ਼ਾਸਤ੍ਰ ਵੇਦ (ਆਦਿਕ) ਵਿਚਾਰਿਆਂ (ਆਵਾ ਗਵਨ ਤੋਂ ਛੁਟਕਾਰਾ ਨਹੀਂ ਹੁੰਦਾ।)"
            },
            "sahib_singh_ru": {
              "main": "даже через рассмотрение Смрити, шастр и Вед от этого не освобождаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13051,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਕਰਹੁ ਮਨੁ ਲਾਇ ॥",
          "roman": "har kī bhagat karah man lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਲਾ ਕੇ ਕੇਵਲ ਪ੍ਰਭੂ ਦੀ ਹੀ ਭਗਤੀ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "С полной сосредоточенностью занимайтесь только преданностью Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13052,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਬੰਛਤ ਨਾਨਕ ਫਲ ਪਾਇ ॥੪॥",
          "roman": "man banchhat Nānak phal pāi ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਭਗਤੀ ਕਰਦਾ ਹੈ) ਹੇ ਨਾਨਕ! ਉਸ ਨੂੰ ਮਨ-ਇੱਛਤ ਫਲ ਮਿਲ ਜਾਂਦੇ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кто предан Господу, получает желаемый плод ума. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1038,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13053,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਨ ਚਾਲਸਿ ਤੇਰੈ ਧਨਾ ॥",
          "roman": "sang na chālas terē dhanā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ ਮਨ! ਧਨ ਤੇਰੇ ਨਾਲ ਨਹੀਂ ਜਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О глупый ум! Богатство не сможет пойти с тобой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13054,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਕਿਆ ਲਪਟਾਵਹਿ ਮੂਰਖ ਮਨਾ ॥",
          "roman": "tū kiā lapaṭāvah mūrakh manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਕਿਉਂ ਇਸ ਨੂੰ ਜੱਫਾ ਮਾਰੀ ਬੈਠਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "так зачем ты вцепился в него?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13055,
          "is_rahao": false,
          "gurmukhi": "ਸੁਤ ਮੀਤ ਕੁਟੰਬ ਅਰੁ ਬਨਿਤਾ ॥",
          "roman": "sut mīt kuṭamb ar banitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੁਤ੍ਰ, ਮਿੱਤ੍ਰ, ਪਰਵਾਰ ਤੇ ਇਸਤ੍ਰੀ;"
            },
            "sahib_singh_ru": {
              "main": "Сыновья, друзья, семья и жена —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13056,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਤੇ ਕਹਹੁ ਤੁਮ ਕਵਨ ਸਨਾਥਾ ॥",
          "roman": "in te kahah tum kavan sanāthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਵਿਚੋਂ, ਦੱਸ, ਕੌਣ ਤੇਰਾ ਸਾਥ ਦੇਣ ਵਾਲਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "скажи, кто из них будет тебе поддержкой?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13057,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜ ਰੰਗ ਮਾਇਆ ਬਿਸਥਾਰ ॥",
          "roman": "rāj rang māiā bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਅਡੰਬਰ, ਰਾਜ ਤੇ ਰੰਗ-ਰਲੀਆਂ-"
            },
            "sahib_singh_ru": {
              "main": "Пышность майи, власть и развлечения —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13058,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਤੇ ਕਹਹੁ ਕਵਨ ਛੁਟਕਾਰ ॥",
          "roman": "in te kahah kavan chhuṭkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ, ਇਹਨਾਂ ਵਿਚੋਂ ਕਿਸ ਦੇ ਨਾਲ (ਮੋਹ ਪਾਇਆਂ) ਸਦਾ ਲਈ (ਮਾਇਆ ਤੋਂ) ਖ਼ਲਾਸੀ ਮਿਲ ਸਕਦੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "скажите, через что из этого, при привязанности к нему, можно получить окончательное освобождение от майи?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13059,
          "is_rahao": false,
          "gurmukhi": "ਅਸੁ ਹਸਤੀ ਰਥ ਅਸਵਾਰੀ ॥",
          "roman": "as hastī rath asvārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘੋੜੇ, ਹਾਥੀ, ਰਥਾਂ ਦੀ ਸਵਾਰੀ ਕਰਨੀ-"
            },
            "sahib_singh_ru": {
              "main": "Ездить на конях, слонах и колесницах —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13060,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠਾ ਡੰਫੁ ਝੂਠੁ ਪਾਸਾਰੀ ॥",
          "roman": "jhūṭhā ḍamph jhūṭh pāsārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਭ ਝੂਠਾ ਦਿਖਾਵਾ ਹੈ, ਇਹ ਅਡੰਬਰ ਰਚਾਉਣ ਵਾਲਾ ਭੀ ਬਿਨਸਨਹਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всё это ложное представление, и сам устроитель этой пышности тоже подвержен гибели."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13061,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਏ ਤਿਸੁ ਬੁਝੈ ਨ ਬਿਗਾਨਾ ॥",
          "roman": "jin dīe tis bujhē na bigānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਨਹੀਂ ਪਛਾਣਦਾ ਜਿਸ ਨੇ ਇਹ ਸਾਰੇ ਪਦਾਰਥ ਦਿੱਤੇ ਹਨ, ਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Глупый человек не узнаёт того Господа, который дал все эти вещи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13062,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਬਿਸਾਰਿ ਨਾਨਕ ਪਛੁਤਾਨਾ ॥੫॥",
          "roman": "nām bisār Nānak pachhutānā ||5||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਨੂੰ ਭੁਲਾ ਕੇ, ਹੇ ਨਾਨਕ! (ਆਖ਼ਰ) ਪਛੁਤਾਉਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и, забыв Имя, о Нанак, в конце раскаивается. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1039,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13063,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਮਤਿ ਤੂੰ ਲੇਹਿ ਇਆਨੇ ॥",
          "roman": "gur kī mat tū leh iāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਞਾਣ! ਸਤਿਗੁਰੂ ਦੀ ਮਤਿ ਲੈ (ਭਾਵ, ਸਿੱਖਿਆ ਤੇ ਤੁਰ)"
            },
            "sahib_singh_ru": {
              "main": "О невежественный! Прими наставление Сатгуру, то есть следуй его учению,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13064,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਬਿਨਾ ਬਹੁ ਡੂਬੇ ਸਿਆਨੇ ॥",
          "roman": "bhagat binā bah ḍūbe siāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੜੇ ਸਿਆਣੇ ਸਿਆਣੇ ਬੰਦੇ ਭੀ ਭਗਤੀ ਤੋਂ ਬਿਨਾ (ਵਿਕਾਰਾਂ ਵਿਚ ਹੀ) ਡੁੱਬ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "даже многие умники без преданности тонут в пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13065,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਕਰਹੁ ਮਨ ਮੀਤ ॥",
          "roman": "har kī bhagat karah man mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿਤ੍ਰ ਮਨ! ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О ум-друг! Совершай преданность Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13066,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਹੋਇ ਤੁਮੑਾਰੋ ਚੀਤ ॥",
          "roman": "nirmal hoi tumhāro chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਤੇਰੀ ਸੁਰਤ ਪਵਿਤ੍ਰ ਹੋਵੇਗੀ।"
            },
            "sahib_singh_ru": {
              "main": "тогда твоё сознание станет чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13067,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਰਾਖਹੁ ਮਨ ਮਾਹਿ ॥",
          "roman": "charan kamal rākah man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪ੍ਰਭੂ ਦੇ ਕਮਲ (ਵਰਗੇ ਸੋਹਣੇ) ਚਰਨ ਆਪਣੇ ਮਨ ਵਿਚ ਪ੍ਰੋ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Храни в своём уме лотосоподобные прекрасные стопы Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
