{
  "ang": 290,
  "shabads": [
    {
      "shabad_id": 1046,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13129,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿਨਿ ਸਭੁ ਕਿਛੁ ਦੀਆ ॥",
          "roman": "so kiu bisrē jin sabh kichh dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਕਿਉਂ ਭੁੱਲ ਜਾਏ ਜਿਸ ਨੇ ਸਭ ਕੁਝ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как может забыться тот Пребывающий, Который дал всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13130,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿ ਜੀਵਨ ਜੀਆ ॥",
          "roman": "so kiu bisrē j jīvan jīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੀਵਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Который является опорой жизни для всех живых существ?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13131,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿ ਅਗਨਿ ਮਹਿ ਰਾਖੈ ॥",
          "roman": "so kiu bisrē j agan mah rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਕਾਲ ਪੁਰਖ ਕਿਉਂ ਵਿਸਰ ਜਾਏ ਜੋ (ਮਾਂ ਦੇ ਪੇਟ ਦੀ) ਅੱਗ ਵਿਚ ਬਚਾ ਕੇ ਰੱਖਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Как может забыться тот Акал Пуракх, Который хранит в огне материнской утробы?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13132,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਕੋ ਬਿਰਲਾ ਲਾਖੈ ॥",
          "roman": "gur prasād ko birlā lākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਇਹ ਗੱਲ) ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но лишь редкий человек по милости Гуру понимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13133,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਿਉ ਬਿਸਰੈ ਜਿ ਬਿਖੁ ਤੇ ਕਾਢੈ ॥",
          "roman": "so kiu bisrē j bikh te kāḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਕਾਲ ਪੁਰਖ ਕਿਉਂ ਭੁੱਲ ਜਾਏ ਜੋ (ਮਾਇਆ-ਰੂਪ) ਜ਼ਹਰ ਤੋਂ ਬਚਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как может забыться тот Акал Пуракх, Который спасает от яда майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13134,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਟੂਟਾ ਗਾਢੈ ॥",
          "roman": "janam janam kā ṭūṭā gāḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਕਈ ਜਨਮ ਦੇ ਵਿਛੁੜੇ ਹੋਏ ਜੀਵ ਨੂੰ (ਆਪਣੇ ਨਾਲ) ਜੋੜ ਲੈਂਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "и соединяет с Собой живое существо, разлучённое с Ним многие рождения?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13135,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਤਤੁ ਇਹੈ ਬੁਝਾਇਆ ॥",
          "roman": "gur pūrē tat ihē bujhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਸੇਵਕਾਂ ਨੂੰ) ਪੂਰੇ ਗੁਰੂ ਨੇ ਇਹ ਗੱਲ ਸਮਝਾਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тем слугам, которым совершенный Гуру объяснил эту истину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13136,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਪਨਾ ਨਾਨਕ ਜਨ ਧਿਆਇਆ ॥੪॥",
          "roman": "prabh apnā Nānak jan dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹਨਾਂ ਨੇ ਆਪਣੇ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, они помнили своего Пребывающего. ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1047,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13137,
          "is_rahao": false,
          "gurmukhi": "ਸਾਜਨ ਸੰਤ ਕਰਹੁ ਇਹੁ ਕਾਮੁ ॥",
          "roman": "sājan sant karah ih kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਜਣ ਜਨੋ! ਹੇ ਸੰਤ ਜਨੋ! ਇਹ ਕੰਮ ਕਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "О добрые люди! О святые! Делайте это дело,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13138,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਤਿਆਗਿ ਜਪਹੁ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "ān tiāg japah har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਾਰੇ (ਆਹਰ) ਛੱਡ ਕੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "оставив все прочие занятия, повторяйте Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13139,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਿਮਰਿ ਸੁਖ ਪਾਵਹੁ ॥",
          "roman": "simar simar simar sukh pāvh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਸਿਮਰੋ ਤੇ ਸਿਮਰ ਕੇ ਸੁਖ ਹਾਸਲ ਕਰੋ;"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помните, помните и, помня, обретайте счастье;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13140,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਜਪਹੁ ਅਵਰਹ ਨਾਮੁ ਜਪਾਵਹੁ ॥",
          "roman": "āp japah avrah nām japāvh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਆਪ ਜਪਹੁ ਤੇ ਹੋਰਨਾਂ ਨੂੰ ਭੀ ਜਪਾਵਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "сами повторяйте Имя Пребывающего и других побуждайте повторять его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13141,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਭਾਇ ਤਰੀਐ ਸੰਸਾਰੁ ॥",
          "roman": "bhagat bhāi tarīai sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਵਿਚ ਨਿਹੁਂ ਲਾਇਆਂ ਇਹ ਸੰਸਾਰ (ਸਮੁੰਦਰ) ਤਰੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "С любовью в бхагти переплывают этот мир-океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13142,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਭਗਤੀ ਤਨੁ ਹੋਸੀ ਛਾਰੁ ॥",
          "roman": "bin bhagatī tan hosī chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ ਤੋਂ ਬਿਨਾ ਇਹ ਸਰੀਰ ਕਿਸੇ ਕੰਮ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "без бхагти это тело не принесёт пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13143,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਸੂਖ ਨਿਧਿ ਨਾਮੁ ॥",
          "roman": "sarab kaliāṇ sūkh nidh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਭਲੇ ਭਾਗਾਂ ਤੇ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Пребывающего — сокровищница доброй судьбы и всех радостей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13144,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਜਾਤ ਪਾਏ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "būḍat jāt pāe bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਜਪਿਆਂ ਵਿਕਾਰਾਂ ਵਿਚ) ਡੁੱਬਦੇ ਜਾਂਦੇ ਨੂੰ ਆਸਰਾ ਟਿਕਾਣਾ ਮਿਲਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "повторяющий его находит опору и место покоя, когда тонет в пороках;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13145,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਦੂਖ ਕਾ ਹੋਵਤ ਨਾਸੁ ॥",
          "roman": "sagal dūkh kā hovat nās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ) ਸਾਰੇ ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и все страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13146,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਜਪਹੁ ਗੁਨਤਾਸੁ ॥੫॥",
          "roman": "Nānak nām japah guntās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਹੇ ਨਾਨਕ! ਨਾਮ ਜਪਹੁ, (ਨਾਮ ਹੀ) ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ (ਹੈ) ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Потому, о Нанак, повторяй Имя, ведь Имя — сокровищница качеств. ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1048,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13147,
          "is_rahao": false,
          "gurmukhi": "ਉਪਜੀ ਪ੍ਰੀਤਿ ਪ੍ਰੇਮ ਰਸੁ ਚਾਉ ॥",
          "roman": "upjī prīt prem ras chāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦੀ) ਪ੍ਰੀਤ ਪੈਦਾ ਹੋਈ ਹੈ, ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਦਾ ਸੁਆਦ ਤੇ ਚਾਉ ਪੈਦਾ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В ком родилась любовь к Пребывающему, в том возник вкус Его любви и стремление к Нему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13148,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਅੰਤਰਿ ਇਹੀ ਸੁਆਉ ॥",
          "roman": "man tan antar ihī suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਮਨ ਤੇ ਤਨ ਵਿਚ ਇਹੀ ਚਾਹ ਹੈ (ਕਿ ਨਾਮ ਦੀ  ਦਾਤ ਮਿਲੇ)।"
            },
            "sahib_singh_ru": {
              "main": "в его уме и теле остаётся только это желание — получить дар Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13149,
          "is_rahao": false,
          "gurmukhi": "ਨੇਤ੍ਰਹੁ ਪੇਖਿ ਦਰਸੁ ਸੁਖੁ ਹੋਇ ॥",
          "roman": "netrah pekh daras sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖਾਂ ਨਾਲ (ਗੁਰੂ ਦਾ) ਦੀਦਾਰ ਕਰ ਕੇ ਉਸ ਨੂੰ ਸੁਖ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда он глазами видит даршан Гуру, он испытывает счастье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13150,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਬਿਗਸੈ ਸਾਧ ਚਰਨ ਧੋਇ ॥",
          "roman": "man bigsē sādh charan dhoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਚਰਨ ਧੋ ਕੇ ਉਸ ਦਾ ਮਨ ਖਿੜ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, омывая стопы Гуру, его ум расцветает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13151,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਜਨਾ ਕੈ ਮਨਿ ਤਨਿ ਰੰਗੁ ॥",
          "roman": "bhagat janā kē man tan rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤਾਂ ਦੇ ਮਨ ਤੇ ਸਰੀਰ ਵਿਚ (ਪ੍ਰਭੂ ਦਾ) ਪਿਆਰ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В уме и теле бхагатов пребывает любовь Пребывающего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13152,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਲਾ ਕੋਊ ਪਾਵੈ ਸੰਗੁ ॥",
          "roman": "birlā koū pāvē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਕਿਸੇ ਵਿਰਲੇ ਭਾਗਾਂ ਵਾਲੇ ਨੂੰ ਉਹਨਾਂ ਦੀ ਸੰਗਤਿ ਨਸੀਬ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но лишь редкому счастливцу достаётся их общество."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13153,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਬਸਤੁ ਦੀਜੈ ਕਰਿ ਮਇਆ ॥",
          "roman": "ek basat dījē kar mēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਇਕ ਨਾਮ-ਵਸਤੂ ਮੇਹਰ ਕਰ ਕੇ (ਸਾਨੂੰ) ਦੇਹ,"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! По милости даруй нам одну вещь — Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13154,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਮੁ ਜਪਿ ਲਇਆ ॥",
          "roman": "gur prasād nām jap laiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਜੋ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਤੇਰਾ ਨਾਮ ਜਪ ਸਕੀਏ।"
            },
            "sahib_singh_ru": {
              "main": "чтобы по милости Гуру мы могли повторять Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13155,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਉਪਮਾ ਕਹੀ ਨ ਜਾਇ ॥",
          "roman": "tā kī upmā kahī na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਵਡਿਆਈ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Его величие невозможно выразить словами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13156,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਹਿਆ ਸਰਬ ਸਮਾਇ ॥੬॥",
          "roman": "Nānak rahiā sarab samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਪ੍ਰਭੂ ਸਭ ਥਾਈਂ ਮੌਜੂਦ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Этот Пребывающий присутствует повсюду. ॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1049,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13157,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਬਖਸੰਦ ਦੀਨ ਦਇਆਲ ॥",
          "roman": "prabh bakhasand dīn daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਬਖ਼ਸ਼ਨਹਾਰ ਪ੍ਰਭੂ! ਹੇ ਗਰੀਬਾਂ ਤੇ ਤਰਸ ਕਰਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О прощающий Пребывающий! О сострадательный к бедным!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13158,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਵਛਲ ਸਦਾ ਕਿਰਪਾਲ ॥",
          "roman": "bhagat vachhal sadā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਗਤੀ ਨਾਲ ਪਿਆਰ ਕਰਨ ਵਾਲੇ! ਹੇ ਸਦਾ ਦਇਆ ਦੇ ਘਰ!"
            },
            "sahib_singh_ru": {
              "main": "О любящий бхагти! О всегда милостивый!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13159,
          "is_rahao": false,
          "gurmukhi": "ਅਨਾਥ ਨਾਥ ਗੋਬਿੰਦ ਗੁਪਾਲ ॥",
          "roman": "anāth nāth Gobind Gupāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅਨਾਥਾਂ ਦੇ ਨਾਥ! ਹੇ ਗੋਬਿੰਦ! ਹੇ ਗੋਪਾਲ!"
            },
            "sahib_singh_ru": {
              "main": "О Владыка беззащитных! О Гобинд! О Гупал!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13160,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਘਟਾ ਕਰਤ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "sarab ghaṭā karat pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਸਰੀਰਾਂ ਦੀ ਪਾਲਣਾ ਕਰਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О питающий и поддерживающий все тела!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13161,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖ ਕਾਰਣ ਕਰਤਾਰ ॥",
          "roman": "ād purakh kāran kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੇ ਮੁੱਢ ਤੇ ਸਭ ਵਿੱਚ ਵਿਆਪਕ ਪ੍ਰਭੂ! ਹੇ (ਜਗਤ ਦੇ) ਮੂਲ! ਹੇ ਕਰਤਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "О изначальный Пребывающий, всеобщая причина, Творец!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13162,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਜਨਾ ਕੇ ਪ੍ਰਾਨ ਅਧਾਰ ॥",
          "roman": "bhagat janā ke prān adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਗਤਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਦੇ ਆਸਰੇ!"
            },
            "sahib_singh_ru": {
              "main": "О опора жизни бхагатов!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13163,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਜਪੈ ਸੁ ਹੋਇ ਪੁਨੀਤ ॥",
          "roman": "jo jo japē so hoi punīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੋ ਮਨੁੱਖ ਤੈਨੂੰ ਜਪਦਾ ਹੈ, ਉਹ ਪਵ੍ਰਿੱਤ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Каждый, кто повторяет Тебя, становится чистым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13164,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਭਾਇ ਲਾਵੈ ਮਨ ਹੀਤ ॥",
          "roman": "bhagat bhāi lāvē man hīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ-ਭਾਵ ਨਾਲ ਆਪਣੇ ਮਨ ਵਿਚ ਤੇਰਾ ਪਿਆਰ ਟਿਕਾਉਂਦਾ ਹੈ (ਉਸ ਦਾ ਉਧਾਰ ਹੋ ਜਾਂਦਾ ਹੈ।)"
            },
            "sahib_singh_ru": {
              "main": "и, устанавливая в сердце любовь к Тебе через бхагти, получает спасение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13165,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਨਿਰਗੁਨੀਆਰ ਨੀਚ ਅਜਾਨ ॥",
          "roman": "ham nirgunīār nīch ajān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਨੀਚ ਹਾਂ, ਅੰਞਾਣ ਹਾਂ ਤੇ ਗੁਣ-ਹੀਨ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Мы лишены достоинств, мы низки и невежественны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13166,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤੁਮਰੀ ਸਰਨਿ ਪੁਰਖ ਭਗਵਾਨ ॥੭॥",
          "roman": "Nānak tumrī saran purakh Bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਬੇਨਤੀ ਕਰ ਤੇ ਆਖ-) ਹੇ ਅਕਾਲ ਪੁਰਖ! ਹੇ ਭਗਵਾਨ! ਅਸੀਂ ਤੇਰੀ ਸਰਨ ਆਏ ਹਾਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи с мольбой: о Акал Пуракх, о Бхагван, мы пришли в Твоё прибежище. ॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1050,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13167,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਬੈਕੁੰਠ ਮੁਕਤਿ ਮੋਖ ਪਾਏ ॥",
          "roman": "sarab bēkunṭh mukt mokh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ (ਮਾਨੋ) ਸਾਰੇ ਸੁਰਗ ਤੇ ਮੋਖ ਮੁਕਤੀ ਹਾਸਲ ਕਰ ਲਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек словно уже обрёл все небеса и освобождение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13168,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਨਿਮਖ ਹਰਿ ਕੇ ਗੁਨ ਗਾਏ ॥",
          "roman": "ek nimakh har ke gun gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਅੱਖ ਦਾ ਇਕ ਫੋਰ ਮਾਤ੍ਰ ਭੀ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "который хотя бы на одно мгновение воспел качества Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13169,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਰਾਜ ਭੋਗ ਬਡਿਆਈ ॥",
          "roman": "anik rāj bhog baḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ (ਮਾਨੋ) ਅਨੇਕਾਂ ਰਾਜ-ਭੋਗ ਪਦਾਰਥ ਤੇ ਵਡਿਆਈਆਂ ਮਿਲ ਗਈਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек словно получил бесчисленные царские наслаждения и почести,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13170,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਕਥਾ ਮਨਿ ਭਾਈ ॥",
          "roman": "har ke nām kī kathā man bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਗੱਲ-ਬਾਤ ਮਿੱਠੀ ਲੱਗੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чьему сердцу стала сладка беседа об Имени Пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13171,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਭੋਜਨ ਕਾਪਰ ਸੰਗੀਤ ॥",
          "roman": "bah bhojan kāpar sangīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ (ਮਾਨੋ) ਕਈ ਕਿਸਮ ਦੇ ਖਾਣੇ ਕੱਪੜੇ ਤੇ ਰਾਗ-ਰੰਗ ਹਾਸਲ ਹੋ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек словно получил множество яств, одежд и развлечений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13172,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਜਪਤੀ ਹਰਿ ਹਰਿ ਨੀਤ ॥",
          "roman": "rasnā japtī har har nīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਜੀਭ ਸਦਾ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "чей язык всегда повторяет Имя Пребывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13173,
          "is_rahao": false,
          "gurmukhi": "ਭਲੀ ਸੁ ਕਰਨੀ ਸੋਭਾ ਧਨਵੰਤ ॥",
          "roman": "bhalī su karnī sobhā dhanvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਮਨੁੱਖ ਦਾ ਹੀ ਆਚਰਨ ਭਲਾ ਹੈ, ਉਸੇ ਨੂੰ ਹੀ ਸੋਭਾ ਮਿਲਦੀ ਹੈ, ਓਹੀ ਧਨਾਢ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Лишь у такого человека поведение доброе, лишь ему достаётся слава, лишь он по-настоящему богат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13174,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਬਸੇ ਪੂਰਨ ਗੁਰ ਮੰਤ ॥",
          "roman": "hirdē base pūran gur mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪੂਰੇ ਗੁਰੂ ਦਾ ਉਪਦੇਸ਼ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце живёт наставление совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13175,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਪ੍ਰਭ ਦੇਹੁ ਨਿਵਾਸ ॥",
          "roman": "sādhsang prabh deh nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਆਪਣੇ ਸੰਤਾਂ ਦੀ ਸੰਗਤ ਵਿਚ ਥਾਂ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "О Пребывающий! Дай место в обществе Твоих святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13176,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਨਾਨਕ ਪਰਗਾਸ ॥੮॥੨੦॥",
          "roman": "sarab sūkh Nānak pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਸਤਸੰਗ ਵਿਚ ਰਿਹਾਂ) ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਪ੍ਰਕਾਸ਼ ਹੋ ਜਾਂਦਾ ਹੈ ॥੮॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Пребывая в святом обществе, человек приходит к раскрытию всех радостей. ॥8॥20॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1051,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13177,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "Salok.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13178,
          "is_rahao": false,
          "gurmukhi": "ਸਰਗੁਨ ਨਿਰਗੁਨ ਨਿਰੰਕਾਰ ਸੁੰਨ ਸਮਾਧੀ ਆਪਿ ॥",
          "roman": "Sarguṇ nirguṇ niraṅkār suṅn samādhī āp.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਰੰਕਾਰ (ਭਾਵ, ਆਕਾਰ-ਰਹਿਤ ਅਕਾਲ ਪੁਰਖ) ਤ੍ਰਿਗੁਣੀ ਮਾਇਆ ਦਾ ਰੂਪ (ਭਾਵ, ਜਗਤ ਰੂਪ) ਭੀ ਆਪ ਹੈ ਤੇ ਮਾਇਆ ਦੇ ਤਿੰਨਾਂ ਗੁਣਾਂ ਤੋਂ ਪਰੇ ਭੀ ਆਪ ਹੀ ਹੈ, ਅਫੁਰ ਅਵਸਥਾ ਵਿਚ ਟਿਕਿਆ ਹੋਇਆ ਭੀ ਆਪ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ниранкар, то есть бесформенный Акал Пуракх, Сам является и формой трёхкачественной майи, то есть миром, и Сам же — вне трёх गुणов майи; и в состоянии пустотного самопогружения тоже пребывает Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13179,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਕੀਆ ਨਾਨਕਾ ਆਪੇ ਹੀ ਫਿਰਿ ਜਾਪਿ ॥੧॥",
          "roman": "Āpan kīā Nānkā āpe hī phir jāp.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਇਹ ਸਾਰਾ ਜਗਤ) ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਰਚਿਆ ਹੈ (ਤੇ ਜਗਤ ਦੇ ਜੀਵਾਂ ਵਿਚ ਬੈਠ ਕੇ) ਆਪ ਹੀ (ਆਪਣੇ ਆਪ ਨੂੰ ਯਾਦ ਕਰ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Весь этот мир Сам Господь и создал, и, пребывая в существах мира, Сам же помнит Самого Себя.1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1052,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13180,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "Asṭapadī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13181,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਅਕਾਰੁ ਇਹੁ ਕਛੁ ਨ ਦ੍ਰਿਸਟੇਤਾ ॥",
          "roman": "Jab akār ih kachh na drisṭetā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਜਗਤ ਦੇ ਜੀਆਂ ਦੀ ਅਜੇ) ਕੋਈ ਸ਼ਕਲ ਹੀ ਨਹੀਂ ਦਿੱਸਦੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда ещё вовсе не было видно никакого облика живых существ мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13182,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਪੁੰਨ ਤਬ ਕਹ ਤੇ ਹੋਤਾ ॥",
          "roman": "Pāp puṅn tab kah te hotā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਪਾਪ ਜਾਂ ਪੁੰਨ ਕਿਸ (ਜੀਵ) ਤੋਂ ਹੋ ਸਕਦਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда от какого существа могли бы происходить грех или заслуга?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13183,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਧਾਰੀ ਆਪਨ ਸੁੰਨ ਸਮਾਧਿ ॥",
          "roman": "Jab dhārī āpan suṅn samādh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ (ਪ੍ਰਭੂ ਨੇ) ਆਪ ਅਫੁਰ ਅਵਸਥਾ ਵਾਲੀ ਸਮਾਧੀ ਲਾਈ ਹੋਈ ਸੀ (ਭਾਵ ਜਦੋਂ ਆਪਣੇ ਆਪ ਵਿਚ ਹੀ ਮਸਤ ਸੀ),"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь Сам пребывал в самопогружении состояния пустоты, то есть был погружён лишь в Самого Себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13184,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਬੈਰ ਬਿਰੋਧ ਕਿਸੁ ਸੰਗਿ ਕਮਾਤਿ ॥",
          "roman": "Tab bēr birodh kis saṅg kamāt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ (ਕਿਸ ਨੇ) ਕਿਸੇ ਨਾਲ ਵੈਰ-ਵਿਰੋਧ ਕਮਾਉਣਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто и с кем мог бы вести вражду и противостояние?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13185,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਇਸ ਕਾ ਬਰਨੁ ਚਿਹਨੁ ਨ ਜਾਪਤ ॥",
          "roman": "Jab is kā barna chihan na jāpat.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਇਸ (ਜਗਤ) ਦਾ ਕੋਈ ਰੰਗ-ਰੂਪ ਹੀ ਨਹੀਂ ਸੀ ਦਿੱਸਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Когда у этого мира ещё вовсе не было видно никакого цвета и облика,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13186,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਹਰਖ ਸੋਗ ਕਹੁ ਕਿਸਹਿ ਬਿਆਪਤ ॥",
          "roman": "Tab harakh sog kaho kiseh biāpat.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ ਖ਼ੁਸ਼ੀ ਜਾਂ ਚਿੰਤਾ ਕਿਸ ਨੂੰ ਪੋਹ ਸਕਦੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажи, кого могли затронуть радость или тревога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13187,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਆਪਨ ਆਪ ਆਪਿ ਪਾਰਬ੍ਰਹਮ ॥",
          "roman": "Jab āpan āp āp Pārbrahm.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਕਾਲ ਪੁਰਖ ਕੇਵਲ ਆਪ ਹੀ ਆਪ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Акал Пуракх был только Сам по Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13188,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਮੋਹ ਕਹਾ ਕਿਸੁ ਹੋਵਤ ਭਰਮ ॥",
          "roman": "Tab moh kahā kis hovt bharam.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਮੋਹ ਕਿਥੇ ਹੋ ਸਕਦਾ ਸੀ, ਤੇ ਭਰਮ-ਭੁਲੇਖੇ ਕਿਸ ਨੂੰ ਹੋ ਸਕਦੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда где могло быть привязанность, и у кого могли быть заблуждения?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
