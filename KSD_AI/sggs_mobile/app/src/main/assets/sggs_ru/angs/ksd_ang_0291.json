{
  "ang": 291,
  "shabads": [
    {
      "shabad_id": 1052,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13189,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਖੇਲੁ ਆਪਿ ਵਰਤੀਜਾ ॥",
          "roman": "Āpan khel āp vartījā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਗਤ ਰੂਪ) ਅਪਾਣੀ ਖੇਡ ਪ੍ਰਭੂ ਨੇ ਆਪ ਬਣਾਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Свою игру в виде мира Господь Сам и устроил,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13190,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਰਨੈਹਾਰੁ ਨ ਦੂਜਾ ॥੧॥",
          "roman": "Nānak karṇēhār na dūjā.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਸ ਤੋਂ ਬਿਨਾ ਇਸ ਖੇਡ ਦਾ) ਬਨਾਉਣ ਵਾਲਾ ਕੋਈ ਹੋਰ ਨਹੀਂ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Кроме Него, нет иного создателя этой игры.1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1053,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13191,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਹੋਵਤ ਪ੍ਰਭ ਕੇਵਲ ਧਨੀ ॥",
          "roman": "Jab hovat prabh keval dhanī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਾਲਕ ਪ੍ਰਭੂ ਸਿਰਫ਼ (ਆਪ ਹੀ) ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Владыка Господь был только Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13192,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਬੰਧ ਮੁਕਤਿ ਕਹੁ ਕਿਸ ਕਉ ਗਨੀ ॥",
          "roman": "Tab bandh mukt kaho kis kau gaṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ, ਕਿਸ ਨੂੰ ਬੰਧਨਾਂ ਵਿਚ ਫਸਿਆ ਹੋਇਆ, ਤੇ ਕਿਸ ਨੂੰ ਮੁਕਤਿ ਸਮਝੀਏ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажи, кого считать связанным узами, а кого — освобождённым?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13193,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਏਕਹਿ ਹਰਿ ਅਗਮ ਅਪਾਰ ॥",
          "roman": "Jab ekah Har agam apār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਗਮ ਤੇ ਬੇਅੰਤ ਪ੍ਰਭੂ ਇਕ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда недостижимый и беспредельный Господь был Один Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13194,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਨਰਕ ਸੁਰਗ ਕਹੁ ਕਉਨ ਅਉਤਾਰ ॥",
          "roman": "Tab narak surag kaho kaun autār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ, ਨਰਕਾਂ ਤੇ ਸੁਰਗਾਂ ਵਿਚ ਆਉਣ ਵਾਲੇ ਕੇਹੜੇ ਜੀਵ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажи, какие существа могли приходить в ад или в рай?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13195,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਨਿਰਗੁਨ ਪ੍ਰਭ ਸਹਜ ਸੁਭਾਇ ॥",
          "roman": "Jab nirguṇ prabh sahaj subhāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਸੁਤੇ ਹੀ ਪ੍ਰਭੂ ਤ੍ਰਿਗੁਣੀ ਮਾਇਆ ਤੋਂ ਪਰੇ ਸੀ, (ਭਾਵ, ਜਦੋਂ ਉਸ ਨੇ ਮਾਇਆ ਰਚੀ ਹੀ ਨਹੀਂ ਸੀ)"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь по самой Своей природе был вне трёх गुणов майи, то есть когда Он ещё вовсе не создал майю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13196,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਸਿਵ ਸਕਤਿ ਕਹਹੁ ਕਿਤੁ ਠਾਇ ॥",
          "roman": "Tab siv śakat kahah kit ṭhāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ, ਕਿਥੇ ਸਨ ਜੀਵ ਤੇ ਕਿਥੇ ਸੀ ਮਾਇਆ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажите, где были живые существа и где была майя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13197,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਆਪਹਿ ਆਪਿ ਅਪਨੀ ਜੋਤਿ ਧਰੈ ॥",
          "roman": "Jab āpah āp apnī jot dharē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਆਪ ਹੀ ਆਪਣੀ ਜੋਤਿ ਜਗਾਈ ਬੈਠਾ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь Сам в Себе держал зажжённым Свой собственный Свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13198,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਕਵਨ ਨਿਡਰੁ ਕਵਨ ਕਤ ਡਰੈ ॥",
          "roman": "Tab kavan niḍar kavan kat ḍarē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੌਣ ਨਿਡਰ ਸੀ ਤੇ ਕੌਣ ਕਿਸੇ ਤੋਂ ਡਰਦੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто был бесстрашен, и кто мог кого бояться?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13199,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਚਲਿਤ ਆਪਿ ਕਰਨੈਹਾਰ ॥",
          "roman": "Āpan chalit āp karṇēhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਤਮਾਸ਼ੇ ਆਪ ਹੀ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он Сам есть Тот, Кто Сам совершает Своё представление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13200,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਠਾਕੁਰ ਅਗਮ ਅਪਾਰ ॥੨॥",
          "roman": "Nānak ṭhākur agam apār.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਕਾਲ ਪੁਰਖ ਅਗਮ ਤੇ ਬੇਅੰਤ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Акал Пуракх недостижим и беспределен.2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1054,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13201,
          "is_rahao": false,
          "gurmukhi": "ਅਬਿਨਾਸੀ ਸੁਖ ਆਪਨ ਆਸਨ ॥",
          "roman": "Abināsī sukh āpan āsan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਕਾਲ ਪੁਰਖ ਆਪਣੀ ਮੌਜ ਵਿਚ ਆਪਣੇ ਹੀ ਸਰੂਪ ਵਿਚ ਟਿਕਿਆ ਬੈਠਾ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Акал Пуракх в Своей радости пребывал утверждённым в Своём собственном существе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13202,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਜਨਮ ਮਰਨ ਕਹੁ ਕਹਾ ਬਿਨਾਸਨ ॥",
          "roman": "Tah janam maran kaho kahā bināsan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ, ਜੰਮਣਾ ਮਰਨਾ ਤੇ ਮੌਤ ਕਿਥੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажи, где были рождение, смерть и уничтожение?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13203,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਪੂਰਨ ਕਰਤਾ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "Jab pūran kartā prabh soi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਕਰਤਾਰ ਪੂਰਨ ਪ੍ਰਭੂ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда совершенный Творец Господь был лишь Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13204,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਜਮ ਕੀ ਤ੍ਰਾਸ ਕਹਹੁ ਕਿਸੁ ਹੋਇ ॥",
          "roman": "Tab jam kī trās kahah kis hoi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਦੱਸੋ, ਮੌਤ ਦਾ ਡਰ ਕਿਸ ਨੂੰ ਹੋ ਸਕਦਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда скажи, у кого мог быть страх смерти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13205,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਅਬਿਗਤ ਅਗੋਚਰ ਪ੍ਰਭ ਏਕਾ ॥",
          "roman": "Jab abigat agochar prabh ekā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਦ੍ਰਿਸ਼ਟ ਤੇ ਅਗੋਚਰ ਪ੍ਰਭੂ ਇਕ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда невидимый и непостижимый Господь был Один Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13206,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਚਿਤ੍ਰ ਗੁਪਤ ਕਿਸੁ ਪੂਛਤ ਲੇਖਾ ॥",
          "roman": "Tab chitr gupt kis pūchhat lekhā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਚਿਤ੍ਰ ਗੁਪਤ ਕਿਸ ਨੂੰ ਲੇਖਾ ਪੁੱਛ ਸਕਦੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда у кого Читр Гупт мог бы спрашивать счёт деяний?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13207,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਨਾਥ ਨਿਰੰਜਨ ਅਗੋਚਰ ਅਗਾਧੇ ॥",
          "roman": "Jab nāth nirañjan agochar agādhe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਾਲਕ ਮਾਇਆ-ਰਹਿਤ ਅਥਾਹ ਅਗੋਚਰ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Владыка, свободный от майи, бездонный и непостижимый, был лишь Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13208,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਕਉਨ ਛੁਟੇ ਕਉਨ ਬੰਧਨ ਬਾਧੇ ॥",
          "roman": "Tab kaun chhuṭe kaun bandhan bādhe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੌਣ ਮਾਇਆ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਮੁਕਤ ਸਨ ਤੇ ਕੌਣ ਬੰਧਨਾਂ ਵਿਚ ਬੱਝੇ ਹੋਏ ਹਨ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто был свободен от уз майи, а кто — связан этими узами?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13209,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਆਪ ਆਪ ਹੀ ਅਚਰਜਾ ॥",
          "roman": "Āpan āp āp hī acharjā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਚਰਜ-ਰੂਪ ਪ੍ਰਭੂ ਆਪਣੇ ਵਰਗਾ ਆਪ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот чудесный Господь Сам подобен Самому Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13210,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਪਨ ਰੂਪ ਆਪ ਹੀ ਉਪਰਜਾ ॥੩॥",
          "roman": "Nānak āpan rūp āp hī uparjā.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਆਪਣਾ ਆਕਾਰ ਉਸ ਨੇ ਆਪ ਹੀ ਪੈਦਾ ਕੀਤਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Свой собственный образ Он Сам и породил.3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1055,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13211,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਨਿਰਮਲ ਪੁਰਖੁ ਪੁਰਖ ਪਤਿ ਹੋਤਾ ॥",
          "roman": "Jah nirmal purakh purakh pat hotā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਅਵਸਥਾ ਵਿਚ ਜੀਵਾਂ ਦਾ ਮਾਲਕ ਨਿਰਮਲ ਪ੍ਰਭੂ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "В том состоянии, где был лишь чистый Господь, Владыка существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13212,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬਿਨੁ ਮੈਲੁ ਕਹਹੁ ਕਿਆ ਧੋਤਾ ॥",
          "roman": "Tah bin mēl kaho kiā dhotā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਥੇ ਉਹ ਮੈਲ-ਰਹਿਤ ਸੀ, ਤਾਂ ਦੱਸੋ, ਉਸ ਨੇ ਕੇਹੜੀ ਮੈਲ ਧੋਣੀ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "там Он был без скверны, так скажи, какую скверну Ему надо было смывать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13213,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਨਿਰੰਜਨ ਨਿਰੰਕਾਰ ਨਿਰਬਾਨ ॥",
          "roman": "Jah nirañjan niraṅkār nirbān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਮਾਇਆ-ਰਹਿਤ, ਆਕਾਰ-ਰਹਿਤ ਤੇ ਵਾਸ਼ਨਾ-ਰਹਿਤ ਪ੍ਰਭੂ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Где был лишь свободный от майи, бесформенный и лишённый желаний Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13214,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਕਉਨ ਕਉ ਮਾਨ ਕਉਨ ਅਭਿਮਾਨ ॥",
          "roman": "Tah kaun kau mān kaun abhimān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਮਾਣ ਅਹੰਕਾਰ ਕਿਸ ਨੂੰ ਹੋਣਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "там у кого могли быть честь и гордыня?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13215,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਸਰੂਪ ਕੇਵਲ ਜਗਦੀਸ ॥",
          "roman": "Jah sarūp keval Jagdīs.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਕੇਵਲ ਜਗਤ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਦੀ ਹੀ ਹਸਤੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Где существование имел только Господь, Владыка мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13216,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਛਲ ਛਿਦ੍ਰ ਲਗਤ ਕਹੁ ਕੀਸ ॥",
          "roman": "Tah chhal chhidar lagat kaho kīs.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਥੇ ਦੱਸੋ, ਛਲ ਤੇ ਐਬ ਕਿਸ ਨੂੰ ਲੱਗ ਸਕਦੇ ਸਨ?"
            },
            "sahib_singh_ru": {
              "main": "там скажи, кого могли коснуться обман и изъян?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13217,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜੋਤਿ ਸਰੂਪੀ ਜੋਤਿ ਸੰਗਿ ਸਮਾਵੈ ॥",
          "roman": "Jah jot sarūpī jot saṅg samāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਜੋਤਿ-ਰੂਪ ਪ੍ਰਭੂ ਆਪਣੀ ਹੀ ਜੋਤਿ ਵਿਚ ਲੀਨ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда светоносный Господь был погружён в Свой собственный Свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13218,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਕਿਸਹਿ ਭੂਖ ਕਵਨੁ ਤ੍ਰਿਪਤਾਵੈ ॥",
          "roman": "Tah kiseh bhūkh kavan triptāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕਿਸ ਨੂੰ (ਮਾਇਆ ਦੀ) ਭੁੱਖ ਹੋ ਸਕਦੀ ਸੀ ਤੇ ਕੌਣ ਰੱਜਿਆ ਹੋਇਆ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда у кого могла быть жажда майи, и кто мог быть насыщен?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13219,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਕਰਨੈਹਾਰੁ ॥",
          "roman": "Karaṇ karāvan karṇēhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰਤਾਰ ਆਪ ਹੀ ਸਭ ਕੁਝ ਕਰਨ ਵਾਲਾ ਤੇ ਜੀਵਾਂ ਤੋਂ ਕਰਾਉਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Творец Сам всё совершает и Сам побуждает существа совершать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13220,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਰਤੇ ਕਾ ਨਾਹਿ ਸੁਮਾਰੁ ॥੪॥",
          "roman": "Nānak karte kā nāh sumār.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਕਰਤਾਰ ਦਾ ਅੰਦਾਜ਼ਾ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Невозможно измерить Творца.4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1056,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13221,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਅਪਨੀ ਸੋਭਾ ਆਪਨ ਸੰਗਿ ਬਨਾਈ ॥",
          "roman": "Jab apnī sobhā āpan saṅg banāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਨੇ ਆਪਣੀ ਸੋਭਾ ਆਪਣੇ ਹੀ ਨਾਲ ਬਣਾਈ ਸੀ (ਭਾਵ, ਜਦੋਂ ਕੋਈ ਹੋਰ ਉਸ ਦੀ ਸੋਭਾ ਕਰਨ ਵਾਲਾ ਨਹੀਂ ਸੀ)"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь создал Свою славу лишь с Самим Собой, то есть когда не было никого иного, кто бы мог Его прославлять,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13222,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਕਵਨ ਮਾਇ ਬਾਪ ਮਿਤ੍ਰ ਸੁਤ ਭਾਈ ॥",
          "roman": "Tab kavan māe bāp mitar sut bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੌਣ ਮਾਂ, ਪਿਉ, ਮਿਤ੍ਰ, ਪੁਤ੍ਰ ਜਾਂ ਭਰਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто был матерью, отцом, другом, сыном или братом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13223,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਸਰਬ ਕਲਾ ਆਪਹਿ ਪਰਬੀਨ ॥",
          "roman": "Jah sarab kalā āpah parbīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਕਾਲ ਪੁਰਖ ਆਪ ਹੀ ਸਾਰੀਆਂ ਤਾਕਤਾਂ ਵਿਚ ਸਿਆਣਾ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Акал Пуракх Сам был искусен во всех силах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13224,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਬੇਦ ਕਤੇਬ ਕਹਾ ਕੋਊ ਚੀਨ ॥",
          "roman": "Tah bed kateb kahā koū chīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕਿਥੇ ਕੋਈ ਵੇਦ (ਹਿੰਦੂ ਧਰਮ ਪੁਸਤਕ) ਤੇ ਕਤੇਬਾਂ (ਮੁਸਲਮਾਨਾਂ ਦੇ ਧਰਮ ਪੁਸਤਕ) ਵਿਚਾਰਦਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда где был кто-либо, размышляющий о Ведах или китобах?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13225,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਆਪਨ ਆਪੁ ਆਪਿ ਉਰਿ ਧਾਰੈ ॥",
          "roman": "Jab āpan āp āp ur dhārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਆਪਣੇ ਆਪ ਨੂੰ ਆਪ ਹੀ ਆਪਣੇ ਆਪ ਵਿਚ ਟਿਕਾਈ ਬੈਠਾ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь Сам удерживал Самого Себя в Самом Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13226,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਸਗਨ ਅਪਸਗਨ ਕਹਾ ਬੀਚਾਰੈ ॥",
          "roman": "Tau sagan apsagan kahā bīchārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਚੰਗੇ ਮੰਦੇ ਸਗਨ ਕੌਣ ਸੋਚਦਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто размышлял о добрых или дурных предзнаменованиях?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13227,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਆਪਨ ਊਚ ਆਪਨ ਆਪਿ ਨੇਰਾ ॥",
          "roman": "Jah āpan ūch āpan āp nerā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਹ ਆਪ ਹੀ ਉੱਚਾ ਅਤੇ ਆਪ ਅਤੇ ਆਪ ਹੀ ਨੀਵਾਂ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Он Сам был и высоким, и Сам же был низким,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13228,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਕਉਨ ਠਾਕੁਰੁ ਕਉਨੁ ਕਹੀਐ ਚੇਰਾ ॥",
          "roman": "Tah kaun ṭhākur kaun kahīai cherā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸੋ ਮਾਲਕ ਕੌਣ ਸੀ ਤੇ ਸੇਵਕ ਕੌਣ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "скажи, кто был господином, а кто — слугой?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13229,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸਮਨ ਬਿਸਮ ਰਹੇ ਬਿਸਮਾਦ ॥",
          "roman": "Bisman bisam rahe bismād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵ ਤੇਰੀ ਗਤਿ ਭਾਲਦੇ ਹੈਰਾਨ ਤੇ ਅਚਰਜ ਹੋ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Живые существа, пытаясь постичь Твоё состояние, остаются поражёнными и изумлёнными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13230,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਪਨੀ ਗਤਿ ਜਾਨਹੁ ਆਪਿ ॥੫॥",
          "roman": "Nānak apnī gat jānhu āp.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਅੱਗੇ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ-ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਆਪਣੀ ਗਤਿ ਆਪ ਹੀ ਜਾਣਦਾ ਹੈਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Молись и говори так: О Господь, лишь Ты Сам знаешь Своё собственное состояние.5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1057,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13231,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਅਛਲ ਅਛੇਦ ਅਭੇਦ ਸਮਾਇਆ ॥",
          "roman": "Jah achhal achhed abhed samāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਅਵਸਥਾ ਵਿਚ ਅਛੱਲ ਅਬਿਨਾਸੀ ਤੇ ਅਭੇਦ ਪ੍ਰਭੂ (ਆਪਣੇ ਆਪ ਵਿਚ) ਟਿਕਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В том состоянии, где пребывает недвижимый, неразрушимый и неделимый Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13232,
          "is_rahao": false,
          "gurmukhi": "ਊਹਾ ਕਿਸਹਿ ਬਿਆਪਤ ਮਾਇਆ ॥",
          "roman": "Ūhā kiseh biāpat māiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਥੇ ਕਿਸ ਨੂੰ ਮਾਇਆ ਪੋਹ ਸਕਦੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "там кого могла бы коснуться майя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13233,
          "is_rahao": false,
          "gurmukhi": "ਆਪਸ ਕਉ ਆਪਹਿ ਆਦੇਸੁ ॥",
          "roman": "Āpas kau āpah ādes.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ) ਪ੍ਰਭੂ ਆਪਣੇ ਆਪ ਨੂੰ ਆਪ ਹੀ ਨਮਸਕਾਰ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда Господь Сам Себе кланяется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13234,
          "is_rahao": false,
          "gurmukhi": "ਤਿਹੁ ਗੁਣ ਕਾ ਨਾਹੀ ਪਰਵੇਸੁ ॥",
          "roman": "Tih guṇ kā nāhī parves.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ) ਤਿੰਨ ਗੁਣਾਂ ਦਾ (ਉਸ ਉਤੇ) ਅਸਰ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и три गुणа майи на Него не действуют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13235,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਏਕਹਿ ਏਕ ਏਕ ਭਗਵੰਤਾ ॥",
          "roman": "Jah ekah ek ek Bhagvaṅtā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਭਗਵਾਨ ਕੇਵਲ ਇਕ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Бхагвант был лишь Один Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13236,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਕਉਨੁ ਅਚਿੰਤੁ ਕਿਸੁ ਲਾਗੈ ਚਿੰਤਾ ॥",
          "roman": "Tah kaun achiṅt kis lāgē chiṅtā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੌਣ ਬੇ-ਫ਼ਿਕਰ ਸੀ ਤੇ ਕਿਸ ਨੂੰ ਕੋਈ ਚਿੰਤਾ ਲੱਗਦੀ ਸੀ।"
            },
            "sahib_singh_ru": {
              "main": "тогда кто был беззаботен, и к кому могла пристать тревога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13237,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਆਪਨ ਆਪੁ ਆਪਿ ਪਤੀਆਰਾ ॥",
          "roman": "Jah āpan āp āp patīārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਆਪਣੇ ਆਪ ਨੂੰ ਪਤਿਆਉਣ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪ ਹੀ ਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Тот, Кто удостоверяет Самого Себя, был лишь Сам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13238,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਕਉਨੁ ਕਥੈ ਕਉਨੁ ਸੁਨਨੈਹਾਰਾ ॥",
          "roman": "Tah kaun kathē kaun sunnēhārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੌਣ ਬੋਲਦਾ ਸੀ, ਤੇ ਕੌਣ ਸੁਣਨ ਵਾਲਾ ਸੀ?"
            },
            "sahib_singh_ru": {
              "main": "тогда кто говорил, и кто был слушателем?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13239,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਬੇਅੰਤ ਊਚ ਤੇ ਊਚਾ ॥",
          "roman": "Bah beaṅt ūch te ūchā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਬੜਾ ਬੇਅੰਤ ਹੈ, ਸਭ ਤੋਂ ਉੱਚਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь безмерно беспределен и превыше всего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13240,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਪਸ ਕਉ ਆਪਹਿ ਪਹੂਚਾ ॥੬॥",
          "roman": "Nānak āpas kau āpahi pahūchā.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਆਪਣੇ ਆਪ ਤਕ ਆਪ ਹੀ ਅੱਪੜਨ ਵਾਲਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Лишь Сам Он доходит до Самого Себя.6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1058,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13241,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਆਪਿ ਰਚਿਓ ਪਰਪੰਚੁ ਅਕਾਰੁ ॥",
          "roman": "Jah āp rachiō parpaṅch akāar.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪ੍ਰਭੂ ਨੇ ਆਪ ਜਗਤ ਦੀ ਖੇਡ ਰਚ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь Сам развернул игру мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13242,
          "is_rahao": false,
          "gurmukhi": "ਤਿਹੁ ਗੁਣ ਮਹਿ ਕੀਨੋ ਬਿਸਥਾਰੁ ॥",
          "roman": "Tih guṇ mah kīno bisthār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ ਦਾ ਖਿਲਾਰਾ ਖਲੇਰ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "и распространил развёртывание трёх गुणов майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13243,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪੁ ਪੁੰਨੁ ਤਹ ਭਈ ਕਹਾਵਤ ॥",
          "roman": "Pāp puṅn tah bhaī kahāvat.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਇਹ ਗੱਲ ਚੱਲ ਪਈ ਕਿ ਇਹ ਪਾਪ ਹੈ ਇਹ ਪੁੰਨ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тогда и пошло различение: это грех, а это заслуга,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
