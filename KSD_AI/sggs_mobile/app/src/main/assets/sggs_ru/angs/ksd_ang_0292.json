{
  "ang": 292,
  "shabads": [
    {
      "shabad_id": 1058,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13244,
          "is_rahao": false,
          "gurmukhi": "ਕੋਊ ਨਰਕ ਕੋਊ ਸੁਰਗ ਬੰਛਾਵਤ ॥",
          "roman": "Koū narak koū surag baṅchhāvat.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਕੋਈ ਜੀਵ ਨਰਕਾਂ ਦਾ ਭਾਗੀ ਤੇ ਕੋਈ ਸੁਰਗਾਂ ਦਾ ਚਾਹਵਾਨ ਬਣਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "тогда одни существа стали уделом ада, а другие — желающими рая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13245,
          "is_rahao": false,
          "gurmukhi": "ਆਲ ਜਾਲ ਮਾਇਆ ਜੰਜਾਲ ॥",
          "roman": "Āl jāl māiā jañjāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘਰਾਂ ਦੇ ਧੰਧੇ, ਮਾਇਆ ਦੇ ਬੰਧਨ,"
            },
            "sahib_singh_ru": {
              "main": "Домашние заботы, узы майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13246,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮੋਹ ਭਰਮ ਭੈ ਭਾਰ ॥",
          "roman": "Haumē moh bharam bhē bhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਹੰਕਾਰ, ਮੋਹ, ਭੁਲੇਖੇ, ਡਰ,"
            },
            "sahib_singh_ru": {
              "main": "Хоумэ, привязанность, заблуждения, страх,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13247,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਸੂਖ ਮਾਨ ਅਪਮਾਨ ॥",
          "roman": "Dūkh sūkh mān apmān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਖ, ਸੁਖ, ਆਦਰ ਨਿਰਾਦਰੀ-"
            },
            "sahib_singh_ru": {
              "main": "страдание, счастье, почёт, бесчестие —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13248,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਪ੍ਰਕਾਰ ਕੀਓ ਬਖੵਾਨ ॥",
          "roman": "Anik prakār kīo bakhyān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੋ ਜਿਹੀਆਂ ਕਈ ਕਿਸਮ ਦੀਆਂ ਗੱਲਾਂ ਚੱਲ ਪਈਆਂ।"
            },
            "sahib_singh_ru": {
              "main": "вот так возникли многие виды подобных разговоров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13249,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਖੇਲੁ ਆਪਿ ਕਰਿ ਦੇਖੈ ॥",
          "roman": "Āpan khel āp kar dekhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣਾ ਤਮਾਸ਼ਾ ਕਰ ਕੇ ਆਪ ਵੇਖ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам устроил это представление и Сам же наблюдает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13250,
          "is_rahao": false,
          "gurmukhi": "ਖੇਲੁ ਸੰਕੋਚੈ ਤਉ ਨਾਨਕ ਏਕੈ ॥੭॥",
          "roman": "Khel saṅkochē tau Nānak ekē.7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਦੋਂ ਇਸ ਖੇਡ ਨੂੰ ਸਮੇਟਦਾ ਹੈ ਤਾਂ ਇਕ ਆਪ ਹੀ ਆਪ ਹੋ ਜਾਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Когда Он сворачивает эту игру, остаётся Один лишь Сам.7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1059,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13251,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਅਬਿਗਤੁ ਭਗਤੁ ਤਹ ਆਪਿ ॥",
          "roman": "Jah abigat bhagat tah āp.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਥੇ ਅਦ੍ਰਿਸ਼ਟ ਪ੍ਰਭੂ ਹੈ ਓਥੇ ਉਸ ਦਾ ਭਗਤ ਹੈ, ਜਿਥੇ ਭਗਤ ਹੈ ਓਥੇ ਉਹ ਪ੍ਰਭੂ ਆਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Где есть невидимый Господь, там есть и Его бхагат; где есть бхагат, там Сам Он и есть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13252,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਪਸਰੈ ਪਾਸਾਰੁ ਸੰਤ ਪਰਤਾਪਿ ॥",
          "roman": "Jah pasrē pāsār sant partāp.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਥਾਂ ਸੰਤਾਂ ਦੀ ਮਹਿਮਾ ਵਾਸਤੇ ਪ੍ਰਭੂ ਜਗਤ ਦਾ ਖਿਲਾਰਾ ਖਿਲਾਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Повсюду Господь разворачивает мир ради славы святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13253,
          "is_rahao": false,
          "gurmukhi": "ਦੁਹੂ ਪਾਖ ਕਾ ਆਪਹਿ ਧਨੀ ॥",
          "roman": "Duhū pākh kā āpah dhanī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਤਾਂ ਦਾ ਪ੍ਰਤਾਪ ਤੇ ਮਾਇਆ ਦਾ ਪ੍ਰਭਾਵ-ਇਨ੍ਹਾਂ) ਦੋਹਾਂ ਪੱਖਾਂ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਆਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам — владыка обеих сторон, и славы святых, и действия майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13254,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਕੀ ਸੋਭਾ ਉਨਹੂ ਬਨੀ ॥",
          "roman": "Un kī sobhā unhū banī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਆਪਣੀ ਸੋਭਾ ਆਪ ਹੀ ਜਾਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам знает Свою собственную славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13255,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਕਉਤਕ ਕਰੈ ਅਨਦ ਚੋਜ ॥",
          "roman": "Āpah kautak karē anad choj.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪ ਹੀ ਖੇਡਾਂ ਖੇਡ ਰਿਹਾ ਹੈ ਆਪ ਹੀ ਆਨੰਦ ਤਮਾਸ਼ੇ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам ведёт игры и Сам совершает радостные забавы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13256,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਰਸ ਭੋਗਨ ਨਿਰਜੋਗ ॥",
          "roman": "Āpah ras bhogan nirjog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ ਰਸਾਂ ਨੂੰ ਭੋਗਣ ਵਾਲਾ ਹੈ ਤੇ ਆਪ ਹੀ ਨਿਰਲੇਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам вкушает все вкусы и Сам же остаётся непричастным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13257,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਆਪਨ ਨਾਇ ਲਾਵੈ ॥",
          "roman": "Jis bhāvē tis āpan nāe lāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਉਸ ਨੂੰ ਭਾਉਂਦਾ ਹੈ, ਉਸ ਨੂੰ ਆਪਣੇ ਨਾਮ ਵਿਚ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто Ему люб, того Он соединяет со Своим Именем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13258,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਖੇਲ ਖਿਲਾਵੈ ॥",
          "roman": "Jis bhāvē tis khel khilāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਿਸ ਨੂੰ ਚਾਹੁੰਦਾ ਹੈ ਮਾਇਆ ਦੀਆਂ ਖੇਡਾਂ ਖਿਡਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а кого пожелает, того вовлекает в игры майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13259,
          "is_rahao": false,
          "gurmukhi": "ਬੇਸੁਮਾਰ ਅਥਾਹ ਅਗਨਤ ਅਤੋਲੈ ॥",
          "roman": "Besumār athāh agnat atolē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਬੇਅੰਤ! ਹੇ ਅਥਾਹ! ਹੇ ਅਗਣਤ! ਹੇ ਅਡੋਲ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О беспредельный! О бездонный! О неисчислимый! О недвижимый Господь!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13260,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਬੁਲਾਵਹੁ ਤਿਉ ਨਾਨਕ ਦਾਸ ਬੋਲੈ ॥੮॥੨੧॥",
          "roman": "Jiū bulāvah tiū Nānak dās bolē.8.21.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ (ਇਉਂ ਅਰਦਾਸ ਕਰ ਤੇ ਆਖ) ਜਿਵੇਂ ਤੂੰ ਬੁਲਾਉਂਦਾ ਹੈਂ ਤਿਵੇਂ ਤੇਰੇ ਦਾਸ ਬੋਲਦੇ ਹਨ ॥੮॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись так и говори: как Ты велишь, так и говорят Твои рабы.8.21."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1060,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13261,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13262,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਕੇ ਠਾਕੁਰਾ ਆਪੇ ਵਰਤਣਹਾਰ ॥",
          "roman": "jīa jant ke ṭhākurā āpe varṭanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜੀਆਂ ਜੰਤਾਂ ਦੇ ਪਾਲਣ ਵਾਲੇ ਪ੍ਰਭੂ! ਤੂੰ ਆਪ ਹੀ ਸਭ ਥਾਈਂ ਵਰਤ ਰਿਹਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, питающий всех живых существ! Ты Сам действуешь повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13263,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਏਕੋ ਪਸਰਿਆ ਦੂਜਾ ਕਹ ਦ੍ਰਿਸਟਾਰ ॥੧॥",
          "roman": "Nānak eko pasriā dūjā kah driṣṭār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਆਪ ਹੀ ਸਭ ਥਾਈਂ ਮੌਜੂਦ ਹੈ, (ਉਸ ਤੋਂ ਬਿਨਾ ਕੋਈ) ਦੂਜਾ ਕਿਥੇ ਵੇਖਣ ਵਿਚ ਆਇਆ ਹੈ? ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Сам Господь присутствует повсюду, и где видно кого-то второго помимо Него? ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1061,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13264,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13265,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਕਥੈ ਆਪਿ ਸੁਨਨੈਹਾਰੁ ॥",
          "roman": "āp kathē āp sunnēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਜੀਵਾਂ ਵਿਚ) ਪ੍ਰਭੂ ਆਪ ਬੋਲ ਰਿਹਾ ਹੈ ਆਪ ਹੀ ਸੁਣਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Во всех существах Сам Господь говорит и Сам же слушает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13266,
          "is_rahao": false,
          "gurmukhi": "ਆਪਹਿ ਏਕੁ ਆਪਿ ਬਿਸਥਾਰੁ ॥",
          "roman": "āpeh ek āp bisthār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਹੀ ਇੱਕ ਹੈ (ਸ੍ਰਿਸ਼ਟੀ ਰਚਣ ਤੋਂ ਪਹਿਲਾਂ), ਤੇ ਆਪ ਹੀ (ਜਗਤ ਨੂੰ ਆਪਣੇ ਵਿਚ) ਸਮੇਟ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам Один до сотворения мира и Сам же собирает мир в Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13267,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਤਿਸੁ ਭਾਵੈ ਤਾ ਸ੍ਰਿਸਟਿ ਉਪਾਏ ॥",
          "roman": "jā tis bhāvē tā srisṭ upāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ਤਾਂ ਸ੍ਰਿਸ਼ਟੀ ਰਚ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Ему угодно, Он творит мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13268,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨੈ ਭਾਣੈ ਲਏ ਸਮਾਏ ॥",
          "roman": "āpnē bhāṇē lae samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਸ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ (ਜਗਤ ਨੂੰ ਆਪਣੇ ਵਿਚ) ਸਮੇਟ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "когда Ему угодно, Он сворачивает его в Себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13269,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਤੇ ਭਿੰਨ ਨਹੀ ਕਿਛੁ ਹੋਇ ॥",
          "roman": "tum te bhinn nahī kichh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੈਥੋਂ ਵੱਖਰਾ ਕੁਝ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Нет ничего отдельного от Тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13270,
          "is_rahao": false,
          "gurmukhi": "ਆਪਨ ਸੂਤਿ ਸਭੁ ਜਗਤੁ ਪਰੋਇ ॥",
          "roman": "āpan sūt sabh jagat paroi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਆਪਣੇ ਹੁਕਮ-ਰੂਪ) ਧਾਗੇ ਵਿਚ ਸਾਰੇ ਜਗਤ ਨੂੰ ਪ੍ਰੋ ਰੱਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ты нанизал весь мир на нить Своего Хукама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13271,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਪ੍ਰਭ ਜੀਉ ਆਪਿ ਬੁਝਾਏ ॥",
          "roman": "jā kau prabh jīu āp bujhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਜੀ ਆਪ ਸੂਝ ਬਖ਼ਸ਼ਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, кому Сам Господь дарует понимание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13272,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਨਾਮੁ ਸੋਈ ਜਨੁ ਪਾਏ ॥",
          "roman": "sach nām soī jan pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦਾ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਨਾਮ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот человек обретает вечное Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13273,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਮਦਰਸੀ ਤਤ ਕਾ ਬੇਤਾ ॥",
          "roman": "so samdarsī tat kā betā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਭ ਵਲ ਇਕ ਨਜ਼ਰ ਨਾਲ ਤੱਕਦਾ ਹੈ, ਅਕਾਲ ਪੁਰਖ ਦਾ ਮਹਰਮ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такой человек смотрит на всех одинаково и становится знатоком сущности Акаал Пуракха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13274,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਗਲ ਸ੍ਰਿਸਟਿ ਕਾ ਜੇਤਾ ॥੧॥",
          "roman": "Nānak sagal srisṭ kā jetā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸਾਰੇ ਜਗਤ ਦਾ ਜਿੱਤਣ ਵਾਲਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Он победитель всего мира. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1062,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13275,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ੍ਰ ਸਭ ਤਾ ਕੈ ਹਾਥ ॥",
          "roman": "jīa jantar sabh tā kē hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵ ਜੰਤ ਉਸ ਪ੍ਰਭੂ ਦੇ ਵੱਸ ਵਿਚ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все живые существа находятся во власти того Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13276,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਅਨਾਥ ਕੋ ਨਾਥੁ ॥",
          "roman": "dīn daiāl anāth ko nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਦੀਨਾਂ ਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈ, ਤੇ, ਅਨਾਥਾਂ ਦਾ ਮਾਲਿਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он милостив к бедным и Владыка сирот."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13277,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਰਾਖੈ ਤਿਸੁ ਕੋਇ ਨ ਮਾਰੈ ॥",
          "roman": "jis rākhē tis koi na mārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਨੂੰ ਪ੍ਰਭੂ ਆਪ ਰੱਖਦਾ ਹੈ ਉਸ ਨੂੰ ਕੋਈ ਮਾਰ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Того существа, которого Сам Господь хранит, никто не может убить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13278,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮੂਆ ਜਿਸੁ ਮਨਹੁ ਬਿਸਾਰੈ ॥",
          "roman": "so mūā jis manh bisārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੋਇਆ ਹੋਇਆ (ਤਾਂ) ਉਹ ਜੀਵ ਹੈ ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਭੁਲਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По-настоящему мёртв тот, кого Господь заставляет забыться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13279,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਤਜਿ ਅਵਰ ਕਹਾ ਕੋ ਜਾਇ ॥",
          "roman": "tis taj avar kahā ko jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਛੱਡ ਕੇ ਹੋਰ ਕਿਥੇ ਕੋਈ ਜਾਏ?"
            },
            "sahib_singh_ru": {
              "main": "Оставив того Господа, куда ещё может кто-либо пойти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13280,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਸਿਰਿ ਏਕੁ ਨਿਰੰਜਨ ਰਾਇ ॥",
          "roman": "sabh sir ek niranjan rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੇ ਸਿਰ ਤੇ ਇਕ ਆਪ ਹੀ ਪ੍ਰਭੂ ਹੈ ਜੋ ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਪਰੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Над всеми существами есть только один Господь, свободный от влияния Майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13281,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਕੀ ਜੁਗਤਿ ਜਾ ਕੈ ਸਭ ਹਾਥਿ ॥",
          "roman": "jīa kī jugat jā kē sabh hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਵੱਸ ਵਿਚ ਸਭ ਜੀਵਾਂ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਭੇਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У Кого в руках тайна жизни всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13282,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਜਾਨਹੁ ਸਾਥਿ ॥",
          "roman": "antar bāhar jānh sāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਅੰਦਰ ਬਾਹਰ ਸਭ ਥਾਈਂ ਅੰਗ-ਸੰਗ ਜਾਣਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "того Господа знайте присутствующим внутри и вовне, повсюду рядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13283,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਨਿਧਾਨ ਬੇਅੰਤ ਅਪਾਰ ॥",
          "roman": "gun nidhān beant apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ, ਬੇਅੰਤ ਹੈ ਤੇ ਅਪਾਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он сокровищница добродетелей, беспределен и безмерен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13284,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸਦਾ ਬਲਿਹਾਰ ॥੨॥",
          "roman": "Nānak dās sadā balihār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ, ਪ੍ਰਭੂ ਦੇ) ਸੇਵਕ ਉਸ ਤੋਂ ਸਦਕੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Слуги Господа всегда отдают себя Ему. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1063,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13285,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹੇ ਦਇਆਲ ॥",
          "roman": "pūran pūr rahe daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦੇ ਘਰ ਪ੍ਰਭੂ ਜੀ ਸਭ ਥਾਈਂ ਭਰਪੂਰ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Милостивый Господь полон и пребывает всюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13286,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਊਪਰਿ ਹੋਵਤ ਕਿਰਪਾਲ ॥",
          "roman": "sabh ūpar hovat kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਭ ਜੀਵਾਂ ਤੇ ਮੇਹਰ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и ко всем существам проявляет милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13287,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਕਰਤਬ ਜਾਨੈ ਆਪਿ ॥",
          "roman": "apne kartab jānē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਖੇਲ ਆਪ ਜਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь Сам знает Свою игру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13288,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਰਹਿਓ ਬਿਆਪਿ ॥",
          "roman": "antarjāmī rahiō biāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਪ੍ਰਭੂ ਸਭ ਥਾਈਂ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всеведущий Господь пребывает повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13289,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਤਿਪਾਲੈ ਜੀਅਨ ਬਹੁ ਭਾਤਿ ॥",
          "roman": "pratipālē jīan bah bhāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਵਾਂ ਨੂੰ ਕਈ ਤਰੀਕੀਆਂ ਨਾਲ ਪਾਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он поддерживает живых существ множеством способов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13290,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਰਚਿਓ ਸੁ ਤਿਸਹਿ ਧਿਆਤਿ ॥",
          "roman": "jo jo rachiō so tiseh dhiāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੋ ਜੀਵ ਉਸ ਨੇ ਪੈਦਾ ਕੀਤਾ ਹੈ, ਉਹ ਉਸੇ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и каждое существо, которое Он создал, вспоминает именно Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13291,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਲਏ ਮਿਲਾਇ ॥",
          "roman": "jis bhāvē tis lae milāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਉਤੇ ਤ੍ਰੁੱਠਦਾ ਹੈ ਉਸ ਨੂੰ ਨਾਲ ਜੋੜ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кем Он доволен, Он соединяет с Собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13292,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰਹਿ ਹਰਿ ਕੇ ਗੁਣ ਗਾਇ ॥",
          "roman": "bhagat kareh har ke gun gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਤੇ ਤ੍ਰੁੱਠਦਾ ਹੈ) ਉਹ ਉਸ ਦੇ ਗੁਣ ਗਾ ਕੇ ਉਸ ਦੀ ਭਗਤੀ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и такие люди, воспевая Его качества, совершают Его бхагти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13293,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਅੰਤਰਿ ਬਿਸ੍ਵਾਸੁ ਕਰਿ ਮਾਨਿਆ ॥",
          "roman": "man antar bisvās kar māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਮਨ ਵਿਚ ਸ਼ਰਧਾ ਧਾਰ ਕੇ ਪ੍ਰਭੂ ਨੂੰ (ਸੱਚਮੁਚ ਹੋਂਦ ਵਾਲਾ) ਮੰਨ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто с верой в сердце принял Господа как поистине существующего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13294,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨਹਾਰੁ ਨਾਨਕ ਇਕੁ ਜਾਨਿਆ ॥੩॥",
          "roman": "karanhār Nānak ek jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੇ ਉਸ ਇੱਕ ਕਰਤਾਰ ਨੂੰ ਹੀ ਪਛਾਣਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот познал лишь одного Творца. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1064,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13295,
          "is_rahao": false,
          "gurmukhi": "ਜਨੁ ਲਾਗਾ ਹਰਿ ਏਕੈ ਨਾਇ ॥",
          "roman": "jan lāgā har ekē nāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ) ਸੇਵਕ ਇਕ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਟਿਕਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга, утвердившийся в Имени одного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13296,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਆਸ ਨ ਬਿਰਥੀ ਜਾਇ ॥",
          "roman": "tis kī ās na birthī jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਆਸ ਕਦੇ ਖ਼ਾਲੀ ਨਹੀਂ ਜਾਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "никогда не остаётся с напрасной надеждой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13297,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕ ਕਉ ਸੇਵਾ ਬਨਿ ਆਈ ॥",
          "roman": "sevak kau sevā ban āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਨੂੰ ਇਹ ਫੱਬਦਾ ਹੈ ਕਿ ਸਭ ਦੀ ਸੇਵਾ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "Слуге подобает служить всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13298,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਬੂਝਿ ਪਰਮ ਪਦੁ ਪਾਈ ॥",
          "roman": "hukam būjh param pad pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਸਮਝ ਕੇ ਉਸ ਨੂੰ ਉੱਚਾ ਦਰਜਾ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Поняв волю Господа, он обретает высшее состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13299,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਤੇ ਊਪਰਿ ਨਹੀ ਬੀਚਾਰੁ ॥",
          "roman": "is te ūpar nahī bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਇਸ (ਨਾਮ ਸਿਮਰਨ) ਤੋਂ ਵੱਡਾ ਹੋਰ ਕੋਈ ਵਿਚਾਰ ਨਹੀਂ ਸੁੱਝਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "Тем, в чьём уме живёт Нираṅкар, не приходит мысль выше этой практики памятования Имени;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13300,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਬਸਿਆ ਨਿਰੰਕਾਰੁ ॥",
          "roman": "jā kē man basiā nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ ਅਕਾਲ ਪੁਰਖ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "в чьём уме пребывает Акаал Пуракх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13301,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਤੋਰਿ ਭਏ ਨਿਰਵੈਰ ॥",
          "roman": "bandhan tor bhae nirvēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ) ਬੰਧਨ ਤੋੜ ਕੇ ਉਹ ਨਿਰਵੈਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Разорвав узы Майи, они становятся безвраждебными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13302,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਪੂਜਹਿ ਗੁਰ ਕੇ ਪੈਰ ॥",
          "roman": "andin pūjeh gur ke pēr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਹਰ ਵੇਲੇ ਸਤਿਗੁਰੂ ਦੇ ਚਰਨ ਪੂਜਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и во всякое время почитают стопы Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13303,
          "is_rahao": false,
          "gurmukhi": "ਇਹ ਲੋਕ ਸੁਖੀਏ ਪਰਲੋਕ ਸੁਹੇਲੇ ॥",
          "roman": "ih lok sukhīe parlok suhele",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਇਸ ਜਨਮ ਵਿਚ ਸੁਖੀ ਹਨ, ਤੇ ਪਰਲੋਕ ਵਿਚ ਭੀ ਸੌਖੇ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Такие люди счастливы в этой жизни и благополучны в ином мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
