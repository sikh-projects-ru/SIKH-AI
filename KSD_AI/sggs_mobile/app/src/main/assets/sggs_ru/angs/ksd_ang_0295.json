{
  "ang": 295,
  "shabads": [
    {
      "shabad_id": 1077,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13424,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਸਭੁ ਜਗਤੁ ਤਰਾਇਆ ॥",
          "roman": "jis prasād sabh jagat tarāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮੇਹਰ ਨਾਲ ਸਾਰਾ ਜਗਤ ਹੀ ਤਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "по чьей милости спасается весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13425,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਆਵਨ ਕਾ ਇਹੈ ਸੁਆਉ ॥",
          "roman": "jan āvan kā ihē suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜਿਹੇ ਮਨੁੱਖ ਦੇ ਆਉਣ ਦਾ ਇਹੀ ਮਨੋਰਥ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Именно в этом цель прихода такого человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13426,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੈ ਸੰਗਿ ਚਿਤਿ ਆਵੈ ਨਾਉ ॥",
          "roman": "jan kē sang chit āvē nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ ਹੋਰ ਮਨੁੱਖਾਂ ਨੂੰ ਪ੍ਰਭੂ ਦਾ) ਨਾਮ ਚੇਤੇ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "что в его сангате другим людям вспоминается Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13427,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਮੁਕਤੁ ਮੁਕਤੁ ਕਰੈ ਸੰਸਾਰੁ ॥",
          "roman": "āp mukat mukat karē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪ (ਮਾਇਆ ਤੋਂ) ਆਜ਼ਾਦ ਹੈ, ਜਗਤ ਨੂੰ ਭੀ ਮੁਕਤ ਕਰਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Он сам свободен от майи и делает свободным также мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13428,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਜਨ ਕਉ ਸਦਾ ਨਮਸਕਾਰੁ ॥੮॥੨੩॥",
          "roman": "Nānak tis jan kau sadā namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਐਸੇ (ਉੱਤਮ) ਮਨੁੱਖ ਨੂੰ ਸਾਡੀ ਸਦਾ ਪ੍ਰਣਾਮ ਹੈ ॥੮॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такому возвышенному человеку наш вечный поклон. ॥8॥23॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1078,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13429,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13430,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਪ੍ਰਭੁ ਆਰਾਧਿਆ ਪੂਰਾ ਜਾ ਕਾ ਨਾਉ ॥",
          "roman": "pūrā prabh ārādhiā pūrā jā kā nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੇ) ਅਟੱਲ ਨਾਮ ਵਾਲੇ ਪੂਰਨ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который помнил совершенного Господа, чьё Имя непреложно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13431,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪੂਰਾ ਪਾਇਆ ਪੂਰੇ ਕੇ ਗੁਨ ਗਾਉ ॥੧॥",
          "roman": "Nānak pūrā pāiā pūre ke gun gāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਪੂਰਨ ਪ੍ਰਭੂ ਮਿਲ ਪਿਆ ਹੈ; (ਤਾਂ ਤੇ) ਹੇ ਨਾਨਕ! ਤੂੰ ਭੀ ਪੂਰਨ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "обретает этого совершенного Господа; потому, о Нанак, и ты пой качества совершенного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1079,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13432,
          "is_rahao": false,
          "gurmukhi": "ਅਸਟਪਦੀ ॥",
          "roman": "asṭpadī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13433,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕਾ ਸੁਨਿ ਉਪਦੇਸੁ ॥",
          "roman": "pūre gur kā sun updes",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਪੂਰੇ ਸਤਿਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О ум, слушай наставление совершенного Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13434,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਨਿਕਟਿ ਕਰਿ ਪੇਖੁ ॥",
          "roman": "pārbrahm nikaṭ kar pekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਅਕਾਲ ਪੁਰਖ ਨੂੰ (ਹਰ ਥਾਂ) ਨੇੜੇ ਜਾਣ ਕੇ ਵੇਖ।"
            },
            "sahib_singh_ru": {
              "main": "и смотри, сознавая Акал Пуракха близким повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13435,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਸਿਮਰਹੁ ਗੋਬਿੰਦ ॥",
          "roman": "sās sās simarah Gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਦੰਮ-ਬ-ਦੰਮ ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, вспоминай Господа с каждым дыханием,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13436,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਅੰਤਰ ਕੀ ਉਤਰੈ ਚਿੰਦ ॥",
          "roman": "man antar kī utrē chind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਜੁ) ਤੇਰੇ ਮਨ ਦੇ ਅੰਦਰ ਦੀ ਚਿੰਤਾ ਮਿਟ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "тогда внутренняя тревога твоего ума исчезнет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13437,
          "is_rahao": false,
          "gurmukhi": "ਆਸ ਅਨਿਤ ਤਿਆਗਹੁ ਤਰੰਗ ॥",
          "roman": "ās anit tiāgah taraṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ!) ਨਿੱਤ ਨਾਹ ਰਹਿਣ ਵਾਲੀਆਂ (ਚੀਜ਼ਾਂ ਦੀਆਂ) ਆਸਾਂ ਦੀਆਂ ਲਹਰਾਂ ਛੱਡ ਦੇਹ,"
            },
            "sahib_singh_ru": {
              "main": "О ум, оставь волны надежд на то, что не пребывает вечно,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13438,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਕੀ ਧੂਰਿ ਮਨ ਮੰਗ ॥",
          "roman": "sant janā kī dhūr man maṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਹੇ ਮਨ! ਸੰਤ ਜਨਾਂ ਦੇ ਪੈਰਾਂ ਦੀ ਖ਼ਾਕ ਮੰਗ।"
            },
            "sahib_singh_ru": {
              "main": "и, о ум, проси пыль со стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13439,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਛੋਡਿ ਬੇਨਤੀ ਕਰਹੁ ॥",
          "roman": "āp chhoḍ benatī karah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਆਪਾ-ਭਾਵ ਛੱਡ ਕੇ (ਪ੍ਰਭੂ ਦੇ ਅੱਗੇ) ਅਰਦਾਸ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, оставив самомнение, возноси молитву перед Господом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13440,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਅਗਨਿ ਸਾਗਰੁ ਤਰਹੁ ॥",
          "roman": "sādhasaṅg agan sāgar tarah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਇਸ ਤਰ੍ਹਾਂ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਰਹਿ ਕੇ) (ਵਿਕਾਰਾਂ ਦੀ) ਅੱਗ ਦੇ ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ।"
            },
            "sahib_singh_ru": {
              "main": "и так, пребывая в садх сангате, переправься через океан огня пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13441,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਧਨ ਕੇ ਭਰਿ ਲੇਹੁ ਭੰਡਾਰ ॥",
          "roman": "har dhan ke bhar leh bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ-ਨਾਮ-ਰੂਪੀ ਧਨ ਦੇ ਖ਼ਜ਼ਾਨੇ ਭਰ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "Наполни свои сокровищницы богатством Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13442,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਪੂਰੇ ਨਮਸਕਾਰ ॥੧॥",
          "roman": "Nānak gur pūre namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਤੇ ਪੂਰੇ ਸਤਿਗੁਰੂ ਨੂੰ ਨਮਸਕਾਰ ਕਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, поклонись совершенному Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1080,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13443,
          "is_rahao": false,
          "gurmukhi": "ਖੇਮ ਕੁਸਲ ਸਹਜ ਆਨੰਦ ॥",
          "roman": "khem kusal sahaj ānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤੈਨੂੰ ਅਟੱਲ ਸੁਖ, ਸੌਖਾ ਜੀਵਨ ਤੇ ਆਤਮਕ ਅਡੋਲਤਾ ਦਾ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੋਣਗੇ;"
            },
            "sahib_singh_ru": {
              "main": "О брат, ты обретёшь непреходящее счастье, спокойную жизнь и радость духовной устойчивости;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13444,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭਜੁ ਪਰਮਾਨੰਦ ॥",
          "roman": "sādhasaṅg bhaj parmānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਪਰਮ-ਸੁਖ ਪ੍ਰਭੂ ਨੂੰ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "в садх сангате помни Господа — высшее блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13445,
          "is_rahao": false,
          "gurmukhi": "ਨਰਕ ਨਿਵਾਰਿ ਉਧਾਰਹੁ ਜੀਉ ॥",
          "roman": "narak nivār udhārah jīo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਰਕਾਂ ਨੂੰ ਦੂਰ ਕਰ ਕੇ ਜਿੰਦ ਬਚਾ ਲੈ-"
            },
            "sahib_singh_ru": {
              "main": "Отврати адские состояния и спаси душу —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13446,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗੋਬਿੰਦ ਅੰਮ੍ਰਿਤ ਰਸੁ ਪੀਉ ॥",
          "roman": "gun Gobind amrit ras pīo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੋਬਿੰਦ ਦੇ ਗੁਣ ਗਾ (ਨਾਮ-) ਅੰਮ੍ਰਿਤ ਦਾ ਰਸ ਪੀ।"
            },
            "sahib_singh_ru": {
              "main": "пой качества Гобинда и пей нектарный вкус Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13447,
          "is_rahao": false,
          "gurmukhi": "ਚਿਤਿ ਚਿਤਵਹੁ ਨਾਰਾਇਣ ਏਕ ॥",
          "roman": "chit chitvah Nārāiṇ ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਇੱਕ ਪੁਭੂ ਦਾ ਧਿਆਨ ਚਿੱਤ ਵਿਚ ਧਰਹੁ,"
            },
            "sahib_singh_ru": {
              "main": "Держите в сердце созерцание Единого Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13448,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਰੂਪ ਜਾ ਕੇ ਰੰਗ ਅਨੇਕ ॥",
          "roman": "ek rūp jā ke raṅg anek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਇੱਕ ਅਕਾਲ ਪੁਰਖ ਦੇ ਅਨੇਕਾਂ ਰੰਗ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "того Единого Акал Пуракха, у которого бесчисленные проявления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13449,
          "is_rahao": false,
          "gurmukhi": "ਗੋਪਾਲ ਦਾਮੋਦਰ ਦੀਨ ਦਇਆਲ ॥",
          "roman": "Gopāl Dāmodar dīn daiāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਗੋਪਾਲ ਦਮੋਦਰ-"
            },
            "sahib_singh_ru": {
              "main": "Гопал Дамодар, милосердный к бедным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13450,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਭੰਜਨ ਪੂਰਨ ਕਿਰਪਾਲ ॥",
          "roman": "dukh bhañjan pūran kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਸਭ ਵਿਚ ਵਿਆਪਕ ਤੇ ਮੇਹਰ ਦਾ ਜੋ ਘਰ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "разрушитель страданий, всепронизывающий и сам дом милости;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13451,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਨਾਮੁ ਬਾਰੰ ਬਾਰ ॥",
          "roman": "simar simar nām bāraṅ bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਨਾਮ ਮੁੜ ਮੁੜ ਯਾਦ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "снова и снова вспоминай Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13452,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੀਅ ਕਾ ਇਹੈ ਅਧਾਰ ॥੨॥",
          "roman": "Nānak jīa kā ihē adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿੰਦ ਦਾ ਆਸਰਾ ਇਹ ਨਾਮ ਹੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, именно это Имя — опора души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1081,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13453,
          "is_rahao": false,
          "gurmukhi": "ਉਤਮ ਸਲੋਕ ਸਾਧ ਕੇ ਬਚਨ ॥",
          "roman": "utam salok sādh ke bachan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ (ਗੁਰੂ) ਦੇ ਬਚਨ ਸਭ ਤੋਂ ਚੰਗੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Слова садха, Гуру, — это высшая речь хвалы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13454,
          "is_rahao": false,
          "gurmukhi": "ਅਮੁਲੀਕ ਲਾਲ ਏਹਿ ਰਤਨ ॥",
          "roman": "amulīk lāl eh ratan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਅਮੋਲਕ ਲਾਲ ਹਨ, ਅਮੋਲਕ ਰਤਨ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "это бесценные рубины, бесценные драгоценности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13455,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਤ ਕਮਾਵਤ ਹੋਤ ਉਧਾਰ ॥",
          "roman": "sunat kamāvat hot udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਬਚਨਾਂ ਨੂੰ) ਸੁਣਿਆਂ ਤੇ ਕਮਾਇਆਂ ਬੇੜਾ ਪਾਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если их слушать и воплощать, переправа совершается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13456,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਤਰੈ ਲੋਕਹ ਨਿਸਤਾਰ ॥",
          "roman": "āp tarē lokah nistār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਕਮਾਉਂਦਾ ਹੈ) ਉਹ ਆਪ ਤਰਦਾ ਹੈ ਤੇ ਲੋਕਾਂ ਦਾ ਭੀ ਨਿਸਤਾਰਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "такой человек сам переправляется и помогает переправиться другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13457,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਜੀਵਨੁ ਸਫਲੁ ਤਾ ਕਾ ਸੰਗੁ ॥",
          "roman": "safal jīvan safal tā kā saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਪੂਰੀਆਂ ਮੁਰਾਦਾਂ ਵਾਲੀ ਹੁੰਦੀ ਹੈ, ਉਸ ਦੀ ਸੰਗਤਿ ਹੋਰਨਾਂ ਦੀਆਂ ਮੁਰਾਦਾਂ ਪੂਰੀਆਂ ਕਰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Жизнь такого человека становится исполненной, и его общество исполняет стремления других;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13458,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਲਾਗਾ ਹਰਿ ਰੰਗੁ ॥",
          "roman": "jā kē man lāgā har raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਪਿਆਰ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если в его уме утвердилась любовь к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13459,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਸਬਦੁ ਅਨਾਹਦੁ ਵਾਜੈ ॥",
          "roman": "jē jē sabad anāhad vājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰ) ਚੜ੍ਹਦੀਆਂ ਕਲਾਂ ਦੀ ਰੌ ਸਦਾ ਚਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри него постоянно звучит поток восходящей силы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13460,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਸੁਨਿ ਅਨਦ ਕਰੇ ਪ੍ਰਭੁ ਗਾਜੈ ॥",
          "roman": "sun sun anad kre prabh gājē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਸੁਣ ਕੇ (ਭਾਵ ਮਹਿਸੂਸ ਕਰ ਕੇ) ਉਹ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ (ਕਿਉਂਕਿ) ਪ੍ਰਭੂ (ਉਸ ਦੇ ਅੰਦਰ) ਆਪਣਾ ਨੂਰ ਰੋਸ਼ਨ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, слыша его, он радуется, потому что Господь внутри него озаряет Своим светом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13461,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਗਟੇ ਗੁਪਾਲ ਮਹਾਂਤ ਕੈ ਮਾਥੇ ॥",
          "roman": "pragaṭe Gupāl mahāṅt kē māthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੋਪਾਲ ਪ੍ਰਭੂ ਜੀ ਉਚੀ ਕਰਨੀ ਵਾਲੇ ਬੰਦੇ ਦੇ ਮੱਥੇ ਉਤੇ ਪਰਗਟ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Гопал Господь проявляется на челе человека высокой жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13462,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰੇ ਤਿਨ ਕੈ ਸਾਥੇ ॥੩॥",
          "roman": "Nānak udhre tin kē sāthe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਜੇਹੇ ਬੰਦੇ ਦੇ ਨਾਲ ਹੋਰ ਕਈ ਮਨੁੱਖਾਂ ਦਾ ਬੇੜਾ ਪਾਰ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, рядом с таким человеком переправляются и многие другие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1082,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13463,
          "is_rahao": false,
          "gurmukhi": "ਸਰਨਿ ਜੋਗੁ ਸੁਨਿ ਸਰਨੀ ਆਏ ॥",
          "roman": "saraṇ jog sun sarnī āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਹ ਸੁਣ ਕੇ ਕਿ ਤੂੰ ਦਰ-ਢੱਠਿਆਂ ਦੀ ਬਾਂਹ ਫੜਨ-ਜੋਗਾ ਹੈਂ, ਅਸੀਂ ਤੇਰੇ ਦਰ ਤੇ ਆਏ ਸਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, услышав, что Ты принимаешь прибегающих, мы пришли к Твоей защите,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13464,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭ ਆਪ ਮਿਲਾਏ ॥",
          "roman": "kar kirpā prabh āp milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੇਹਰ ਕਰ ਕੇ (ਸਾਨੂੰ) ਆਪਣੇ ਨਾਲ ਮੇਲ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и Ты по милости соединил нас с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13465,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਿ ਗਏ ਬੈਰ ਭਏ ਸਭ ਰੇਨ ॥",
          "roman": "miṭ gae bēr bhae sabh ren",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਸਾਡੇ) ਵੈਰ ਮਿਟ ਗਏ ਹਨ, ਅਸੀਂ ਸਭ ਦੇ ਪੈਰਾਂ ਦੀ ਖ਼ਾਕ ਹੋ ਗਏ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь наша вражда исчезла, и мы стали пылью у ног всех,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13466,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਸਾਧਸੰਗਿ ਲੈਨ ॥",
          "roman": "amrit nām sādhasaṅg lēn",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਅਮਰ ਕਰਨ ਵਾਲਾ ਨਾਮ ਜਪ ਰਹੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и теперь в садх сангате повторяем дарующее бессмертие Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13467,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪ੍ਰਸੰਨ ਭਏ ਗੁਰਦੇਵ ॥",
          "roman": "suprasann bhae Gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਦੇਵ ਜੀ (ਸਾਡੇ ਉਤੇ) ਤ੍ਰੁੱਠ ਪਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Гурудэв стал доволен нами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13468,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਈ ਸੇਵਕ ਕੀ ਸੇਵ ॥",
          "roman": "pūran hoī sevak kī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਵਾਸਤੇ (ਸਾਡੀ) ਸੇਵਕਾਂ ਦੀ ਸੇਵਾ ਸਿਰੇ ਚੜ੍ਹ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "поэтому служение нас, слуг, завершилось успешно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13469,
          "is_rahao": false,
          "gurmukhi": "ਆਲ ਜੰਜਾਲ ਬਿਕਾਰ ਤੇ ਰਹਤੇ ॥",
          "roman": "āl jañjāl bikār te rahte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸੀਂ ਹੁਣ) ਘਰ ਦੇ ਧੰਧਿਆਂ ਤੇ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚ ਗਏ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь мы избавились от домашних пут и пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13470,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਸੁਨਿ ਰਸਨਾ ਕਹਤੇ ॥",
          "roman": "Rām nām sun rasnā kahte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸੁਣ ਕੇ ਜੀਭ ਨਾਲ (ਭੀ) ਉਚਾਰਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и, услышав Имя Господа, произносим его и языком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13471,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਪ੍ਰਸਾਦੁ ਦਇਆ ਪ੍ਰਭਿ ਧਾਰੀ ॥",
          "roman": "kar prasād daiā prabh dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਨੇ ਮੇਹਰ ਕਰ ਕੇ (ਸਾਡੇ ਉਤੇ) ਦਇਆ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь по милости явил к нам сострадание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13472,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਿਬਹੀ ਖੇਪ ਹਮਾਰੀ ॥੪॥",
          "roman": "Nānak nibahī khep hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਤੇ ਸਾਡਾ ਕੀਤਾ ਹੋਇਆ ਵਣਜ ਦਰਗਾਹੇ ਕਬੂਲ ਹੋ ਗਿਆ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, наш торговый товар был принят в Божьем дворе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1083,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13473,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਉਸਤਤਿ ਕਰਹੁ ਸੰਤ ਮੀਤ ॥",
          "roman": "prabh kī ustat karah sant mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਮਿਤ੍ਰ! ਅਕਾਲ ਪੁਰਖ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰੋ-"
            },
            "sahib_singh_ru": {
              "main": "О святой друг, восхваляй Акал Пуракха —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13474,
          "is_rahao": false,
          "gurmukhi": "ਸਾਵਧਾਨ ਏਕਾਗਰ ਚੀਤ ॥",
          "roman": "sāvdhān ekāgar chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਿਆਨ ਨਾਲ ਚਿੱਤ ਨੂੰ ਇਕ ਨਿਸ਼ਾਨੇ ਤੇ ਟਿਕਾ ਕੇ।"
            },
            "sahib_singh_ru": {
              "main": "внимательно, удерживая ум на одной цели."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13475,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖਮਨੀ ਸਹਜ ਗੋਬਿੰਦ ਗੁਨ ਨਾਮ ॥",
          "roman": "sukhmanī sahaj Gobind gun nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਤੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਅਡੋਲ ਅਵਸਥਾ (ਦਾ ਕਾਰਣ ਹੈ ਤੇ) ਸੁਖਾਂ ਦੀ ਮਣੀ (ਰਤਨ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Хвала Господу и Его Имя — причина устойчивого состояния и драгоценность счастья,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13476,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਬਸੈ ਸੁ ਹੋਤ ਨਿਧਾਨ ॥",
          "roman": "jis man basē so hot nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ (ਨਾਮ) ਵੱਸਦਾ ਹੈ ਉਹ (ਗੁਣਾਂ ਦਾ) ਖ਼ਜ਼ਾਨਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, в чьём уме живёт Имя, становится сокровищницей достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13477,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਇਛਾ ਤਾ ਕੀ ਪੂਰਨ ਹੋਇ ॥",
          "roman": "sarab ichhā tā kī pūran hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਇੱਛਿਆ ਸਾਰੀ ਪੂਰੀ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Все желания такого человека исполняются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13478,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਧਾਨ ਪੁਰਖੁ ਪ੍ਰਗਟੁ ਸਭ ਲੋਇ ॥",
          "roman": "pradhān purakh pragaṭ sabh loi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੰਦਾ ਤੁਰਨੇ-ਸਿਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਤੇ ਸਾਰੇ ਜਗਤ ਵਿਚ ਉੱਘਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "он становится выдающимся человеком и прославляется во всём мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13479,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚ ਪਾਏ ਅਸਥਾਨੁ ॥",
          "roman": "sabh te ūch pāe asthān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉੱਚੇ ਤੋਂ ਉੱਚਾ ਟਿਕਾਣਾ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ему достаётся высочайшее место,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13480,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਨ ਹੋਵੈ ਆਵਨ ਜਾਨੁ ॥",
          "roman": "bahur na hovē āvan jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁੜ ਉਸ ਨੂੰ ਜਨਮ ਮਰਨ (ਦਾ ਗੇੜ) ਨਹੀਂ ਵਿਆਪਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и больше его не затрагивает круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13481,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਧਨੁ ਖਾਟਿ ਚਲੈ ਜਨੁ ਸੋਇ ॥",
          "roman": "har dhan khāṭ chalē jan soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਰੂਪ ਧਨ ਖੱਟ ਕੇ (ਜਗਤ ਤੋਂ) ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот человек уходит из мира, заработав богатство Имени Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13482,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸਹਿ ਪਰਾਪਤਿ ਹੋਇ ॥੫॥",
          "roman": "Nānak jiseh parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਧੁਰੋਂ) ਇਹ  ਦਾਤ ਮਿਲਦੀ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, если ему даруется этот дар свыше."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1084,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 13483,
          "is_rahao": false,
          "gurmukhi": "ਖੇਮ ਸਾਂਤਿ ਰਿਧਿ ਨਵ ਨਿਧਿ ॥",
          "roman": "khem sāṅt ridh nav nidh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਟੱਲ ਸੁਖ ਮਨ ਦਾ ਟਿਕਾਉ, ਰਿਧੀਆਂ, ਨੌ ਖ਼ਜ਼ਾਨੇ,"
            },
            "sahib_singh_ru": {
              "main": "Непреходящее счастье, покой ума, риддхи, девять сокровищ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13484,
          "is_rahao": false,
          "gurmukhi": "ਬੁਧਿ ਗਿਆਨੁ ਸਰਬ ਤਹ ਸਿਧਿ ॥",
          "roman": "budh giān sarab tah sidh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਲ, ਗਿਆਨ ਤੇ ਸਾਰੀਆਂ ਕਰਾਮਾਤਾਂ ਉਸ ਮਨੁੱਖ ਵਿਚ (ਆ ਜਾਂਦੀਆਂ ਹਨ);"
            },
            "sahib_singh_ru": {
              "main": "разум, знание и все духовные силы приходят в такого человека;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 13485,
          "is_rahao": false,
          "gurmukhi": "ਬਿਦਿਆ ਤਪੁ ਜੋਗੁ ਪ੍ਰਭ ਧਿਆਨੁ ॥",
          "roman": "bidiā tap jog prabh dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿੱਦਿਆ, ਤਪ, ਜੋਗ, ਅਕਾਲ ਪੁਰਖ ਦਾ ਧਿਆਨ,"
            },
            "sahib_singh_ru": {
              "main": "знание, тапас, йога, созерцание Акал Пуракха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
