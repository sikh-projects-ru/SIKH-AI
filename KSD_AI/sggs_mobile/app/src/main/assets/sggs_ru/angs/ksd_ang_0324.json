{
  "ang": 324,
  "shabads": [
    {
      "shabad_id": 1286,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14686,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਸਤਿਗੁਰੁ ਹਉ ਨਉਤਨੁ ਚੇਲਾ ॥",
          "roman": "tū satgur hau nautan chelā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ (ਮੇਰਾ) ਗੁਰੂ ਹੈਂ, ਮੈਂ ਤੇਰਾ ਨਵਾਂ ਸਿੱਖ ਹਾਂ (ਭਾਵ, ਤੇਰੇ ਨਾਲ ਉਸੇ ਤਰ੍ਹਾਂ ਪਿਆਰ ਹੈ ਜਿਵੇਂ ਨਵਾਂ ਨਵਾਂ ਸਿੱਖ ਆਪਣੇ ਗੁਰੂ ਨਾਲ ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Ты мой Гуру, а я твой новый ученик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14687,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਮਿਲੁ ਅੰਤ ਕੀ ਬੇਲਾ ॥੪॥੨॥",
          "roman": "kahi kabīr mil ant kī belā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ-ਹੁਣ ਤਾਂ (ਮਨੁੱਖਾ-ਜਨਮ) ਅਖ਼ੀਰ ਦਾ ਵੇਲਾ ਹੈ, ਮੈਨੂੰ ਜ਼ਰੂਰ ਮਿਲ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: сейчас последний момент, встреть меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1287,
      "rahao_verse_id": 14692,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14688,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14689,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਹਮ ਏਕੋ ਏਕੁ ਕਰਿ ਜਾਨਿਆ ॥",
          "roman": "jab ham eko ek kar jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਅਸਾਂ (ਭਾਵ, ਮੈਂ) ਇਹ ਸਮਝ ਲਿਆ ਹੈ ਕਿ ਸਭ ਥਾਈਂ ਇਕ ਪਰਮਾਤਮਾ ਹੀ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда я понял, что везде один только Параматма присутствует,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14690,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲੋਗਹ ਕਾਹੇ ਦੁਖੁ ਮਾਨਿਆ ॥੧॥",
          "roman": "tab logah kāhe dukh māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਪਤਾ ਨਹੀਂ) ਲੋਕਾਂ ਨੇ ਇਸ ਗੱਲ ਨੂੰ ਕਿਉਂ ਬੁਰਾ ਮਨਾਇਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда непонятно, почему люди приняли это как что-то плохое ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14691,
          "is_rahao": true,
          "gurmukhi": "ਹਮ ਅਪਤਹ ਅਪੁਨੀ ਪਤਿ ਖੋਈ ॥",
          "roman": "ham aptah apunī pat khoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਨਿਸੰਗ ਹੋ ਗਿਆ ਹਾਂ ਤੇ ਮੈਨੂੰ ਇਹ ਪਰਵਾਹ ਨਹੀਂ ਕਿ ਕੋਈ ਮਨੁੱਖ ਮੇਰੀ ਇੱਜ਼ਤ ਕਰੇ ਜਾਂ ਨਾਹ ਕਰੇ।"
            },
            "sahib_singh_ru": {
              "main": "Я стал отрешённым, и мне безразлично, уважает меня кто-то или нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14692,
          "is_rahao": true,
          "gurmukhi": "ਹਮਰੈ ਖੋਜਿ ਪਰਹੁ ਮਤਿ ਕੋਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "hamrē khoj parah mat koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੁਹਾਨੂੰ ਲੋਕਾਂ ਨੂੰ ਜਗਤ ਵਿਚ ਮਨ-ਵਡਿਆਈ ਦਾ ਖ਼ਿਆਲ ਹੈ, ਇਸ ਵਾਸਤੇ ਜਿਸ ਰਾਹੇ ਮੈਂ ਪਿਆ ਹਾਂ) ਉਸ ਰਾਹੇ ਮੇਰੇ ਪਿੱਛੇ ਨਾਹ ਤੁਰੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Вы, люди, озабочены мирской честью, поэтому не следуйте за мной по тому пути, по которому я иду ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14693,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਮੰਦੇ ਮੰਦੇ ਮਨ ਮਾਹੀ ॥",
          "roman": "ham mande mande man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮੈਂ ਭੈੜਾ ਹਾਂ ਤਾਂ ਆਪਣੇ ਹੀ ਅੰਦਰ ਭੈੜਾ ਹਾਂ ਨ, (ਕਿਸੇ ਨੂੰ ਇਸ ਗੱਲ ਨਾਲ ਕੀਹ?)"
            },
            "sahib_singh_ru": {
              "main": "Если я плох, то плох лишь внутри себя — какое кому до этого дело?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14694,
          "is_rahao": false,
          "gurmukhi": "ਸਾਝ ਪਾਤਿ ਕਾਹੂ ਸਿਉ ਨਾਹੀ ॥੨॥",
          "roman": "sāñjh pāt kāhū siu nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਕਿਸੇ ਨਾਲ (ਇਸੇ ਕਰਕੇ) ਕੋਈ ਮੇਲ-ਮੁਲਾਕਾਤ ਭੀ ਨਹੀਂ ਰੱਖੀ ਹੋਈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому я ни с кем не поддерживаю связей ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14695,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿ ਅਪਤਿ ਤਾ ਕੀ ਨਹੀ ਲਾਜ ॥",
          "roman": "pat apat tā kī nahī lāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮੇਰੀ ਇੱਜ਼ਤ ਕਰੇ ਜਾਂ ਨਿਰਾਦਰੀ ਕਰੇ, ਮੈਂ ਇਸ ਵਿਚ ਕੋਈ ਹਾਣਤ ਨਹੀਂ ਸਮਝਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "Почитают меня или унижают — я не считаю это потерей;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14696,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਜਾਨਹੁਗੇ ਜਬ ਉਘਰੈਗੋ ਪਾਜ ॥੩॥",
          "roman": "tab jānahuge jab ughrēgo pāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਤੁਹਾਨੂੰ ਭੀ ਤਦੋਂ ਹੀ ਸਮਝ ਆਵੇਗੀ (ਕਿ ਅਸਲ ਇੱਜ਼ਤ ਜਾਂ ਨਿਰਾਦਰੀ ਕਿਹੜੀ ਹੈ) ਜਦੋਂ ਤੁਹਾਡਾ ਇਹ ਜਗਤ-ਵਿਖਾਵਾ ਉੱਘੜ ਜਾਇਗਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "вы сами поймёте это лишь тогда, когда раскроется ваша мирская показуха ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14697,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਪਤਿ ਹਰਿ ਪਰਵਾਨੁ ॥",
          "roman": "kah kabīr pat har parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- (ਅਸਲ) ਇੱਜ਼ਤ ਉਸੇ ਦੀ ਹੀ ਹੈ, ਜਿਸ ਨੂੰ ਪ੍ਰਭੂ ਕਬੂਲ ਕਰ ਲਏ।"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит — истинная честь только у того,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14698,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਤਿਆਗਿ ਭਜੁ ਕੇਵਲ ਰਾਮੁ ॥੪॥੩॥",
          "roman": "sarab tiāg bhaj keval rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ, ਹੇ ਕਬੀਰ!) ਹੋਰ ਸਭ ਕੁਝ (ਭਾਵ, ਦੁਨੀਆ ਦੀ ਲੋਕ-ਲਾਜ) ਛੱਡ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "кого принимает Господь; поэтому оставь всё и помни только Рама ॥੪॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1288,
      "rahao_verse_id": 14703,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14699,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14700,
          "is_rahao": false,
          "gurmukhi": "ਨਗਨ ਫਿਰਤ ਜੌ ਪਾਈਐ ਜੋਗੁ ॥",
          "roman": "nagan phirat jau pāīai jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਨੰਗੇ ਫਿਰਦਿਆਂ ਪਰਮਾਤਮਾ ਨਾਲ ਮਿਲਾਪ ਹੋ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы, ходя нагим, можно было достичь единения с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14701,
          "is_rahao": false,
          "gurmukhi": "ਬਨ ਕਾ ਮਿਰਗੁ ਮੁਕਤਿ ਸਭੁ ਹੋਗੁ ॥੧॥",
          "roman": "ban kā mirag mukat sabh hog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਜੰਗਲ ਦਾ ਹਰੇਕ ਪਸ਼ੂ ਮੁਕਤ ਹੋ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "то все звери в лесу уже были бы освобождены ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14702,
          "is_rahao": true,
          "gurmukhi": "ਕਿਆ ਨਾਗੇ ਕਿਆ ਬਾਧੇ ਚਾਮ ॥",
          "roman": "kiā nāge kiā bādhe chām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਤਦ ਤਕ ਨੰਗੇ ਰਿਹਾਂ ਕੀਹ ਸੌਰ ਜਾਣਾ ਹੈ ਤੇ ਪਿੰਡੇ ਤੇ ਚੰਮ ਲਪੇਟਿਆਂ ਕੀਹ ਮਿਲ ਜਾਣਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Что даёт нагота или ношение кожи?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14703,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਨਹੀ ਚੀਨਸਿ ਆਤਮ ਰਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jab nahī chīnas ātm rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਤੂੰ ਪਰਮਾਤਮਾ ਨੂੰ ਨਹੀਂ ਪਛਾਣਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "пока ты не познал внутреннего Рама ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14704,
          "is_rahao": false,
          "gurmukhi": "ਮੂਡ ਮੁੰਡਾਏ ਜੌ ਸਿਧਿ ਪਾਈ ॥",
          "roman": "mūḍ muṇḍāe jau sidh pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਸਿਰ ਮੁਨਾਇਆਂ ਸਿੱਧੀ ਮਿਲ ਸਕਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы от сбривания волос достигалась духовная сила,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14705,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤੀ ਭੇਡ ਨ ਗਈਆ ਕਾਈ ॥੨॥",
          "roman": "mukti bheḍ na gaīā kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਇਹ ਕੀਹ ਕਾਰਨ ਹੈ ਕਿ) ਕੋਈ ਭੀ ਭੇਡ (ਹੁਣ ਤਕ ਮੁਕਤ ਨਹੀਂ ਹੋਈ?) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "то почему ни одна овца не получила освобождения? ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14706,
          "is_rahao": false,
          "gurmukhi": "ਬਿੰਦੁ ਰਾਖਿ ਜੌ ਤਰੀਐ ਭਾਈ ॥",
          "roman": "bind rākh jau tarīai bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇ ਬਾਲ-ਜਤੀ ਰਿਹਾਂ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਤਰ ਸਕੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если, сохраняя семя, можно переплыть океан мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14707,
          "is_rahao": false,
          "gurmukhi": "ਖੁਸਰੈ ਕਿਉ ਨ ਪਰਮ ਗਤਿ ਪਾਈ ॥੩॥",
          "roman": "khusrē kiu na param gat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਖੁਸਰੇ ਨੂੰ ਕਿਉਂ ਮੁਕਤੀ ਨਹੀਂ ਮਿਲ ਜਾਂਦੀ? ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то почему евнух не достигает высшего состояния? ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14708,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਸੁਨਹੁ ਨਰ ਭਾਈ ॥",
          "roman": "kah kabīr sunah nar bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਹੇ ਭਰਾਵੋ! ਸੁਣੋ!"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит — слушайте, о братья!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14709,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਕਿਨਿ ਗਤਿ ਪਾਈ ॥੪॥੪॥",
          "roman": "rām nām bin kin gat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਨੂੰ ਮੁਕਤੀ ਨਹੀਂ ਮਿਲੀ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Рама никто не достиг освобождения ॥੪॥੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1289,
      "rahao_verse_id": 14714,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14710,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14711,
          "is_rahao": false,
          "gurmukhi": "ਸੰਧਿਆ ਪ੍ਰਾਤ ਇਸ੍ਨਾਨੁ ਕਰਾਹੀ ॥",
          "roman": "sandhiā prāt isnān karāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਮਨੁੱਖ) ਸਵੇਰੇ ਤੇ ਸ਼ਾਮ ਨੂੰ (ਭਾਵ, ਦੋਵੇਂ ਵੇਲੇ ਨਿਰਾ) ਇਸ਼ਨਾਨ ਹੀ ਕਰਦੇ ਹਨ"
            },
            "sahib_singh_ru": {
              "main": "Те, кто утром и вечером только совершают омовения,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14712,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਏ ਦਾਦੁਰ ਪਾਨੀ ਮਾਹੀ ॥੧॥",
          "roman": "jiu bhae dādur pānī māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਸਮਝਦੇ ਹਨ ਕਿ ਅਸੀਂ ਪਵਿੱਤਰ ਹੋ ਗਏ ਹਾਂ, ਉਹ ਇਉਂ ਹਨ) ਜਿਵੇਂ ਪਾਣੀ ਵਿਚ ਡੱਡੂ ਵੱਸ ਰਹੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "похожи на лягушек, живущих в воде ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14713,
          "is_rahao": true,
          "gurmukhi": "ਜਉ ਪੈ ਰਾਮ ਰਾਮ ਰਤਿ ਨਾਹੀ ॥",
          "roman": "jau pē rām rām rat nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਕਰ ਉਹਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਪਿਆਰ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если в их сердце нет любви к Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14714,
          "is_rahao": true,
          "gurmukhi": "ਤੇ ਸਭਿ ਧਰਮ ਰਾਇ ਕੈ ਜਾਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "te sabh dharam rāi kē jāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਹ ਸਾਰੇ ਧਰਮਰਾਜ ਦੇ ਵੱਸ ਪੈਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "то все они подпадают под власть Дхармараджа ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14715,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਰਤਿ ਬਹੁ ਰੂਪ ਰਚਾਹੀ ॥",
          "roman": "kāiā rat bah rūp rachāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਈ ਮਨੁੱਖ) ਸਰੀਰ ਦੇ ਮੋਹ ਵਿਚ ਹੀ (ਭਾਵ, ਸਰੀਰ ਨੂੰ ਪਾਲਣ ਦੀ ਖ਼ਾਤਰ ਹੀ) ਕਈ ਭੇਖ ਬਣਾਉਂਦੇ ਹਨ;"
            },
            "sahib_singh_ru": {
              "main": "Многие, привязанные к телу, принимают разные обличья,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14716,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਕਉ ਦਇਆ ਸੁਪਨੈ ਭੀ ਨਾਹੀ ॥੨॥",
          "roman": "tin kau dēyā supnē bhī nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਕਦੇ ਸੁਪਨੇ ਵਿਚ ਭੀ ਦਇਆ ਨਹੀਂ ਆਈ (ਉਹਨਾਂ ਦਾ ਹਿਰਦਾ ਕਦੇ ਭੀ ਨਹੀਂ ਦ੍ਰਵਿਆ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но у них нет сострадания даже во сне ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14717,
          "is_rahao": false,
          "gurmukhi": "ਚਾਰਿ ਚਰਨ ਕਹਹਿ ਬਹੁ ਆਗਰ ॥",
          "roman": "chār charan kahah bah āgar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤੇ ਸਿਆਣੇ ਮਨੁੱਖ ਚਾਰ ਵੇਦ (ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕਾਂ ਨੂੰ) ਹੀ (ਨਿਰੇ) ਪੜ੍ਹਦੇ ਹਨ (ਪਰ ਨਿਰਾ ਪੜ੍ਹਨ ਨਾਲ ਕੀਹ ਬਣੇ?)।"
            },
            "sahib_singh_ru": {
              "main": "Многие учёные читают четыре Веды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14718,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੁਖੁ ਪਾਵਹਿ ਕਲਿ ਸਾਗਰ ॥੩॥",
          "roman": "sādhū sukh pāveh kal sāgar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ (ਸਿਰਫ਼) ਸੰਤ ਜਨ ਹੀ (ਅਸਲ) ਸੁਖ ਮਾਣਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "но только святые находят истинное счастье в этом океане мира ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14719,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਬਹੁ ਕਾਇ ਕਰੀਜੈ ॥",
          "roman": "kah kabīr bah kāi karījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਸਾਰੀਆਂ ਵਿਚਾਰਾਂ ਦਾ ਨਿਚੋੜ ਇਹ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит — суть всех размышлений такова:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14720,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬਸੁ ਛੋਡਿ ਮਹਾ ਰਸੁ ਪੀਜੈ ॥੪॥੫॥",
          "roman": "sarbas chhoḍ mahā ras pījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਸਭ ਪਦਾਰਥਾਂ ਦਾ ਮੋਹ ਛੱਡ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਰਸ ਪੀਣਾ ਚਾਹੀਦਾ ਹੈ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "оставь всё и вкуси высший нектар Имени ॥੪॥੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1290,
      "rahao_verse_id": 14725,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14721,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਜੀ ਗਉੜੀ ॥",
          "roman": "kabīr jī gauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14722,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਜਪੁ ਕਿਆ ਤਪੁ ਕਿਆ ਬ੍ਰਤ ਪੂਜਾ ॥",
          "roman": "kiā jap kiā tap kiā brat pūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਜਪ ਕਰਨਾ ਕਿਸ ਭਾ? ਉਸ ਦਾ ਤਪ ਕਿਸ ਅਰਥ? ਉਸ ਦੇ ਵਰਤ ਤੇ ਪੂਜਾ ਕਿਹੜੇ ਗੁਣ?"
            },
            "sahib_singh_ru": {
              "main": "Какой смысл в повторении, аскезе, обетах и поклонении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14723,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਰਿਦੈ ਭਾਉ ਹੈ ਦੂਜਾ ॥੧॥",
          "roman": "jā kē ridē bhāu hē dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਹੋਰ ਦਾ ਪਿਆਰ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если в сердце есть любовь к другому, не к Богу? ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14724,
          "is_rahao": true,
          "gurmukhi": "ਰੇ ਜਨ ਮਨੁ ਮਾਧਉ ਸਿਉ ਲਾਈਐ ॥",
          "roman": "re jan man mādhau siu lāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਨ ਨੂੰ ਪਰਮਾਤਮਾ ਨਾਲ ਜੋੜਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О человек, направь свой ум к Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14725,
          "is_rahao": true,
          "gurmukhi": "ਚਤੁਰਾਈ ਨ ਚਤੁਰਭੁਜੁ ਪਾਈਐ ॥ ਰਹਾਉ ॥",
          "roman": "chaturāī na chaturbhuj pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਛੱਡ ਕੇ ਹੋਰ) ਸਿਆਣਪਾਂ ਨਾਲ ਰੱਬ ਨਹੀਂ ਮਿਲ ਸਕਦਾ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "ибо хитростью Его не достичь ॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14726,
          "is_rahao": false,
          "gurmukhi": "ਪਰਹਰੁ ਲੋਭੁ ਅਰੁ ਲੋਕਾਚਾਰੁ ॥",
          "roman": "parhar lobh aru lokāchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਲਾਲਚ, ਵਿਖਾਵੇ ਦਾ ਤਿਆਗ ਕਰ ਦੇਹ।"
            },
            "sahib_singh_ru": {
              "main": "Оставь жадность и показную религиозность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14727,
          "is_rahao": false,
          "gurmukhi": "ਪਰਹਰੁ ਕਾਮੁ ਕ੍ਰੋਧੁ ਅਹੰਕਾਰੁ ॥੨॥",
          "roman": "parhar kām krodh ahaṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ, ਕ੍ਰੋਧ ਅਤੇ ਅਹੰਕਾਰ ਛੱਡ ਦੇਹ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "оставь похоть, гнев и эго ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14728,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਕਰਤ ਬਧੇ ਅਹੰਮੇਵ ॥",
          "roman": "karam karat badhe ahaṅmev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਧਾਰਮਿਕ ਰਸਮਾਂ ਕਰਦੇ ਕਰਦੇ ਹਉਮੈ ਵਿਚ ਬੱਝੇ ਪਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди, выполняя ритуалы, связаны эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14729,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਪਾਥਰ ਕੀ ਕਰਹੀ ਸੇਵ ॥੩॥",
          "roman": "mil pāthar kī karahī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਰਲ ਕੇ ਪੱਥਰਾਂ ਦੀ (ਹੀ) ਪੂਜਾ ਕਰ ਰਹੇ ਹਨ (ਪਰ ਇਹ ਸਭ ਕੁਝ ਵਿਅਰਥ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и вместе поклоняются камням ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14730,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਭਗਤਿ ਕਰਿ ਪਾਇਆ ॥",
          "roman": "kah kabīr bhagat kar pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਪਰਮਾਤਮਾ ਬੰਦਗੀ ਕਰਨ ਨਾਲ (ਹੀ) ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит — Бог достигается только через преданность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14731,
          "is_rahao": false,
          "gurmukhi": "ਭੋਲੇ ਭਾਇ ਮਿਲੇ ਰਘੁਰਾਇਆ ॥੪॥੬॥",
          "roman": "bhole bhāe mile raghurāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭੋਲੇ ਸੁਭਾਉ ਨਾਲ ਮਿਲਦਾ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и встречается в простоте сердца ॥੪॥੬॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1291,
      "rahao_verse_id": 14736,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14732,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14733,
          "is_rahao": false,
          "gurmukhi": "ਗਰਭ ਵਾਸ ਮਹਿ ਕੁਲੁ ਨਹੀ ਜਾਤੀ ॥",
          "roman": "garabh vās meh kul nahī jātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਂ ਦੇ ਪੇਟ ਵਿਚ ਤਾਂ ਕਿਸੇ ਨੂੰ ਇਹ ਸਮਝ ਨਹੀਂ ਹੁੰਦੀ ਕਿ ਮੈਂ ਕਿਸ ਕੁਲ ਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "В утробе матери никто не знает своей касты,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14734,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਬਿੰਦੁ ਤੇ ਸਭ ਉਤਪਾਤੀ ॥੧॥",
          "roman": "brahm bind te sabh utpātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵਾਂ ਦੀ ਉਤਪੱਤੀ ਪਰਮਾਤਮਾ ਦੀ ਅੰਸ਼ ਤੋਂ (ਹੋ ਰਹੀ) ਹੈ (ਭਾਵ, ਸਭ ਦਾ ਮੂਲ ਕਾਰਨ ਪਰਮਾਤਮਾ ਆਪ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "все происходят из божественной сущности ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14735,
          "is_rahao": true,
          "gurmukhi": "ਕਹੁ ਰੇ ਪੰਡਿਤ ਬਾਮਨ ਕਬ ਕੇ ਹੋਏ ॥",
          "roman": "kah re paṇḍit bāman kab ke hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸ, ਹੇ ਪੰਡਿਤ! ਤੁਸੀ ਬ੍ਰਾਹਮਣ ਕਦੋਂ ਦੇ ਬਣ ਗਏ ਹੋ?"
            },
            "sahib_singh_ru": {
              "main": "Скажи, о пандит, когда ты стал брахманом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14736,
          "is_rahao": true,
          "gurmukhi": "ਬਾਮਨ ਕਹਿ ਕਹਿ ਜਨਮੁ ਮਤ ਖੋਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bāman kahi kahi janam mat khoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਆਖ ਆਖ ਕੇ ਕਿ ਮੈਂ ਬ੍ਰਾਹਮਣ ਹਾਂ, ਮੈਂ ਬ੍ਰਾਹਮਣ ਹਾਂ, ਮਨੁੱਖਾ ਜਨਮ (ਅਹੰਕਾਰ ਵਿਚ ਅਜਾਈਂ) ਨਾਹ ਗਵਾਓ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Не теряй человеческую жизнь, повторяя, что ты брахман ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14737,
          "is_rahao": false,
          "gurmukhi": "ਜੌ ਤੂੰ ਬ੍ਰਾਹਮਣੁ ਬ੍ਰਹਮਣੀ ਜਾਇਆ ॥",
          "roman": "jau tū bāhmaṇ brahmaṇī jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ (ਹੇ ਪੰਡਿਤ!) ਤੂੰ (ਸੱਚ-ਮੁੱਚ) ਬ੍ਰਾਹਮਣ ਹੈਂ ਤੇ ਬ੍ਰਾਹਮਣੀ ਦੇ ਪੇਟੋਂ ਜੰਮਿਆ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если ты действительно брахман, рождённый от брахманки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14738,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਆਨ ਬਾਟ ਕਾਹੇ ਨਹੀ ਆਇਆ ॥੨॥",
          "roman": "tau ān bāṭ kāhe nahī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਕਿਸੇ ਹੋਰ ਰਾਹੇ ਕਿਉਂ ਨਹੀਂ ਜੰਮ ਪਿਆ? ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "почему ты не пришёл в мир другим путём? ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14739,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਕਤ ਬ੍ਰਾਹਮਣ ਹਮ ਕਤ ਸੂਦ ॥",
          "roman": "tum kat bāhmaṇ ham kat sūd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪੰਡਿਤ!) ਤੁਸੀ ਕਿਵੇਂ ਬ੍ਰਾਹਮਣ (ਬਣ ਗਏ)? ਅਸੀਂ ਕਿਵੇਂ ਸ਼ੂਦਰ (ਰਹਿ ਗਏ)?"
            },
            "sahib_singh_ru": {
              "main": "Как ты стал брахманом, а мы шудрами?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14740,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਕਤ ਲੋਹੂ ਤੁਮ ਕਤ ਦੂਧ ॥੩॥",
          "roman": "ham kat lohū tum kat dūdh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਾਡੇ ਸਰੀਰ ਵਿਚ ਕਿਵੇਂ (ਨਿਰਾ) ਲਹੂ ਹੀ ਹੈ? ਤੁਹਾਡੇ ਸਰੀਰ ਵਿਚ ਕਿਵੇਂ (ਲਹੂ ਦੀ ਥਾਂ) ਦੁੱਧ ਹੈ? ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Почему в нас кровь, а в вас будто молоко? ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14741,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜੋ ਬ੍ਰਹਮੁ ਬੀਚਾਰੈ ॥",
          "roman": "kah kabīr jo brahm bīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਜੋ ਪਰਮਾਤਮਾ (ਬ੍ਰਹਮ) ਨੂੰ ਸਿਮਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит — тот, кто размышляет о Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14742,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬ੍ਰਾਹਮਣੁ ਕਹੀਅਤੁ ਹੈ ਹਮਾਰੈ ॥੪॥੭॥",
          "roman": "so bāhmaṇ kahīat hamārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਤਾਂ ਉਸ ਮਨੁੱਖ ਨੂੰ ਬ੍ਰਾਹਮਣ ਸੱਦਦੇ ਹਾਂ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "того мы называем брахманом ॥੪॥੭॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
