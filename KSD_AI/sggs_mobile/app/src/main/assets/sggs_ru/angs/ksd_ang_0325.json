{
  "ang": 325,
  "shabads": [
    {
      "shabad_id": 1292,
      "rahao_verse_id": 14747,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14743,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14744,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਕਾਰ ਸੁਖਿ ਕਬਹਿ ਨ ਸੋਈ ਹੈ ॥",
          "roman": "andhkār sukh kabah na soī hē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾ ਕੇ ਅਗਿਆਨਤਾ ਦੇ) ਹਨੇਰੇ ਵਿਚ ਕਦੇ ਸੁਖੀ ਨਹੀਂ ਸੌਂ ਸਕੀਦਾ;"
            },
            "sahib_singh_ru": {
              "main": "В темноте неведения, забыв Бога, никогда нельзя спокойно спать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14745,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜਾ ਰੰਕੁ ਦੋਊ ਮਿਲਿ ਰੋਈ ਹੈ ॥੧॥",
          "roman": "rājā rank doū mil roī hē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜਾ ਹੋਵੇ ਚਾਹੇ ਕੰਗਾਲ, ਦੋਵੇਂ ਹੀ ਦੁਖੀ ਹੁੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "И царь, и нищий — оба страдают и плачут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14746,
          "is_rahao": true,
          "gurmukhi": "ਜਉ ਪੈ ਰਸਨਾ ਰਾਮੁ ਨ ਕਹਿਬੋ ॥",
          "roman": "jau pē rasnā rām na kahibo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਦ ਤਕ ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਨੂੰ ਨਹੀਂ ਜਪਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! пока языком не произносишь Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14747,
          "is_rahao": true,
          "gurmukhi": "ਉਪਜਤ ਬਿਨਸਤ ਰੋਵਤ ਰਹਿਬੋ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "upjat binasat rovat rahibo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ ਜੰਮਦੇ ਮਰਦੇ ਤੇ (ਇਸੇ ਦੁੱਖ ਵਿਚ) ਰੋਂਦੇ ਰਹੋਗੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "до тех пор будешь рождаться и умирать, и пребывать в этом страдании, плача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14748,
          "is_rahao": false,
          "gurmukhi": "ਜਸ ਦੇਖੀਐ ਤਰਵਰ ਕੀ ਛਾਇਆ ॥",
          "roman": "jas dekhīai tarvār kī chhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਰੁੱਖ ਦੀ ਛਾਂ ਵੇਖੀਦੀ ਹੈ (ਭਾਵ, ਜਿਵੇਂ ਰੁੱਖ ਦੀ ਛਾਂ ਸਦਾ ਟਿਕੀ ਨਹੀਂ ਰਹਿੰਦੀ, ਤਿਵੇਂ ਇਸ ਮਾਇਆ ਦਾ ਹਾਲ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Как тень дерева не остаётся постоянной, таково и состояние майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14749,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਨ ਗਏ ਕਹੁ ਕਾ ਕੀ ਮਾਇਆ ॥੨॥",
          "roman": "prān gae kah kā kī māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਦੇ ਪ੍ਰਾਣ ਨਿਕਲ ਜਾਂਦੇ ਹਨ ਤਾਂ ਦੱਸੋ, ਇਹ ਮਾਇਆ ਕਿਸ ਦੀ ਹੁੰਦੀ ਹੈ? (ਭਾਵ, ਕਿਸੇ ਹੋਰ ਦੀ ਬਣ ਜਾਂਦੀ ਹੈ, ਤਾਂ ਤੇ ਇਸ ਦਾ ਕੀਹ ਮਾਣ?) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Когда человек умирает, скажи, чьей становится эта майя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14750,
          "is_rahao": false,
          "gurmukhi": "ਜਸ ਜੰਤੀ ਮਹਿ ਜੀਉ ਸਮਾਨਾ ॥",
          "roman": "jas jantī meh jīu samānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਜਦੋਂ ਗਵਈਆ ਆਪਣਾ ਹੱਥ ਸਾਜ਼ ਤੋਂ ਹਟਾ ਲੈਂਦਾ ਹੈ, ਤਾਂ) ਰਾਗ ਦੀ ਅਵਾਜ਼ ਸਾਜ਼ ਦੇ ਵਿਚ (ਹੀ) ਲੀਨ ਹੋ ਜਾਂਦੀ ਹੈ (ਕੋਈ ਦੱਸ ਨਹੀਂ ਸਕਦਾ ਕਿ ਉਹ ਕਿਥੇ ਗਈ)"
            },
            "sahib_singh_ru": {
              "main": "Как звук растворяется в инструменте, когда музыкант перестаёт играть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14751,
          "is_rahao": false,
          "gurmukhi": "ਮੂਏ ਮਰਮੁ ਕੋ ਕਾ ਕਰ ਜਾਨਾ ॥੩॥",
          "roman": "mūe maram ko kā kar jānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਮਰੇ ਮਨੁੱਖ ਦਾ ਭੇਤ (ਕਿ ਉਸ ਦੀ ਜਿੰਦ ਕਿਥੇ ਗਈ) ਕੋਈ ਮਨੁੱਖ ਕਿਵੇਂ ਜਾਣ ਸਕਦਾ ਹੈ? ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так и тайну умершего — куда ушла его жизнь — никто не может узнать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14752,
          "is_rahao": false,
          "gurmukhi": "ਹੰਸਾ ਸਰਵਰੁ ਕਾਲੁ ਸਰੀਰ ॥",
          "roman": "hansā sarvar kāl sarīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹੰਸਾਂ ਨੂੰ ਸਰੋਵਰ ਹੈ (ਭਾਵ, ਜਿਵੇਂ ਹੰਸ ਸਰੋਵਰ ਦੇ ਨੇੜੇ ਹੀ ਉੱਡਦੇ ਰਹਿੰਦੇ ਹਨ) ਤਿਵੇਂ ਮੌਤ ਸਰੀਰਾਂ (ਲਈ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Как лебеди связаны с водоёмом, так смерть связана с телом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14753,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਨ ਪੀਉ ਰੇ ਕਬੀਰ ॥੪॥੮॥",
          "roman": "rām rasāyan pīo re kabīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਤੇ ਹੇ ਕਬੀਰ! ਸਭ ਰਸਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਨਾਮ-ਰਸ ਪੀ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о Кабир, пей высший нектар Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1293,
      "rahao_verse_id": 14758,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14754,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14755,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤਿ ਕੀ ਜਾਤਿ ਜਾਤਿ ਕੀ ਜੋਤੀ ॥",
          "roman": "jot kī jāt jāt kī jotī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਬਣਾਈ ਹੋਈ (ਸਾਰੀ) ਸ੍ਰਿਸ਼ਟੀ ਹੈ; ਇਸ ਸ੍ਰਿਸ਼ਟੀ ਦੇ (ਜੀਵਾਂ) ਦੀ (ਜੋ) ਬੁੱਧੀ (ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Всё творение создано Богом, и в нём есть разум существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14756,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਲਾਗੇ ਕੰਚੂਆ ਫਲ ਮੋਤੀ ॥੧॥",
          "roman": "tit lāge kanchūā phal motī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ) ਨੂੰ ਕੱਚ ਤੇ ਮੋਤੀ ਫਲ ਲੱਗੇ ਹੋਏ ਹਨ (ਭਾਵ, ਕੋਈ ਭਲੇ ਪਾਸੇ ਲੱਗੇ ਹੋਏ ਹਨ, ਤੇ ਕੋਈ ਮੰਦੇ ਪਾਸੇ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "в котором есть и стекло, и жемчуг — одни тянутся к добру, другие к злу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14757,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਘਰੁ ਜੋ ਨਿਰਭਉ ਕਹੀਐ ॥",
          "roman": "kavan su ghar jo nirbhau kahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕਿਹੜਾ ਥਾਂ ਹੈ ਜੋ ਡਰ ਤੋਂ ਖ਼ਾਲੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Где то место, которое можно назвать свободным от страха?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14758,
          "is_rahao": true,
          "gurmukhi": "ਭਉ ਭਜਿ ਜਾਇ ਅਭੈ ਹੋਇ ਰਹੀਐ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bhau bhaj jāi abhē hoi rahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਥੇ ਰਿਹਾਂ ਹਿਰਦੇ ਦਾ) ਡਰ ਦੂਰ ਹੋ ਸਕਦਾ ਹੈ, ਜਿਥੇ ਨਿਡਰ ਹੋ ਕੇ ਰਹਿ ਸਕੀਦਾ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Где можно избавиться от страха и жить без него?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14759,
          "is_rahao": false,
          "gurmukhi": "ਤਟਿ ਤੀਰਥਿ ਨਹੀ ਮਨੁ ਪਤੀਆਇ ॥",
          "roman": "tat tīrath nahī man patīāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ (ਪਵਿਤ੍ਰ ਨਦੀ ਦੇ) ਕੰਢੇ ਜਾਂ ਤੀਰਥ ਤੇ (ਜਾ ਕੇ ਭੀ) ਮਨ ਥਾਵੇਂ ਨਹੀਂ ਆਉਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Даже на берегах святых рек и в местах паломничества ум не успокаивается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14760,
          "is_rahao": false,
          "gurmukhi": "ਚਾਰ ਅਚਾਰ ਰਹੇ ਉਰਝਾਇ ॥੨॥",
          "roman": "chār achār rahe urjhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਓਥੇ ਭੀ ਲੋਕ ਪੁੰਨ-ਪਾਪ ਵਿਚ ਰੁੱਝੇ ਪਏ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "люди и там запутаны в грехах и добродетелях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14761,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਪੁੰਨ ਦੁਇ ਏਕ ਸਮਾਨ ॥",
          "roman": "pāp punn duī ek samān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਪਾਪ ਅਤੇ ਪੁੰਨ ਦੋਵੇਂ ਹੀ ਇਕੋ ਜਿਹੇ ਹਨ (ਭਾਵ, ਦੋਵੇਂ ਹੀ ਵਾਸ਼ਨਾ ਵਲ ਦੁੜਾਈ ਫਿਰਦੇ ਹਨ।)"
            },
            "sahib_singh_ru": {
              "main": "Но грех и добродетель — оба одинаковы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14762,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਘਰਿ ਪਾਰਸੁ ਤਜਹੁ ਗੁਨ ਆਨ ॥੩॥",
          "roman": "nij ghar pāras tajah gun ān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ! ਨੀਚੋਂ ਊਚ ਕਰਨ ਵਾਲਾ) ਪਾਰਸ (ਪ੍ਰਭੂ) ਤੇਰੇ ਆਪਣੇ ਅੰਦਰ ਹੀ ਹੈ, (ਤਾਂ ਤੇ, ਪਾਪ ਪੁੰਨ ਵਾਲੇ) ਹੋਰ ਗੁਣ (ਅੰਦਰ ਧਾਰਨੇ) ਛੱਡ ਦੇਹ (ਅਤੇ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਅੰਦਰ ਸੰਭਾਲ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ведь истинный философский камень — Бог — внутри тебя, оставь прочие качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14763,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਨਿਰਗੁਣ ਨਾਮ ਨ ਰੋਸੁ ॥",
          "roman": "kabīr nirgun nām na ros",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਕਬੀਰ! ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਉੱਚੇ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਨੂੰ ਨਾਹ ਭੁਲਾ;"
            },
            "sahib_singh_ru": {
              "main": "О Кабир, не забывай Имя Бога, превосходящего майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14764,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਪਰਚਾਇ ਪਰਚਿ ਰਹੁ ਏਸੁ ॥੪॥੯॥",
          "roman": "is parchāi parch rah es",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਨੂੰ ਨਾਮ ਜਪਣ ਦੇ ਆਹਰੇ ਲਾ ਕੇ ਨਾਮ ਵਿਚ ਰੁੱਝਿਆ ਰਹੁ ॥੪॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "Погрузи ум в повторение Имени и пребывай в нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1294,
      "rahao_verse_id": 14769,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14765,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14766,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨ ਪਰਮਿਤਿ ਪਰਮਨੁ ਜਾਨਾ ॥",
          "roman": "jo jan paramit paraman jānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ (ਨਿਰਾ ਆਖਦੇ ਹੀ ਹਨ ਕਿ) ਅਸਾਂ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਜਾਣ ਲਿਆ ਹੈ, ਜਿਸ ਦਾ ਹੱਦ-ਬੰਨਾ ਨਹੀਂ ਲੱਭਿਆ ਜਾ ਸਕਦਾ ਤੇ ਜੋ ਮਨ ਦੀ ਪਹੁੰਚ ਤੋਂ ਪਰੇ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто лишь говорят, что познали беспредельного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14767,
          "is_rahao": false,
          "gurmukhi": "ਬਾਤਨ ਹੀ ਬੈਕੁੰਠ ਸਮਾਨਾ ॥੧॥",
          "roman": "bātan hī bēkunth samānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਨਿਰੀਆਂ ਗੱਲਾਂ ਨਾਲ ਹੀ ਬੈਕੁੰਠ ਵਿਚ ਅੱਪੜੇ ਹਨ (ਭਾਵ, ਉਹ ਗੱਪਾਂ ਹੀ ਮਾਰ ਰਹੇ ਹਨ, ਉਹਨਾਂ ਬੈਕੁੰਠ ਅਸਲ ਵਿਚ ਡਿੱਠਾ ਨਹੀਂ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "достигают небес лишь словами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14768,
          "is_rahao": true,
          "gurmukhi": "ਨਾ ਜਾਨਾ ਬੈਕੁੰਠ ਕਹਾ ਹੀ ॥",
          "roman": "nā jānā bēkunth kahā hī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਤਾਂ ਪਤਾ ਨਹੀਂ, ਉਹ ਬੈਕੁੰਠ ਕਿੱਥੇ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я не знаю, где этот рай,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14769,
          "is_rahao": true,
          "gurmukhi": "ਜਾਨੁ ਜਾਨੁ ਸਭਿ ਕਹਹਿ ਤਹਾ ਹੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jān jān sabh kahah tahā hī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿੱਥੇ ਇਹ ਸਾਰੇ ਲੋਕ ਆਖਦੇ ਹਨ, ਚੱਲਣਾ ਹੈ, ਚੱਲਣਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "о котором все говорят: идём туда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14770,
          "is_rahao": false,
          "gurmukhi": "ਕਹਨ ਕਹਾਵਨ ਨਹ ਪਤੀਅਈ ਹੈ ॥",
          "roman": "kahan kahāvan nah patīāī hē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਰਾ ਇਹ ਆਖਣ ਨਾਲ ਤੇ ਸੁਣਨ ਨਾਲ (ਕਿ ਅਸਾਂ ਬੈਕੁੰਠ ਵਿਚ ਜਾਣਾ ਹੈ) ਮਨ ਨੂੰ ਤਸੱਲੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Просто слова и разговоры не приносят удовлетворения уму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14771,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਮਨੁ ਮਾਨੈ ਜਾ ਤੇ ਹਉਮੈ ਜਈ ਹੈ ॥੨॥",
          "roman": "tau man mānē jā te haumē jaī hē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਨੂੰ ਤਦੋਂ ਹੀ ਧੀਰਜ ਆ ਸਕਦੀ ਹੈ ਜੇ ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਏ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ум обретает покой только когда уходит эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14772,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਲਗੁ ਮਨਿ ਬੈਕੁੰਠ ਕੀ ਆਸ ॥",
          "roman": "jab lag man bēkunth kī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇੱਕ ਗੱਲ ਹੋਰ ਚੇਤੇ ਰੱਖਣ ਵਾਲੀ ਹੈ ਕਿ) ਜਦ ਤਕ ਮਨ ਵਿਚ ਬੈਕੁੰਠ ਜਾਣ ਦੀ ਤਾਂਘ ਲੱਗੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока в уме есть желание попасть в рай,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14773,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲਗੁ ਹੋਇ ਨਹੀ ਚਰਨ ਨਿਵਾਸੁ ॥੩॥",
          "roman": "tab lag hoi nahī charan nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਮਨ ਜੁੜ ਨਹੀਂ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "до тех пор ум не пребывает у ног Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14774,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਇਹ ਕਹੀਐ ਕਾਹਿ ॥",
          "roman": "kah kabīr ih kahīai kāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਇਹ ਗੱਲ ਕਿਵੇਂ ਸਮਝਾ ਕੇ ਦੱਸੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: как это объяснить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14775,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਬੈਕੁੰਠੈ ਆਹਿ ॥੪॥੧੦॥",
          "roman": "sādh sangat bēkunthē āh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵ, ਇਹ ਗੱਲ ਪਰਤੱਖ ਹੀ ਹੈ) ਕਿ ਸਾਧ-ਸੰਗਤ ਹੀ (ਅਸਲੀ) ਬੈਕੁੰਠ ਹੈ ॥੪॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "что истинный рай — это общение со святыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1295,
      "rahao_verse_id": 14780,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14776,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14777,
          "is_rahao": false,
          "gurmukhi": "ਉਪਜੈ ਨਿਪਜੈ ਨਿਪਜਿ ਸਮਾਈ ॥",
          "roman": "upjē nipjē nipaj samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਹਿਲਾਂ ਇਸ ਜੀਵ ਦਾ ਪਿਤਾ ਦੀ ਬਿੰਦ ਤੋਂ) ਮੁੱਢ ਬੱਝਦਾ ਹੈ, (ਫਿਰ ਮਾਂ ਦੇ ਪੇਟ ਵਿਚ ਇਹ) ਵਜੂਦ ਵਿਚ ਆਉਂਦਾ ਹੈ; ਵਜੂਦ ਵਿਚ ਆ ਕੇ (ਮੁੜ) ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Жизнь возникает, развивается и снова исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14778,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨਹ ਦੇਖਤ ਇਹੁ ਜਗੁ ਜਾਈ ॥੧॥",
          "roman": "nēnah dekhat ih jag jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੋ) ਅਸਾਡੇ ਅਖੀਂ ਵੇਖਦਿਆਂ ਹੀ ਇਹ ਸੰਸਾਰ (ਇਸੇ ਤਰ੍ਹਾਂ) ਤੁਰਿਆ ਜਾ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Прямо на наших глазах мир уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14779,
          "is_rahao": true,
          "gurmukhi": "ਲਾਜ ਨ ਮਰਹੁ ਕਹਹੁ ਘਰੁ ਮੇਰਾ ॥",
          "roman": "lāj na marah kahah ghar merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ, ਹੇ ਜੀਵ!) ਸ਼ਰਮ ਨਾਲ ਕਿਉਂ ਨਹੀਂ ਡੁੱਬ ਮਰਦਾ (ਭਾਵ, ਤੂੰ ਝੱਕਦਾ ਕਿਉਂ ਨਹੀਂ) ਜਦੋਂ ਤੂੰ ਇਹ ਆਖਦਾ ਹੈਂ ਕਿ ਇਹ ਘਰ ਮੇਰਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Почему ты не стыдишься, говоря: это мой дом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14780,
          "is_rahao": true,
          "gurmukhi": "ਅੰਤ ਕੀ ਬਾਰ ਨਹੀ ਕਛੁ ਤੇਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ant kī bār nahī kachh terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਚੇਤੇ ਰੱਖ) ਜਿਸ ਵੇਲੇ ਮੌਤ ਆਵੇਗੀ, ਤਦੋਂ ਕੋਈ ਭੀ ਚੀਜ਼ ਤੇਰੀ ਨਹੀਂ ਰਹੇਗੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "В момент смерти ничего не останется твоим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14781,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਤਨ ਕਰਿ ਕਾਇਆ ਪਾਲੀ ॥",
          "roman": "anik jatan kar kāiā pālī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜਤਨ ਕਰ ਕੇ ਇਹ ਸਰੀਰ ਪਾਲੀਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Много усилий прилагается, чтобы поддерживать тело,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14782,
          "is_rahao": false,
          "gurmukhi": "ਮਰਤੀ ਬਾਰ ਅਗਨਿ ਸੰਗਿ ਜਾਲੀ ॥੨॥",
          "roman": "martī bār agan sang jālī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਮੌਤ ਆਉਂਦੀ ਹੈ, ਇਸ ਨੂੰ ਅੱਗ ਨਾਲ ਸਾੜ ਦੇਈਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но в конце его сжигают огнём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14783,
          "is_rahao": false,
          "gurmukhi": "ਚੋਆ ਚੰਦਨੁ ਮਰਦਨ ਅੰਗਾ ॥",
          "roman": "choā chandan mardan angā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਸਰੀਰ ਦੇ) ਅੰਗਾਂ ਨੂੰ ਅਤਰ ਤੇ ਚੰਦਨ ਮਲੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тело, которое натирают ароматами и сандалом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14784,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਤਨੁ ਜਲੈ ਕਾਠ ਕੈ ਸੰਗਾ ॥੩॥",
          "roman": "so tan jalē kāṭh kē sangā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਰੀਰ (ਆਖ਼ਰ ਨੂੰ) ਲੱਕੜਾਂ ਨਾਲ ਸੜ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в итоге сгорает вместе с дровами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14785,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਸੁਨਹੁ ਰੇ ਗੁਨੀਆ ॥",
          "roman": "kah kabīr sunah re gunīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਹੇ ਵਿਚਾਰਨ ਮਨੁੱਖ! ਚੇਤੇ ਰੱਖ;"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: слушай, разумный человек,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14786,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੈਗੋ ਰੂਪੁ ਦੇਖੈ ਸਭ ਦੁਨੀਆ ॥੪॥੧੧॥",
          "roman": "binsēgo rūp dekhē sabh dunīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀ ਦੁਨੀਆ ਵੇਖੇਗੀ (ਭਾਵ, ਸਭ ਦੇ ਵੇਖਦਿਆਂ ਵੇਖਦਿਆਂ) ਇਹ ਰੂਪ ਨਾਸ ਹੋ ਜਾਇਗਾ ॥੪॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "этот облик исчезнет на глазах у всего мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1296,
      "rahao_verse_id": 14791,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14787,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14788,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਮੂਏ ਕਿਆ ਸੋਗੁ ਕਰੀਜੈ ॥",
          "roman": "avar mūe kiā sog karījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰਨਾਂ ਦੇ ਮਰਨ ਤੇ ਸੋਗ ਕਰਨ ਦਾ ਕੀਹ ਲਾਭ?"
            },
            "sahib_singh_ru": {
              "main": "Какой смысл скорбеть о смерти других?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14789,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਕੀਜੈ ਜਉ ਆਪਨ ਜੀਜੈ ॥੧॥",
          "roman": "tau kījē jau āpan jījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਵਿਛੋੜੇ ਦਾ) ਸੋਗ ਤਾਂ ਹੀ ਕਰੀਏ ਜੇ ਆਪ (ਇਥੇ ਸਦਾ) ਜੀਊਂਦੇ ਰਹਿਣਾ ਹੋਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Скорбь имеет смысл, если бы ты сам жил вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14790,
          "is_rahao": true,
          "gurmukhi": "ਮੈ ਨ ਮਰਉ ਮਰਿਬੋ ਸੰਸਾਰਾ ॥",
          "roman": "mē na marau maribo sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਆਤਮਾ ਦੀ ਕਦੇ ਮੌਤ ਨਹੀਂ ਹੋਵੇਗੀ। ਮੁਰਦਾ ਹਨ ਉਹ ਜੀਵ ਜੋ ਜਗਤ ਦੇ ਧੰਧਿਆਂ ਵਿਚ ਫਸੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Моя душа не умирает; умирают те, кто погружён в мирские дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14791,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਮੋਹਿ ਮਿਲਿਓ ਹੈ ਜੀਆਵਨਹਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ab mohi miliyo hē jīāvanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ (ਤਾਂ) ਹੁਣ (ਅਸਲ) ਜ਼ਿੰਦਗੀ ਦੇਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਮਿਲ ਪਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Теперь я встретил Дающего жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14792,
          "is_rahao": false,
          "gurmukhi": "ਇਆ ਦੇਹੀ ਪਰਮਲ ਮਹਕੰਦਾ ॥",
          "roman": "iā dehī paramal mahkandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ) ਇਸ ਸਰੀਰ ਤੇ ਕਈ ਸੁਗੰਧੀਆਂ ਮਹਿਕਾਉਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Человек украшает тело ароматами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14793,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਸੁਖ ਬਿਸਰੇ ਪਰਮਾਨੰਦਾ ॥੨॥",
          "roman": "tā sukh bisre paramānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਹੀ ਸੁਖਾਂ ਵਿਚ ਇਸ ਨੂੰ ਪਰਮ ਅਨੰਦ-ਸਰੂਪ ਪਰਮਾਤਮਾ ਭੁੱਲ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и в этих удовольствиях забывает Высшее Блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14794,
          "is_rahao": false,
          "gurmukhi": "ਕੂਅਟਾ ਏਕੁ ਪੰਚ ਪਨਿਹਾਰੀ ॥",
          "roman": "kūaṭā ek panch panihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਰੀਰ ਮਾਨੋ) ਇਕ ਨਿੱਕਾ ਜਿਹਾ ਖੂਹ ਹੈ, (ਪੰਜ ਗਿਆਨ-ਇੰਦਰੇ, ਮਾਨੋ) ਪੰਜ ਚਰੱਖੜੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тело подобно колодцу, а пять чувств — водоносы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14795,
          "is_rahao": false,
          "gurmukhi": "ਟੂਟੀ ਲਾਜੁ ਭਰੈ ਮਤਿ ਹਾਰੀ ॥੩॥",
          "roman": "ṭūṭī lāj bharē mat hārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਰੀ ਹੋਈ ਮੱਤ ਲੱਜ ਤੋਂ ਬਿਨਾ (ਪਾਣੀ) ਭਰ ਰਹੀ ਹੈ (ਭਾਵ, ਵਿਕਾਰਾਂ ਵਿਚ ਫਸੀ ਹੋਈ ਮੱਤ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਰਾਹੀਂ ਵਿਕਾਰਾਂ ਵਿਚੋਂ ਸੁਖ ਲੈਣ ਦੇ ਵਿਅਰਥ ਜਤਨ ਕਰ ਰਹੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потерявший разум без стыда черпает из него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14796,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਇਕ ਬੁਧਿ ਬੀਚਾਰੀ ॥",
          "roman": "kah kabīr ik budh bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- (ਜਦੋਂ) ਵਿਚਾਰ ਵਾਲੀ ਬੁੱਧ ਅੰਦਰ (ਜਾਗ ਪਈ),"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: когда пробуждается разум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14797,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਓਹੁ ਕੂਅਟਾ ਨਾ ਪਨਿਹਾਰੀ ॥੪॥੧੨॥",
          "roman": "nā oh kūaṭā nā panihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਨਾਹ ਉਹ ਸਰੀਰਕ ਮੋਹ ਰਿਹਾ ਤੇ ਨਾਹ ਹੀ (ਵਿਕਾਰਾਂ ਵਲ ਖਿੱਚਣ ਵਾਲੇ) ਉਹ ਇੰਦਰੇ ਰਹੇ ॥੪॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда нет ни колодца, ни водоносов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1297,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14798,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gaurī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14799,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਾਵਰ ਜੰਗਮ ਕੀਟ ਪਤੰਗਾ ॥",
          "roman": "asthāvar jangam kīṭ patangā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ (ਹੁਣ ਤਕ) ਅਸਥਾਵਰ, ਜੰਗਮ ਕੀੜੇ-ਪਤੰਗੇ"
            },
            "sahib_singh_ru": {
              "main": "Мы были неподвижными, подвижными, насекомыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14800,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਜਨਮ ਕੀਏ ਬਹੁ ਰੰਗਾ ॥੧॥",
          "roman": "anik janam kīe bah rangā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹੋ ਜਿਹੇ ਕਈ ਕਿਸਮਾਂ ਦੇ ਜਨਮਾਂ ਵਿਚ ਆ ਚੁਕੇ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "пережили множество разных рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
