{
  "ang": 326,
  "shabads": [
    {
      "shabad_id": 1297,
      "rahao_verse_id": 14802,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14801,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਘਰ ਹਮ ਬਹੁਤੁ ਬਸਾਏ ॥",
          "roman": "Aisē ghar ham bahut basāē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такие многие тела-обители мы уже населяли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14802,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਹਮ ਰਾਮ ਗਰਭ ਹੋਇ ਆਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Jab ham rām garabh hoe āē. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Рам, когда мы снова и снова входили в утробы, мы проходили через такие многие тела. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14803,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਜਤੀ ਤਪੀ ਬ੍ਰਹਮਚਾਰੀ ॥",
          "roman": "Jogī jatī tapī brahmachārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда-то мы становились йогами, воздержанными, подвижниками и брахмачари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14804,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਰਾਜਾ ਛਤ੍ਰਪਤਿ ਕਬਹੂ ਭੇਖਾਰੀ ॥੨॥",
          "roman": "Kabahū rājā chhatrapat kabahū bhēkhārī. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда-то были царями под зонтами власти, а когда-то нищими. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14805,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਮਰਹਿ ਸੰਤ ਸਭਿ ਜੀਵਹਿ ॥",
          "roman": "Sākat marah sant sabh jīvah.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди, оторванные от Бога, снова и снова умирают, попадая в круг рождений; святые же пребывают живыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14806,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਨੁ ਰਸਨਾ ਪੀਵਹਿ ॥੩॥",
          "roman": "Rām rasāin rasnā pīvah. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они языком пьют высший нектар Имени Рама. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14807,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਪ੍ਰਭ ਕਿਰਪਾ ਕੀਜੈ ॥",
          "roman": "Kaho Kabīr prabh kirpā kījē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: о Господь, яви милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14808,
          "is_rahao": false,
          "gurmukhi": "ਹਾਰਿ ਪਰੇ ਅਬ ਪੂਰਾ ਦੀਜੈ ॥੪॥੧੩॥",
          "roman": "Hār parē ab pūrā dījē. ||4||13||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы устали, истощились и пали у Твоей двери; теперь даруй совершенное знание. ||4||13||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1298,
      "rahao_verse_id": 14811,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14809,
          "is_rahao": true,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਕੀ ਨਾਲਿ ਰਲਾਇ ਲਿਖਿਆ ਮਹਲਾ ੫ ॥",
          "roman": "Gauṛī Kabīr jī kī nāl ralāe likhiā mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир джи; вместе с ним записано также участие Пятого Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14810,
          "is_rahao": true,
          "gurmukhi": "ਐਸੋ ਅਚਰਜੁ ਦੇਖਿਓ ਕਬੀਰ ॥",
          "roman": "Aiso acharaj dēkhio Kabīr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, я увидел удивительное зрелище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14811,
          "is_rahao": true,
          "gurmukhi": "ਦਧਿ ਕੈ ਭੋਲੈ ਬਿਰੋਲੈ ਨੀਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Dadh kē bholē birolē nīr. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живое существо, думая, что это простокваша, взбивает воду, то есть делает бесполезное и перевёрнутое дело. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14812,
          "is_rahao": false,
          "gurmukhi": "ਹਰੀ ਅੰਗੂਰੀ ਗਦਹਾ ਚਰੈ ॥",
          "roman": "Harī angūrī gadhā charē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Глупое существо, словно осёл, питается свежими побегами приятных ему пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14813,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਉਠਿ ਹਾਸੈ ਹੀਗੈ ਮਰੈ ॥੧॥",
          "roman": "Nit uṭh hāsē hīgē marē. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так оно всё время смеётся, ревёт и в конце попадает в круг рождения и смерти. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14814,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤਾ ਭੈਸਾ ਅੰਮੁਹਾ ਜਾਇ ॥",
          "roman": "Mātā bhēsā ammuhā jāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Опьянённый ум, подобный неукротимому быку, действует упрямо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14815,
          "is_rahao": false,
          "gurmukhi": "ਕੁਦਿ ਕੁਦਿ ਚਰੈ ਰਸਾਤਲਿ ਪਾਇ ॥੨॥",
          "roman": "Kud kud charē rasātal pāe. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он скачет, проявляет гордыню, пасётся на поле чувственных удовольствий и падает в ад. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14816,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਪਰਗਟੁ ਭਈ ਖੇਡ ॥",
          "roman": "Kaho Kabīr pargaṭ bhaī khēḍ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: эта странная игра стала мне понятна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14817,
          "is_rahao": false,
          "gurmukhi": "ਲੇਲੇ ਕਉ ਚੂਘੈ ਨਿਤ ਭੇਡ ॥੩॥",
          "roman": "Lēlē kau chūghē nit bhēḍ. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Игра такова: разум мирских существ постоянно следует за умом, словно овца сосёт ягнёнка. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14818,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਮਤ ਮਤਿ ਪਰਗਟੀ ਆਈ ॥",
          "roman": "Rām ramat mat pargaṭī āī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя и созерцая Рама, моя мудрость пробудилась."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14819,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਗੁਰਿ ਸੋਝੀ ਪਾਈ ॥੪॥੧॥੧੪॥",
          "roman": "Kaho Kabīr gur sojhī pāī. ||4||1||14||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: Гуру даровал это понимание, благодаря которому разум перестал идти за умом. ||4||1||14||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1299,
      "rahao_verse_id": 14824,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14820,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਪੰਚਪਦੇ ॥",
          "roman": "Gauṛī Kabīr jī panchpadē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир джи, пятистрофный шабад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14821,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜਲ ਛੋਡਿ ਬਾਹਰਿ ਭਇਓ ਮੀਨਾ ॥",
          "roman": "Jiu jal chhoḍ bāhar bhaio mīnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди говорят мне: как рыба, выйдя из воды, мучается и умирает..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14822,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਬ ਜਨਮ ਹਉ ਤਪ ਕਾ ਹੀਨਾ ॥੧॥",
          "roman": "Pūrab janam hau tap kā hīnā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "...так и я, должно быть, был лишён подвижничества в прошлых рождениях, раз покинул освобождающую Каши. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14823,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਕਹੁ ਰਾਮ ਕਵਨ ਗਤਿ ਮੋਰੀ ॥",
          "roman": "Ab kaho rām kavan gat morī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Рам, теперь скажи: каково будет моё состояние?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14824,
          "is_rahao": true,
          "gurmukhi": "ਤਜੀ ਲੇ ਬਨਾਰਸ ਮਤਿ ਭਈ ਥੋਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Tajī lē Banāras mat bhaī thorī. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я оставил Банарас; неужели моя мудрость уменьшилась и помрачилась? ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14825,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਜਨਮੁ ਸਿਵ ਪੁਰੀ ਗਵਾਇਆ ॥",
          "roman": "Sagal janam siv purī gavāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди говорят: ты всю жизнь впустую провёл в городе Шивы, Каши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14826,
          "is_rahao": false,
          "gurmukhi": "ਮਰਤੀ ਬਾਰ ਮਗਹਰਿ ਉਠਿ ਆਇਆ ॥੨॥",
          "roman": "Martī bār Magahar uṭh āiā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А в час смерти покинул его и ушёл в Магхар. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14827,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਬਰਸ ਤਪੁ ਕੀਆ ਕਾਸੀ ॥",
          "roman": "Bahut baras tap kīā Kāsī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди говорят: много лет ты совершал аскезу в Каши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14828,
          "is_rahao": false,
          "gurmukhi": "ਮਰਨੁ ਭਇਆ ਮਗਹਰ ਕੀ ਬਾਸੀ ॥੩॥",
          "roman": "Maran bhaeā Magahar kī bāsī. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но когда пришло время смерти, ты стал жителем Магхара. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14829,
          "is_rahao": false,
          "gurmukhi": "ਕਾਸੀ ਮਗਹਰ ਸਮ ਬੀਚਾਰੀ ॥",
          "roman": "Kāsī Magahar sam bīchārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди насмехаются: ты счёл Каши и Магхар одинаковыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14830,
          "is_rahao": false,
          "gurmukhi": "ਓਛੀ ਭਗਤਿ ਕੈਸੇ ਉਤਰਸਿ ਪਾਰੀ ॥੪॥",
          "roman": "Ochhī bhagat kēsē utaras pārī. ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как же с такой мелкой, неполной преданностью ты переправишься через мирской океан? ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14831,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਗੁਰ ਗਜ ਸਿਵ ਸਭੁ ਕੋ ਜਾਨੈ ॥",
          "roman": "Kaho gur gaj siv sabh ko jānē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи: каждый признаёт Ганеша и Шиву, думая, будто именно они дают или отнимают освобождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14832,
          "is_rahao": false,
          "gurmukhi": "ਮੁਆ ਕਬੀਰੁ ਰਮਤ ਸ੍ਰੀ ਰਾਮੈ ॥੫॥੧੫॥",
          "roman": "Muā Kabīr ramat srī rāmē. ||5||15||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но Кабир, созерцая Прекрасного Рама, умер для чувства «я» и «моё». ||5||15||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1300,
      "rahao_verse_id": 14837,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14833,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14834,
          "is_rahao": false,
          "gurmukhi": "ਚੋਆ ਚੰਦਨ ਮਰਦਨ ਅੰਗਾ ॥",
          "roman": "Choā chandan mardan angā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело, чьи члены натирают благовониями и сандалом..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14835,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਤਨੁ ਜਲੈ ਕਾਠ ਕੈ ਸੰਗਾ ॥੧॥",
          "roman": "So tan jalē kāṭh kē sangā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "...в конце кладут вместе с дровами и сжигают. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14836,
          "is_rahao": true,
          "gurmukhi": "ਇਸੁ ਤਨ ਧਨ ਕੀ ਕਵਨ ਬਡਾਈ ॥",
          "roman": "Is tan dhan kī kavan baḍāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чем же гордиться этим телом и богатством?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14837,
          "is_rahao": true,
          "gurmukhi": "ਧਰਨਿ ਪਰੈ ਉਰਵਾਰਿ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Dharan parē urvār na jāī. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они остаются здесь, лежат на земле и не идут вместе с живым существом. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14838,
          "is_rahao": false,
          "gurmukhi": "ਰਾਤਿ ਜਿ ਸੋਵਹਿ ਦਿਨ ਕਰਹਿ ਕਾਮ ॥",
          "roman": "Rāt je soveh din karah kām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, что ночью спят, а днём заняты мирскими делами..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14839,
          "is_rahao": false,
          "gurmukhi": "ਇਕੁ ਖਿਨੁ ਲੇਹਿ ਨ ਹਰਿ ਕੋ ਨਾਮ ॥੨॥",
          "roman": "Ik khin lēh na har ko nām. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "...не повторяют Имя Бога даже на одно мгновение. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14840,
          "is_rahao": false,
          "gurmukhi": "ਹਾਥਿ ਤ ਡੋਰ ਮੁਖਿ ਖਾਇਓ ਤੰਬੋਰ ॥",
          "roman": "Hāth ta ḍor mukh khāio tambor.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У них в руках верёвки для ловчих птиц, а во рту они жуют пан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14841,
          "is_rahao": false,
          "gurmukhi": "ਮਰਤੀ ਬਾਰ ਕਸਿ ਬਾਧਿਓ ਚੋਰ ॥੩॥",
          "roman": "Martī bār kas bādhio chor. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но в час смерти их туго связывают, словно воров. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14842,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਰਸਿ ਰਸਿ ਹਰਿ ਗੁਨ ਗਾਵੈ ॥",
          "roman": "Gurmat ras ras har gun gāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто, приняв наставление Гуру, с глубокой любовью воспевает качества Бога..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14843,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮੈ ਰਾਮ ਰਮਤ ਸੁਖੁ ਪਾਵੈ ॥੪॥",
          "roman": "Rāmē rām ramat sukh pāvē. ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "...обретает радость, снова и снова созерцая одного лишь Рама. ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14844,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਾ ਕਰਿ ਕੈ ਨਾਮੁ ਦ੍ਰਿੜਾਈ ॥",
          "roman": "Kirpā kar kē nām driṛāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Своей милости Господь утверждает Имя в сердце человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14845,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਬਾਸੁ ਸੁਗੰਧ ਬਸਾਈ ॥੫॥",
          "roman": "Har har bās sugandh basāī. ||5||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он поселяeт в нём благоухание Имени Хар-Хар. ||5||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14846,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਕਬੀਰ ਚੇਤਿ ਰੇ ਅੰਧਾ ॥",
          "roman": "Kahat Kabīr chēt rē andhā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: о слепой, невежественный человек, вспоминай Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14847,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਰਾਮੁ ਝੂਠਾ ਸਭੁ ਧੰਧਾ ॥੬॥੧੬॥",
          "roman": "Sat rām jhūṭhā sabh dhandhā. ||6||16||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рам один вечен и истинен; вся остальная суета преходяща и ложна. ||6||16||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1301,
      "rahao_verse_id": 14854,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14848,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਤਿਪਦੇ ਚਾਰਤੁਕੇ ॥",
          "roman": "Gauṛī Kabīr jī tipadē chārtukē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир джи, трёхстрофный шабад с четверостишиями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14849,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਤੇ ਉਲਟਿ ਭਏ ਹੈ ਰਾਮ ॥",
          "roman": "Jam tē ulaṭ bhaē hē rām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто прежде казались мне посланцами смерти, переменились и стали образом Рама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14850,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਬਿਨਸੇ ਸੁਖ ਕੀਓ ਬਿਸਰਾਮ ॥",
          "roman": "Dukh binsē sukh kīo bisrām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мои страдания исчезли, и радость устроила во мне своё пребывание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14851,
          "is_rahao": false,
          "gurmukhi": "ਬੈਰੀ ਉਲਟਿ ਭਏ ਹੈ ਮੀਤਾ ॥",
          "roman": "Bērī ulaṭ bhaē hē mītā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто прежде были врагами, превратились в друзей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14852,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤ ਉਲਟਿ ਸੁਜਨ ਭਏ ਚੀਤਾ ॥੧॥",
          "roman": "Sākat ulaṭ sujan bhaē chītā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри они перестали быть оторванными от Бога и стали благими, обращёнными к Гуру. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14853,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਮੋਹਿ ਸਰਬ ਕੁਸਲ ਕਰਿ ਮਾਨਿਆ ॥",
          "roman": "Ab moh sarab kusal kar māniā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь я воспринимаю всё как благополучие и радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14854,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਭਈ ਜਬ ਗੋਬਿਦੁ ਜਾਨਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Sānt bhaī jab gobid jāniā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С тех пор как я познал Гобинда и вошёл с Ним в связь, внутри меня наступил покой. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
