{
  "ang": 327,
  "shabads": [
    {
      "shabad_id": 1301,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14855,
          "is_rahao": false,
          "gurmukhi": "ਤਨ ਮਹਿ ਹੋਤੀ ਕੋਟਿ ਉਪਾਧਿ ॥",
          "roman": "tan meh hotī koṭ upādh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В теле были мириады бед, недугов и обременений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14856,
          "is_rahao": false,
          "gurmukhi": "ਉਲਟਿ ਭਈ ਸੁਖ ਸਹਜਿ ਸਮਾਧਿ ॥",
          "roman": "ulaṭ bhaī sukh sahaj samādh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда сознание обратилось внутрь, возникло естественное состояние покоя и самадхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14857,
          "is_rahao": false,
          "gurmukhi": "ਆਪੁ ਪਛਾਨੈ ਆਪੈ ਆਪ ॥",
          "roman": "āp pachhānē āpē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам познаёт самого себя, свою истинную суть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14858,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਨ ਬਿਆਪੈ ਤੀਨੌ ਤਾਪ ॥੨॥",
          "roman": "rog na biāpē tīno tāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда болезнь не овладевает им, и три вида страданий не касаются его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14859,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਮਨੁ ਉਲਟਿ ਸਨਾਤਨੁ ਹੂਆ ॥",
          "roman": "ab man ulaṭ sanātan hūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь ум обратился и стал утверждён в изначальном, вечном состоянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14860,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਜਾਨਿਆ ਜਬ ਜੀਵਤ ਮੂਆ ॥",
          "roman": "tab jāniā jab jīvat mūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда я понял это, когда умер при жизни, то есть оставил чувство отдельного «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14861,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਸੁਖਿ ਸਹਜਿ ਸਮਾਵਉ ॥",
          "roman": "kah kabīr sukh sahaj samāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Говорит Кабир: я погружаюсь в естественный покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14862,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਨ ਡਰਉ ਨ ਅਵਰ ਡਰਾਵਉ ॥੩॥੧੭॥",
          "roman": "āp na ḍarau na avar ḍarāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я сам не боюсь и других не пугаю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1302,
      "rahao_verse_id": 14869,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14863,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14864,
          "is_rahao": false,
          "gurmukhi": "ਪਿੰਡਿ ਮੂਐ ਜੀਉ ਕਿਹ ਘਰਿ ਜਾਤਾ ॥",
          "roman": "piṇḍ mūey jīu kih ghar jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда привязанность к телу умирает, где тогда пребывает душа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14865,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਅਤੀਤਿ ਅਨਾਹਦਿ ਰਾਤਾ ॥",
          "roman": "sabad atīt anāhad rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По благодати Слова Сатгуру она остаётся соединённой с тем Господом, который за пределами уз майи и бесконечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14866,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਰਾਮੁ ਜਾਨਿਆ ਤਿਨਹਿ ਪਛਾਨਿਆ ॥",
          "roman": "jin rām jāniā tineh pachhāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот, кто познал Господа внутри себя, по-настоящему распознал Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14867,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਗੂੰਗੇ ਸਾਕਰ ਮਨੁ ਮਾਨਿਆ ॥੧॥",
          "roman": "jio gūṅge sākar man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это подобно тому, как ум немого насыщается вкусом сахара: другой не может понять этот вкус, и сам он не может его объяснить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14868,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਗਿਆਨੁ ਕਥੈ ਬਨਵਾਰੀ ॥",
          "roman": "ēsā giān kathē banvārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такое знание открывает Сам Господь, Владыка леса-мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14869,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਰੇ ਪਵਨ ਦ੍ਰਿੜ ਸੁਖਮਨ ਨਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man re pavan driṛ sukhman nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, повторяй Имя с каждым дыханием; именно это и есть подлинная практика сухмана-нади."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14870,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਗੁਰੁ ਕਰਹੁ ਜਿ ਬਹੁਰਿ ਨ ਕਰਨਾ ॥",
          "roman": "so gur karah j bahur na karnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прими такого Гуру, чтобы уже не было нужды принимать другого; то есть припади к стопам совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14871,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਦੁ ਰਵਹੁ ਜਿ ਬਹੁਰਿ ਨ ਰਵਨਾ ॥",
          "roman": "so pad ravah j bahur na ravnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наслаждайся таким состоянием, чтобы уже не оставалось желания искать иных вкусов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14872,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਿਆਨੁ ਧਰਹੁ ਜਿ ਬਹੁਰਿ ਨ ਧਰਨਾ ॥",
          "roman": "so dhiān dharah j bahur na dharnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Утверди такое сосредоточение, чтобы потом уже не приходилось направлять внимание куда-либо ещё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14873,
          "is_rahao": false,
          "gurmukhi": "ਐਸੇ ਮਰਹੁ ਜਿ ਬਹੁਰਿ ਨ ਮਰਨਾ ॥੨॥",
          "roman": "aise marah ji bahur na marnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Умри так, то есть устрани чувство отдельного «я», чтобы больше не попадать в рождение и смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14874,
          "is_rahao": false,
          "gurmukhi": "ਉਲਟੀ ਗੰਗਾ ਜਮੁਨ ਮਿਲਾਵਉ ॥",
          "roman": "ulṭī gaṅgā jamun milāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я повернул направление ума от мира и так соединяю Гангу и Джамну внутри себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14875,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਜਲ ਸੰਗਮ ਮਨ ਮਹਿ ਨੑਾਵਉ ॥",
          "roman": "bin jal saṅgam man meh nhāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этом внутреннем слиянии ума, где нет внешней воды, я совершаю омовение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14876,
          "is_rahao": false,
          "gurmukhi": "ਲੋਚਾ ਸਮਸਰਿ ਇਹੁ ਬਿਉਹਾਰਾ ॥",
          "roman": "lochā samsar ih biuhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь этими глазами я вижу всех одинаково; таков мой образ поведения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14877,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਬੀਚਾਰਿ ਕਿਆ ਅਵਰਿ ਬੀਚਾਰਾ ॥੩॥",
          "roman": "tat bīchār kiā avar bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Размышляя об одном Господе, я больше не нуждаюсь в иных размышлениях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14878,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁ ਤੇਜੁ ਬਾਇ ਪ੍ਰਿਥਮੀ ਆਕਾਸਾ ॥",
          "roman": "ap tej bāe prithmī ākāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как вода, огонь, воздух, земля и небо несут свои благие качества, так и я принимаю такую благую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14879,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਰਹਤ ਰਹਉ ਹਰਿ ਪਾਸਾ ॥",
          "roman": "aisī rahat rahau har pāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соединившись со стопами Господа, я живу таким образом жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14880,
          "is_rahao": false,
          "gurmukhi": "ਕਹੈ ਕਬੀਰ ਨਿਰੰਜਨ ਧਿਆਵਉ ॥",
          "roman": "kahē kabīr nirañjan dhiāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я созерцаю Господа, свободного от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14881,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਘਰਿ ਜਾਉ ਜਿ ਬਹੁਰਿ ਨ ਆਵਉ ॥੪॥੧੮॥",
          "roman": "tit ghar jāu ji bahur na āvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через симран я достиг того дома, состояния сахадж, откуда уже не нужно возвращаться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1303,
      "rahao_verse_id": 14886,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14882,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਤਿਪਦੇ ॥",
          "roman": "gauṛī kabīr jī tipade",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи, трёхстрофные шабады."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14883,
          "is_rahao": false,
          "gurmukhi": "ਕੰਚਨ ਸਿਉ ਪਾਈਐ ਨਹੀ ਤੋਲਿ ॥",
          "roman": "kañchan sio pāīai nahī tol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бога нельзя получить в обмен на золото, даже если отвесить золото равным весом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14884,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਦੇ ਰਾਮੁ ਲੀਆ ਹੈ ਮੋਲਿ ॥੧॥",
          "roman": "man de rām līā hē mol",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я же отдал свой ум как цену и так нашёл Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14885,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਮੋਹਿ ਰਾਮੁ ਅਪੁਨਾ ਕਰਿ ਜਾਨਿਆ ॥",
          "roman": "ab mohe rām apunā kar jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь во мне утвердилась уверенность, что Господь — мой собственный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14886,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਸੁਭਾਇ ਮੇਰਾ ਮਨੁ ਮਾਨਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sahaj subhāe merā man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Само собой, без усилия, эта уверенность прочно связалась в моём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14887,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮੈ ਕਥਿ ਕਥਿ ਅੰਤੁ ਨ ਪਾਇਆ ॥",
          "roman": "brahmē kath kath ant na pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже Брахма, снова и снова описывая качества этого Господа, не смог найти Его предела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14888,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਭਗਤਿ ਬੈਠੇ ਘਰਿ ਆਇਆ ॥੨॥",
          "roman": "rām bhagat bēṭhe ghar āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А благодаря бхаджану Господь сам, естественно и без усилия, пришёл ко мне в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14889,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਚੰਚਲ ਮਤਿ ਤਿਆਗੀ ॥",
          "roman": "kah kabīr chañchal mat tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: теперь я оставил непостоянный, легкомысленный склад ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14890,
          "is_rahao": false,
          "gurmukhi": "ਕੇਵਲ ਰਾਮ ਭਗਤਿ ਨਿਜ ਭਾਗੀ ॥੩॥੧॥੧੯॥",
          "roman": "keval rām bhagat nij bhāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь на мою долю выпала только преданность Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1304,
      "rahao_verse_id": 14895,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14891,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14892,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਮਰਨੈ ਸਭੁ ਜਗਤੁ ਤਰਾਸਿਆ ॥",
          "roman": "jih marnē sabh jagat tarāsiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та смерть, которая напугала весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14893,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮਰਨਾ ਗੁਰ ਸਬਦਿ ਪ੍ਰਗਾਸਿਆ ॥੧॥",
          "roman": "so marnā gur sabad pragāsiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По благодати Слова Гуру мне стало ясно, что эта смерть представляет собой на самом деле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14894,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਕੈਸੇ ਮਰਉ ਮਰਨਿ ਮਨੁ ਮਾਨਿਆ ॥",
          "roman": "ab kēse marau maran man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь зачем мне попадать в рождение и смерть? Мой ум принял смерть чувства отдельного «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14895,
          "is_rahao": true,
          "gurmukhi": "ਮਰਿ ਮਰਿ ਜਾਤੇ ਜਿਨ ਰਾਮੁ ਨ ਜਾਨਿਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mar mar jāte jin rām na jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только те снова и снова рождаются и умирают, кто не распознал Господа и не вошёл с Ним в связь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14896,
          "is_rahao": false,
          "gurmukhi": "ਮਰਨੋ ਮਰਨੁ ਕਹੈ ਸਭੁ ਕੋਈ ॥",
          "roman": "marno maran kahē sabh koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мире каждый говорит: смерть, смерть; каждый страшится смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14897,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜੇ ਮਰੈ ਅਮਰੁ ਹੋਇ ਸੋਈ ॥੨॥",
          "roman": "sahaje marē amar hoe soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но тот, кто в состоянии сахадж умирает для желаний мира, становится бессмертным; смерть уже не может его испугать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14898,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਮਨਿ ਭਇਆ ਅਨੰਦਾ ॥",
          "roman": "kah kabīr man bhaiā anandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: по милости Гуру в моём уме возникла радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14899,
          "is_rahao": false,
          "gurmukhi": "ਗਇਆ ਭਰਮੁ ਰਹਿਆ ਪਰਮਾਨੰਦਾ ॥੩॥੨੦॥",
          "roman": "gaiā bharam rahiā parmānandā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моё заблуждение ушло, и в сердце утвердилось высшее блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1305,
      "rahao_verse_id": 14904,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14900,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "gauṛī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гаури, Кабир Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14901,
          "is_rahao": false,
          "gurmukhi": "ਕਤ ਨਹੀ ਠਉਰ ਮੂਲੁ ਕਤ ਲਾਵਉ ॥",
          "roman": "kat nahī ṭhaur mūl kat lāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нигде нет такого места; куда же мне приложить лекарство?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14902,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਤਨ ਮਹਿ ਠਉਰ ਨ ਪਾਵਉ ॥੧॥",
          "roman": "khojat tan meh ṭhaur na pāvau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ища в теле, я не нахожу места, где можно было бы указать боль разлуки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14903,
          "is_rahao": true,
          "gurmukhi": "ਲਾਗੀ ਹੋਇ ਸੁ ਜਾਨੈ ਪੀਰ ॥",
          "roman": "lāgī hoe su jānē pīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот, кто ранен этими стрелами, знает, какова эта боль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14904,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਭਗਤਿ ਅਨੀਆਲੇ ਤੀਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rām bhagat anīāle tīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Преданность Господу — это острые стрелы с наконечниками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14905,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਭਾਇ ਦੇਖਉ ਸਭ ਨਾਰੀ ॥",
          "roman": "ek bhāe dekhau sabh nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я вижу всех живых-душ как невест в любви к одному Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14906,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਜਾਨਉ ਸਹ ਕਉਨ ਪਿਆਰੀ ॥੨॥",
          "roman": "kiā jāṇau sah kaun piārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но откуда мне знать, какая из них любима Господом-супругом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14907,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜਾ ਕੈ ਮਸਤਕਿ ਭਾਗੁ ॥",
          "roman": "kah kabīr jā kē mastak bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Кабир: та душа-невеста, на чьём челе добрые судьбы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14908,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਪਰਹਰਿ ਤਾ ਕਉ ਮਿਲੈ ਸੁਹਾਗੁ ॥੩॥੨੧॥",
          "roman": "sabh parhar tā kau milē suhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив всех прочих, супруг-Господь приходит к ней; Он любит её особенно и устраняет её боль разлуки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
