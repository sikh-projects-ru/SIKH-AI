{
  "ang": 328,
  "shabads": [
    {
      "shabad_id": 1306,
      "rahao_verse_id": 14913,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14909,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14910,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹਰਿ ਸਾ ਠਾਕੁਰੁ ਭਾਈ ॥",
          "roman": "Jā kē har sā ṭhākur bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੱਜਣ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ-ਰੂਪ ਘਰ ਵਿਚ ਪ੍ਰਭੂ ਮਾਲਕ ਆਪ (ਮੌਜੂਦ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О друг! У того человека, в доме-сердце которого сам Пребывающий Господь-Владыка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14911,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਅਨੰਤ ਪੁਕਾਰਣਿ ਜਾਈ ॥੧॥",
          "roman": "Mukat anant pukāraṇ jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁਕਤੀ ਉਸ ਅੱਗੇ ਆਪਣਾ ਆਪ ਅਨੇਕਾਂ ਵਾਰੀ ਭੇਟ ਕਰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "освобождение само бесчисленное множество раз приносит себя ему в дар. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14912,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਕਹੁ ਰਾਮ ਭਰੋਸਾ ਤੋਰਾ ॥",
          "roman": "Ab kaho rām bharosā torā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਕਬੀਰ! ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਹੁਣ ਆਖ-ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਇਕ ਤੇਰਾ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Теперь скажи: о Господь! У того человека, у которого опора только на Тебя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14913,
          "is_rahao": true,
          "gurmukhi": "ਤਬ ਕਾਹੂ ਕਾ ਕਵਨੁ ਨਿਹੋਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Tab kāhū kā kavan nihorā ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹੁਣ ਕਿਸੇ ਦੀ ਖ਼ੁਸ਼ਾਮਦ (ਕਰਨ ਦੀ ਲੋੜ) ਨਹੀਂ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "уже нет нужды угождать кому бы то ни было. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14914,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨਿ ਲੋਕ ਜਾ ਕੈ ਹਹਿ ਭਾਰ ॥",
          "roman": "Tīn lok jā kē heh bhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਦੇ ਆਸਰੇ ਤ੍ਰੈਵੇ ਲੋਕ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "На опоре того Господа держатся три мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14915,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਾਹੇ ਨ ਕਰੈ ਪ੍ਰਤਿਪਾਰ ॥੨॥",
          "roman": "So kāhe na karē pratipār ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਤੇਰੀ) ਪਾਲਣਾ ਕਿਉਂ ਨ ਕਰੇਗਾ? ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так разве Он не позаботится о тебе? ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14916,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਇਕ ਬੁਧਿ ਬੀਚਾਰੀ ॥",
          "roman": "Kaho Kabīr ik budh bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਅਸਾਂ ਇਕ ਸੋਚ ਸੋਚੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я обдумал одну мысль;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14917,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਬਸੁ ਜਉ ਬਿਖੁ ਦੇ ਮਹਤਾਰੀ ॥੩॥੨੨॥",
          "roman": "Kiā bas jau bikh de mahtārī ॥3॥22॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਇਹ ਹੈ ਕਿ) ਜੇ ਮਾਂ ਹੀ ਜ਼ਹਿਰ ਦੇਣ ਲੱਗੇ ਤਾਂ (ਪੁੱਤਰ ਦਾ) ਕੋਈ ਜ਼ੋਰ ਨਹੀਂ ਚੱਲ ਸਕਦਾ ॥੩॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "она такова: если сама мать станет давать яд, тогда у сына уже никакой силы не останется. ॥3॥22॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1307,
      "rahao_verse_id": 14922,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14918,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14919,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਤ ਸਤੀ ਹੋਇ ਕੈਸੇ ਨਾਰਿ ॥",
          "roman": "Bin sat satī hoi kēse nār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਲਾ ਸਤਿ-ਧਰਮ ਤੋਂ ਬਿਨਾ ਕੋਈ ਇਸਤ੍ਰੀ ਸਤੀ ਕਿਵੇਂ ਬਣ ਸਕਦੀ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Разве может женщина стать верной супругой без истины-дхармы?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14920,
          "is_rahao": false,
          "gurmukhi": "ਪੰਡਿਤ ਦੇਖਹੁ ਰਿਦੈ ਬੀਚਾਰਿ ॥੧॥",
          "roman": "Paṇḍit dekhah ridē bīchār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਮਨ ਵਿਚ ਵਿਚਾਰ ਕੇ ਵੇਖ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О пандит! Вглядись, размышляя в сердце. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14921,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰੀਤਿ ਬਿਨਾ ਕੈਸੇ ਬਧੈ ਸਨੇਹੁ ॥",
          "roman": "Prīt binā kēse badhē saneh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸੇ ਤਰ੍ਹਾਂ ਹਿਰਦੇ ਵਿਚ) ਪ੍ਰੀਤ ਤੋਂ ਬਿਨਾ (ਪ੍ਰਭੂ-ਪਤੀ ਨਾਲ) ਪਿਆਰ ਕਿਵੇਂ ਬਣ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Точно так же без любви как может возникнуть привязанность к Господу-Супругу?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14922,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਲਗੁ ਰਸੁ ਤਬ ਲਗੁ ਨਹੀ ਨੇਹੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Jab lag ras tab lag nahī neh ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਾਈਂ (ਮਨ ਵਿਚ) ਮਾਇਆ ਦਾ ਚਸਕਾ ਹੈ, ਤਦ ਤਾਈਂ (ਪਤੀ ਪਰਮਾਤਮਾ ਨਾਲ) ਪਿਆਰ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Пока в уме есть вкус к майе, до тех пор не может быть любви к Супругу-Параматме. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14923,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਨਿ ਸਤੁ ਕਰੈ ਜੀਅ ਅਪਨੈ ॥",
          "roman": "Sāhan sat karē jīa apnē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਮਾਇਆ ਨੂੰ ਹੀ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਸੱਤ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который считает майю истинной в своём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14924,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਰਮਯੇ ਕਉ ਮਿਲੈ ਨ ਸੁਪਨੈ ॥੨॥",
          "roman": "So ramye kau milē na supnē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਨੂੰ ਸੁਪਨੇ ਵਿਚ ਭੀ (ਭਾਵ, ਕਦੇ ਭੀ) ਨਹੀਂ ਮਿਲ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "не может обрести Господа даже во сне, то есть никогда. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14925,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਧਨੁ ਗ੍ਰਿਹੁ ਸਉਪਿ ਸਰੀਰੁ ॥",
          "roman": "Tan man dhan grih saup sarīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਆਪਣਾ ਤਨ, ਮਨ, ਧਨ, ਘਰ ਤੇ ਸਰੀਰ (ਆਪਣੇ ਪਤੀ ਦੇ) ਹਵਾਲੇ ਕਰ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Та, что вручает своё тело, ум, богатство, дом и всё своё существо своему Супругу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14926,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਸੁਹਾਗਨਿ ਕਹੈ ਕਬੀਰੁ ॥੩॥੨੩॥",
          "roman": "Soī suhāgan kahē Kabīr ॥3॥23॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ-ਉਹੋ (ਜੀਵ-) ਇਸਤ੍ਰੀ ਭਾਗਾਂ ਵਾਲੀ ਹੈ ॥੩॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "о ней Кабир говорит: именно она и есть счастливая невеста-душа. ॥3॥23॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1308,
      "rahao_verse_id": 14931,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14927,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14928,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਿਆ ਬਿਆਪਿਆ ਸਗਲ ਸੰਸਾਰੁ ॥",
          "roman": "Bikhiā biāpiā sagal sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰਾ ਜਹਾਨ ਹੀ ਮਾਇਆ (ਦੇ ਪ੍ਰਭਾਵ) ਨਾਲ ਨੱਪਿਆ ਹੋਇਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Весь мир охвачен влиянием майи;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14929,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਿਆ ਲੈ ਡੂਬੀ ਪਰਵਾਰੁ ॥੧॥",
          "roman": "Bikhiā lē ḍūbī parvār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਸਾਰੇ ਹੀ ਕਟੁੰਬ ਨੂੰ (ਸਾਰੇ ਹੀ ਜੀਵਾਂ ਨੂੰ) ਡੋਬੀ ਬੈਠੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "майя уже утопила всё семейство, то есть всех существ. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14930,
          "is_rahao": true,
          "gurmukhi": "ਰੇ ਨਰ ਨਾਵ ਚਉੜਿ ਕਤ ਬੋੜੀ ॥",
          "roman": "Re nar nāv chauṛ kat boṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨੁੱਖ! ਤੂੰ (ਆਪਣੀ ਜ਼ਿੰਦਗੀ ਦੀ) ਬੇੜੀ ਕਿਉਂ ਰੜੇ ਥਾਂ ਤੇ ਹੀ ਡੋਬ ਲਈ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "О человек! Зачем ты утопил лодку своей жизни прямо на мелком месте?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14931,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਸਿਉ ਤੋੜਿ ਬਿਖਿਆ ਸੰਗਿ ਜੋੜੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Har siu toṛ bikhīā sang joṛī ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਪ੍ਰਭੂ ਨਾਲੋਂ ਪ੍ਰੀਤ ਤੋੜ ਕੇ ਮਾਇਆ ਨਾਲ ਗੰਢੀ ਬੈਠਾ ਹੈਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Ты порвал любовь с Господом и связал себя с майей. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14932,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਿ ਨਰ ਦਾਧੇ ਲਾਗੀ ਆਗਿ ॥",
          "roman": "Sur nar dādhe lāgī āg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਰੇ ਜਗਤ ਵਿਚ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਲੱਗੀ ਹੋਈ ਹੈ (ਜਿਸ ਵਿਚ) ਦੇਵਤੇ ਤੇ ਮਨੁੱਖ ਸੜ ਰਹੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Во всём мире пылает огонь жажды майи, в котором горят и боги, и люди."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14933,
          "is_rahao": false,
          "gurmukhi": "ਨਿਕਟਿ ਨੀਰੁ ਪਸੁ ਪੀਵਸਿ ਨ ਝਾਗਿ ॥੨॥",
          "roman": "Nikaṭ nīr pas pīvas na jhāg ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਅੱਗ ਨੂੰ ਸ਼ਾਂਤ ਕਰਨ ਲਈ ਨਾਮ-ਰੂਪ) ਪਾਣੀ ਭੀ ਨੇੜੇ ਹੀ ਹੈ, ਪਰ (ਇਹ) ਪਸ਼ੂ (ਜੀਵ) ਉੱਦਮ ਕਰ ਕੇ ਪੀਂਦਾ ਨਹੀਂ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Чтобы погасить этот огонь, рядом есть вода-Имя, но это животное-существо не делает усилия и не пьёт её. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14934,
          "is_rahao": false,
          "gurmukhi": "ਚੇਤਤ ਚੇਤਤ ਨਿਕਸਿਓ ਨੀਰੁ ॥",
          "roman": "Chetat chetat niksio nīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਨਾਮ-ਰੂਪ) ਪਾਣੀ ਸਿਮਰਨ ਕਰਦਿਆਂ ਕਰਦਿਆਂ ਹੀ (ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਪਰਗਟ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Та вода-Имя проявляется в сердце человека именно через постоянное памятование."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14935,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਲੁ ਨਿਰਮਲੁ ਕਥਤ ਕਬੀਰੁ ॥੩॥੨੪॥",
          "roman": "So jal nirmal kathat Kabīr ॥3॥24॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਉਹ (ਅੰਮ੍ਰਿਤ-) ਜਲ ਪਵਿੱਤਰ ਹੁੰਦਾ ਹੈ, (ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਉਸੇ ਜਲ ਨਾਲ ਬੁਝ ਸਕਦੀ ਹੈ) ॥੩॥੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: та вода, амритная вода, чиста; только ею и может быть потушен огонь жажды. ॥3॥24॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1309,
      "rahao_verse_id": 14940,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14936,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14937,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਕੁਲਿ ਪੂਤੁ ਨ ਗਿਆਨ ਬੀਚਾਰੀ ॥",
          "roman": "Jih kul pūt na giān bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਕੁਲ ਵਿਚ ਗਿਆਨ ਦੀ ਵਿਚਾਰ ਕਰਨ ਵਾਲਾ (ਕੋਈ) ਪੁੱਤਰ ਨਹੀਂ (ਜੰਮਿਆ),"
            },
            "sahib_singh_ru": {
              "main": "В том роду, где не родился сын, размышляющий о знании,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14938,
          "is_rahao": false,
          "gurmukhi": "ਬਿਧਵਾ ਕਸ ਨ ਭਈ ਮਹਤਾਰੀ ॥੧॥",
          "roman": "Bidhvā kas na bhaī mahtārī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਮਾਂ ਰੰਡੀ ਕਿਉਂ ਨ ਹੋ ਗਈ? ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "почему его мать не стала вдовой? ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14939,
          "is_rahao": true,
          "gurmukhi": "ਜਿਹ ਨਰ ਰਾਮ ਭਗਤਿ ਨਹਿ ਸਾਧੀ ॥",
          "roman": "Jih nar rām bhagat nah sādhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਪ੍ਰਭੂ ਦੀ ਬੰਦਗ਼ੀ ਨਹੀਂ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который не совершал поклонения Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14940,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮਤ ਕਸ ਨ ਮੁਓ ਅਪਰਾਧੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Janmat kas na muo aprādhī ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਅਪਰਾਧੀ ਜੰਮਦਾ ਹੀ ਕਿਉਂ ਨਹੀਂ ਮਰ ਗਿਆ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "почему этот преступный не умер сразу при рождении? ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14941,
          "is_rahao": false,
          "gurmukhi": "ਮੁਚੁ ਮੁਚੁ ਗਰਭ ਗਏ ਕੀਨ ਬਚਿਆ ॥",
          "roman": "Much much garabh gae kīn bachiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਸਾਰ ਵਿਚ) ਕਈ ਗਰਭ ਛਣ ਗਏ ਹਨ, ਇਹ (ਬੰਦਗੀ-ਹੀਣ ਚੰਦਰਾ) ਕਿਉਂ ਬਚ ਰਿਹਾ?"
            },
            "sahib_singh_ru": {
              "main": "В мире столько утроб оказалось опустошено, почему же этот, лишённый бхагти, уцелел?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14942,
          "is_rahao": false,
          "gurmukhi": "ਬੁਡਭੁਜ ਰੂਪ ਜੀਵੇ ਜਗ ਮਝਿਆ ॥੨॥",
          "roman": "Buḍbhuj rūp jīve jag majhiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬੰਦਗੀ ਤੋਂ ਸੱਖਣਾ ਇਹ) ਜਗਤ ਵਿਚ ਇਕ ਕੋੜ੍ਹੀ ਜੀਊ ਰਿਹਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Лишённый поклонения, он живёт в мире, словно прокажённый. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14943,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜੈਸੇ ਸੁੰਦਰ ਸਰੂਪ ॥ ਨਾਮ ਬਿਨਾ ਜੈਸੇ ਕੁਬਜ ਕੁਰੂਪ ॥੩॥੨੫॥",
          "roman": "Kaho Kabīr jēse sundar sarūp ॥ nām binā jēse kubaj kurūp ॥3॥25॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਜੋ ਮਨੁੱਖ ਨਾਮ ਤੋਂ ਸੱਖਣੇ ਹਨ, ਉਹ (ਭਾਵੇਂ ਵੇਖਣ ਨੂੰ) ਸੋਹਣੇ ਰੂਪ ਵਾਲੇ ਹਨ ਪਰ ਨਾਮ ਤੋਂ ਸੱਖਣੇ (ਅਸਲ ਵਿਚ) ਕੁੱਬੇ ਤੇ ਬਦ-ਸ਼ਕਲ ਹਨ ॥੩॥੨੫॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: те люди, что лишены Имени, пусть даже на вид красивы, но без Имени они на самом деле горбаты и безобразны. ॥3॥25॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1310,
      "rahao_verse_id": 14947,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14944,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14945,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨ ਲੇਹਿ ਖਸਮ ਕਾ ਨਾਉ ॥ ਤਿਨ ਕੈ ਸਦ ਬਲਿਹਾਰੈ ਜਾਉ ॥੧॥",
          "roman": "Jo jan leh khasam kā nāu ॥ tin kē sad balihārē jāu ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਮਾਲਕ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ, ਮੈਂ ਸਦਾ ਉਹਨਾਂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые повторяют Имя Господа-Владыки, я всегда иду отдать себя за них. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14946,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਨਿਰਮਲੁ ਨਿਰਮਲ ਹਰਿ ਗੁਨ ਗਾਵੈ ॥",
          "roman": "So nirmal nirmal har guṇ gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਵੀਰ ਪ੍ਰਭੂ ਦੇ ਸੁਹਣੇ (ਨਿਰਮਲ) ਗੁਣ ਗਾਂਦਾ ਹੈ, ਉਹ ਪਵਿੱਤਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, что поёт прекрасные, чистые качества Господа, сам чист,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14947,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਭਾਈ ਮੇਰੈ ਮਨਿ ਭਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "So bhāī merē man bhāvē ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਉਹ ਮੇਰੇ ਮਨ ਵਿਚ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и он дорог моему сердцу. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14948,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਘਟ ਰਾਮੁ ਰਹਿਆ ਭਰਪੂਰਿ ॥ ਤਿਨ ਕੀ ਪਗ ਪੰਕਜ ਹਮ ਧੂਰਿ ॥੨॥",
          "roman": "Jih ghaṭ rām rahiā bharpūr ॥ tin kī pag pankaj ham dhūr ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਹਿਰਦਿਆਂ ਵਿਚ ਪ੍ਰਭੂ ਪਰਗਟ ਹੋ ਗਿਆ ਹੈ, ਉਹਨਾਂ ਦੇ ਕੌਲ ਫੁੱਲ ਵਰਗੇ (ਸੁਹਣੇ) ਚਰਨਾਂ ਦੀ ਅਸੀਂ ਧੂੜ ਹਾਂ (ਭਾਵ, ਚਰਨਾਂ ਤੋਂ ਸਦਕੇ ਹਾਂ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тех людей, в чьих сердцах Господь открылся во всей полноте, мы считаем себя пылью у их прекрасных, как лотос, стоп. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14949,
          "is_rahao": false,
          "gurmukhi": "ਜਾਤਿ ਜੁਲਾਹਾ ਮਤਿ ਕਾ ਧੀਰੁ ॥",
          "roman": "Jāt julāhā mat kā dhīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਭਾਵੇਂ ਜਾਤ ਦਾ ਜੁਲਾਹਾ ਹੈ, ਪਰ ਮੱਤ ਦਾ ਧੀਰਜ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир хоть и ткач по касте, но в уме обладает стойкостью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14950,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਸਹਜਿ ਗੁਣ ਰਮੈ ਕਬੀਰੁ ॥੩॥੨੬॥",
          "roman": "Sahaj sahaj guṇ ramē Kabīr ॥3॥26॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਅਡੋਲਤਾ ਵਿਚ ਰਹਿ ਕੇ (ਪ੍ਰਭੂ ਦੇ) ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੩॥੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "потому что в устойчивости и естественной уравновешенности поёт качества Господа. ॥3॥26॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1311,
      "rahao_verse_id": 14955,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 14951,
          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14952,
          "is_rahao": false,
          "gurmukhi": "ਗਗਨਿ ਰਸਾਲ ਚੁਐ ਮੇਰੀ ਭਾਠੀ ॥",
          "roman": "Gagan rasāl chuaī merī bhāṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀ ਗਗਨ-ਰੂਪ ਭੱਠੀ ਵਿਚੋਂ ਸੁਆਦਲਾ ਅੰਮ੍ਰਿਤ ਚੋ ਰਿਹਾ ਹੈ (ਭਾਵ, ਜਿਉਂ ਜਿਉਂ ਮੇਰਾ ਮਨ ਪ੍ਰਭੂ ਦੀ ਯਾਦ ਵਿਚ ਜੁੜਦਾ ਹੈ, ਉਸ ਯਾਦ ਵਿਚ ਜੁੜੇ ਰਹਿਣ ਦੀ ਇਕ-ਤਾਰ ਲਗਨ, ਮਾਨੋ, ਅੰਮ੍ਰਿਤ ਦੀ ਧਾਰ ਨਿਕਲਣੀ ਸ਼ੁਰੂ ਹੋ ਜਾਂਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Из моей печи-неба каплет сладостный амрит, то есть чем больше мой ум соединяется с памятью о Господе, тем больше начинает течь, словно струя амрита, однонаправленная жажда оставаться в этой памяти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14953,
          "is_rahao": false,
          "gurmukhi": "ਸੰਚਿ ਮਹਾ ਰਸੁ ਤਨੁ ਭਇਆ ਕਾਠੀ ॥੧॥",
          "roman": "Sanch mahā ras tan bhaiā kāṭhī ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਉੱਚੇ ਨਾਮ-ਰਸ ਨੂੰ ਇਕੱਠਾ ਕਰਨ ਕਰਕੇ ਸਰੀਰ (ਦੀ ਮਮਤਾ) ਲੱਕੜੀਆਂ ਦਾ ਕੰਮ ਦੇ ਰਹੀ ਹੈ (ਭਾਵ, ਸਰੀਰ ਦੀ ਮਮਤਾ ਸੜ ਗਈ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и от собирания этого высокого нектара Имени тело, то есть привязанность к телу, стало дровами, то есть сгорело. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14954,
          "is_rahao": true,
          "gurmukhi": "ਉਆ ਕਉ ਕਹੀਐ ਸਹਜ ਮਤਵਾਰਾ ॥",
          "roman": "Uā kau kahīai sahaj matvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕੁਦਰਤੀ ਤੌਰ ਤੇ (ਭਾਵ, ਸੁਭਾਵਿਕ ਹੀ) ਮਸਤ ਹੋਇਆ ਹੋਇਆ ਆਖੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его и называют естественно, по самой природе, опьянённым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14955,
          "is_rahao": true,
          "gurmukhi": "ਪੀਵਤ ਰਾਮ ਰਸੁ ਗਿਆਨ ਬੀਚਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Pīvat rām ras giān bīchārā ॥1॥ rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗਿਆਨ ਦੇ ਵਿਚਾਰ ਦੀ ਰਾਹੀਂ (ਭਾਵ, ਸੁਰਤ ਮਾਇਆ ਤੋਂ ਉੱਚੀ ਕਰ ਕੇ) ਰਾਮ-ਰਸ ਪੀਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "того человека, который через размышление знания, то есть подняв сознание выше майи, выпил нектар Рама. ॥1॥ Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14956,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਕਲਾਲਨਿ ਜਉ ਮਿਲਿ ਆਈ ॥",
          "roman": "Sahaj kalālan jau mil āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਸਹਿਜ ਅਵਸਥਾ-ਰੂਪ ਸ਼ਰਾਬ ਪਿਲਾਉਣ ਵਾਲੀ ਆ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда приходит виночерпица в образе состояния сахадж,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14957,
          "is_rahao": false,
          "gurmukhi": "ਆਨੰਦਿ ਮਾਤੇ ਅਨਦਿਨੁ ਜਾਈ ॥੨॥",
          "roman": "Ānand māte andin jāī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਅਨੰਦ ਵਿਚ ਮਸਤ ਹੋ ਕੇ (ਉਮਰ ਦਾ) ਹਰੇਕ ਦਿਨ ਬੀਤਦਾ ਹੈ (ਭਾਵ, ਨਾਮ ਸਿਮਰਦਿਆਂ ਮਨ ਵਿਚ ਇਕ ਐਸੀ ਹਾਲਤ ਪੈਦਾ ਹੁੰਦੀ ਹੈ ਜਿੱਥੇ ਮਨ ਮਾਇਆ ਦੇ ਝਕੋਲਿਆਂ ਵਿਚ ਡੋਲਦਾ ਨਹੀਂ। ਇਸ ਹਾਲਤ ਨੂੰ ਸਹਿਜ ਅਵਸਥਾ ਕਹੀਦਾ ਹੈ; ਇਹ ਸਹਿਜ ਅਵਸਥਾ, ਮਾਨੋ, ਇਕ ਕਲਾਲਣ ਹੈ, ਜੋ ਨਾਮ ਦਾ ਨਸ਼ਾ ਦੇਈ ਜਾਂਦੀ ਹੈ; ਇਸ ਨਸ਼ੇ ਤੋਂ ਵਿਛੜਨ ਨੂੰ ਚਿੱਤ ਨਹੀਂ ਕਰਦਾ, ਤੇ ਮੁੜ ਮੁੜ ਨਾਮ ਦੀ ਲਿਵ ਵਿਚ ਹੀ ਟਿਕੇ ਰਹੀਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тогда каждый день проходит в опьянении блаженством. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14958,
          "is_rahao": false,
          "gurmukhi": "ਚੀਨਤ ਚੀਤੁ ਨਿਰੰਜਨ ਲਾਇਆ ॥",
          "roman": "Chīnat chīt niranjan lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਆਨੰਦ ਮਾਣ ਮਾਣ ਕੇ ਜਦੋਂ ਮੈਂ ਆਪਣਾ ਮਨ ਨਿਰੰਕਾਰ ਨਾਲ ਜੋੜਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Так, наслаждаясь этим блаженством, я соединил свой ум с Ниранкаром,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 14959,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਤੌ ਅਨਭਉ ਪਾਇਆ ॥੩॥੨੭॥",
          "roman": "Kaho Kabīr tau anbhau pāiā ॥3॥27॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਤਾਂ ਮੈਨੂੰ ਅੰਦਰਲਾ ਚਾਨਣ ਲੱਭ ਪਿਆ ॥੩॥੨੭॥"
            },
            "sahib_singh_ru": {
              "main": "и тогда, говорит Кабир, я обрёл внутренний свет. ॥3॥27॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
