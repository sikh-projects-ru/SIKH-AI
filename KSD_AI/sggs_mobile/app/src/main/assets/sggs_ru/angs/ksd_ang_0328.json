          "is_rahao": false,
          "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "Gauṛī Kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
