            }
          }
        },
        {
          "verse_id": 14961,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਸੁਭਾਉ ਮਨਹਿ ਬਿਆਪੀ ॥",
          "roman": "Man kā subhāu maneh biāpī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰੇਕ ਮਨੁੱਖ ਦੇ) ਮਨ ਦੀ ਅੰਦਰਲੀ ਲਗਨ (ਜੋ ਭੀ ਹੋਵੇ ਉਹ ਉਸ ਮਨੁੱਖ ਦੇ) ਸਾਰੇ ਮਨ (ਭਾਵ, ਮਨ ਦੀ ਸਾਰੀ ਦੌੜ-ਭੱਜ, ਸਾਰੇ ਮਨੁੱਖੀ ਜੀਵਨ) ਉਤੇ ਪ੍ਰਭਾਵ ਪਾ ਰੱਖਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутренняя склонность ума каждого человека, какой бы она ни была, оказывает влияние на весь его ум, то есть на всю его жизненную деятельность,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
