{
  "ang": 362,
  "shabads": [
    {
      "shabad_id": 1412,
      "rahao_verse_id": 16468,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 16467,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਮਨਿ ਰਾਤੇ ਹਰਿ ਰੰਗੁ ਲਾਇ ॥",
          "roman": "jo man rāte har rang lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਪ੍ਰੇਮ-ਰੰਗ ਵਰਤ ਵਰਤ ਕੇ ਆਪਣੇ ਮਨ ਵਿਚ (ਪ੍ਰੇਮ-ਰੰਗ ਨਾਲ) ਰੰਗੇ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, те люди, которые вновь и вновь употребляют любовный цвет Бога и окрашиваются им в своём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16468,
          "is_rahao": true,
          "gurmukhi": "ਤਿਨ ਕਾ ਜਨਮ ਮਰਣ ਦੁਖੁ ਲਾਥਾ ਤੇ ਹਰਿ ਦਰਗਹ ਮਿਲੇ ਸੁਭਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tin kā janam maraṇ dukh lāthā te har dargeh milē subhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਦਾ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦਾ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਪ੍ਰੇਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "У тех исчезает страдание круга рождения и смерти, и по благодати любви они пребывают в присутствии Бога. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16469,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਚਾਖੈ ਸਾਚਾ ਸਾਦੁ ਪਾਏ ॥",
          "roman": "sabad chākhē sāchā sād pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦਾ ਰਸ ਚੱਖਦਾ ਹੈ, ਉਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ (ਆਤਮਕ) ਆਨੰਦ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, кто вкушает вкус Шабада Гуру, тот наслаждается вечным духовным блаженством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16470,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਮੰਨਿ ਵਸਾਏ ॥",
          "roman": "har kā nām mann vasāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨੂੰ (ਸਦਾ ਆਪਣੇ) ਮਨ ਵਿਚ ਵਸਾਈ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Потому что он всегда сохраняет Имя Бога в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16471,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪ੍ਰਭੁ ਸਦਾ ਰਹਿਆ ਭਰਪੂਰਿ ॥",
          "roman": "har prabh sadā rahiā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਫਿਰ ਪ੍ਰਤੱਖ ਇਉਂ ਦਿੱਸਦਾ ਹੈ ਕਿ) ਪਰਮਾਤਮਾ ਸਦਾ ਹਰ ਥਾਂ ਵਿਆਪ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тогда ему становится ясно видно, что Бог всегда полностью наполняет всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16472,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਨੇੜੈ ਆਪੇ ਦੂਰਿ ॥੨॥",
          "roman": "āpē nēṛē āpē dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ (ਹਰੇਕ ਜੀਵ ਦੇ) ਅੰਗ-ਸੰਗ ਹੈ ਤੇ ਆਪ ਹੀ ਦੂਰ (ਅਪਹੁੰਚ) ਭੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он Сам рядом с каждым существом и Сам же далёк, недостижим. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16473,
          "is_rahao": false,
          "gurmukhi": "ਆਖਣਿ ਆਖੈ ਬਕੈ ਸਭੁ ਕੋਇ ॥",
          "roman": "ākhaṇ ākhē bakē sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਰਿਵਾਜੀ ਤੌਰ ਤੇ ਹਰੇਕ ਮਨੁੱਖ ਆਖਦਾ ਹੈ, ਸੁਣਾਂਦਾ ਹੈ ਕਿ (ਪਰਮਾਤਮਾ) ਹਰੇਕ ਦੇ ਨੇੜੇ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, по обычаю каждый человек говорит и повторяет, что Бог обитает рядом со всеми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16474,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਬਖਸਿ ਮਿਲਾਏ ਸੋਇ ॥",
          "roman": "āpē bakhas milāē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਿਸ ਕਿਸੇ ਨੂੰ ਉਹ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਮਿਲਾਂਦਾ ਹੈ, ਉਹ ਆਪ ਹੀ ਮੇਹਰ ਕਰ ਕੇ ਮਿਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но кого Он соединяет со Своими стопами, того Сам по милости и соединяет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16475,
          "is_rahao": false,
          "gurmukhi": "ਕਹਣੈ ਕਥਨਿ ਨ ਪਾਇਆ ਜਾਇ ॥",
          "roman": "kahaṇē kathan na pāiā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜ਼ਬਾਨੀ ਆਖਣ ਨਾਲ ਗੱਲਾਂ ਕਰਨ ਨਾਲ ਪਰਮਾਤਮਾ ਮਿਲਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Одними словами и разговорами Бога не обрести."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16476,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਵਸੈ ਮਨਿ ਆਇ ॥੩॥",
          "roman": "gur parsād vasē man āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру Он приходит и поселяется в уме. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16477,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਵਿਚਹੁ ਆਪੁ ਗਵਾਇ ॥",
          "roman": "gurmukh vichah āp gavāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, обращённый к Гуру, удаляет изнутри себя эго-чувство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16478,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰੰਗਿ ਰਾਤੇ ਮੋਹੁ ਚੁਕਾਇ ॥",
          "roman": "har rang rāte moh chukāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗੀਜ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦਾ) ਮੋਹ ਮੁਕਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И, окрасившись в любовный цвет Бога, устраняет из себя привязанность к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16479,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਨਿਰਮਲੁ ਗੁਰ ਸਬਦ ਵੀਚਾਰ ॥",
          "roman": "at nirmal gur sabad vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਵਿਚਾਰ ਮਨੁੱਖ ਨੂੰ ਬਹੁਤ ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲਾ ਬਣਾ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Размышление над Шабадом Гуру делает человека обладателем очень чистой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16480,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਸਵਾਰਣਹਾਰ ॥੪॥੪॥੪੩॥",
          "roman": "nānak nām savāraṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ-ਨਾਮ ਵਿਚ ਜੁੜ ਕੇ ਮਨੁੱਖ ਹੋਰਨਾਂ ਦਾ ਜੀਵਨ ਸੰਵਾਰਨ ਜੋਗਾ ਭੀ ਹੋ ਜਾਂਦਾ ਹੈ ॥੪॥੪॥੪੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, соединившись с Именем Бога, человек становится способным устраивать и жизнь других. ॥4॥4॥43॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1413,
      "rahao_verse_id": 16487,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 16481,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੩ ॥",
          "roman": "āsā mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16482,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਲਗੇ ਦੁਖੁ ਪਾਇਆ ॥",
          "roman": "dūjē bhāy lage dukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਛੱਡ ਕੇ) ਕਿਸੇ ਹੋਰ ਦੇ ਪਿਆਰ ਵਿਚ ਮੱਤੇ ਰਹਿੰਦੇ ਹਨ ਉਹਨਾਂ ਨੇ ਦੁੱਖ ਹੀ ਦੁੱਖ ਸਹੇੜਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто, оставив Бога, опьянены любовью к иному, набрали себе одни лишь страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16483,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਬਿਰਥਾ ਜਨਮੁ ਗਵਾਇਆ ॥",
          "roman": "bin sabdē birthā janam gavāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਤੋਂ ਵਾਂਜੇ ਰਹਿ ਕੇ ਉਹਨਾਂ ਆਪਣੀ ਜ਼ਿੰਦਗੀ ਵਿਅਰਥ ਗਵਾ ਲਈ।"
            },
            "sahib_singh_ru": {
              "main": "оставшись без Шабда Гуру, они напрасно растратили свою жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16484,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵੈ ਸੋਝੀ ਹੋਇ ॥",
          "roman": "satgur sevē sojhī hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕੋਈ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਦੱਸੇ ਰਾਹ ਉਤੇ ਤੁਰਦਾ ਹੈ ਉਸ ਨੂੰ (ਸਹੀ ਜੀਵਨ ਦੀ) ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт по пути, указанному Гуру, обретает понимание правильной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16485,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਨ ਲਾਗੈ ਕੋਇ ॥੧॥",
          "roman": "dūjē bhāy na lāgē koi. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਫਿਰ ਮਾਇਆ ਦੇ ਪਿਆਰ ਵਿਚ ਨਹੀਂ ਲੱਗਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и тогда уже не привязывается к любви майи. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16486,
          "is_rahao": true,
          "gurmukhi": "ਮੂਲਿ ਲਾਗੇ ਸੇ ਜਨ ਪਰਵਾਣੁ ॥",
          "roman": "mūl lāge se jan parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜੇਹੜੇ ਮਨੁੱਖ) ਜਗਤ ਦੇ ਰਚਨਹਾਰ ਪਰਮਾਤਮਾ (ਦੀ ਯਾਦ) ਵਿਚ ਜੁੜਦੇ ਹਨ, ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые соединяются с Памятью о Боге, Творце мира, становятся принятыми в Его глазах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16487,
          "is_rahao": true,
          "gurmukhi": "ਅਨਦਿਨੁ ਰਾਮ ਨਾਮੁ ਜਪਿ ਹਿਰਦੈ ਗੁਰ ਸਬਦੀ ਹਰਿ ਏਕੋ ਜਾਣੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "andin rām nām jap hirdē gur sabdī har eko jāṇ. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹਰ ਵੇਲੇ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਜਪ ਕੇ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Бога всегда в своём сердце, человек по милости Шабда Гуру вступает в глубокую связь с единым Богом. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16488,
          "is_rahao": false,
          "gurmukhi": "ਡਾਲੀ ਲਾਗੈ ਨਿਹਫਲੁ ਜਾਇ ॥",
          "roman": "ḍālī lāgē nihphal jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਜਗਤ ਦੇ ਮੂਲ-ਪ੍ਰਭੂ-ਰੁੱਖ ਨੂੰ ਛੱਡ ਕੇ ਉਸ ਦੀ ਰਚੀ ਮਾਇਆ-ਰੂਪ) ਟਹਣੀ ਨੂੰ ਚੰਬੜਿਆ ਰਹਿੰਦਾ ਹੈ ਉਹ ਅੱਫਲ ਹੀ ਜਾਂਦਾ ਹੈ (ਜੀਵਨ-ਫਲ ਪ੍ਰਾਪਤ ਨਹੀਂ ਕਰ ਸਕਦਾ।)"
            },
            "sahib_singh_ru": {
              "main": "Кто, оставив дерево-Господа, корень мира, цепляется за ветвь, то есть за созданную Им майю, тот уходит бесплодным, не получив плода жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16489,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਂੀ ਕੰਮੀ ਅੰਧ ਸਜਾਇ ॥",
          "roman": "andhīṃ kammī andh sajāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇ-ਸਮਝੀ ਦੇ ਕੰਮਾਂ ਵਿਚ ਪੈ ਕੇ-"
            },
            "sahib_singh_ru": {
              "main": "Впав в дела безрассудства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16490,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖੁ ਅੰਧਾ ਠਉਰ ਨ ਪਾਇ ॥",
          "roman": "manmukh andhā ṭhauṛ na pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ) ਅੰਨ੍ਹਾ ਹੋਇਆ ਮਨੁੱਖ (ਮਾਇਆ ਦੀ ਭਟਕਣਾ ਤੋਂ ਬਚਣ ਦਾ) ਟਿਕਾਣਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "ослеплённый майей человек не может найти прибежища, где можно было бы спастись от блуждания в майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16491,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸਟਾ ਕਾ ਕੀੜਾ ਬਿਸਟਾ ਮਾਹਿ ਪਚਾਇ ॥੨॥",
          "roman": "bisṭā kā kīṛā bisṭā māhi pachāi. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਇਉਂ ਹੀ) ਖ਼ੁਆਰ ਹੁੰਦਾ ਹੈ (ਜਿਵੇਂ) ਗੰਦ ਦਾ ਕੀੜਾ ਗੰਦ ਵਿਚ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он так и гибнет в привязанности к майе, как червь в нечистотах. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16492,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੇਵਾ ਸਦਾ ਸੁਖੁ ਪਾਏ ॥",
          "roman": "gur kī sevā sadā sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਦੱਸੀ ਸੇਵਾ ਕਰਦਾ ਹੈ ਉਹ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто совершает служение, указанное Гуру, всегда вкушает духовную радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16493,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਤਿ ਮਿਲਿ ਹਰਿ ਗੁਣ ਗਾਏ ॥",
          "roman": "santsangat mil har guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਉਹ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ (ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "потому что, встретившись с Сангатом святых, он воспевает качества Бога, возносит Ему хвалу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16494,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਨਾਮਿ ਕਰੇ ਵੀਚਾਰੁ ॥",
          "roman": "nāme nām kre vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜ ਕੇ (ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦੀ) ਵਿਚਾਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он всегда, соединившись с Именем Бога, размышляет о Его качествах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16495,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਤਰੈ ਕੁਲ ਉਧਰਣਹਾਰੁ ॥੩॥",
          "roman": "āp tarē kul udharaṇhār. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਉਹ ਆਪ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ਤੇ ਆਪਣੀਆਂ ਕੁਲਾਂ ਨੂੰ ਪਾਰ ਲੰਘਾਣ ਜੋਗਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Так он сам переправляется через океан мира и становится способным переправить свои роды. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16496,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਬਾਣੀ ਨਾਮਿ ਵਜਾਏ ॥",
          "roman": "gur kī bāṇī nām vajāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜ ਕੇ ਜੇਹੜਾ ਮਨੁੱਖ ਸਤਿਗੁਰੂ ਦੀ ਬਾਣੀ (ਦਾ ਵਾਜਾ) ਵਜਾਂਦਾ ਹੈ (ਆਪਣੇ ਅੰਦਰ ਗੁਰੂ ਦੀ ਬਾਣੀ ਦਾ ਪੂਰਨ ਪ੍ਰਭਾਵ ਪਾਈ ਰੱਖਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Соединившись с Именем Бога, тот человек, который играет на инструменте Бани Сатгуру, то есть удерживает внутри себя полное воздействие Бани Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16497,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਹਲੁ ਸਬਦਿ ਘਰੁ ਪਾਏ ॥",
          "roman": "nānak mahal sabd ghar pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਘਰ ਮਹਲ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, по милости Шабда Гуру достигает дома-дворца у стоп Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16498,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਸਤ ਸਰਿ ਹਰਿ ਜਲਿ ਨਾਇਆ ॥",
          "roman": "gurmat sat sar har jal nāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਮਤਿ ਲੈ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੇ ਸਤਸੰਗ-ਸਰੋਵਰ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਜਲ ਨਾਲ ਇਸ਼ਨਾਨ ਕੀਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Приняв наставление Гуру, тот, кто омылся в озере Сатсанга водой Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16499,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਮੈਲੁ ਸਭੁ ਦੁਰਤੁ ਗਵਾਇਆ ॥੪॥੫॥੪੪॥",
          "roman": "durmat mēl sabh durat gavāiā. 4. 5. 44.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਭੈੜੀ ਖੋਟੀ ਮਤਿ ਦੀ ਮੈਲ ਧੋ ਲਈ ਉਸ ਨੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਸਾਰਾ ਪਾਪ ਦੂਰ ਕਰ ਲਿਆ ॥੪॥੫॥੪੪॥"
            },
            "sahib_singh_ru": {
              "main": "смыл грязь дурного ложного ума и устранил из себя весь грех. ॥4॥5॥44॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1414,
      "rahao_verse_id": 16506,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 16500,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੩ ॥",
          "roman": "āsā mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16501,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਮਰਹਿ ਮਰਿ ਮਰਣੁ ਵਿਗਾੜਹਿ ॥",
          "roman": "manmukh mareh mar maraṇ vigāṛeh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮਨੁੱਖ (ਆਤਮਕ ਮੌਤੇ) ਮਰਦੇ ਹਨ (ਇਸ ਤਰ੍ਹਾਂ) ਮਰ ਕੇ ਉਹ ਆਪਣੀ ਮੌਤ ਖ਼ਰਾਬ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Идущие за своим умом люди умирают духовной смертью, и, умирая так, они портят свою смерть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16502,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਆਤਮ ਸੰਘਾਰਹਿ ॥",
          "roman": "dūjē bhāy ātam sanghāreh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਪੈ ਕੇ ਉਹ ਆਪਣਾ ਆਤਮਕ ਜੀਵਨ ਤਬਾਹ ਕਰ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "потому что, впав в любовь к майе, они разрушают свою духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16503,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਮੇਰਾ ਕਰਿ ਕਰਿ ਵਿਗੂਤਾ ॥",
          "roman": "merā merā kar kar vigūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ (ਇਹ ਧਨ) ਮੇਰਾ ਹੈ (ਇਹ ਪਰਵਾਰਾ) ਮੇਰਾ ਹੈ-ਨਿੱਤ ਇਹੀ ਆਖ ਆਖ ਕੇ ਖ਼ੁਆਰ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Идущий за своим умом человек, повторяя: «это богатство моё», «эта семья моя», всё время так говорит и истощается,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16504,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮੁ ਨ ਚੀਨੑੈ ਭਰਮੈ ਵਿਚਿ ਸੂਤਾ ॥੧॥",
          "roman": "ātam na chīṇhē bharmāi vich sūtā. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਆਪਣੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਨਹੀਂ ਪੜਤਾਲਦਾ, ਮਾਇਆ ਦੀ ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ (ਆਤਮਕ ਜੀਵਨ) ਵਲੋਂ ਗ਼ਾਫ਼ਿਲ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "никогда не исследует свою духовную жизнь и, впав в блуждание майи, остаётся беспечным по отношению к ней. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16505,
          "is_rahao": true,
          "gurmukhi": "ਮਰੁ ਮੁਇਆ ਸਬਦੇ ਮਰਿ ਜਾਇ ॥",
          "roman": "mar muiā sabde mar jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਸੁਰਖਰੂਈ ਮੌਤ ਮਰਦਾ ਹੈ, ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਮੋਹ ਵਲੋਂ) ਅਛੋਹ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек умирает благой смертью по отношению к привязанности к майе, через Шабд Гуру остаётся незатронутым ею,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16506,
          "is_rahao": true,
          "gurmukhi": "ਉਸਤਤਿ ਨਿੰਦਾ ਗੁਰਿ ਸਮ ਜਾਣਾਈ ਇਸੁ ਜੁਗ ਮਹਿ ਲਾਹਾ ਹਰਿ ਜਪਿ ਲੈ ਜਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ustat nindā gur sam jāṇāī is jug meh lāhā har jap lē jāi. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਇਹ ਸੂਝ ਬਖ਼ਸ਼ ਦਿੱਤੀ ਹੈ, ਕਿ ਭਾਵੇਂ ਕੋਈ ਚੰਗਾ ਆਖੇ, ਕੋਈ ਮੰਦਾ ਆਖੇ, ਇਸ ਨੂੰ ਇਕੋ ਜਿਹਾ ਸਹਾਰਨਾ ਹੈ। ਉਹ ਮਨੁੱਖ ਇਸ ਜੀਵਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ (ਜਗਤ ਤੋਂ) ਖੱਟੀ ਖੱਟ ਕੇ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Кому Гуру даровал это понимание, что и похвалу, и порицание надо переносить одинаково, тот человек в этой жизни, повторяя Имя Бога, уходит, заработав истинную прибыль. ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16507,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਵਿਹੂਣ ਗਰਭ ਗਲਿ ਜਾਇ ॥",
          "roman": "nām vihūṇ garabh gal jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਤੋਂ ਵਾਂਜਿਆ ਰਹਿ ਕੇ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜਾਂ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਨਾਸ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь лишённым Имени, человек в круговороте рождений и смертей губит свою духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16508,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥਾ ਜਨਮੁ ਦੂਜੈ ਲੋਭਾਇ ॥",
          "roman": "birthā janam dūjē lobhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ (ਇਸ ਵਾਸਤੇ) ਉਸ ਦੀ ਜ਼ਿੰਦਗੀ ਵਿਅਰਥ ਚਲੀ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всегда запутанный в любви к майе, и потому его жизнь проходит напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16509,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਣੀ ਦੁਖਿ ਜਲੈ ਸਬਾਈ ॥",
          "roman": "nām bihūṇī dukh jalē sabāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਤੋਂ ਸੱਖਣੀ ਰਹਿ ਕੇ ਸਾਰੀ ਲੁਕਾਈ ਦੁੱਖ ਵਿਚ ਸੜਦੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Весь мир, оставаясь без Имени, горит в страдании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16510,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਪੂਰੈ ਬੂਝ ਬੁਝਾਈ ॥੨॥",
          "roman": "satgur pūrē būjh bujhāī. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਸਮਝ ਪੂਰੇ ਗੁਰੂ ਨੇ (ਕਿਸੇ ਵਿਰਲੇ ਨੂੰ) ਬਖ਼ਸ਼ੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Но это понимание совершенный Гуру дарует лишь редкому. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16511,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਚੰਚਲੁ ਬਹੁ ਚੋਟਾ ਖਾਇ ॥",
          "roman": "man chanchal bah choṭā khāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਹਰ ਵੇਲੇ ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਭਟਕਦਾ ਹੈ ਉਹ ਮੋਹ ਦੀਆਂ ਸੱਟਾਂ ਖਾਂਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Чей ум всё время блуждает в любви к майе, тот постоянно получает удары этой привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16512,
          "is_rahao": false,
          "gurmukhi": "ਏਥਹੁ ਛੁੜਕਿਆ ਠਉਰ ਨ ਪਾਇ ॥",
          "roman": "ethah chhuṛkiā ṭhauṛ na pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਮਨੁੱਖਾ ਜੀਵਨ ਵਿਚ (ਸਿਮਰਨ ਵਲੋਂ) ਖੁੰਝਿਆ ਹੋਇਆ ਫਿਰ ਆਤਮਕ ਆਨੰਦ ਦੀ ਥਾਂ ਨਹੀਂ ਪ੍ਰਾਪਤ ਕਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Упустив здесь, в этой человеческой жизни, путь симрана, он уже не может обрести место духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16513,
          "is_rahao": false,
          "gurmukhi": "ਗਰਭ ਜੋਨਿ ਵਿਸਟਾ ਕਾ ਵਾਸੁ ॥",
          "roman": "garabh jon visṭā kā vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ (ਮਾਨੋ) ਗੰਦ ਦਾ ਘਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Круг рождений и смертей — словно жилище нечистот,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16514,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਘਰਿ ਮਨਮੁਖੁ ਕਰੇ ਨਿਵਾਸੁ ॥੩॥",
          "roman": "tit ghar manmukh kre nivās. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਘਰ ਵਿਚ ਉਸ ਮਨੁੱਖ ਦਾ ਨਿਵਾਸ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ ਜੋ ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и именно в таком доме пребывает тот, кто следует за своим умом. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16515,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਸਤਿਗੁਰ ਕਉ ਸਦਾ ਬਲਿ ਜਾਈ ॥",
          "roman": "apune satgur kau sadā bal jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਮੈਂ ਆਪਣੇ ਸਤਿਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, я всегда иду в жертву своему Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16516,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜੋਤੀ ਜੋਤਿ ਮਿਲਾਈ ॥",
          "roman": "gurmukh jotī jot milāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਵਾਲੇ ਮਨੁੱਖ ਦੀ ਸੁਰਤਿ ਨੂੰ ਗੁਰੂ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ ਵਿਚ ਮਿਲਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тому, кто обращён к Гуру, Гуру соединяет сознание с Божественным Светом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16517,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਬਾਣੀ ਨਿਜ ਘਰਿ ਵਾਸਾ ॥",
          "roman": "nirmal bāṇī nij ghar vāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਪਵਿਤ੍ਰ ਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ ਆਪਣੇ ਅਸਲ ਘਰ ਵਿਚ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਟਿਕਾਣਾ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости чистой Бани Гуру человек обретает пребывание в своём истинном доме, у стоп Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 16518,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਉਮੈ ਮਾਰੇ ਸਦਾ ਉਦਾਸਾ ॥੪॥੬॥੪੫॥",
          "roman": "nānak haumē māre sadā udāsā. 4. 6. 45.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਮਨੁੱਖ) ਹਉਮੈ ਨੂੰ ਮੁਕਾ ਲੈਂਦਾ ਹੈ ਤੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਸਦਾ ਉਪਰਾਮ ਰਹਿੰਦਾ ਹੈ ॥੪॥੬॥੪੫॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, по милости Гуру человек уничтожает Хоумэ и навсегда становится отрешённым от любви к майе. ॥4॥6॥45॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
