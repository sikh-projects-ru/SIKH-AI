        {
          "verse_id": 16520,
          "is_rahao": false,
          "gurmukhi": "ਲਾਲੈ ਆਪਣੀ ਜਾਤਿ ਗਵਾਈ ॥",
          "roman": "lālē āpṇī jāt gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਨੇ ਆਪਣੀ (ਵੱਖਰੀ) ਹਸਤੀ ਮਿਟਾ ਲਈ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга стирает свою отдельную самость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
