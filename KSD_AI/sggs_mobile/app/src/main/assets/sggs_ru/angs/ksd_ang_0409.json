{
  "ang": 409,
  "shabads": [
    {
      "shabad_id": 1589,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18629,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਮਾਨ ਮੋਹ ਵਿਕਾਰ ਮਿਥਿਆ ਜਪਿ ਰਾਮ ਰਾਮ ਰਾਮ ॥",
          "roman": "taj mān moh bikār mithiā jap rām rām rām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਹੰਕਾਰ ਮੋਹ ਵਿਕਾਰ ਝੂਠ ਤਿਆਗ ਦੇਹ, ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Оставь гордыню, привязанность, пороки и ложь, постоянно помни Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18630,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸੰਤਨਾ ਕੈ ਚਰਨਿ ਲਾਗੁ ॥੧॥",
          "roman": "man santnā kē charan lāg ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸਰਨ ਪਿਆ ਰਹੁ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о ум! Оставайся в прибежище святых. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18631,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਗੋਪਾਲ ਦੀਨ ਦਇਆਲ ਪਤਿਤ ਪਾਵਨ ਪਾਰਬ੍ਰਹਮ ਹਰਿ ਚਰਣ ਸਿਮਰਿ ਜਾਗੁ ॥",
          "roman": "prabh gopāl dīn da-iāl patit pāvan pārbrahm har charaṇ simar jāg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਹਰੀ-ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰ ਕੇ (ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਸੁਚੇਤ ਰਹੁ ਜੋ ਧਰਤੀ ਦਾ ਰਾਖਾ ਹੈ ਜੋ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈ ਅਤੇ ਜੋ ਵਿਕਾਰਾਂ ਵਿਚ ਡਿੱਗੇ ਹੋਏ ਬੰਦਿਆਂ ਨੂੰ ਪਵ੍ਰਿਤ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Размышляя о стопах того Хари-Господа, будь бдителен к натискам майи; Он — хранитель земли, милостивый к бедным и очищающий тех, кто пал в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18632,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਭਗਤਿ ਨਾਨਕ ਪੂਰਨ ਭਾਗੁ ॥੨॥੪॥੧੫੫॥",
          "roman": "kar bhagat nānak pūran bhāg ॥2॥4॥155॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰ, ਤੇਰੀ ਕਿਸਮਤ ਜਾਗ ਪਏਗੀ ॥੨॥੪॥੧੫੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Скажи: «О брат! Совершай бхагати Богу, и твоя судьба пробудится». ॥2॥4॥155॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1590,
      "rahao_verse_id": 18634,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18633,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੫ ॥",
          "roman": "āsā mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Арджандэва Джи в раге Аса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18634,
          "is_rahao": true,
          "gurmukhi": "ਹਰਖ ਸੋਗ ਬੈਰਾਗ ਅਨੰਦੀ ਖੇਲੁ ਰੀ ਦਿਖਾਇਓ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "harakh sog bēraag anandī khel rī dikhāio.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀ! (ਹੇ ਸਤਸੰਗੀ!) ਆਨੰਦ-ਰੂਪ ਪਰਮਾਤਮਾ ਨੇ ਮੈਨੂੰ ਇਹ ਜਗਤ-ਤਮਾਸ਼ਾ ਵਿਖਾ ਦਿੱਤਾ ਹੈ (ਇਸ ਜਗਤ-ਤਮਾਸ਼ੇ ਦੀ ਅਸਲੀਅਤ ਵਿਖਾ ਦਿਤੀ ਹੈ)। (ਇਸ ਵਿਚ ਕਿਤੇ) ਖ਼ੁਸ਼ੀ ਹੈ (ਕਿਤੇ) ਗ਼ਮੀ ਹੈ (ਕਿਤੇ) ਵੈਰਾਗ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О подруга, о сатсанги! Блаженный по своей природе Параматма показал мне это зрелище мира, показал его подлинную суть. В нём где-то радость, где-то печаль, где-то отрешённость. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18635,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨਹੂੰ ਭੈ ਨਿਰਭੈ ਖਿਨਹੂੰ ਖਿਨਹੂੰ ਉਠਿ ਧਾਇਓ ॥",
          "roman": "khinhū bhē nirbhē khinhū khinhū uṭh dhāio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਤਸੰਗੀ! ਇਸ ਜਗਤ-ਤਮਾਸ਼ੇ ਵਿਚ ਕਿਤੇ) ਇਕ ਪਲ ਵਿਚ ਅਨੇਕਾਂ ਡਰ (ਆ ਘੇਰਦੇ ਹਨ, ਕਿਤੇ) ਨਿਡਰਤਾ ਹੈ (ਕਿਤੇ ਕੋਈ ਦੁਨੀਆ ਦੇ ਪਦਾਰਥਾਂ ਵਲ) ਉਠ ਭੱਜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О сатсанги! В этом мировом зрелище где-то в один миг человека окружают многие страхи, где-то есть бесстрашие, где-то кто-то вскакивает и бежит к мирским вещам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18636,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨਹੂੰ ਰਸ ਭੋਗਨ ਖਿਨਹੂੰ ਖਿਨਹੂ ਤਜਿ ਜਾਇਓ ॥੧॥",
          "roman": "khinhū ras bhogan khinhū khinhū taj jāio.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਤੇ ਇਕ ਪਲ ਵਿਚ ਸੁਆਦਲੇ ਪਦਾਰਥ ਭੋਗੇ ਜਾ ਰਹੇ ਹਨ ਕਿਤੇ ਕੋਈ ਇਕ ਪਲ ਵਿਚ ਇਹਨਾਂ ਭੋਗਾਂ ਨੂੰ ਤਿਆਗ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "где-то в один миг наслаждаются вкусными вещами, а где-то кто-то в один миг отказывается от этих наслаждений. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18637,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨਹੂੰ ਜੋਗ ਤਾਪ ਬਹੁ ਪੂਜਾ ਖਿਨਹੂੰ ਭਰਮਾਇਓ ॥",
          "roman": "khinhū jog tāp bah pūjā khinhū bharamāio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ! ਇਸ ਜਗਤ-ਤਮਾਸ਼ੇ ਵਿਚ ਕਿਤੇ) ਜੋਗ-ਸਾਧਨ ਕੀਤੇ ਜਾ ਰਹੇ ਹਨ ਕਿਤੇ ਧੂਣੀਆਂ ਤਪਾਈਆਂ ਜਾ ਰਹੀਆਂ ਹਨ ਕਿਤੇ ਅਨੇਕਾਂ ਦੇਵ-ਪੂਜਾ ਹੋ ਰਹੀਆਂ ਹਨ, ਕਿਤੇ ਹੋਰ ਹੋਰ ਭਟਕਣਾ ਭਟਕੀਆਂ ਜਾ ਰਹੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! В этом мировом зрелище где-то совершаются йогические практики, где-то разжигают аскетические огни, где-то совершают многочисленные поклонения божествам, а где-то блуждают в иных и иных скитаниях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18638,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨਹੂੰ ਕਿਰਪਾ ਸਾਧੂ ਸੰਗ ਨਾਨਕ ਹਰਿ ਰੰਗੁ ਲਾਇਓ ॥੨॥੫॥੧੫੬॥",
          "roman": "khinhū kirpā sādhū sang nānak har rang lāio.2.5.156.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਸਖੀ!) ਕਿਤੇ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਰੱਖ ਕੇ ਇਕ ਪਲ ਵਿਚ ਪਰਮਾਤਮਾ ਦੀ ਮੇਹਰ ਹੋ ਰਹੀ ਹੈ, ਤੇ ਪਰਮਾਤਮਾ ਦਾ ਪ੍ਰੇਮ-ਰੰਗ ਬਖ਼ਸ਼ਿਆ ਜਾ ਰਿਹਾ ਹੈ ॥੨॥੫॥੧੫੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи, о подруга: где-то, будучи удержанным в садх-сангате, в один миг обретают милость Параматмы, и даруется любовный цвет Параматмы. ॥2॥5॥156॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1591,
      "rahao_verse_id": 18645,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18639,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਆਸਾ ਮਹਲਾ ੫ ਘਰੁ ੧੭ ਆਸਾਵਰੀ",
          "roman": "rāg āsā mehlā 5 ghar 17 āsāvarī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾਵਰੀ, ਘਰ ੧੭ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Арджандэва Джи в раге Асаавари, в доме 17."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18640,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и встречается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18641,
          "is_rahao": true,
          "gurmukhi": "ਗੋਬਿੰਦ ਗੋਬਿੰਦ ਕਰਿ ਹਾਂ ॥",
          "roman": "gobind gobind kar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸਖੀ!) ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦੀ ਰਹੁ, (ਇਸ ਤਰ੍ਹਾਂ ਆਪਣੇ)।"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Постоянно продолжай поминать Параматму, и так"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18642,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਮਨਿ ਪਿਆਰਿ ਹਾਂ ॥",
          "roman": "har har man piār hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਨਾਲ ਪਿਆਰ ਬਣਾ।"
            },
            "sahib_singh_ru": {
              "main": "сохраняй в уме любовь к Параматме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18643,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਕਹਿਆ ਸੁ ਚਿਤਿ ਧਰਿ ਹਾਂ ॥",
          "roman": "gur kahiā su chit dhar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਗੁਰੂ ਨੇ ਦੱਸਿਆ ਉਹ ਆਪਣੇ ਚਿੱਤ ਵਿਚ ਵਸਾ।"
            },
            "sahib_singh_ru": {
              "main": "То, что сказал Гуру, помести в своё сознание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18644,
          "is_rahao": true,
          "gurmukhi": "ਅਨ ਸਿਉ ਤੋਰਿ ਫੇਰਿ ਹਾਂ ॥",
          "roman": "an siu tor pher hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਨਾਲ ਬਣਾਈ ਹੋਈ ਪ੍ਰੀਤ ਤੋੜ ਦੇ, ਹੋਰ ਵਲੋਂ ਆਪਣੇ ਮਨ ਨੂੰ ਪਰਤਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "Разорви любовь, устроенную с кем-либо помимо Параматмы, и отврати свой ум от иного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18645,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਲਾਲਨੁ ਪਾਇਓ ਰੀ ਸਖੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "aise lālan pāio rī sakhī.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀ! (ਜਿਸ ਨੇ ਭੀ) ਪਰਮਾਤਮਾ ਨੂੰ (ਲੱਭਾ ਹੈ) ਇਸ ਤਰੀਕੇ ਨਾਲ ਹੀ ਲੱਭਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Кто и обрёл Параматму, тот обрёл Его именно таким путём. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18646,
          "is_rahao": false,
          "gurmukhi": "ਪੰਕਜ ਮੋਹ ਸਰਿ ਹਾਂ ॥",
          "roman": "pankaj moh sar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਹੇਲੀ! ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਮੋਹ ਦਾ ਚਿੱਕੜ ਹੈ (ਇਸ ਵਿਚ ਫਸਿਆ ਹੋਇਆ),"
            },
            "sahib_singh_ru": {
              "main": "О подруга! В мировом океане есть грязь привязанности, и в ней, увязнув,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18647,
          "is_rahao": false,
          "gurmukhi": "ਪਗੁ ਨਹੀ ਚਲੈ ਹਰਿ ਹਾਂ ॥",
          "roman": "pag nahī chalē har hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੈਰ ਪਰਮਾਤਮਾ ਵਾਲੇ ਪਾਸੇ ਨਹੀਂ ਤੁਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "нога не может идти в сторону Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18648,
          "is_rahao": false,
          "gurmukhi": "ਗਹਡਿਓ ਮੂੜ ਨਰਿ ਹਾਂ ॥",
          "roman": "gahḍio mūṛ nar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੂਰਖ ਮਨੁੱਖ ਨੇ (ਆਪਣਾ ਪੈਰ ਮੋਹ ਦੇ ਚਿੱਕੜ ਵਿਚ) ਫਸਾਇਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Глупый человек засадил свою ногу в грязь привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18649,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਨ ਉਪਾਵ ਕਰਿ ਹਾਂ ॥",
          "roman": "anin upāv kar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਹੋਰ ਹੋਰ ਸਾਧਨ ਕਰ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и всё делает иные и иные средства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18650,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਨਿਕਸੈ ਸਰਨਿ ਪੈ ਰੀ ਸਖੀ ॥੧॥",
          "roman": "tau niksē saran pē rī sakhī.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਜਦੋਂ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਿਆ ਜਾਂਦਾ, ਤਦੋਂ ਹੀ (ਮੋਹ-ਚਿੱਕੜ ਵਿਚ ਫਸਿਆ ਪੈਰ) ਨਿਕਲ ਸਕਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О подруга! Лишь когда человек падает в убежище Параматмы, тогда и может выйти эта нога, застрявшая в грязи привязанности. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18651,
          "is_rahao": false,
          "gurmukhi": "ਥਿਰ ਥਿਰ ਚਿਤ ਥਿਰ ਹਾਂ ॥",
          "roman": "thir thir chit thir hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਚਿੱਤ ਨੂੰ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਲੋਂ) ਅਡੋਲ ਬਣਾ ਲੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сделай своё сознание неподвижным со стороны привязанности к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18652,
          "is_rahao": false,
          "gurmukhi": "ਬਨੁ ਗ੍ਰਿਹੁ ਸਮਸਰਿ ਹਾਂ ॥",
          "roman": "ban grih samsar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਤਨਾ ਅਡੋਲ ਕਿ) ਜੰਗਲ ਅਤੇ ਘਰ ਇਕ-ਸਮਾਨ ਪ੍ਰਤੀਤ ਹੋਣ।"
            },
            "sahib_singh_ru": {
              "main": "настолько неподвижным, чтобы лес и дом казались одинаковыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18653,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਏਕ ਪਿਰ ਹਾਂ ॥",
          "roman": "antar ek pir hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਇਕ ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਟਿਕਾਈ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "В своём сердце удерживай память об одном Параматме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18654,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਅਨੇਕ ਧਰਿ ਹਾਂ ॥",
          "roman": "bāhar anek dhar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਜਗਤ ਵਿੱਚ ਬੇ-ਸ਼ੱਕ ਕਈ ਤਰ੍ਹਾਂ ਦੀ ਕਿਰਤ-ਕਾਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "а во внешнем мире, конечно, совершай многие виды дел и занятий,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18655,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜਨ ਜੋਗੁ ਕਰਿ ਹਾਂ ॥",
          "roman": "rājan jog kar hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਰਾਜ ਭੀ ਕਰ ਤੇ ਜੋਗ ਭੀ ਕਮਾ।"
            },
            "sahib_singh_ru": {
              "main": "так и царствуй, и йогу практикуй."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18656,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਲੋਗ ਅਲੋਗੀ ਰੀ ਸਖੀ ॥੨॥੧॥੧੫੭॥",
          "roman": "kah nānak log alogī rī sakhī.2.1.157.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ,) ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਸਖੀ! (ਕਿਰਤ-ਕਾਰ ਕਰਦਿਆਂ ਹੀ ਨਿਰਲੇਪ ਰਹਿਣਾ-ਇਹ) ਸੰਸਾਰ ਤੋਂ ਨਿਰਾਲਾ ਰਸਤਾ ਹੈ ॥੨॥੧॥੧੫੭॥"
            },
            "sahib_singh_ru": {
              "main": "Но Нанак говорит: о подруга, оставаться неприлеплённым даже среди дел и занятий — это путь, отличный от мира. ॥2॥1॥157॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1592,
      "rahao_verse_id": 18662,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18657,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾਵਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "āsāvarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18658,
          "is_rahao": true,
          "gurmukhi": "ਮਨਸਾ ਏਕ ਮਾਨਿ ਹਾਂ ॥",
          "roman": "mansā ek mān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ!) ਇਕ (ਪਰਮਾਤਮਾ ਦੇ ਮਿਲਾਪ) ਦੀ ਤਾਂਘ (ਆਪਣੇ ਅੰਦਰ) ਕਾਇਮ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Утверди в себе одно стремление — к встрече с Параматмой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18659,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਸਿਉ ਨੇਤ ਧਿਆਨਿ ਹਾਂ ॥",
          "roman": "gur siu net dhiān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਕੇ ਸਦਾ (ਪਰਮਾਤਮਾ ਦੇ) ਧਿਆਨ ਵਿਚ ਟਿਕਿਆ ਰਹੁ।"
            },
            "sahib_singh_ru": {
              "main": "Соединившись с лотосными стопами Гуру, всегда пребывай в созерцании Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18660,
          "is_rahao": true,
          "gurmukhi": "ਦ੍ਰਿੜੁ ਸੰਤ ਮੰਤ ਗਿਆਨਿ ਹਾਂ ॥",
          "roman": "driṛ sant mant giān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਉਪਦੇਸ਼ ਦੀ ਜਾਣ-ਪਛਾਣ ਵਿਚ ਮਜ਼ਬੂਤ-ਚਿੱਤ ਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "Будь твёрд в понимании наставления Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18661,
          "is_rahao": true,
          "gurmukhi": "ਸੇਵਾ ਗੁਰ ਚਰਾਨਿ ਹਾਂ ॥",
          "roman": "sevā gur charān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ-ਚਰਨਾਂ ਵਿਚ (ਰਹਿ ਕੇ) ਸੇਵਾ-ਭਗਤੀ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Оставаясь у стоп Гуру, совершай служение-бхакти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18662,
          "is_rahao": true,
          "gurmukhi": "ਤਉ ਮਿਲੀਐ ਗੁਰ ਕ੍ਰਿਪਾਨਿ ਮੇਰੇ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tau milīai gur kripān mere manā.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਤਦੋਂ ਹੀ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਨੂੰ) ਮਿਲ ਸਕੀਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Только тогда по милости Гуру можно встретить Параматму. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18663,
          "is_rahao": false,
          "gurmukhi": "ਟੂਟੇ ਅਨ ਭਰਾਨਿ ਹਾਂ ॥",
          "roman": "ṭūṭe an bharān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਜਦੋਂ ਹੋਰ ਭਟਕਣਾਂ ਮੁੱਕ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Когда прекращаются прочие блуждания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18664,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿਓ ਸਰਬ ਥਾਨਿ ਹਾਂ ॥",
          "roman": "ravio sarab thān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਹਰੇਕ ਥਾਂ ਵਿਚ ਪਰਮਾਤਮਾ ਹੀ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "когда во всяком месте видят только Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18665,
          "is_rahao": false,
          "gurmukhi": "ਲਹਿਓ ਜਮ ਭਇਆਨਿ ਹਾਂ ॥",
          "roman": "lahio jam bhaiān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਡਰਾਉਣੇ ਜਮ ਦਾ ਸਹਮ ਲਹਿ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тогда исчезает страх перед страшным Джамом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18666,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇਓ ਪੇਡ ਥਾਨਿ ਹਾਂ ॥",
          "roman": "pāio peḍ thān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਸਾਰ-ਰੁੱਖ ਦੇ ਮੁੱਢ-ਹਰੀ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕਾਣਾ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "обретается пристанище у корня мирового дерева — в стопах Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18667,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਚੂਕੀ ਸਗਲ ਕਾਨਿ ॥੧॥",
          "roman": "tau chūkī sagal kān.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹਰੇਕ ਕਿਸਮ ਦੀ ਮੁਥਾਜੀ ਮੁੱਕ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тогда кончается всякая зависимость. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18668,
          "is_rahao": false,
          "gurmukhi": "ਲਹਨੋ ਜਿਸੁ ਮਥਾਨਿ ਹਾਂ ॥",
          "roman": "lahno jis mathān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਉੱਤੇ ਭਾਗ ਜਾਗਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, на челе которого пробуждается удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18669,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਪਾਵਕ ਪਾਰਿ ਪਰਾਨਿ ਹਾਂ ॥",
          "roman": "bhē pāvak pār parān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਵਿਕਾਰਾਂ ਦੀ) ਅੱਗ ਦੇ ਖ਼ਤਰੇ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он переходит через опасность огня пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18670,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਘਰਿ ਤਿਸਹਿ ਥਾਨਿ ਹਾਂ ॥",
          "roman": "nij ghar tiseh thān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਆਪਣੇ ਅਸਲ ਘਰ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਥਾਂ ਮਿਲ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "ему находится место в его истинном доме, в стопах Прабху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18671,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸ ਰਸਹਿ ਮਾਨਿ ਹਾਂ ॥",
          "roman": "har ras raseh mān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਰਸਾਂ ਵਿਚ ਸ੍ਰੇਸ਼ਟ ਰਸ ਹਰਿ ਨਾਮ ਰਸ ਨੂੰ ਸਦਾ ਮਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он всегда вкушает высший из всех вкусов — вкус Имени Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18672,
          "is_rahao": false,
          "gurmukhi": "ਲਾਥੀ ਤਿਸ ਭੁਖਾਨਿ ਹਾਂ ॥",
          "roman": "lāthī tis bhukhān hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ (ਮਾਇਆ ਵਾਲੀ) ਤ੍ਰੇਹ ਭੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "у него исчезают жажда и голод по майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18673,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਹਜਿ ਸਮਾਇਓ ਰੇ ਮਨਾ ॥੨॥੨॥੧੫੮॥",
          "roman": "nānak sahaj samāio re manā.2.2.158.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਮੇਰੇ ਮਨ! ਉਹ ਸਦਾ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ ॥੨॥੨॥੧੫੮॥"
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, скажи: о мой ум, такой человек всегда погружён в духовную устойчивость. ॥2॥2॥158॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1593,
      "rahao_verse_id": 18679,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18674,
          "is_rahao": true,
          "gurmukhi": "ਆਸਾਵਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "āsāvarī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18675,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਹਰਿ ਗੁਨੀ ਹਾਂ ॥",
          "roman": "har har har gunī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ!) ਉਸ ਪਰਮਾਤਮਾ ਜੇਹੜਾ ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਮਾਲਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Имя того Параматмы, Который есть владыка всех достоинств,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18676,
          "is_rahao": true,
          "gurmukhi": "ਜਪੀਐ ਸਹਜ ਧੁਨੀ ਹਾਂ ॥",
          "roman": "japīai sahaj dhunī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾ ਨਾਮ ਆਤਮਕ ਅਡੋਲਤਾ ਦੀ ਲਹਿਰ ਵਿਚ ਲੀਨ ਹੋ ਕੇ ਜਪਣਾ ਚਾਹੀਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "следует повторять, погрузившись в волну духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18677,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧੂ ਰਸਨ ਭਨੀ ਹਾਂ ॥",
          "roman": "sādhū rasan bhanī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਆਪਣੀ) ਜੀਭ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਉਚਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "прибегнув к прибежищу Гуру, своим языком произноси достоинства Параматмы!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18678,
          "is_rahao": true,
          "gurmukhi": "ਛੂਟਨ ਬਿਧਿ ਸੁਨੀ ਹਾਂ ॥",
          "roman": "chhūṭan bidh sunī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਣ, ਇਹੀ ਹੈ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਣ ਦਾ ਤਰੀਕਾ,"
            },
            "sahib_singh_ru": {
              "main": "Слушай, именно таков способ спастись от пороков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18679,
          "is_rahao": true,
          "gurmukhi": "ਪਾਈਐ ਵਡ ਪੁਨੀ ਮੇਰੇ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pāīai vaḍ punī mere manā.1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰ ਇਹ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "о мой ум! Но это достигается лишь по великой удаче. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18680,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਹਿ ਜਨ ਮੁਨੀ ਹਾਂ ॥",
          "roman": "khojah jan munī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਰਿਸ਼ੀ ਮੁਨੀ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਖੋਜਦੇ ਆ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все риши и муни ищут этого Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18681,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਬ ਕਾ ਪ੍ਰਭ ਧਨੀ ਹਾਂ ॥",
          "roman": "srab kā prabh dhanī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਸਾਰੇ ਜੀਵਾਂ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Который есть Господь, владыка всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18682,
          "is_rahao": false,
          "gurmukhi": "ਦੁਲਭ ਕਲਿ ਦੁਨੀ ਹਾਂ ॥",
          "roman": "dulabh kal dunī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਇਸ ਮਾਇਆ-ਵੇੜ੍ਹੀ ਦੁਨੀਆ ਵਿਚ ਲੱਭਣਾ ਔਖਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Которого трудно найти в этом мире, окружённом майей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18683,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਬਿਨਾਸਨੀ ਹਾਂ ॥",
          "roman": "dūkh bināsnī hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਸਾਰੇ ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Который уничтожает все страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18684,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਪੂਰਨ ਆਸਨੀ ਮੇਰੇ ਮਨਾ ॥੧॥",
          "roman": "prabh pūran āsnī mere manā.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਤੇ ਜੇਹੜਾ ਸਭ ਦੀਆਂ ਆਸਾਂ ਪੂਰੀਆਂ ਕਰਨ ਵਾਲਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "о мой ум, и Который исполняет все надежды. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18685,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਸੋ ਸੇਵੀਐ ਹਾਂ ॥",
          "roman": "man so sevīai hāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਉਸ ਪਰਮਾਤਮਾ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум! Следует совершать служение-бхакти этому Параматме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
