{
  "ang": 411,
  "shabads": [
    {
      "shabad_id": 1597,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18761,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਉ ਤਜਿ ਗਏ ਹਾਂ ॥",
          "roman": "sabh kau taj gae hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਖ਼ਰ ਉਸ ਸਾਰੀ ਨੂੰ ਛੱਡ ਕੇ ਇਥੋਂ ਚਲੇ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "но в конце концов оставили всё это и ушли отсюда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18762,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨਾ ਜਿਉ ਭਏ ਹਾਂ ॥",
          "roman": "supnā jiu bhae hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਉਹ) ਸੁਪਨੇ ਵਾਂਗ ਹੋ ਗਏ ਹਨ (ਕੋਈ ਉਹਨਾਂ ਨੂੰ ਚੇਤੇ ਭੀ ਨਹੀਂ ਕਰਦਾ),"
            },
            "sahib_singh_ru": {
              "main": "и теперь стали как сон, о них уже никто даже не вспоминает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18763,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਜਿਨਿੑ ਲਏ ॥੧॥",
          "roman": "har nām jinh lae ǁ1ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ) ਤੂੰ ਕਿਉਂ (ਮਾਇਆ ਦਾ ਮੋਹ ਛੱਡ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਯਾਦ ਕਰਦਾ? ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так почему же ты не помнишь Имя Параматмы, отбросив привязанность к майе? ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18764,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਤਜਿ ਅਨ ਲਗੇ ਹਾਂ ॥",
          "roman": "har taj an lage hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਭੁਲਾ ਕੇ ਹੋਰ ਹੋਰ ਪਦਾਰਥਾਂ ਦੇ ਮੋਹ ਵਿਚ ਫਸੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые, забыв Параматму, запутываются в привязанности к другим и другим вещам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18765,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮਹਿ ਮਰਿ ਭਗੇ ਹਾਂ ॥",
          "roman": "janmeh mar bhage hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "скитаются в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18766,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਜਨਿ ਲਹੇ ਹਾਂ ॥",
          "roman": "har har jan lahe hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਨੂੰ ਲੱਭ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Каждый человек, который обрёл Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18767,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਸੇ ਰਹੇ ਹਾਂ ॥",
          "roman": "jīvat se rahe hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਤਮਕ ਜੀਵਨ ਦੇ ਮਾਲਕ ਬਣ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "стал обладателем духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18768,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਕ੍ਰਿਪਾਲੁ ਹੋਇ ਹਾਂ ॥",
          "roman": "jisah kripāl hoi hā̃",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, к кому Господь становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18769,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤੁ ਸੋਇ ॥੨॥੭॥੧੬੩॥੨੩੨॥",
          "roman": "nānak bhagat soi ǁ2ǁ7ǁ163ǁ232ǁ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਉਸ ਦਾ ਭਗਤ ਬਣਦਾ ਹੈ ॥੨॥੭॥੧੬੩॥੨੩੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! становится Его бхагатом. ॥2॥7॥163॥232॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1598,
      "rahao_verse_id": 18773,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18770,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вечный Творец один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18771,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਆਸਾ ਮਹਲਾ ੯ ॥",
          "roman": "rāg āsā mehlā 9",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਤੇਗਬਹਾਦਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру Тег Бахадура Джи в раге Аса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18772,
          "is_rahao": true,
          "gurmukhi": "ਬਿਰਥਾ ਕਹਉ ਕਉਨ ਸਿਉ ਮਨ ਕੀ ॥",
          "roman": "birthā kahau kaun siu man kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਇਸ (ਮਨੁੱਖੀ) ਮਨ ਦੀ ਭੈੜੀ ਹਾਲਤ ਕਿਸ ਨੂੰ ਦੱਸਾਂ (ਹਰੇਕ ਮਨੁੱਖ ਦਾ ਇਹੀ ਹਾਲ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Кому мне рассказать о плохом состоянии этого человеческого ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18773,
          "is_rahao": true,
          "gurmukhi": "ਲੋਭਿ ਗ੍ਰਸਿਓ ਦਸ ਹੂ ਦਿਸ ਧਾਵਤ ਆਸਾ ਲਾਗਿਓ ਧਨ ਕੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "lobh grasio das hū dis dhāvat āsā lāgio dhan kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਲੋਭ ਵਿਚ ਫਸਿਆ ਹੋਇਆ ਇਹ ਮਨ ਦਸੀਂ ਪਾਸੀਂ ਦੌੜਦਾ ਰਹਿੰਦਾ ਹੈ, ਇਸ ਨੂੰ ਧਨ ਜੋੜਨ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਚੰਬੜੀ ਰਹਿੰਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Охваченный жадностью, этот ум бегает во все стороны, к нему прилепилась жажда накопления богатства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18774,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਕੈ ਹੇਤਿ ਬਹੁਤੁ ਦੁਖੁ ਪਾਵਤ ਸੇਵ ਕਰਤ ਜਨ ਜਨ ਕੀ ॥",
          "roman": "sukh kē het bahut dukh pāvat sev karat jan jan kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਖ ਹਾਸਲ ਕਰਨ ਵਾਸਤੇ (ਇਹ ਮਨ) ਧਿਰ ਧਿਰ ਦੀ ਖ਼ੁਸ਼ਾਮਦ ਕਰਦਾ ਫਿਰਦਾ ਹੈ (ਤੇ ਇਸ ਤਰ੍ਹਾਂ ਸੁਖ ਦੇ ਥਾਂ ਸਗੋਂ) ਦੁੱਖ ਸਹਾਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Стремясь к счастью, он терпит много страданий, угождая каждому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18775,
          "is_rahao": false,
          "gurmukhi": "ਦੁਆਰਹਿ ਦੁਆਰਿ ਸੁਆਨ ਜਿਉ ਡੋਲਤ ਨਹ ਸੁਧ ਰਾਮ ਭਜਨ ਕੀ ॥੧॥",
          "roman": "duāreh duār suān jiu dolat nah sudh rām bhajan kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੁੱਤੇ ਵਾਂਗ ਹਰੇਕ ਦੇ ਦਰ ਤੇ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ ਇਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਭਜਨ ਕਰਨ ਦੀ ਕਦੇ ਸੂਝ ਹੀ ਨਹੀਂ ਪੈਂਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Как собака, он бродит от двери к двери, и у него вовсе нет понимания воспевания Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18776,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨਸ ਜਨਮ ਅਕਾਰਥ ਖੋਵਤ ਲਾਜ ਨ ਲੋਕ ਹਸਨ ਕੀ ॥",
          "roman": "mānas janam akārath khovat lāj na lok hasan kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਲੋਭ ਵਿਚ ਫਸਿਆ ਹੋਇਆ) ਇਹ ਜੀਵ ਆਪਣਾ ਮਨੁੱਖਾ ਜਨਮ ਵਿਅਰਥ ਹੀ ਗਵਾ ਲੈਂਦਾ ਹੈ, (ਇਸ ਦੇ ਲਾਲਚ ਦੇ ਕਾਰਨ) ਲੋਕਾਂ ਵਲੋਂ ਹੋ ਰਹੇ ਹਾਸੇ-ਮਖ਼ੌਲ ਦੀ ਭੀ ਇਸ ਨੂੰ ਸ਼ਰਮ ਨਹੀਂ ਆਉਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Он напрасно теряет человеческую жизнь и не стыдится насмешек людей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18777,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਜਸੁ ਕਿਉ ਨਹੀ ਗਾਵਤ ਕੁਮਤਿ ਬਿਨਾਸੈ ਤਨ ਕੀ ॥੨॥੧॥੨੩੩॥",
          "roman": "nānak har jas kiu nahī gāvat kumat bināsē tan kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਜੀਵ!) ਤੂੰ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਿਉਂ ਨਹੀਂ ਕਰਦਾ? (ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹੀ) ਤੇਰੀ ਇਹ ਖੋਟੀ ਮਤਿ ਦੂਰ ਹੋ ਸਕੇਗੀ ॥੨॥੧॥੨੩੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, почему ты не поёшь славу Бога — только так исчезнет твоя дурная мысль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1599,
      "rahao_verse_id": 18785,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18778,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਆਸਾ ਮਹਲਾ ੧ ਅਸਟਪਦੀਆ ਘਰੁ ੨",
          "roman": "rāg āsā mehlā 1 asṭpadīā ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ, ਘਰ ੨ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਅੱਠ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Аса, дом 2, восьмистрофная бани Гуру Нанак Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18779,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōaṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Вечный Творец один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18780,
          "is_rahao": false,
          "gurmukhi": "ਉਤਰਿ ਅਵਘਟਿ ਸਰਵਰਿ ਨੑਾਵੈ ॥",
          "roman": "utar avghaṭ sarvar nhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਰਥਰੀ ਜੋਗੀ ਕਿਸੇ ਪਹਾੜ ਦੇ ਟਿੱਲੇ ਤੋਂ ਉਤਰ ਕੇ ਕਿਸੇ ਤੀਰਥ-ਸਰੋਵਰ ਵਿਚ ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈ, ਤੇ ਇਸ ਨੂੰ ਪੁੰਨ ਕਰਮ ਸਮਝਦਾ ਹੈ) ਜੇਹੜਾ ਮਨੁੱਖ ਅਹੰਕਾਰ ਆਦਿਕ ਦੀ ਔਖੀ ਘਾਟੀ ਤੋਂ ਉਤਰ ਕੇ ਸਤਸੰਗ ਸਰੋਵਰ ਵਿਚ ਆਤਮਕ ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто спускается из трудной долины эго и омывается в озере сатсанга,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18781,
          "is_rahao": false,
          "gurmukhi": "ਬਕੈ ਨ ਬੋਲੈ ਹਰਿ ਗੁਣ ਗਾਵੈ ॥",
          "roman": "bakē na bolē har guṇ gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਜੋ ਬਹੁਤਾ ਵਿਅਰਥ ਨਹੀਂ ਬੋਲਦਾ ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и не говорит лишнего, а поёт качества Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18782,
          "is_rahao": false,
          "gurmukhi": "ਜਲੁ ਆਕਾਸੀ ਸੁੰਨਿ ਸਮਾਵੈ ॥",
          "roman": "jal ākāsī sunn samāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਪਹੁੰਚਦਾ ਹੈ, ਜਿਵੇਂ (ਸਮੁੰਦਰ ਦਾ) ਜਲ (ਸੂਰਜ ਦੀ ਮਦਦ ਨਾਲ ਉੱਚਾ ਉਠ ਕੇ) ਆਕਾਸ਼ਾਂ ਵਿਚ (ਉਡਾਰੀਆਂ ਲਾਂਦਾ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тот достигает высокого духовного состояния, как вода поднимается в небо,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18783,
          "is_rahao": false,
          "gurmukhi": "ਰਸੁ ਸਤੁ ਝੋਲਿ ਮਹਾ ਰਸੁ ਪਾਵੈ ॥੧॥",
          "roman": "ras sat jhol mahā ras pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸ਼ਾਂਤੀ ਰਸ ਨੂੰ ਹਲਾ ਕੇ (ਮਾਣ ਕੇ) ਨਾਮ ਮਹਾ ਰਸ ਪੀਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "он вкушает высший нектар имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18784,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਗਿਆਨੁ ਸੁਨਹੁ ਅਭ ਮੋਰੇ ॥",
          "roman": "aisā giān sunah abh more",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਣ ਦੀ ਇਹ ਗੱਲ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, послушай это знание о глубокой связи с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18785,
          "is_rahao": true,
          "gurmukhi": "ਭਰਿਪੁਰਿ ਧਾਰਿ ਰਹਿਆ ਸਭ ਠਉਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bharpur dhār rahia sabh ṭhaure",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਪਰਮਾਤਮਾ ਹਰ ਥਾਂ ਭਰਪੂਰ ਹੈ, ਤੇ ਹਰ ਥਾਂ ਸਹਾਰਾ ਦੇ ਰਿਹਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что Бог везде присутствует и везде поддерживает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18786,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਬ੍ਰਤੁ ਨੇਮੁ ਨ ਕਾਲੁ ਸੰਤਾਵੈ ॥",
          "roman": "sach brat nem na kāl santāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜਿਸ ਮਨੁੱਖ ਨੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦੇ ਨਾਮ) ਨੂੰ ਆਪਣਾ ਨਿੱਤ ਦਾ ਪ੍ਰਣ ਬਣਾ ਲਿਆ ਹੈ, ਨਿੱਤ ਦੀ ਕਾਰ ਬਣਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кто сделал вечного Бога своей постоянной практикой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18787,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਸਬਦਿ ਕਰੋਧੁ ਜਲਾਵੈ ॥",
          "roman": "satigur sabad krodh jalāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਕ੍ਰੋਧ ਸਾੜ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тот, соединяясь со словом Гуру, сжигает свой гнев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18788,
          "is_rahao": false,
          "gurmukhi": "ਗਗਨਿ ਨਿਵਾਸਿ ਸਮਾਧਿ ਲਗਾਵੈ ॥",
          "roman": "gagan nivās samādh lagāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਉੱਚੇ ਆਤਮਕ ਮੰਡਲ ਵਿਚ ਨਿਵਾਸ ਦੀ ਰਾਹੀਂ ਉਹ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ (ਸਮਾਧੀ ਲਾਈ ਰੱਖਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и пребывает в высоком духовном состоянии, оставаясь в сосредоточении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18789,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਸੁ ਪਰਸਿ ਪਰਮ ਪਦੁ ਪਾਵੈ ॥੨॥",
          "roman": "pāras paras param pad pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਗੁਰੂ-) ਪਾਰਸ (ਦੇ ਚਰਨਾਂ) ਨੂੰ ਛੁਹ ਕੇ ਉਹ ਸਭ ਤੋਂ ਉੱਚਾ ਆਤਮਕ ਦਰਜਾ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "прикоснувшись к Парасу Гуру, он достигает высшего состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18790,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਮਨ ਕਾਰਣਿ ਤਤੁ ਬਿਲੋਵੈ ॥",
          "roman": "sach man kāraṇ tat bilovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜੇਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਮਨ ਨੂੰ ਵੱਸ ਕਰਨ ਵਾਸਤੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ (ਚੇਤੇ ਰੱਖਦਾ ਹੈ) ਮੁੜ ਮੁੜ ਯਾਦ ਕਰਦਾ ਹੈ (ਜਿਵੇਂ ਦੁੱਧ ਰਿੜਕੀਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто ради управления умом постоянно вспоминает Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18791,
          "is_rahao": false,
          "gurmukhi": "ਸੁਭਰ ਸਰਵਰਿ ਮੈਲੁ ਨ ਧੋਵੈ ॥",
          "roman": "subhar sarvar mēl na dhovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਜੋ (ਨਾਮ-ਅੰਮ੍ਰਿਤ ਨਾਲ) ਨਕਾਨਕ ਭਰੇ ਹੋਏ ਸਰੋਵਰ ਵਿਚ (ਜਿਥੇ ਕੋਈ ਵਿਕਾਰ ਆਦਿਕਾਂ ਦੀ) ਮੈਲ ਨਹੀਂ ਹੈ ਆਪਣੇ ਆਪ ਨੂੰ ਧੋਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и очищается в полном озере нектара без скверны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18792,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਸਿਉ ਰਾਤਾ ਤੈਸੋ ਹੋਵੈ ॥",
          "roman": "jē siu rātā tēso hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਉਹੋ ਜਿਹਾ ਹੀ ਬਣ ਜਾਂਦਾ ਹੈ ਜਿਹੋ ਜਿਹੇ ਪ੍ਰਭੂ ਨਾਲ ਉਹ ਪਿਆਰ ਪਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "становится таким же, с каким Богом он соединяется любовью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18793,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਤਾ ਕਰੇ ਸੁ ਹੋਵੈ ॥੩॥",
          "roman": "āpe kartā kare so hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਫਿਰ ਇਹ ਸੂਝ ਆ ਜਾਂਦੀ ਹੈ ਕਿ) ਜਗਤ ਵਿਚ ਉਹੀ ਕੁਝ ਹੁੰਦਾ ਹੈ ਜੋ ਕਰਤਾਰ ਆਪ ਹੀ ਕਰ ਰਿਹਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он понимает, что происходит только то, что делает Сам Творец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18794,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਹਿਵ ਸੀਤਲੁ ਅਗਨਿ ਬੁਝਾਵੈ ॥",
          "roman": "gur hiv sītal agan bujhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜੋ ਮਨੁੱਖ ਬਰਫ਼ ਵਰਗੇ ਠੰਡੇ ਠਾਰ ਜਿਗਰੇ ਵਾਲੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਆਪਣੇ ਅੰਦਰੋਂ ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਬੁਝਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто встречает прохладного как лёд Гуру и гасит огонь жажды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18795,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਾ ਸੁਰਤਿ ਬਿਭੂਤ ਚੜਾਵੈ ॥",
          "roman": "sevā surat bibhūt chaṛāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਗੁਰੂ ਦੀ ਦੱਸੀ ਹੋਈ ਸੇਵਾ ਵਿਚ ਆਪਣੀ ਸੁਰਤਿ ਰੱਖਦਾ ਹੈ, ਤੇ, ਮਾਨੋ, ਐਸੀ ਸੁਆਹ ਪਿੰਡੇ ਤੇ ਮਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и удерживает сознание в служении Гуру, словно наносит святую пепел,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18796,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਆਪਿ ਸਹਜ ਘਰਿ ਆਵੈ ॥",
          "roman": "darsan āp sahaj ghar āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਅਡੋਲ ਆਤਮਕ ਅਵਸਥਾ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ, ਸਮਝੋ ਉਸ ਨੇ (ਅਸਲ) ਭੇਖ ਧਾਰਨ ਕਰ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот пребывает в устойчивом духовном состоянии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18797,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਬਾਣੀ ਨਾਦੁ ਵਜਾਵੈ ॥੪॥",
          "roman": "nirmal bāṇī nād vajāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਐਸਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨਾਲ ਭਰਪੂਰ ਗੁਰੂ ਦੀ ਪਵਿਤ੍ਰ ਬਾਣੀ ਦਾ ਇਹ ਵਾਜਾ ਵਜਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и играет мелодию чистой бани, полной хвалы Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18798,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਗਿਆਨੁ ਮਹਾ ਰਸੁ ਸਾਰਾ ॥",
          "roman": "antar giān mahā ras sārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣੇ ਅੰਦਰ ਪ੍ਰਭੂ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾ ਲਈ ਹੈ, ਜੋ ਸਦਾ ਸ੍ਰੇਸ਼ਟ ਨਾਮ ਮਹਾ ਰਸ ਪੀ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обрел внутри глубокую связь с Богом и пьёт высший нектар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18799,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥ ਮਜਨੁ ਗੁਰ ਵੀਚਾਰਾ ॥",
          "roman": "tīrath majan gur vīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਸਤਿਗੁਰੂ ਦੀ ਬਾਣੀ ਦੀ ਵਿਚਾਰ ਨੂੰ (ਅਠਾਹਠ) ਤੀਰਥਾਂ ਦਾ ਇਸ਼ਨਾਨ ਬਣਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто сделал размышление над словом Гуру своим омовением,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18800,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪੂਜਾ ਥਾਨੁ ਮੁਰਾਰਾ ॥",
          "roman": "antar pūjā thān murārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਆਪਣੇ ਹਿਰਦੇ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਰਹਿਣ ਲਈ ਮੰਦਰ ਬਣਾਇਆ ਹੈ, ਤੇ ਅੰਤਰ ਆਤਮੇ ਉਸ ਦੀ ਪੂਜਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и сделал своё сердце храмом для Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18801,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤੀ ਜੋਤਿ ਮਿਲਾਵਣਹਾਰਾ ॥੫॥",
          "roman": "jotī jot milāvaṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣੀ ਜੋਤਿ ਨੂੰ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ ਵਿੱਚ ਮਿਲਾ ਲੈਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "тот соединяет свою душу с Божественным светом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18802,
          "is_rahao": false,
          "gurmukhi": "ਰਸਿ ਰਸਿਆ ਮਤਿ ਏਕੈ ਭਾਇ ॥",
          "roman": "ras rasiya mat ekē bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ!) ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਨਾਮ-ਰਸ ਵਿਚ ਭਿੱਜ ਜਾਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Тот, чей ум пропитан нектаром имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18803,
          "is_rahao": false,
          "gurmukhi": "ਤਖਤ ਨਿਵਾਸੀ ਪੰਚ ਸਮਾਇ ॥",
          "roman": "takhat nivāsī panch samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਮਤਿ ਇੱਕ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ ਭਿੱਜ ਜਾਂਦੀ ਹੈ, ਉਹ ਕਾਮਾਦਿਕ ਪੰਜਾਂ ਨੂੰ ਮੁਕਾ ਕੇ ਅੰਤਰ ਆਤਮੇ ਅਡੋਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "чья мысль растворена в любви к одному Богу, побеждает пять страстей и становится устойчивым внутри,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18804,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰ ਕਮਾਈ ਖਸਮ ਰਜਾਇ ॥",
          "roman": "kār kamāī khasam rajāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਖਸਮ-ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਨਾ ਉਸ ਦੀ ਨਿੱਤ ਦੀ ਕਾਰ ਨਿੱਤ ਦੀ ਕਮਾਈ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "следование воле Господа становится его постоянным делом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18805,
          "is_rahao": false,
          "gurmukhi": "ਅਵਿਗਤ ਨਾਥੁ ਨ ਲਖਿਆ ਜਾਇ ॥੬॥",
          "roman": "avigat nāth na lakhia jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਉਸ 'ਨਾਥ' ਦਾ ਰੂਪ ਹੋ ਜਾਂਦਾ ਹੈ ਜੋ ਅਦ੍ਰਿਸ਼ਟ ਹੈ ਤੇ ਜਿਸ ਦਾ ਸਰੂਪ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и он становится подобным Невидимому Господу, которого невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18806,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਮਹਿ ਉਪਜੈ ਜਲ ਤੇ ਦੂਰਿ ॥",
          "roman": "jal mah upjē jal te dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੋਗੀ! ਸੂਰਜ ਜਾਂ ਚੰਦ੍ਰਮਾ ਸਰੋਵਰ ਆਦਿਕ ਦੇ) ਪਾਣੀ ਵਿਚ ਚਮਕਦਾ ਹੈ, ਪਰ ਉਸ ਪਾਣੀ ਤੋਂ ਉਹ ਬਹੁਤ ਹੀ ਦੂਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Солнце отражается в воде, но находится далеко от неё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18807,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਮਹਿ ਜੋਤਿ ਰਹਿਆ ਭਰਪੂਰਿ ॥",
          "roman": "jal mah jot rahia bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਾਣੀ ਵਿਚ ਉਸ ਦੀ ਜੋਤਿ ਲਿਸ਼ਕਾਂ ਮਾਰਦੀ ਹੈ, ਇਸੇ ਤਰ੍ਹਾਂ ਪਰਮਾਤਮਾ ਦੀ ਜੋਤਿ ਸਭ ਜੀਵਾਂ ਵਿਚ ਹਰ ਥਾਂ ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "его свет сияет в воде, так же и свет Бога присутствует во всех существах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18808,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੁ ਨੇੜੈ ਕਿਸੁ ਆਖਾ ਦੂਰਿ ॥",
          "roman": "kis neṛē kis ākhā dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਹ ਪਰਮਾਤਮਾ ਨਿਰਲੇਪ ਭੀ ਹੈ, ਸਭ ਦੇ ਨੇੜੇ ਭੀ ਹੈ ਤੇ ਦੂਰ ਭੀ ਹੈ) ਮੈਂ ਇਹ ਨਹੀਂ ਦੱਸ ਸਕਦਾ ਕਿ ਉਹ ਕਿਸ ਦੇ ਨੇੜੇ ਹੈ ਤੇ ਕਿਸ ਤੋਂ ਦੂਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но невозможно сказать, кому Он близок, а от кого далёк."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18809,
          "is_rahao": false,
          "gurmukhi": "ਨਿਧਿ ਗੁਣ ਗਾਵਾ ਦੇਖਿ ਹਦੂਰਿ ॥੭॥",
          "roman": "nidh guṇ gāvā dekh hadūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਹਾਜ਼ਰ ਵੇਖ ਕੇ ਮੈਂ ਉਸ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹਾਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Видя Его повсюду присутствующим, я пою Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18810,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਅਵਰੁ ਨ ਕੋਇ ॥",
          "roman": "antar bāhar avar na koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਥਾਂ ਜੀਵਾਂ ਦੇ ਅੰਦਰ ਤੇ ਬਾਹਰ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри и снаружи нет никого кроме Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
