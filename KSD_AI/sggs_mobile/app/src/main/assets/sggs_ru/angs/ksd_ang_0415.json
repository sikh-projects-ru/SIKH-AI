{
  "ang": 415,
  "shabads": [
    {
      "shabad_id": 1605,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 18989,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਕਰਮ ਕਮਾਉ ॥",
          "roman": "gur parsādī karam kamāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਂ ਉਹੀ ਕੰਮ ਕਰਾਂ (ਜਿਨ੍ਹਾਂ ਕਰਕੇ ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪ੍ਰਾਪਤ ਹੋਵੇ),"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру я совершаю такие деяния, которые ведут к обретению Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18990,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਰਾਤਾ ਹਰਿ ਗੁਣ ਗਾਉ ॥੫॥",
          "roman": "nāme rātā har gun gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਹੋਇਆ ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਗੁਣ ਗਾਂਦਾ ਰਹਾਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и, окрашенный в Имя Бога, я воспеваю Его качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18991,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਆਪੁ ਪਛਾਤਾ ॥",
          "roman": "gur sevā te āp pachhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਦੱਸੀ ਹੋਈ ਸੇਵਾ ਦੀ ਰਾਹੀਂ ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣਾ ਅੰਦਰਲਾ ਆਤਮਕ ਜੀਵਨ ਪਛਾਣ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто через служение Гуру познал своё внутреннее состояние,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18992,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਵਸਿਆ ਸੁਖਦਾਤਾ ॥",
          "roman": "amrit nām vasiā sukh dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਮਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਆਤਮਕ ਆਨੰਦ ਦੇਣ ਵਾਲਾ ਹਰੀ-ਨਾਮ ਵੱਸ ਪਿਆ (ਸਮਝੋ)।"
            },
            "sahib_singh_ru": {
              "main": "в его уме обитает дающее блаженство Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18993,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਬਾਣੀ ਨਾਮੇ ਰਾਤਾ ॥੬॥",
          "roman": "anadin bāṇī nāme rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਦੀ ਰਾਹੀਂ ਹਰ ਰੋਜ਼ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "и через Бани он каждый день пребывает в окраске Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18994,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਪ੍ਰਭੁ ਲਾਏ ਤਾ ਕੋ ਲਾਗੈ ॥",
          "roman": "merā prabh lāe tā ko lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਖੇਡ ਜੀਵ ਦੇ ਵੱਸ ਦੀ ਨਹੀਂ) ਜਦੋਂ ਪਿਆਰਾ ਪ੍ਰਭੂ ਕਿਸੇ ਜੀਵ ਨੂੰ ਆਪਣੇ ਨਾਮ ਵਿਚ ਲਗਾਂਦਾ ਹੈ ਤਦੋਂ ਹੀ ਕੋਈ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но это не в руках человека — только когда Бог Сам привлекает, человек соединяется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18995,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਮਾਰੇ ਸਬਦੇ ਜਾਗੈ ॥",
          "roman": "haumē māre sabde jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਗੁਰ-ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਉਹ ਹਉਮੈ ਨੂੰ ਮਾਰ ਕੇ (ਇਸ ਵਲੋਂ ਸਦਾ) ਸੁਚੇਤ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и через Слово Гуру, уничтожив эго, он становится осознанным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18996,
          "is_rahao": false,
          "gurmukhi": "ਐਥੈ ਓਥੈ ਸਦਾ ਸੁਖੁ ਆਗੈ ॥੭॥",
          "roman": "ēthē othē sadā sukh āgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਫਿਰ ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਉਸ ਦੇ ਸਾਹਮਣੇ ਮੌਜੂਦ ਰਹਿੰਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "и тогда в этом и в том мире перед ним всегда пребывает блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18997,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਚੰਚਲੁ ਬਿਧਿ ਨਾਹੀ ਜਾਣੈ ॥",
          "roman": "man chanchal bidh nāhī jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਚੰਚਲ ਮਨ (ਹਉਮੈ ਨੂੰ ਮਾਰਨ ਦਾ) ਤਰੀਕਾ ਨਹੀਂ ਜਾਣ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Но беспокойный ум не знает способа победить эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18998,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਮੈਲਾ ਸਬਦੁ ਨ ਪਛਾਣੈ ॥",
          "roman": "manmukh mēlā shabad na pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਮਨਮੁਖਿ ਦਾ ਮਨ (ਵਿਕਾਰਾਂ ਨਾਲ ਸਦਾ) ਮੈਲਾ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨਾਲ ਸਾਂਝ ਨਹੀਂ ਪਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "ибо ум человека, обращённого к себе, загрязнён и не способен соединиться со Словом Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 18999,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਿਰਮਲੁ ਨਾਮੁ ਵਖਾਣੈ ॥੮॥",
          "roman": "gurmukh nirmal nām vakhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਦੱਸੇ ਰਾਹ ਤੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ ਤੇ ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲਾ ਹੁੰਦਾ ਹੈ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "А тот, кто следует пути Гуру, произносит Имя Бога и становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19000,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਆਗੈ ਕਰੀ ਅਰਦਾਸਿ ॥",
          "roman": "har jīo āgē karī ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਪ੍ਰਭੂ ਜੀ ਅੱਗੇ ਇਹ ਅਰਦਾਸਿ ਕਰਦਾ ਹਾਂ ਕਿ,"
            },
            "sahib_singh_ru": {
              "main": "Я возношу молитву перед Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19001,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਜਨ ਸੰਗਤਿ ਹੋਇ ਨਿਵਾਸੁ ॥",
          "roman": "sādhū jan sangat hoī nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮੇਰਾ ਨਿਵਾਸ ਬਣਿਆ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "пусть моё пребывание будет в обществе святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19002,
          "is_rahao": false,
          "gurmukhi": "ਕਿਲਵਿਖ ਦੁਖ ਕਾਟੇ ਹਰਿ ਨਾਮੁ ਪ੍ਰਗਾਸੁ ॥੯॥",
          "roman": "kilvikh dukh kāṭe har nām pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੇਰੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਚਮਕ ਪਏ, ਤੇ ਉਹ ਨਾਮ ਮੇਰੇ ਪਾਪ ਕਲੇਸ਼ ਕੱਟ ਦੇਵੇ ॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "и пусть Имя Бога озарит меня и уничтожит мои грехи и страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19003,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਬੀਚਾਰੁ ਆਚਾਰੁ ਪਰਾਤਾ ॥",
          "roman": "kar bīchār āchār parātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਗੁਰੂ ਦੀ ਬਾਣੀ ਨੂੰ ਵਿਚਾਰ ਕੇ ਚੰਗਾ ਆਚਰਨ ਬਣਾਣਾ ਸਮਝ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто размышляя над Бани Гуру, понимает правильное поведение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19004,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਬਚਨੀ ਏਕੋ ਜਾਤਾ ॥",
          "roman": "satgur bachnī eko jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਗੁਰੂ ਦੇ ਬਚਨਾਂ ਉਤੇ ਤੁਰ ਕੇ ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਸਾਂਝ ਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и, следуя словам Гуру, соединяется с Единым Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19005,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਮ ਨਾਮਿ ਮਨੁ ਰਾਤਾ ॥੧੦॥੭॥",
          "roman": "nānak rām nām man rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ। ਹੇ ਨਾਨਕ! ॥੧੦॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "его ум окрашен в Имя Бога, о Нанак!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1606,
      "rahao_verse_id": 19012,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 19006,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В раге Аса — Бани Гуру Нанака Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19007,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮੈਗਲੁ ਸਾਕਤੁ ਦੇਵਾਨਾ ॥",
          "roman": "man mēgal sākat devānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰ-ਸ਼ਬਦ ਤੋਂ ਖੁੰਝ ਕੇ (ਮਾਇਆ-ਵੇੜ੍ਹਿਆ) ਮਨ ਪਾਗਲ ਹਾਥੀ (ਸਮਾਨ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Отдалённый от Гур-Шабда, охваченный майей ум подобен безумному слону,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19008,
          "is_rahao": false,
          "gurmukhi": "ਬਨ ਖੰਡਿ ਮਾਇਆ ਮੋਹਿ ਹੈਰਾਨਾ ॥",
          "roman": "ban khaṇḍ māyā moh hērānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ (ਸੰਸਾਰ-) ਜੰਗਲ ਵਿਚ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и из-за привязанности к майе блуждает в лесу мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19009,
          "is_rahao": false,
          "gurmukhi": "ਇਤ ਉਤ ਜਾਹਿ ਕਾਲ ਕੇ ਚਾਪੇ ॥",
          "roman": "it ut jāh kāl ke chāpe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ) ਜਿਨ੍ਹਾਂ ਨੂੰ ਆਤਮਕ ਮੌਤ ਦਬਾ ਲੈਂਦੀ ਹੈ ਉਹ ਇਧਰ ਉਧਰ ਭਟਕਦੇ ਫਿਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те, кого подавляет духовная смерть, блуждают туда и сюда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19010,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਖੋਜਿ ਲਹੈ ਘਰੁ ਆਪੇ ॥੧॥",
          "roman": "gurmukh khoj lahē ghar āpe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੁੰਦਾ ਹੈ ਉਹ ਭਾਲ ਕੇ ਆਪਣੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦਾ ਟਿਕਾਣਾ ਲੱਭ ਲੈਂਦਾ ਹੈ (ਤੇ ਭਟਕਣਾ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто становится обращённым к Гуру, находит внутри себя обитель Бога и перестаёт блуждать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19011,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਸਬਦੈ ਮਨੁ ਨਹੀ ਠਉਰਾ ॥",
          "roman": "bin gur sabdē man nahī ṭhaurā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ (ਵਿਚ ਜੁੜਨ) ਤੋਂ ਬਿਨਾ ਮਨ ਇਕ ਥਾਂ ਟਿਕਿਆ ਨਹੀਂ ਰਹਿ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без соединения с Шабдом Гуру ум не может устояться на одном месте."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19012,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਹੁ ਰਾਮ ਨਾਮੁ ਅਤਿ ਨਿਰਮਲੁ ਅਵਰ ਤਿਆਗਹੁ ਹਉਮੈ ਕਉਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simrahu rām nām at nirmal avar tiāgah haumē kaurā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਮਨ ਨੂੰ ਟਿਕਾਣ ਵਾਸਤੇ ਗੁਰ-ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰੋ ਜੋ ਬਹੁਤ ਹੀ ਪਵਿਤ੍ਰ ਹੈ, ਅਤੇ ਹੋਰ ਰਸ ਛੱਡੋ ਜੋ ਕੌੜੇ ਭੀ ਹਨ ਤੇ ਹਉਮੈ ਨੂੰ ਵਧਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Чтобы ум обрёл устойчивость, вспоминай Имя Бога — оно чистейшее, и оставь прочие вкусы, которые горьки и усиливают эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19013,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਮੁਗਧੁ ਕਹਹੁ ਕਿਉ ਰਹਸੀ ॥",
          "roman": "ihu man mugadh kahah kiu rahsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੈਰਾਨ ਹੋਇਆ) ਇਹ ਮਨ ਆਪਣੀ ਸੂਝ ਗਵਾ ਲੈਂਦਾ ਹੈ, ਫਿਰ ਦੱਸੋ, ਇਹ ਭਟਕਣੋਂ ਕਿਵੇਂ ਰਹਿ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Этот ум, ошеломлённый майей, теряет разум — скажи, как он может не блуждать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19014,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਮਝੇ ਜਮ ਕਾ ਦੁਖੁ ਸਹਸੀ ॥",
          "roman": "bin samjhe jam kā dukh sahsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਅਸਲੇ ਦੀ ਸੂਝ ਤੋ ਬਿਨਾ ਇਹ ਮਨ ਆਤਮਕ ਮੌਤ ਦਾ ਦੁੱਖ ਸਹਾਰੇਗਾ ਹੀ।"
            },
            "sahib_singh_ru": {
              "main": "Без понимания своей сути этот ум неизбежно будет терпеть страдание духовной смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19015,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਬਖਸੇ ਸਤਿਗੁਰੁ ਮੇਲੈ ॥",
          "roman": "āpe bakhse satgur melē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਆਪ ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ, ਉਸ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кому Бог Сам дарует милость, тот встречает Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19016,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੁ ਕੰਟਕੁ ਮਾਰੇ ਸਚੁ ਪੇਲੈ ॥੨॥",
          "roman": "kāl kaṇṭak māre sach pelē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਦੁਖਦਾਈ ਆਤਮਕ ਮੌਤ ਨੂੰ ਸਹਾਰ ਲੈਂਦਾ ਹੈ, ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਉਸ ਨੂੰ ਆਤਮਕ ਜੀਵਨ ਵਲ) ਪ੍ਰੇਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "он преодолевает страдание духовной смерти, и Вечный Бог направляет его к духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19017,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਕਰਮਾ ਇਹੁ ਮਨੁ ਧਰਮਾ ॥",
          "roman": "ihu man karmā ihu man dharmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੈਰਾਨ ਹੋਇਆ) ਇਹ ਮਨ ਹੋਰ ਹੋਰ ਧਾਰਮਿਕ ਰਸਮਾਂ ਰੀਵਾਜ ਕਰਦਾ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот ум, запутавшийся в майе, занимается различными религиозными обрядами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19018,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਪੰਚ ਤਤੁ ਤੇ ਜਨਮਾ ॥",
          "roman": "ihu man pañch tat te janmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇਹ ਮਨ ਪੰਜਾਂ ਤੱਤਾਂ ਤੋਂ ਜੰਮਿਆ ਹੋਇਆ ਹੈ (ਭਾਵ, ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਲਈ ਫਿਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и он возник из пяти элементов, потому вращается в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19019,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਤੁ ਲੋਭੀ ਇਹੁ ਮਨੁ ਮੂੜਾ ॥",
          "roman": "sākat lobhī ihu man mūṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ-ਵੇੜ੍ਹਿਆ ਇਹ ਮਨ ਲਾਲਚੀ ਬਣ ਜਾਂਦਾ ਹੈ, ਮੂਰਖ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Погружённый в майю, этот ум становится жадным и глупым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19020,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਜਪੈ ਮਨੁ ਰੂੜਾ ॥੩॥",
          "roman": "gurmukh nām japē man rūṛā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ਉਸ ਦਾ ਮਨ ਸੁੰਦਰ (ਘਾੜਤ ਵਾਲਾ ਬਣ ਜਾਂਦਾ) ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обращается к Гуру и повторяет Имя, делает свой ум прекрасным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19021,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਮਨੁ ਅਸਥਾਨੇ ਸੋਈ ॥",
          "roman": "gurmukh man asthāne soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋਏ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਨੂੰ (ਆਪਣੇ ਅੰਦਰ) ਥਾਂ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ум обращённого к Гуру даёт место Богу внутри себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19022,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਤ੍ਰਿਭਵਣਿ ਸੋਝੀ ਹੋਈ ॥",
          "roman": "gurmukh tribhavan sojhī hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਸ ਪ੍ਰਭੂ ਦੀ ਸੂਝ ਹੋ ਜਾਂਦੀ ਹੈ ਜੋ ਤਿੰਨਾਂ ਭਵਨਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и он постигает Того, Кто пронизывает три мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19023,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਜੋਗੀ ਭੋਗੀ ਤਪੁ ਤਾਪੈ ॥",
          "roman": "ihu man jogī bhogī tap tāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੈਰਾਨ ਹੋਇਆ) ਇਹ ਮਨ ਕਦੇ ਜੋਗ-ਸਾਧਨ ਕਰਦਾ ਹੈ ਕਦੇ ਮਾਇਆ ਦੇ ਭੋਗ ਭੋਗਦਾ ਹੈ ਕਦੇ ਤਪਾਂ ਨਾਲ ਸਰੀਰ ਨੂੰ ਕਸ਼ਟ ਦੇਂਦਾ ਹੈ (ਪਰ ਆਤਮਕ ਆਨੰਦ ਉਸ ਨੂੰ ਕਿਤੇ ਨਹੀਂ ਲੱਭਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Этот ум то практикует йогу, то предаётся наслаждениям, то истязает тело аскезами, но духовной радости нигде не находит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19024,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਚੀਨੈੑ ਹਰਿ ਪ੍ਰਭੁ ਆਪੈ ॥੪॥",
          "roman": "gurmukh chīnhē har prabh āpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੁੰਦਾ ਹੈ ਉਹ ਹਰੀ ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ ਅੰਦਰ ਖੋਜ ਲੈਂਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Обращённый к Гуру человек находит Бога внутри себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19025,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਬੈਰਾਗੀ ਹਉਮੈ ਤਿਆਗੀ ॥",
          "roman": "man bērāgī haumē tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੈਰਾਨ ਹੋਇਆ) ਇਹ ਮਨ ਕਦੇ (ਆਪਣੇ ਵਲੋਂ) ਹਉਮੈ ਤਿਆਗ ਕੇ (ਦੁਨੀਆ ਛੱਡ ਕੇ) ਵੈਰਾਗਵਾਨ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Иногда этот ум, оставляя эго, становится отрешённым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19026,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਮਨਸਾ ਦੁਬਿਧਾ ਲਾਗੀ ॥",
          "roman": "ghaṭ ghaṭ mansā dubidhā lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਦੇ ਹਰੇਕ ਸਰੀਰ ਵਿਚ (ਮਾਇਆ-ਵੇੜ੍ਹੇ ਮਨ ਨੂੰ) ਮਾਇਕ ਫੁਰਨਾ ਤੇ ਦੁਬਿਧਾ ਆ ਚੰਬੜਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "а иногда в каждом теле его охватывают желания и двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19027,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣੁ ਗੁਰਮੁਖਿ ਚਾਖੈ ॥",
          "roman": "rām rasāiṇ gurmukh chākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਰਸਾਂ ਦਾ ਘਰ ਨਾਮ-ਰਸ ਚੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто в прибежище Гуру вкушает нектар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19028,
          "is_rahao": false,
          "gurmukhi": "ਦਰਿ ਘਰਿ ਮਹਲੀ ਹਰਿ ਪਤਿ ਰਾਖੈ ॥੫॥",
          "roman": "dar ghar mahlī har pat rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਅੰਦਰ ਬਾਹਰ ਮਹਲ ਦਾ ਮਾਲਕ-ਪ੍ਰਭੂ (ਦਿੱਸਦਾ ਹੈ) ਜੋ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਬਚਾ ਕੇ) ਉਸ ਦੀ ਇੱਜ਼ਤ ਰੱਖਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "видит Господа внутри и снаружи, и Он сохраняет его честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19029,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਰਾਜਾ ਸੂਰ ਸੰਗ੍ਰਾਮਿ ॥",
          "roman": "ihu man rājā sūr sangrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਹੈਰਾਨ ਹੋਇਆ) ਇਹ ਮਨ ਕਦੇ ਰਣ-ਭੂਮੀ ਵਿਚ ਰਾਜਾ ਤੇ ਸੂਰਮਾ ਬਣਿਆ ਪਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот ум иногда становится царём и воином на поле битвы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19030,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਨਿਰਭਉ ਗੁਰਮੁਖਿ ਨਾਮਿ ॥",
          "roman": "ihu man nirbhau gurmukh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਇਹ ਮਨ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਜੁੜਦਾ ਹੈ ਤਾਂ (ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਨਿਡਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но когда он соединяется с Именем через Гуру, становится бесстрашным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19031,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੇ ਪੰਚ ਅਪੁਨੈ ਵਸਿ ਕੀਏ ॥",
          "roman": "māre pañch apunē vas kīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮਾਦਿਕ ਪੰਜਾਂ (ਵੈਰੀਆਂ) ਨੂੰ ਮਾਰ ਦੇਂਦਾ ਹੈ, ਆਪਣੇ ਵੱਸ ਵਿਚ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "побеждает пять врагов и подчиняет их себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19032,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਗ੍ਰਾਸਿ ਇਕਤੁ ਥਾਇ ਕੀਏ ॥੬॥",
          "roman": "haumē grās ikat thāe kīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਨੂੰ ਮੁਕਾ ਕੇ ਇਹਨਾਂ ਸਭਨਾਂ ਨੂੰ ਇਕੋ ਥਾਂ ਵਿਚ (ਕਾਬੂ) ਕਰ ਲੈਂਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "устранив эго, собирает их под одним контролем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19033,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਗ ਸੁਆਦ ਅਨ ਤਿਆਗੇ ॥",
          "roman": "gurmukh rāg suād an tiāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋਇਆ ਇਹ ਮਨ ਰਾਗ (ਦ੍ਵੈਖ) ਤੇ ਹੋਰ ਹੋਰ ਸੁਆਦ ਤਿਆਗ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Обращённый к Гуру ум отказывается от привязанностей и прочих вкусов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19034,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਇਹੁ ਮਨੁ ਭਗਤੀ ਜਾਗੇ ॥",
          "roman": "gurmukh ihu man bhagtī jāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਇਹ ਮਨ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਵਿਚ ਜੁੜ ਕੇ (ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਵਲੋਂ) ਸੁਚੇਤ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и пробуждается в преданности Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19035,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਸੁਣਿ ਮਾਨਿਆ ਸਬਦੁ ਵੀਚਾਰੀ ॥",
          "roman": "anhad suṇ māniā sabad vīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਆਪਣੇ ਸੋਚ-ਮੰਡਲ ਵਿਚ ਟਿਕਾਂਦਾ ਹੈ, ਉਹ (ਅੰਦਰਲੇ ਆਤਮਕ ਖੇੜੇ ਦੇ) ਇਕ-ਰਸ (ਹੋ ਰਹੇ ਗੀਤ) ਨੂੰ ਸੁਣ ਸੁਣ ਕੇ (ਉਸ ਵਿਚ) ਗਿੱਝ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто удерживает Шабд в размышлении, слушает внутреннюю беззвучную мелодию и утверждается в ней,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19036,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮੁ ਚੀਨਿੑ ਭਏ ਨਿਰੰਕਾਰੀ ॥੭॥",
          "roman": "ātam chīnh bhaye nirankārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਆਪੇ ਨੂੰ ਖੋਜ ਕੇ ਪਰਮਾਤਮਾ ਰੂਪ ਹੋ ਜਾਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "познав себя, становится единым с Бесформенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19037,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਨਿਰਮਲੁ ਦਰਿ ਘਰਿ ਸੋਈ ॥",
          "roman": "ihu man nirmal dar ghar soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ) ਇਹ ਮਨ (ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੁੰਦਾ ਹੈ ਤਦੋਂ) ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਇਸ ਨੂੰ ਅੰਦਰ ਬਾਹਰ ਉਹ ਪਰਮਾਤਮਾ ਹੀ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда ум становится чистым и видит Бога внутри и снаружи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19038,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਭਗਤਿ ਭਾਉ ਧੁਨਿ ਹੋਈ ॥",
          "roman": "gurmukh bhagat bhāu dhun hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ (ਇਸ ਮਨ ਦੇ ਅੰਦਰ) ਭਗਤੀ ਦੀ ਲਗਨ ਲੱਗ ਪੈਂਦੀ ਹੈ, (ਇਸ ਦੇ ਅੰਦਰ ਪ੍ਰਭੂ ਦਾ) ਪਿਆਰ (ਜਾਗ ਪੈਂਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "В нём возникает мелодия преданности и любовь к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19039,
          "is_rahao": false,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਹਰਿ ਜਸੁ ਗੁਰ ਪਰਸਾਦਿ ॥",
          "roman": "ahinīs har jas gur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕ੍ਰਿਪਾ ਨਾਲ ਇਹ ਮਨ ਦਿਨ ਰਾਤ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру он день и ночь воспевает Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19040,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸੋ ਪ੍ਰਭੁ ਆਦਿ ਜੁਗਾਦਿ ॥੮॥",
          "roman": "ghaṭ ghaṭ so prabh ād jugād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਪਰਮਾਤਮਾ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਮੁੱਢ ਹੈ ਜੋ ਪਰਮਾਤਮਾ ਜੁਗਾਂ ਦੇ ਮੁੱਢ ਤੋਂ ਮੌਜੂਦ ਹੈ ਉਹ ਇਸ ਮਨ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੱਸਦਾ ਦਿੱਸ ਪੈਂਦਾ ਹੈ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "И он видит Того, Кто существует с начала времён, во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19041,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣਿ ਇਹੁ ਮਨੁ ਮਾਤਾ ॥",
          "roman": "rām rasāiṇ ihu man mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋ ਕੇ ਇਹ ਮਨ ਰਸਾਂ ਦੇ ਘਰ ਨਾਮ-ਰਸ ਵਿਚ ਮਸਤ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Обращённый к Гуру ум опьяняется нектаром Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19042,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਰਸਾਇਣੁ ਗੁਰਮੁਖਿ ਜਾਤਾ ॥",
          "roman": "sarab rasāiṇ gurmukh jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੋਇਆ ਇਹ ਮਨ ਸਭ ਰਸਾਂ ਦੇ ਸੋਮੇ ਪ੍ਰਭੂ ਨੂੰ ਪਛਾਣ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и узнаёт Бога как источник всех вкусов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19043,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਹੇਤੁ ਗੁਰ ਚਰਣ ਨਿਵਾਸਾ ॥",
          "roman": "bhagat het gur charan nivāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ (ਇਸ ਮਨ ਦਾ) ਨਿਵਾਸ ਹੁੰਦਾ ਹੈ ਤਾਂ (ਇਸ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦੀ) ਭਗਤੀ ਦਾ ਪ੍ਰੇਮ (ਜਾਗ ਪੈਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Когда ум пребывает у стоп Гуру, в нём пробуждается любовь к преданности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19044,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਜਨ ਕੇ ਦਾਸਨਿ ਦਾਸਾ ॥੯॥੮॥",
          "roman": "nānak har jan ke dāsan dāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਤਦੋਂ ਇਹ ਮਨ ਗੁਰਮੁਖਾਂ ਦੇ ਦਾਸਾਂ ਦਾ ਦਾਸ ਬਣ ਜਾਂਦਾ ਹੈ ॥੯॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тогда он становится слугой слуг людей Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
