{
  "ang": 416,
  "shabads": [
    {
      "shabad_id": 1607,
      "rahao_verse_id": 19051,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 19045,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ॥",
          "roman": "āsā mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਆਸਾ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "В рааге Аса — бани Гуру Нанак Дев Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19046,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਬਿਨਸੈ ਧਨੁ ਕਾ ਕੋ ਕਹੀਐ ॥",
          "roman": "tan binsē dhan kā ko kahīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ ਦਾ ਸਰੀਰ ਬਿਨਸ ਜਾਂਦਾ ਹੈ ਤਦੋਂ (ਉਸ ਦਾ ਕਮਾਇਆ ਹੋਇਆ) ਧਨ ਉਸ ਦਾ ਨਹੀਂ ਕਿਹਾ ਜਾ ਸਕਦਾ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਅਸਲ ਧਨ ਹੈ ਜੋ ਮਨੁੱਖਾ ਸਰੀਰ ਦੇ ਨਾਸ ਹੋਣ ਪਿਛੋਂ ਭੀ ਆਪਣੇ ਨਾਲ ਲੈ ਜਾ ਸਕਦਾ ਹੈ, ਪਰ),"
            },
            "sahib_singh_ru": {
              "main": "Когда тело человека разрушается, тогда накопленное им богатство уже нельзя назвать его собственным (истинным богатством является Имя Бога, которое можно унести с собой и после разрушения тела, но)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19047,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਗੁਰ ਰਾਮ ਨਾਮੁ ਕਤ ਲਹੀਐ ॥",
          "roman": "bin gur rām nām kat lahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਧਨ ਗੁਰੂ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਹੋਰ ਪਾਸੋਂ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Но богатство Имени Бога невозможно получить ни откуда, кроме как от Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19048,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਧਨੁ ਸੰਗਿ ਸਖਾਈ ॥",
          "roman": "rām nām dhan sang sakhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਧਨ ਹੀ ਮਨੁੱਖ ਦੇ ਨਾਲ ਅਸਲ ਸਾਥੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только богатство Имени Бога является истинным спутником человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19049,
          "is_rahao": false,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਨਿਰਮਲੁ ਹਰਿ ਲਿਵ ਲਾਈ ॥੧॥",
          "roman": "ahinis nirmal har liv lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਦਿਨ ਰਾਤ ਆਪਣੀ ਸੁਰਤਿ ਪ੍ਰਭੂ (-ਚਰਨਾਂ) ਵਿਚ ਜੋੜਦਾ ਹੈ ਉਸ ਦਾ ਜੀਵਨ ਪਵਿਤ੍ਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который днём и ночью соединяет своё сознание с Богом, становится чистым ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19050,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਬਿਨੁ ਕਵਨੁ ਹਮਾਰਾ ॥",
          "roman": "rām nām bin kavan hamārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਸਾਡਾ (ਜੀਵਾਂ ਦਾ) ਹੋਰ ਕੇਹੜਾ (ਸਦੀਵੀ ਮਿੱਤਰ) ਹੋ ਸਕਦਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога кто ещё может быть нашим (вечным другом)?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19051,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖ ਦੁਖ ਸਮ ਕਰਿ ਨਾਮੁ ਨ ਛੋਡਉ ਆਪੇ ਬਖਸਿ ਮਿਲਾਵਣਹਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukh dukh sam kar nām na chhodau āpe bakhas milāvaṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੁਖ ਤੇ ਦੁਖ ਉਸੇ ਪ੍ਰਭੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਆਉਂਦੇ ਹਨ, ਇਸ ਵਾਸਤੇ) ਸੁਖ ਤੇ ਦੁਖ ਨੂੰ ਇਕੋ ਜਿਹਾ (ਉਸ ਦੀ ਰਜ਼ਾ ਸਮਝ ਕੇ) ਮੈਂ (ਕਦੇ) ਉਸ ਦਾ ਨਾਮ ਨਹੀਂ ਛੱਡਾਂਗਾ। (ਮੈਨੂੰ ਨਿਸਚਾ ਹੈ ਕਿ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਮੇਹਰ ਕਰ ਕੇ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਜੋੜਨ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Считая счастье и страдание одинаковыми (как волю Бога), я никогда не оставлю Его Имя. (Я уверен, что) Сам Бог по милости соединяет (с Собой) ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19052,
          "is_rahao": false,
          "gurmukhi": "ਕਨਿਕ ਕਾਮਨੀ ਹੇਤੁ ਗਵਾਰਾ ॥",
          "roman": "kanik kāmanī het gavārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮੂਰਖ ਹਨ ਜੋ ਸੋਨੇ ਤੇ ਇਸਤ੍ਰੀ ਨਾਲ ਹੀ ਮੋਹ ਵਧਾ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Глупцы — те, кто привязан к золоту и женщине,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19053,
          "is_rahao": false,
          "gurmukhi": "ਦੁਬਿਧਾ ਲਾਗੇ ਨਾਮੁ ਵਿਸਾਰਾ ॥",
          "roman": "dubidhā lāge nām visārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਭੁਲਾ ਕੇ ਭਟਕਣਾ ਵਿਚ ਪਏ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "и, забыв Имя Бога, погружены в двойственность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19054,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂੰ ਬਖਸਹਿ ਨਾਮੁ ਜਪਾਇ ॥",
          "roman": "jis tū bakhsah nām japāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜੀਵ ਨੂੰ ਤੂੰ ਆਪਣਾ ਨਾਮ ਜਪਾ ਕੇ (ਨਾਮ ਦੀ ਦਾਤਿ) ਬਖ਼ਸ਼ਦਾ ਹੈਂ, ਉਹ ਤੇਰੇ ਗੁਣ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому существу, которому Ты даруешь повторение Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19055,
          "is_rahao": false,
          "gurmukhi": "ਦੂਤੁ ਨ ਲਾਗਿ ਸਕੈ ਗੁਨ ਗਾਇ ॥੨॥",
          "roman": "dūt na lāg sakē gun gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਮਦੂਤ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕ ਸਕਦਾ ਆਤਮਕ ਮੌਤ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦੀ ('ਕਨਿਕ ਕਾਮਨੀ ਹੇਤੁ' ਉਸ ਦੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਮਾਰ ਨਹੀਂ ਸਕਦਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "посланник смерти не может приблизиться; он воспевает Твои качества ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19056,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਰੁ ਦਾਤਾ ਰਾਮ ਗੁਪਾਲਾ ॥",
          "roman": "har gur dātā rām gupālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਰਾਮ! ਹੇ ਹਰੀ! ਹੇ ਗੁਪਾਲ! ਤੂੰ ਹੀ ਸਭ ਤੋਂ ਵੱਡਾ ਦਾਤਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Рам! О Хари! О Гопал! Ты — величайший даритель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19057,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਾਖੁ ਦਇਆਲਾ ॥",
          "roman": "jiu bhāvē tiu rākh dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਤੈਨੂੰ ਚੰਗਾ ਲਗੇ ਤਿਵੇਂ, ਹੇ ਦਇਆਲ! ਮੈਨੂੰ ('ਕਨਿਕ ਕਾਮਨੀ ਹੇਤ' ਤੋਂ) ਬਚਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "Как Тебе угодно, так и храни меня, о Милостивый."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19058,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਮੁ ਮੇਰੈ ਮਨਿ ਭਾਇਆ ॥",
          "roman": "gurmukh rām merē man bhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ (ਦਾ ਨਾਮ) ਮੇਰੇ ਮਨ ਵਿਚ ਪਿਆਰਾ ਲੱਗਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Через Гуру Имя Бога стало дорогим моему сердцу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19059,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗ ਮਿਟੇ ਦੁਖੁ ਠਾਕਿ ਰਹਾਇਆ ॥੩॥",
          "roman": "rog miṭe dukh ṭhāk rahāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ (ਆਤਮਕ) ਰੋਗ ਮਿਟ ਗਏ ਹਨ (ਆਤਮਕ ਮੌਤ ਵਾਲਾ) ਦੁੱਖ ਮੈਂ ਰੋਕ ਲਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "мои духовные болезни исчезли, и страдание остановлено ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19060,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰੁ ਨ ਅਉਖਧੁ ਤੰਤ ਨ ਮੰਤਾ ॥",
          "roman": "avar na aukhadh tant na mantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "('ਕਨਿਕ ਕਾਮਨੀ ਹੇਤ' ਦੇ ਰੋਗ ਤੋਂ ਬਚਾਣ ਵਾਲਾ ਪ੍ਰਭੂ-ਨਾਮ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਕੋਈ ਦਾਰੂ ਨਹੀਂ ਹੈ, ਕੋਈ ਮੰਤ੍ਰ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Нет другого лекарства и нет никакого иного средства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19061,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਸਿਮਰਣੁ ਕਿਲਵਿਖ ਹੰਤਾ ॥",
          "roman": "har har simraṇ kilvikh hantā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸਿਮਰਨ ਹੀ ਸਾਰੇ ਪਾਪਾਂ ਦਾ ਨਾਸ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только памятование Имени Бога уничтожает все грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19062,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਆਪਿ ਭੁਲਾਵਹਿ ਨਾਮੁ ਵਿਸਾਰਿ ॥",
          "roman": "tū āp bhulāvah nām visār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਅਸੀਂ ਜੀਵ ਕੀਹ ਕਰ ਸਕਦੇ ਹਾਂ?) ਤੂੰ ਆਪ ਸਾਡੇ ਮਨਾਂ ਤੋਂ (ਆਪਣਾ) ਨਾਮ ਭੁਲਾ ਕੇ ਸਾਨੂੰ ਕੁਰਾਹੇ ਪਾਂਦਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты Сам заставляешь нас забывать Твоё Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19063,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਆਪੇ ਰਾਖਹਿ ਕਿਰਪਾ ਧਾਰਿ ॥੪॥",
          "roman": "tū āpe rākhe kirpā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਤੂੰ ਆਪ ਹੀ ਮੇਹਰ ਕਰ ਕੇ ਸਾਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਾਂਦਾ ਹੈਂ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и Сам по милости защищаешь от пороков ॥੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19064,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਭਰਮੁ ਭੇਦੁ ਮਨਿ ਦੂਜਾ ॥",
          "roman": "rog bharam bhed man dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਇਹ ਰੋਗ ਹੈ, ਭਟਕਣਾ ਹੈ, ਪ੍ਰਭੂ ਨਾਲੋਂ ਵਿੱਥ ਹੈ, ਮੇਰ-ਤੇਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Это болезнь — сомнение, разделение, двойственность в уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19065,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਬਿਨੁ ਭਰਮਿ ਜਪਹਿ ਜਪੁ ਦੂਜਾ ॥",
          "roman": "gur bin bharam japah jap dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਬਿਨਾ ਜੇਹੜੇ ਮਨੁੱਖ ਕੁਰਾਹੇ ਪੈ ਕੇ ਦੂਜਾ ਜਪ ਜਪਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "когда без Гуру люди в заблуждении повторяют иное."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19066,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖ ਗੁਰ ਦਰਸ ਨ ਦੇਖਹਿ ॥",
          "roman": "ād purakh gur daras na dekhah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਕਦੇ ਗੁਰੂ ਦਾ ਦਰਸ਼ਨ ਨਹੀਂ ਕਰਦੇ ਸਭ ਦੇ ਮੁੱਢ ਸਰਬ-ਵਿਆਪਕ ਦਾ ਦਰਸ਼ਨ ਨਹੀਂ ਕਰਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто не видят Гуру, не видят и изначального Всепронизывающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19067,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਗੁਰ ਸਬਦੈ ਜਨਮੁ ਕਿ ਲੇਖਹਿ ॥੫॥",
          "roman": "viṇ gur sabdē janam ki lekhah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਨ ਤੋਂ ਬਿਨਾ ਉਹਨਾਂ ਦਾ ਜਨਮ ਕਿਸੇ ਭੀ ਲੇਖੇ ਵਿਚ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Без Шабда Гуру их рождение не имеет ценности ॥੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19068,
          "is_rahao": false,
          "gurmukhi": "ਦੇਖਿ ਅਚਰਜੁ ਰਹੇ ਬਿਸਮਾਦਿ ॥",
          "roman": "dekh acharaj rahe bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੈਨੂੰ ਅਚਰਜ-ਰੂਪ ਨੂੰ ਵੇਖ ਕੇ ਅਸੀਂ ਜੀਵ ਹੈਰਾਨ ਹੁੰਦੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Увидев Твою чудесную форму, мы изумляемся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19069,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸੁਰ ਨਰ ਸਹਜ ਸਮਾਧਿ ॥",
          "roman": "ghaṭ ghaṭ sur nar sahaj samādh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈਂ, ਦੇਵਤਿਆਂ ਵਿਚ ਮਨੁੱਖਾਂ ਵਿਚ ਹਰੇਕ ਵਿਚ ਸੁਤੇ ਹੀ ਅਡੋਲ ਟਿਕਿਆ ਹੋਇਆ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты пребываешь в каждом, среди богов и людей, в естественном покое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19070,
          "is_rahao": false,
          "gurmukhi": "ਭਰਿਪੁਰਿ ਧਾਰਿ ਰਹੇ ਮਨ ਮਾਹੀ ॥",
          "roman": "bharipur dhār rahe man māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਹਰੇਕ ਜੀਵ ਦੇ ਮਨ ਵਿਚ ਭਰਪੂਰ ਹੈਂ, ਤੇ ਹਰੇਕ ਨੂੰ ਸਹਾਰਾ ਦੇ ਰਿਹਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты полностью наполняешь сердца всех и поддерживаешь каждого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19071,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਸਮਸਰਿ ਅਵਰੁ ਕੋ ਨਾਹੀ ॥੬॥",
          "roman": "tum samsar avar ko nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਬਰਾਬਰ ਹੋਰ ਕੋਈ ਨਹੀਂ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Нет никого равного Тебе ॥੬॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19072,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਭਗਤਿ ਹੇਤੁ ਮੁਖਿ ਨਾਮੁ ॥",
          "roman": "jā kī bhagat het mukh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਉਹਨਾਂ ਸੰਤਾਂ ਭਗਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਿਲਦਾ ਹੈ ਜਿਨ੍ਹਾਂ ਦੇ ਮੂੰਹ ਵਿਚ (ਸਦਾ ਉਸ ਦਾ) ਨਾਮ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог встречается в обществе тех, чьи уста наполнены Его Именем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19073,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਭਗਤ ਕੀ ਸੰਗਤਿ ਰਾਮੁ ॥",
          "roman": "sant bhagat kī sangat rām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਸੰਤ ਜਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਸ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਵਾਸਤੇ ਪ੍ਰੇਮ ਹੈ ਖਿੱਚ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В сердцах этих святых есть любовь к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19074,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਤੋਰੇ ਸਹਜਿ ਧਿਆਨੁ ॥",
          "roman": "bandhan tore sahaj dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਡੋਲ ਅਵਸਥਾ ਵਿਚ (ਟਿਕ ਕੇ, ਪ੍ਰਭੂ ਦਾ) ਧਿਆਨ (ਧਰ ਕੇ ਸੰਤ ਜਨ 'ਕਨਿਕ ਕਾਮਨੀ' ਵਾਲੇ) ਬੰਧਨ ਤੋੜ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в естественном состоянии и медитируя, они разрывают оковы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19075,
          "is_rahao": false,
          "gurmukhi": "ਛੂਟੈ ਗੁਰਮੁਖਿ ਹਰਿ ਗੁਰ ਗਿਆਨੁ ॥੭॥",
          "roman": "chhūṭē gurmukh har gur giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਹੁੰਦਾ ਹੈ ਜਿਸ ਦੇ ਅੰਦਰ ਗੁਰੂ ਦਾ ਦਿੱਤਾ ਰੱਬੀ ਗਿਆਨ ਪਰਗਟ ਹੁੰਦਾ ਹੈ ਉਹ ਭੀ ਇਹਨਾਂ ਬੰਧਨਾਂ ਤੋਂ ਮੁਕਤ ਹੋ ਜਾਂਦਾ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Гурмух, обладающий знанием от Гуру, также освобождается ॥੭॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19076,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਜਮਦੂਤ ਦੂਖੁ ਤਿਸੁ ਲਾਗੈ ॥",
          "roman": "nā jamdūt dūkh tis lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਨੂੰ ਜਮਦੂਤਾਂ ਦਾ ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ (ਮੌਤ ਦਾ ਡਰ, ਆਤਮਕ ਮੌਤ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁੱਕਦੀ),"
            },
            "sahib_singh_ru": {
              "main": "Его не касается страдание от посланников смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19077,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨੁ ਰਾਮ ਨਾਮਿ ਲਿਵ ਜਾਗੈ ॥",
          "roman": "jo jan rām nām liv jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਲਿਵ ਲਾ ਲਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "кто пребывает в любви к Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19078,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਵਛਲੁ ਭਗਤਾ ਹਰਿ ਸੰਗਿ ॥",
          "roman": "bhagat vachhal bhagtā har sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ ਨਾਲ ਪਿਆਰ ਕਰਨ ਵਾਲਾ ਪਰਮਾਤਮਾ ਆਪਣੇ ਭਗਤਾਂ ਦੇ ਅੰਗ-ਸੰਗ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Любящий преданных Бог всегда с ними."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19079,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮੁਕਤਿ ਭਏ ਹਰਿ ਰੰਗਿ ॥੮॥੯॥",
          "roman": "nānak mukat bhaye har rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦੇ ਭਗਤ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ-ਰੰਗ ਵਿਚ (ਰੰਗੀਜ ਕੇ, ਬੰਧਨਾਂ ਤੋਂ) ਆਜ਼ਾਦ ਹੋ ਜਾਂਦੇ ਹਨ ॥੮॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Преданные, окрашенные в любовь Бога, становятся свободными ॥੮॥੯॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1608,
      "rahao_verse_id": 19084,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 19080,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਹਲਾ ੧ ਇਕਤੁਕੀ ॥",
          "roman": "āsā mehlā 1 iktukī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19081,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਸੇਵੇ ਸੋ ਠਾਕੁਰ ਜਾਨੈ ॥",
          "roman": "gur sevē so ṭhākur jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਦੱਸੇ ਅਨੁਸਾਰ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਹੈ, ਉਹ ਪਰਮਾਤਮਾ ਨੂੰ (ਹਰ ਥਾਂ ਵਿਆਪਕ) ਜਾਣ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто следует Гуру, познаёт Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19082,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਮਿਟੈ ਸਚੁ ਸਬਦਿ ਪਛਾਨੈ ॥੧॥",
          "roman": "dūkh miṭē sach sabad pachhānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਹਰ ਥਾਂ) ਪਛਾਣ ਲੈਂਦਾ ਹੈ, ਤੇ (ਇਸ ਤਰ੍ਹਾਂ ਉਸ ਦਾ ਮੋਹ ਦਾ) ਦੁੱਖ ਮਿਟ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он узнаёт Истинного через Шабд и избавляется от страдания ॥੧॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19083,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮੁ ਜਪਹੁ ਮੇਰੀ ਸਖੀ ਸਖੈਨੀ ॥",
          "roman": "rām japah merī sakhī sakhēnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ ਸਹੇਲੀਹੋ! (ਹੇ ਮੇਰੇ ਸਤਸੰਗੀਓ!) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪੋ,"
            },
            "sahib_singh_ru": {
              "main": "О мои подруги! Повторяйте Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19084,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸੇਵਿ ਦੇਖਹੁ ਪ੍ਰਭੁ ਨੈਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "satgur sev dekhah prabh nēnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਦੱਸੀ ਹੋਈ (ਇਹ) ਸੇਵਾ ਕਰ ਕੇ (ਭਾਵ, ਗੁਰੂ ਦੀ ਸਿੱਖਿਆ ਅਨੁਸਾਰ ਪ੍ਰਭੂ ਦਾ ਭਜਨ ਕਰ ਕੇ) ਤੁਸੀ (ਹਰ ਥਾਂ) ਪਰਮਾਤਮਾ ਦਾ ਦਰਸ਼ਨ ਕਰੋਗੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "служа Гуру, вы увидите Бога своими глазами ॥੧॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19085,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਮਾਤ ਪਿਤਾ ਸੰਸਾਰਿ ॥",
          "roman": "bandhan māt pitā sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਨ ਤੋਂ ਬਿਨਾ) ਸੰਸਾਰ ਵਿਚ ਮਾਂ, ਪਿਉ, ਬੰਧਨਾਂ ਦਾ ਕਾਰਣ ਬਣ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Бога мать и отец становятся узами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19086,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਸੁਤ ਕੰਨਿਆ ਅਰੁ ਨਾਰਿ ॥੨॥",
          "roman": "bandhan sut kanniā ar nār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪੁੱਤਰ, ਧੀ ਅਤੇ ਵਹੁਟੀ (ਮੋਹ ਦੇ) ਵੀ ਬੰਧਨਾਂ ਦਾ ਕਾਰਣ ਬਣ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так же как сын, дочь и жена ॥੨॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19087,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਰਮ ਧਰਮ ਹਉ ਕੀਆ ॥",
          "roman": "bandhan karam dharam hau kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ) ਧਾਰਮਿਕ ਰਸਮਾਂ ਬੰਧਨ ਬਣ ਜਾਂਦੀਆਂ ਹਨ, (ਮਨੁੱਖ ਮਾਣ ਕਰਦਾ ਹੈ ਕਿ ਇਹ ਸਭ ਕੁਝ) 'ਮੈਂ ਕੀਤਾ ਹੈ, ਮੈਂ ਕੀਤਾ ਹੈ'।"
            },
            "sahib_singh_ru": {
              "main": "Религиозные действия становятся узами, когда есть мысль «я сделал»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19088,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਪੁਤੁ ਕਲਤੁ ਮਨਿ ਬੀਆ ॥੩॥",
          "roman": "bandhan put kalat man bīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਮਨ ਵਿਚ (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ) ਦੂਜਾ ਪ੍ਰੇਮ ਹੈ, ਤਾਂ ਪੁੱਤਰ ਵਹੁਟੀ (ਦਾ ਰਿਸ਼ਤਾ ਭੀ) ਬੰਧਨਾਂ (ਦਾ ਮੂਲ ਹੋ ਜਾਂਦਾ) ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Если в уме есть другая любовь, то и семья становится узами ॥੩॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19089,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਿਰਖੀ ਕਰਹਿ ਕਿਰਸਾਨ ॥",
          "roman": "bandhan kirakhī karah kirsān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸਾਨ (ਆਜੀਵਕਾ ਵਾਸਤੇ) ਖੇਤੀ-ਵਾਹੀ ਕਰਦੇ ਹਨ (ਕਰਨੀ ਭੀ ਚਾਹੀਦੀ ਹੈ, ਪਰ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਇਹ ਖੇਤੀ-ਵਾਹੀ) ਬੰਧਨ ਬਣ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Земледелие становится узами без памятования Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19090,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਡੰਨੁ ਸਹੈ ਰਾਜਾ ਮੰਗੈ ਦਾਨ ॥੪॥",
          "roman": "haumē ḍann sahē rājā mangē dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜਾ (ਕਿਸਾਨਾਂ ਪਾਸੋਂ) ਮਾਮਲਾ ਲੈਂਦਾ ਹੈ, (ਪਰ ਪਰਮਾਤਮਾ ਦੇ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਰਾਜਾ) ਹਉਮੈ ਦੀ ਸਜ਼ਾ ਭੁਗਤਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Царь взимает налоги, но без памятования страдает от эго ॥੪॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19091,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਸਉਦਾ ਅਣਵੀਚਾਰੀ ॥",
          "roman": "bandhan saudā aṇvīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਵਪਾਰੀ ਦਾ ਵਪਾਰ ਬੰਧਨਾਂ ਦਾ ਮੂਲ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Торговля без размышления о Боге — источник оков,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19092,
          "is_rahao": false,
          "gurmukhi": "ਤਿਪਤਿ ਨਾਹੀ ਮਾਇਆ ਮੋਹ ਪਸਾਰੀ ॥੫॥",
          "roman": "tripat nāhī māiā moh pasārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਖਿਲਾਰੇ ਵਿਚ (ਇਤਨਾ ਫਸਦਾ ਹੈ ਕਿ ਮਾਇਆ ਵਲੋਂ) ਰੱਜਦਾ ਨਹੀਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "ибо человек не насыщается в привязанности к майе ॥੫॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19093,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਸਾਹ ਸੰਚਹਿ ਧਨੁ ਜਾਇ ॥",
          "roman": "bandhan sāh sanchah dhan jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ਾਹ-ਸੌਦਾਗਰ (ਸੌਦਾਗਰੀ ਕਰ ਕੇ) ਧਨ ਇਕੱਠਾ ਕਰਦੇ ਹਨ, ਧਨ (ਆਖ਼ਰ) ਸਾਥ ਛੱਡ ਜਾਂਦਾ ਹੈ (ਪਰ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਧਨ) ਬੰਧਨ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Торговцы накапливают богатство, но оно уходит и становится узами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19094,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਭਗਤਿ ਨ ਪਵਈ ਥਾਇ ॥੬॥",
          "roman": "bin har bhagat na pavī thai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਤੋਂ ਬਿਨਾ (ਉਹਨਾਂ ਦਾ ਕੋਈ ਉੱਦਮ ਪਰਮਾਤਮਾ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ) ਪਰਵਾਨ ਨਹੀਂ ਹੁੰਦਾ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Без преданности Богу их дела не принимаются ॥੬॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19095,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਬੇਦੁ ਬਾਦੁ ਅਹੰਕਾਰ ॥",
          "roman": "bandhan bed bād ahankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ) ਵੇਦ-ਪਾਠ ਤੇ ਵੇਦ-ਰਚਨਾ ਭੀ ਅਹੰਕਾਰ ਪੈਦਾ ਕਰਦਾ ਹਨ ਤੇ ਬੰਧਨਾਂ ਦਾ ਮੂਲ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Даже изучение Вед становится причиной эго и оков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19096,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨਿ ਬਿਨਸੈ ਮੋਹ ਵਿਕਾਰ ॥੭॥",
          "roman": "bandhan binsē moh vikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੋਹ ਦੇ ਬੰਧਨ ਵਿਚ ਵਿਕਾਰਾਂ ਦੇ ਬੰਧਨ ਵਿਚ (ਫਸ ਕੇ) ਮਨੁੱਖ ਦੀ ਆਤਮਕ ਮੌਤ ਹੋ ਜਾਂਦੀ ਹੈ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "В оковах привязанности человек духовно погибает ॥੭॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19097,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਮ ਨਾਮ ਸਰਣਾਈ ॥",
          "roman": "nānak rām nām saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੇਹੜੇ ਮਨੁੱਖ (ਦੁਨੀਆ ਦੀ ਹਰੇਕ ਕਿਸਮ ਦੀ ਕਿਰਤ-ਕਾਰ ਵਿਚ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਆਸਰਾ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Те, кто принимают прибежище Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 19098,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਰਾਖੇ ਬੰਧੁ ਨ ਪਾਈ ॥੮॥੧੦॥",
          "roman": "satgur rākhe band na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਨੇ ਉਹਨਾਂ ਨੂੰ ਮੋਹ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਰੱਖ ਲਿਆ (ਸਮਝੋ) ਉਹਨਾਂ ਨੂੰ ਕੋਈ ਬੰਧਨ ਨਹੀਂ ਪੈਂਦਾ ॥੮॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру сохраняет их, и они не попадают в оковы ॥੮॥੧੦॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
