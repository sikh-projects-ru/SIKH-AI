{
  "ang": 466,
  "shabads": [
    {
      "shabad_id": 1702,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20919,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖਮ ਮੂਰਤਿ ਨਾਮੁ ਨਿਰੰਜਨ ਕਾਇਆ ਕਾ ਆਕਾਰੁ ॥",
          "roman": "sūkham mūrat nām nirañjan kāiā kā ākār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя незапятнанного Господа — тонкая, невидимая сущность, но телесный облик видим и оформлен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20920,
          "is_rahao": false,
          "gurmukhi": "ਸਤੀਆ ਮਨਿ ਸੰਤੋਖੁ ਉਪਜੈ ਦੇਣੈ ਕੈ ਵੀਚਾਰਿ ॥",
          "roman": "satīā man santokh upjē dēṇē kē vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В умах благородных рождается довольство, когда они размышляют о даянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20921,
          "is_rahao": false,
          "gurmukhi": "ਦੇ ਦੇ ਮੰਗਹਿ ਸਹਸਾ ਗੂਣਾ ਸੋਭ ਕਰੇ ਸੰਸਾਰੁ ॥",
          "roman": "dē dē maṅgeh sahsā gūṇā sobh karē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они раздают, но потом желают получить во много раз больше, и мир прославляет их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20922,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰਾ ਜਾਰਾ ਤੈ ਕੂੜਿਆਰਾ ਖਾਰਾਬਾ ਵੇਕਾਰ ॥",
          "roman": "chorā jārā tē kūṛiārā khārābā vēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воры, прелюбодеи, лжецы, испорченные и бесполезные люди —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20923,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਹੋਦਾ ਖਾਇ ਚਲਹਿ ਐਥਾਊ ਤਿਨਾ ਭਿ ਕਾਈ ਕਾਰ ॥",
          "roman": "ik hodā khāē chaleh aithāū tinā bh kāī kār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "одни здесь едят то, что есть, и уходят; но и у них тоже есть своё дело в Божьем порядке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20924,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਜੀਆ ਪੁਰੀਆ ਲੋਆ ਆਕਾਰਾ ਆਕਾਰ ॥",
          "roman": "jal thal jīā purīā loā ākārā ākār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В воде, на суше, в мирах и областях — живые существа, формы за формами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20925,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਜਿ ਆਖਹਿ ਸੁ ਤੂੰਹੈ ਜਾਣਹਿ ਤਿਨਾ ਭਿ ਤੇਰੀ ਸਾਰ ॥",
          "roman": "oi j ākheh su tūnhē jāṇeh tinā bh tērī sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что бы они ни говорили, это знаешь только Ты; и о них тоже Ты заботишься."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20926,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤਾ ਭੁਖ ਸਾਲਾਹਣੁ ਸਚੁ ਨਾਮੁ ਆਧਾਰੁ ॥",
          "roman": "nānak bhagtā bhukh sālāhaṇ sach nām ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у преданных есть лишь жажда восхвалять Господа; вечно истинное Имя Хари — их опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20927,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਅਨੰਦਿ ਰਹਹਿ ਦਿਨੁ ਰਾਤੀ ਗੁਣਵੰਤਿਆ ਪਾ ਛਾਰੁ ॥੧॥",
          "roman": "sadā anand raheh din rātī guṇvantiā pā chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они всегда, днём и ночью, пребывают в блаженстве и считают себя пылью у ног добродетельных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1703,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20928,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā pehlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20929,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੀ ਮੁਸਲਮਾਨ ਕੀ ਪੇੜੈ ਪਈ ਕੁਮਿੑਆਰ ॥",
          "roman": "miṭī musalmān kī pēṛē paī kumhiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Почва с места, где мусульмане погребают умерших, тоже порой попадает к гончару."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20930,
          "is_rahao": false,
          "gurmukhi": "ਘੜਿ ਭਾਂਡੇ ਇਟਾ ਕੀਆ ਜਲਦੀ ਕਰੇ ਪੁਕਾਰ ॥",
          "roman": "ghaṛ bhāṅḍē iṭā kīā jaldī karē pukār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гончар лепит из неё сосуды и кирпичи, и, попав в печь, эта глина словно горит и кричит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20931,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਜਲਿ ਰੋਵੈ ਬਪੁੜੀ ਝੜਿ ਝੜਿ ਪਵਹਿ ਅੰਗਿਆਰ ॥",
          "roman": "jal jal rovē bapuṛī jhaṛ jhaṛ paveh aṅgiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бедная, сгорая, плачет, и из неё осыпаются горящие угли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20932,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਨਿ ਕਰਤੈ ਕਾਰਣੁ ਕੀਆ ਸੋ ਜਾਣੈ ਕਰਤਾਰੁ ॥੨॥",
          "roman": "nānak jin kartē kāraṇ kīā so jāṇē kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Тот Творец, который создал устройство мира, один знает истинную тайну."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1704,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20933,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20934,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਤਿਗੁਰ ਕਿਨੈ ਨ ਪਾਇਓ ਬਿਨੁ ਸਤਿਗੁਰ ਕਿਨੈ ਨ ਪਾਇਆ ॥",
          "roman": "bin satigur kinē na pāio bin satigur kinē na pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто не обрёл Подателя жизни без Сатгуру; истинно, никто не обрёл Его без прибежища Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20935,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਵਿਚਿ ਆਪੁ ਰਖਿਓਨੁ ਕਰਿ ਪਰਗਟੁ ਆਖਿ ਸੁਣਾਇਆ ॥",
          "roman": "satigur vich āp rakhion kar pargaṭ ākh suṇāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь поместил Себя в Сатгуру; это открыто сказано и возвещено всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20936,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਮਿਲਿਐ ਸਦਾ ਮੁਕਤੁ ਹੈ ਜਿਨਿ ਵਿਚਹੁ ਮੋਹੁ ਚੁਕਾਇਆ ॥",
          "roman": "satigur miliē sadā mukat hē jin vichah moh chukāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если человеку встречается такой Гуру, который удалил изнутри привязанность к майе, человек становится навсегда свободным от мирских уз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20937,
          "is_rahao": false,
          "gurmukhi": "ਉਤਮੁ ਏਹੁ ਬੀਚਾਰੁ ਹੈ ਜਿਨਿ ਸਚੇ ਸਿਉ ਚਿਤੁ ਲਾਇਆ ॥",
          "roman": "utam ēh bīchār hē jin sachē siu chit lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лучшее из всех рассуждений таково: тот, кто соединил сознание с Истинным через Гуру, избрал прекрасный путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20938,
          "is_rahao": false,
          "gurmukhi": "ਜਗਜੀਵਨੁ ਦਾਤਾ ਪਾਇਆ ॥੬॥",
          "roman": "jagjīvan dātā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он обрёл Подателя жизни всему миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1705,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20939,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahlā pehlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20940,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਆਇਆ ਹਉ ਵਿਚਿ ਗਇਆ ॥",
          "roman": "hau vich āiā hau vich gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока живое существо пребывает в «я», оно приходит в мир и уходит из мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20941,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਜੰਮਿਆ ਹਉ ਵਿਚਿ ਮੁਆ ॥",
          "roman": "hau vich janmiā hau vich muā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В состоянии «я» оно рождается и в состоянии «я» умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20942,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਦਿਤਾ ਹਉ ਵਿਚਿ ਲਇਆ ॥",
          "roman": "hau vich ditā hau vich laiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В пределах этой отдельной самости оно то даёт нуждающемуся, то берёт для своей нужды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20943,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਖਟਿਆ ਹਉ ਵਿਚਿ ਗਇਆ ॥",
          "roman": "hau vich khaṭiā hau vich gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мысли «это делаю я» оно то приобретает, то теряет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20944,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਸਚਿਆਰੁ ਕੂੜਿਆਰੁ ॥",
          "roman": "hau vich sachiār kūṛiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока оно ограничено «моё-твоё», в глазах людей оно бывает то правдивым, то лживым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20945,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਪਾਪ ਪੁੰਨ ਵੀਚਾਰੁ ॥",
          "roman": "hau vich pāp punn vīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В заблуждении отдельного существования оно подсчитывает свои грехи и добрые дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20946,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਨਰਕਿ ਸੁਰਗਿ ਅਵਤਾਰੁ ॥",
          "roman": "hau vich narak surag avtār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за этого разделения, не слившись с Богом, оно попадает то в ад, то в рай."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20947,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਹਸੈ ਹਉ ਵਿਚਿ ਰੋਵੈ ॥",
          "roman": "hau vich hasē hau vich rovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока оно связано отдельностью от Творца, оно то смеётся, то плачет, считая себя то счастливым, то несчастным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20948,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਭਰੀਐ ਹਉ ਵਿਚਿ ਧੋਵੈ ॥",
          "roman": "hau vich bharīē hau vich dhovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за отдельной самости его ум загрязняется греховной грязью, и оно пытается собственными усилиями её смывать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20949,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਜਾਤੀ ਜਿਨਸੀ ਖੋਵੈ ॥",
          "roman": "hau vich jātī jinsī khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Охваченное отдельной самостью, оно теряет себя в мыслях о касте и происхождении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20950,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਮੂਰਖੁ ਹਉ ਵਿਚਿ ਸਿਆਣਾ ॥",
          "roman": "hau vich mūrakh hau vich siāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока оно заключено в стенах отдельного существования, люди считают его то глупым, то мудрым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20951,
          "is_rahao": false,
          "gurmukhi": "ਮੋਖ ਮੁਕਤਿ ਕੀ ਸਾਰ ਨ ਜਾਣਾ ॥",
          "roman": "mokh mukt kī sār na jāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но пока оно связано этой ограниченностью, оно не понимает сути освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20952,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਵਿਚਿ ਮਾਇਆ ਹਉ ਵਿਚਿ ਛਾਇਆ ॥",
          "roman": "hau vich māiā hau vich chhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока оно находится в состоянии разлуки с Богом, оно кричит «майя, майя», и на нём лежит тень майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20953,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਕਰਿ ਕਰਿ ਜੰਤ ਉਪਾਇਆ ॥",
          "roman": "haumē kar kar jant upāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставаясь отделённым от Бога из-за Хоумэ, живое существо снова и снова рождается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20954,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਬੂਝੈ ਤਾ ਦਰੁ ਸੂਝੈ ॥",
          "roman": "haumē būjhē tā dar sūjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда оно понимает состояние Хоумэ и осознаёт, что заключено в границе отделённости, тогда ему открывается дверь к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20955,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨ ਵਿਹੂਣਾ ਕਥਿ ਕਥਿ ਲੂਝੈ ॥",
          "roman": "giān vihūṇā kath kath lūjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А пока оно лишено этого знания, оно лишь говорит о знании и, считая себя знающим, сжигает свой внутренний мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20956,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹੁਕਮੀ ਲਿਖੀਐ ਲੇਖੁ ॥",
          "roman": "nānak hukmī likhīai lēkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, этот внутренний отпечаток отдельного «я» тоже записывается по Божьему Хукаму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20957,
          "is_rahao": false,
          "gurmukhi": "ਜੇਹਾ ਵੇਖਹਿ ਤੇਹਾ ਵੇਖੁ ॥੧॥",
          "roman": "jēhā vēkheh tēhā vēkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как живые существа смотрят на других, с каким намерением обращаются с ними, таким становится их собственный облик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1706,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20958,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੨ ॥",
          "roman": "mahlā dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20959,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਏਹਾ ਜਾਤਿ ਹੈ ਹਉਮੈ ਕਰਮ ਕਮਾਹਿ ॥",
          "roman": "haumē ēhā jāt hē haumē karam kamāheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такова природа Хоумэ: если сохраняется отдельная самость от Бога, живые существа совершают такие дела, которые поддерживают эту отдельность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20960,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਏਈ ਬੰਧਨਾ ਫਿਰਿ ਫਿਰਿ ਜੋਨੀ ਪਾਹਿ ॥",
          "roman": "haumē ēī bandhanā phir phir jonī pāheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Таковы и узы Хоумэ: под властью следов этих дел живые существа снова и снова попадают в рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20961,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਕਿਥਹੁ ਊਪਜੈ ਕਿਤੁ ਸੰਜਮਿ ਇਹ ਜਾਇ ॥",
          "roman": "haumē kithah ūpjē kit sanjam ih jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Возникает вопрос: откуда появляется этот обман отдельной личности и каким способом он может уйти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20962,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਏਹੋ ਹੁਕਮੁ ਹੈ ਪਇਐ ਕਿਰਤਿ ਫਿਰਾਹਿ ॥",
          "roman": "haumē ēho hukam hē pēē kirat phirāheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ответ таков: это Божий Хукам, создающий отдельную личность, и живые существа по следам прежних поступков снова стремятся к тем же делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20963,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਦੀਰਘ ਰੋਗੁ ਹੈ ਦਾਰੂ ਭੀ ਇਸੁ ਮਾਹਿ ॥",
          "roman": "haumē dīragh rog hē dārū bhī is māheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хоумэ — долгий, глубоко укоренённый недуг, но он не неизлечим: лекарство от него тоже есть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20964,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਾ ਕਰੇ ਜੇ ਆਪਣੀ ਤਾ ਗੁਰ ਕਾ ਸਬਦੁ ਕਮਾਹਿ ॥",
          "roman": "kirpā karē jē āpṇī tā gur kā sabad kamāheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Господь являет Свою милость, тогда живые существа воплощают в жизни Слово Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20965,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਕਹੈ ਸੁਣਹੁ ਜਨਹੁ ਇਤੁ ਸੰਜਮਿ ਦੁਖ ਜਾਹਿ ॥੨॥",
          "roman": "nānak kahē suṇhu janhu it sanjam dukh jāheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: слушайте, люди, этим способом уходят страдания, рождаемые долгим недугом Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1707,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20966,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20967,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵ ਕੀਤੀ ਸੰਤੋਖੀੲਂੀ ਜਿਨੑੀ ਸਚੋ ਸਚੁ ਧਿਆਇਆ ॥",
          "roman": "sēv kītī santokhīāṅ jinhī sacho sach dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Довольные, удовлетворённые люди совершали служение — те, кто созерцал Истинного, истинно Истинного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
