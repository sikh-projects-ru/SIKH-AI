{
  "ang": 467,
  "shabads": [
    {
      "shabad_id": 1707,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20968,
          "is_rahao": false,
          "gurmukhi": "ਓਨੑੀ ਮੰਦੈ ਪੈਰੁ ਨ ਰਖਿਓ ਕਰਿ ਸੁਕ੍ਰਿਤੁ ਧਰਮੁ ਕਮਾਇਆ ॥",
          "roman": "onhī mandē pēr na rakhio kar sukrit dharam kamāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они никогда не приближаются к дурным делам; делают добро и ведут жизнь согласно дхарме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20969,
          "is_rahao": false,
          "gurmukhi": "ਓਨੑੀ ਦੁਨੀਆ ਤੋੜੇ ਬੰਧਨਾ ਅੰਨੁ ਪਾਣੀ ਥੋੜਾ ਖਾਇਆ ॥",
          "roman": "onhī dunīā tōṛē bandhnā ann pāṇī thōṛā khāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они разорвали цепи мирских привязанностей, мало едят и мало пьют — лишь для поддержания тела, а не ради вкуса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20970,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਬਖਸੀਸੀ ਅਗਲਾ ਨਿਤ ਦੇਵਹਿ ਚੜਹਿ ਸਵਾਇਆ ॥",
          "roman": "tū̃ bakhsīsī aglā nit dēveh chaṛeh savāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты щедро дарующий; Ты всегда даёшь живым дары, и Твоя слава всё возрастает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20971,
          "is_rahao": false,
          "gurmukhi": "ਵਡਿਆਈ ਵਡਾ ਪਾਇਆ ॥੭॥",
          "roman": "vaḍiāī vaḍā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так прославляя Господа, эти довольные люди достигают великого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1708,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20972,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Первый Мехл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20973,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਖਾਂ ਬਿਰਖਾਂ ਤੀਰਥਾਂ ਤਟਾਂ ਮੇਘਾਂ ਖੇਤਾਂਹ ॥",
          "roman": "purakhā̃ birakhā̃ tīrathā̃ taṭā̃ mēghā̃ khētā̃h",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Людей, деревьев, мест паломничества, берегов рек, облаков и полей — их меру знает только Тот Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20974,
          "is_rahao": false,
          "gurmukhi": "ਦੀਪਾਂ ਲੋਆਂ ਮੰਡਲਾਂ ਖੰਡਾਂ ਵਰਭੰਡਾਂਹ ॥",
          "roman": "dīpā̃ loā̃ maṇḍlā̃ khaṇḍā̃ varbhaṇḍā̃h",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Островов, миров, небесных кругов, частей земли и вселенных — их счёт знает только Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20975,
          "is_rahao": false,
          "gurmukhi": "ਅੰਡਜ ਜੇਰਜ ਉਤਭੁਜਾਂ ਖਾਣੀ ਸੇਤਜਾਂਹ ॥",
          "roman": "aṇḍaj jēraj utbhujā̃ khāṇī sētajā̃h",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Существ, рождающихся из яиц, из утробы, из земли и из влаги, — всех их меру знает только Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20976,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮਿਤਿ ਜਾਣੈ ਨਾਨਕਾ ਸਰਾਂ ਮੇਰਾਂ ਜੰਤਾਹ ॥",
          "roman": "so mit jāṇē nānakā sarā̃ mērā̃ jantāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только Он знает меру озёр, гор, подобных Меру, и всех живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20977,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੰਤ ਉਪਾਇ ਕੈ ਸੰਮਾਲੇ ਸਭਨਾਹ ॥",
          "roman": "nānak jant upāi kē sammālē sabhnāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, создав всех живых существ, Господь также заботится обо всех них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20978,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕਰਤੈ ਕਰਣਾ ਕੀਆ ਚਿੰਤਾ ਭਿ ਕਰਣੀ ਤਾਹ ॥",
          "roman": "jin kartē karṇā kīā chintā bh karṇī tāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Творец, который сотворил мироздание, Сам же несёт заботу о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20979,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕਰਤਾ ਚਿੰਤਾ ਕਰੇ ਜਿਨਿ ਉਪਾਇਆ ਜਗੁ ॥",
          "roman": "so kartā chintā karē jin upāiā jag",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Творец, который создал мир, Сам заботится о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20980,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜੋਹਾਰੀ ਸੁਅਸਤਿ ਤਿਸੁ ਤਿਸੁ ਦੀਬਾਣੁ ਅਭਗੁ ॥",
          "roman": "tis johārī suast tis tis dībāṇ abhag",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я кланяюсь Ему и прославляю Его; опора того Господа для живого существа неразрушима."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20981,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਚੇ ਨਾਮ ਬਿਨੁ ਕਿਆ ਟਿਕਾ ਕਿਆ ਤਗੁ ॥੧॥",
          "roman": "nānak sachē nām bin kiā ṭikā kiā tag",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, без памятования истинного Имени Господа что значат тилак и священная нить? Внешние религиозные знаки бесполезны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1709,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20982,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Мехл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20983,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਨੇਕੀਆ ਚੰਗਿਆਈਆ ਲਖ ਪੁੰਨਾ ਪਰਵਾਣੁ ॥",
          "roman": "lakh nēkīā changiāīā lakh punnā parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть совершаются сотни тысяч добрых и благих дел, сотни тысяч дел дхармы, признанных людьми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20984,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਤਪ ਉਪਰਿ ਤੀਰਥਾਂ ਸਹਜ ਜੋਗ ਬੇਬਾਣ ॥",
          "roman": "lakh tap upar tīrathā̃ sahaj jog bēbāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть на местах паломничества совершаются сотни тысяч аскез, пусть в лесах практикуется йога спокойного самоуглубления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20985,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਸੂਰਤਣ ਸੰਗਰਾਮ ਰਣ ਮਹਿ ਛੁਟਹਿ ਪਰਾਣ ॥",
          "roman": "lakh sūrtaṇ sangrām raṇ meh chhuṭeh parāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть на полях битвы проявляется бесчисленная храбрость героев, и пусть жизнь отдаётся в бою лицом к врагу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20986,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਸੁਰਤੀ ਲਖ ਗਿਆਨ ਧਿਆਨ ਪੜੀਅਹਿ ਪਾਠ ਪੁਰਾਣ ॥",
          "roman": "lakh surtī lakh giān dhiān paṛīah pāṭh purāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть многими способами сосредоточивают сознание, обсуждают знание, стараются собрать ум и бесчисленно читают Пураны и другие религиозные тексты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20987,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕਰਤੈ ਕਰਣਾ ਕੀਆ ਲਿਖਿਆ ਆਵਣ ਜਾਣੁ ॥",
          "roman": "jin kartē karṇā kīā likhiā āvaṇ jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Творец сотворил всё мироздание и установил для живых существ приход и уход, рождение и смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20988,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਤੀ ਮਿਥਿਆ ਕਰਮੁ ਸਚਾ ਨੀਸਾਣੁ ॥੨॥",
          "roman": "nānak matī mithiā karam sachā nīsāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, все эти умствования тщетны; только милость Господа является истинным пропуском к принятию в Его Дворе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1710,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20989,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20990,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਸਾਹਿਬੁ ਏਕੁ ਤੂੰ ਜਿਨਿ ਸਚੋ ਸਚੁ ਵਰਤਾਇਆ ॥",
          "roman": "sachā sāhib ēk tū̃ jin sacho sach vartāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, только Ты — полностью устойчивый Владыка; Ты Сам распространил в мире качество полной устойчивости и раскрытия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20991,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂੰ ਦੇਹਿ ਤਿਸੁ ਮਿਲੈ ਸਚੁ ਤਾ ਤਿਨੑੀ ਸਚੁ ਕਮਾਇਆ ॥",
          "roman": "jis tū̃ dēh tis milē sach tā tinhī sach kamāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это качество истины получает лишь тот, кому Ты Сам его даёшь; по Твоей милости такие люди строят жизнь согласно этой истине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20992,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮਿਲਿਐ ਸਚੁ ਪਾਇਆ ਜਿਨੑ ਕੈ ਹਿਰਦੈ ਸਚੁ ਵਸਾਇਆ ॥",
          "roman": "satgur miliē sach pāiā jinh kē hirdē sach vasāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встретив Сатгуру, они получают дар полной истины; Сатгуру утверждает эту истину в их сердцах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20993,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖ ਸਚੁ ਨ ਜਾਣਨੑੀ ਮਨਮੁਖੀ ਜਨਮੁ ਗਵਾਇਆ ॥",
          "roman": "mūrakh sach na jāṇanhī manmukhī janam gavāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Глупцы не понимают этой истины; манмукхи, оставшись без неё, напрасно теряют свою жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20994,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਿ ਦੁਨੀਆ ਕਾਹੇ ਆਇਆ ॥੮॥",
          "roman": "vich dunīā kāhē āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Их приход в мир не приносит им никакой пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1711,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 20995,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Первый Мехл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20996,
          "is_rahao": false,
          "gurmukhi": "ਪੜਿ ਪੜਿ ਗਡੀ ਲਦੀਅਹਿ ਪੜਿ ਪੜਿ ਭਰੀਅਹਿ ਸਾਥ ॥",
          "roman": "paṛ paṛ gaḍī ladīah paṛ paṛ bharīah sāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если прочитать столько книг, что ими можно нагрузить множество телег и сложить груды за грудами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20997,
          "is_rahao": false,
          "gurmukhi": "ਪੜਿ ਪੜਿ ਬੇੜੀ ਪਾਈਐ ਪੜਿ ਪੜਿ ਗਡੀਅਹਿ ਖਾਤ ॥",
          "roman": "paṛ paṛ bēṛī pāīai paṛ paṛ gaḍīah khāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если прочитать столько книг, что ими можно наполнить лодку и засыпать множество ям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20998,
          "is_rahao": false,
          "gurmukhi": "ਪੜੀਅਹਿ ਜੇਤੇ ਬਰਸ ਬਰਸ ਪੜੀਅਹਿ ਜੇਤੇ ਮਾਸ ॥",
          "roman": "paṛīah jētē baras baras paṛīah jētē mās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если проводить в чтении годы за годами и все месяцы года."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 20999,
          "is_rahao": false,
          "gurmukhi": "ਪੜੀਐ ਜੇਤੀ ਆਰਜਾ ਪੜੀਅਹਿ ਜੇਤੇ ਸਾਸ ॥",
          "roman": "paṛīai jētī ārjā paṛīah jētē sās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если всю жизнь и все дыхания провести за чтением книг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21000,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਲੇਖੈ ਇਕ ਗਲ ਹੋਰੁ ਹਉਮੈ ਝਖਣਾ ਝਾਖ ॥੧॥",
          "roman": "nānak lēkhē ik gal hor haumē jhakhṇā jhākh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у Господа принимается только одно — Его прославление; всё прочее без Него есть блуждание в Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1712,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21001,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Мехл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21002,
          "is_rahao": false,
          "gurmukhi": "ਲਿਖਿ ਲਿਖਿ ਪੜਿਆ ॥",
          "roman": "likh likh paṛiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чем больше человек умеет писать и читать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21003,
          "is_rahao": false,
          "gurmukhi": "ਤੇਤਾ ਕੜਿਆ ॥",
          "roman": "tētā kaṛiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем больше у него становится гордости за своё знание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21004,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਤੀਰਥ ਭਵਿਆ ॥",
          "roman": "bah tīrath bhaviā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чем больше он странствует по местам паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21005,
          "is_rahao": false,
          "gurmukhi": "ਤੇਤੋ ਲਵਿਆ ॥",
          "roman": "tēto laviā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем больше он повсюду кричит о том, что совершил эти паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21006,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਭੇਖ ਕੀਆ ਦੇਹੀ ਦੁਖੁ ਦੀਆ ॥",
          "roman": "bah bhēkh kīā dēhī dukh dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто-то принимает множество религиозных обликов и мучит своё тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21007,
          "is_rahao": false,
          "gurmukhi": "ਸਹੁ ਵੇ ਜੀਆ ਅਪਣਾ ਕੀਆ ॥",
          "roman": "sah vē jīā apṇā kīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О живое существо, терпи боль от того, что сам сделал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21008,
          "is_rahao": false,
          "gurmukhi": "ਅੰਨੁ ਨ ਖਾਇਆ ਸਾਦੁ ਗਵਾਇਆ ॥",
          "roman": "ann na khāiā sād gavāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто-то отказывается от пищи и теряет радость вкуса."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21009,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਦੁਖੁ ਪਾਇਆ ਦੂਜਾ ਭਾਇਆ ॥",
          "roman": "bah dukh pāiā dūjā bhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он много страдает, потому что вместо памятования Господа ему полюбился иной обряд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21010,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤ੍ਰ ਨ ਪਹਿਰੈ ॥",
          "roman": "bastar na pehrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто-то не носит одежды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21011,
          "is_rahao": false,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਕਹਰੈ ॥",
          "roman": "ahinis kehrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "День и ночь он терпит мучения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21012,
          "is_rahao": false,
          "gurmukhi": "ਮੋਨਿ ਵਿਗੂਤਾ ॥",
          "roman": "mon vigūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Храня молчание, он сбился с истинного пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21013,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਜਾਗੈ ਗੁਰ ਬਿਨੁ ਸੂਤਾ ॥",
          "roman": "kiu jāgē gur bin sūtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как может пробудиться спящий в майе человек без Гуру?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21014,
          "is_rahao": false,
          "gurmukhi": "ਪਗ ਉਪੇਤਾਣਾ ॥",
          "roman": "pag upētāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один ходит босыми ногами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21015,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਕੀਆ ਕਮਾਣਾ ॥",
          "roman": "apṇā kīā kamāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И пожинает боль от собственной ошибки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21016,
          "is_rahao": false,
          "gurmukhi": "ਅਲੁ ਮਲੁ ਖਾਈ ਸਿਰਿ ਛਾਈ ਪਾਈ ॥",
          "roman": "al mal khāī sir chhāī pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он ест грязную пищу и посыпает голову пеплом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21017,
          "is_rahao": false,
          "gurmukhi": "ਮੂਰਖਿ ਅੰਧੈ ਪਤਿ ਗਵਾਈ ॥",
          "roman": "mūrakh andhē pat gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот слепой глупец так потерял свою честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21018,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਨਾਵੈ ਕਿਛੁ ਥਾਇ ਨ ਪਾਈ ॥",
          "roman": "viṇ nāvē kichh thāi na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Имени Господа никакое другое усилие не принимается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21019,
          "is_rahao": false,
          "gurmukhi": "ਰਹੈ ਬੇਬਾਣੀ ਮੜੀ ਮਸਾਣੀ ॥",
          "roman": "rahē bēbāṇī maṛī masāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слепой глупец живёт в пустынных местах, среди гробниц и мест кремации."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21020,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧੁ ਨ ਜਾਣੈ ਫਿਰਿ ਪਛੁਤਾਣੀ ॥",
          "roman": "andh na jāṇē phir pachhutāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не понимает пути к Господу и потом, когда время проходит, раскаивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
