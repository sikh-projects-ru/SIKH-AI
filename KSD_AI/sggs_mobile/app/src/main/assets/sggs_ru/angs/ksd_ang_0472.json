{
  "ang": 472,
  "shabads": [
    {
      "shabad_id": 1738,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21217,
          "is_rahao": false,
          "gurmukhi": "ਨੀਲ ਵਸਤ੍ਰ ਪਹਿਰਿ ਹੋਵਹਿ ਪਰਵਾਣੁ ॥",
          "roman": "nīl vasatar pahir hovah parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Надев синие одежды, они становятся признанными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21218,
          "is_rahao": false,
          "gurmukhi": "ਮਲੇਛ ਧਾਨੁ ਲੇ ਪੂਜਹਿ ਪੁਰਾਣੁ ॥",
          "roman": "malechh dhān le pūjah purāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Берут пищу у чужеверцев, а затем почитают Пураны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21219,
          "is_rahao": false,
          "gurmukhi": "ਅਭਾਖਿਆ ਕਾ ਕੁਠਾ ਬਕਰਾ ਖਾਣਾ ॥",
          "roman": "abhākhiyā kā kuṭhā bakrā khāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Едят козла, зарезанного с чужой речью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21220,
          "is_rahao": false,
          "gurmukhi": "ਚਉਕੇ ਉਪਰਿ ਕਿਸੈ ਨ ਜਾਣਾ ॥",
          "roman": "chaukey upar kisē na jāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но на свой очищенный кухонный круг никому не позволяют входить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21221,
          "is_rahao": false,
          "gurmukhi": "ਦੇ ਕੈ ਚਉਕਾ ਕਢੀ ਕਾਰ ॥",
          "roman": "de kē chaukā kaḍhī kār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они обводят линию вокруг кухни и делают её отдельной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21222,
          "is_rahao": false,
          "gurmukhi": "ਉਪਰਿ ਆਇ ਬੈਠੇ ਕੂੜਿਆਰ ॥",
          "roman": "upar āe bēṭhe kūṛiyār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А затем эти лживые люди приходят и садятся внутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21223,
          "is_rahao": false,
          "gurmukhi": "ਮਤੁ ਭਿਟੈ ਵੇ ਮਤੁ ਭਿਟੈ ॥ ਇਹੁ ਅੰਨੁ ਅਸਾਡਾ ਫਿਟੈ ॥",
          "roman": "mat bhiṭē ve mat bhiṭē, ih ann asāḍā phiṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "«Не прикасайся, не прикасайся, иначе наша пища осквернится»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21224,
          "is_rahao": false,
          "gurmukhi": "ਤਨਿ ਫਿਟੈ ਫੇੜ ਕਰੇਨਿ ॥",
          "roman": "tan phiṭē pheṛ karen",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но в их теле уже есть осквернение, и они творят дурные дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21225,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਜੂਠੈ ਚੁਲੀ ਭਰੇਨਿ ॥",
          "roman": "man jūṭhē chulī bharen",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С нечистым умом они лишь полощут рот водой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21226,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਚੁ ਧਿਆਈਐ ॥",
          "roman": "kah Nānak sach dhiāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: нужно созерцать Истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21227,
          "is_rahao": false,
          "gurmukhi": "ਸੁਚਿ ਹੋਵੈ ਤਾ ਸਚੁ ਪਾਈਐ ॥੨॥",
          "roman": "such hovē tā sach pāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если внутри будет чистота, тогда Истина будет обретена."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1739,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21228,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21229,
          "is_rahao": false,
          "gurmukhi": "ਚਿਤੈ ਅੰਦਰਿ ਸਭੁ ਕੋ ਵੇਖਿ ਨਦਰੀ ਹੇਠਿ ਚਲਾਇਦਾ ॥",
          "roman": "chitē andar sabh ko vekh nadrī heṭh chalāidā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь держит каждого живого в Своём внимании и, наблюдая за каждым, направляет его в дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21230,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਦੇ ਵਡਿਆਈਆ ਆਪੇ ਹੀ ਕਰਮ ਕਰਾਇਦਾ ॥",
          "roman": "āpe de vaḍiāīāṅ āpe hī karam karāidā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он Сам дарует существам достоинства и Сам побуждает их к действию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21231,
          "is_rahao": false,
          "gurmukhi": "ਵਡਹੁ ਵਡਾ ਵਡ ਮੇਦਨੀ ਸਿਰੇ ਸਿਰਿ ਧੰਧੈ ਲਾਇਦਾ ॥",
          "roman": "vaḍah vaḍā vaḍ mednī sire sir dhandhē lāidā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он больше всех великих, и Его творение безмерно; каждого Он ставит на своё место и занимает своим делом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21232,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਉਪਠੀ ਜੇ ਕਰੇ ਸੁਲਤਾਨਾ ਘਾਹੁ ਕਰਾਇਦਾ ॥",
          "roman": "nadar upaṭhī je kare sultānā ghāh karāidā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Он обратит даже на царей гневный взгляд, то делает их легче соломы, так что никто и не смотрит на них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21233,
          "is_rahao": false,
          "gurmukhi": "ਦਰਿ ਮੰਗਨਿ ਭਿਖ ਨ ਪਾਇਦਾ ॥੧੬॥",
          "roman": "dar mangaṇ bhikh na pāidā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда такие цари просят у дверей людей, им не дают даже милостыни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1740,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21234,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahallā pehilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21235,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਮੋਹਾਕਾ ਘਰੁ ਮੁਹੈ ਘਰੁ ਮੁਹਿ ਪਿਤਰੀ ਦੇਇ ॥",
          "roman": "je mohākā ghar muhē ghar muh pitarī dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если вор обкрадёт чужой дом и, награбив чужое, отдаст это в честь своих предков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21236,
          "is_rahao": false,
          "gurmukhi": "ਅਗੈ ਵਸਤੁ ਸਿਞਾਣੀਐ ਪਿਤਰੀ ਚੋਰ ਕਰੇਇ ॥",
          "roman": "agē vasat siñāṇīē pitarī chor karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если там, в ином мире, эта вещь действительно распознаётся, то он делает своих предков ворами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21237,
          "is_rahao": false,
          "gurmukhi": "ਵਢੀਅਹਿ ਹਥ ਦਲਾਲ ਕੇ ਮੁਸਫੀ ਏਹ ਕਰੇਇ ॥",
          "roman": "vaḍhīah hath dalāl ke musafī eh karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда, по Божьему суду, отсекаются руки того посредника-брахмана, который доставлял этот краденый дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21238,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਗੈ ਸੋ ਮਿਲੈ ਜਿ ਖਟੇ ਘਾਲੇ ਦੇਇ ॥੧॥",
          "roman": "Nānak agē so milē ji khaṭe ghāle dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, в дальнейшем человек получает только то, что сам заработал, добыл трудом и отдал своими руками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1741,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21239,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pehilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21240,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜੋਰੂ ਸਿਰਨਾਵਣੀ ਆਵੈ ਵਾਰੋ ਵਾਰ ॥",
          "roman": "jiu jorū sirnāvaṇī āvē vāro vār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как у женщины каждый месяц снова и снова приходит месячное очищение, и эта нечистота возникает изнутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21241,
          "is_rahao": false,
          "gurmukhi": "ਜੂਠੇ ਜੂਠਾ ਮੁਖਿ ਵਸੈ ਨਿਤ ਨਿਤ ਹੋਇ ਖੁਆਰੁ ॥",
          "roman": "jūṭhe jūṭhā mukh vasē nit nit hoi khuār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так и в устах лживого человека постоянно живёт ложь, и из-за этого он снова и снова терпит страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21242,
          "is_rahao": false,
          "gurmukhi": "ਸੂਚੇ ਏਹਿ ਨ ਆਖੀਅਹਿ ਬਹਨਿ ਜਿ ਪਿੰਡਾ ਧੋਇ ॥",
          "roman": "sūche eh na ākhīah bahan j piṇḍā dhoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Не называются чистыми те, кто лишь омывает тело и сидит, считая себя очищенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21243,
          "is_rahao": false,
          "gurmukhi": "ਸੂਚੇ ਸੇਈ ਨਾਨਕਾ ਜਿਨ ਮਨਿ ਵਸਿਆ ਸੋਇ ॥੨॥",
          "roman": "sūche seī Nānakā jin man vasiā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, чисты только те, в чьём уме обитает тот Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1742,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21244,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21245,
          "is_rahao": false,
          "gurmukhi": "ਤੁਰੇ ਪਲਾਣੇ ਪਉਣ ਵੇਗ ਹਰ ਰੰਗੀ ਹਰਮ ਸਵਾਰਿਆ ॥",
          "roman": "ture palāṇe pauṇ veg har raṅgī haram savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех, у кого есть осёдланные кони, быстрые как ветер, и кто украшает свои дворцы всеми цветами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21246,
          "is_rahao": false,
          "gurmukhi": "ਕੋਠੇ ਮੰਡਪ ਮਾੜੀਆ ਲਾਇ ਬੈਠੇ ਕਰਿ ਪਾਸਾਰਿਆ ॥",
          "roman": "koṭhe maṇḍap māṛīāṅ lāi bēṭhe kar pāsāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто сидит горделиво среди расставленных домов, палат, башен и украшений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21247,
          "is_rahao": false,
          "gurmukhi": "ਚੀਜ ਕਰਨਿ ਮਨਿ ਭਾਵਦੇ ਹਰਿ ਬੁਝਨਿ ਨਾਹੀ ਹਾਰਿਆ ॥",
          "roman": "chīj karan man bhāvde har bujhan nāhī hāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто наслаждается желанными забавами, но не познаёт Господа, тот проигрывает своё человеческое рождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21248,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਫੁਰਮਾਇਸਿ ਖਾਇਆ ਵੇਖਿ ਮਹਲਤਿ ਮਰਣੁ ਵਿਸਾਰਿਆ ॥",
          "roman": "kar phurmāis khāiā vekh mahalat maraṇ visāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто ест по приказу, наслаждаясь властью, и, глядя на свои дворцы, забывает о смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21249,
          "is_rahao": false,
          "gurmukhi": "ਜਰੁ ਆਈ ਜੋਬਨਿ ਹਾਰਿਆ ॥੧੭॥",
          "roman": "jar āī joban hāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "К таким обманутым молодостью людям незаметно приходит старость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1743,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21250,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahallā pehilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21251,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕਰਿ ਸੂਤਕੁ ਮੰਨੀਐ ਸਭ ਤੈ ਸੂਤਕੁ ਹੋਇ ॥",
          "roman": "je kar sūtak mannīē sabh tē sūtak hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если признавать су́так, ритуальную нечистоту, то су́так оказывается повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21252,
          "is_rahao": false,
          "gurmukhi": "ਗੋਹੇ ਅਤੈ ਲਕੜੀ ਅੰਦਰਿ ਕੀੜਾ ਹੋਇ ॥",
          "roman": "gohe atē lakṛī andar kīṛā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В коровьем навозе и в дровах тоже есть черви, то есть жизнь там тоже рождается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21253,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਦਾਣੇ ਅੰਨ ਕੇ ਜੀਆ ਬਾਝੁ ਨ ਕੋਇ ॥",
          "roman": "jete dāṇe ann ke jīā bājh na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сколько бы ни было зёрен пищи, ни одно из них не лишено жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21254,
          "is_rahao": false,
          "gurmukhi": "ਪਹਿਲਾ ਪਾਣੀ ਜੀਉ ਹੈ ਜਿਤੁ ਹਰਿਆ ਸਭੁ ਕੋਇ ॥",
          "roman": "pehilā pāṇī jīu hē jit hariā sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И прежде всего вода сама является жизнью, ведь с её помощью всё живое становится живым и зелёным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21255,
          "is_rahao": false,
          "gurmukhi": "ਸੂਤਕੁ ਕਿਉ ਕਰਿ ਰਖੀਐ ਸੂਤਕੁ ਪਵੈ ਰਸੋਇ ॥",
          "roman": "sūtak kiu kar rakhīē sūtak pavē rasoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как же тогда можно соблюдать су́так? Ведь при таком понимании нечистота постоянно попадает и в кухню."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21256,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੂਤਕੁ ਏਵ ਨ ਉਤਰੈ ਗਿਆਨੁ ਉਤਾਰੇ ਧੋਇ ॥੧॥",
          "roman": "Nānak sūtak ev na utarē giān utāre dhoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, таким путём су́так из ума не уходит; только знание Господа смывает и удаляет его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1744,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21257,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pehilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21258,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਸੂਤਕੁ ਲੋਭੁ ਹੈ ਜਿਹਵਾ ਸੂਤਕੁ ਕੂੜੁ ॥",
          "roman": "man kā sūtak lobh hē jihvā sūtak kūṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Су́так ума — это жадность; су́так языка — это ложь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21259,
          "is_rahao": false,
          "gurmukhi": "ਅਖੀ ਸੂਤਕੁ ਵੇਖਣਾ ਪਰ ਤ੍ਰਿਅ ਪਰ ਧਨ ਰੂਪੁ ॥",
          "roman": "akhī sūtak vekhṇā par tria par dhan rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Су́так глаз — смотреть на чужую жену, чужое богатство и чужую красоту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21260,
          "is_rahao": false,
          "gurmukhi": "ਕੰਨੀ ਸੂਤਕੁ ਕੰਨਿ ਪੈ ਲਾਇਤਬਾਰੀ ਖਾਹਿ ॥",
          "roman": "kannī sūtak kann pē lāitabārī khāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Су́так ушей — когда уши беспечно и жадно слушают клевету."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21261,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹੰਸਾ ਆਦਮੀ ਬਧੇ ਜਮ ਪੁਰਿ ਜਾਹਿ ॥੨॥",
          "roman": "Nānak haṅsā ādamī badhe jam pur jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такие люди, даже если снаружи выглядят чистыми как лебеди, связанными уходят в обитель Джама."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1745,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 21262,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pehilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21263,
          "is_rahao": false,
          "gurmukhi": "ਸਭੋ ਸੂਤਕੁ ਭਰਮੁ ਹੈ ਦੂਜੈ ਲਗੈ ਜਾਇ ॥",
          "roman": "sabho sūtak bharam hē dūjē lagē jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Весь су́так — чистое заблуждение; он пристаёт к человеку, когда тот привязан к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21264,
          "is_rahao": false,
          "gurmukhi": "ਜੰਮਣੁ ਮਰਣਾ ਹੁਕਮੁ ਹੈ ਭਾਣੈ ਆਵੈ ਜਾਇ ॥",
          "roman": "jammaṇ marṇā hukam hē bhāṇē āvē jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рождение и смерть происходят по Хукаму; по Его воле живое приходит и уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21265,
          "is_rahao": false,
          "gurmukhi": "ਖਾਣਾ ਪੀਣਾ ਪਵਿਤ੍ਰੁ ਹੈ ਦਿਤੋਨੁ ਰਿਜਕੁ ਸੰਬਾਹਿ ॥",
          "roman": "khāṇā pīṇā pavitar hē diton rijak sambāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Еда и питьё чисты, потому что Господь Сам собрал и дал существам пропитание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 21266,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਨੑੀ ਗੁਰਮੁਖਿ ਬੁਝਿਆ ਤਿਨੑਾ ਸੂਤਕੁ ਨਾਹਿ ॥੩॥",
          "roman": "Nānak jinī gurmukh bujhiā tinhā sūtak nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у тех гурмукхов, которые это поняли, нет су́така."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
