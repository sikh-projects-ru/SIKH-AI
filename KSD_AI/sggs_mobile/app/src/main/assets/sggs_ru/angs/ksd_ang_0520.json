{
  "ang": 520,
  "shabads": [
    {
      "shabad_id": 1964,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23115,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23116,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਪਟੋਲਾ ਤੈ ਸਹਿ ਦਿਤਾ ਢਕਣ ਕੂ ਪਤਿ ਮੇਰੀ ॥",
          "roman": "prem paṭolā tē sah ditā ḍhakaṇ kū pat merī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чтобы прикрыть мою честь, Ты, Господь-супруг, дал мне шелковое одеяние любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23117,
          "is_rahao": false,
          "gurmukhi": "ਦਾਨਾ ਬੀਨਾ ਸਾਈ ਮੈਡਾ ਨਾਨਕ ਸਾਰ ਨ ਜਾਣਾ ਤੇਰੀ ॥੧॥",
          "roman": "dānā bīnā sāī mēḍā nānak sār na jāṇā terī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты — мой Господь, знающий сердца; я, Нанак, не познал Твоей истинной ценности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1965,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23118,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23119,
          "is_rahao": false,
          "gurmukhi": "ਤੈਡੈ ਸਿਮਰਣਿ ਹਭੁ ਕਿਛੁ ਲਧਮੁ ਬਿਖਮੁ ਨ ਡਿਠਮੁ ਕੋਈ ॥",
          "roman": "tēḍē simraṇ habh kichh ladham bikham na ḍiṭham koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря Твоему памятованию я словно обрел всё; никакой трудности в жизни я не увидел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23120,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪਤਿ ਰਖੈ ਸਚਾ ਸਾਹਿਬੁ ਨਾਨਕ ਮੇਟਿ ਨ ਸਕੈ ਕੋਈ ॥੨॥",
          "roman": "jis pat rakhē sachā sāhib nānak meṭ na sakē koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, честь того, кого хранит Истинный Владыка, никто не может уничтожить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1966,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23121,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paoṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23122,
          "is_rahao": false,
          "gurmukhi": "ਹੋਵੈ ਸੁਖੁ ਘਣਾ ਦਯਿ ਧਿਆਇਐ ॥",
          "roman": "hovē sukh ghaṇā day dhiāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если вспоминать любимого Господа, возникает большой покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23123,
          "is_rahao": false,
          "gurmukhi": "ਵੰਞੈ ਰੋਗਾ ਘਾਣਿ ਹਰਿ ਗੁਣ ਗਾਇਐ ॥",
          "roman": "vañjē rogā ghāṇ har guṇ gāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если петь достоинства Хари, исчезает вся масса болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23124,
          "is_rahao": false,
          "gurmukhi": "ਅੰਦਰਿ ਵਰਤੈ ਠਾਢਿ ਪ੍ਰਭਿ ਚਿਤਿ ਆਇਐ ॥",
          "roman": "andar vartē ṭhāḍh prabh chit āiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь приходит в сознание, внутри воцаряется прохлада и мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23125,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਵੈ ਆਸ ਨਾਇ ਮੰਨਿ ਵਸਾਇਐ ॥",
          "roman": "pūran hovē ās nāi mann vasāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Имя поселить в уме, надежда исполняется, то есть исчезают желания и жажда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23126,
          "is_rahao": false,
          "gurmukhi": "ਕੋਇ ਨ ਲਗੈ ਬਿਘਨੁ ਆਪੁ ਗਵਾਇਐ ॥",
          "roman": "koī na lagē bighan āp gavāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если отбросить чувство отдельного «я», на жизненном пути не возникает препятствий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23127,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨ ਪਦਾਰਥੁ ਮਤਿ ਗੁਰ ਤੇ ਪਾਇਐ ॥",
          "roman": "giān padārath mat gur te pāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если получить наставление от Гуру, обретается сокровище знания Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23128,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਪਾਏ ਸਭੇ ਥੋਕ ਜਿਸੁ ਆਪਿ ਦਿਵਾਇਐ ॥",
          "roman": "tin pāe sabhe thok jis āp divāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все эти блага обрел тот человек, кому Господь Сам даровал их через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23129,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਸਭਨਾ ਕਾ ਖਸਮੁ ਸਭ ਤੇਰੀ ਛਾਇਐ ॥੮॥",
          "roman": "tūṅ sabhnā kā khasam sabh terī chhāiē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты — Владыка всех существ; вся вселенная находится под Твоей тенью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1967,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23130,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23131,
          "is_rahao": false,
          "gurmukhi": "ਨਦੀ ਤਰੰਦੜੀ ਮੈਡਾ ਖੋਜੁ ਨ ਖੁੰਭੈ ਮੰਝਿ ਮੁਹਬਤਿ ਤੇਰੀ ॥",
          "roman": "nadī tarandaṛī mēḍā khoj na khumbhē mañjh muhabbat terī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Плывя через реку мира, моя нога не вязнет в грязи привязанности, потому что в моем сердце есть Твоя любовь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23132,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਸਹ ਚਰਣੀ ਮੈਡਾ ਹੀਅੜਾ ਸੀਤਮੁ ਹਰਿ ਨਾਨਕ ਤੁਲਹਾ ਬੇੜੀ ॥੧॥",
          "roman": "tau sah charaṇī mēḍā hīaṛā sītam har nānak tulhā beṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь-супруг, я пришил свое смиренное сердце к Твоим стопам; о Хари, для Нанака Ты — плот и лодка для переправы через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1968,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23133,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23134,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑਾ ਦਿਸੰਦੜਿਆ ਦੁਰਮਤਿ ਵੰਞੈ ਮਿਤ੍ਰ ਅਸਾਡੜੇ ਸੇਈ ॥",
          "roman": "jinhāṅ disandaṛiā durmat vañjē mitr asāḍaṛe seī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наши истинные друзья — те, при виде которых дурная мысль уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23135,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਢੂਢੇਦੀ ਜਗੁ ਸਬਾਇਆ ਜਨ ਨਾਨਕ ਵਿਰਲੇ ਕੇਈ ॥੨॥",
          "roman": "hau ḍhūḍhedī jag sabāiā jan nānak virle keī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я искала по всему миру; о слуга Нанак, такие люди встречаются редко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1969,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23136,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paoṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23137,
          "is_rahao": false,
          "gurmukhi": "ਆਵੈ ਸਾਹਿਬੁ ਚਿਤਿ ਤੇਰਿਆ ਭਗਤਾ ਡਿਠਿਆ ॥",
          "roman": "āvē sāhib chit teriā bhagtā ḍiṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При виде Твоих преданных, о Господь, Ты, Владыка, входишь в наше сознание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23138,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕੀ ਕਟੀਐ ਮੈਲੁ ਸਾਧਸੰਗਿ ਵੁਠਿਆ ॥",
          "roman": "man kī kaṭīē mēl sādhsaṅg vuṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда приходишь в Садх Сангат, грязь ума счищается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23139,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਭਉ ਕਟੀਐ ਜਨ ਕਾ ਸਬਦੁ ਜਪਿ ॥",
          "roman": "janam maraṇ bhau kaṭīai jan kā sabad jap",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя Бани хвалы, у слуги отсекается страх рождения и смерти, страх всей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23140,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਖੋਲਨਿੑ ਸੰਤ ਦੂਤ ਸਭਿ ਜਾਹਿ ਛਪਿ ॥",
          "roman": "bandhan kholanh sant dūt sabh jāh chhap",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые развязывают узы, и все демоны-пороки скрываются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23141,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸਿਉ ਲਾਇਨਿੑ ਰੰਗੁ ਜਿਸ ਦੀ ਸਭ ਧਾਰੀਆ ॥",
          "roman": "tis siu lāinh rang jis dī sabh dhārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые соединяют нас любовью с Тем, на Чьей опоре держится вся вселенная."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23142,
          "is_rahao": false,
          "gurmukhi": "ਊਚੀ ਹੂੰ ਊਚਾ ਥਾਨੁ ਅਗਮ ਅਪਾਰੀਆ ॥",
          "roman": "ūchī hūṅ ūchā thān agam apārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его место выше самого высокого; Он недостижим и бесконечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23143,
          "is_rahao": false,
          "gurmukhi": "ਰੈਣਿ ਦਿਨਸੁ ਕਰ ਜੋੜਿ ਸਾਸਿ ਸਾਸਿ ਧਿਆਈਐ ॥",
          "roman": "rēṇ dinas kar joṛ sās sās dhiāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Днем и ночью, сложив руки, с каждым дыханием следует помнить Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23144,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਆਪੇ ਹੋਇ ਦਇਆਲੁ ਤਾਂ ਭਗਤ ਸੰਗੁ ਪਾਈਐ ॥੯॥",
          "roman": "jā āpe hoe dayāl tāṅ bhagat saṅg pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Он Сам становится милостивым, тогда обретается общество Его преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1970,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23145,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23146,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰਿ ਵਿਡਾਨੜੈ ਹੁੰਮਸ ਧੁੰਮਸ ਕੂਕਾ ਪਈਆ ਰਾਹੀ ॥",
          "roman": "bār viḍānaṛē huṃmas dhuṃmas kūkā paīā rāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этой чужой области мира, из-за сильного жара огня жажды, на дорогах раздаются крики о помощи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23147,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਸਹ ਸੇਤੀ ਲਗੜੀ ਡੋਰੀ ਨਾਨਕ ਅਨਦ ਸੇਤੀ ਬਨੁ ਗਾਹੀ ॥੧॥",
          "roman": "tau sah setī lagaṛī ḍorī nānak anad setī ban gāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь-супруг, нить Нанака привязана к Тебе; поэтому он с радостью проходит через лес мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1971,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23148,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23149,
          "is_rahao": false,
          "gurmukhi": "ਸਚੀ ਬੈਸਕ ਤਿਨੑਾ ਸੰਗਿ ਜਿਨ ਸੰਗਿ ਜਪੀਐ ਨਾਉ ॥",
          "roman": "sachī bēsak tinhāṅ saṅg jin saṅg japīē nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Настоящая, выдерживающая до конца близость — с теми, с кем можно вспоминать Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23150,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨੑ ਸੰਗਿ ਸੰਗੁ ਨ ਕੀਚਈ ਨਾਨਕ ਜਿਨਾ ਆਪਣਾ ਸੁਆਉ ॥੨॥",
          "roman": "tinh saṅg saṅg na kīchai nānak jinā āpṇā suāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, с теми, у кого всегда только своя выгода, не следует вступать в общение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1972,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23151,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paoṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23152,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਵੇਲਾ ਪਰਵਾਣੁ ਜਿਤੁ ਸਤਿਗੁਰੁ ਭੇਟਿਆ ॥",
          "roman": "sā velā parvāṇ jit satigur bheṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Принятым считается тот миг, когда человек встретил Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23153,
          "is_rahao": false,
          "gurmukhi": "ਹੋਆ ਸਾਧੂ ਸੰਗੁ ਫਿਰਿ ਦੂਖ ਨ ਤੇਟਿਆ ॥",
          "roman": "hoā sādhū saṅg fir dūkh na teṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда произошла встреча с Садху, человек больше не попадает под удар страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23154,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇਆ ਨਿਹਚਲੁ ਥਾਨੁ ਫਿਰਿ ਗਰਭਿ ਨ ਲੇਟਿਆ ॥",
          "roman": "pāiā nihchal thān fir garabh na leṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Обретя прочное место, он больше не ложится в утробу, то есть не входит в новые рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23155,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰੀ ਆਇਆ ਇਕੁ ਸਗਲ ਬ੍ਰਹਮੇਟਿਆ ॥",
          "roman": "nadrī āiā ik sagal brahmeṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ему повсюду видится один Брахм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23156,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਗਿਆਨੁ ਲਾਇ ਧਿਆਨੁ ਦ੍ਰਿਸਟਿ ਸਮੇਟਿਆ ॥",
          "roman": "tat giān lāe dhiān driśṭ sameṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Собрав взгляд от внешнего и сосредоточив внимание на Господе, он обретает подлинное высшее понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23157,
          "is_rahao": false,
          "gurmukhi": "ਸਭੋ ਜਪੀਐ ਜਾਪੁ ਜਿ ਮੁਖਹੁ ਬੋਲੇਟਿਆ ॥",
          "roman": "sabho japīai jāp j mukhah boleṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все, что он произносит устами, становится повторением хвалы Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23158,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਬੁਝਿ ਨਿਹਾਲੁ ਸੁਖਿ ਸੁਖੇਟਿਆ ॥",
          "roman": "hukme bujh nihāl sukh sukheṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поняв волю Господа, он остается радостным и пребывает в полном покое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23159,
          "is_rahao": false,
          "gurmukhi": "ਪਰਖਿ ਖਜਾਨੈ ਪਾਏ ਸੇ ਬਹੁੜਿ ਨ ਖੋਟਿਆ ॥੧੦॥",
          "roman": "parakh khajānē pāe se bahuṛ na khoṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кого Господь проверил и поместил в Свое сокровище, уже снова не становятся фальшивыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 1973,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 23160,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23161,
          "is_rahao": false,
          "gurmukhi": "ਵਿਛੋਹੇ ਜੰਬੂਰ ਖਵੇ ਨ ਵੰਞਨਿ ਗਾਖੜੇ ॥",
          "roman": "vichhohe jambūr khave na vañjan gākhaṛe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Страдания разлуки со стопами Господа подобны клещам пытки: они тяжелы и невыносимы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 23162,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸੋ ਧਣੀ ਮਿਲੰਨਿ ਨਾਨਕ ਸੁਖ ਸੰਬੂਹ ਸਚੁ ॥੧॥",
          "roman": "je so dhaṇī milann nānak sukh sambūh sach",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если встретится тот Господь-Владыка, тогда воистину приходят все радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
