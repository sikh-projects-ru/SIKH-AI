{
  "ang": 623,
  "shabads": [
    {
      "shabad_id": 2355,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26941,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਗਲੀ ਲਾਜ ਰਾਖੀ ॥੩॥",
          "roman": "tin saglī lāj rākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ਬਦ ਨੇ ਉਸ ਦੀ ਸਾਰੀ ਇੱਜ਼ਤ ਰੱਖ ਲਈ (ਉਸ ਨੂੰ ਵਿਕਾਰਾਂ ਦੇ ਢਹੇ ਚੜ੍ਹਨ ਤੋਂ ਬਚਾ ਲਿਆ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "оно сохранило всю его честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26942,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲਾਇਆ ਬੋਲੀ ਤੇਰਾ ॥",
          "roman": "bolāiā bolī terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਦੋਂ ਤੂੰ ਪ੍ਰੇਰਨਾ ਦੇਂਦਾ ਹੈਂ ਤਦੋਂ ਹੀ ਮੈਂ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰ ਸਕਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Только по Твоему вдохновению я могу воспевать Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26943,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਸਾਹਿਬੁ ਗੁਣੀ ਗਹੇਰਾ ॥",
          "roman": "tū sāhib guṇī gaherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਾਡਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈਂ, ਤੂੰ ਡੂੰਘੇ ਜਿਗਰੇ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — наш Владыка, сокровищница качеств, глубокий по сущности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26944,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਨਾਨਕ ਨਾਮੁ ਸਚੁ ਸਾਖੀ ॥",
          "roman": "jap nānak nām sach sākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ, ਇਹੀ ਸਦਾ ਹਾਮੀ ਭਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Повторяй Имя вечного Бога — это истинный свидетель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26945,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨੇ ਦਾਸ ਕੀ ਪੈਜ ਰਾਖੀ ॥੪॥੬॥੫੬॥",
          "roman": "apṇe dās kī pēj rākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦੀ (ਸਦਾ) ਇੱਜ਼ਤ ਰੱਖਦਾ ਆਇਆ ਹੈ ॥੪॥੬॥੫੬॥"
            },
            "sahib_singh_ru": {
              "main": "Господь всегда сохраняет честь Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2356,
      "rahao_verse_id": 26952,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26946,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26947,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਿ ਕਰਤਾ ਪੁਰਖੁ ਖਲੋਆ ॥",
          "roman": "vich kartā purakh khaloā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰਬ-ਵਿਆਪਕ ਕਰਤਾਰ ਆਪ ਉਸ ਦੀ ਸਹੈਤਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Вездесущий Творец Сам оказывает ему помощь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26948,
          "is_rahao": false,
          "gurmukhi": "ਵਾਲੁ ਨ ਵਿੰਗਾ ਹੋਆ ॥",
          "roman": "vāl na vingā hoā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਆਤਮਕ ਰਾਸਿ-ਪੂੰਜੀ ਦਾ) ਰਤਾ ਭਰ ਭੀ ਨੁਕਸਾਨ ਨਹੀਂ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "ни малейшего ущерба (его духовному богатству) не происходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26949,
          "is_rahao": false,
          "gurmukhi": "ਮਜਨੁ ਗੁਰ ਆਂਦਾ ਰਾਸੇ ॥",
          "roman": "majan gur āndā rāse",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਜਿਸ ਮਨੁੱਖ ਦਾ) ਆਤਮਕ ਇਸ਼ਨਾਨ ਗੁਰੂ ਨੇ ਸਫਲ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "чьё духовное омовение Гуру сделал успешным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26950,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਹਰਿ ਹਰਿ ਕਿਲਵਿਖ ਨਾਸੇ ॥੧॥",
          "roman": "jap har har kilvikh nāse",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ (ਆਪਣੇ ਸਾਰੇ) ਪਾਪ ਨਾਸ ਕਰ ਲੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек, постоянно повторяя Имя Бога, уничтожает все свои грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26951,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਰਾਮਦਾਸ ਸਰੋਵਰੁ ਨੀਕਾ ॥",
          "roman": "santah rāmdās sarovar nīkā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਸਾਧ ਸੰਗਤਿ (ਇਕ) ਸੁੰਦਰ (ਅਸਥਾਨ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О святые! Садх сангат — это прекрасное место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26952,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਨਾਵੈ ਸੋ ਕੁਲੁ ਤਰਾਵੈ ਉਧਾਰੁ ਹੋਆ ਹੈ ਜੀ ਕਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo nāvē so kul tarāvē udhār hoā hē jī kā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ (ਸਾਧ ਸੰਗਤਿ ਵਿਚ) ਆਤਮਕ ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈ (ਮਨ ਨੂੰ ਨਾਮ-ਜਲ ਨਾਲ ਪਵਿਤ੍ਰ ਕਰਦਾ ਹੈ), ਉਸ ਦੀ ਜਿੰਦ ਦਾ (ਵਿਕਾਰਾਂ ਤੋਂ) ਪਾਰ-ਉਤਾਰਾ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਹ ਆਪਣੀ ਸਾਰੀ ਕੁਲ ਨੂੰ ਭੀ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто совершает там духовное омовение, очищая ум Имением, спасает свою душу и переправляет весь свой род через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26953,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਜਗੁ ਗਾਵੈ ॥",
          "roman": "jē jē kār jag gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਰਾ ਜਗਤ ਉਸ ਦੀ ਸੋਭਾ ਦਾ ਗੀਤ ਗਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Весь мир поёт его славу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26954,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਚਿੰਦਿਅੜੇ ਫਲ ਪਾਵੈ ॥",
          "roman": "man chindiṛe phal pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮਨ-ਚਿਤਵੇ ਫਲ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и человек получает плоды, желаемые умом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26955,
          "is_rahao": false,
          "gurmukhi": "ਸਹੀ ਸਲਾਮਤਿ ਨਾਇ ਆਏ ॥ ਅਪਣਾ ਪ੍ਰਭੂ ਧਿਆਏ ॥੨॥",
          "roman": "sahī salāmat nāe āe apṇā prabhū dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ ਇਸ ਸਤਸੰਗ-ਸਰੋਵਰ ਵਿਚ ਆਤਮਕ) ਇਸ਼ਨਾਨ ਕਰ ਕੇ ਆਪਣੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਰਾਸਿ-ਪੂੰਜੀ ਨੂੰ ਪੂਰਨ ਤੌਰ ਤੇ ਬਚਾ ਲੈਂਦਾ ਹੈ, (ਜੇਹੜਾ ਮਨੁੱਖ ਰਾਮ ਦੇ ਦਾਸਾਂ ਦੇ ਸਰੋਵਰ ਵਿਚ ਟਿਕ ਕੇ) ਆਪਣੇ ਪਰਮਾਤਮਾ ਦਾ ਆਰਾਧਨ ਕਰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он, совершив духовное омовение, полностью сохраняет своё духовное богатство, если, пребывая там, поклоняется Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26956,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਰੋਵਰ ਨਾਵੈ ॥",
          "roman": "sant sarovar nāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਸੰਤਾਂ ਦੇ ਸਰੋਵਰ ਵਿਚ (ਸਾਧ ਸੰਗਤਿ ਵਿਚ) ਆਤਮਕ ਇਸ਼ਨਾਨ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто совершает духовное омовение в озере святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26957,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਪਰਮ ਗਤਿ ਪਾਵੈ ॥",
          "roman": "so jan param gat pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਭ ਤੋਂ ਆਤਮਕ ਅਵਸਥਾ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот достигает высшего духовного состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26958,
          "is_rahao": false,
          "gurmukhi": "ਮਰੈ ਨ ਆਵੈ ਜਾਈ ॥",
          "roman": "marē na āvē jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Он не попадает в круг рождения и смерти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26959,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਧਿਆਈ ॥੩॥",
          "roman": "har har nām dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если постоянно медитирует на Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26960,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਬ੍ਰਹਮ ਬਿਚਾਰੁ ਸੁ ਜਾਨੈ ॥",
          "roman": "ihu brahm bichār su jānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਨਾਲ ਮਿਲਾਪ ਦੀ ਇਸ ਵਿਚਾਰ ਨੂੰ ਉਹ ਮਨੁੱਖ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Эту мысль о единении с Богом понимает тот,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26961,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਦਇਆਲੁ ਹੋਇ ਭਗਵਾਨੈ ॥",
          "roman": "jis dayāl hoī bhagvānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਉੱਤੇ ਪਰਮਾਤਮਾ ਆਪ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "к кому Сам Бог проявляет милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26962,
          "is_rahao": false,
          "gurmukhi": "ਬਾਬਾ ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਈ ॥",
          "roman": "bābā nānak prabh saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਸ਼ਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кто пребывает в прибежище Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26963,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਚਿੰਤਾ ਗਣਤ ਮਿਟਾਈ ॥੪॥੭॥੫੭॥",
          "roman": "sabh chintā gaṇat miṭāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪਣਾ ਹਰੇਕ ਕਿਸਮ ਦਾ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਦੂਰ ਕਰ ਲੈਂਦਾ ਹੈ ॥੪॥੭॥੫੭॥"
            },
            "sahib_singh_ru": {
              "main": "избавляется от всех забот и тревог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2357,
      "rahao_verse_id": 26970,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26964,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26965,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮਿ ਨਿਬਾਹੀ ਪੂਰੀ ॥",
          "roman": "pārbrahm nibāhī pūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਦਾ ਤੋਂ ਹੀ) ਪਰਮਾਤਮਾ ਨੇ ਆਪਣੇ ਸੇਵਕ ਨਾਲ ਪ੍ਰੀਤਿ ਤੋੜ ਤਕ ਨਿਬਾਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда полностью сохраняет любовь со Своим слугой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26966,
          "is_rahao": false,
          "gurmukhi": "ਕਾਈ ਬਾਤ ਨ ਰਹੀਆ ਊਰੀ ॥",
          "roman": "kāī bāt na rahīā ūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਨੂੰ ਕਿਸੇ ਗੱਲੇ ਕੋਈ ਕਮੀ ਨਹੀਂ ਰਹਿੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "У слуги не остаётся никакой нехватки ни в чём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26967,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਚਰਨ ਲਾਇ ਨਿਸਤਾਰੇ ॥",
          "roman": "gur charan lāe nistāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਸੰਭਾਲ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Слуга всегда хранит Имя Бога в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26968,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਸਮੑਾਰੇ ॥੧॥",
          "roman": "har har nām samhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ (ਸੇਵਕਾਂ ਨੂੰ ਸਦਾ ਹੀ) ਚਰਨੀਂ ਲਾ ਕੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾਇਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру, приняв к Своим стопам, переправил через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26969,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਦਾਸ ਕਾ ਸਦਾ ਰਖਵਾਲਾ ॥",
          "roman": "apne dās kā sadā rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਆਪਣੇ ਸੇਵਕ ਦਾ ਸਦਾ ਰਾਖਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог всегда является защитником Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26970,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪੁਨੇ ਕਰਿ ਰਾਖੇ ਮਾਤ ਪਿਤਾ ਜਿਉ ਪਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā apune kar rākhe māt pitā jiu pālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਾਪੇ (ਬੱਚਿਆਂ ਨੂੰ) ਪਾਲਦੇ ਹਨ, ਤਿਵੇਂ ਪ੍ਰਭੂ ਕਿਰਪਾ ਕਰ ਕੇ ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ ਆਪਣੇ ਬਣਾਈ ਰੱਖਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Как родители воспитывают детей, так и Бог по милости сохраняет Своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26971,
          "is_rahao": false,
          "gurmukhi": "ਵਡਭਾਗੀ ਸਤਿਗੁਰੁ ਪਾਇਆ ॥",
          "roman": "vaḍbhāgī satgur pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਵੱਡੇ ਭਾਗਾਂ ਵਾਲੇ ਮਨੁੱਖਾਂ ਨੇ (ਉਹ) ਗੁਰੂ ਲੱਭ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Счастливые люди обрели Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26972,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਮ ਕਾ ਪੰਥੁ ਮਿਟਾਇਆ ॥",
          "roman": "jin jam kā panth miṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਨੇ (ਉਹਨਾਂ ਵਾਸਤੇ) ਜਮ ਦੇ ਦੇਸ ਨੂੰ ਲੈ ਜਾਣ ਵਾਲਾ ਰਸਤਾ ਮਿਟਾ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "который уничтожил путь, ведущий к смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26973,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਭਗਤਿ ਭਾਇ ਚਿਤੁ ਲਾਗਾ ॥",
          "roman": "har bhagat bhāe chit lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਉਹਨਾਂ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਵਿਚ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ ਮਗਨ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Их ум погружён в любовь к Богу и преданность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26974,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜੀਵਹਿ ਸੇ ਵਡਭਾਗਾ ॥੨॥",
          "roman": "jap jīveh se vaḍbhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਵਡ-ਭਾਗੀ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Они, повторяя Имя, обретают духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26975,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਅੰਮ੍ਰਿਤ ਬਾਣੀ ਗਾਵੈ ॥",
          "roman": "har amrit bāṇī gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਸੇਵਕ) ਪਰਮਾਤਮਾ ਦੀ ਆਤਮਿਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਬਾਣੀ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга поёт животворящую Божественную Бани,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26976,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਾ ਕੀ ਧੂਰੀ ਨਾਵੈ ॥",
          "roman": "sādhā kī dhūrī nāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਗੁਰਮੁਖਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਵਿਚ ਇਸ਼ਨਾਨ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ (ਆਪਾ-ਭਾਵ ਮਿਟਾ ਕੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸ਼ਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "омывается в пыли стоп святых, пребывая в их прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26977,
          "is_rahao": false,
          "gurmukhi": "ਅਪੁਨਾ ਨਾਮੁ ਆਪੇ ਦੀਆ ॥",
          "roman": "apṇā nām āpe dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਹੀ (ਆਪਣੇ ਸੇਵਕ ਨੂੰ) ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог даровал Своё Имя слуге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26978,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਰਣਹਾਰ ਰਖਿ ਲੀਆ ॥੩॥",
          "roman": "prabh karaṇhār rakh līā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਜਣਹਾਰ ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ (ਸਦਾ ਤੋਂ ਆਪਣੇ ਸੇਵਕ ਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾਇਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и Сам Творец всегда защищает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26979,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਰਸਨ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥",
          "roman": "har darsan prān adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਦਰਸ਼ਨ ਹੀ (ਸੇਵਕ ਦੀ) ਜ਼ਿੰਦਗੀ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Созерцание Бога — основа жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26980,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਪੂਰਨ ਬਿਮਲ ਬੀਚਾਰਾ ॥",
          "roman": "ihu pūran bimal bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਦਾ) ਇਹ ਪਵਿਤ੍ਰ ਤੇ ਪੂਰਨ ਵਿਚਾਰ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это чистое и совершенное понимание остаётся у слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26981,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "kar kirpā antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੇ ਦਿਲਾਂ ਦੀ ਜਾਣਨ ਵਾਲੇ! ਹੇ ਸੁਆਮੀ! (ਮੇਰੇ ਉਤੇ) ਮੇਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Всеведущий! Прояви милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26982,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਨਾਨਕ ਸਰਣਿ ਸੁਆਮੀ ॥੪॥੮॥੫੮॥",
          "roman": "dās nānak saraṇ suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਤੂੰ ਭੀ ਪ੍ਰਭੂ-ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ, ਤੇ, ਆਖ-) ਮੈਂ ਤੇਰੀ ਸ਼ਰਨ ਆਇਆ ਹਾਂ ॥੪॥੮॥੫੮॥"
            },
            "sahib_singh_ru": {
              "main": "я, слуга Нанак, пришёл в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2358,
      "rahao_verse_id": 26989,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 26983,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26984,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਚਰਨੀ ਲਾਇਆ ॥",
          "roman": "gur pūrē charnī lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪੂਰੇ ਗੁਰੂ ਨੇ (ਪਰਮਾਤਮਾ ਦੇ) ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Того, кого совершенный Гуру соединил со стопами Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26985,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸੰਗਿ ਸਹਾਈ ਪਾਇਆ ॥",
          "roman": "har sang sahāī pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਉਹ ਪਰਮਾਤਮਾ ਲੱਭ ਲਿਆ ਜੋ ਹਰ ਵੇਲੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਹੈ, ਤੇ, (ਜਿੰਦ ਦਾ) ਮਦਦਗਾਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот обрёл Бога, пребывающего рядом и помогающего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26986,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜਾਈਐ ਤਹਾ ਸੁਹੇਲੇ ॥",
          "roman": "jah jāīai tahā suhele",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜੇ ਰਹੀਏ, ਤਾਂ) ਜਿੱਥੇ ਭੀ ਜਾਈਏ, ਉਥੇ ਹੀ ਸੁਖੀ ਰਹਿ ਸਕੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Куда бы он ни шёл, везде остаётся в счастье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26987,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਮੇਲੇ ॥੧॥",
          "roman": "kar kirpā prabh mele",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਜਿਨ੍ਹਾਂ ਨੂੰ ਚਰਨਾਂ ਵਿਚ ਮਿਲਾਇਆ ਹੈ) ਪ੍ਰਭੂ ਨੇ (ਆਪ ਹੀ) ਕਿਰਪਾ ਕਰ ਕੇ ਮਿਲਾਇਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "ибо Бог Сам по милости соединил его с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26988,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਗਾਵਹੁ ਸਦਾ ਸੁਭਾਈ ॥",
          "roman": "har guṇ gāvah sadā subhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਪਿਆਰ ਨਾਲ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦੇ ਰਿਹਾ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Пойте с любовью хвалу Бога всегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26989,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਚਿੰਦੇ ਸਗਲੇ ਫਲ ਪਾਵਹੁ ਜੀਅ ਕੈ ਸੰਗਿ ਸਹਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man chinde sagle phal pāvah jīa kē sang sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਨ-ਮੰਗੇ ਫਲ (ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੋਂ) ਪ੍ਰਾਪਤ ਕਰਦੇ ਰਹੋਗੇ, ਪਰਮਾਤਮਾ ਜਿੰਦ ਦੇ ਨਾਲ (ਵੱਸਦਾ) ਸਾਥੀ (ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਰਹੇਗਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Вы будете получать все желаемые плоды, и Бог будет ощущаться как постоянный спутник души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26990,
          "is_rahao": false,
          "gurmukhi": "ਨਾਰਾਇਣ ਪ੍ਰਾਣ ਅਧਾਰਾ ॥",
          "roman": "nārāyaṇ prān adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸੰਤ ਜਨਾਂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਪਰਮਾਤਮਾ ਜਿੰਦ ਦਾ ਆਸਰਾ (ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Бог становится опорой жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26991,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਸੰਤ ਜਨਾਂ ਰੇਨਾਰਾ ॥",
          "roman": "ham sant janā renārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤਾਂ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣਿਆ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "а я остаюсь пылью у стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26992,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪੁਨੀਤ ਕਰਿ ਲੀਨੇ ॥",
          "roman": "patit punīt kar līne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨ ਵਿਕਾਰਾਂ ਵਿਚ ਡਿੱਗੇ ਹੋਇਆਂ ਨੂੰ (ਭੀ) ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲਾ ਬਣਾ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Святые очищают даже падших,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26993,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਹਰਿ ਜਸੁ ਦੀਨੇ ॥੨॥",
          "roman": "kar kirpā har jas dīne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਉਹ) ਕਿਰਪਾ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਦਾਤਿ ਦੇਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "даруя по милости воспевание Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26994,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਕਰੇ ਪ੍ਰਤਿਪਾਲਾ ॥",
          "roman": "pārbrahm kare pratipālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਆਪ (ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨ ਵਾਲਿਆਂ ਦੀ) ਰਾਖੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам защищает тех, кто восхваляет Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26995,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਜੀਅ ਸੰਗਿ ਰਖਵਾਲਾ ॥",
          "roman": "sad jīa sang rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਉਹਨਾਂ ਦੀ ਜਿੰਦ ਦੇ ਨਾਲ ਰਾਖਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всегда оставаясь защитником их жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26996,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਿਨੁ ਰੈਨਿ ਕੀਰਤਨੁ ਗਾਈਐ ॥",
          "roman": "har din rēn kīrtan gāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਤੇ) ਦਿਨ ਰਾਤ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Поэтому следует днём и ночью петь хвалу Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26997,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁੜਿ ਨ ਜੋਨੀ ਪਾਈਐ ॥੩॥",
          "roman": "bahuṛ na jonī pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮੁੜ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪਈਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "тогда не попадёшь вновь в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26998,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਦੇਵੈ ਪੁਰਖੁ ਬਿਧਾਤਾ ॥",
          "roman": "jis devē purakh bidhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਸਿਰਜਣਹਾਰ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਆਪ (ਇਹ ਦਾਤਿ) ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому Сам Творец даёт этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 26999,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਰਸੁ ਤਿਨ ਹੀ ਜਾਤਾ ॥",
          "roman": "har ras tin hī jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਹੀ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਸਮਝਿਆ ਹੈ (ਕਦਰ ਜਾਣੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "тот и познаёт вкус Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27000,
          "is_rahao": false,
          "gurmukhi": "ਜਮਕੰਕਰੁ ਨੇੜਿ ਨ ਆਇਆ ॥",
          "roman": "jamkankar neṛ na āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਮ-ਦੂਤ ਭੀ ਉਸ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Посланник смерти не приближается к нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27001,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਨਕ ਸਰਣੀ ਪਾਇਆ ॥੪॥੯॥੫੯॥",
          "roman": "sukh nānak saraṇī pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸ਼ਰਨ ਪਿਆ ਰਹਿ ਕੇ ਉਹ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੯॥੫੯॥"
            },
            "sahib_singh_ru": {
              "main": "Пребывая в прибежище Бога, он наслаждается духовным блаженством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
