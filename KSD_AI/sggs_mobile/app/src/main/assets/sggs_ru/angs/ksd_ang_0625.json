{
  "ang": 625,
  "shabads": [
    {
      "shabad_id": 2361,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27047,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਦਇਆਲੁ ਕਿਰਪਾਲੁ ਪ੍ਰਭੁ ਠਾਕੁਰੁ ਆਪੇ ਸੁਣੈ ਬੇਨੰਤੀ ॥",
          "roman": "hoi dayāl kirpāl prabh ṭhākur āpē suṇē benantī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Став милостивым и сострадательным, Господь-Владыка Сам слышит мольбу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27048,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਾ ਸਤਗੁਰੁ ਮੇਲਿ ਮਿਲਾਵੈ ਸਭ ਚੂਕੈ ਮਨ ਕੀ ਚਿੰਤੀ ॥",
          "roman": "pūrā satgur mel milāvē sabh chūkē man kī chintī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Сатгуру соединяет с Господом, и вся тревога ума исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27049,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਅਵਖਦੁ ਮੁਖਿ ਪਾਇਆ ਜਨ ਨਾਨਕ ਸੁਖਿ ਵਸੰਤੀ ॥੪॥੧੨॥੬੨॥",
          "roman": "har har nām avkẖad mukh pāiā jan nānak sukh vasantī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда в уста вложено лекарство Имени Хари, раб Нанак пребывает в покое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2362,
      "rahao_verse_id": 27054,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27050,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сораṭх, Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27051,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਪ੍ਰਭ ਭਏ ਅਨੰਦਾ ਦੁਖ ਕਲੇਸ ਸਭਿ ਨਾਠੇ ॥",
          "roman": "simar simar prabh bhaē anandā dukh kalēs sabh nāṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова вспоминая Господа, люди становятся радостными, и все их страдания и мучения уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27052,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਤ ਧਿਆਵਤ ਪ੍ਰਭੁ ਅਪਨਾ ਕਾਰਜ ਸਗਲੇ ਸਾਂਠੇ ॥੧॥",
          "roman": "gun gāvat dhiāvat prabh apnā kāraj saglē sāṅṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевая достоинства своего Господа и созерцая Его, удачливые люди приводят в порядок все свои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27053,
          "is_rahao": true,
          "gurmukhi": "ਜਗਜੀਵਨ ਨਾਮੁ ਤੁਮਾਰਾ ॥",
          "roman": "jagjīvan nām tumārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твоё Имя даёт духовную жизнь существам мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27054,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਦੀਓ ਉਪਦੇਸਾ ਜਪਿ ਭਉਜਲੁ ਪਾਰਿ ਉਤਾਰਾ ॥ ਰਹਾਉ ॥",
          "roman": "gur pūrē dīo updesā jap bhaujal pār utārā rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Сатгуру дал наставление о памятовании Имени; повторяя его, человек переправляется через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27055,
          "is_rahao": false,
          "gurmukhi": "ਤੂਹੈ ਮੰਤ੍ਰੀ ਸੁਨਹਿ ਪ੍ਰਭ ਤੂਹੈ ਸਭੁ ਕਿਛੁ ਕਰਣੈਹਾਰਾ ॥",
          "roman": "tūhē mantrī sunah prabh tūhē sabh kichh karṇēhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты Сам Себе советник, Ты Сам слышишь всё и обладаешь силой совершить всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27056,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਆਪੇ ਦਾਤਾ ਆਪੇ ਭੁਗਤਾ ਕਿਆ ਇਹੁ ਜੰਤੁ ਵਿਚਾਰਾ ॥੨॥",
          "roman": "tū āpē dātā āpē bhugtā kiā ih jant vichārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты Сам даритель, Ты Сам наслаждающийся; это бедное существо само по себе ничего не значит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27057,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਗੁਣ ਤੇਰੇ ਆਖਿ ਵਖਾਣੀ ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈ ॥",
          "roman": "kiā guṇ tēre ākh vakhāṇī kīmat kahaṇ na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, я не способен словами описать Твои достоинства; Твою ценность невозможно высказать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27058,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਿ ਪੇਖਿ ਜੀਵੈ ਪ੍ਰਭੁ ਅਪਨਾ ਅਚਰਜੁ ਤੁਮਹਿ ਵਡਾਈ ॥੩॥",
          "roman": "pēkh pēkh jīvē prabh apnā acharaj tumahi vaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Созерцая своего Господа вновь и вновь, человек обретает духовную жизнь; Твоё величие изумительно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27059,
          "is_rahao": false,
          "gurmukhi": "ਧਾਰਿ ਅਨੁਗ੍ਰਹੁ ਆਪਿ ਪ੍ਰਭ ਸ੍ਵਾਮੀ ਪਤਿ ਮਤਿ ਕੀਨੀ ਪੂਰੀ ॥",
          "roman": "dhār anugrah āp prabh svāmī pat mat kīnī pūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, о Владыка, Ты Сам, проявив милость, даруешь человеку честь и совершенный разум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27060,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਨਾਨਕ ਬਲਿਹਾਰੀ ਬਾਛਉ ਸੰਤਾ ਧੂਰੀ ॥੪॥੧੩॥੬੩॥",
          "roman": "sadā sadā nānak balihārī bāchhau santā dhūrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак всегда приносит себя в жертву Тебе и просит пыли со стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2363,
      "rahao_verse_id": 27067,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27061,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਃ ੫ ॥",
          "roman": "soraṭh mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сораṭх, Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27062,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਨਮਸਕਾਰੇ ॥",
          "roman": "gur pūrā namaskārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто склоняется перед полным Гуру и входит в его прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27063,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਸਭੇ ਕਾਜ ਸਵਾਰੇ ॥",
          "roman": "prabh sabhē kāj savārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "у того Господь устраивает все дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27064,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਅਪਣੀ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "har apṇī kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хари обращает на него взгляд Своей милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27065,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਪੂਰਨ ਪੈਜ ਸਵਾਰੀ ॥੧॥",
          "roman": "prabh pūran pēj savārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Господь полностью сохраняет его честь в этом мире и в следующем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27066,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਦਾਸ ਕੋ ਭਇਓ ਸਹਾਈ ॥",
          "roman": "apnē dās ko bhaio sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма становится помощником Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27067,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਕੀਨੇ ਕਰਤੈ ਊਣੀ ਬਾਤ ਨ ਕਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "sagal manorath kīnē kartē ūṇī bāt na kāī rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Творец исполняет все желания Своего слуги, и у него не остаётся никакой нехватки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27068,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤੈ ਪੁਰਖਿ ਤਾਲੁ ਦਿਵਾਇਆ ॥",
          "roman": "kartē purakh tāl divāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всепроникающий Творец через Гуру даёт ему скрытое сокровище Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27069,
          "is_rahao": false,
          "gurmukhi": "ਪਿਛੈ ਲਗਿ ਚਲੀ ਮਾਇਆ ॥",
          "roman": "pichhē lag chalī māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда жажда майи исчезает, и майя сама следует за ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27070,
          "is_rahao": false,
          "gurmukhi": "ਤੋਟਿ ਨ ਕਤਹੂ ਆਵੈ ॥",
          "roman": "ṭoṭ na kathū āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Со стороны майи он нигде не ощущает недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27071,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੇ ਪੂਰੇ ਸਤਗੁਰ ਭਾਵੈ ॥੨॥",
          "roman": "mērē pūrē satgur bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно это нравится моему полному Сатгуру для такого счастливого человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27072,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਦਇਆਲਾ ॥",
          "roman": "simar simar dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова вспоминая Параматму, дом милости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27073,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜੀਅ ਭਏ ਕਿਰਪਾਲਾ ॥",
          "roman": "sabh jīa bhaē kirpālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "все такие существа становятся образом милостивого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27074,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਗੁਸਾਈ ॥",
          "roman": "jē jē kār gusāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прославляйте и восхваляйте Владыку творения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27075,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਪੂਰੀ ਬਣਤ ਬਣਾਈ ॥੩॥",
          "roman": "jin pūrī baṇat baṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он создал прекрасный порядок, через который существа соединяются с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27076,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਭਾਰੋ ਸੁਆਮੀ ਮੋਰਾ ॥",
          "roman": "tū bhāro suāmī morā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты мой великий Владыка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27077,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਪੁੰਨੁ ਪਦਾਰਥੁ ਤੇਰਾ ॥",
          "roman": "ih punn padārath terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это сокровище Имени, полученное через Гуру, является Твоим даром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27078,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਏਕੁ ਧਿਆਇਆ ॥",
          "roman": "jan nānak ēk dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О раб Нанак, тот, кто начал вспоминать единого Параматму,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27079,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਫਲਾ ਪੁੰਨੁ ਪਾਇਆ ॥੪॥੧੪॥੬੪॥",
          "roman": "sarab phalā punn pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "обрёл божественный дар, дающий все плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2364,
      "rahao_verse_id": 27087,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27080,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ਘਰੁ ੩ ਦੁਪਦੇ",
          "roman": "soraṭh mahallā 5 ghar 3 dupdē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сораṭх, Пятый Махал, третий дом, двустишия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27081,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27082,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਦਾਸ ਸਰੋਵਰਿ ਨਾਤੇ ॥",
          "roman": "rāmdās sarovar nātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто омываются в озере слуг Рама, то есть в Садх Санғат, где течёт вода Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27083,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਉਤਰੇ ਪਾਪ ਕਮਾਤੇ ॥",
          "roman": "sabh utrē pāp kamātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "смывают все совершённые прежде грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27084,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਹੋਏ ਕਰਿ ਇਸਨਾਨਾ ॥",
          "roman": "nirmal hoē kar isnānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Омывшись водой Имени Хари, они становятся людьми чистой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27085,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਕੀਨੇ ਦਾਨਾ ॥੧॥",
          "roman": "gur pūrē kīnē dānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но такую милость совершает только полный Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27086,
          "is_rahao": true,
          "gurmukhi": "ਸਭਿ ਕੁਸਲ ਖੇਮ ਪ੍ਰਭਿ ਧਾਰੇ ॥",
          "roman": "sabh kusal khēm prabh dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь порождает в сердце все духовные покои и радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27087,
          "is_rahao": true,
          "gurmukhi": "ਸਹੀ ਸਲਾਮਤਿ ਸਭਿ ਥੋਕ ਉਬਾਰੇ ਗੁਰ ਕਾ ਸਬਦੁ ਵੀਚਾਰੇ ॥ ਰਹਾਉ ॥",
          "roman": "sahī salāmat sabh thok ubārē gur kā sabad vīchārē rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто удерживает в своём сознании Слово Гуру, сохраняет все качества духовной жизни в целости от падения в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27088,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਲੁ ਲਾਥੀ ॥",
          "roman": "sādhsang mal lāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Садх Санғат, человек освобождается от грязи пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27089,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਭਇਓ ਸਾਥੀ ॥",
          "roman": "pārbrahm bhaio sāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря Садх Санғат Парабрахм становится его помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27090,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "nānak nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто, придя к Рамдас-саровару, вспоминал Имя Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27091,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖ ਪ੍ਰਭੁ ਪਾਇਆ ॥੨॥੧॥੬੫॥",
          "roman": "ād purakh prabh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "нашёл того Господа, который является началом всего и пребывает повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
