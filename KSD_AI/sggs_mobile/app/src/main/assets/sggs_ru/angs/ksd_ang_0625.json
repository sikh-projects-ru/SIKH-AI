      "lines": [
        {
          "verse_id": 27092,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сораṭх, Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27093,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਪਾਰਬ੍ਰਹਮੁ ਚਿਤਿ ਆਇਆ ॥ ਸੋ ਘਰੁ ਦਯਿ ਵਸਾਇਆ ॥",
          "roman": "jit pārbrahm chit āiā so ghar day vasāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот дом, в чьём сознании появился Парабрахм, Господь Сам сделал обителью благословения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
