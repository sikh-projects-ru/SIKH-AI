{
  "ang": 626,
  "shabads": [
    {
      "shabad_id": 2365,
      "rahao_verse_id": 27097,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27094,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਸਾਗਰੁ ਗੁਰੁ ਪਾਇਆ ॥ ਤਾ ਸਹਸਾ ਸਗਲ ਮਿਟਾਇਆ ॥੧॥",
          "roman": "sukh sāgar gur pāiā. tā sahsā sagal miṭāiā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда был обретён Гуру, океан счастья, тогда весь страх и сомнение исчезли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27095,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "har ke nām kī vaḍiāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Величие — в восхвалении Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27096,
          "is_rahao": true,
          "gurmukhi": "ਆਠ ਪਹਰ ਗੁਣ ਗਾਈ ॥",
          "roman": "āṭh pahar guṇ gāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все восемь страж дня и ночи воспевай достоинства Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27097,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਪਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "gur pūre te pāī. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот дар обретается только от совершенного Гуру. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27098,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਅਕਥ ਕਹਾਣੀ ॥",
          "roman": "prabh kī akath kahāṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повествование о сущности Господа невозможно полностью выразить словами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27099,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਬੋਲਹਿ ਅੰਮ੍ਰਿਤ ਬਾਣੀ ॥",
          "roman": "jan bolah amrit bāṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуги Господа произносят Бани хвалы, дающую духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27100,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਵਖਾਣੀ ॥",
          "roman": "nānak dās vakhāṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: слуги Господа произносят эту Бани."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27101,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਜਾਣੀ ॥੨॥੨॥੬੬॥",
          "roman": "gur pūre te jāṇī. ||2||2||66||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они познали это понимание от совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2366,
      "rahao_verse_id": 27109,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27102,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahlā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27103,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਸੁਖੁ ਗੁਰਿ ਦੀਆ ॥",
          "roman": "āgē sukh gur dīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру даровал покой и на пути будущей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27104,
          "is_rahao": false,
          "gurmukhi": "ਪਾਛੈ ਕੁਸਲ ਖੇਮ ਗੁਰਿ ਕੀਆ ॥",
          "roman": "pāchhē kusal khem gur kīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И в прошедшем, в этой жизни, Гуру дал мир, благополучие и радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27105,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਸੁਖ ਪਾਇਆ ॥",
          "roman": "sarab nidhān sukh pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так человек обрёл все духовные сокровища и всё счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27106,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਅਪੁਨਾ ਰਿਦੈ ਧਿਆਇਆ ॥੧॥",
          "roman": "gur apunā ridē dhiāiā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Потому что он поселил своего Гуру в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27107,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਸਤਿਗੁਰ ਕੀ ਵਡਿਆਈ ॥",
          "roman": "apne satigur kī vaḍiāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Таково величие и высокая духовная щедрость своего Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27108,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਇਛੇ ਫਲ ਪਾਈ ॥",
          "roman": "man ichhe phal pāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто приходит под защиту Гуру, получает желанные плоды сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27109,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਦਿਨੁ ਦਿਨੁ ਚੜੈ ਸਵਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "santah din din chaṛē savāī. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, щедрость Гуру день ото дня возрастает. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27110,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਭਿ ਭਏ ਦਇਆਲਾ ਪ੍ਰਭਿ ਅਪਨੇ ਕਰਿ ਦੀਨੇ ॥",
          "roman": "jīa jant sabh bhae daiālā prabh apne kar dīne.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все существа, пришедшие под защиту Гуру, становятся исполненными милости, и Господь делает их своими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27111,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਸੁਭਾਇ ਮਿਲੇ ਗੋਪਾਲਾ ਨਾਨਕ ਸਾਚਿ ਪਤੀਨੇ ॥੨॥੩॥੬੭॥",
          "roman": "sahaj subhāe mile gopālā nānak sāch patīne. ||2||3||67||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: благодаря духовной устойчивости и любви они встречают Господа-Хранителя мира и остаются опьянёнными Истинным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2367,
      "rahao_verse_id": 27118,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27112,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahlā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27113,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਰਖਵਾਰੇ ॥",
          "roman": "gur kā sabad rakhvāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слово Гуру — наш защитник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27114,
          "is_rahao": false,
          "gurmukhi": "ਚਉਕੀ ਚਉਗਿਰਦ ਹਮਾਰੇ ॥",
          "roman": "chaukī chaugirad hamāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это Слово стоит стражей вокруг нас со всех сторон."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27115,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮਿ ਮਨੁ ਲਾਗਾ ॥",
          "roman": "rām nām man lāgā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда ум соединяется с Именем Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27116,
          "is_rahao": false,
          "gurmukhi": "ਜਮੁ ਲਜਾਇ ਕਰਿ ਭਾਗਾ ॥੧॥",
          "roman": "jam lajāe kar bhāgā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даже Джам, посрамлённый, убегает от такого человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27117,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਜੀ ਤੂ ਮੇਰੋ ਸੁਖਦਾਤਾ ॥",
          "roman": "prabh jī tū mero sukhdātā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, для меня только Ты — даритель счастья."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27118,
          "is_rahao": true,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਿ ਕਰੇ ਮਨੁ ਨਿਰਮਲੁ ਪੂਰਨ ਪੁਰਖੁ ਬਿਧਾਤਾ ॥ ਰਹਾਉ ॥",
          "roman": "bandhan kāṭ kare man nirmal pūran purakh bidhātā. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всепроникающий Творец отсекает узы привязанности и очищает ум. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27119,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭੁ ਅਬਿਨਾਸੀ ॥",
          "roman": "nānak prabh abināsī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: бессмертный Господь так щедр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27120,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਸੇਵ ਨ ਬਿਰਥੀ ਜਾਸੀ ॥",
          "roman": "tā kī sev na birthī jāsī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "что служение и преданность Ему никогда не проходят впустую."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27121,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਕਰਹਿ ਤੇਰੇ ਦਾਸਾ ॥",
          "roman": "anad karah tere dāsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твои слуги всегда наслаждаются духовной радостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27122,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਪੂਰਨ ਹੋਈ ਆਸਾ ॥੨॥੪॥੬੮॥",
          "roman": "jap pūran hoī āsā. ||2||4||68||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя Твоё Имя, они обретают исполнение всех сердечных желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2368,
      "rahao_verse_id": 27129,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27123,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahlā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27124,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਅਪੁਨੇ ਬਲਿਹਾਰੀ ॥",
          "roman": "gur apune balihārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой своему Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27125,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਪੂਰਨ ਪੈਜ ਸਵਾਰੀ ॥",
          "roman": "jin pūran pēj savārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он полностью сохранил мою честь, даровав мне Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27126,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਚਿੰਦਿਆ ਫਲੁ ਪਾਇਆ ॥",
          "roman": "man chindiā phal pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек получает желанный плод сердца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27127,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਪੁਨਾ ਸਦਾ ਧਿਆਇਆ ॥੧॥",
          "roman": "prabh apunā sadā dhiāiā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "если всегда медитирует на своего Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27128,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਤਿਸੁ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "santah tis bin avar na koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О святые, кроме этого Господа, нет другого защитника."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27129,
          "is_rahao": true,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਪ੍ਰਭੁ ਸੋਈ ॥ ਰਹਾਉ ॥",
          "roman": "karaṇ kāraṇ prabh soī. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только этот Господь — первооснова всего мира. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27130,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਅਪਨੈ ਵਰ ਦੀਨੇ ॥",
          "roman": "prabh apnē var dīne.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Любимый Господь даровал все благословения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27131,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਜੀਅ ਵਸਿ ਕੀਨੇ ॥",
          "roman": "sagal jīa vas kīne.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он держит всех существ в своей власти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27132,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "jan nānak nām dhiāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак говорит: когда кто-либо медитирует на Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27133,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਸਗਲੇ ਦੂਖ ਮਿਟਾਇਆ ॥੨॥੫॥੬੯॥",
          "roman": "tā sagle dūkh miṭāiā. ||2||5||69||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда все его страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2369,
      "rahao_verse_id": 27140,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27134,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahlā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27135,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪੁ ਗਵਾਇਆ ਗੁਰਿ ਪੂਰੇ ॥",
          "roman": "tāp gavāiā gur pūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру устранил внутреннюю боль и страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27136,
          "is_rahao": false,
          "gurmukhi": "ਵਾਜੇ ਅਨਹਦ ਤੂਰੇ ॥",
          "roman": "vāje anahad tūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри зазвучали непрерывные трубы духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27137,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਿਆਣ ਪ੍ਰਭਿ ਕੀਨੇ ॥",
          "roman": "sarab kaliāṇ prabh kīne.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь даровал все виды счастья и благополучия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27138,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਆਪਿ ਦੀਨੇ ॥੧॥",
          "roman": "kar kirpā āp dīne. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По своей милости Он сам всё это дал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27139,
          "is_rahao": true,
          "gurmukhi": "ਬੇਦਨ ਸਤਿਗੁਰਿ ਆਪਿ ਗਵਾਈ ॥",
          "roman": "bedan satigur āp gavāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру сам устранил всякую боль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27140,
          "is_rahao": true,
          "gurmukhi": "ਸਿਖ ਸੰਤ ਸਭਿ ਸਰਸੇ ਹੋਏ ਹਰਿ ਹਰਿ ਨਾਮੁ ਧਿਆਈ ॥ ਰਹਾਉ ॥",
          "roman": "sikh sant sabh sarse hoe har har nām dhiāī. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все сикхи и святые, медитируя на Имя Бога, стали исполнены радости. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27141,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਮੰਗਹਿ ਸੋ ਲੇਵਹਿ ॥",
          "roman": "jo mangah so levah.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что бы святые ни просили у Твоих дверей, они это получают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27142,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਅਪਣਿਆ ਸੰਤਾ ਦੇਵਹਿ ॥",
          "roman": "prabh apṇiā santā devah.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты сам даёшь всё своим святым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27143,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੋਵਿਦੁ ਪ੍ਰਭਿ ਰਾਖਿਆ ॥",
          "roman": "har govid prabh rākhiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сам защитил Харгобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27144,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸਾਚੁ ਸੁਭਾਖਿਆ ॥੨॥੬॥੭੦॥",
          "roman": "jan nānak sāch subhākhiā. ||2||6||70||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак говорит: я произношу только Имя вечно Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2370,
      "rahao_verse_id": 27151,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27145,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mahlā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соратх, Пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27146,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਕਰਾਇ ਜੋ ਤੁਧੁ ਭਾਵੈ ॥",
          "roman": "soī karāe jo tudh bhāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, заставляй меня делать только то, что Тебе угодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27147,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਸਿਆਣਪ ਕਛੂ ਨ ਆਵੈ ॥",
          "roman": "moh siāṇap kachhū na āvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мне не приходит никакая собственная мудрость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27148,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਬਾਰਿਕ ਤਉ ਸਰਣਾਈ ॥",
          "roman": "ham bārik tau sarṇāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы — Твои дети и пришли под Твою защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27149,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਆਪੇ ਪੈਜ ਰਖਾਈ ॥੧॥",
          "roman": "prabh āpe pēj rakhāī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сам всегда сохраняет честь того, кто приходит под Его защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27150,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰਾ ਮਾਤ ਪਿਤਾ ਹਰਿ ਰਾਇਆ ॥",
          "roman": "merā māt pitā har rāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь-Царь, Ты — моя мать и мой отец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27151,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਤਿਪਾਲਣ ਲਾਗਾ ਕਰਂੀ ਤੇਰਾ ਕਰਾਇਆ ॥ ਰਹਾਉ ॥",
          "roman": "kar kirpā pratipālaṇ lāgā karī terā karāiā. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Ты сам заботишься обо мне; я делаю только то, что Ты заставляешь меня делать. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27152,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਤੇਰੇ ਧਾਰੇ ॥",
          "roman": "jīa jant tere dhāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все живые существа держатся на Твоей опоре."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27153,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਡੋਰੀ ਹਾਥਿ ਤੁਮਾਰੇ ॥",
          "roman": "prabh ḍorī hāth tumāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, нить жизни находится в Твоей руке."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
