{
  "ang": 628,
  "shabads": [
    {
      "shabad_id": 2376,
      "rahao_verse_id": 27217,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27216,
          "is_rahao": true,
          "gurmukhi": "ਸੰਤਹੁ ਸੁਖੁ ਹੋਆ ਸਭ ਥਾਈ ॥",
          "roman": "santahu sukh hoā sabh thā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! (ਉਸ ਮਨੁੱਖ ਨੂੰ) ਸਭ ਥਾਵਾਂ ਵਿਚ ਸੁਖ ਹੀ ਪ੍ਰਤੀਤ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! он ощущает счастье повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27217,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਪੂਰਨ ਪਰਮੇਸਰੁ ਰਵਿ ਰਹਿਆ ਸਭਨੀ ਜਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "pārbrahm pūraṇ parmesar rav rahiā sabhnī jā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਇਹ ਯਕੀਨ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ) ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਪਰਮੇਸਰ ਸਭ ਥਾਵਾਂ ਵਿਚ ਮੌਜੂਦ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "когда осознаёт, что Бог присутствует везде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27218,
          "is_rahao": false,
          "gurmukhi": "ਧੁਰ ਕੀ ਬਾਣੀ ਆਈ ॥",
          "roman": "dhur kī bāṇī ā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਆ ਵੱਸੀ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! когда в человеке поселяется божественная речь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27219,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸਗਲੀ ਚਿੰਤ ਮਿਟਾਈ ॥",
          "roman": "tin saglī chint miṭā-ī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਆਪਣੀ ਸਾਰੀ ਚਿੰਤਾ ਦੂਰ ਕਰ ਲਈ।"
            },
            "sahib_singh_ru": {
              "main": "он избавляется от всех забот."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27220,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਪੁਰਖ ਮਿਹਰਵਾਨਾ ॥",
          "roman": "da-iāl purakh miharvānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਇਆ ਦਾ ਸੋਮਾ ਪ੍ਰਭੂ ਉਸ ਮਨੁੱਖ ਉੱਤੇ ਮੇਹਰਵਾਨ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "милосердный Господь пребывает милостив к нему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27221,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਨਕ ਸਾਚੁ ਵਖਾਨਾ ॥੨॥੧੩॥੭੭॥",
          "roman": "har nānak sāch vakhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਉਸ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਸਦਾ) ਉਚਾਰਦਾ ਹੈ ॥੨॥੧੩॥੭੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак говорит: он постоянно произносит имя вечного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2377,
      "rahao_verse_id": 27228,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27222,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27223,
          "is_rahao": false,
          "gurmukhi": "ਐਥੈ ਓਥੈ ਰਖਵਾਲਾ ॥",
          "roman": "ēthē othē rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਪ੍ਰਭੂ ਸਰਨ ਪਿਆਂ ਦੀ) ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਰਾਖੀ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Он является защитником в этом мире и в мире ином для тех, кто ищет прибежище у Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27224,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਤਿਗੁਰ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "prabh satgur dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਪ੍ਰਭੂ ਗਰੀਬਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру-Прабху проявляет милость к бедным и униженным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27225,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਅਪਨੇ ਆਪਿ ਰਾਖੇ ॥",
          "roman": "dās apne āp rākhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪ੍ਰਭੂ) ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਆਪ ਰਖਿਆ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Господь Сам оберегает Своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27226,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸਬਦੁ ਸੁਭਾਖੇ ॥੧॥",
          "roman": "ghaṭ ghaṭ sabad subhākhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੇਵਕਾਂ ਨੂੰ ਇਹ ਨਿਸ਼ਚਾ ਰਹਿੰਦਾ ਹੈ ਕਿ) ਪ੍ਰਭੂ ਹਰੇਕ ਸਰੀਰ ਵਿਚ (ਆਪ ਹੀ) ਬਚਨ ਬੋਲ ਰਿਹਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Слуги уверены, что Господь Сам говорит в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27227,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਣ ਊਪਰਿ ਬਲਿ ਜਾਈ ॥",
          "roman": "gur ke charaṇ ūpar bal jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ (ਆਪਣੇ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я посвящаю себя стопам своего Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27228,
          "is_rahao": true,
          "gurmukhi": "ਦਿਨਸੁ ਰੈਨਿ ਸਾਸਿ ਸਾਸਿ ਸਮਾਲੀ ਪੂਰਨੁ ਸਭਨੀ ਥਾਈ ॥ ਰਹਾਉ ॥",
          "roman": "dinas rēn sās sās samālī pūran sabhnī thāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹੀ) ਮੈਂ (ਆਪਣੇ) ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਦਿਨ ਰਾਤ (ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ) ਯਾਦ ਕਰਦਾ ਰਹਿੰਦਾ ਹਾਂ ਜੋ ਸਭਨਾਂ ਥਾਵਾਂ ਵਿਚ ਭਰਪੂਰ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "по милости Гуру я помню Бога с каждым дыханием днём и ночью, Он присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27229,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਸਹਾਈ ਹੋਆ ॥",
          "roman": "āp sahāī hoā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਪਰਮਾਤਮਾ ਆਪ ਮਦਦਗਾਰ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру Сам Бог становится помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27230,
          "is_rahao": false,
          "gurmukhi": "ਸਚੇ ਦਾ ਸਚਾ ਢੋਆ ॥",
          "roman": "sache dā sachā ḍhoā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ) ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੀ ਸਿਫ਼ਤਿ ਸਾਲਾਹ ਦੀ ਦਾਤਿ ਮਿਲਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру даруется вечная хвала Вечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27231,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਭਗਤਿ ਵਡਿਆਈ ॥",
          "roman": "terī bhagat vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਭਗਤੀ ਤੇਰੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ-"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твоя преданность и хвала-"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27232,
          "is_rahao": false,
          "gurmukhi": "ਪਾਈ ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਈ ॥੨॥੧੪॥੭੮॥",
          "roman": "pāī nānak prabh saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਤੇਰੀ ਸਰਨ ਪਿਆਂ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ ॥੨॥੧੪॥੭੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Достигается, когда человек приходит в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2378,
      "rahao_verse_id": 27239,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27233,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27234,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਪੂਰੇ ਭਾਣਾ ॥",
          "roman": "satgur pūre bhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਭਾਈ!) ਜਦੋਂ ਗੁਰੂ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ਜਦੋਂ ਗੁਰੂ ਤ੍ਰੁੱਠਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда Гуру доволен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27235,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਜਪਿਆ ਨਾਮੁ ਰਮਾਣਾ ॥",
          "roman": "tā japiā nām ramāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда только можно повторять Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27236,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "gobind kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਮੇਹਰ ਕੀਤੀ (ਗੁਰੂ ਮਿਲਾਇਆ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਅਸਾਂ ਨਾਮ ਜਪਿਆ, ਤਾਂ)"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь проявляет милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27237,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਿ ਰਾਖੀ ਪੈਜ ਹਮਾਰੀ ॥੧॥",
          "roman": "prabh rākhi pēj hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਸਾਡੀ ਲਾਜ ਰੱਖ ਲਈ (ਬਿਖੈ ਠਗਉਰੀ ਤੋਂ ਬਚਾ ਲਿਆ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он сохраняет нашу честь и защищает нас."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27238,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੇ ਚਰਨ ਸਦਾ ਸੁਖਦਾਈ ॥",
          "roman": "har ke charaṇ sadā sukhḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਸਦਾ ਸੁਖ ਦੇਣ ਵਾਲੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Стопы Господа всегда приносят счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27239,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਇਛਹਿ ਸੋਈ ਫਲੁ ਪਾਵਹਿ ਬਿਰਥੀ ਆਸ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo ichhah soī phal pāveh birthī ās na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਮਨੁੱਖ ਹਰਿ-ਚਰਨਾਂ ਦਾ ਆਸਰਾ ਲੈਂਦੇ ਹਨ, ਉਹ) ਜੋ ਕੁਝ (ਪਰਮਾਤਮਾ ਪਾਸੋਂ) ਮੰਗਦੇ ਹਨ ਉਹੀ ਫਲ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦੇ ਹਨ। (ਪਰਮਾਤਮਾ ਦੀ ਸਹੈਤਾ ਉਤੇ ਰੱਖੀ ਹੋਈ ਕੋਈ ਭੀ) ਆਸ ਖ਼ਾਲੀ ਨਹੀਂ ਜਾਂਦੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Те, кто ищут прибежище у Господа, получают то, что желают; ни одна надежда не остаётся напрасной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27240,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਕਰੇ ਜਿਸੁ ਪ੍ਰਾਨਪਤਿ ਦਾਤਾ ਸੋਈ ਸੰਤੁ ਗੁਣ ਗਾਵੈ ॥",
          "roman": "kirpā kare jis prāṇpat dātā soī sant guṇ gāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੀਵਨ ਦਾ ਮਾਲਕ ਦਾਤਾਰ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਮੇਹਰ ਕਰਦਾ ਹੈ ਉਹ ਸੰਤ (ਸੁਭਾਉ ਬਣ ਜਾਂਦਾ ਹੈ, ਤੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кому Господь, дарующий жизнь, оказывает милость, тот становится святым и поёт Его славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27241,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਤਾ ਕਾ ਮਨੁ ਲੀਣਾ ਪਾਰਬ੍ਰਹਮ ਮਨਿ ਭਾਵੈ ॥੨॥",
          "roman": "prem bhagat tā kā man līṇā pārbrahm man bhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਮਨ ਪਰਮਾਤਮਾ ਦੀ ਪਿਆਰ-ਭਰੀ ਭਗਤੀ ਵਿਚ ਮਸਤ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਮਨ ਵਿਚ ਪਿਆਰਾ ਲੱਗਣ ਲੱਗ ਪੈਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Его ум погружается в любовную преданность, и он становится дорог Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27242,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਕਾ ਜਸੁ ਰਵਣਾ ਬਿਖੈ ਠਗਉਰੀ ਲਾਥੀ ॥",
          "roman": "āṭh pahar har kā jas ravṇā bikhē ṭhagaurī lāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨ ਨਾਲ ਵਿਕਾਰਾਂ ਦੀ ਠਗ-ਬੂਟੀ ਦਾ ਜ਼ੋਰ ਮੁੱਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Постоянное прославление Бога уничтожает силу обмана пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27243,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਮਿਲਾਇ ਲੀਆ ਮੇਰੈ ਕਰਤੈ ਸੰਤ ਸਾਧ ਭਏ ਸਾਥੀ ॥੩॥",
          "roman": "sang milāe līā merē kartē sant sādh bhe sāthī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਭੀ ਮਨੁੱਖ ਨੇ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਿਚ ਮਨ ਜੋੜਿਆ) ਕਰਤਾਰ ਨੇ (ਉਸ ਨੂੰ) ਆਪਣੇ ਨਾਲ ਮਿਲਾ ਲਿਆ, ਸੰਤ ਜਨ ਉਸ ਦੇ ਸੰਗੀ-ਸਾਥੀ ਬਣ ਗਏ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Творец соединяет такого человека с Собой, и святые становятся его спутниками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27244,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਗਹਿ ਲੀਨੇ ਸਰਬਸੁ ਦੀਨੇ ਆਪਹਿ ਆਪੁ ਮਿਲਾਇਆ ॥",
          "roman": "kar gah līne sarbas dīne āpah āp milāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸ਼ਰਨ ਪੈ ਕੇ ਜਿਸ ਭੀ ਮਨੁੱਖ ਨੇ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਦਾ ਆਰਾਧਨ ਕੀਤਾ) ਪ੍ਰਭੂ ਨੇ ਉਸ ਦਾ ਹੱਥ ਫੜ ਕੇ ਉਸ ਨੂੰ ਸਭ ਕੁਝ ਬਖ਼ਸ਼ ਦਿੱਤਾ, ਪ੍ਰਭੂ ਨੇ ਉਸ ਨੂੰ ਆਪਣਾ ਆਪ ਹੀ ਮਿਲਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Господь берёт его за руку, дарует всё и соединяет с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27245,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਰਬ ਥੋਕ ਪੂਰਨ ਪੂਰਾ ਸਤਿਗੁਰੁ ਪਾਇਆ ॥੪॥੧੫॥੭੯॥",
          "roman": "kaho nānak sarab thok pūran pūrā satgur pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪਿਆ, ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਸਫਲ ਹੋ ਗਏ ॥੪॥੧੫॥੭੯॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тот, кто нашёл совершенного Гуру, достиг полноты во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2379,
      "rahao_verse_id": 27252,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27246,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27247,
          "is_rahao": false,
          "gurmukhi": "ਗਰੀਬੀ ਗਦਾ ਹਮਾਰੀ ॥",
          "roman": "garībī gadā hamārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਿਮ੍ਰਤਾ-ਸੁਭਾਉ ਸਾਡੇ ਪਾਸ ਗੁਰਜ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Смирение — это наше оружие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27248,
          "is_rahao": false,
          "gurmukhi": "ਖੰਨਾ ਸਗਲ ਰੇਨੁ ਛਾਰੀ ॥",
          "roman": "khaṇnā sagal ren chhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੀ ਚਰਨ-ਧੂੜ ਬਣੇ ਰਹਿਣਾ ਸਾਡੇ ਪਾਸ ਖੰਡਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а быть пылью у ног всех — это наш меч."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27249,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਆਗੈ ਕੋ ਨ ਟਿਕੈ ਵੇਕਾਰੀ ॥",
          "roman": "is āgē ko na ṭikē vekārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ (ਗੁਰਜ) ਅੱਗੇ, ਇਸ (ਖੰਡੇ) ਅੱਗੇ ਕੋਈ ਭੀ ਕੁਕਰਮੀ ਟਿਕ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Перед этим не может устоять ни один грешник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27250,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਏਹ ਗਲ ਸਾਰੀ ॥੧॥",
          "roman": "gur pūre eh gal sārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਨੂੰ) ਪੂਰੇ ਗੁਰੂ ਨੇ ਇਹ ਗੱਲ ਸਮਝਾ ਦਿੱਤੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру объяснил нам это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27251,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਸੰਤਨ ਕੀ ਓਟਾ ॥",
          "roman": "har har nām santan kī oṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸੰਤ ਜਨਾਂ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Господа — опора святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27252,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਸਿਮਰੈ ਤਿਸ ਕੀ ਗਤਿ ਹੋਵੈ ਉਧਰਹਿ ਸਗਲੇ ਕੋਟਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo simrē tis kī gat hovē udhreh sagle koṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਸਿਮਰਦਾ ਹੈ, ਉਸ ਦੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ। (ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸਾਰੇ ਕ੍ਰੋੜਾਂ ਹੀ ਜੀਵ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто помнит Имя, достигает высокой духовной ступени; миллионы существ освобождаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27253,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸੰਗਿ ਜਸੁ ਗਾਇਆ ॥",
          "roman": "sant sang jas gāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਬੈਠ ਕੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто в обществе святых поёт славу Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27254,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਪੂਰਨ ਹਰਿ ਧਨੁ ਪਾਇਆ ॥",
          "roman": "ih pūran har dhan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਇਹ ਹਰਿ-ਨਾਮ ਧਨ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਹੈ ਜੋ ਕਦੇ ਭੀ ਨਹੀਂ ਮੁੱਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "получает это неиссякаемое сокровище Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27255,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਆਪੁ ਮਿਟਾਇਆ ॥",
          "roman": "kaho nānak āp miṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-  ਉਸ ਮਨੁੱਖ ਨੇ (ਆਪਣੇ ਅੰਦਰੋਂ ਆਪਾ-ਭਾਵ ਦੂਰ ਕਰ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: он устраняет своё эго,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27256,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਪਾਰਬ੍ਰਹਮੁ ਨਦਰੀ ਆਇਆ ॥੨॥੧੬॥੮੦॥",
          "roman": "sabh pārbrahm nadrī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਪਰਮਾਤਮਾ ਹੀ (ਵੱਸਦਾ) ਦਿੱਸ ਪਿਆ ਹੈ ॥੨॥੧੬॥੮੦॥"
            },
            "sahib_singh_ru": {
              "main": "и повсюду видит только Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2380,
      "rahao_verse_id": 27263,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 27257,
          "is_rahao": false,
          "gurmukhi": "ਸੋਰਠਿ ਮਹਲਾ ੫ ॥",
          "roman": "soraṭh mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27258,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਪੂਰੀ ਕੀਨੀ ॥",
          "roman": "gur pūrē pūrī kīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪੂਰੇ ਗੁਰੂ ਨੇ ਪੂਰੀ ਕਿਰਪਾ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тому, на кого совершенный Гуру проявил милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27259,
          "is_rahao": false,
          "gurmukhi": "ਬਖਸ ਅਪੁਨੀ ਕਰਿ ਦੀਨੀ ॥",
          "roman": "bakhas apunī kar dīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਗੁਰੂ ਨੇ ਆਪਣੇ ਦਰ ਤੋਂ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਦੀ ਦਾਤਿ ਦੇ ਦਿੱਤੀ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру дарует благословение преданности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27260,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਅਨੰਦ ਸੁਖ ਪਾਇਆ ॥",
          "roman": "nit anand sukh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਆਤਮਕ ਸੁਖ ਆਤਮਕ ਆਨੰਦ ਮਾਣਨ ਲੱਗ ਪਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно пребывает в духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27261,
          "is_rahao": false,
          "gurmukhi": "ਥਾਵ ਸਗਲੇ ਸੁਖੀ ਵਸਾਇਆ ॥੧॥",
          "roman": "thāv sagle sukhī vasāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਉਸ ਦੇ ਸਾਰੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਨੂੰ (ਵਿਕਾਰਾਂ ਵਲੋਂ ਬਚਾ ਕੇ) ਸ਼ਾਂਤੀ ਵਿਚ ਟਿਕਾ ਦਿੱਤਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру устанавливает все его чувства в покое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27262,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕੀ ਭਗਤਿ ਫਲ ਦਾਤੀ ॥",
          "roman": "har kī bhagat phal dātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਸਾਰੇ ਫਲ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Преданность Богу дарует все плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27263,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਕਿਰਪਾ ਕਰਿ ਦੀਨੀ ਵਿਰਲੈ ਕਿਨ ਹੀ ਜਾਤੀ ॥ ਰਹਾਉ ॥",
          "roman": "gur pūrē kirpā kar dīnī virlē kin hī jātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ) ਮੇਹਰ ਕਰ ਦਿੱਤੀ (ਉਸ ਨੇ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰਨੀ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤੀ। ਪਰ, ਹੇ ਭਾਈ!) ਕਿਸੇ ਵਿਰਲੇ ਮਨੁੱਖ ਨੇ ਹੀ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਦੀ ਕਦਰ ਸਮਝੀ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру дарует милость, но лишь немногие понимают ценность преданности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27264,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਬਾਣੀ ਗਾਵਹ ਭਾਈ ॥",
          "roman": "gurbāṇī gāvah bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਓ ਅਸੀਂ ਭੀ ਗੁਰੂ ਦੀ ਬਾਣੀ ਗਾਵਿਆ ਕਰੀਏ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Давайте петь Бани Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27265,
          "is_rahao": false,
          "gurmukhi": "ਓਹ ਸਫਲ ਸਦਾ ਸੁਖਦਾਈ ॥",
          "roman": "oh safal sadā sukhḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਬਾਣੀ ਸਦਾ ਹੀ ਸਾਰੇ ਫਲ ਦੇਣ ਵਾਲੀ ਸੁਖ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бани Гуру всегда приносит плоды и счастье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27266,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥",
          "roman": "nānak nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) (ਉਸੇ ਮਨੁੱਖ ਨੇ ਗੁਰਬਾਣੀ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਸਿਮਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кто размышляет об Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 27267,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਬਿ ਲਿਖਿਆ ਪਾਇਆ ॥੨॥੧੭॥੮੧॥",
          "roman": "pūrab likhiā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਪੂਰਬਲੇ ਜਨਮ ਵਿਚ ਲਿਖਿਆ ਭਗਤੀ ਦਾ ਲੇਖ ਪ੍ਰਾਪਤ ਕੀਤਾ ਹੈ ॥੨॥੧੭॥੮੧॥"
            },
            "sahib_singh_ru": {
              "main": "получает это согласно написанному в прошлых жизнях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
