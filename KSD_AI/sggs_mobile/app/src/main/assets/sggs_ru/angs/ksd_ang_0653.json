{
  "ang": 653,
  "shabads": [
    {
      "shabad_id": 2493,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28217,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਏ ਪੁਨੀਤ ਹਰਿ ਤੀਰਥਿ ਨਾਇਆ ॥੨੬॥",
          "roman": "nānak bhae punīt har tīrath nāiā ॥26॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, они стали чистыми, омывшись в священном месте Хар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2494,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28218,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੪ ॥",
          "roman": "salok mahallā 4 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махалла 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28219,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਅੰਤਰਿ ਸਾਂਤਿ ਹੈ ਮਨਿ ਤਨਿ ਨਾਮਿ ਸਮਾਇ ॥",
          "roman": "gurmukh antar sānt hē man tan nām samāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У человека, обращённого к Сатгуру, внутри покой; он умом и телом пребывает погружённым в Наам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28220,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੋ ਚਿਤਵੈ ਨਾਮੁ ਪੜੈ ਨਾਮਿ ਰਹੈ ਲਿਵ ਲਾਇ ॥",
          "roman": "nāmo chitvē nām paṛhē nām rahey liv lāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он вспоминает только Наам, читает только Наам и удерживает внимание соединённым с Наамом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28221,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਪਦਾਰਥੁ ਪਾਇਆ ਚਿੰਤਾ ਗਈ ਬਿਲਾਇ ॥",
          "roman": "nām padārath pāiā chintā gaī bilāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Найдя прекрасное сокровище Наам, он освобождается от тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28222,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮਿਲਿਐ ਨਾਮੁ ਊਪਜੈ ਤਿਸਨਾ ਭੁਖ ਸਭ ਜਾਇ ॥",
          "roman": "satigur miliē nām ūpajē tisnā bhukh sabh jāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда встречается Гуру, Наам прорастает в сердце, и вся жажда, вся голодная тяга к Майе уходят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28223,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੇ ਰਤਿਆ ਨਾਮੋ ਪਲੈ ਪਾਇ ॥੧॥",
          "roman": "nānak nāme ratiā nāmo palē pāe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда человек окрашен Наамом, Наам запечатлевается в его сердечном уделе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2495,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28224,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੪ ॥",
          "roman": "mahallā 4 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махалла 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28225,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਪੁਰਖਿ ਜਿ ਮਾਰਿਆ ਭ੍ਰਮਿ ਭ੍ਰਮਿਆ ਘਰੁ ਛੋਡਿ ਗਇਆ ॥",
          "roman": "satigur purakh j māriā bhram bhramiā ghar chhoḍ gaiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, поражённый Гуру-Пармешаром, то есть совершенно отвернувшийся от стороны Бога, блуждая в заблуждении, покидает своё истинное место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28226,
          "is_rahao": false,
          "gurmukhi": "ਓਸੁ ਪਿਛੈ ਵਜੈ ਫਕੜੀ ਮੁਹੁ ਕਾਲਾ ਆਗੈ ਭਇਆ ॥",
          "roman": "os pichhē vajē fakṛī muh kālā āgē bhēā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "За его спиной люди бьют насмешливую трещотку, а впереди, куда бы он ни пошёл, он зарабатывает себе позор."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28227,
          "is_rahao": false,
          "gurmukhi": "ਓਸੁ ਅਰਲੁ ਬਰਲੁ ਮੁਹਹੁ ਨਿਕਲੈ ਨਿਤ ਝਗੂ ਸੁਟਦਾ ਮੁਆ ॥",
          "roman": "os aral baral muhah niklē nit jhagū suṭdā muā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из его уст выходит один лишь вздор; постоянно злословя, он остаётся несчастным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28228,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਹੋਵੈ ਕਿਸੈ ਹੀ ਦੈ ਕੀਤੈ ਜਾਂ ਧੁਰਿ ਕਿਰਤੁ ਓਸ ਦਾ ਏਹੋ ਜੇਹਾ ਪਇਆ ॥",
          "roman": "kiā hovē kisē hī dē kītē jāṅ dhur kirat os dā eho jehā pēā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что может сделать кто-либо другой, если с самого начала по прежним поступкам ему досталась такая дурная склонность к злословию?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28229,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਓਹੁ ਜਾਇ ਤਿਥੈ ਓਹੁ ਝੂਠਾ ਕੂੜੁ ਬੋਲੇ ਕਿਸੈ ਨ ਭਾਵੈ ॥",
          "roman": "jithē oh jāe tithē oh jhūṭhā kūṛ boley kisē na bhāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Куда бы ни пошёл такой манмукх, всюду он оказывается лживым; он говорит ложь и никому не нравится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28230,
          "is_rahao": false,
          "gurmukhi": "ਵੇਖਹੁ ਭਾਈ ਵਡਿਆਈ ਹਰਿ ਸੰਤਹੁ ਸੁਆਮੀ ਅਪੁਨੇ ਕੀ ਜੈਸਾ ਕੋਈ ਕਰੈ ਤੈਸਾ ਕੋਈ ਪਾਵੈ ॥",
          "roman": "vekhh bhāī vaḍiāī har santah suāmī apune kī jēsā koī karē tēsā koī pāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О братья, о святые, посмотрите на величие своего любимого Владыки-Прабху: какую работу кто совершает, такой плод и получает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28231,
          "is_rahao": false,
          "gurmukhi": "ਏਹੁ ਬ੍ਰਹਮ ਬੀਚਾਰੁ ਹੋਵੈ ਦਰਿ ਸਾਚੈ ਅਗੋ ਦੇ ਜਨੁ ਨਾਨਕੁ ਆਖਿ ਸੁਣਾਵੈ ॥੨॥",
          "roman": "eh brahm bīchār hovē dar sāchē ago de jan nānak ākh suṇāvē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такое истинное рассмотрение совершается в истинном Дворе; слуга Нанак заранее говорит и даёт услышать это, чтобы можно было сеять добро и надеяться на добрый плод."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2496,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28232,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28233,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਸਚੈ ਬਧਾ ਥੇਹੁ ਰਖਵਾਲੇ ਗੁਰਿ ਦਿਤੇ ॥",
          "roman": "gur sachē badhā theh rakhvāle gur dite ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный Сатгуру основал селение Сатсанга, и для этого селения Сатгуру сам дал стражей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28234,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਈ ਆਸ ਗੁਰ ਚਰਣੀ ਮਨ ਰਤੇ ॥",
          "roman": "pūran hoī ās gur charṇī man rate ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех, чьи умы окрашены у стоп Гуру, надежда исполнилась, то есть их жажда угасла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28235,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਕ੍ਰਿਪਾਲਿ ਬੇਅੰਤਿ ਅਵਗੁਣ ਸਭਿ ਹਤੇ ॥",
          "roman": "gur kripāl beant avguṇ sabh hate ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милостивый и бесконечный Гуру уничтожил все их грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28236,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਅਪਣੀ ਕਿਰਪਾ ਧਾਰਿ ਅਪਣੇ ਕਰਿ ਲਿਤੇ ॥",
          "roman": "gur apṇī kirpā dhār apṇe kar lite ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру, явив свою милость, сделал их своими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28237,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਦ ਬਲਿਹਾਰ ਜਿਸੁ ਗੁਰ ਕੇ ਗੁਣ ਇਤੇ ॥੨੭॥",
          "roman": "nānak sad balihār jis gur ke guṇ ite ॥27॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я всегда жертвую собой тому Сатгуру, в котором столько достоинств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2497,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28238,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahallā 1 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махалла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28239,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਰਜਾਇ ਲੇਖਿਆ ਪਾਇ ਅਬ ਕਿਆ ਕੀਜੈ ਪਾਂਡੇ ॥",
          "roman": "tā kī rajāe lekhiā pāe ab kiā kījē pāṅḍe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О пандит, теперь от сожалений ничего не выйдет; в воле Прабху человек получает запись согласно прежним делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28240,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਹੋਆ ਹਾਸਲੁ ਤਦੇ ਹੋਇ ਨਿਬੜਿਆ ਹੰਢਹਿ ਜੀਅ ਕਮਾਂਦੇ ॥੧॥",
          "roman": "hukam hoā hāsal tade hoe nibaṛiā haṅḍhahi jīa kamānde ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда пришёл приказ Прабху, тогда это решение стало окончательным, и согласно этой записи существа ходят, совершая свои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2498,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28241,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahallā 2 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махалла 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28242,
          "is_rahao": false,
          "gurmukhi": "ਨਕਿ ਨਥ ਖਸਮ ਹਥ ਕਿਰਤੁ ਧਕੇ ਦੇ ॥",
          "roman": "nak nath khasam hath kirat dhakke de ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В носу существа находится недоуздок воли, и он в руке Владыки-Прабху; склонность, созданная прежними поступками, теперь толкает его вперёд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28243,
          "is_rahao": false,
          "gurmukhi": "ਜਹਾ ਦਾਣੇ ਤਹਾਂ ਖਾਣੇ ਨਾਨਕਾ ਸਚੁ ਹੇ ॥੨॥",
          "roman": "jahā dāṇe tahāṅ khāṇe nānakā sach he ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, истина такова: где у существа назначены зерно и вода, там ему и приходится есть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2499,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28244,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28245,
          "is_rahao": false,
          "gurmukhi": "ਸਭੇ ਗਲਾ ਆਪਿ ਥਾਟਿ ਬਹਾਲੀਓਨੁ ॥",
          "roman": "sabhe galā āp thāṭ bahālīon ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам создал и установил все порядки мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28246,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਰਚਨੁ ਰਚਾਇ ਆਪੇ ਹੀ ਘਾਲਿਓਨੁ ॥",
          "roman": "āpe rachan rachāe āpe hī ghālīon ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам творит мироздание и сам же его разрушает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28247,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਜੰਤ ਉਪਾਇ ਆਪਿ ਪ੍ਰਤਿਪਾਲਿਓਨੁ ॥",
          "roman": "āpe jant upāe āp pratipālīon ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам создаёт существ и сам их поддерживает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28248,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਰਖੇ ਕੰਠਿ ਲਾਇ ਨਦਰਿ ਨਿਹਾਲਿਓਨੁ ॥",
          "roman": "dās rakhe kaṇṭh lāe nadar nihālīon ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам, прижав к груди, хранит своих слуг и сам смотрит на них милостивым взглядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28249,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤਾ ਸਦਾ ਅਨੰਦੁ ਭਾਉ ਦੂਜਾ ਜਾਲਿਓਨੁ ॥੨੮॥",
          "roman": "nānak bhagtā sadā anand bhāu dūjā jālīon ॥28॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у бхагтов всегда радость, потому что любовь к Майе Прабху сам сжёг в них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2500,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28250,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahallā 3 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махалла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28251,
          "is_rahao": false,
          "gurmukhi": "ਏ ਮਨ ਹਰਿ ਜੀ ਧਿਆਇ ਤੂ ਇਕ ਮਨਿ ਇਕ ਚਿਤਿ ਭਾਇ ॥",
          "roman": "e man har jī dhiāe tū ik man ik chit bhāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, с любовью и сосредоточенным сознанием созерцай Хар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28252,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੀਆ ਸਦਾ ਸਦਾ ਵਡਿਆਈਆ ਦੇਇ ਨ ਪਛੋਤਾਇ ॥",
          "roman": "har kīā sadā sadā vaḍiāīā dei na pachhotāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Таковы вечные достоинства Хар: даруя дары, Он не сожалеет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28253,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਹਰਿ ਕੈ ਸਦ ਬਲਿਹਾਰਣੈ ਜਿਤੁ ਸੇਵਿਐ ਸੁਖੁ ਪਾਇ ॥",
          "roman": "hau har kē sad balihārṇē jit seviē sukh pāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я всегда жертвую собой Хар, служение которому приносит покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28254,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮਿਲਿ ਰਹੈ ਹਉਮੈ ਸਬਦਿ ਜਲਾਇ ॥੧॥",
          "roman": "nānak gurmukh mil rahē haumē sabad jalāe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, гурмукх, сжигая Хоумэ через Шабад Сатгуру, пребывает соединённым с Хар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2501,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28255,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahallā 3 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махалла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28256,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸੇਵਾ ਲਾਇਅਨੁ ਆਪੇ ਬਖਸ ਕਰੇਇ ॥",
          "roman": "āpe sevā lāian āpe bakhas kare ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хар сам поставил людей на служение и сам дарует прощение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28257,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨਾ ਕਾ ਮਾ ਪਿਉ ਆਪਿ ਹੈ ਆਪੇ ਸਾਰ ਕਰੇਇ ॥",
          "roman": "sabhnā kā mā piu āp hē āpe sār kare ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам мать и отец всех и сам заботится обо всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28258,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਨਿ ਤਿਨ ਨਿਜ ਘਰਿ ਵਾਸੁ ਹੈ ਜੁਗੁ ਜੁਗੁ ਸੋਭਾ ਹੋਇ ॥੨॥",
          "roman": "nānak nām dhiāin tin nij ghar vās hē jug jug sobhā hoe ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто созерцает Наам, пребывают в своём истинном доме; в каждом веке их слава сияет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2502,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28259,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28260,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਕਰਣ ਕਾਰਣ ਸਮਰਥੁ ਹਹਿ ਕਰਤੇ ਮੈ ਤੁਝ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ॥",
          "roman": "tū karaṇ kāraṇ samrath hah karte mē tujh bin avar na koī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Картар, Ты способен сотворить всю природу; кроме Тебя я не вижу никого, равного Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
