{
  "ang": 655,
  "shabads": [
    {
      "shabad_id": 2505,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28296,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜਨ ਭਏ ਖਾਲਸੇ ਪ੍ਰੇਮ ਭਗਤਿ ਜਿਹ ਜਾਨੀ ॥੪॥੩॥",
          "roman": "kah kabīr jan bhae khālase prem bhagat jih jānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੇ ਪ੍ਰੇਮਾ-ਭਗਤੀ ਕਰਨੀ ਸਮਝ ਲਈ ਹੈ ਉਹ (ਮੌਤ ਦੇ ਸਹਿਮ ਤੋਂ) ਆਜ਼ਾਦ ਹੋ ਗਏ ਹਨ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: те, кто познали любовь и преданность, стали свободными от страха смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2506,
      "rahao_verse_id": 28303,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28297,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ੨ ॥",
          "roman": "ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28298,
          "is_rahao": false,
          "gurmukhi": "ਦੁਇ ਦੁਇ ਲੋਚਨ ਪੇਖਾ ॥",
          "roman": "dui dui lochan pekhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਤਾਂ) ਮੈਂ (ਜਿੱਧਰ) ਅੱਖਾਂ ਖੋਲ੍ਹ ਕੇ ਤੱਕਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "(Теперь) я, куда ни открываю глаза и смотрю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28299,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਹਰਿ ਬਿਨੁ ਅਉਰੁ ਨ ਦੇਖਾ ॥",
          "roman": "hau har bin aur na dekhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਹੋਰ (ਓਪਰਾ) ਕੋਈ ਦਿੱਸਦਾ ਹੀ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "мне, кроме Бога, ничего и никого другого вовсе не видно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28300,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨ ਰਹੇ ਰੰਗੁ ਲਾਈ ॥",
          "roman": "nēn rahe rang lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀਆਂ ਅੱਖਾਂ (ਪ੍ਰਭੂ ਨਾਲ) ਪਿਆਰ ਲਾਈ ਬੈਠੀਆਂ ਹਨ (ਮੈਨੂੰ ਹਰ ਪਾਸੇ ਪ੍ਰਭੂ ਹੀ ਦਿੱਸਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Мои глаза погружены в любовь к Нему (и потому везде вижу только Его),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28301,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਬੇ ਗਲ ਕਹਨੁ ਨ ਜਾਈ ॥੧॥",
          "roman": "ab be gal kahan na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਥੋਂ ਕੋਈ ਹੋਰ ਗੱਲ ਆਖੀ ਹੀ ਨਹੀਂ ਜਾ ਸਕਦੀ (ਭਾਵ, ਮੈਂ ਹੁਣ ਇਹ ਆਖਣ-ਜੋਗਾ ਹੀ ਨਹੀਂ ਰਿਹਾ ਕਿ ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਭੀ ਕਿਤੇ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "теперь я не могу сказать ничего иного (я уже не способен говорить, будто есть что-то кроме Бога) ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28302,
          "is_rahao": true,
          "gurmukhi": "ਹਮਰਾ ਭਰਮੁ ਗਇਆ ਭਉ ਭਾਗਾ ॥",
          "roman": "hamrā bharam gayā bhau bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਦੋਂ ਤੋਂ) ਮੇਰਾ ਭੁਲੇਖਾ ਦੂਰ ਹੋ ਗਿਆ ਹੈ (ਕਿ ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਹਸਤੀ ਭੀ ਜਗਤ ਵਿਚ ਹੈ; ਇਸ ਭੁਲੇਖੇ ਦੇ ਦੂਰ ਹੋਣ ਨਾਲ) ਹੁਣ ਕੋਈ ਡਰ ਨਹੀਂ ਰਹਿ ਗਿਆ (ਕਿਉਂਕਿ ਡਰ ਤਾਂ ਕਿਸੇ ਓਪਰੇ ਪਾਸੋਂ ਹੀ ਹੋ ਸਕਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "С тех пор мой обман исчез, и страх ушёл (ведь страх бывает только перед чем-то чуждым)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28303,
          "is_rahao": true,
          "gurmukhi": "ਜਬ ਰਾਮ ਨਾਮ ਚਿਤੁ ਲਾਗਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jab rām nām chit lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਤੋਂ ਮੇਰਾ ਚਿੱਤ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਗਿੱਝ ਗਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "с тех пор как моё сознание погрузилось в Имя Бога ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28304,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜੀਗਰ ਡੰਕ ਬਜਾਈ ॥",
          "roman": "bājīgar ḍaṅk bajāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ ਹੁਣ ਇਉਂ ਦਿੱਸਦਾ ਹੈ ਕਿ) ਜਦੋਂ ਪ੍ਰਭੂ-ਬਾਜ਼ੀਗਰ ਡੁਗਡੁਗੀ ਵਜਾਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(Мне теперь так видится:) когда Бог-фокусник бьёт в барабан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28305,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਖਲਕ ਤਮਾਸੇ ਆਈ ॥",
          "roman": "sabh khalak tamāse āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਸਾਰੀ ਖ਼ਲਕਤ (ਜਗਤ-) ਤਮਾਸ਼ਾ ਵੇਖਣ ਆ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "всё творение приходит смотреть представление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28306,
          "is_rahao": false,
          "gurmukhi": "ਬਾਜੀਗਰ ਸ੍ਵਾਂਗੁ ਸਕੇਲਾ ॥",
          "roman": "bājīgar svāṅg sakelā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਦੋਂ ਉਹ ਬਾਜੀਗਰ ਖੇਲ ਸਮੇਟਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "а когда он сворачивает игру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28307,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਰੰਗ ਰਵੈ ਅਕੇਲਾ ॥੨॥",
          "roman": "apne rang ravē akelā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਇਕੱਲਾ ਆਪ ਹੀ ਆਪ ਆਪਣੀ ਮੌਜ ਵਿਚ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "он остаётся один, пребывая в собственной игре ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28308,
          "is_rahao": false,
          "gurmukhi": "ਕਥਨੀ ਕਹਿ ਭਰਮੁ ਨ ਜਾਈ ॥",
          "roman": "kathnī kah bharam na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਇਹ ਦ੍ਵੈਤ ਦਾ) ਭੁਲੇਖਾ ਨਿਰੀਆਂ ਗੱਲਾਂ ਕਰਨ ਨਾਲ ਦੂਰ ਨਹੀਂ ਹੁੰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Но этот обман двойственности не уходит от одних разговоров,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28309,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਥਿ ਕਥਿ ਰਹੀ ਲੁਕਾਈ ॥",
          "roman": "sabh kath kath rahī lukāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਰੀਆਂ ਗੱਲਾਂ ਕਰ ਕਰ ਕੇ ਤਾਂ ਸਾਰੀ ਦੁਨੀਆ ਥੱਕ ਚੁੱਕੀ ਹੈ (ਕਿਸੇ ਦੇ ਅੰਦਰੋਂ ਦ੍ਵੈਤ-ਭਾਵ ਜਾਂਦੀ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "весь мир устал говорить, но двойственность не исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28310,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਗੁਰਮੁਖਿ ਆਪਿ ਬੁਝਾਈ ॥",
          "roman": "jā kau gurmukh āp bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਆਪ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਸੁਮੱਤ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому Сам Бог через Гуру даёт понимание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28311,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੇ ਹਿਰਦੈ ਰਹਿਆ ਸਮਾਈ ॥੩॥",
          "roman": "tā ke hirdē rahiā samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਸਦਾ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в его сердце Он всегда пребывает ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28312,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿੰਚਤ ਕਿਰਪਾ ਕੀਨੀ ॥",
          "roman": "gur kinchat kirpā kīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਗੁਰੂ ਨੇ ਥੋੜੀ ਜਿਤਨੀ ਭੀ ਮਿਹਰ ਕਰ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Гуру хотя бы немного проявил милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28313,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਤਨੁ ਮਨੁ ਦੇਹ ਹਰਿ ਲੀਨੀ ॥",
          "roman": "sabh tan man deh har līnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਤਨ ਤੇ ਮਨ ਸਭ ਹਰੀ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот телом и умом полностью растворяется в Боге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28314,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਰੰਗਿ ਰਾਤਾ ॥",
          "roman": "kah Kabīr rang rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਉਹ ਪ੍ਰਭੂ ਦੇ ਪਿਆਰ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: он окрашивается любовью Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28315,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿਓ ਜਗਜੀਵਨ ਦਾਤਾ ॥੪॥੪॥",
          "roman": "milio jagjīvan dātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ਜੋ ਸਾਰੇ ਜਗਤ ਨੂੰ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "и встречает Того, кто даёт жизнь всему миру ॥4॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2507,
      "rahao_verse_id": 28321,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28316,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਨਿਗਮ ਦੂਧ ਕੇ ਠਾਟਾ ॥",
          "roman": "jā ke nigam dūdh ke ṭhāṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜਿੰਦੇ! ਤੂੰ ਉਸ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਚਿੱਤ ਜੋੜ) ਵੇਦ ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕ ਜਿਸ ਦੇ (ਨਾਮ-ਅੰਮ੍ਰਿਤ) ਦੁੱਧ ਦੇ ਸੋਮੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Веды и священные книги — источники молока Его Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28317,
          "is_rahao": false,
          "gurmukhi": "ਸਮੁੰਦੁ ਬਿਲੋਵਨ ਕਉ ਮਾਟਾ ॥",
          "roman": "samund bilovan kau māṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਤਸੰਗ ਉਸ ਦੁੱਧ ਦੇ ਰਿੜਕਣ ਲਈ ਚਾਟੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а святое собрание — это сосуд для взбивания этого молока."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28318,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਹੋਹੁ ਬਿਲੋਵਨਹਾਰੀ ॥",
          "roman": "tā kī hoh bilovanhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜਿੰਦੇ!) ਤੂੰ ਉਸ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਰਿੜਕਣ ਵਾਲੀ ਬਣ।"
            },
            "sahib_singh_ru": {
              "main": "Стань той, кто взбивает Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28319,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਮੇਟੈ ਗੋ ਛਾਛਿ ਤੁਹਾਰੀ ॥੧॥",
          "roman": "kiu meṭē go chhāchh tuhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜਿੰਦੇ! ਜੇ ਤੈਨੂੰ ਹਰਿ-ਮਿਲਾਪ ਨਸੀਬ ਨਾਹ ਹੋਇਆ, ਤਾਂ ਭੀ) ਉਹ ਪ੍ਰਭੂ (ਸਤਸੰਗ ਵਿਚ ਬੈਠ ਕੇ ਧਰਮ-ਪੁਸਤਕਾਂ ਦੇ ਵਿਚਾਰਨ ਦਾ) ਤੇਰਾ ਸਾਧਾਰਨ ਅਨੰਦ ਨਹੀਂ ਮਿਟਾਇਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Даже если не достигнешь Бога, Он не лишит тебя этого духовного наслаждения ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28320,
          "is_rahao": true,
          "gurmukhi": "ਚੇਰੀ ਤੂ ਰਾਮੁ ਨ ਕਰਸਿ ਭਤਾਰਾ ॥",
          "roman": "cherī tū rām na karas bhatārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਿੰਦੇ! ਤੂੰ ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਕਿਉਂ ਆਪਣਾ ਖਸਮ ਨਹੀਂ ਬਣਾਉਂਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О душа, почему ты не делаешь Бога своим супругом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28321,
          "is_rahao": true,
          "gurmukhi": "ਜਗਜੀਵਨ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jagjīvan prān adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜਗਤ ਦਾ ਜੀਵਨ ਹੈ ਤੇ ਸਭ ਦੇ ਪ੍ਰਾਣਾਂ ਦਾ ਆਸਰਾ ਹੈ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он — жизнь мира и опора всех существ ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28322,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਗਲਹਿ ਤਉਕੁ ਪਗ ਬੇਰੀ ॥",
          "roman": "tere galah tauk pag berī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਿੰਦੇ! ਤੇਰੇ ਗਲ ਵਿਚ ਮੋਹ ਦਾ ਪਟਾ ਤੇ ਤੇਰੇ ਪੈਰਾਂ ਵਿਚ ਆਸਾਂ ਦੀਆਂ ਬੇੜੀਆਂ ਹੋਣ ਕਰਕੇ,"
            },
            "sahib_singh_ru": {
              "main": "На твоей шее цепь привязанности, на ногах — оковы желаний,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28323,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਘਰ ਘਰ ਰਮਈਐ ਫੇਰੀ ॥",
          "roman": "tū ghar ghar ramaiyai pherī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਪਰਮਾਤਮਾ ਨੇ ਘਰ ਘਰ (ਕਈ ਜੂਨਾਂ ਵਿਚ) ਫਿਰਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и потому Бог заставляет тебя скитаться из жизни в жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28324,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਅਜਹੁ ਨ ਚੇਤਸਿ ਚੇਰੀ ॥",
          "roman": "tū ajah na chetas cherī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਭਾਗਾਂ ਨਾਲ ਕਿਤੇ ਮਨੁੱਖਾ-ਜਨਮ ਮਿਲਿਆ ਸੀ) ਹੁਣ ਭੀ ਤੂੰ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਨਹੀਂ ਕਰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "И даже теперь ты не помнишь Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28325,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਜਮਿ ਬਪੁਰੀ ਹੈ ਹੇਰੀ ॥੨॥",
          "roman": "tū jam bapurī hē herī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਗ-ਹੀਣ! ਤੈਨੂੰ ਜਮ ਨੇ ਆਪਣੀ ਤੱਕ ਵਿਚ ਰੱਖਿਆ ਹੋਇਆ ਹੈ (ਭਾਵ, ਮੌਤ ਆਇਆਂ ਫਿਰ ਪਤਾ ਨਹੀਂ ਕਿਸ ਲੰਮੇ ਗੇੜ ਵਿਚ ਪੈ ਜਾਇਂਗੀ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О несчастная, смерть следит за тобой ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28326,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕਰਨ ਕਰਾਵਨਹਾਰੀ ॥",
          "roman": "prabh karan karāvanhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਕੁਝ ਕਰਨ ਕਰਾਉਣ ਵਾਲਾ ਪ੍ਰਭੂ ਆਪ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё делает Сам Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28327,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਚੇਰੀ ਹਾਥ ਬਿਚਾਰੀ ॥",
          "roman": "kiā cherī hāth bichārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਸ ਵਿਚਾਰੀ ਜਿੰਦ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?"
            },
            "sahib_singh_ru": {
              "main": "Что может сделать эта бедная душа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28328,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਸੋਈ ਜਾਗੀ ॥",
          "roman": "soī soī jāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਕਈ ਜਨਮਾਂ ਦੀ ਸੁੱਤੀ ਹੋਈ ਜਿੰਦ (ਤਦੋਂ ਹੀ) ਜਾਗਦੀ ਹੈ (ਜਦੋਂ ਉਹ ਆਪ ਜਗਾਉਂਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Эта спящая душа пробуждается лишь тогда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28329,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਲਾਈ ਤਿਤੁ ਲਾਗੀ ॥੩॥",
          "roman": "jit lāī tit lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਜਿੱਧਰ ਉਹ ਇਸ ਨੂੰ ਲਾਉਂਦਾ ਹੈ ਉਧਰ ਹੀ ਇਹ ਲੱਗਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "куда Он её направит, туда она и идёт ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28330,
          "is_rahao": false,
          "gurmukhi": "ਚੇਰੀ ਤੈ ਸੁਮਤਿ ਕਹਾਂ ਤੇ ਪਾਈ ॥",
          "roman": "cherī tē sumat kahā te pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਮਿਹਰ ਨਾਲ ਜਾਗੀ ਹੋਈ ਜਿੰਦ ਨੂੰ ਜੱਗਿਆਸੂ ਜਿੰਦ ਪੁੱਛਦੀ ਹੈ) ਹੇ (ਭਾਗਾਂ ਵਾਲੀਏ) ਜਿੰਦੇ! ਤੈਨੂੰ ਕਿੱਥੋਂ ਇਹ ਸੁਮੱਤ ਮਿਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Откуда ты получила такую мудрость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28331,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਤੇ ਭ੍ਰਮ ਕੀ ਲੀਕ ਮਿਟਾਈ ॥",
          "roman": "jā te bhram kī līk miṭāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਤੇਰੇ ਉਹ ਸੰਸਕਾਰ ਮਿਟ ਗਏ ਹਨ, ਜੋ ਤੈਨੂੰ ਭਟਕਣਾ ਵਿਚ ਪਾਈ ਰੱਖਦੇ ਸਨ।"
            },
            "sahib_singh_ru": {
              "main": "которая стёрла следы заблуждения?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28332,
          "is_rahao": false,
          "gurmukhi": "ਸੁ ਰਸੁ ਕਬੀਰੈ ਜਾਨਿਆ ॥",
          "roman": "su ras Kabīrē jāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅੱਗੋਂ ਜਾਗੀ ਹੋਈ ਜਿੰਦ ਉੱਤਰ ਦੇਂਦੀ ਹੈ) ਹੇ ਕਬੀਰ! ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੇਰੀ ਉਸ ਆਤਮਕ ਆਨੰਦ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਹੋ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я познал этот духовный вкус,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28333,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੋ ਗੁਰ ਪ੍ਰਸਾਦਿ ਮਨੁ ਮਾਨਿਆ ॥੪॥੫॥",
          "roman": "mero gur prasād man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਮੇਰਾ ਮਨ ਉਸ ਵਿਚ ਪਰਚ ਗਿਆ ਹੈ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "и мой ум утвердился в нём по милости Гуру ॥4॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2508,
      "rahao_verse_id": 28339,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28334,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਬਾਝੁ ਨ ਜੀਆ ਜਾਈ ॥",
          "roman": "jih bājh na jīā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਆਤਮਕ ਜੀਵਨ) ਤੋਂ ਬਿਨਾ ਜੀਵਿਆ ਹੀ ਨਹੀਂ ਜਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Без этого духовного жизни нельзя жить,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28335,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਮਿਲੈ ਤ ਘਾਲ ਅਘਾਈ ॥",
          "roman": "jau milē ta ghāl aghāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜੇ ਉਹ ਜੀਵਨ ਮਿਲ ਜਾਏ ਤਾਂ ਘਾਲ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если оно достигается, труд становится успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28336,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਜੀਵਨੁ ਭਲੋ ਕਹਾਂਹੀ ॥",
          "roman": "sad jīvan bhalo kahāṅhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੀਵਨ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਤੇ ਜਿਸ ਨੂੰ ਲੋਕ ਸੁਹਣਾ ਜੀਵਨ ਆਖਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Это вечная жизнь, которую называют прекрасной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28337,
          "is_rahao": false,
          "gurmukhi": "ਮੂਏ ਬਿਨੁ ਜੀਵਨੁ ਨਾਹੀ ॥੧॥",
          "roman": "mūe bin jīvan nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜੀਵਨ ਆਪਾ-ਭਾਵ ਤਿਆਗਣ ਤੋਂ ਬਿਨਾ ਨਹੀਂ ਮਿਲ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но её нельзя получить без отказа от эго ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28338,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਕਿਆ ਕਥੀਐ ਗਿਆਨੁ ਬੀਚਾਰਾ ॥",
          "roman": "ab kiā kathīai giān bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਸ 'ਸਦ-ਜੀਵਨ' ਦੀ ਸਮਝ ਪੈ ਜਾਂਦੀ ਹੈ ਤਦੋਂ ਉਸ ਦੇ ਬਿਆਨ ਕਰਨ ਦੀ ਲੋੜ ਨਹੀਂ ਰਹਿੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Когда это осознано, нет нужды говорить об этом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28339,
          "is_rahao": true,
          "gurmukhi": "ਨਿਜ ਨਿਰਖਤ ਗਤ ਬਿਉਹਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nij nirakhat gat biuhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਂਞ ਉਸ ਦਾ ਸਿੱਟਾ ਇਹ ਨਿਕਲਦਾ ਹੈ ਕਿ) ਆਪਣੇ ਵੇਂਹਦਿਆਂ ਹੀ (ਜਗਤ ਦੀ ਸਦਾ) ਬਦਲਦੇ ਰਹਿਣ ਦੀ ਚਾਲ ਵੇਖ ਲਈਦੀ ਹੈ (ਭਾਵ, ਇਹ ਵੇਖ ਲਈਦਾ ਹੈ ਕਿ ਜਗਤ ਸਦਾ ਬਦਲ ਰਿਹਾ ਹੈ, ਪਰ ਆਪਾ ਮਿਟਾਇਆਂ ਮਿਲਿਆ ਜੀਵਨ ਅਟੱਲ ਰਹਿੰਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда видно, как мир постоянно меняется, а истинная жизнь остаётся неизменной ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28340,
          "is_rahao": false,
          "gurmukhi": "ਘਸਿ ਕੁੰਕਮ ਚੰਦਨੁ ਗਾਰਿਆ ॥",
          "roman": "ghas kuṅkam chandan gāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪੁੱਤਰ (ਜੀਵਾਤਮਾ) ਨੇ ਘਾਲ-ਕਮਾਈ ਕਰ ਕੇ ਆਪਣੀ ਜਿੰਦ ਨੂੰ ਪ੍ਰਭੂ ਵਿਚ ਮਿਲਾ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто очистил себя трудом и соединился с Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28341,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨੈਨਹੁ ਜਗਤੁ ਨਿਹਾਰਿਆ ॥",
          "roman": "bin nēnah jagat nihāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਆਪਣੀਆਂ ਅੱਖਾਂ ਨੂੰ ਜਗਤ-ਤਮਾਸ਼ੇ ਵਲੋਂ ਹਟਾ ਕੇ ਜਗਤ (ਦੀ ਅਸਲੀਅਤ) ਨੂੰ ਵੇਖ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "видит истинную природу мира, отвратив глаза от иллюзии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28342,
          "is_rahao": false,
          "gurmukhi": "ਪੂਤਿ ਪਿਤਾ ਇਕੁ ਜਾਇਆ ॥",
          "roman": "pūt pitā ik jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਆਪਣੇ ਅੰਦਰ ਆਪਣੇ ਪਿਤਾ-ਪ੍ਰਭੂ ਨੂੰ ਪਰਗਟ ਕਰ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он открыл внутри себя Отца-Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28343,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਠਾਹਰ ਨਗਰੁ ਬਸਾਇਆ ॥੨॥",
          "roman": "bin ṭhāhar nagar basāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਹਿਲਾਂ ਉਹ ਸਦਾ ਬਾਹਰ ਭਟਕਦਾ ਸੀ, ਹੁਣ (ਉਸ ਨੇ ਆਪਣੇ ਅੰਦਰ, ਮਾਨੋ,) ਸ਼ਹਿਰ ਵਸਾ ਲਿਆ ਹੈ (ਭਾਵ, ਉਸ ਦੇ ਅੰਦਰ ਉਹ ਸੁੰਦਰ ਗੁਣ ਪੈਦਾ ਹੋ ਗਏ ਹਨ ਕਿ ਹੁਣ ਉਹ ਬਾਹਰ ਨਹੀਂ ਭਟਕਦਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и внутри себя создал обитель, перестав блуждать ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28344,
          "is_rahao": false,
          "gurmukhi": "ਜਾਚਕ ਜਨ ਦਾਤਾ ਪਾਇਆ ॥",
          "roman": "jāchak jan dātā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਮੰਗਤਾ (ਬਣ ਕੇ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੋਂ ਮੰਗਦਾ) ਹੈ ਉਸ ਨੂੰ ਦਾਤਾ-ਪ੍ਰਭੂ ਆਪ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто просит Бога, тот находит Дарителя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28345,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਦੀਆ ਨ ਜਾਈ ਖਾਇਆ ॥",
          "roman": "so dīā na jāī khāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਇਤਨੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਦਾਤ ਬਖ਼ਸ਼ਦਾ ਹੈ ਜੋ ਖ਼ਰਚਿਆਂ ਖ਼ਤਮ ਨਹੀਂ ਹੁੰਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "и получает дар, который невозможно исчерпать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28346,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿਆ ਜਾਇ ਨ ਮੂਕਾ ॥",
          "roman": "chhoḍiā jāi na mūkā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾਤ ਨੂੰ ਨਾਹ ਛੱਡਣ ਨੂੰ ਜੀ ਕਰਦਾ ਹੈ, ਨਾਹ ਉਹ ਮੁੱਕਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот дар не хочется оставить, и он не иссякает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28347,
          "is_rahao": false,
          "gurmukhi": "ਅਉਰਨ ਪਹਿ ਜਾਨਾ ਚੂਕਾ ॥੩॥",
          "roman": "aurn pah jānā chūkā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਉਸ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਹੋਰਨਾਂ ਦੇ ਦਰ ਤੇ ਭਟਕਣਾ ਮੁੱਕ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и прекращается скитание по чужим дверям ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28348,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੀਵਨ ਮਰਨਾ ਜਾਨੈ ॥ ਸੋ ਪੰਚ ਸੈਲ ਸੁਖ ਮਾਨੈ ॥",
          "roman": "jo jīvan marnā jānē so panch sēl sukh mānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਇਸ ਆਤਮਕ ਅਟੱਲ ਜੀਵਨ ਦੀ ਖ਼ਾਤਰ ਆਪਾ-ਭਾਵ ਮਿਟਾਉਣ ਦੀ ਜਾਚ ਸਿੱਖ ਲੈਂਦਾ ਹੈ, ਉਹ ਸੰਤਾਂ ਵਾਲੇ ਅਟੱਲ ਆਤਮਕ ਸੁਖ ਨੂੰ ਮਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто умеет умирать для эго ради духовной жизни, тот наслаждается высшим духовным счастьем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28349,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰੈ ਸੋ ਧਨੁ ਪਾਇਆ ॥",
          "roman": "Kabīrē so dhan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਕਬੀਰ ਨੇ (ਭੀ) ਉਹ (ਆਤਮਕ ਜੀਵਨ-ਰੂਪ) ਧਨ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я обрёл это духовное богатство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28350,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਭੇਟਤ ਆਪੁ ਮਿਟਾਇਆ ॥੪॥੬॥",
          "roman": "har bheṭat āp miṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪ੍ਰਭੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਕੇ ਆਪਾ-ਭਾਵ ਮਿਟਾ ਲਿਆ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "соединившись с Богом и уничтожив эго ॥4॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2509,
      "rahao_verse_id": 28356,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28351,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਪੜੀਐ ਕਿਆ ਗੁਨੀਐ ॥",
          "roman": "kiā paṛīai kiā guṇīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਗਵਾਰ!) (ਵੇਦ ਪੁਰਾਣ ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕਾਂ ਨੂੰ) ਨਿਰੇ ਪੜ੍ਹਨ ਸੁਣਨ ਦਾ ਕੀ ਲਾਭ?"
            },
            "sahib_singh_ru": {
              "main": "Какой толк просто читать и изучать?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28352,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਬੇਦ ਪੁਰਾਨਾਂ ਸੁਨੀਐ ॥",
          "roman": "kiā bed purānāṅ sunīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਦ ਪੁਰਾਣ ਸੁਣਨ ਦਾ ਕੀ ਫ਼ਾਇਦਾ?"
            },
            "sahib_singh_ru": {
              "main": "Какой толк слушать Веды и Пураны?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28353,
          "is_rahao": false,
          "gurmukhi": "ਪੜੇ ਸੁਨੇ ਕਿਆ ਹੋਈ ॥",
          "roman": "paṛe sune kiā hoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਇਸ ਪੜ੍ਹਨ ਸੁਣਨ ਦੇ ਕੁਦਰਤੀ ਨਤੀਜੇ ਦੇ ਤੌਰ ਤੇ-"
            },
            "sahib_singh_ru": {
              "main": "Что толку в этом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28354,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਸਹਜ ਨ ਮਿਲਿਓ ਸੋਈ ॥੧॥",
          "roman": "jau sahaj na miliō soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਦਾ ਮਿਲਾਪ ਹੀ ਨਾਹ ਹੋਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если не достигается Бог ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28355,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਨ ਜਪਸਿ ਗਵਾਰਾ ॥",
          "roman": "har kā nām na japas gavārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ! ਤੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਤਾਂ) ਸਿਮਰਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "О глупец, ты не повторяешь Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28356,
          "is_rahao": true,
          "gurmukhi": "ਕਿਆ ਸੋਚਹਿ ਬਾਰੰ ਬਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kiā sochahi bāraṅ bārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਨੂੰ ਵਿਸਾਰ ਕੇ) ਮੁੜ ਮੁੜ ਹੋਰ ਸੋਚਾਂ ਸੋਚਣ ਦਾ ਤੈਨੂੰ ਕੀਹ ਲਾਭ ਹੋਵੇਗਾ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Что тебе даст постоянное размышление о другом? ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28357,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧਿਆਰੇ ਦੀਪਕੁ ਚਹੀਐ ॥",
          "roman": "andhiāre dīpak chahīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਨੇਰੇ ਵਿਚ (ਤਾਂ) ਦੀਵੇ ਦੀ ਲੋੜ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В темноте нужен светильник,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
