{
  "ang": 662,
  "shabads": [
    {
      "shabad_id": 2529,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28623,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਮਨੁ ਰਾਖਿਆ ਅਗਨੀ ਪਾਇ ॥",
          "roman": "jin man rākhiā agnī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਸਾਡੇ ਸਰੀਰ ਵਿਚ ਨਿੱਘ ਪਾ ਕੇ ਜਿੰਦ (ਸਰੀਰ ਵਿਚ) ਟਿਕਾ ਦਿੱਤੀ;"
            },
            "sahib_singh_ru": {
              "main": "Кто вложил тепло и поддержал жизнь в теле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28624,
          "is_rahao": false,
          "gurmukhi": "ਵਾਜੈ ਪਵਣੁ ਆਖੈ ਸਭ ਜਾਇ ॥੨॥",
          "roman": "vājē pavaṇ ākhē sabh jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੀ ਕਲਾ ਨਾਲ ਸਰੀਰ ਵਿਚ) ਸੁਆਸ ਚੱਲਦਾ ਹੈ ਤੇ ਮਨੁੱਖ ਹਰ ਥਾਂ (ਤੁਰ ਫਿਰ ਕੇ) ਬੋਲ ਚਾਲ ਕਰ ਸਕਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "по Его силе дыхание движется, и человек может говорить и действовать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28625,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤਾ ਮੋਹੁ ਪਰੀਤਿ ਸੁਆਦ ॥",
          "roman": "jetā moh parīt suād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਭੀ ਮਾਇਆ ਦਾ ਮੋਹ ਹੈ ਦੁਨੀਆ ਦੀ ਪ੍ਰੀਤ ਹੈ ਰਸਾਂ ਦੇ ਸੁਆਦ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Сколько бы ни было привязанностей, любви к миру и вкусов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28626,
          "is_rahao": false,
          "gurmukhi": "ਸਭਾ ਕਾਲਖ ਦਾਗਾ ਦਾਗ ॥",
          "roman": "sabhā kālakh dāgā dāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰੇ ਮਨ ਵਿਚ ਵਿਕਾਰਾਂ ਦੀ ਕਾਲਖ ਹੀ ਪੈਦਾ ਕਰਦੇ ਹਨ, ਵਿਕਾਰਾਂ ਦੇ ਦਾਗ਼ ਹੀ ਲਾਂਦੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "всё это лишь оставляет пятна пороков на уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28627,
          "is_rahao": false,
          "gurmukhi": "ਦਾਗ ਦੋਸ ਮੁਹਿ ਚਲਿਆ ਲਾਇ ॥",
          "roman": "dāg dos muh chaliā lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਤੋਂ ਸੁੰਞਾ ਰਹਿ ਕੇ ਵਿਕਾਰਾਂ ਵਿਚ ਫਸ ਕੇ) ਮਨੁੱਖ ਵਿਕਾਰਾਂ ਦੇ ਦਾਗ਼ ਆਪਣੇ ਮੱਥੇ ਤੇ ਲਾ ਕੇ (ਇਥੋਂ) ਚੱਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек уходит, запятнанный этими пороками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28628,
          "is_rahao": false,
          "gurmukhi": "ਦਰਗਹ ਬੈਸਣ ਨਾਹੀ ਜਾਇ ॥੩॥",
          "roman": "dargah bēsan nāhī jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਇਸ ਨੂੰ ਬੈਠਣ ਲਈ ਥਾਂ ਨਹੀਂ ਮਿਲਦੀ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И в присутствии Бога ему нет места."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28629,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮਿ ਮਿਲੈ ਆਖਣੁ ਤੇਰਾ ਨਾਉ ॥",
          "roman": "karam milē ākhaṇ terā nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਪ੍ਰਭੂ! ਜੀਵ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਤੇਰਾ ਨਾਮ ਸਿਮਰਨ (ਦਾ ਗੁਣ) ਤੇਰੀ ਮੇਹਰ ਨਾਲ ਹੀ ਮਿਲ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Поминание Твоего Имени даётся только по Твоей милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28630,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਲਗਿ ਤਰਣਾ ਹੋਰੁ ਨਹੀ ਥਾਉ ॥",
          "roman": "jit lag tarṇā hor nahī thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਨਾਮ ਵਿਚ ਹੀ ਲੱਗ ਕੇ (ਮੋਹ ਤੇ ਵਿਕਾਰਾਂ ਦੇ ਸਮੁੰਦਰ ਵਿਚੋਂ) ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ, (ਇਹਨਾਂ ਤੋਂ ਬਚਣ ਲਈ) ਹੋਰ ਕੋਈ ਥਾਂ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только через Твоё Имя можно переправиться, другого пути нет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28631,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੋ ਡੂਬੈ ਫਿਰਿ ਹੋਵੈ ਸਾਰ ॥",
          "roman": "je ko ḍūbē fir hovē sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਿਰਾਸਤਾ ਦੀ ਲੋੜ ਨਹੀਂ) ਜੇ ਕੋਈ ਮਨੁੱਖ (ਪ੍ਰਭੂ ਨੂੰ ਭੁਲਾ ਕੇ ਵਿਕਾਰਾਂ ਵਿਚ) ਡੁੱਬਦਾ ਭੀ ਹੈ (ਉਹ ਪ੍ਰਭੂ ਇਤਨਾ ਦਿਆਲ ਹੈ ਕਿ) ਫਿਰ ਭੀ ਉਸ ਦੀ ਸੰਭਾਲ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Даже если человек тонет в пороках, Ты всё равно заботишься о нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28632,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚਾ ਸਰਬ ਦਾਤਾਰ ॥੪॥੩॥੫॥",
          "roman": "nānak sāchā sarab dātār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਨੂੰ ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈ (ਕਿਸੇ ਨੂੰ ਵਿਰਵਾ ਨਹੀਂ ਰੱਖਦਾ) ॥੪॥੩॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Вечный Господь — дающий всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2530,
      "rahao_verse_id": 28639,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28633,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ॥",
          "roman": "dhanāsrī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28634,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰੁ ਸਲਾਹੇ ਚੀਤੁ ਨ ਭੀਜੈ ॥",
          "roman": "chor salāhe chīt na bhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਚੋਰ (ਉਸ ਹਾਕਮ ਦੀ ਜਿਸ ਦੇ ਸਾਹਮਣੇ ਉਸ ਦਾ ਮੁਕੱਦਮਾ ਪੇਸ਼ ਹੈ) ਖ਼ੁਸ਼ਾਮਦ ਕਰੇ ਤਾਂ ਉਸ ਨੂੰ (ਇਹ) ਯਕੀਨ ਨਹੀਂ ਬਣ ਸਕਦਾ (ਕਿ ਇਹ ਸੱਚਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Если вор начинает льстить правителю, перед которым представлен его суд, то это не может внушить уверенности, что он правдив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28635,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਬਦੀ ਕਰੇ ਤਾ ਤਸੂ ਨ ਛੀਜੈ ॥",
          "roman": "je badī kare tā tasū na chhījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਹ ਚੋਰ (ਹਾਕਮ ਦੀ) ਬਦ-ਖ਼ੋਈ ਕਰੇ ਤਾਂ ਭੀ ਉਹ ਰਤਾ ਭਰ ਨਹੀਂ ਘਾਬਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Если тот вор начинает порицать правителя, он всё равно ни на йоту не пугается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28636,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰ ਕੀ ਹਾਮਾ ਭਰੇ ਨ ਕੋਇ ॥",
          "roman": "chor kī hāmā bhare na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਭੀ ਮਨੁੱਖ ਕਿਸੇ ਚੋਰ ਦੇ ਚੰਗੇ ਹੋਣ ਦੀ ਗਵਾਹੀ ਨਹੀਂ ਦੇ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не может засвидетельствовать, что вор — хороший."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28637,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰੁ ਕੀਆ ਚੰਗਾ ਕਿਉ ਹੋਇ ॥੧॥",
          "roman": "chor kīā changā kio hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ (ਲੋਕਾਂ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ) ਚੋਰ ਮੰਨਿਆ ਗਿਆ, ਉਹ (ਖ਼ੁਸ਼ਾਮਦਾਂ ਜਾਂ ਬਦ-ਖ਼ੋਈਆਂ ਨਾਲ ਹੋਰਨਾਂ ਦੇ ਸਾਹਮਣੇ) ਚੰਗਾ ਨਹੀਂ ਬਣ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто признан вором в глазах людей, не может стать хорошим перед другими ни лестью, ни порицанием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28638,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਮਨ ਅੰਧੇ ਕੁਤੇ ਕੂੜਿਆਰ ॥",
          "roman": "sun man andhe kutē kūṛiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਅੰਨ੍ਹੇ ਲਾਲਚੀ ਤੇ ਝੂਠੇ ਮਨ! (ਧਿਆਨ ਨਾਲ) ਸੁਣ।"
            },
            "sahib_singh_ru": {
              "main": "Слушай, о слепой, жадный и лживый ум!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28639,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਬੋਲੇ ਬੂਝੀਐ ਸਚਿਆਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bin bole būjhīai sachiyār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੱਚਾ ਮਨੁੱਖ ਬਿਨਾ ਬੋਲਿਆਂ ਹੀ ਪਛਾਣਿਆ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Истинный человек распознаётся без слов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28640,
          "is_rahao": false,
          "gurmukhi": "ਚੋਰੁ ਸੁਆਲਿਉ ਚੋਰੁ ਸਿਆਣਾ ॥",
          "roman": "chor suāliyu chor siyāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੋਰ ਪਿਆ ਸੋਹਣਾ ਬਣੇ ਚਤੁਰ ਬਣੇ,"
            },
            "sahib_singh_ru": {
              "main": "Вор может казаться красивым и умным,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28641,
          "is_rahao": false,
          "gurmukhi": "ਖੋਟੇ ਕਾ ਮੁਲੁ ਏਕੁ ਦੁਗਾਣਾ ॥",
          "roman": "khoṭe kā mul ek dugāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਆਖ਼ਰ ਉਹ ਚੋਰ ਹੀ ਹੈ ਉਸ ਦੀ ਕਦਰ ਕੀਮਤ ਨਹੀਂ ਪੈਂਦੀ, ਜਿਵੇਂ) ਖੋਟੇ ਰੁਪਏ ਦਾ ਮੁੱਲ ਦੋ ਗੰਢੇ ਕੌਡਾਂ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но в конце он остаётся вором, и у него нет ценности, как у фальшивой монеты, стоящей лишь пару кауд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28642,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਾਥਿ ਰਖੀਐ ਦੀਜੈ ਰਲਾਇ ॥",
          "roman": "je sāth rakhīē dījē ralāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਖੋਟੇ ਰੁਪਏ ਨੂੰ (ਖਰਿਆਂ ਵਿਚ) ਰੱਖ ਦੇਈਏ, (ਖਰਿਆਂ ਵਿਚ) ਰਲਾ ਦੇਈਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если фальшивую монету положить среди настоящих,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28643,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਪਰਖੀਐ ਖੋਟਾ ਹੋਇ ਜਾਇ ॥੨॥",
          "roman": "jā parakhīai khoṭā hoi jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਜਦੋਂ ਉਸ ਦੀ ਪਰਖ ਹੁੰਦੀ ਹੈ ਤਦੋਂ ਉਹ ਖੋਟਾ ਹੀ ਕਿਹਾ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "то при проверке она всё равно окажется фальшивой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28644,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਕਰੇ ਸੁ ਤੈਸਾ ਪਾਵੈ ॥",
          "roman": "jēsā kare so tēsā pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਜੈਸਾ ਕੰਮ ਕਰਦਾ ਹੈ ਵੈਸਾ ਹੀ ਉਸ ਦਾ ਫਲ ਪਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Человек получает результат своих поступков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28645,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਬੀਜਿ ਆਪੇ ਹੀ ਖਾਵੈ ॥",
          "roman": "āp bīj āpe hī khāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਕੋਈ ਆਪ (ਕਰਮਾਂ ਦੇ ਬੀਜ) ਬੀਜ ਕੇ ਆਪ ਹੀ ਫਲ ਖਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Каждый сам сеет и сам пожинает плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28646,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਵਡਿਆਈਆ ਆਪੇ ਖਾਇ ॥",
          "roman": "je vaḍiāīā āpe khāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ (ਹੋਵੇ ਤਾਂ ਖੋਟਾ, ਪਰ) ਆਪਣੀਆਂ ਵਡਿਆਈਆਂ ਦੀਆਂ ਕਸਮਾਂ ਚੁੱਕੀ ਜਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "Если человек сам восхваляет себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28647,
          "is_rahao": false,
          "gurmukhi": "ਜੇਹੀ ਸੁਰਤਿ ਤੇਹੈ ਰਾਹਿ ਜਾਇ ॥੩॥",
          "roman": "jehī surat tehē rāh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦਾ ਇਤਬਾਰ ਨਹੀਂ ਬਣ ਸਕਦਾ, ਕਿਉਂਕਿ) ਮਨੁੱਖ ਦੀ ਜਿਹੋ ਜਿਹੀ ਮਨੋ-ਵਾਸਨਾ ਹੈ ਉਹੋ ਜਿਹੇ ਰਸਤੇ ਉਤੇ ਹੀ ਉਹ ਤੁਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то он идёт по пути, соответствующему его внутренним склонностям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28648,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਉ ਕੂੜੀਆ ਕੂੜੁ ਕਬਾੜੁ ॥",
          "roman": "je sau kūṛīā kūṛ kabāṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣਾ ਇਤਬਾਰ ਜਮਾਣ ਲਈ ਚਲਾਕ ਬਣ ਕੇ) ਝੂਠੀਆਂ ਗੱਪਾਂ ਅਤੇ ਝੂਠ ਕਬਾੜ ਦੀਆਂ ਗੱਲਾਂ-"
            },
            "sahib_singh_ru": {
              "main": "Даже если он рассказывает сотни лживых и пустых историй,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28649,
          "is_rahao": false,
          "gurmukhi": "ਭਾਵੈ ਸਭੁ ਆਖਉ ਸੰਸਾਰੁ ॥",
          "roman": "bhāvē sabh ākhao sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਾਵੇਂ ਸਾਰੇ ਸੰਸਾਰ ਨੂੰ ਆਖੀਆਂ ਜਾਣ (ਪਰ, ਹੇ ਪ੍ਰਭੂ! ਕੋਈ ਮਨੁੱਖ ਤੈਨੂੰ ਧੋਖਾ ਨਹੀਂ ਦੇ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "даже если он говорит их всему миру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28650,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਭਾਵੈ ਅਧੀ ਪਰਵਾਣੁ ॥",
          "roman": "tudh bhāvē adhī parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜੇ ਦਿਲ ਦਾ ਖਰਾ ਹੋਵੇ ਤਾਂ) ਇਕ ਸਿੱਧੜ ਮਨੁੱਖ ਭੀ ਤੈਨੂੰ ਪਸੰਦ ਆ ਜਾਂਦਾ ਹੈ, ਤੇਰੇ ਦਰ ਤੇ ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но, о Господь, если человек искренен сердцем, даже один простой человек становится Тебе угоден и принимается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28651,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾਣੈ ਜਾਣੁ ਸੁਜਾਣੁ ॥੪॥੪॥੬॥",
          "roman": "nānak jāṇē jāṇ sujāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਘਟ ਘਟ ਦੀ ਜਾਣਨ ਵਾਲਾ ਸੁਜਾਨ ਪ੍ਰਭੂ (ਸਭ ਕੁਝ) ਜਾਣਦਾ ਹੈ ॥੪॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: всеведущий Господь знает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2531,
      "rahao_verse_id": 28658,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28652,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ॥",
          "roman": "dhanāsrī mehlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28653,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਕਾਗਦੁ ਮਨੁ ਪਰਵਾਣਾ ॥",
          "roman": "kāiā kāgad man parvāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਮਨੁੱਖਾ ਸਰੀਰ (ਮਾਨੋ) ਇਕ ਕਾਗ਼ਜ਼ ਹੈ, ਅਤੇ ਮਨੁੱਖ ਦਾ ਮਨ (ਸਰੀਰ-ਕਾਗ਼ਜ਼ ਉਤੇ ਲਿਖਿਆ ਹੋਇਆ) ਦਰਗਾਹੀ ਪਰਵਾਨਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это человеческое тело подобно бумаге, а ум — записанному на ней документу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28654,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰ ਕੇ ਲੇਖ ਨ ਪੜੈ ਇਆਣਾ ॥",
          "roman": "sir ke lekh na paṛē iāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੂਰਖ ਮਨੁੱਖ ਆਪਣੇ ਮੱਥੇ ਦੇ ਇਹ ਲੇਖ ਨਹੀਂ ਪੜ੍ਹਦਾ (ਭਾਵ, ਇਹ ਸਮਝਣ ਦਾ ਜਤਨ ਨਹੀਂ ਕਰਦਾ ਕਿ ਉਸ ਦੇ ਪਿਛਲੇ ਕੀਤੇ ਕਰਮਾਂ ਅਨੁਸਾਰ ਕਿਹੋ ਜਿਹੇ ਸੰਸਕਾਰ-ਲੇਖ ਉਸ ਦੇ ਮਨ ਵਿਚ ਮੌਜੂਦ ਹਨ ਜੋ ਉਸ ਨੂੰ ਹੁਣ ਹੋਰ ਪ੍ਰੇਰਨਾ ਕਰ ਰਹੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Но неразумный человек не читает написанного на своём лбу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28655,
          "is_rahao": false,
          "gurmukhi": "ਦਰਗਹ ਘੜੀਅਹਿ ਤੀਨੇ ਲੇਖ ॥",
          "roman": "dargah ghaṛīah tīne lekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਤਿੰਨ ਗੁਣਾਂ ਦੇ ਅਸਰ ਹੇਠ ਰਹਿ ਕੇ ਕੀਤੇ ਹੋਏ ਕੰਮਾਂ ਦੇ ਸੰਸਕਾਰ ਰੱਬੀ ਨਿਯਮ ਅਨੁਸਾਰ ਹਰੇਕ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਉੱਕਰੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Под воздействием трёх гун майи впечатления от поступков записываются в уме каждого по Божественному закону."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28656,
          "is_rahao": false,
          "gurmukhi": "ਖੋਟਾ ਕਾਮਿ ਨ ਆਵੈ ਵੇਖੁ ॥੧॥",
          "roman": "khoṭā kām na āvē vekh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹੇ ਭਾਈ! ਵੇਖ (ਜਿਵੇਂ ਕੋਈ ਖੋਟਾ ਸਿੱਕਾ ਕੰਮ ਨਹੀਂ ਆਉਂਦਾ, ਤਿਵੇਂ ਖੋਟੇ ਕੀਤੇ ਕੰਮਾਂ ਦਾ) ਖੋਟਾ ਸੰਸਕਾਰ-ਲੇਖ ਭੀ ਕੰਮ ਨਹੀਂ ਆਉਂਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но фальшивые записи, как и фальшивая монета, не приносят пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28657,
          "is_rahao": true,
          "gurmukhi": "ਨਾਨਕ ਜੇ ਵਿਚਿ ਰੁਪਾ ਹੋਇ ॥",
          "roman": "nānak je vich rupā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੇ ਰੁਪਏ ਆਦਿਕ ਸਿੱਕੇ ਵਿਚ ਚਾਂਦੀ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: если в монете есть серебро,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28658,
          "is_rahao": true,
          "gurmukhi": "ਖਰਾ ਖਰਾ ਆਖੈ ਸਭੁ ਕੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kharā kharā ākhē sabh koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਹਰ ਕੋਈ ਉਸ ਨੂੰ ਖਰਾ ਸਿੱਕਾ ਆਖਦਾ ਹੈ (ਇਸੇ ਤਰ੍ਹਾਂ ਜਿਸ ਮਨ ਵਿਚ ਪਵਿਤ੍ਰਤਾ ਹੋਵੇ, ਉਸ ਨੂੰ ਖਰਾ ਆਖਿਆ ਜਾਂਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "то все называют её подлинной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28659,
          "is_rahao": false,
          "gurmukhi": "ਕਾਦੀ ਕੂੜੁ ਬੋਲਿ ਮਲੁ ਖਾਇ ॥",
          "roman": "kādī kūṛ bol mal khāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਜ਼ੀ (ਜੇ ਇਕ ਪਾਸੇ ਤਾਂ ਇਸਲਾਮੀ ਧਰਮ ਦਾ ਨੇਤਾ ਹੈ ਤੇ ਦੂਜੇ ਪਾਸੇ ਹਾਕਮ ਭੀ ਹੈ, ਰਿਸ਼ਵਤ ਦੀ ਖ਼ਾਤਰ ਸ਼ਰਈ ਕਾਨੂੰਨ ਬਾਰੇ) ਝੂਠ ਬੋਲ ਕੇ ਹਰਾਮ ਦਾ ਮਾਲ (ਰਿਸ਼ਵਤ) ਖਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кази, лживо толкуя закон ради взятки, ест нечестный доход."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28660,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਾਹਮਣੁ ਨਾਵੈ ਜੀਆ ਘਾਇ ॥",
          "roman": "brāhmaṇ nāvē jīā ghāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਾਹਮਣਾਂ (ਕ੍ਰੋੜਾਂ ਸ਼ੂਦਰ-ਅਖਵਾਂਦੇ) ਬੰਦਿਆਂ ਨੂੰ ਦੁਖੀ ਕਰ ਕਰ ਕੇ ਤੀਰਥ-ਇਸ਼ਨਾਨ (ਭੀ) ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Брахман причиняет страдания людям и при этом совершает омовения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28661,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਜੁਗਤਿ ਨ ਜਾਣੈ ਅੰਧੁ ॥",
          "roman": "jogī jugat na jāṇē andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗੀ ਭੀ ਅੰਨ੍ਹਾ ਹੈ ਤੇ ਜੀਵਨ ਦੀ ਜਾਚ ਨਹੀਂ ਜਾਣਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Йог слеп и не знает истинного пути жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28662,
          "is_rahao": false,
          "gurmukhi": "ਤੀਨੇ ਓਜਾੜੇ ਕਾ ਬੰਧੁ ॥੨॥",
          "roman": "tīne ojāṛe kā bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਤਿੰਨੇ ਆਪਣੇ ਵਲੋਂ ਧਰਮ-ਨੇਤਾ ਹਨ, ਪਰ) ਇਹਨਾਂ ਤਿੰਨਾਂ ਦੇ ਹੀ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਸੁੰਞ ਹੀ ਸੁੰਞ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Все трое духовно опустошены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28663,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜੋਗੀ ਜੋ ਜੁਗਤਿ ਪਛਾਣੈ ॥",
          "roman": "so jogī jo jugat pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਜੋਗੀ ਉਹ ਹੈ ਜੋ ਜੀਵਨ ਦੀ ਸਹੀ ਜਾਚ ਸਮਝਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Истинный йог — тот, кто понимает правильный путь жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28664,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਏਕੋ ਜਾਣੈ ॥",
          "roman": "gur parsādī eko jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਇਕ ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и по милости Гуру соединяется с Единым Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28665,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਸੋ ਜੋ ਉਲਟੀ ਕਰੈ ॥",
          "roman": "kājī so jo ulṭī karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਜ਼ੀ ਉਹ ਹੈ ਜੋ ਸੁਰਤਿ ਨੂੰ ਹਰਾਮ ਦੇ ਮਾਲ ਵਲੋਂ ਮੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Истинный кази — тот, кто отворачивает ум от нечестного богатства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28666,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਜੀਵਤੁ ਮਰੈ ॥",
          "roman": "gur parsādī jīvat marē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਦੁਨੀਆ ਵਿਚ ਰਹਿੰਦਾ ਹੋਇਆ ਦੁਨਿਆਵੀ ਖ਼ਾਹਸ਼ਾਂ ਵਲੋਂ ਪਰਤਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и по милости Гуру умирает при жизни, отрекаясь от мирских желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28667,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬ੍ਰਾਹਮਣੁ ਜੋ ਬ੍ਰਹਮੁ ਬੀਚਾਰੈ ॥",
          "roman": "so brāhmaṇ jo brahm bīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬ੍ਰਾਹਮਣ ਉਹ ਹੈ ਜੋ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਵਿਚ ਸੁਰਤਿ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Истинный брахман — тот, кто размышляет о Всепроникающем Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28668,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਤਰੈ ਸਗਲੇ ਕੁਲ ਤਾਰੈ ॥੩॥",
          "roman": "āp tarē sagle kul tārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਤਰ੍ਹਾਂ ਆਪ ਭੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ ਪਾਰ ਲੰਘਦਾ ਹੈ ਤੇ ਆਪਣੀਆਂ ਸਾਰੀਆਂ ਕੁਲਾਂ ਨੂੰ ਭੀ ਲੰਘਾ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "он сам переплывает океан мира и помогает переправиться своему роду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28669,
          "is_rahao": false,
          "gurmukhi": "ਦਾਨਸਬੰਦੁ ਸੋਈ ਦਿਲਿ ਧੋਵੈ ॥",
          "roman": "dānsband soī dil dhovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਅਕਲਮੰਦ ਹੈ ਜੋ ਆਪਣੇ ਦਿਲ ਵਿਚ ਟਿਕੀ ਹੋਈ ਬੁਰਾਈ ਨੂੰ ਦੂਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот по-настоящему разумен, кто очищает своё сердце от зла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28670,
          "is_rahao": false,
          "gurmukhi": "ਮੁਸਲਮਾਣੁ ਸੋਈ ਮਲੁ ਖੋਵੈ ॥",
          "roman": "musalmān soī mal khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮੁਸਲਮਾਨ ਹੈ ਜੋ ਮਨ ਵਿਚੋਂ ਵਿਕਾਰਾਂ ਦੀ ਮੈਲ ਦੀ ਨਾਸ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот истинный мусульманин, кто уничтожает внутреннюю нечистоту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28671,
          "is_rahao": false,
          "gurmukhi": "ਪੜਿਆ ਬੂਝੈ ਸੋ ਪਰਵਾਣੁ ॥",
          "roman": "paṛiā būjhē so parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਵਿਦਵਾਨ ਹੈ ਜੋ ਜੀਵਨ ਦਾ ਸਹੀ ਰਸਤਾ ਸਮਝਦਾ ਹੈ, ਉਹੀ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਕਬੂਲ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот образован, кто понимает правильный путь и принимается у Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28672,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਰਿ ਦਰਗਹ ਕਾ ਨੀਸਾਣੁ ॥੪॥੫॥੭॥",
          "roman": "jis sir dargah kā nīsāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮੱਥੇ ਉਤੇ ਦਰਗਾਹ ਦਾ ਟਿੱਕਾ ਲੱਗਦਾ ਹੈ ॥੪॥੫॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "На чьём челе стоит знак Божественного суда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2532,
      "rahao_verse_id": 28678,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28673,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੧ ਘਰੁ ੩",
          "roman": "dhanāsrī mehlā 1 ghar 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਧਨਾਸਰੀ, ਘਰ ੩ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Дханасри, дом 3, слово Гуру Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28674,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог, постигаемый по милости Истинного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28675,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੁ ਨਾਹੀ ਜੋਗੁ ਨਾਹੀ ਨਾਹੀ ਸਤ ਕਾ ਢਬੁ ॥",
          "roman": "kāl nāhī jog nāhī nāhī sat kā ḍhab",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ (ਮਨੁੱਖਾ ਜਨਮ ਦਾ) ਸਮਾ (ਅੱਖਾਂ ਮੀਟਣ ਤੇ ਨੱਕ ਫੜਨ ਵਾਸਤੇ) ਨਹੀਂ ਹੈ, (ਇਹਨਾਂ ਢਬਾਂ ਨਾਲ) ਪਰਮਾਤਮਾ ਦਾ ਮੇਲ ਨਹੀਂ ਹੁੰਦਾ, ਨਾਹ ਹੀ ਉੱਚੇ ਆਚਰਨ ਦਾ ਤਰੀਕਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это время не для внешних практик; через них не достигается Бог и не достигается истинное поведение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28676,
          "is_rahao": false,
          "gurmukhi": "ਥਾਨਸਟ ਜਗ ਭਰਿਸਟ ਹੋਏ ਡੂਬਤਾ ਇਵ ਜਗੁ ॥੧॥",
          "roman": "thānasṭ jag bharisṭ hoe ḍūbtā iv jag",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹਨਾਂ ਤਰੀਕਿਆਂ ਦੀ ਰਾਹੀਂ) ਜਗਤ ਦੇ (ਅਨੇਕਾਂ) ਪਵਿਤ੍ਰ ਹਿਰਦੇ (ਭੀ) ਗੰਦੇ ਹੋ ਜਾਂਦੇ ਹਨ, ਇਸ ਤਰ੍ਹਾਂ ਜਗਤ (ਵਿਕਾਰਾਂ ਵਿਚ) ਡੁੱਬਣ ਲੱਗ ਪੈਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Даже чистые сердца загрязняются, и мир начинает тонуть в пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28677,
          "is_rahao": true,
          "gurmukhi": "ਕਲ ਮਹਿ ਰਾਮ ਨਾਮੁ ਸਾਰੁ ॥",
          "roman": "kal meh rām nām sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਗਤ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਸਿਮਰਨਾ ਹੋਰ ਸਾਰੇ ਕੰਮਾਂ ਨਾਲੋਂ) ਸ੍ਰੇਸ਼ਟ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В этом мире имя Бога — самое высшее."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28678,
          "is_rahao": true,
          "gurmukhi": "ਅਖੀ ਤ ਮੀਟਹਿ ਨਾਕ ਪਕੜਹਿ ਠਗਣ ਕਉ ਸੰਸਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "akhī ta mīṭeh nāk pakṛeh ṭhagaṇ kau sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜੇ ਇਹ ਲੋਕ) ਅੱਖਾਂ ਤਾਂ ਮੀਟਦੇ ਹਨ, ਨੱਕ ਭੀ ਫੜਦੇ ਹਨ (ਇਹ) ਜਗਤ ਨੂੰ ਠੱਗਣ ਵਾਸਤੇ (ਕਰਦੇ ਹਨ, ਇਹ ਭਗਤੀ ਨਹੀਂ, ਇਹ ਸ੍ਰੇਸ਼ਟ ਧਾਰਮਿਕ ਕੰਮ ਨਹੀਂ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Они закрывают глаза и зажимают нос лишь для того, чтобы обманывать мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28679,
          "is_rahao": false,
          "gurmukhi": "ਆਂਟ ਸੇਤੀ ਨਾਕੁ ਪਕੜਹਿ ਸੂਝਤੇ ਤਿਨਿ ਲੋਅ ॥",
          "roman": "āṇṭ setī nāk pakṛeh sūjhte tin loe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੱਥ ਦੇ ਅੰਗੂਠੇ ਤੇ ਨਾਲ ਦੀਆਂ ਦੋ ਉਂਗਲਾਂ ਨਾਲ ਇਹ (ਆਪਣਾ) ਨੱਕ ਫੜਦੇ ਹਨ (ਸਮਾਧੀ ਦੀ ਸ਼ਕਲ ਵਿਚ ਬੈਠ ਕੇ ਮੂੰਹੋਂ ਆਖਦੇ ਹਨ ਕਿ) ਤਿੰਨੇ ਹੀ ਲੋਕ ਦਿੱਸ ਰਹੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Они зажимают нос пальцами и говорят, что видят все три мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
