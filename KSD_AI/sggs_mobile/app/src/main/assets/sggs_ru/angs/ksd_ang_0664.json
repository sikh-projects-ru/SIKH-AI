{
  "ang": 664,
  "shabads": [
    {
      "shabad_id": 2534,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28718,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਮਿਲੈ ਮਨੁ ਮਾਨਿਆ ॥੪॥੧॥",
          "roman": "nānak nām milē man māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਸਦਾ ਲਈ) ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਸ ਦਾ ਮਨ (ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਵਿਚ) ਪਤੀਜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такой человек обретает Имя Бога, и его ум пребывает в удовлетворении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2535,
      "rahao_verse_id": 28725,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28719,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ॥",
          "roman": "dhanāsrī mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28720,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਧਨੁ ਨਿਰਮਲੁ ਅਤਿ ਅਪਾਰਾ ॥",
          "roman": "har nām dhan nirmal at apārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪਵਿੱਤਰ ਧਨ ਹੈ, ਕਦੇ ਨਾਹ ਮੁੱਕਣ ਵਾਲਾ ਧਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Имя Бога — это чистое богатство, богатство, которое никогда не иссякает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28721,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਭਰੇ ਭੰਡਾਰਾ ॥",
          "roman": "gur kē sabad bhare bhandārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ (ਜੁੜਿਆਂ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਇਸ ਧਨ ਦੇ) ਖ਼ਜ਼ਾਨੇ ਭਰ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Через слово Гуру внутренние сокровищницы этого богатства наполняются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28722,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਧਨ ਬਿਨੁ ਹੋਰ ਸਭ ਬਿਖੁ ਜਾਣੁ ॥",
          "roman": "nām dhan bin hor sabh bikh jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਹਰਿ-ਨਾਮ-ਧਨ ਤੋਂ ਬਿਨਾ ਹੋਰ (ਦੁਨੀਆ ਵਾਲਾ ਧਨ) ਸਾਰਾ ਜ਼ਹਰ ਸਮਝ (ਜੋ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਮਾਰ ਮੁਕਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Без богатства Имени всё остальное (мирское богатство) считай ядом, который губит духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28723,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮੋਹਿ ਜਲੈ ਅਭਿਮਾਨੁ ॥੧॥",
          "roman": "māiā moh jalē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਵਾਲਾ ਧਨ) ਅਹੰਕਾਰ ਪੈਦਾ ਕਰਦਾ ਹੈ (ਦੁਨੀਆ ਵਾਲੇ ਧਨ ਨੂੰ ਇਕੱਠਾ ਕਰਨ ਵਾਲਾ ਮਨੁੱਖ) ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਸੜਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Мирское богатство порождает гордыню, и человек, собирающий его, сгорает в привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28724,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹਰਿ ਰਸੁ ਚਾਖੈ ਕੋਇ ॥",
          "roman": "gurmukh har ras chākhē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਚੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто, обратившись к Гуру, вкушает нектар Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28725,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸੁ ਸਦਾ ਅਨੰਦੁ ਹੋਵੈ ਦਿਨੁ ਰਾਤੀ ਪੂਰੈ ਭਾਗਿ ਪਰਾਪਤਿ ਹੋਇ ॥ ਰਹਾਉ ॥",
          "roman": "tis sadā anand hovē din rātī pūrē bhāg parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਦਿਨ ਰਾਤ ਹਰ ਵੇਲੇ ਆਤਮਕ ਆਨੰਦ ਮਿਲਿਆ ਰਹਿੰਦਾ ਹੈ। (ਪਰ ਇਹ ਹਰਿ-ਨਾਮ-ਰਸ) ਪੂਰੀ ਕਿਸਮਤਿ ਨਾਲ ਹੀ ਮਿਲਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "у него всегда, днём и ночью, пребывает духовная радость. Но этот нектар Имени даётся только по великой судьбе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28726,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਦੀਪਕੁ ਵਰਤੈ ਤਿਹੁ ਲੋਇ ॥",
          "roman": "sabad dīpak vartē tih loe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ (ਮਾਨੋ) ਦੀਵਾ (ਹੈ, ਜੋ) ਸਾਰੇ ਸੰਸਾਰ ਵਿਚ ਚਾਨਣ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Слово Гуру — как светильник, освещающий весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28727,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਚਾਖੈ ਸੋ ਨਿਰਮਲੁ ਹੋਇ ॥",
          "roman": "jo chākhē so nirmal hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਚੱਖਦਾ ਹੈ, ਉਹ ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто вкушает слово Гуру, становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28728,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਨਾਮਿ ਹਉਮੈ ਮਲੁ ਧੋਇ ॥",
          "roman": "nirmal nām haumē mal dhoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ) ਪਵਿਤ੍ਰ ਹਰਿ-ਨਾਮ ਵਿਚ (ਜੁੜ ਕੇ ਮਨੁੱਖ ਆਪਣੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਦੀ ਮੈਲ ਧੋ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Соединившись с чистым Именем, человек смывает грязь эгоизма изнутри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28729,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਭਗਤਿ ਸਦਾ ਸੁਖੁ ਹੋਇ ॥੨॥",
          "roman": "sāchī bhagat sadā sukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря истинной преданности Вечному Господу внутри всегда сохраняется духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28730,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਹਰਿ ਰਸੁ ਚਾਖਿਆ ਸੋ ਹਰਿ ਜਨੁ ਲੋਗੁ ॥",
          "roman": "jin har ras chākhiā so har jan log",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਰਸ ਚੱਖ ਲਿਆ, ਉਹ ਪਰਮਾਤਮਾ ਦਾ ਦਾਸ ਬਣ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто вкусил нектар Имени, становится слугой Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28731,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸਦਾ ਹਰਖੁ ਨਾਹੀ ਕਦੇ ਸੋਗੁ ॥",
          "roman": "tis sadā harakh nāhī kade sog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਸਦਾ ਆਨੰਦ ਪ੍ਰਾਪਤ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਕੋਈ ਗ਼ਮ ਨਹੀਂ ਵਿਆਪਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Он всегда пребывает в радости, и его не поражает печаль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28732,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਮੁਕਤੁ ਅਵਰਾ ਮੁਕਤੁ ਕਰਾਵੈ ॥",
          "roman": "āp mukt avarā mukt karāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪ (ਦੁੱਖਾਂ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ, ਹੋਰਨਾਂ ਨੂੰ ਭੀ ਬਚਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он сам освобождён и других освобождает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28733,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਜਪੈ ਹਰਿ ਤੇ ਸੁਖੁ ਪਾਵੈ ॥੩॥",
          "roman": "har nām japē har te sukh pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਵਡ-ਭਾਗੀ) ਮਨੁੱਖ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਰਹਿੰਦਾ ਹੈ, ਤੇ, ਪਰਮਾਤਮਾ ਪਾਸੋਂ ਸੁਖ ਹਾਸਲ ਕਰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно повторяет Имя Бога и получает счастье от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28734,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਤਿਗੁਰ ਸਭ ਮੁਈ ਬਿਲਲਾਇ ॥",
          "roman": "bin satgur sabh muī billāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸਰਨ ਪੈਣ ਤੋਂ ਬਿਨਾ ਸਾਰੀ ਲੋਕਾਈ ਦੁੱਖੀ ਹੋ ਹੋ ਕੇ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਲੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Без прибежища у Гуру весь мир страдает и духовно погибает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28735,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਦਾਝਹਿ ਸਾਤਿ ਨ ਪਾਇ ॥",
          "roman": "andin dājheh sāt na pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਤੋਂ ਵਿਛੁੜ ਕੇ ਮਨੁੱਖ) ਹਰ ਵੇਲੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ) ਸੜਦੇ ਰਹਿੰਦੇ ਹਨ। (ਗੁਰੂ ਦੀ ਸਰਨ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ) ਸ਼ਾਂਤੀ ਹਾਸਲ ਨਹੀਂ ਕਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Они постоянно сгорают в привязанности к майе и не находят покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28736,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮਿਲੈ ਸਭੁ ਤ੍ਰਿਸਨ ਬੁਝਾਏ ॥",
          "roman": "satgur milē sabh trisan bujhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਗੁਰੂ ਉਸ ਦੀ ਸਾਰੀ (ਮਾਇਆ ਦੀ) ਤ੍ਰੇਹ ਮਿਟਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кому встречается Гуру, тот гасит всю жажду майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28737,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਸਾਂਤਿ ਸੁਖੁ ਪਾਏ ॥੪॥੨॥",
          "roman": "nānak nām sānt sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਹਰਿ-ਨਾਮ ਵਿਚ ਟਿਕ ਕੇ ਸ਼ਾਂਤੀ ਤੇ ਆਨੰਦ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Утвердившись в Имени, человек обретает покой и радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2536,
      "rahao_verse_id": 28744,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28738,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ॥",
          "roman": "dhanāsrī mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28739,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਧਨੁ ਅੰਤਰਿ ਨਾਮੁ ਸਮਾਲੇ ॥",
          "roman": "sadā dhan antar nām samāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਮ ਧਨ ਨੂੰ ਆਪਣੇ ਅੰਦਰ ਸਾਂਭ ਕੇ ਰੱਖ। ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਐਸਾ) ਧਨ (ਹੈ ਜੋ) ਸਦਾ ਸਾਥ ਨਿਬਾਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Храни в себе богатство Имени — это богатство всегда остаётся с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28740,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਜਿਨਹਿ ਪ੍ਰਤਿਪਾਲੇ ॥",
          "roman": "jīa jant jineh pratipāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਸਾਰੇ ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ (ਕਰਨ ਦੀ ਜ਼ਿੰਮੇਵਾਰੀ) ਲਈ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который заботится обо всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28741,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਪਦਾਰਥੁ ਤਿਨ ਕਉ ਪਾਏ ॥",
          "roman": "mukt padārath tin kau pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਵਿਕਾਰਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਕਰਾਣ ਵਾਲਾ ਨਾਮ-ਧਨ ਉਹਨਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Освобождающее богатство Имени получают те,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28742,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੈ ਨਾਮਿ ਰਤੇ ਲਿਵ ਲਾਏ ॥੧॥",
          "roman": "har kē nām rate liv lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਸੁਰਤਿ ਜੋੜ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ (-ਰੰਗ) ਵਿਚ ਰੰਗੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "кто с сосредоточением окрашены в Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28743,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਹਰਿ ਨਾਮੁ ਧਨੁ ਪਾਵੈ ॥",
          "roman": "gur sevā te har nām dhan pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ (ਦੱਸੀ) ਸੇਵਾ ਕਰਨ ਨਾਲ (ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਧਨ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через служение Гуру человек получает богатство Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28744,
          "is_rahao": true,
          "gurmukhi": "ਅੰਤਰਿ ਪਰਗਾਸੁ ਹਰਿ ਨਾਮੁ ਧਿਆਵੈ ॥ ਰਹਾਉ ॥",
          "roman": "antar pargās har nām dhiāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ, ਉਸ ਦੇ ਅੰਦਰ (ਆਤਮਕ ਜੀਵਨ ਦੀ) ਸੂਝ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто медитирует на Имя, обретает внутреннее просветление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28745,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਹਰਿ ਰੰਗੁ ਗੂੜਾ ਧਨ ਪਿਰ ਹੋਇ ॥",
          "roman": "ih har rang gūṛhā dhan pir hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪ੍ਰਭੂ-ਪਤੀ (ਦੇ ਪ੍ਰੇਮ) ਦਾ ਇਹ ਗੂੜ੍ਹਾ ਰੰਗ ਉਸ ਜੀਵ-ਇਸਤ੍ਰੀ ਨੂੰ ਚੜ੍ਹਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Глубокий цвет любви к Господу окрашивает душу-невесту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28746,
          "is_rahao": false,
          "gurmukhi": "ਸਾਂਤਿ ਸੀਗਾਰੁ ਰਾਵੇ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "sānt sīgār rāve prabh soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ (ਆਤਮਕ) ਸ਼ਾਂਤੀ ਨੂੰ (ਆਪਣੇ ਜੀਵਨ ਦਾ) ਗਹਣਾ ਬਣਾਂਦੀ ਹੈ, ਉਹ ਜੀਵ-ਇਸਤ੍ਰੀ ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਹਰ ਵੇਲੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਈ ਰੱਖਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Та, кто украшена покоем, удерживает Господа в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28747,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਵਿਚਿ ਪ੍ਰਭੁ ਕੋਇ ਨ ਪਾਏ ॥",
          "roman": "haumē vich prabh koi na pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਅਹੰਕਾਰ ਵਿਚ (ਰਹਿ ਕੇ) ਕੋਈ ਭੀ ਜੀਵ ਪਰਮਾਤਮਾ ਨੂੰ ਮਿਲ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Но в эго никто не может достичь Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28748,
          "is_rahao": false,
          "gurmukhi": "ਮੂਲਹੁ ਭੁਲਾ ਜਨਮੁ ਗਵਾਏ ॥੨॥",
          "roman": "mūlah bhulā janam gavāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਜਿੰਦ-ਦਾਤੇ ਤੋਂ ਭੁੱਲਾ ਹੋਇਆ ਮਨੁੱਖ ਆਪਣਾ ਮਨੁੱਖਾ ਜਨਮ ਵਿਅਰਥ ਗਵਾ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Отвернувшись от Источника, человек напрасно теряет жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28749,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਤੇ ਸਾਤਿ ਸਹਜ ਸੁਖੁ ਬਾਣੀ ॥",
          "roman": "gur te sāt sahaj sukh bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਪਾਸੋਂ (ਮਿਲੀ) ਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ ਆਤਮਕ ਸ਼ਾਂਤੀ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ, ਆਤਮਕ ਅਡੋਲਤਾ ਦਾ ਆਨੰਦ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через Бани Гуру приходит покой и естественная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28750,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਾ ਸਾਚੀ ਨਾਮਿ ਸਮਾਣੀ ॥",
          "roman": "sevā sāchī nām samāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਦੱਸੀ) ਸੇਵਾ ਸਦਾ ਨਾਲ ਨਿਭਣ ਵਾਲੀ ਚੀਜ਼ ਹੈ (ਇਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ) ਨਾਮ ਵਿਚ ਲੀਨਤਾ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Истинное служение приводит к слиянию с Именем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28751,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਮਿਲੈ ਪ੍ਰੀਤਮੁ ਸਦਾ ਧਿਆਏ ॥",
          "roman": "sabad milē prītam sadā dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਪ੍ਰੀਤਮ-ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Соединённый со словом Гуру человек всегда помнит Возлюбленного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28752,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਨਾਮਿ ਵਡਿਆਈ ਪਾਏ ॥੩॥",
          "roman": "sāch nām vadiāī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ ਲੀਨ ਹੋ ਕੇ (ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਖੱਟਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В Имени Вечного он обретает честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28753,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਤਾ ਜੁਗਿ ਜੁਗਿ ਸੋਇ ॥",
          "roman": "āpe kartā jug jug soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕਰਤਾਰ ਹਰੇਕ ਜੁਗ ਵਿਚ ਆਪ ਹੀ (ਮੌਜੂਦ ਚਲਿਆ ਆ ਰਿਹਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Творец Сам пребывает во всех эпохах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28754,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਮੇਲਾਵਾ ਹੋਇ ॥",
          "roman": "nadar kare melāvā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਮੇਹਰ ਦੀ) ਨਿਗਾਹ ਕਰਦਾ ਹੈ (ਉਸ ਮਨੁੱਖ ਦਾ ਉਸ ਨਾਲ) ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кому Он дарует милость, тот соединяется с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28755,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਬਾਣੀ ਤੇ ਹਰਿ ਮੰਨਿ ਵਸਾਏ ॥",
          "roman": "gurbāṇī te har mann vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ ਪਰਮਾਤਮਾ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через Бани Гуру человек вселяет Бога в своё сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28756,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚਿ ਰਤੇ ਪ੍ਰਭਿ ਆਪਿ ਮਿਲਾਏ ॥੪॥੩॥",
          "roman": "nānak sāch rate prabh āp milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਪ੍ਰਭੂ ਨੇ ਆਪ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਮਿਲਾਇਆ ਹੈ, ਉਹ ਉਸ ਸਦਾ-ਥਿਰ (ਦੇ ਪ੍ਰੇਮ-ਰੰਗ) ਵਿਚ ਰੰਗੇ ਰਹਿੰਦੇ ਹਨ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тех, кого Бог соединяет с Собой, Он окрашивает в Свою истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2537,
      "rahao_verse_id": 28763,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28757,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ਤੀਜਾ ॥",
          "roman": "dhanāsrī mehlā 3 tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28758,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਮੈਲਾ ਮੈਲੋ ਹੋਇ ਜਾਇ ॥",
          "roman": "jag mēlā mēlo hoi jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ ਜਗਤ ਮੈਲੇ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ, ਹੋਰ ਹੋਰ ਵਧੀਕ ਮੈਲੇ ਜੀਵਨ ਵਾਲਾ ਬਣਦਾ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Погружённый в майю, мир становится нечистым и всё более загрязняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28759,
          "is_rahao": false,
          "gurmukhi": "ਆਵੈ ਜਾਇ ਦੂਜੈ ਲੋਭਾਇ ॥",
          "roman": "āvē jāe dūjē lobhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਪਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "И остаётся в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28760,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਸਭ ਪਰਜ ਵਿਗੋਈ ॥",
          "roman": "dūjē bhāe sabh parj vigoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ ਸਾਰੀ ਲੁਕਾਈ ਖ਼ੁਆਰ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В привязанности к майе всё человечество страдает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28761,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਚੋਟਾ ਖਾਇ ਅਪੁਨੀ ਪਤਿ ਖੋਈ ॥੧॥",
          "roman": "manmukh choṭā khāe apnī pat khoī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲਾ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ) ਸੱਟਾਂ ਖਾਂਦਾ ਹੈ, ਤੇ, ਆਪਣੀ ਇੱਜ਼ਤ ਗਵਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Следующий за своим умом получает удары и теряет честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28762,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਜਨੁ ਨਿਰਮਲੁ ਹੋਇ ॥",
          "roman": "gur sevā te jan nirmal hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ (ਦੱਸੀ ਹੋਈ) ਸੇਵਾ ਦੀ ਰਾਹੀਂ ਮਨੁੱਖ ਪਵਿੱਤਰ ਜੀਵਨ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через служение Гуру человек становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28763,
          "is_rahao": true,
          "gurmukhi": "ਅੰਤਰਿ ਨਾਮੁ ਵਸੈ ਪਤਿ ਊਤਮ ਹੋਇ ॥ ਰਹਾਉ ॥",
          "roman": "antar nām vasē pat ūttam hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ, ਤੇ, ਉਸ ਨੂੰ ਉੱਚੀ ਇੱਜ਼ਤ ਮਿਲਦੀ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Внутри него поселяется Имя, и он обретает высокую честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28764,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਉਬਰੇ ਹਰਿ ਸਰਣਾਈ ॥",
          "roman": "gurmukh ubare har saraṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ) ਬਚ ਨਿਕਲਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Обратившиеся к Гуру спасаются, найдя прибежище у Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28765,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮਿ ਰਾਤੇ ਭਗਤਿ ਦ੍ਰਿੜਾਈ ॥",
          "roman": "rām nām rātē bhagat driṛāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਮਗਨ ਰਹਿੰਦੇ ਹਨ, ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪੱਕੀ ਟਿਕਾਈ ਰੱਖਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Они погружены в Имя Бога и утверждают преданность в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28766,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰੇ ਜਨੁ ਵਡਿਆਈ ਪਾਏ ॥",
          "roman": "bhagat kare jan vadiāī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਦਾ ਹੈ ਉਹ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਖੱਟਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто предан Богу, обретает честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28767,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਿ ਰਤੇ ਸੁਖ ਸਹਜਿ ਸਮਾਏ ॥੨॥",
          "roman": "sāch rate sukh sahaj samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ (ਦੇ ਪ੍ਰੇਮ-ਰੰਗ) ਵਿਚ ਰੰਗੇ ਰਹਿੰਦੇ ਹਨ ਉਹ ਆਤਮਕ ਹੁਲਾਰਿਆਂ ਵਿਚ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Окрашенные в истину пребывают в духовной радости и равновесии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28768,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੇ ਕਾ ਗਾਹਕੁ ਵਿਰਲਾ ਕੋ ਜਾਣੁ ॥",
          "roman": "sāche kā gāhak virlā ko jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਫਿਰ ਭੀ,) ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨਾਲ ਮਿਲਾਪ ਦਾ ਚਾਹਵਾਨ ਕਿਸੇ ਵਿਰਲੇ ਮਨੁੱਖ ਨੂੰ ਹੀ ਸਮਝੋ।"
            },
            "sahib_singh_ru": {
              "main": "Редок тот, кто стремится к соединению с Вечным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28769,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਆਪੁ ਪਛਾਣੁ ॥",
          "roman": "gur kē sabad āp pachhāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਕੋਈ ਮਿਲਾਪ ਦਾ ਚਾਹਵਾਨ ਹੁੰਦਾ ਹੈ, ਉਹ) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ ਆਪਣੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਪਰਖਣ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он, соединяясь со словом Гуру, познаёт своё духовное состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28770,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੀ ਰਾਸਿ ਸਾਚਾ ਵਾਪਾਰੁ ॥",
          "roman": "sāchī rās sāchā vāpar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਦੀ ਪੂੰਜੀ (ਆਪਣੇ ਅੰਦਰ ਸਾਂਭ ਕੇ ਰੱਖਦਾ ਹੈ), ਉਹ ਮਨੁੱਖ ਸਦਾ ਸਾਥ ਨਿਬਾਹੁਣ ਵਾਲਾ (ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਦਾ) ਵਪਾਰ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он хранит истинное богатство Имени и ведёт истинную духовную торговлю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28771,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧੰਨੁ ਪੁਰਖੁ ਜਿਸੁ ਨਾਮਿ ਪਿਆਰੁ ॥੩॥",
          "roman": "so dhann purakh jis nām piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਮਨੁੱਖ ਭਾਗਾਂ ਵਾਲਾ ਹੈ ਜਿਸ ਦਾ ਪਿਆਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਪੈ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Благословен тот, кто любит Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28772,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਪ੍ਰਭਿ ਸਾਚੈ ਇਕਿ ਸਚਿ ਲਾਏ ॥",
          "roman": "tin prabh sāche ik sach lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੇ ਕਈ (ਮਨੁੱਖਾਂ) ਨੂੰ (ਆਪਣੇ) ਸਦਾ-ਥਿਰ ਨਾਮ ਵਿਚ ਜੋੜਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Вечный Бог соединяет некоторых с Своей истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28773,
          "is_rahao": false,
          "gurmukhi": "ਊਤਮ ਬਾਣੀ ਸਬਦੁ ਸੁਣਾਏ ॥",
          "roman": "ūttam bāṇī sabad suṇāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੂੰ ਗੁਰੂ ਦੀ ਬਾਣੀ ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਸੁਣਾਂਦਾ ਹੈ, ਤੇ ਪਵਿਤ੍ਰ ਜੀਵਨ ਵਾਲਾ ਬਣਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он даёт им слушать слово Гуру и делает их чистыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
