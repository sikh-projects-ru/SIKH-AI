{
  "ang": 665,
  "shabads": [
    {
      "shabad_id": 2537,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28774,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਾਚੇ ਕੀ ਸਾਚੀ ਕਾਰ ॥",
          "roman": "prabh sāche kī sāchī kār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਇਹ ਅਟੱਲ ਮਰਯਾਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Таков неизменный закон Вечного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28775,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮਿ ਸਵਾਰਣਹਾਰ ॥੪॥੪॥",
          "roman": "nānak nām savāraṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਹੇ ਨਾਨਕ!  ਉਹ ਆਪਣੇ ਨਾਮ ਵਿਚ ਜੋੜ ਕੇ ਜੀਵਾਂ ਦੇ ਜੀਵਨ ਸੋਹਣੇ ਬਣਾ ਦੇਣ ਵਾਲਾ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "что, о Нанак, соединяя с Именем, Он делает жизнь прекрасной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2538,
      "rahao_verse_id": 28782,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28776,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ॥",
          "roman": "dhanāsrī mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28777,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਹਰਿ ਸੇਵਹਿ ਤਿਨ ਬਲਿ ਜਾਉ ॥",
          "roman": "jo har sevah tin bal jāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰਬਾਣੀ ਦਾ ਆਸਰਾ ਲੈ ਕੇ) ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦੇ ਹਨ, ਮੈਂ ਉਹਨਾਂ ਤੋਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые, опираясь на Гурбани, помнят Бога, я жертвую собой ради них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28778,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨ ਹਿਰਦੈ ਸਾਚੁ ਸਚਾ ਮੁਖਿ ਨਾਉ ॥",
          "roman": "tin hirdē sāch sachā mukh nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਵੱਸਿਆ ਰਹਿੰਦਾ ਹੈ, ਉਹਨਾਂ ਦੇ ਮੂੰਹ ਵਿਚ ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В их сердце пребывает вечный Господь, и на их устах всегда утверждён Его вечный Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28779,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੋ ਸਾਚੁ ਸਮਾਲਿਹੁ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "sācho sāch samālih dukh jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ ਹੀ (ਹਿਰਦੇ ਵਿਚ) ਸੰਭਾਲ ਕੇ ਰੱਖਿਆ ਕਰੋ (ਇਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਹਰੇਕ) ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Храни в сердце только Вечного Господа — благодаря этому всякая боль уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28780,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੈ ਸਬਦਿ ਵਸੈ ਮਨਿ ਆਇ ॥੧॥",
          "roman": "sāchē shabad vasē man āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਾਲੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਿਆਂ (ਹਰਿ-ਨਾਮ) ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Соединившись со словом хвалы Вечного Господа, Его Имя входит и пребывает в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28781,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਬਾਣੀ ਸੁਣਿ ਮੈਲੁ ਗਵਾਏ ॥",
          "roman": "gurbāṇī sun mēl gavāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਬਾਣੀ ਸੁਣਿਆ ਕਰ, (ਇਹ ਬਾਣੀ ਮਨ ਵਿਚੋਂ ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਦੂਰ ਕਰ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Слушай Бани Гуру — она удаляет грязь пороков из ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28782,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜੇ ਹਰਿ ਨਾਮੁ ਮੰਨਿ ਵਸਾਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sahjē har nām mann vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਬਾਣੀ) ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ (ਟਿਕਾ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮਨ ਵਿਚ ਵਸਾ ਦੇਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Она утверждает Имя Бога в уме, вводя в состояние внутреннего равновесия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28783,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜੁ ਕੁਸਤੁ ਤ੍ਰਿਸਨਾ ਅਗਨਿ ਬੁਝਾਏ ॥",
          "roman": "kūṛ kust trisnā agan bujhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਬਾਣੀ ਮਨ ਵਿਚੋਂ) ਝੂਠ ਫ਼ਰੇਬ ਮੁਕਾ ਦੇਂਦੀ ਹੈ, ਤ੍ਰਿਸ਼ਨਾ ਦੀ ਅੱਗ ਬੁਝਾ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Она устраняет ложь и обман, и гасит огонь жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28784,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਸਾਂਤਿ ਸਹਜਿ ਸੁਖੁ ਪਾਏ ॥",
          "roman": "antar sānt sahj sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਨ ਵਿਚ ਸ਼ਾਂਤੀ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ, ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਜਾਈਦਾ ਹੈ, ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря ей в уме возникает покой, достигается внутренняя устойчивость и духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28785,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਭਾਣੈ ਚਲੈ ਤਾ ਆਪੁ ਜਾਇ ॥",
          "roman": "gur kē bhāṇē chalē tā āp jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਮਨੁੱਖ ਗੁਰਬਾਣੀ ਅਨੁਸਾਰ) ਗੁਰੂ ਦੀ ਰਜ਼ਾ ਵਿਚ ਤੁਰਦਾ ਹੈ, ਤਦੋਂ (ਉਸ ਦੇ ਅੰਦਰੋਂ) ਆਪਾ-ਭਾਵ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек идёт по воле Гуру, тогда эгоизм исчезает из него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28786,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੁ ਮਹਲੁ ਪਾਏ ਹਰਿ ਗੁਣ ਗਾਇ ॥੨॥",
          "roman": "sāch mahal pāe har guṇ gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਹ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾ ਗਾ ਕੇ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਟਿਕਾਣਾ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ (ਪ੍ਰਭੂ ਚਰਨਾਂ ਵਿਚ ਲੀਨ ਰਹਿੰਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда, воспевая добродетели Бога, он достигает вечного обиталища и пребывает в единстве с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28787,
          "is_rahao": false,
          "gurmukhi": "ਨ ਸਬਦੁ ਬੂਝੈ ਨ ਜਾਣੈ ਬਾਣੀ ॥",
          "roman": "na shabad būjhē na jāṇē bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਮਨੁੱਖ ਨਾਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਸਮਝਦਾ ਹੈ, ਨਾਹ ਗੁਰੂ ਦੀ ਬਾਣੀ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто не понимает слово Гуру и не соединяется глубоко с Бани,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28788,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਅੰਧੇ ਦੁਖਿ ਵਿਹਾਣੀ ॥",
          "roman": "manmukh andhē dukh vihāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਅੰਨ੍ਹੇ ਹੋ ਚੁਕੇ, ਤੇ, ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ (ਉਸ ਮਨੁੱਖ ਦੀ ਉਮਰ) ਦੁੱਖ ਵਿਚ ਹੀ ਗੁਜ਼ਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "ослеплённый привязанностью к майе и следуя своему уму, проводит жизнь в страдании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28789,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟੇ ਤਾ ਸੁਖੁ ਪਾਏ ॥",
          "roman": "satgur bhēṭe tā sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਉਸ ਨੂੰ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਤਦੋਂ ਉਹ ਆਤਮਕ ਆਨੰਦ ਹਾਸਲ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда он встречает Гуру, тогда обретает духовное блаженство,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28790,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਵਿਚਹੁ ਠਾਕਿ ਰਹਾਏ ॥੩॥",
          "roman": "haumē vichah ṭhāk rahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਉਸ ਦੇ ਮਨ ਵਿਚੋਂ ਹਉਮੈ ਮਾਰ ਮੁਕਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и Гуру устраняет из его ума эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28791,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸ ਨੋ ਕਹੀਐ ਦਾਤਾ ਇਕੁ ਸੋਇ ॥",
          "roman": "kis no kahīai dātā ik soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਹੇ ਭਾਈ! (ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਕਿਸੇ ਅੱਗੇ ਅਰਜ਼ੋਈ ਕੀਤੀ ਨਹੀਂ ਜਾ ਸਕਦੀ। ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਹੀ (ਗੁਰੂ ਦੇ ਮਿਲਾਪ ਦੀ ਦਾਤਿ) ਦੇਣ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! К кому ещё обращаться кроме Бога — только Он является дарующим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28792,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਪਾ ਕਰੇ ਸਬਦਿ ਮਿਲਾਵਾ ਹੋਇ ॥",
          "roman": "kirpā karē shabad milāvā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪਰਮਾਤਮਾ (ਇਹ) ਕਿਰਪਾ ਕਰਦਾ ਹੈ, ਤਦੋਂ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਿਆਂ (ਪ੍ਰਭੂ ਨਾਲ) ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда Бог проявляет милость, соединяясь со словом Гуру, происходит встреча с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28793,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਪ੍ਰੀਤਮ ਸਾਚੇ ਗੁਣ ਗਾਵਾ ॥",
          "roman": "mil prītam sāche guṇ gāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਪ੍ਰਭੂ ਦੀ ਮੇਹਰ ਹੋਵੇ, ਤਾਂ) ਮੈਂ ਪ੍ਰੀਤਮ-ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਗੀਤ ਗਾ ਸਕਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Если есть милость, встретив Возлюбленного Гуру, можно воспевать качества Вечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28794,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੇ ਸਾਚਾ ਭਾਵਾ ॥੪॥੫॥",
          "roman": "nānak sāche sāchā bhāvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ ਪਿਆਰਾ ਲੱਗ ਸਕਦਾ ਹਾਂ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Повторяя Имя Вечного Господа, можно стать Ему дорогим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2539,
      "rahao_verse_id": 28801,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28795,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ॥",
          "roman": "dhanāsrī mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28796,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮਰੈ ਧਾਤੁ ਮਰਿ ਜਾਇ ॥",
          "roman": "man marē dhāt mar jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਉਸ ਹਰਿ-ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ ਦਾ) ਮਨ ਵਿਕਾਰਾਂ ਦਾ ਅਸਰ ਨਹੀਂ ਕਬੂਲਦਾ, ਮਨ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਮੁੱਕ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря Имени ум перестаёт принимать влияние пороков, и его жажда исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28797,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਮਨ ਮੂਏ ਕੈਸੇ ਹਰਿ ਪਾਇ ॥",
          "roman": "bin man mūe kēsē har pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਮਨ ਵਿਕਾਰਾਂ ਵਲੋਂ ਅਛੋਹ ਨਹੀਂ ਹੁੰਦਾ, ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਮਿਲਾਪ ਪ੍ਰਾਪਤ ਨਹੀਂ ਕਰ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Пока ум не станет невосприимчив к порокам, человек не может встретить Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28798,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਮਰੈ ਦਾਰੂ ਜਾਣੈ ਕੋਇ ॥",
          "roman": "ihu man marē dārū jāṇē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਉਹ ਦਵਾਈ ਜਾਣਦਾ ਹੈ, ਜਿਸ ਦੇ ਵਰਤਣ ਨਾਲ ਇਹ ਮਨ ਵਿਕਾਰਾਂ ਦਾ ਅਸਰ ਕਬੂਲਣੋਂ ਹਟ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек знает лекарство, благодаря которому ум перестаёт поддаваться порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28799,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਸਬਦਿ ਮਰੈ ਬੂਝੈ ਜਨੁ ਸੋਇ ॥੧॥",
          "roman": "man shabad marē būjhē jan soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਦਾ ਹੈ) ਉਹ ਮਨੁੱਖ ਸਮਝ ਲੈਂਦਾ ਹੈ ਕਿ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜਿਆਂ ਮਨ ਵਿਕਾਰਾਂ ਵਲੋਂ ਅਛੋਹ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто соединяется со словом Гуру, понимает, что именно так ум становится свободным от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28800,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸ ਨੋ ਬਖਸੇ ਹਰਿ ਦੇ ਵਡਿਆਈ ॥",
          "roman": "jis no bakhsē har dē vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਰਮਾਤਮਾ ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ, ਜਿਸ ਨੂੰ ਇੱਜ਼ਤ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кого Бог благословляет и наделяет честью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28801,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਵਸੈ ਮਨਿ ਆਈ ॥ ਰਹਾਉ ॥",
          "roman": "gur parsād vasē man āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ) ਆ ਵੱਸਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "в его уме по милости Гуру поселяется Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28802,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਕਰਣੀ ਕਾਰ ਕਮਾਵੈ ॥",
          "roman": "gurmukh karṇī kār kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਦੋਂ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਗੁਰੂ ਵਲੋਂ ਮਿਲੀ) ਕਰਨ-ਜੋਗ ਕਾਰ ਕਰਨੀ ਸ਼ੁਰੂ ਕਰ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек, следуя Гуру, начинает выполнять предписанное действие,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28803,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਇਸੁ ਮਨ ਕੀ ਸੋਝੀ ਪਾਵੈ ॥",
          "roman": "tā is man kī sojhī pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ ਉਸ ਨੂੰ ਇਸ ਮਨ (ਨੂੰ ਵੱਸ ਵਿਚ ਰੱਖਣ) ਦੀ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда он обретает понимание того, как управлять своим умом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28804,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮੈ ਮਤੁ ਮੈਗਲ ਮਿਕਦਾਰਾ ॥",
          "roman": "man mē mat mēgal mikdārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਮਨੁੱਖ ਸਮਝ ਲੈਂਦਾ ਹੈ ਕਿ) ਮਨ (ਹਉਮੈ ਦੇ) ਨਸ਼ੇ ਵਿਚ ਮਸਤ ਹੋ ਕੇ (ਮਸਤ) ਹਾਥੀ ਵਰਗਾ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он понимает, что ум, опьянённый эго, подобен бешеному слону,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28805,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਅੰਕਸੁ ਮਾਰਿ ਜੀਵਾਲਣਹਾਰਾ ॥੨॥",
          "roman": "gur aṅkas mār jīvālaṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਹੀ (ਆਪਣੇ ਸ਼ਬਦ ਦਾ) ਕੁੰਡਾ ਵਰਤ ਕੇ (ਵਿਕਾਰਾਂ ਵਿਚ ਆਤਮਕ ਮੌਤੇ ਮਰੇ ਹੋਏ ਮਨ ਨੂੰ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਦੀ ਸਮਰਥਾ ਰੱਖਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и только Гуру, используя крюк своего слова, способен оживить его духовно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28806,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਅਸਾਧੁ ਸਾਧੈ ਜਨੁ ਕੋਈ ॥",
          "roman": "man asādh sādhē jan koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਹ ਮਨ ਬੜੀ ਮੁਸ਼ਕਿਲ ਨਾਲ ਵੱਸ ਵਿਚ ਆਉਂਦਾ ਹੈ, ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਇਸ ਨੂੰ ਵੱਸ ਵਿਚ ਲਿਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот ум крайне трудно обуздать, лишь редкий человек может это сделать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28807,
          "is_rahao": false,
          "gurmukhi": "ਅਚਰੁ ਚਰੈ ਤਾ ਨਿਰਮਲੁ ਹੋਈ ॥",
          "roman": "achar charē tā nirmal hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਮਨੁੱਖ (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਮਨ ਦੇ) ਅਸਾਧ ਰੋਗ (ਕਾਮਾਦਿਕ) ਨੂੰ ਮੁਕਾ ਲੈਂਦਾ ਹੈ, ਤਦੋਂ (ਇਸ ਦਾ ਮਨ) ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек, следуя Гуру, устраняет болезнь пороков, его ум становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28808,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਇਹੁ ਮਨੁ ਲਇਆ ਸਵਾਰਿ ॥",
          "roman": "gurmukh ihu man laeā savār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪਏ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ ਇਸ ਮਨ ਨੂੰ ਸੋਹਣਾ ਬਣਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Следующий Гуру украшает и совершенствует этот ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28809,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਵਿਚਹੁ ਤਜੈ ਵਿਕਾਰ ॥੩॥",
          "roman": "haumē vichah tajē vikār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਆਪਣੇ ਅੰਦਰੋਂ ਹਉਮੈ ਆਦਿਕ ਵਿਕਾਰਾਂ ਨੂੰ ਕੱਢ ਦੇਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и избавляется от эго и пороков внутри себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28810,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਧੁਰਿ ਰਖਿਅਨੁ ਮੇਲਿ ਮਿਲਾਇ ॥",
          "roman": "jo dhur rakhiān mel milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਉਸ (ਪਰਮਾਤਮਾ) ਨੇ ਧੁਰ ਤੋਂ ਹੀ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਰੱਖਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кого Бог изначально соединил с Собой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28811,
          "is_rahao": false,
          "gurmukhi": "ਕਦੇ ਨ ਵਿਛੁੜਹਿ ਸਬਦਿ ਸਮਾਇ ॥",
          "roman": "kadē na vichhuṛeh shabad samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਲੀਨ ਰਹਿ ਕੇ ਕਦੇ ਭੀ (ਪ੍ਰਭੂ ਤੋਂ) ਨਹੀਂ ਵਿਛੁੜਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "пребывая в слове Гуру, никогда не отделяются от Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28812,
          "is_rahao": false,
          "gurmukhi": "ਆਪਣੀ ਕਲਾ ਆਪੇ ਪ੍ਰਭੁ ਜਾਣੈ ॥",
          "roman": "āpṇī kalā āpe prabh jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਹੇ ਭਾਈ! ਪ੍ਰਭੂ ਆਪ ਹੀ ਆਪਣੀ ਗੁੱਝੀ ਤਾਕਤ ਜਾਣਦਾ ਹੈ (ਕਿ ਕਿਸ ਨੂੰ ਉਹ ਆਪਣੇ ਨਾਲ ਜੋੜੀ ਰੱਖਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Бог Сам знает Свою скрытую силу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28813,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਪਛਾਣੈ ॥੪॥੬॥",
          "roman": "nānak gurmukh nām pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਗੁਰੂ ਦੇ ਸਨਮੁਖ ਰਹਿਣ ਵਾਲਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨਾਲ ਸਾਂਝ ਬਣਾਈ ਰੱਖਦਾ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Следующий Гуру распознаёт и соединяется с Именем Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2540,
      "rahao_verse_id": 28820,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 28814,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੩ ॥",
          "roman": "dhanāsrī mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28815,
          "is_rahao": false,
          "gurmukhi": "ਕਾਚਾ ਧਨੁ ਸੰਚਹਿ ਮੂਰਖ ਗਾਵਾਰ ॥",
          "roman": "kāchā dhan sanchah mūṛakh gāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੂਰਖ ਅੰਞਾਣ ਲੋਕ (ਸਿਰਫ਼ ਦੁਨੀਆ ਵਾਲਾ) ਨਾਸਵੰਤ ਧਨ (ਹੀ) ਜੋੜਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Невежественные люди собирают лишь тленное богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28816,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਭੂਲੇ ਅੰਧ ਗਾਵਾਰ ॥",
          "roman": "manmukh bhūlē andh gāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ, ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਅੰਨ੍ਹੇ ਹੋਏ ਹੋਏ ਮਨੁੱਖ ਕੁਰਾਹੇ ਪਏ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Следующие своему уму, ослеплённые майей, они сбиваются с пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28817,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਿਆ ਕੈ ਧਨਿ ਸਦਾ ਦੁਖੁ ਹੋਇ ॥",
          "roman": "bikhiyā kē dhan sadā dukh hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ ਦੇ ਧਨ ਨਾਲ ਸਦਾ ਦੁੱਖ (ਹੀ) ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "От богатства майи всегда приходит страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28818,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸਾਥਿ ਜਾਇ ਨ ਪਰਾਪਤਿ ਹੋਇ ॥੧॥",
          "roman": "nā sāth jāe na parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਧਨ ਨਾਹ ਹੀ ਮਨੁੱਖ ਦੇ ਨਾਲ ਜਾਂਦਾ ਹੈ, ਅਤੇ, ਨਾਹ ਹੀ (ਇਸ ਨੂੰ ਜੋੜ ਜੋੜ ਕੇ) ਸੰਤੋਖ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Это богатство не идёт с человеком и не даёт удовлетворения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28819,
          "is_rahao": true,
          "gurmukhi": "ਸਾਚਾ ਧਨੁ ਗੁਰਮਤੀ ਪਾਏ ॥",
          "roman": "sāchā dhan gurmatī pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਮਤਿ ਉਤੇ ਤੁਰਦਾ ਹੈ, ਉਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ-ਧਨ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Следуя учению Гуру, человек получает истинное богатство — Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28820,
          "is_rahao": true,
          "gurmukhi": "ਕਾਚਾ ਧਨੁ ਫੁਨਿ ਆਵੈ ਜਾਏ ॥ ਰਹਾਉ ॥",
          "roman": "kāchā dhan phun āvē jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਦੁਨੀਆ ਵਾਲਾ) ਨਾਸਵੰਤ ਧਨ ਕਦੇ ਮਨੁੱਖ ਨੂੰ ਮਿਲ ਜਾਂਦਾ ਹੈ ਕਦੇ ਹੱਥੋਂ ਨਿਕਲ ਜਾਂਦਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Тленное богатство приходит и уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28821,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਭੂਲੇ ਸਭਿ ਮਰਹਿ ਗਵਾਰ ॥",
          "roman": "manmukh bhūlē sabh marah gāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮੂਰਖ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ) ਕੁਰਾਹੇ ਪੈ ਕੇ ਸਭ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Следующие своему уму глупцы заблуждаются и духовно умирают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28822,
          "is_rahao": false,
          "gurmukhi": "ਭਵਜਲਿ ਡੂਬੇ ਨ ਉਰਵਾਰਿ ਨ ਪਾਰਿ ॥",
          "roman": "bhavjal ḍūbē na urvār na pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਡੁੱਬ ਜਾਂਦੇ ਹਨ, ਨਾਹ ਉਰਲੇ ਬੰਨੇ ਰਹਿੰਦੇ ਹਨ, ਨਾਹ ਪਾਰਲੇ ਬੰਨੇ (ਨਾਹ ਇਹ ਮਾਇਆ ਸਾਥ ਤੋੜ ਨਿਬਾਹੁੰਦੀ ਹੈ, ਨਾਹ ਨਾਮ-ਧਨ ਜੋੜਿਆ ਹੁੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Они тонут в океане мира, не достигая ни этого берега, ни другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28823,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟੇ ਪੂਰੈ ਭਾਗਿ ॥",
          "roman": "satgur bhēṭe pūrē bhāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਪੂਰੀ ਕਿਸਮਤ ਨਾਲ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тем, кому по великой удаче встречается Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28824,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਿ ਰਤੇ ਅਹਿਨਿਸਿ ਬੈਰਾਗਿ ॥੨॥",
          "roman": "sāch rate ahinis bērāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਦਿਨ ਰਾਤ (ਹਰ ਵੇਲੇ) ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਵਿਚ ਮਗਨ ਰਹਿੰਦੇ ਹਨ (ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਾਇਆ ਵਲੋਂ) ਉਪਰਾਮਤਾ ਵਿਚ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "они днём и ночью пребывают в Имени Бога и остаются отрешёнными от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28825,
          "is_rahao": false,
          "gurmukhi": "ਚਹੁ ਜੁਗ ਮਹਿ ਅੰਮ੍ਰਿਤੁ ਸਾਚੀ ਬਾਣੀ ॥",
          "roman": "chah jug mah amrit sāchī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਾਲੀ ਗੁਰਬਾਣੀ ਸਦਾ ਹੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ-ਜਲ (ਵੰਡਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Во все времена истинная Бани раздаёт нектар Имени, дающий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28826,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਭਾਗਿ ਹਰਿ ਨਾਮਿ ਸਮਾਣੀ ॥",
          "roman": "pūrē bhāg har nām samāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੀ ਕਿਸਮਤ ਨਾਲ (ਮਨੁੱਖ ਇਸ ਬਾਣੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਲੀਨ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По великой удаче человек сливается с Именем Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28827,
          "is_rahao": false,
          "gurmukhi": "ਸਿਧ ਸਾਧਿਕ ਤਰਸਹਿ ਸਭਿ ਲੋਇ ॥",
          "roman": "sidh sādhik tarsah sabh loi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਕਰਾਮਾਤੀ ਜੋਗੀ ਤੇ ਸਾਧਨਾਂ ਕਰਨ ਵਾਲੇ ਜੋਗੀ ਸਾਰੇ ਹੀ ਜਗਤ ਵਿਚ (ਇਸ ਬਾਣੀ ਦੀ ਖ਼ਾਤਰ) ਤਰਲੇ ਲੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Йоги и аскеты во всём мире стремятся к этой Бани."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28828,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਭਾਗਿ ਪਰਾਪਤਿ ਹੋਇ ॥੩॥",
          "roman": "pūrē bhāg parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਵਾਲੀ ਗੁਰਬਾਣੀ) ਪੂਰੀ ਕਿਸਮਤ ਨਾਲ ਹੀ ਮਿਲਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но она достигается только по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28829,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਸਾਚਾ ਸਾਚਾ ਹੈ ਸੋਇ ॥",
          "roman": "sabh kichh sāchā sāchā hē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜਾ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਪਵਿੱਤ੍ਰ-ਸਰੂਪ ਪਰਮਾਤਮਾ ਨਾਲ ਸਾਂਝ ਪਾਂਦਾ ਹੈ ਉਸ ਨੂੰ ਹਰੇਕ ਸ਼ੈ ਉਸ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਰੂਪ ਦਿੱਸਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кто соединяется с Богом, всё видится как проявление Вечного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28830,
          "is_rahao": false,
          "gurmukhi": "ਊਤਮ ਬ੍ਰਹਮੁ ਪਛਾਣੈ ਕੋਇ ॥",
          "roman": "ūtam brahm pachhāṇē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਹਰ ਥਾਂ ਉਹ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਹੀ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он видит присутствие Вечного Господа повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 28831,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸਾਚਾ ਸਚੁ ਆਪਿ ਦ੍ਰਿੜਾਏ ॥",
          "roman": "sach sāchā sach āp driṛhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਪਰਮਾਤਮਾ ਆਪਣਾ ਸਦਾ-ਥਿਰ ਨਾਮ ਆਪ ਹੀ (ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਪੱਕਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сам Бог утверждает Своё вечное Имя в сердце человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
