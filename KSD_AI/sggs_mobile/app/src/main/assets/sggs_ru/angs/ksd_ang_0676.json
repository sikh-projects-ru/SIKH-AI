{
  "ang": 676,
  "shabads": [
    {
      "shabad_id": 2575,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29184,
          "is_rahao": false,
          "gurmukhi": "ਤਾਣੁ ਮਾਣੁ ਦੀਬਾਣੁ ਸਾਚਾ ਨਾਨਕ ਕੀ ਪ੍ਰਭ ਟੇਕ ॥੪॥੨॥੨੦॥",
          "roman": "tāṇ māṇ dībāṇ sāchā nānak kī prabh ṭek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਪਰਮਾਤਮਾ ਦੀ ਓਟ ਹੀ ਉਹਨਾਂ ਦਾ ਬਲ ਹੈ, ਸਹਾਰਾ ਹੈ, ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਆਸਰਾ ਹੈ ॥੪॥੨॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! опора на Бога — это их сила, поддержка и вечное убежище ॥੪॥੨॥੨੦॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2576,
      "rahao_verse_id": 29189,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29185,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "dhanāsrī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29186,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਤ ਫਿਰਤ ਭੇਟੇ ਜਨ ਸਾਧੂ ਪੂਰੈ ਗੁਰਿ ਸਮਝਾਇਆ ॥",
          "roman": "phirat phirat bheṭe jan sādhū pūre gur samjhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਭਾਲ ਕਰਦਿਆਂ ਕਰਦਿਆਂ ਜਦੋਂ ਮੈਂ ਗੁਰੂ ਮਹਾ ਪੁਰਖ ਨੂੰ ਮਿਲਿਆ, ਤਾਂ ਪੂਰੇ ਗੁਰੂ ਨੇ (ਮੈਨੂੰ) ਇਹ ਸਮਝ ਬਖ਼ਸ਼ੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Ища и ища, когда я встретил великого святого Гуру, совершенный Гуру даровал мне это понимание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29187,
          "is_rahao": false,
          "gurmukhi": "ਆਨ ਸਗਲ ਬਿਧਿ ਕਾਂਮਿ ਨ ਆਵੈ ਹਰਿ ਹਰਿ ਨਾਮੁ ਧਿਆਇਆ ॥੧॥",
          "roman": "ān sagal bidh kām na āvē har har nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਬਚਣ ਲਈ) ਹੋਰ ਸਾਰੀਆਂ ਜੁਗਤੀਆਂ ਵਿਚੋਂ ਕੋਈ ਇੱਕ ਜੁਗਤਿ ਭੀ ਕੰਮ ਨਹੀਂ ਆਉਂਦੀ। ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਹੋਇਆ ਹੀ ਕੰਮ ਆਉਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "что из всех прочих способов ни один не помогает. Лишь памятование Имени Бога приносит пользу ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29188,
          "is_rahao": true,
          "gurmukhi": "ਤਾ ਤੇ ਮੋਹਿ ਧਾਰੀ ਓਟ ਗੋਪਾਲ ॥",
          "roman": "tā te moh dhārī oṭ gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਵਾਸਤੇ, ਹੇ ਭਾਈ! ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲੈ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, о брат, я принял прибежище у Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29189,
          "is_rahao": true,
          "gurmukhi": "ਸਰਨਿ ਪਰਿਓ ਪੂਰਨ ਪਰਮੇਸੁਰ ਬਿਨਸੇ ਸਗਲ ਜੰਜਾਲ ॥ ਰਹਾਉ ॥",
          "roman": "saran pariō pūran parmesar binse sagal janjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਮੈਂ) ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਿਆ, ਤਾਂ ਮੇਰੇ ਸਾਰੇ (ਮਾਇਆ ਦੇ) ਜੰਜਾਲ ਨਾਸ ਹੋ ਗਏ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда я пал к стопам всепроникающего Бога, все мои оковы майи разрушились ॥пауза॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29190,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਗ ਮਿਰਤ ਪਇਆਲ ਭੂ ਮੰਡਲ ਸਗਲ ਬਿਆਪੇ ਮਾਇ ॥",
          "roman": "surag mrit paiāl bhū maṇḍal sagal biāpe māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਦੇਵ ਲੋਕ, ਮਾਤ-ਲੋਕ, ਪਾਤਾਲ-ਸਾਰੀ ਹੀ ਸ੍ਰਿਸ਼ਟੀ ਮਾਇਆ (ਦੇ ਮੋਹ) ਵਿਚ ਫਸੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Небесные миры, мир людей и подземные области — вся вселенная погружена в майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29191,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਉਧਾਰਨ ਸਭ ਕੁਲ ਤਾਰਨ ਹਰਿ ਹਰਿ ਨਾਮੁ ਧਿਆਇ ॥੨॥",
          "roman": "jīa udhāran sabh kul tāran har har nām dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ, ਇਹੀ ਹੈ ਜਿੰਦ ਨੂੰ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚੋਂ) ਬਚਾਣ ਵਾਲਾ, ਇਹੀ ਹੈ ਸਾਰੀਆਂ ਕੁਲਾਂ ਨੂੰ ਤਾਰਨ ਵਾਲਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда помни Имя Бога — оно спасает душу и освобождает все роды ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29192,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਨਿਰੰਜਨੁ ਗਾਈਐ ਪਾਈਐ ਸਰਬ ਨਿਧਾਨਾ ॥",
          "roman": "nānak nām niranjan gāīai pāīai sarab nidhānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮਾਇਆ ਤੋਂ ਨਿਰਲੇਪ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਗਾਣਾ ਚਾਹੀਦਾ ਹੈ, (ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸਾਰੇ ਖ਼ਜ਼ਾਨਿਆਂ ਦੀ ਪ੍ਰਾਪਤੀ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Следует воспевать Имя безупречного Бога; благодаря Имени обретаются все сокровища,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29193,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਦੇਇ ਸੁਆਮੀ ਬਿਰਲੇ ਕਾਹੂ ਜਾਨਾ ॥੩॥੩॥੨੧॥",
          "roman": "kar kirpā jis deī suāmī birle kāhū jānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ (ਇਹ ਭੇਤ) ਕਿਸੇ (ਉਸ) ਵਿਰਲੇ ਮਨੁੱਖ ਨੇ ਸਮਝਿਆ ਹੈ ਜਿਸ ਨੂੰ ਮਾਲਕ-ਪ੍ਰਭੂ ਆਪ ਮੇਹਰ ਕਰ ਕੇ (ਨਾਮ ਦੀ ਦਾਤਿ) ਦੇਂਦਾ ਹੈ ॥੩॥੩॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "но эту тайну понимает лишь редкий человек, кому Сам Господь дарует милость ॥3॥3॥21॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2577,
      "rahao_verse_id": 29201,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29194,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ਘਰੁ ੨ ਚਉਪਦੇ",
          "roman": "dhanāsrī mehlā 5 ghar 2 chaupadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਧਨਾਸਰੀ, ਘਰ ੨ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਚਾਰ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Дханасри, дом 2, бани Гуру Арджан Дев Джи из четырёх строф."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29195,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Есть один А́кал Пуракх, и достигается Он милостью Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29196,
          "is_rahao": false,
          "gurmukhi": "ਛੋਡਿ ਜਾਹਿ ਸੇ ਕਰਹਿ ਪਰਾਲ ॥",
          "roman": "chhoḍ jāh se karah parāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ-ਵੇੜ੍ਹੇ ਜੀਵ ਉਹੀ ਨਿਕੰਮੇ ਕੰਮ ਕਰਦੇ ਰਹਿੰਦੇ ਹਨ, ਜਿਨ੍ਹਾਂ ਨੂੰ ਆਖ਼ਰ ਛੱਡ ਕੇ ਇਥੋਂ ਚਲੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Люди, погружённые в майю, занимаются лишь теми делами, которые в конце оставляют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29197,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਿ ਨ ਆਵਹਿ ਸੇ ਜੰਜਾਲ ॥",
          "roman": "kām na āvah se janjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਜੰਜਾਲ ਸਹੇੜੀ ਰੱਖਦੇ ਹਨ, ਜੇਹੜੇ ਇਹਨਾਂ ਦੇ ਕਿਸੇ ਕੰਮ ਨਹੀਂ ਆਉਂਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Они собирают те оковы, которые им не приносят пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29198,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਨ ਚਾਲਹਿ ਤਿਨ ਸਿਉ ਹੀਤ ॥",
          "roman": "sang na chāleh tin siu hīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨਾਲ ਮੋਹ-ਪਿਆਰ ਬਣਾਈ ਰੱਖਦੇ ਹਨ, ਜੇਹੜੇ (ਅੰਤ ਵੇਲੇ) ਨਾਲ ਨਹੀਂ ਜਾਂਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Они привязываются к тому, что не пойдёт с ними в конце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29199,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਬੈਰਾਈ ਸੇਈ ਮੀਤ ॥੧॥",
          "roman": "jo bērāī seī mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ (ਵਿਕਾਰਾਂ) ਨੂੰ ਮਿੱਤਰ ਸਮਝਦੇ ਰਹਿੰਦੇ ਹਨ ਜੋ (ਅਸਲ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੇ) ਵੈਰੀ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "То, что является врагом, они считают другом ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29200,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਭਰਮਿ ਭੁਲੇ ਸੰਸਾਰਾ ॥",
          "roman": "aise bharam bhule sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੂਰਖ ਜਗਤ (ਮਾਇਆ ਦੀ) ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ ਅਜੇ ਕੁਰਾਹੇ ਪਿਆ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Глупый мир, впав в заблуждение майи, сбился с пути,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29201,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਖੋਇ ਗਵਾਰਾ ॥ ਰਹਾਉ ॥",
          "roman": "janam padārath khoi gavārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ ਆਪਣਾ) ਕੀਮਤੀ ਮਨੁੱਖਾ ਜਨਮ ਗਵਾ ਰਿਹਾ ਹੈ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "и теряет драгоценное человеческое рождение ॥пауза॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29202,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੁ ਧਰਮੁ ਨਹੀ ਭਾਵੈ ਡੀਠਾ ॥",
          "roman": "sāch dharam nahī bhāvē ḍīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਮਾਇਆ-ਵੇੜ੍ਹੇ ਮੂਰਖ ਮਨੁੱਖ ਨੂੰ) ਸਦਾ-ਥਿਰ ਹਰਿ-ਨਾਮ ਸਿਮਰਨ (ਵਾਲਾ) ਧਰਮ ਅੱਖੀਂ ਵੇਖਿਆ ਨਹੀਂ ਭਾਉਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Человеку, окутанному майей, не нравится истинная религия — памятование Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29203,
          "is_rahao": false,
          "gurmukhi": "ਝੂਠ ਧੋਹ ਸਿਉ ਰਚਿਓ ਮੀਠਾ ॥",
          "roman": "jhūṭh dhōh siu rachiō mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਝੂਠ ਨੂੰ ਠੱਗੀ ਨੂੰ ਮਿੱਠਾ ਜਾਣ ਕੇ ਇਹਨਾਂ ਨਾਲ ਮਸਤ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он, считая ложь и обман сладкими, погружён в них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29204,
          "is_rahao": false,
          "gurmukhi": "ਦਾਤਿ ਪਿਆਰੀ ਵਿਸਰਿਆ ਦਾਤਾਰਾ ॥",
          "roman": "dāt piārī visriā dātārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਤਾਰ-ਪ੍ਰਭੂ ਨੂੰ ਭੁਲਾਈ ਰੱਖਦਾ ਹੈ, ਉਸ ਦੀ ਦਿੱਤੀ ਹੋਈ ਦਾਤਿ ਇਸ ਨੂੰ ਪਿਆਰੀ ਲੱਗਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он забывает Дающего, а любит Его дары."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29205,
          "is_rahao": false,
          "gurmukhi": "ਜਾਣੈ ਨਾਹੀ ਮਰਣੁ ਵਿਚਾਰਾ ॥੨॥",
          "roman": "jāṇē nāhī maraṇ vichārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੋਹ ਵਿਚ) ਬੇਬਸ ਹੋਇਆ ਜੀਵ ਆਪਣੀ ਮੌਤ ਨੂੰ ਚੇਤੇ ਨਹੀਂ ਕਰਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поглощённый привязанностью, он не думает о смерти ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29206,
          "is_rahao": false,
          "gurmukhi": "ਵਸਤੁ ਪਰਾਈ ਕਉ ਉਠਿ ਰੋਵੈ ॥",
          "roman": "vast parāī kau uṭh rovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਭਟਕਣਾ ਵਿਚ ਪਿਆ ਹੋਇਆ ਜੀਵ) ਉਸ ਚੀਜ਼ ਲਈ ਦੌੜ ਦੌੜ ਤਰਲੇ ਲੈਂਦਾ ਹੈ ਜੋ ਆਖ਼ਰ ਬਿਗਾਨੀ ਹੋ ਜਾਣੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Человек, блуждающий в заблуждении, стремится к тому, что в итоге станет чужим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29207,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮ ਧਰਮ ਸਗਲਾ ਈ ਖੋਵੈ ॥",
          "roman": "karam dharam saglā ī khovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣਾ ਇਨਸਾਨੀ ਫ਼ਰਜ਼ ਸਾਰਾ ਹੀ ਭੁਲਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он забывает все свои человеческие обязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29208,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੁ ਨ ਬੂਝੈ ਆਵਣ ਜਾਣੇ ॥",
          "roman": "hukam na būjhē āvaṇ jāṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ ਨਹੀਂ ਸਮਝਦਾ (ਜਿਸ ਕਰਕੇ ਇਸ ਦੇ ਵਾਸਤੇ) ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ (ਬਣੇ ਰਹਿੰਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Человек не понимает воли Бога, и поэтому остаётся в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29209,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਕਰੈ ਤਾ ਪਛੋਤਾਣੇ ॥੩॥",
          "roman": "pāp karē tā pachhotāṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿੱਤ ਪਾਪ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ, ਆਖ਼ਰ ਪਛੁਤਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно совершает грехи, а затем раскаивается ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29210,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੁਧੁ ਭਾਵੈ ਸੋ ਪਰਵਾਣੁ ॥",
          "roman": "jo tudh bhāvē so parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਪ੍ਰਭੂ! ਜੀਵਾਂ ਦੇ ਕੀਹ ਵੱਸ?) ਜੋ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ, ਉਹੀ ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ ਕਬੂਲ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь, что Тебе угодно, то и принимается нами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29211,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਭਾਣੇ ਨੋ ਕੁਰਬਾਣੁ ॥",
          "roman": "tere bhāṇe no kurbāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੀ ਮਰਜ਼ੀ ਤੋਂ ਸਦਕੇ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я предан Твоей воле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29212,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਗਰੀਬੁ ਬੰਦਾ ਜਨੁ ਤੇਰਾ ॥",
          "roman": "nānak garīb bandā jan terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗਰੀਬ ਨਾਨਕ ਤੇਰਾ ਦਾਸ ਹੈ ਤੇਰਾ ਗ਼ੁਲਾਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бедный Нанак — Твой слуга, Твой раб."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29213,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਿ ਲੇਇ ਸਾਹਿਬੁ ਪ੍ਰਭੁ ਮੇਰਾ ॥੪॥੧॥੨੨॥",
          "roman": "rākh leī sāhib prabh merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਮਾਲਕ-ਪ੍ਰਭੂ (ਆਪਣੇ ਦਾਸ ਦੀ ਲਾਜ ਆਪ) ਰੱਖ ਲੈਂਦਾ ਹੈ ॥੪॥੧॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "Мой Господь Сам сохраняет честь Своего слуги ॥4॥1॥22॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2578,
      "rahao_verse_id": 29220,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 29214,
          "is_rahao": false,
          "gurmukhi": "ਧਨਾਸਰੀ ਮਹਲਾ ੫ ॥",
          "roman": "dhanāsrī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29215,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਮਸਕੀਨ ਪ੍ਰਭੁ ਨਾਮੁ ਅਧਾਰੁ ॥",
          "roman": "moh maskīn prabh nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਨੂੰ ਆਜਿਜ਼ ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਹੀ) ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Для меня, смиренного, Имя Бога — единственная опора,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29216,
          "is_rahao": false,
          "gurmukhi": "ਖਾਟਣ ਕਉ ਹਰਿ ਹਰਿ ਰੋਜਗਾਰੁ ॥",
          "roman": "khāṭaṇ kau har har rojgār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਵਾਸਤੇ ਖੱਟਣ ਕਮਾਣ ਲਈ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਰੋਜ਼ੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "для меня Имя Бога — единственный заработок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29217,
          "is_rahao": false,
          "gurmukhi": "ਸੰਚਣ ਕਉ ਹਰਿ ਏਕੋ ਨਾਮੁ ॥",
          "roman": "sanchan kau har eko nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਵਾਸਤੇ ਇਕੱਠਾ ਕਰਨ ਲਈ (ਭੀ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Для накопления у меня есть лишь Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29218,
          "is_rahao": false,
          "gurmukhi": "ਹਲਤਿ ਪਲਤਿ ਤਾ ਕੈ ਆਵੈ ਕਾਮ ॥੧॥",
          "roman": "halat palat tā kē āvē kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਹਰਿ-ਨਾਮ-ਧਨ ਇਕੱਠਾ ਕਰਦਾ ਹੈ) ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਉਸ ਦੇ ਕੰਮ ਆਉਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Оно помогает и в этом мире, и в следующем ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29219,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮਿ ਰਤੇ ਪ੍ਰਭ ਰੰਗਿ ਅਪਾਰ ॥",
          "roman": "nām rate prabh rang apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਮਸਤ ਹੋ ਕੇ, ਸੰਤ ਜਨ ਬੇਅੰਤ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ ਜੁੜ ਕੇ-"
            },
            "sahib_singh_ru": {
              "main": "О брат! Погружённые в Имя, святые соединяются с бесконечной любовью Бога —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29220,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧ ਗਾਵਹਿ ਗੁਣ ਏਕ ਨਿਰੰਕਾਰ ॥ ਰਹਾਉ ॥",
          "roman": "sādh gāvahi guṇ ek nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇੱਕ ਨਿਰੰਕਾਰ ਦੇ ਗੁਣ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ ਰਹਾਉ॥"
            },
            "sahib_singh_ru": {
              "main": "и воспевают качества Единого Бесформенного ॥пауза॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29221,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਕੀ ਸੋਭਾ ਅਤਿ ਮਸਕੀਨੀ ॥",
          "roman": "sādh kī sobhā at maskīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਬਹੁਤ ਨਿਮ੍ਰਤਾ-ਸੁਭਾਉ ਸੰਤ ਦੀ ਸੋਭਾ (ਦਾ ਮੂਲ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Смирение — основа славы святого,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29222,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਵਡਾਈ ਹਰਿ ਜਸੁ ਚੀਨੀ ॥",
          "roman": "sant vaḍāī har jas chīnī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਨੀ ਹੀ ਸੰਤ ਦੀ ਵਡਿਆਈ (ਦਾ ਕਾਰਨ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "а прославление Бога — причина величия святого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29223,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦੁ ਸੰਤਨ ਕੈ ਭਗਤਿ ਗੋਵਿੰਦ ॥",
          "roman": "anad santan kē bhagat govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਸੰਤ ਜਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆਨੰਦ ਪੈਦਾ ਕਰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Преданность Богу приносит радость в сердца святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29224,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖੁ ਸੰਤਨ ਕੈ ਬਿਨਸੀ ਚਿੰਦ ॥੨॥",
          "roman": "sūkh santan kē binsī chind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਗਤੀ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸੰਤ ਜਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਸੁਖ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਚਿੰਤਾ ਨਾਸ ਹੋ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря ей в их сердцах пребывает покой, а тревоги исчезают ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29225,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਸਾਧ ਸੰਤਨ ਹੋਵਹਿ ਇਕਤ੍ਰ ॥",
          "roman": "jah sādh santan hovah ikatr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਧ ਸੰਤ ਜਿੱਥੇ (ਭੀ) ਇਕੱਠੇ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Где бы ни собирались святые,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29226,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਹਰਿ ਜਸੁ ਗਾਵਹਿ ਨਾਦ ਕਵਿਤ ॥",
          "roman": "tah har jas gāvah nād kavit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਉਹ ਸਾਜ ਵਰਤ ਕੇ ਬਾਣੀ ਪੜ੍ਹ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ (ਹੀ) ਗਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "там они, используя музыку и слово, воспевают хвалу Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29227,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਸਭਾ ਮਹਿ ਅਨਦ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "sādh sabhā mah anad bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸੰਤਾਂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਬੈਠਿਆਂ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ ਸ਼ਾਂਤੀ ਹਾਸਲ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В собрании святых обретается духовная радость и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29228,
          "is_rahao": false,
          "gurmukhi": "ਉਨ ਸੰਗੁ ਸੋ ਪਾਏ ਜਿਸੁ ਮਸਤਕਿ ਕਰਾਮ ॥੩॥",
          "roman": "un sang so pāe jis mastak karām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਉਹਨਾਂ ਦੀ ਸੰਗਤਿ ਉਹੀ ਮਨੁੱਖ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ ਜਿਸ ਦੇ ਮੱਥੇ ਉੱਤੇ ਬਖ਼ਸ਼ਸ਼ (ਦਾ ਲੇਖ ਲਿਖਿਆ ਹੋਵੇ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но такую компанию получает лишь тот, на чьём челе написана милость ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29229,
          "is_rahao": false,
          "gurmukhi": "ਦੁਇ ਕਰ ਜੋੜਿ ਕਰੀ ਅਰਦਾਸਿ ॥",
          "roman": "dui kar joṛ karī ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ ਆਪਣੇ ਦੋਵੇਂ ਹੱਥ ਜੋੜ ਕੇ ਅਰਦਾਸ ਕਰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Сложив руки, я молюсь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29230,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਪਖਾਰਿ ਕਹਾਂ ਗੁਣਤਾਸ ॥",
          "roman": "charan pakhār kahāṅ guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਮੈਂ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨ ਧੋ ਕੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਉਚਾਰਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "чтобы, омывая стопы святых, я произносил Имя — сокровище добродетелей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29231,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਇਆਲ ਕਿਰਪਾਲ ਹਜੂਰਿ ॥",
          "roman": "prabh daiāl kirpāl hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੇਹੜੇ ਦਇਆਲ ਕਿਰਪਾਲ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ (ਸਦਾ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Те, кто пребывают в присутствии милосердного и сострадательного Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 29232,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜੀਵੈ ਸੰਤਾ ਧੂਰਿ ॥੪॥੨॥੨੩॥",
          "roman": "nānak jīvē santā dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਉਹਨਾਂ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਤੋਂ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ ॥੪॥੨॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак получает духовную жизнь от пыли стоп святых ॥4॥2॥23॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
