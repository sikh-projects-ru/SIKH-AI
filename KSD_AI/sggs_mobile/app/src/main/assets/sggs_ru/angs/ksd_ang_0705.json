{
  "ang": 705,
  "shabads": [
    {
      "shabad_id": 2678,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30262,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30263,
          "is_rahao": false,
          "gurmukhi": "ਚਿਤਿ ਜਿ ਚਿਤਵਿਆ ਸੋ ਮੈ ਪਾਇਆ ॥",
          "roman": "chit j chitviyā so mēṃ pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё, что я помыслил и попросил в сердце, я получил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30264,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਇ ਸੁਖ ਸਬਾਇਆ ॥੪॥",
          "roman": "nānak nām dhiāe sukh sabāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, созерцай Имя: через него обретаются все радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2679,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30265,
          "is_rahao": false,
          "gurmukhi": "ਛੰਤੁ ॥",
          "roman": "chhant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чхант."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30266,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਮਨੁ ਛੂਟਿ ਗਇਆ ਸਾਧੂ ਸੰਗਿ ਮਿਲੇ ॥",
          "roman": "ab man chhūṭ gaiā sādhū saṅg mile",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь, встретившись с Гуру в его сангате, мой ум освободился от привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30267,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਲਇਆ ਜੋਤੀ ਜੋਤਿ ਰਲੇ ॥",
          "roman": "gurmukh nām laiā jotī jot ralē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто, придя к прибежищу Гуру, поминали Имя, пребывают душой слитыми со Светом Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30268,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਸਿਮਰਤ ਮਿਟੇ ਕਿਲਬਿਖ ਬੁਝੀ ਤਪਤਿ ਅਘਾਨਿਆ ॥",
          "roman": "har nām simrat miṭe kilbikh bujhī tapat aghāniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При памятовании Имени Хари стираются грехи, угасает жар пороков, и ум насыщается, отвращаясь от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30269,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿ ਭੁਜਾ ਲੀਨੇ ਦਇਆ ਕੀਨੇ ਆਪਨੇ ਕਰਿ ਮਾਨਿਆ ॥",
          "roman": "gah bhujā līne daiā kīne āpne kar māniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Господь берет за руку, являя милость, тех Он признает Своими и дарует им почет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30270,
          "is_rahao": false,
          "gurmukhi": "ਲੈ ਅੰਕਿ ਲਾਏ ਹਰਿ ਮਿਲਾਏ ਜਨਮ ਮਰਣਾ ਦੁਖ ਜਲੇ ॥",
          "roman": "lē aṅk lāe har milāe janam marṇā dukh jalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Хари принимает к Своим стопам и соединяет с Собой, у тех сгорают все страдания рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30271,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਵੰਤਿ ਨਾਨਕ ਦਇਆ ਧਾਰੀ ਮੇਲਿ ਲੀਨੇ ਇਕ ਪਲੇ ॥੪॥੨॥",
          "roman": "binvant nānak daiā dhārī mel līne ik pale",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молит: оказав милость, Он соединяет с Собой в одно мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2680,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30272,
          "is_rahao": false,
          "gurmukhi": "ਜੈਤਸਰੀ ਛੰਤ ਮਃ ੫ ॥",
          "roman": "jētsarī chhant mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Джайтсари, чхант, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30273,
          "is_rahao": false,
          "gurmukhi": "ਪਾਧਾਣੂ ਸੰਸਾਰੁ ਗਾਰਬਿ ਅਟਿਆ ॥",
          "roman": "pādhāṇū sansār gārab aṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мир — путник, но он весь измазан гордыней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30274,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤੇ ਪਾਪ ਅਨੇਕ ਮਾਇਆ ਰੰਗ ਰਟਿਆ ॥",
          "roman": "karte pāp anek māiā raṅg raṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Опьяненные играми майи, существа совершают множество грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30275,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭਿ ਮੋਹਿ ਅਭਿਮਾਨਿ ਬੂਡੇ ਮਰਣੁ ਚੀਤਿ ਨ ਆਵਏ ॥",
          "roman": "lobh moh abhimān būḍe maraṇ chīt na āvayē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они тонут в алчности, привязанности и гордыне; смерть даже не приходит им на ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30276,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤ੍ਰ ਮਿਤ੍ਰ ਬਿਉਹਾਰ ਬਨਿਤਾ ਏਹ ਕਰਤ ਬਿਹਾਵਏ ॥",
          "roman": "putr mitr biuhār banitā eh karat bihāvayē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Занятые связями с сыновьями, друзьями и женой, они так и проводят жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30277,
          "is_rahao": false,
          "gurmukhi": "ਪੁਜਿ ਦਿਵਸ ਆਏ ਲਿਖੇ ਮਾਏ ਦੁਖੁ ਧਰਮ ਦੂਤਹ ਡਿਠਿਆ ॥",
          "roman": "puj divas āe likhe māe dukh dharam dūtah ḍiṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мать, когда исчерпываются записанные дни жизни, вид посланцев Дхарамраджа приносит сильное страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30278,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਤ ਕਰਮ ਨ ਮਿਟੈ ਨਾਨਕ ਹਰਿ ਨਾਮ ਧਨੁ ਨਹੀ ਖਟਿਆ ॥੧॥",
          "roman": "kirat karam na miṭe nānak har nām dhan nahī khaṭiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если человек не заработал богатство Имени Хари, счет совершенных дел не стирается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30279,
          "is_rahao": false,
          "gurmukhi": "ਉਦਮ ਕਰਹਿ ਅਨੇਕ ਹਰਿ ਨਾਮੁ ਨ ਗਾਵਹੀ ॥",
          "roman": "udam kareh anek har nām na gāvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди предпринимают множество других усилий, но Имя Хари не воспевают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30280,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਹਿ ਜੋਨਿ ਅਸੰਖ ਮਰਿ ਜਨਮਹਿ ਆਵਹੀ ॥",
          "roman": "bhrameh jon asaṅkh mar janmeh āvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они блуждают в бесчисленных лонах; умирая духовной смертью, снова рождаются и приходят в мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30281,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਪੰਖੀ ਸੈਲ ਤਰਵਰ ਗਣਤ ਕਛੂ ਨ ਆਵਏ ॥",
          "roman": "pasū paṅkhī sēl tarvar gaṇat kachhū na āvayē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они попадают в состояния животных, птиц, камней и деревьев — этим состояниям нет счета."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30282,
          "is_rahao": false,
          "gurmukhi": "ਬੀਜੁ ਬੋਵਸਿ ਭੋਗ ਭੋਗਹਿ ਕੀਆ ਅਪਣਾ ਪਾਵਏ ॥",
          "roman": "bīj bovas bhog bhogeh kīā āpṇā pāvayē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что посеешь, то и пожнешь; человек получает плод собственных поступков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30283,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨ ਜਨਮੁ ਹਾਰੰਤ ਜੂਐ ਪ੍ਰਭੂ ਆਪਿ ਨ ਭਾਵਹੀ ॥",
          "roman": "ratan janam hārant jūai prabhū āp na bhāvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто проигрывает драгоценное человеческое рождение в азартной игре майи, не нравятся Самому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30284,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਵੰਤਿ ਨਾਨਕ ਭਰਮਹਿ ਭ੍ਰਮਾਏ ਖਿਨੁ ਏਕੁ ਟਿਕਣੁ ਨ ਪਾਵਹੀ ॥੨॥",
          "roman": "binvant nānak bhrameh bhramāe khin ek ṭikaṇ na pāvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молит: сбитые майей с пути, они блуждают и ни на миг не находят покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30285,
          "is_rahao": false,
          "gurmukhi": "ਜੋਬਨੁ ਗਇਆ ਬਿਤੀਤਿ ਜਰੁ ਮਲਿ ਬੈਠੀਆ ॥",
          "roman": "joban gēā bitīt jar mal bēṭhīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Юность в конце концов проходит, и старость прочно садится на ее место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30286,
          "is_rahao": false,
          "gurmukhi": "ਕਰ ਕੰਪਹਿ ਸਿਰੁ ਡੋਲ ਨੈਣ ਨ ਡੀਠਿਆ ॥",
          "roman": "kar kampeh sir ḍol nēṇ na ḍīṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Руки начинают дрожать, голова качается, и глаза уже ничего не видят."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30287,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਨੈਣ ਦੀਸੈ ਬਿਨੁ ਭਜਨ ਈਸੈ ਛੋਡਿ ਮਾਇਆ ਚਾਲਿਆ ॥",
          "roman": "nah nēṇ dīsē bin bhajan īsē chhoḍ māiā chāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Глаза ничего не видят; лишенный бхаджана Господа, человек в конце концов уходит, оставив майю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30288,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿਆ ਨ ਮਾਨਹਿ ਸਿਰਿ ਖਾਕੁ ਛਾਨਹਿ ਜਿਨ ਸੰਗਿ ਮਨੁ ਤਨੁ ਜਾਲਿਆ ॥",
          "roman": "kahiā na māneh sir khāk chhāneh jin saṅg man tan jāliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, ради кого его ум и тело сгорали в огне жажды, не слушают его слов и словно посыпают голову пеплом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30289,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰੀਰਾਮ ਰੰਗ ਅਪਾਰ ਪੂਰਨ ਨਹ ਨਿਮਖ ਮਨ ਮਹਿ ਵੂਠਿਆ ॥",
          "roman": "śrī rām raṅg apār pūran nah nimakh man meh vūṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Любовь к Шри Раму, бесконечному и всепроникающему, ни на мгновение не поселилась в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30290,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਵੰਤਿ ਨਾਨਕ ਕੋਟਿ ਕਾਗਰ ਬਿਨਸ ਬਾਰ ਨ ਝੂਠਿਆ ॥੩॥",
          "roman": "binvant nānak koṭ kāgar binas bār na jhūṭhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молит: это тленное тело уничтожается без промедления, как вмиг сгорают кроры листов бумаги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30291,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਰਣਾਇ ਨਾਨਕੁ ਆਇਆ ॥",
          "roman": "charan kamal sarṇāe nānak āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак пришел к прибежищу лотосных стоп Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30292,
          "is_rahao": false,
          "gurmukhi": "ਦੁਤਰੁ ਭੈ ਸੰਸਾਰੁ ਪ੍ਰਭਿ ਆਪਿ ਤਰਾਇਆ ॥",
          "roman": "dutar bhē sansār prabh āp tarāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через этот полный страхов мир, который трудно перейти, Господь Сам переправил его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30293,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਾਧਸੰਗੇ ਭਜੇ ਸ੍ਰੀਧਰ ਕਰਿ ਅੰਗੁ ਪ੍ਰਭ ਜੀ ਤਾਰਿਆ ॥",
          "roman": "mil sādhsange bhaje śrīdhar kar aṅg prabh jī tāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встретившись в Садхсангате, те, кто воспевал Шридхара, были спасены: Господь принял их сторону."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30294,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਮਾਨਿ ਲੀਏ ਨਾਮ ਦੀਏ ਅਵਰੁ ਕਛੁ ਨ ਬੀਚਾਰਿਆ ॥",
          "roman": "har mān līe nām dīe avar kachh na bīchāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хари признал их, дал им Имя и ничего иного — их достоинств или недостатков — не рассматривал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30295,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਨਿਧਾਨ ਅਪਾਰ ਠਾਕੁਰ ਮਨਿ ਲੋੜੀਦਾ ਪਾਇਆ ॥",
          "roman": "guṇ nidhān apār ṭhākur man loṛīdā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они нашли в уме желанного безмерного Владыку, сокровищницу качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30296,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਵੰਤਿ ਨਾਨਕੁ ਸਦਾ ਤ੍ਰਿਪਤੇ ਹਰਿ ਨਾਮੁ ਭੋਜਨੁ ਖਾਇਆ ॥੪॥੨॥੩॥",
          "roman": "binvant nānak sadā tripte har nām bhojan khāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак молит: те, кто вкусил пищу Имени Хари, навсегда насытились."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2681,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30297,
          "is_rahao": false,
          "gurmukhi": "ਜੈਤਸਰੀ ਮਹਲਾ ੫ ਵਾਰ ਸਲੋਕਾ ਨਾਲਿ",
          "roman": "jētsarī mahallā 5 vār salokā nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Джайтсари, Махала 5, вар со шлоками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30298,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oaṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар, по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30299,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30300,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੂਰਨ ਮਧਿ ਪੂਰਨ ਅੰਤਿ ਪੂਰਨ ਪਰਮੇਸੁਰਹ ॥",
          "roman": "ād pūran madh pūran ant pūran parmēsrah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пармешвар присутствует в начале, присутствует в середине и присутствует в конце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30301,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰੰਤਿ ਸੰਤ ਸਰਬਤ੍ਰ ਰਮਣੰ ਨਾਨਕ ਅਘਨਾਸਨ ਜਗਦੀਸੁਰਹ ॥੧॥",
          "roman": "simrant sant sarbatr ramaṇaṅ nānak aghnāsan jagdīsrah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые поминают вездесущего Господа; о Нанак, Владыка мира уничтожает все грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
