{
  "ang": 709,
  "shabads": [
    {
      "shabad_id": 2706,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30441,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਪਵਿਤ੍ਰ ਸਰੀਰੁ ਚਰਨਾ ਧੂਰੀਐ ॥",
          "roman": "hoi pavitr sarīr charnā dhūrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело становится чистым от пыли стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30442,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਰਦੇਵ ਸਦਾ ਹਜੂਰੀਐ ॥੧੩॥",
          "roman": "pārbraham gurdev sadā hajūrīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Парабрахм-Гурдев всегда пребывает рядом, в Своём присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2707,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30443,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30444,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਉਚਰੰਤਿ ਨਾਮੰ ਸ੍ਰਵਣੰ ਸੁਨੰਤਿ ਸਬਦ ਅੰਮ੍ਰਿਤਹ ॥",
          "roman": "rasnā ucharant nāmaṅ sravaṇaṅ sunant śabad amritah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они языком произносят Имя Парабрахма и ушами слушают амритное Слово — святую Бани хвалы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30445,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਸਦ ਬਲਿਹਾਰੰ ਜਿਨਾ ਧਿਆਨੁ ਪਾਰਬ੍ਰਹਮਣਹ ॥੧॥",
          "roman": "nānak tin sad balihāraṅ jinā dhiān pārbrahmaṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я всегда жертвую собой ради тех людей, кто держит внимание на Парабрахме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30446,
          "is_rahao": false,
          "gurmukhi": "ਹਭਿ ਕੂੜਾਵੇ ਕੰਮ ਇਕਸੁ ਸਾਈ ਬਾਹਰੇ ॥",
          "roman": "habh kūṛāvē kamm ikas sāī bāhrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вне памяти единого Хозяина-Прабху все дела ложны, напрасны и бесплодны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30447,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੇਈ ਧੰਨੁ ਜਿਨਾ ਪਿਰਹੜੀ ਸਚ ਸਿਉ ॥੨॥",
          "roman": "nānak seī dhan jinā pirhaṛī sach siu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только те люди благословенны, у кого есть любовь к вечно пребывающему Истинному Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2708,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30448,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30449,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਬਲਿਹਾਰੀ ਤਿਨਾ ਜਿ ਸੁਨਤੇ ਹਰਿ ਕਥਾ ॥",
          "roman": "sad balihārī tinā j suntē har kathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я всегда жертвую собой ради тех, кто слушает рассказы о Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30450,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਤੇ ਪਰਧਾਨ ਨਿਵਾਵਹਿ ਪ੍ਰਭ ਮਥਾ ॥",
          "roman": "pūrē tē pardhān nivāvah prabh mathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто склоняет голову перед Прабху, полны добродетелей и являются лучшими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30451,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਸੁ ਲਿਖਹਿ ਬੇਅੰਤ ਸੋਹਹਿ ਸੇ ਹਥਾ ॥",
          "roman": "har jas likhah beant sohahe sē hathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прекрасны те руки, которые пишут хвалу бесконечного Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30452,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਪੁਨੀਤ ਪਵਿਤ੍ਰ ਚਾਲਹਿ ਪ੍ਰਭ ਪਥਾ ॥",
          "roman": "charaṇ punīt pavitr chālah prabh pathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чисты и святы те ноги, которые идут путём Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30453,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਾਂ ਸੰਗਿ ਉਧਾਰੁ ਸਗਲਾ ਦੁਖੁ ਲਥਾ ॥੧੪॥",
          "roman": "santāṅ sang udhār saglā dukh lathā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе таких святых приходит спасение от страданий и пороков, и вся боль уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2709,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30454,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30455,
          "is_rahao": false,
          "gurmukhi": "ਭਾਵੀ ਉਦੋਤ ਕਰਣੰ ਹਰਿ ਰਮਣੰ ਸੰਜੋਗ ਪੂਰਨਹ ॥",
          "roman": "bhāvī udot karaṇaṅ har ramaṇaṅ sañjog pūraṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда раскрываются предначертанные судьбой записи и по полному счастливому стечению обстоятельств человек вспоминает Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30456,
          "is_rahao": false,
          "gurmukhi": "ਗੋਪਾਲ ਦਰਸ ਭੇਟੰ ਸਫਲ ਨਾਨਕ ਸੋ ਮਹੂਰਤਹ ॥੧॥",
          "roman": "gopāl daras bheṭaṅ safal nānak so mahūratah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, та благодатная минута плодотворна, когда приходит даршан Гопала, Хранителя мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30457,
          "is_rahao": false,
          "gurmukhi": "ਕੀਮ ਨ ਸਕਾ ਪਾਇ ਸੁਖ ਮਿਤੀ ਹੂ ਬਾਹਰੇ ॥",
          "roman": "kīm na sakā pāe sukh mitī hū bāhrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я не могу определить цену тех радостей, они за пределами всякой меры и счёта."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30458,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾ ਵੇਲੜੀ ਪਰਵਾਣੁ ਜਿਤੁ ਮਿਲੰਦੜੋ ਮਾ ਪਿਰੀ ॥੨॥",
          "roman": "nānak sā velaṛī parvāṇ jit milandṛo mā pirī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только та прекрасная минута становится принятой, в которую встречается мой возлюбленный Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2710,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30459,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30460,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਵੇਲਾ ਕਹੁ ਕਉਣੁ ਹੈ ਜਿਤੁ ਪ੍ਰਭ ਕਉ ਪਾਈ ॥",
          "roman": "sā vēlā kaho kauṇ hē jit prabh kau pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Да придёт скорее тот час, когда я обрету Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30461,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮੂਰਤੁ ਭਲਾ ਸੰਜੋਗੁ ਹੈ ਜਿਤੁ ਮਿਲੈ ਗੁਸਾਈ ॥",
          "roman": "so mūrat bhalā sañjog hē jit milē gusāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та минута и тот час встречи благословенны, когда встречается Господин земли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30462,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਧਿਆਇ ਕੈ ਮਨ ਇਛ ਪੁਜਾਈ ॥",
          "roman": "āṭh pahar har dhiāe kē man ichh pujāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милостью Прабху я восемь пaharов вспоминаю Хари и исполняю желание своего ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30463,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਸਤਸੰਗੁ ਹੋਇ ਨਿਵਿ ਲਾਗਾ ਪਾਈ ॥",
          "roman": "vaḍē bhāg satsang hoe niv lāgā pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По великой удаче пусть мне достанется Сатсанг, и я, склоняясь, припаду к стопам его участников."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30464,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਦਰਸਨ ਕੀ ਪਿਆਸ ਹੈ ਨਾਨਕ ਬਲਿ ਜਾਈ ॥੧੫॥",
          "roman": "man darśan kī piās hē nānak bal jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В моём уме есть жажда даршана Прабху; о Нанак, я жертвую собой ради святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2711,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30465,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30466,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪੁਨੀਤ ਗੋਬਿੰਦਹ ਸਰਬ ਦੋਖ ਨਿਵਾਰਣਹ ॥",
          "roman": "patit punīt gobindah sarab dokh nivāraṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гобинд очищает падших в пороки и устраняет все недостатки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30467,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਸੂਰ ਭਗਵਾਨਹ ਜਪੰਤਿ ਨਾਨਕ ਹਰਿ ਹਰਿ ਹਰੇ ॥੧॥",
          "roman": "saraṇ sūr bhagvānah japant nānak har har harē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, для тех, кто повторяет Хари, Хари, Харе, Бхагаван могущественно защищает пришедших в Его убежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30468,
          "is_rahao": false,
          "gurmukhi": "ਛਡਿਓ ਹਭੁ ਆਪੁ ਲਗੜੋ ਚਰਣਾ ਪਾਸਿ ॥",
          "roman": "chhaḍio habh āp lagṛo charṇā pās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек оставил всё самоощущение и эго и прилепился к стопам Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30469,
          "is_rahao": false,
          "gurmukhi": "ਨਠੜੋ ਦੁਖ ਤਾਪੁ ਨਾਨਕ ਪ੍ਰਭੁ ਪੇਖੰਦਿਆ ॥੨॥",
          "roman": "naṭhṛo dukh tāp nānak prabh pekhandiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, при видении Прабху все его страдания и муки исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2712,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30470,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30471,
          "is_rahao": false,
          "gurmukhi": "ਮੇਲਿ ਲੈਹੁ ਦਇਆਲ ਢਹਿ ਪਏ ਦੁਆਰਿਆ ॥",
          "roman": "mēl lēh dēāl ḍhah pae duāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый, я пал у Твоих дверей; соедини меня со Своими стопами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30472,
          "is_rahao": false,
          "gurmukhi": "ਰਖਿ ਲੇਵਹੁ ਦੀਨ ਦਇਆਲ ਭ੍ਰਮਤ ਬਹੁ ਹਾਰਿਆ ॥",
          "roman": "rakh levah dīn daiāl bhramat bah hāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый к бедным, сохрани меня; я очень устал, блуждая и блуждая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30473,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਵਛਲੁ ਤੇਰਾ ਬਿਰਦੁ ਹਰਿ ਪਤਿਤ ਉਧਾਰਿਆ ॥",
          "roman": "bhagat vachhal terā birad har patit udhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Хари, любить бхагти и спасать падших — это Твой изначальный обычай."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30474,
          "is_rahao": false,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਨਾਹੀ ਕੋਇ ਬਿਨਉ ਮੋਹਿ ਸਾਰਿਆ ॥",
          "roman": "tujh bin nāhī koe binau moh sāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя нет никого, кто мог бы довести мою просьбу до исполнения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30475,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਗਹਿ ਲੇਹੁ ਦਇਆਲ ਸਾਗਰ ਸੰਸਾਰਿਆ ॥੧੬॥",
          "roman": "kar gah leh daiāl sāgar sansāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый, возьми меня за руку и спаси из океана мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2713,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30476,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30477,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਉਧਰਣ ਦਇਆਲੰ ਆਸਰੰ ਗੋਪਾਲ ਕੀਰਤਨਹ ॥",
          "roman": "sant udharaṇ daiālaṅ āsaraṅ gopāl kīrtanah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милостивый Прабху спасает тех святых, кто сделал киртан Гопала опорой своей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30478,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲੰ ਸੰਤ ਸੰਗੇਣ ਓਟ ਨਾਨਕ ਪਰਮੇਸੁਰਹ ॥੧॥",
          "roman": "nirmalaṅ sant saṅgeṇ oṭ nānak parmesurah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В обществе таких святых человек становится чистым; о Нанак, держись за покровительство Пармешвара."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30479,
          "is_rahao": false,
          "gurmukhi": "ਚੰਦਨ ਚੰਦੁ ਨ ਸਰਦ ਰੁਤਿ ਮੂਲਿ ਨ ਮਿਟਈ ਘਾਂਮ ॥",
          "roman": "chandan chand na sarad rut mūl na miṭaī ghāṅm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ни сандал, ни луна, ни холодное время года вовсе не устраняют жар ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30480,
          "is_rahao": false,
          "gurmukhi": "ਸੀਤਲੁ ਥੀਵੈ ਨਾਨਕਾ ਜਪੰਦੜੋ ਹਰਿ ਨਾਮੁ ॥੨॥",
          "roman": "sītal thīvē nānakā japandṛo har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, только повторяя Имя Хари, ум человека становится прохладным и спокойным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2714,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30481,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30482,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਕੀ ਓਟ ਉਧਰੇ ਸਗਲ ਜਨ ॥",
          "roman": "charaṇ kamal kī oṭ udharē sagal jan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Опираясь на прекрасные лотосные стопы Прабху, все существа спасаются от жара мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30483,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਪਰਤਾਪੁ ਗੋਵਿੰਦ ਨਿਰਭਉ ਭਏ ਮਨ ॥",
          "roman": "suṇ partāp govind nirbhau bhae man",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слушая славу Говинда, у преданных умы становятся бесстрашными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30484,
          "is_rahao": false,
          "gurmukhi": "ਤੋਟਿ ਨ ਆਵੈ ਮੂਲਿ ਸੰਚਿਆ ਨਾਮੁ ਧਨ ॥",
          "roman": "toṭ na āvē mūl sañchiā nām dhan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они накапливают богатство Имени Прабху, и в этом богатстве никогда не бывает недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30485,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਜਨਾ ਸਿਉ ਸੰਗੁ ਪਾਈਐ ਵਡੈ ਪੁਨ ॥",
          "roman": "sant janā siu sang pāīē vaḍē pun",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Общество таких гурмукхов и святых людей обретается по великой удаче."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30486,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਧਿਆਇ ਹਰਿ ਜਸੁ ਨਿਤ ਸੁਨ ॥੧੭॥",
          "roman": "āṭh pahar har dhiāe har jas nit sun",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти святые восемь пaharов вспоминают Хари и всегда слушают славу Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2715,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 30487,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30488,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਕਰਣੰ ਦੁਖ ਹਰਣੰ ਉਚਰਣੰ ਨਾਮ ਕੀਰਤਨਹ ॥",
          "roman": "daiā karaṇaṅ dukh haraṇaṅ ucharaṇaṅ nām kīrtanah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек произносит киртан Имени милостивого всепроникающего Бхагавана, Прабху проявляет милость и уничтожает его страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 30489,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆਲ ਪੁਰਖ ਭਗਵਾਨਹ ਨਾਨਕ ਲਿਪਤ ਨ ਮਾਇਆ ॥੧॥",
          "roman": "daiāl purakh bhagvānah nānak lipat na māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой человек не запутывается в привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
