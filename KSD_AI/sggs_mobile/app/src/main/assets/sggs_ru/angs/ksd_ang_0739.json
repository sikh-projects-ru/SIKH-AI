{
  "ang": 739,
  "shabads": [
    {
      "shabad_id": 2814,
      "rahao_verse_id": 31557,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31555,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਸਾਧਸੰਗੁ ਦੀਜੈ ॥੪॥",
          "roman": "kar kirpā moh sādhsaṅg dījē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਕਰ ਕੇ ਮੈਨੂੰ ਗੁਰਮੁਖਾਂ ਦੀ ਸੰਗਤਿ ਬਖ਼ਸ਼ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "По милости даруй мне общество гурсикхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31556,
          "is_rahao": true,
          "gurmukhi": "ਤਉ ਕਿਛੁ ਪਾਈਐ ਜਉ ਹੋਈਐ ਰੇਨਾ ॥",
          "roman": "tau kichh pāīai jau hoīai renā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਾਧ ਸੰਗਤਿ ਵਿਚੋਂ ਭੀ) ਤਦੋਂ ਹੀ ਕੁਝ ਹਾਸਲ ਕਰ ਸਕੀਦਾ ਹੈ, ਜਦੋਂ ਗੁਰਮੁਖਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣ ਜਾਈਏ।"
            },
            "sahib_singh_ru": {
              "main": "Только став пылью у их стоп, можно что-то обрести."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31557,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸਹਿ ਬੁਝਾਏ ਤਿਸੁ ਨਾਮੁ ਲੈਨਾ ॥੧॥ ਰਹਾਉ ॥੨॥੮॥",
          "roman": "jisah bujhāe tis nām lēnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ (ਚਰਨ-ਧੂੜ ਹੋਣ ਦੀ) ਸੂਝ ਬਖ਼ਸ਼ਦਾ ਹੈ, ਓਹ (ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਟਿਕ ਕੇ ਓਸ ਦਾ) ਨਾਮ ਸਿਮਰਦਾ ਹੈ।੧।ਰਹਾਉ ॥੧॥ ਰਹਾਉ ॥੨॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Кому Господь даёт понимание, тот пребывает в Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2815,
      "rahao_verse_id": 31562,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31558,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31559,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਮਹਿ ਠਾਕੁਰੁ ਨਦਰਿ ਨ ਆਵੈ ॥",
          "roman": "ghar meh ṭhākur nadar na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਕਤ ਨੂੰ ਆਪਣੇ) ਹਿਰਦੇ-ਘਰ ਵਿਚ ਮਾਲਕ-ਪ੍ਰਭੂ (ਵੱਸਦਾ) ਨਹੀਂ ਦਿੱਸਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "(сакат) в своём сердце-доме не видит пребывающего Господа-Владыку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31560,
          "is_rahao": false,
          "gurmukhi": "ਗਲ ਮਹਿ ਪਾਹਣੁ ਲੈ ਲਟਕਾਵੈ ॥੧॥",
          "roman": "gal meh pāhaṇ lē laṭkāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੱਥਰ (ਦੀ ਮੂਰਤੀ) ਲੈ ਕੇ ਆਪਣੇ ਗਲ ਵਿਚ ਲਟਕਾਈ ਫਿਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "берёт камень (идола) и носит его, повесив на шею."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31561,
          "is_rahao": true,
          "gurmukhi": "ਭਰਮੇ ਭੂਲਾ ਸਾਕਤੁ ਫਿਰਤਾ ॥",
          "roman": "bharme bhūlā sākat firta",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਟੁੱਟਾ ਹੋਇਆ ਮਨੁੱਖ ਭਟਕਣਾ ਵਿਚ ਪੈ ਕੇ ਕੁਰਾਹੇ ਤੁਰਿਆ ਫਿਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! оторванный от Бога человек, заблудившись, блуждает по ложному пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31562,
          "is_rahao": true,
          "gurmukhi": "ਨੀਰੁ ਬਿਰੋਲੈ ਖਪਿ ਖਪਿ ਮਰਤਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nīr birolē khap khap marta",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੂਰਤੀ ਪੂਜਾ ਕਰ ਕੇ) ਪਾਣੀ (ਹੀ) ਰਿੜਕਦਾ ਹੈ, ਇਹ ਵਿਅਰਥ ਮੇਹਨਤ ਕਰ ਕੇ ਆਤਮਕ ਮੌਤ ਸਹੇੜਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(поклоняясь идолу) он лишь взбалтывает воду, и, напрасно трудясь, обрекает себя на духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31563,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪਾਹਣ ਕਉ ਠਾਕੁਰੁ ਕਹਤਾ ॥",
          "roman": "jis pāhaṇ kau ṭhākur kahtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਾਕਤ ਮਨੁੱਖ ਜਿਸ ਪੱਥਰ ਨੂੰ ਪਰਮਾਤਮਾ ਆਖਦਾ (ਸਮਝਦਾ) ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! тот камень, которого человек-сакат называет Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31564,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਪਾਹਣੁ ਲੈ ਉਸ ਕਉ ਡੁਬਤਾ ॥੨॥",
          "roman": "oh pāhaṇ lē us kau ḍubtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪੱਥਰ (ਆਪਣੇ) ਉਸ (ਪੁਜਾਰੀ) ਨੂੰ ਭੀ ਲੈ ਕੇ (ਪਾਣੀ ਵਿਚ) ਡੁੱਬ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот камень и его самого уводит ко дну (в воде)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31565,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨਹਗਾਰ ਲੂਣ ਹਰਾਮੀ ॥",
          "roman": "gunahgār lūṇ harāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਪੀ! ਹੇ ਅਕਿਰਤਘਣ!"
            },
            "sahib_singh_ru": {
              "main": "О грешник! О неблагодарный!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31566,
          "is_rahao": false,
          "gurmukhi": "ਪਾਹਣ ਨਾਵ ਨ ਪਾਰਗਿਰਾਮੀ ॥੩॥",
          "roman": "pāhaṇ nāv na pār girāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੱਥਰ ਦੀ ਬੇੜੀ (ਨਦੀ ਤੋਂ) ਪਾਰ ਨਹੀਂ ਲੰਘ ਸਕਦੀ (ਪੱਥਰ ਦੀ ਮੂਰਤੀ ਦੀ ਪੂਜਾ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਨਹੀਂ ਲੰਘਾ ਸਕਦੀ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "каменная лодка не может переправить (через реку) (так и поклонение идолу не может переправить через океан мира)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31567,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਨਾਨਕ ਠਾਕੁਰੁ ਜਾਤਾ ॥",
          "roman": "gur mil nānak ṭhākur jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਪਾਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! тот, кто, встретив Гуру, познал Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31568,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਪੂਰਨ ਬਿਧਾਤਾ ॥੪॥੩॥੯॥",
          "roman": "jal thal mahīal pūran bidhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਉਹ ਕਰਤਾਰ ਪਾਣੀ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ ਹਰ ਥਾਂ ਵੱਸਦਾ ਦਿੱਸਦਾ ਹੈ ॥੪॥੩॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "видит Творца пребывающим в воде, на земле и в небе, повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2816,
      "rahao_verse_id": 31572,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31569,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31570,
          "is_rahao": false,
          "gurmukhi": "ਲਾਲਨੁ ਰਾਵਿਆ ਕਵਨ ਗਤੀ ਰੀ ॥",
          "roman": "lālan rāviā kavan gatī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਤੂੰ ਕਿਸ ਤਰੀਕੇ ਨਾਲ ਸੋਹਣੇ ਲਾਲ ਦਾ ਮਿਲਾਪ ਪ੍ਰਾਪਤ ਕੀਤਾ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "О подруга! каким образом ты достигла соединения с прекрасным Возлюбленным?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31571,
          "is_rahao": false,
          "gurmukhi": "ਸਖੀ ਬਤਾਵਹੁ ਮੁਝਹਿ ਮਤੀ ਰੀ ॥੧॥",
          "roman": "sakhī batāvah mujhahi matī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਮੈਨੂੰ ਭੀ ਉਹ ਅਕਲ ਦੱਸ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О подруга! скажи и мне эту мудрость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31572,
          "is_rahao": true,
          "gurmukhi": "ਸੂਹਬ ਸੂਹਬ ਸੂਹਵੀ ॥ ਅਪਨੇ ਪ੍ਰੀਤਮ ਕੈ ਰੰਗਿ ਰਤੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sūhab sūhab sūhavī apne prītam kē raṅg ratī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਤੇਰੇ ਮੂੰਹ ਉਤੇ ਲਾਲੀ ਭਖ ਰਹੀ ਹੈ, ਤੂੰ ਆਪਣੇ ਪਿਆਰੇ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗੀ ਹੋਈ ਹੈਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О подруга! твоё лицо сияет румянцем, ты окрашена в цвет любви своего Возлюбленного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31573,
          "is_rahao": false,
          "gurmukhi": "ਪਾਵ ਮਲੋਵਉ ਸੰਗਿ ਨੈਨ ਭਤੀਰੀ ॥",
          "roman": "pāv malovau saṅg nēn bhatīrī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! (ਮੈਨੂੰ ਭੀ ਦੱਸ) ਮੈਂ ਤੇਰੇ ਪੈਰ ਆਪਣੀਆਂ ਅੱਖਾਂ ਦੀਆਂ ਪੁਤਲੀਆਂ ਨਾਲ ਮਲਾਂਗੀ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! (скажи мне тоже) я буду растирать твои стопы зрачками своих глаз,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31574,
          "is_rahao": false,
          "gurmukhi": "ਜਹਾ ਪਠਾਵਹੁ ਜਾਂਉ ਤਤੀ ਰੀ ॥੨॥",
          "roman": "jahā paṭhāvah jāu tatī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੈਨੂੰ ਜਿਥੇ ਭੀ (ਕਿਸੇ ਕੰਮ) ਭੇਜੇਂਗੀ ਮੈਂ ਉਥੇ ਹੀ (ਖ਼ੁਸ਼ੀ ਨਾਲ) ਜਾਵਾਂਗੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "куда бы ты ни послала меня, я с радостью пойду туда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31575,
          "is_rahao": false,
          "gurmukhi": "ਜਪ ਤਪ ਸੰਜਮ ਦੇਉ ਜਤੀ ਰੀ ॥",
          "roman": "jap tap sanjam deu jatī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਖੀ! ਮੈਂ ਉਸ ਦੇ ਇਵਜ਼ ਵਿਚ ਸਾਰੇ ਜਪ ਤਪ ਸੰਜਮ ਦੇ ਦਿਆਂਗੀ,"
            },
            "sahib_singh_ru": {
              "main": "О подруга! взамен я отдам все свои практики, аскезы и самообладание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31576,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਨਿਮਖ ਮਿਲਾਵਹੁ ਮੋਹਿ ਪ੍ਰਾਨਪਤੀ ਰੀ ॥੩॥",
          "roman": "ik nimakh milāvah moh prānpati rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੱਖ ਝਮਕਣ ਜਿਤਨੇ ਸਮੇ ਵਾਸਤੇ ਹੀ ਤੂੰ ਮੈਨੂੰ ਜਿੰਦ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਮਿਲਾ ਦੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "соедини меня с Господом моей жизни хотя бы на мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31577,
          "is_rahao": false,
          "gurmukhi": "ਮਾਣੁ ਤਾਣੁ ਅਹੰਬੁਧਿ ਹਤੀ ਰੀ ॥",
          "roman": "māṇ tāṇ ahambudh hatī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਵ-ਇਸਤ੍ਰੀ (ਕਿਸੇ ਭੀ ਆਪਣੇ ਮਿਥੇ ਹੋਏ ਪਦਾਰਥ ਜਾਂ ਉੱਦਮ ਆਦਿਕ ਦਾ) ਮਾਣ ਤੇ ਆਸਰਾ ਛੱਡ ਦੇਂਦੀ ਹੈ, ਹਉਮੈ ਵਾਲੀ ਅਕਲ ਤਿਆਗ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "та душа-женщина, которая оставляет гордость и опору на свои достижения и отбрасывает эгоистический ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31578,
          "is_rahao": false,
          "gurmukhi": "ਸਾ ਨਾਨਕ ਸੋਹਾਗਵਤੀ ਰੀ ॥੪॥੪॥੧੦॥",
          "roman": "sā nānak sohāgvatī rī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਸੁਹਾਗ-ਭਾਗ ਵਾਲੀ ਹੋ ਜਾਂਦੀ ਹੈ ॥੪॥੪॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! становится благословенной невестой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2817,
      "rahao_verse_id": 31583,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31579,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31580,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਜੀਵਨੁ ਤੂੰ ਪ੍ਰਾਨ ਅਧਾਰਾ ॥",
          "roman": "tū jīvan tū prān adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਹੀ ਮੇਰੀ ਜਿੰਦ ਹੈਂ, ਤੂੰ ਹੀ ਮੇਰੀ ਜਿੰਦ ਦਾ ਸਹਾਰਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — моя жизнь, Ты — опора моей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31581,
          "is_rahao": false,
          "gurmukhi": "ਤੁਝ ਹੀ ਪੇਖਿ ਪੇਖਿ ਮਨੁ ਸਾਧਾਰਾ ॥੧॥",
          "roman": "tujh hī pekh pekh man sādhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਹੀ ਵੇਖ ਕੇ ਮੇਰਾ ਮਨ ਧੀਰਜ ਫੜਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "видя Тебя, моё сердце обретает покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31582,
          "is_rahao": true,
          "gurmukhi": "ਤੂੰ ਸਾਜਨੁ ਤੂੰ ਪ੍ਰੀਤਮੁ ਮੇਰਾ ॥",
          "roman": "tū sājan tū prītam merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਹੀ ਮੇਰਾ ਸੱਜਣ ਹੈਂ ਤੂੰ ਹੀ ਮੇਰਾ ਪਿਆਰਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты — мой друг, Ты — мой возлюбленный,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31583,
          "is_rahao": true,
          "gurmukhi": "ਚਿਤਹਿ ਨ ਬਿਸਰਹਿ ਕਾਹੂ ਬੇਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "chitah na bisreh kāhū berā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਹਰ ਕਰ) ਕਿਸੇ ਭੀ ਵੇਲੇ ਮਨ ਤੋਂ ਨਾਹ ਵਿੱਸਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "(прояви милость) не забывайся моим умом ни в какое время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31584,
          "is_rahao": false,
          "gurmukhi": "ਬੈ ਖਰੀਦੁ ਹਉ ਦਾਸਰੋ ਤੇਰਾ ॥",
          "roman": "bē kharīd hau dāsro terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਮੁੱਲ ਖ਼ਰੀਦਿਆ ਹੋਇਆ ਤੇਰਾ ਨਿਮਾਣਾ ਜਿਹਾ ਸੇਵਕ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! я купленный слуга Твой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31585,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਭਾਰੋ ਠਾਕੁਰੁ ਗੁਣੀ ਗਹੇਰਾ ॥੨॥",
          "roman": "tū bhāro ṭhākur guṇī gaherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੇਰਾ ਵੱਡਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ ਭਰਪੂਰ ਹੈਂ, ਤੂੰ ਡੂੰਘੇ ਜਿਗਰੇ ਵਾਲਾ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — мой великий Владыка, полный добродетелей и глубины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31586,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਦਾਸ ਜਾ ਕੈ ਦਰਬਾਰੇ ॥",
          "roman": "koṭ dās jā kē darbāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਪ੍ਰਭੂ ਐਸਾ ਹੈ ਕਿ ਕ੍ਰੋੜਾਂ ਸੇਵਕ ਉਸ ਦੇ ਦਰ ਤੇ (ਡਿੱਗੇ ਰਹਿੰਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! у Него миллионы слуг пребывают у Его двора,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31587,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨਿਮਖ ਵਸੈ ਤਿਨੑ ਨਾਲੇ ॥੩॥",
          "roman": "nimakh nimakh vasē tinh nāle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹਰ ਵੇਲੇ ਉਹਨਾਂ ਦੇ ਨਾਲ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно пребывает с ними."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31588,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਕਿਛੁ ਨਾਹੀ ਸਭੁ ਕਿਛੁ ਤੇਰਾ ॥",
          "roman": "hau kichh nāhī sabh kichh terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਮੇਰੀ ਆਪਣੀ ਪਾਂਇਆਂ ਕੁਝ ਭੀ ਨਹੀਂ, (ਮੇਰੇ ਪਾਸ ਜੋ ਕੁਝ ਭੀ ਹੈ) ਸਭ ਕੁਝ ਤੇਰਾ ਬਖ਼ਸ਼ਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(О Господь!) у меня нет ничего своего, всё, что есть, — Твоё дарование."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31589,
          "is_rahao": false,
          "gurmukhi": "ਓਤਿ ਪੋਤਿ ਨਾਨਕ ਸੰਗਿ ਬਸੇਰਾ ॥੪॥੫॥੧੧॥",
          "roman": "ot pot nānak saṅg baserā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਤਾਣੇ ਪੇਟੇ ਵਾਂਗ ਤੂੰ ਹੀ ਮੇਰੇ ਨਾਲ ਵੱਸਦਾ ਹੈਂ ॥੪॥੫॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Ты пребываешь со мной, словно нити основы и утка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2818,
      "rahao_verse_id": 31594,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31590,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31591,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਮਹਲ ਜਾ ਕੇ ਊਚ ਦੁਆਰੇ ॥",
          "roman": "sūkh mahal jā ke ūch duāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਮਹਲ ਆਨੰਦ-ਭਰਪੂਰ ਹਨ, ਤੇ ਜਿਸ ਦੇ ਦਰਵਾਜ਼ੇ ਉੱਚੇ ਹਨ (ਭਾਵ, ਉਥੇ ਆਤਮਕ ਆਨੰਦ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕਿਸੇ ਵਿਕਾਰ ਆਦਿਕ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! у того Господа дворцы полны блаженства, и врата Его высоки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31592,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਮਹਿ ਵਾਸਹਿ ਭਗਤ ਪਿਆਰੇ ॥੧॥",
          "roman": "tā meh vāsahi bhagat piyāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ) ਵਿਚ ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਪਿਆਰੇ ਭਗਤ (ਹੀ) ਵੱਸਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "в них обитают лишь Его возлюбленные преданные."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31593,
          "is_rahao": true,
          "gurmukhi": "ਸਹਜ ਕਥਾ ਪ੍ਰਭ ਕੀ ਅਤਿ ਮੀਠੀ ॥",
          "roman": "sahaj kathā prabh kī at mīṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਬੜੀ ਹੀ ਸੁਆਦਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! хвала Господу, рождающая внутреннее равновесие, очень сладостна,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31594,
          "is_rahao": true,
          "gurmukhi": "ਵਿਰਲੈ ਕਾਹੂ ਨੇਤ੍ਰਹੁ ਡੀਠੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "virlē kāhū netrah ḍīṭhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਿਸੇ ਵਿਰਲੇ ਹੀ ਮਨੁੱਖ ਨੇ ਉਸ ਨੂੰ ਅੱਖੀਂ ਵੇਖਿਆ ਹੈ (ਮਾਣਿਆ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но лишь редкий человек увидел и испытал её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31595,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਗੀਤ ਨਾਦ ਅਖਾਰੇ ਸੰਗਾ ॥",
          "roman": "tah gīt nād akhāre saṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਆਤਮਕ ਅਡੋਲਤਾ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਉਸ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਵਿਚ (ਮਾਨੋ) ਗੀਤ ਤੇ ਰਾਗ ਹੋ ਰਹੇ ਹੁੰਦੇ ਹਨ (ਉਸ ਵਿਚ, ਮਾਨੋ) ਪਿੜ ਬੱਝੇ ਹੁੰਦੇ ਹਨ (ਜਿੱਥੇ ਕਾਮਾਦਿਕ ਪਹਿਲਵਾਨਾਂ ਨਾਲ ਟਾਕਰਾ ਕਰਨ ਦੀ ਜਾਚ ਸਿੱਖੀਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! в этой хвале словно звучат песни и раги, словно устроены арены (где учатся бороться с пороками)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31596,
          "is_rahao": false,
          "gurmukhi": "ਊਹਾ ਸੰਤ ਕਰਹਿ ਹਰਿ ਰੰਗਾ ॥੨॥",
          "roman": "ūhā sant karahi har raṅgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਵਿਚ ਜੁੜ ਕੇ ਸੰਤ ਜਨ ਪਰਮਾਤਮਾ ਦੇ ਮਿਲਾਪ ਦਾ ਆਨੰਦ ਮਾਣਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "соединяясь с ней, святые наслаждаются союзом с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31597,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਮਰਣੁ ਨ ਜੀਵਣੁ ਸੋਗੁ ਨ ਹਰਖਾ ॥",
          "roman": "tah maraṇ na jīvaṇ sog na harkhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਵਿਚ ਜੁੜਿਆਂ ਜਨਮ ਮਰਨ ਦਾ ਗੇੜ ਨਹੀਂ ਰਹਿੰਦਾ, ਖ਼ੁਸ਼ੀ ਗ਼ਮੀ ਨਹੀਂ ਪੋਹ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! в этом состоянии нет круга рождения и смерти, ни печаль, ни радость не затрагивают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31598,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਨਾਮ ਕੀ ਅੰਮ੍ਰਿਤ ਵਰਖਾ ॥੩॥",
          "roman": "sāch nām kī amrit varkhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਅਵਸਥਾ ਵਿਚ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੇ ਨਾਮ-ਜਲ ਦੀ ਵਰਖਾ ਹੁੰਦੀ ਰਹਿੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в этом состоянии постоянно проливается нектар Имени вечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31599,
          "is_rahao": false,
          "gurmukhi": "ਗੁਹਜ ਕਥਾ ਇਹ ਗੁਰ ਤੇ ਜਾਣੀ ॥",
          "roman": "guhaj kathā ih gur te jāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਬਾਰੇ) ਇਹ ਭੇਤ ਦੀ ਗੱਲ (ਨਾਨਕ ਨੇ) ਗੁਰੂ ਪਾਸੋਂ ਸਮਝੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! эту тайну хвалы Господу Нанак понял от Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31600,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਬੋਲੈ ਹਰਿ ਹਰਿ ਬਾਣੀ ॥੪॥੬॥੧੨॥",
          "roman": "nānak bolē har har bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ) ਨਾਨਕ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੬॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому Нанак произносит речь хвалы Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2819,
      "rahao_verse_id": 31605,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31601,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31602,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਦਰਸਿ ਪਾਪ ਕੋਟਿ ਉਤਾਰੇ ॥",
          "roman": "jā kē daras pāp koṭ utāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਹ ਸੰਤ ਜਨ ਹੀ ਮੇਰੇ ਪਿਆਰੇ ਮਿੱਤਰ ਹਨ) ਜਿਨ੍ਹਾਂ ਦੇ ਦਰਸਨ ਨਾਲ ਕ੍ਰੋੜਾਂ ਪਾਪ ਲਹਿ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! те святые — мои друзья, при виде которых снимаются миллионы грехов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31603,
          "is_rahao": false,
          "gurmukhi": "ਭੇਟਤ ਸੰਗਿ ਇਹੁ ਭਵਜਲੁ ਤਾਰੇ ॥੧॥",
          "roman": "bheṭat saṅg ih bhavjal tāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਦੇ ਚਰਨਾਂ) ਨਾਲ ਛੁਹਿਆਂ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "прикоснувшись к ним, можно переправиться через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31604,
          "is_rahao": true,
          "gurmukhi": "ਓਇ ਸਾਜਨ ਓਇ ਮੀਤ ਪਿਆਰੇ ॥",
          "roman": "oi sājan oi mīt piyāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ (ਸੰਤ ਜਨ ਹੀ) ਮੇਰੇ ਸੱਜਣ ਹਨ, ਉਹ (ਹੀ) ਮੇਰੇ ਪਿਆਰੇ ਮਿੱਤਰ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! они — мои друзья, они — мои дорогие товарищи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31605,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਹਮ ਕਉ ਹਰਿ ਨਾਮੁ ਚਿਤਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo ham kau har nām chitāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੇ ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਚੇਤੇ ਕਰਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "которые напоминают мне Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31606,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਸਬਦੁ ਸੁਨਤ ਸੁਖ ਸਾਰੇ ॥",
          "roman": "jā kā sabad sunat sukh sāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਹੀ ਹਨ ਮੇਰੇ ਮਿੱਤਰ) ਜਿਨ੍ਹਾਂ ਦਾ ਬਚਨ ਸੁਣਦਿਆਂ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! те — мои друзья, чьё слово приносит все радости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31607,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਟਹਲ ਜਮਦੂਤ ਬਿਦਾਰੇ ॥੨॥",
          "roman": "jā kī ṭahal jamdūt bidāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੀ ਟਹਲ ਕੀਤਿਆਂ ਜਮਦੂਤ (ਭੀ) ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "служение которым разрушает даже посланников смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31608,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਧੀਰਕ ਇਸੁ ਮਨਹਿ ਸਧਾਰੇ ॥",
          "roman": "jā kī dhīrak is manah sadhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਹੀ ਹਨ ਮੇਰੇ ਮਿੱਤਰ) ਜਿਨ੍ਹਾਂ ਦੀ (ਦਿੱਤੀ ਹੋਈ) ਧੀਰਜ (ਮੇਰੇ) ਇਸ ਮਨ ਨੂੰ ਸਹਾਰਾ ਦੇਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! те — мои друзья, чьё утешение поддерживает этот мой ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31609,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਣਿ ਮੁਖ ਉਜਲਾਰੇ ॥੩॥",
          "roman": "jā kē simran mukh ujlāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ (ਦੇ ਦਿੱਤੇ ਹੋਏ ਹਰਿ-ਨਾਮ) ਦੇ ਸਿਮਰਨ ਨਾਲ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਮੂੰਹ ਉਜਲਾ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "памятование Имени, данное ими, делает лицо светлым в этом и ином мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31610,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੇ ਸੇਵਕ ਪ੍ਰਭਿ ਆਪਿ ਸਵਾਰੇ ॥",
          "roman": "prabh ke sevak prabh āp savāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਆਪਣੇ ਸੇਵਕਾਂ ਦਾ ਜੀਵਨ ਸੋਹਣਾ ਬਣਾ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Сам Господь сделал жизнь Своих слуг прекрасной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31611,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਨਾਨਕ ਤਿਨੑ ਸਦ ਬਲਿਹਾਰੇ ॥੪॥੭॥੧੩॥",
          "roman": "saraṇ nānak tinh sad balihāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹਨਾਂ ਸੇਵਕਾਂ ਦੀ ਸਰਨ ਪੈਣਾ ਚਾਹੀਦਾ ਹੈ, ਉਹਨਾਂ ਤੋਂ ਸਦਾ ਕੁਰਬਾਨ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ ॥੪॥੭॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! следует искать прибежище у них и всегда жертвовать собой ради них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
