{
  "ang": 743,
  "shabads": [
    {
      "shabad_id": 2834,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31776,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਣ ਗਹੇ ਨਾਨਕ ਸਰਣਾਇ ॥੪॥੨੨॥੨੮॥",
          "roman": "har charaṇ gahe nānak saraṇāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਜਿਸ ਮਨੁੱਖ ਨੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਫੜ ਲਏ, ਜੋ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਆ ਪਿਆ ॥੪॥੨੨॥੨੮॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тот, кто ухватился за стопы Господа и пришёл в Его прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2835,
      "rahao_verse_id": 31781,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31777,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31778,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨੁ ਛਡਾਇ ਦੁਨੀ ਜੋ ਲਾਏ ॥",
          "roman": "dīn chhaḍāe dunī jo lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਨਾਮ-ਧਨ ਵਿਹਾਝਣ ਵਲੋਂ ਹਟਾ ਕੇ ਦੁਨੀਆ ਦੇ ਧਨ ਵਲ ਲਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Кого Бог отвлекает от приобретения имени и направляет к богатству мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31779,
          "is_rahao": false,
          "gurmukhi": "ਦੁਹੀ ਸਰਾਈ ਖੁਨਾਮੀ ਕਹਾਏ ॥੧॥",
          "roman": "duhī sarāī khunāmī kahāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਦੋਹਾਂ ਜਹਾਨਾਂ ਵਿਚ (ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ) ਗੁਨਹਗਾਰ ਅਖਵਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек считается виновным в обоих мирах — в этом и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31780,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਪਰਵਾਣੁ ॥",
          "roman": "jo tis bhāvē so parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ, ਜੀਵਾਂ ਨੂੰ ਉਹੀ ਕੁਝ ਸਿਰ-ਮੱਥੇ ਮੰਨਣਾ ਪੈਂਦਾ ਹੈ (ਉਹੀ ਕੁਝ ਜੀਵ ਕਰਦੇ ਹਨ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Что угодно Богу, то и приходится принимать как истину,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31781,
          "is_rahao": true,
          "gurmukhi": "ਆਪਣੀ ਕੁਦਰਤਿ ਆਪੇ ਜਾਣੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āpaṇī kudrat āpe jāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪਣੀ ਰਚੀ ਸ੍ਰਿਸ਼ਟੀ ਬਾਰੇ ਆਪ ਹੀ ਸਭ ਕੁਝ ਜਾਣਨ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Бог сам знает всё о своём творении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31782,
          "is_rahao": false,
          "gurmukhi": "ਸਚਾ ਧਰਮੁ ਪੁੰਨੁ ਭਲਾ ਕਰਾਏ ॥",
          "roman": "sachā dharam punn bhalā karāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜਿਸ ਮਨੁੱਖ ਪਾਸੋਂ ਪਰਮਾਤਮਾ) ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ (ਨਾਮ-ਸਿਮਰਨ-) ਧਰਮ ਕਰਾਂਦਾ ਹੈ, (ਨਾਮ-ਸਿਮਰਨ ਦਾ) ਨੇਕ ਭਲਾ ਕੰਮ ਕਰਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, через кого Бог совершает истинный вечный धर्म и добрые дела,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31783,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਕੈ ਤੋਸੈ ਦੁਨੀ ਨ ਜਾਏ ॥੨॥",
          "roman": "dīn kē tosē dunī na jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ-ਧਨ ਇਕੱਠਾ ਕਰਦਿਆਂ ਉਸ ਦੀ ਇਹ ਦੁਨੀਆ ਭੀ ਨਹੀਂ ਵਿਗੜਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "собирая богатство имени, не портит и свою мирскую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31784,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਏਕੋ ਜਾਗੈ ॥",
          "roman": "sarab nirantar eko jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜੀਵਾਂ ਦੇ ਕੀਹ ਵੱਸ?) ਹਰੇਕ ਜੀਵ ਉਸੇ ਉਸੇ ਕੰਮ ਵਿਚ ਲੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каждый занят тем делом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31785,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਜਿਤੁ ਲਾਇਆ ਤਿਤੁ ਤਿਤੁ ਕੋ ਲਾਗੈ ॥੩॥",
          "roman": "jit jit lāiā tit tit ko lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਜਿਸ ਕੰਮ ਵਿਚ ਪਰਮਾਤਮਾ ਲਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в которое Бог его направляет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31786,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰੁ ਸਚੁ ਸਾਹਿਬੁ ਮੇਰਾ ॥",
          "roman": "agam agochar sach sāhib merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਮੇਰਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਅਪਹੁੰਚ ਹੈਂ, ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਰਾਹੀਂ ਤੇਰੇ ਤਕ ਪਹੁੰਚਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты мой вечный владыка, непостижимый и недоступный чувствам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31787,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਬੋਲੈ ਬੋਲਾਇਆ ਤੇਰਾ ॥੪॥੨੩॥੨੯॥",
          "roman": "nānak bolē bolāiā terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਦਾਸ) ਨਾਨਕ ਤੇਰਾ ਪ੍ਰੇਰਿਆ ਹੋਇਆ ਹੀ ਤੇਰਾ ਨਾਮ ਉਚਾਰ ਸਕਦਾ ਹੈ ॥੪॥੨੩॥੨੯॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит только по твоему вдохновению и произносит твоё имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2836,
      "rahao_verse_id": 31792,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31788,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31789,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਤਹਕਾਲਿ ਹਰਿ ਨਾਮੁ ਉਚਾਰੀ ॥",
          "roman": "prātahkāl har nām uchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅੰਮ੍ਰਿਤ ਵੇਲੇ (ਉੱਠ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В амрит-вела произноси имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31790,
          "is_rahao": false,
          "gurmukhi": "ਈਤ ਊਤ ਕੀ ਓਟ ਸਵਾਰੀ ॥੧॥",
          "roman": "īt ūt kī oṭ savārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਇਸ ਲੋਕ ਅਤੇ ਪਰਲੋਕ ਵਾਸਤੇ ਸੋਹਣਾ ਆਸਰਾ ਬਣਾਂਦਾ ਰਿਹਾ ਕਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так ты устроишь прекрасную опору для этого и будущего мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31791,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਪੀਐ ਹਰਿ ਨਾਮ ॥",
          "roman": "sadā sadā japīai har nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда следует повторять имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31792,
          "is_rahao": true,
          "gurmukhi": "ਪੂਰਨ ਹੋਵਹਿ ਮਨ ਕੇ ਕਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pūraṇ hovahi man ke kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਮਨ ਦੇ ਚਿਤਵੇ ਹੋਏ ਸਾਰੇ ਕੰਮ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Благодаря स्मरण исполняются все желания ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31793,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਅਬਿਨਾਸੀ ਰੈਣਿ ਦਿਨੁ ਗਾਉ ॥",
          "roman": "prabh abināsī rēṇ din gāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਰਾਤ ਦਿਨ ਅਬਿਨਾਸ਼ੀ ਪ੍ਰਭੂ (ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ) ਗਾਇਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Днём и ночью воспевай бессмертного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31794,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਮਰਤ ਨਿਹਚਲੁ ਪਾਵਹਿ ਥਾਉ ॥੨॥",
          "roman": "jīvat marat nihchal pāvahi thāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਦੁਨੀਆ ਦੀ ਕਾਰ ਕਰਦਾ ਹੋਇਆ ਨਿਰਮੋਹ ਰਹਿ ਕੇ ਤੂੰ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਥਾਂ ਪ੍ਰਾਪਤ ਕਰ ਲਏਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Так, живя в мире и оставаясь непривязанным, ты обретёшь вечное место."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31795,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਾਹੁ ਸੇਵਿ ਜਿਤੁ ਤੋਟਿ ਨ ਆਵੈ ॥",
          "roman": "so sāh sev jit toṭ na āvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਮ-ਧਨ ਦੇ ਮਾਲਕ ਉਸ ਪ੍ਰਭੂ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰਿਆ ਕਰ, (ਉਸ ਪਾਸੋਂ ਐਸਾ ਧਨ ਮਿਲਦਾ ਹੈ) ਜਿਸ ਧਨ ਵਿਚ ਕਦੇ ਘਾਟਾ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Служи тому Господу, чьё богатство никогда не убывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31796,
          "is_rahao": false,
          "gurmukhi": "ਖਾਤ ਖਰਚਤ ਸੁਖਿ ਅਨਦਿ ਵਿਹਾਵੈ ॥੩॥",
          "roman": "khāt kharchat sukh anad vihāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਧਨ ਨੂੰ ਆਪ ਵਰਤਦਿਆਂ ਹੋਰਨਾਂ ਵਿਚ ਵਰਤਾਂਦਿਆਂ ਜ਼ਿੰਦਗੀ ਸੁਖ ਆਨੰਦ ਨਾਲ ਬੀਤਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Пользуясь этим богатством и делясь им, жизнь проходит в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31797,
          "is_rahao": false,
          "gurmukhi": "ਜਗਜੀਵਨ ਪੁਰਖੁ ਸਾਧਸੰਗਿ ਪਾਇਆ ॥",
          "roman": "jagjīvan purakh sādhsaṅg pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ ਜਗਤ ਦੇ ਜੀਵਨ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਦਾ ਮਿਲਾਪ ਹਾਸਲ ਕਰ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек обрёл встречу с всепроникающим Господом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31798,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਨਾਮੁ ਧਿਆਇਆ ॥੪॥੨੪॥੩੦॥",
          "roman": "gur prasād nānak nām dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਨੇ ਸਾਧ ਸੰਗਤਿ ਵਿਚ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ ॥੪॥੨੪॥੩੦॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, кто в обществе святых по милости Гуру начал स्मरण имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2837,
      "rahao_verse_id": 31804,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31799,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31800,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਜਬ ਭਏ ਦਇਆਲ ॥",
          "roman": "gur pūre jab bhae dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਦੋਂ (ਕਿਸੇ ਮਨੁੱਖ ਉਤੇ) ਪੂਰੇ ਸਤਿਗੁਰੂ ਜੀ ਦਇਆਵਾਨ ਹੁੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда совершенный Гуру становится милостив,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31801,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਬਿਨਸੇ ਪੂਰਨ ਭਈ ਘਾਲ ॥੧॥",
          "roman": "dukh binse pūraṇ bhaī ghāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਮਨੁੱਖ ਹਰਿ-ਨਾਮ ਸਿਮਰਦਾ ਹੈ, ਉਸ ਦੀ ਇਹ) ਮੇਹਨਤ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ, ਤੇ ਉਸ ਦੇ ਸਾਰੇ ਦੁੱਖ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "труд становится успешным и все страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31802,
          "is_rahao": true,
          "gurmukhi": "ਪੇਖਿ ਪੇਖਿ ਜੀਵਾ ਦਰਸੁ ਤੁਮੑਾਰਾ ॥",
          "roman": "pekh pekh jīvā dars tumhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਮੇਹਰ ਕਰ) ਤੇਰਾ ਦਰਸਨ ਸਦਾ ਕਰ ਕਰ ਕੇ ਮੈਨੂੰ ਆਤਮਕ ਜੀਵਨ ਮਿਲਦਾ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Пусть, созерцая тебя, я обрету духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31803,
          "is_rahao": true,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਜਾਈ ਬਲਿਹਾਰਾ ॥",
          "roman": "charan kamal jāī balihārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੇ ਸੋਹਣੇ ਚਰਨਾਂ ਤੋਂ ਸਦਕੇ ਹੁੰਦਾ ਰਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "я жертвую себя твоим прекрасным стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31804,
          "is_rahao": true,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਠਾਕੁਰ ਕਵਨੁ ਹਮਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tujh bin ṭhākur kavan hamārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਲਕ ਤੇਰੇ ਬਿਨਾ ਮੇਰਾ ਹੋਰ ਕੋਈ ਆਸਰਾ ਨਹੀਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Кроме тебя у меня нет иной опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31805,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਸਿਉ ਪ੍ਰੀਤਿ ਬਣਿ ਆਈ ॥",
          "roman": "sādhsaṅgat sio prīt baṇ āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਨੁੱਖ ਦਾ ਪਿਆਰ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਨਾਲ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Любовь возникает в общении со святыми,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31806,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਬ ਕਰਮਿ ਲਿਖਤ ਧੁਰਿ ਪਾਈ ॥੨॥",
          "roman": "pūrab karam likhat dhur pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰਬਲੇ ਜਨਮਾਂ ਦੇ ਕੀਤੇ ਕਰਮ ਅਨੁਸਾਰ ਧੁਰ ਦਰਗਾਹ ਤੋਂ ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਸਤਕ ਉਤੇ ਲਿਖਿਆ ਲੇਖ ਉੱਘੜਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "согласно заслугам прошлых деяний и записи судьбы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31807,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਹਰਿ ਹਰਿ ਨਾਮੁ ਅਚਰਜੁ ਪਰਤਾਪ ॥",
          "roman": "jap har har nām acharaj partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ, ਅਜੇਹਾ ਹੈਰਾਨ ਕਰਨ ਵਾਲਾ ਆਤਮਕ ਤੇਜ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Повторяй имя Бога — возникает удивительное духовное сияние,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31808,
          "is_rahao": false,
          "gurmukhi": "ਜਾਲਿ ਨ ਸਾਕਹਿ ਤੀਨੇ ਤਾਪ ॥੩॥",
          "roman": "jāl na sākahi tīne tāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ (ਆਧਿ, ਬਿਆਧਿ, ਉਪਾਧਿ-ਇਹ) ਤਿੰਨੇ ਹੀ ਤਾਪ (ਆਤਮਕ ਜੀਵਨ ਨੂੰ) ਸਾੜ ਨਹੀਂ ਸਕਣਗੇ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и три вида страданий не смогут сжечь душу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31809,
          "is_rahao": false,
          "gurmukhi": "ਨਿਮਖ ਨ ਬਿਸਰਹਿ ਹਰਿ ਚਰਣ ਤੁਮੑਾਰੇ ॥",
          "roman": "nimakh na bisrah har charan tumhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਤੇਰੇ ਚਰਨ (ਨਾਨਕ ਨੂੰ) ਅੱਖ ਝਮਕਣ ਜਿਤਨੇ ਸਮੇ ਲਈ ਭੀ ਨਾਹ ਭੁੱਲਣ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Пусть твои стопы не забываются ни на мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31810,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਮਾਗੈ ਦਾਨੁ ਪਿਆਰੇ ॥੪॥੨੫॥੩੧॥",
          "roman": "nānak māgē dān piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਿਆਰੇ! (ਤੇਰੇ ਦਰ ਤੋਂ ਤੇਰਾ ਦਾਸ) ਨਾਨਕ (ਇਹੋ) ਦਾਨ ਮੰਗਦਾ ਹੈ ॥੪॥੨੫॥੩੧॥"
            },
            "sahib_singh_ru": {
              "main": "О любимый! Нанак просит только этот дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2838,
      "rahao_verse_id": 31815,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31811,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31812,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਸੰਜੋਗ ਕਰਹੁ ਮੇਰੇ ਪਿਆਰੇ ॥",
          "roman": "se sanjog karah mere piāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪਿਆਰੇ! (ਮੇਰੇ ਵਾਸਤੇ) ਉਹ ਢੋ ਢੁਕਾ,"
            },
            "sahib_singh_ru": {
              "main": "О мой любимый! Устрой такие обстоятельства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31813,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਰਸਨਾ ਹਰਿ ਨਾਮੁ ਉਚਾਰੇ ॥੧॥",
          "roman": "jit rasnā har nām uchāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਰਾਹੀਂ (ਮੇਰੀ) ਜੀਭ ਤੇਰਾ ਨਾਮ ਉਚਾਰਦੀ ਰਹੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы мой язык произносил твоё имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31814,
          "is_rahao": true,
          "gurmukhi": "ਸੁਣਿ ਬੇਨਤੀ ਪ੍ਰਭ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "suṇ benatī prabh dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ! (ਮੇਰੀ) ਬੇਨਤੀ ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "О сострадательный к бедным Господь! Услышь мою молитву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31815,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧ ਗਾਵਹਿ ਗੁਣ ਸਦਾ ਰਸਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādh gāvahi guṇ sadā rasālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਸੰਤ ਜਨ ਸਦਾ ਤੇਰੇ ਰਸ-ਭਰੇ ਗੁਣ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ (ਤਿਵੇਂ ਮੈਂ ਭੀ ਗਾਂਦਾ ਰਹਾਂ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "как святые всегда воспевают твои сладостные गुणы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31816,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਨ ਰੂਪੁ ਸਿਮਰਣੁ ਪ੍ਰਭ ਤੇਰਾ ॥",
          "roman": "jīvan rūp simran prabh terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਸਿਮਰਨਾ (ਅਸਾਂ ਜੀਵਾਂ ਵਾਸਤੇ) ਆਤਮਕ ਜੀਵਨ ਦੇ ਬਰਾਬਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! स्मरण твоего имени есть сама духовная жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31817,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਕ੍ਰਿਪਾ ਕਰਹਿ ਬਸਹਿ ਤਿਸੁ ਨੇਰਾ ॥੨॥",
          "roman": "jis kirpā karahi basahi tis nerā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਤੂੰ ਕਿਰਪਾ ਕਰਦਾ ਹੈਂ, ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Кому ты даруешь милость, в том сердце ты поселяешься."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31818,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਕੀ ਭੂਖ ਤੇਰਾ ਨਾਮੁ ਅਹਾਰੁ ॥",
          "roman": "jan kī bhūkh terā nām ahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੀ (ਆਤਮਕ) ਭੁਖ (ਦੂਰ ਕਰਨ ਲਈ) ਤੇਰਾ ਨਾਮ ਖ਼ੁਰਾਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Имя твоё — пища для духовного голода твоих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31819,
          "is_rahao": false,
          "gurmukhi": "ਤੂੰ ਦਾਤਾ ਪ੍ਰਭ ਦੇਵਣਹਾਰੁ ॥੩॥",
          "roman": "tūn dātā prabh devanahār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਖ਼ੁਰਾਕ ਤੂੰ ਹੀ ਦੇਂਦਾ ਹੈਂ, ਤੂੰ ਹੀ ਦੇ ਸਕਦਾ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ты — дарующий, только ты даёшь эту пищу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31820,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਮਤ ਸੰਤਨ ਸੁਖੁ ਮਾਨਾ ॥",
          "roman": "rām ramat santan sukh mānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Святые, स्मरणяя Бога, пребывают в आनंदе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31821,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦੇਵਨਹਾਰ ਸੁਜਾਨਾ ॥੪॥੨੬॥੩੨॥",
          "roman": "nānak devanahār sujānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜੋ ਸਭ ਕੁਝ ਦੇਣ ਦੇ ਸਮਰਥ ਹੈ ਅਤੇ ਜੋ (ਹਰ ਗੱਲੇ) ਸਿਆਣਾ ਹੈ ॥੪॥੨੬॥੩੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Он — всезнающий и дающий всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2839,
      "rahao_verse_id": 31826,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31822,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31823,
          "is_rahao": false,
          "gurmukhi": "ਬਹਤੀ ਜਾਤ ਕਦੇ ਦ੍ਰਿਸਟਿ ਨ ਧਾਰਤ ॥",
          "roman": "bahtī jāt kade drisht na dhārat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਤੇਰੀ ਉਮਰ ਦੀ ਨਦੀ) ਵਹਿੰਦੀ ਜਾ ਰਹੀ ਹੈ, ਪਰ ਤੂੰ ਇਧਰ ਧਿਆਨ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Твоя жизнь течёт, но ты не обращаешь на это внимания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31824,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਮੋਹ ਬੰਧਹਿ ਨਿਤ ਪਾਰਚ ॥੧॥",
          "roman": "mithyā moh bandheh nit pārach",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਨਾਸਵੰਤ ਪਦਾਰਥਾਂ ਦੇ ਮੋਹ ਦੇ ਬਾਨ੍ਹਣੂ ਹੀ ਸਦਾ ਬੰਨ੍ਹਦਾ ਰਹਿੰਦਾ ਹੈਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты постоянно связываешь себя узами привязанности к тленному."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31825,
          "is_rahao": true,
          "gurmukhi": "ਮਾਧਵੇ ਭਜੁ ਦਿਨ ਨਿਤ ਰੈਣੀ ॥",
          "roman": "mādhve bhaj din nit rēṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਦਿਨ ਰਾਤ ਸਦਾ ਮਾਇਆ ਦੇ ਪਤੀ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Днём и ночью स्मरणяй Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31826,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਜੀਤਿ ਹਰਿ ਸਰਣੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "janam padārath jīt har saraṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਕੀਮਤੀ ਮਨੁੱਖਾ ਜਨਮ ਦਾ ਲਾਭ ਖੱਟ ਲੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "В прибежище Бога обрети пользу драгоценного человеческого рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31827,
          "is_rahao": false,
          "gurmukhi": "ਕਰਤ ਬਿਕਾਰ ਦੋਊ ਕਰ ਝਾਰਤ ॥ ਰਾਮ ਰਤਨੁ ਰਿਦ ਤਿਲੁ ਨਹੀ ਧਾਰਤ ॥੨॥",
          "roman": "karat bikār doū kar jhārat rām ratan rid til nahī dhārat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਤੂੰ ਹਾਣ ਲਾਭ ਵਿਚਾਰਨ ਤੋਂ ਬਿਨਾ ਹੀ ਵਿਕਾਰ ਕਰੀ ਜਾ ਰਿਹਾ ਹੈਂ, ਪਰਮਾਤਮਾ ਦਾ ਰਤਨ (ਵਰਗਾ ਕੀਮਤੀ) ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਤੂੰ ਇਕ ਛਿਨ ਵਾਸਤੇ ਭੀ ਨਹੀਂ ਟਿਕਾਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Ты совершаешь пороки без размышления и не удерживаешь имя Бога в сердце даже на мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31828,
          "is_rahao": false,
          "gurmukhi": "ਭਰਣ ਪੋਖਣ ਸੰਗਿ ਅਉਧ ਬਿਹਾਣੀ ॥",
          "roman": "bharan pokhan saṅg audh bihāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਆਪਣਾ ਸਰੀਰ) ਪਾਲਣ ਪੋਸਣ ਵਿਚ ਹੀ ਤੇਰੀ ਉਮਰ ਲੰਘਦੀ ਜਾ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Вся жизнь проходит в заботе о теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
