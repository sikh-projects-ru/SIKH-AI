        {
          "verse_id": 31972,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਕੁਰਬਾਣੀ ਤੇਰਿਆ ਸੇਵਕਾ ਜਿਨੑ ਹਰਿ ਨਾਮੁ ਪਿਆਰਾ ॥੩॥",
          "roman": "hau kurbānī teriā sevkā jinh har nām piārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
