              "main": ""
            }
          }
        },
        {
          "verse_id": 31971,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਰੂਪੁ ਅਗੰਮੁ ਹੈ ਅਨੂਪੁ ਤੇਰਾ ਦਰਸਾਰਾ ॥",
          "roman": "terā rūp agam hē anūp terā darsārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਹਸਤੀ ਐਸੀ ਹੈ ਜਿਸ ਤਕ (ਅਸਾਂ ਜੀਵਾਂ ਦੀ) ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, ਤੇਰਾ ਦਰਸਨ ਅਦੁੱਤੀ ਹੈ (ਤੇਰੇ ਵਰਗਾ ਹੋਰ ਕੋਈ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твоя сущность непостижима, и Твоё видение несравненно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
