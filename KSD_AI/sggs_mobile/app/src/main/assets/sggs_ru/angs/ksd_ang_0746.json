{
  "ang": 746,
  "shabads": [
    {
      "shabad_id": 2850,
      "rahao_verse_id": 31930,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31927,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਸੂਹੀ ਮਹਲਾ ੫ ਘਰੁ ੫ ਪੜਤਾਲ",
          "roman": "rāg sūhī mehlā 5 ghar 5 paṛtāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੂਹੀ, ਘਰ ੫ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ 'ਪੜਤਾਲ'।"
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи, дом 5, бани Гуру Арджандева Джи «Падрталь»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31928,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ака́л Пуракх один и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31929,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰੀਤਿ ਪ੍ਰੀਤਿ ਗੁਰੀਆ ਮੋਹਨ ਲਾਲਨਾ ॥",
          "roman": "prīt prīt gurīā mohan lālnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਦੁਨੀਆ ਦੀਆਂ) ਪ੍ਰੀਤਾਂ ਵਿਚੋਂ ਵੱਡੀ ਪ੍ਰੀਤ ਮਨ ਨੂੰ ਮੋਹਣ ਵਾਲੇ ਲਾਲ-ਪ੍ਰਭੂ ਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Из всех привязанностей величайшая — любовь к очаровывающему Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31930,
          "is_rahao": true,
          "gurmukhi": "ਜਪਿ ਮਨ ਗੋਬਿੰਦ ਏਕੈ ਅਵਰੁ ਨਹੀ ਕੋ ਲੇਖੈ ਸੰਤ ਲਾਗੁ ਮਨਹਿ ਛਾਡੁ ਦੁਬਿਧਾ ਕੀ ਕੁਰੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jap man gobind ekē avar nahī ko lekhē sant lāg maneh chhāḍ dubidhā kī kurīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਸਿਰਫ਼ ਉਸ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ। ਹੋਰ ਕੋਈ ਉੱਦਮ ਉਸ ਦੀ ਦਰਗਾਹ ਵਿਚ ਪਰਵਾਨ ਨਹੀਂ ਹੁੰਦਾ। ਹੇ ਭਾਈ! ਸੰਤਾਂ ਦੀ ਚਰਨੀਂ ਲੱਗਾ ਰਹੁ, ਅਤੇ ਆਪਣੇ ਮਨ ਵਿਚੋਂ ਡਾਂਵਾਂਡੋਲ ਰਹਿਣ-ਵਾਲੀ ਦਸ਼ਾ ਦੀ ਪਗਡੰਡੀ ਦੂਰ ਕਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О ум! Повторяй только Имя Господа. Никакое другое усилие не принимается в Его обители. О брат! Пребывай у стоп святых и устрани из своего ума состояние колебаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31931,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਗੁਨ ਹਰੀਆ ਸਰਗੁਨ ਧਰੀਆ ਅਨਿਕ ਕੋਠਰੀਆ ਭਿੰਨ ਭਿੰਨ ਭਿੰਨ ਭਿਨ ਕਰੀਆ ॥",
          "roman": "nirgun harīā sargun dharīā anik koṭharīā bhinn bhinn bhinn bhin karīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਿਰਲੇਪ ਪ੍ਰਭੂ ਨੇ ਤ੍ਰਿਗੁਣੀ ਸੰਸਾਰ ਬਣਾਇਆ, ਇਸ ਵਿਚ ਇਹ ਅਨੇਕਾਂ (ਸਰੀਰ-) ਕੋਠੜੀਆਂ ਉਸ ਨੇ ਵੱਖ ਵੱਖ (ਕਿਸਮ ਦੀਆਂ) ਬਣਾ ਦਿੱਤੀਆਂ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Беспристрастный Господь создал трёхгунный мир и в нём создал множество различных тел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31932,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਿ ਮਨ ਕੋਟਵਰੀਆ ॥",
          "roman": "vich man koṭvarīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹਰੇਕ ਸਰੀਰ-ਕੋਠੜੀ) ਵਿਚ ਮਨ ਨੂੰ ਕੋਤਵਾਲ ਬਣਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "В каждой телесной обители сделал ум стражем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31933,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਮੰਦਰਿ ਪਿਰੀਆ ॥",
          "roman": "nij mandir pirīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਆਰਾ ਪ੍ਰਭੂ (ਹਰੇਕ ਸਰੀਰ-ਕੋਠੜੀ ਵਿਚ) ਆਪਣੇ ਮੰਦਰ ਵਿਚ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный Господь пребывает в каждой обители в Своём храме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31934,
          "is_rahao": false,
          "gurmukhi": "ਤਹਾ ਆਨਦ ਕਰੀਆ ॥",
          "roman": "tahā ānand karīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉੱਥੇ ਆਨੰਦ ਮਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и там наслаждается блаженством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31935,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਮਰੀਆ ਨਹ ਜਰੀਆ ॥੧॥",
          "roman": "nah marīā nah jarīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪ੍ਰਭੂ ਨੂੰ ਨਾਹ ਮੌਤ ਆਉਂਦੀ ਹੈ, ਨਾਹ ਬੁਢਾਪਾ ਉਸ ਦੇ ਨੇੜੇ ਢੁੱਕਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь не умирает и старость к Нему не приближается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31936,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਤਨਿ ਜੁਰੀਆ ਬਹੁ ਬਿਧਿ ਫਿਰੀਆ ਪਰ ਕਉ ਹਿਰੀਆ ॥",
          "roman": "kirtan jurīā bah bidh phirīā par kau hirīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੀਵ ਪ੍ਰਭੂ ਦੀ ਰਚੀ ਰਚਨਾ ਵਿਚ ਹੀ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ, ਕਈ ਤਰੀਕਿਆਂ ਨਾਲ ਭਟਕਦਾ ਫਿਰਦਾ ਹੈ, ਪਰਾਏ (ਧਨ ਨੂੰ, ਰੂਪ ਨੂੰ) ਤੱਕਦਾ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Существо связано творением Господа, блуждает разными путями и устремляется к чужому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31937,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਨਾ ਘਿਰੀਆ ॥",
          "roman": "bikhnā ghirīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਸ਼ੇ-ਵਿਕਾਰਾਂ ਵਿਚ ਘਿਰਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Оно окружено страстями и пороками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31938,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਸਾਧੂ ਸੰਗਿ ਪਰੀਆ ॥",
          "roman": "ab sādhū sang parīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਮਨੁੱਖਾ ਜਨਮ ਵਿਚ ਜਦੋਂ ਜੀਵ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਅੱਪੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В этом человеческом рождении, когда существо приходит в общество Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31939,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦੁਆਰੈ ਖਰੀਆ ॥",
          "roman": "har duārē kharīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਆ ਖਲੋਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "оно встаёт у двери Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31940,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਕਰੀਆ ॥",
          "roman": "darsan karīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਦਾ) ਦਰਸਨ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и созерцает Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31941,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰ ਮਿਰੀਆ ॥",
          "roman": "nānak gur mirīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੇਹੜਾ ਭੀ ਮਨੁੱਖ) ਗੁਰੂ ਨੂੰ ਮਿਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот, кто встречает Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31942,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਰਿ ਨ ਫਿਰੀਆ ॥੨॥੧॥੪੪॥",
          "roman": "bahur na phirīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮੁੜ ਜਨਮ-ਮਰਣ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਭਟਕਦਾ ॥੨॥੧॥੪੪॥"
            },
            "sahib_singh_ru": {
              "main": "не блуждает снова в круге рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2851,
      "rahao_verse_id": 31945,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31943,
          "is_rahao": true,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31944,
          "is_rahao": true,
          "gurmukhi": "ਰਾਸਿ ਮੰਡਲੁ ਕੀਨੋ ਆਖਾਰਾ ॥",
          "roman": "rās maṇḍal kīno ākhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਹ ਸਾਰਾ ਜਗਤ-ਖਿਲਾਰਾ ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਬਣਾ ਰੱਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Весь этот мир создан самим Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31945,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲੋ ਸਾਜਿ ਰਖਿਓ ਪਾਸਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "saglo sāj rakhio pāsārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ (ਮਾਨੋ) ਉਸ ਨੇ (ਰਾਸਾਂ ਪਾਣ ਲਈ) ਅਖਾੜਾ ਤਿਆਰ ਕੀਤਾ ਹੈ, ਰਾਸਾਂ ਵਾਸਤੇ ਮੰਡੂਆ ਬਣਾ ਦਿੱਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он словно устроил арену и подготовил пространство для игр."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31946,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਬਿਧਿ ਰੂਪ ਰੰਗ ਆਪਾਰਾ ॥",
          "roman": "bah bidh rūp raṅg āpārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਇਸ ਜਗਤ-ਅਖਾੜੇ ਵਿਚ) ਕਈ ਕਿਸਮਾਂ ਦੇ ਬੇਅੰਤ ਰੂਪ ਹਨ ਰੰਗ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! В этом мире бесчисленные формы и цвета."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31947,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖੈ ਖੁਸੀ ਭੋਗ ਨਹੀ ਹਾਰਾ ॥",
          "roman": "pekhē khusī bhog nahī hārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਆਪ ਇਸ ਨੂੰ) ਖ਼ੁਸ਼ੀ ਨਾਲ ਵੇਖਦਾ ਹੈ, (ਪਦਾਰਥਾਂ ਦੇ) ਭੋਗ (ਭੋਗਦਾ ਹੈ, ਪਰ ਭੋਗਦਾ) ਥੱਕਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Господь с радостью наблюдает и наслаждается, не уставая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31948,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਰਸ ਲੈਤ ਬਸਤ ਨਿਰਾਰਾ ॥੧॥",
          "roman": "sabh ras lēt bast nirārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਰਸ ਮਾਣਦਾ ਹੋਇਆ ਭੀ ਉਹ ਪ੍ਰਭੂ ਆਪ ਨਿਰਲੇਪ ਹੀ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Наслаждаясь всеми вкусами, Он остаётся непривязанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31949,
          "is_rahao": false,
          "gurmukhi": "ਬਰਨੁ ਚਿਹਨੁ ਨਾਹੀ ਮੁਖੁ ਨ ਮਾਸਾਰਾ ॥",
          "roman": "barn chihan nāhī mukh na māsārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਹ ਕੋਈ ਰੰਗ ਹੈ, ਨਾਹ ਕੋਈ ਨਿਸ਼ਾਨ ਹੈ, ਨਾਹ ਤੇਰਾ ਕੋਈ ਮੂੰਹ ਹੈ, ਨਾਹ ਕੋਈ ਦਾੜ੍ਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! У Тебя нет ни цвета, ни знака, ни лица, ни бороды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31950,
          "is_rahao": false,
          "gurmukhi": "ਕਹਨੁ ਨ ਜਾਈ ਖੇਲੁ ਤੁਹਾਰਾ ॥",
          "roman": "kahan na jāī khel tuhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਰਚਿਆ ਜਗਤ-ਖੇਲ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Твою игру невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31951,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰੇਣ ਸੰਤ ਚਰਨਾਰਾ ॥੨॥੨॥੪੫॥",
          "roman": "nānak reṇ sant charnā rā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਦਰ ਤੋਂ ਤੇਰੇ) ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹਾਂ ॥੨॥੨॥੪੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Проси пыль у стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2852,
      "rahao_verse_id": 31955,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31952,
          "is_rahao": true,
          "gurmukhi": "ਸੂਹੀ ਮਹਲਾ ੫ ॥",
          "roman": "sūhī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31953,
          "is_rahao": true,
          "gurmukhi": "ਤਉ ਮੈ ਆਇਆ ਸਰਨੀ ਆਇਆ ॥",
          "roman": "tau mē āiā sarnī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я пришёл в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31954,
          "is_rahao": true,
          "gurmukhi": "ਭਰੋਸੈ ਆਇਆ ਕਿਰਪਾ ਆਇਆ ॥",
          "roman": "bharosē āiā kirpā āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਭਰੋਸੇ ਨਾਲ ਆਇਆ ਹਾਂ ਕਿ ਤੂੰ ਕਿਰਪਾ ਕਰੇਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "Я пришёл с надеждой на Твою милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31955,
          "is_rahao": true,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਾਖਹੁ ਸੁਆਮੀ ਮਾਰਗੁ ਗੁਰਹਿ ਪਠਾਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jio bhāvē tio rākhah suāmī mārag gurahi paṭhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋ, ਹੇ ਮਾਲਕ ਪ੍ਰਭੂ! ਜਿਵੇਂ ਤੈਨੂੰ ਚੰਗੇ ਲੱਗੇ, ਮੇਰੀ ਰੱਖਿਆ ਕਰ। (ਮੈਨੂੰ ਤੇਰੇ ਦਰ ਤੇ) ਗੁਰੂ ਨੇ ਭੇਜਿਆ ਹੈ, (ਮੈਨੂੰ ਤੇਰੇ ਦਰ ਦਾ) ਰਸਤਾ ਗੁਰੂ ਨੇ (ਵਿਖਾਇਆ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Сохрани меня, как Тебе угодно. Гуру направил меня на этот путь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31956,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਦੁਤਰੁ ਮਾਇਆ ॥ ਜੈਸੇ ਪਵਨੁ ਝੁਲਾਇਆ ॥੧॥",
          "roman": "mahā dutar māiā jēsē pavan jhulāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਤੇਰੀ ਰਚੀ) ਮਾਇਆ (ਇਕ ਵੱਡਾ ਸਮੁੰਦਰ ਹੈ ਜਿਸ ਤੋਂ) ਪਾਰ ਲੰਘਣਾ ਬਹੁਤ ਔਖਾ ਹੈ। ਜਿਵੇਂ (ਤੇਜ਼) ਹਵਾ ਧੱਕੇ ਮਾਰਦੀ ਹੈ, ਤਿਵੇਂ ਮਾਇਆ (ਦੀਆਂ ਲਹਿਰਾਂ ਧੱਕੇ ਮਾਰਦੀਆਂ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Майя — великий океан, который трудно пересечь, как сильный ветер толкает, так и волны майи толкают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31957,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਿ ਸੁਨਿ ਹੀ ਡਰਾਇਆ ॥",
          "roman": "sun sun hī ḍarāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤਾਂ ਇਹ ਸੁਣ ਸੁਣ ਕੇ ਹੀ ਡਰ ਰਿਹਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я лишь слыша об этом уже пугаюсь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31958,
          "is_rahao": false,
          "gurmukhi": "ਕਰਰੋ ਧ੍ਰਮਰਾਇਆ ॥੨॥",
          "roman": "karro dharamrāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਧਰਮਰਾਜ ਬੜਾ ਕਰੜਾ (ਹਾਕਮ) ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "что Дхармраджа суров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31959,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹ ਅੰਧ ਕੂਪਾਇਆ ॥",
          "roman": "grih andh kūpāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਹ ਸੰਸਾਰ ਇਕ ਅੰਨ੍ਹਾ ਖੂਹ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Этот мир — тёмный колодец,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31960,
          "is_rahao": false,
          "gurmukhi": "ਪਾਵਕੁ ਸਗਰਾਇਆ ॥੩॥",
          "roman": "pāvak sagarāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਵਿਚ ਸਾਰੀ (ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਹੀ ਅੱਗ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "в котором лишь огонь желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31961,
          "is_rahao": false,
          "gurmukhi": "ਗਹੀ ਓਟ ਸਾਧਾਇਆ ॥",
          "roman": "gahī oṭ sādhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜਦੋਂ ਤੋਂ) ਮੈਂ ਗੁਰੂ ਦਾ ਆਸਰਾ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "С тех пор как я принял прибежище Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31962,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਰਿ ਧਿਆਇਆ ॥",
          "roman": "nānak har dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ (ਆਖ-) ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰ ਰਿਹਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, я медитирую на Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31963,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਮੈ ਪੂਰਾ ਪਾਇਆ ॥੪॥੩॥੪੬॥",
          "roman": "ab mē pūrā pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਮੈਨੂੰ ਪੂਰਨ ਪ੍ਰਭੂ ਲੱਭ ਪਿਆ ਹੈ ॥੪॥੩॥੪੬॥"
            },
            "sahib_singh_ru": {
              "main": "и теперь нашёл Совершенного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2853,
      "rahao_verse_id": 31968,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 31964,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੂਹੀ ਮਹਲਾ ੫ ਘਰੁ ੬",
          "roman": "rāg sūhī mehlā 5 ghar 6",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੂਹੀ, ਘਰ ੬ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи, дом 6, бани Гуру Арджандева Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31965,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ака́л Пуракх один и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31966,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਪਾਸਿ ਬੇਨੰਤੀਆ ਮਿਲੈ ਨਾਮੁ ਆਧਾਰਾ ॥",
          "roman": "satgur pās benantīā milē nām ādhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੈਂ ਤਾਂ ਗੁਰੂ ਦੇ ਪਾਸ ਹੀ (ਸਦਾ) ਅਰਜ਼ੋਈ ਕਰਦਾ ਹਾਂ ਕਿ ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮਿਲ ਜਾਏ, (ਇਹ ਨਾਮ ਹੀ ਮੇਰੀ ਜ਼ਿੰਦਗੀ ਦਾ) ਸਹਾਰਾ (ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Я постоянно молю у Гуру, чтобы получить Имя Господа — это опора жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31967,
          "is_rahao": false,
          "gurmukhi": "ਤੁਠਾ ਸਚਾ ਪਾਤਿਸਾਹੁ ਤਾਪੁ ਗਇਆ ਸੰਸਾਰਾ ॥੧॥",
          "roman": "tuṭhā sachā pātisāh tāp gaiā sansārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ (ਉਸ ਨੂੰ ਉਸ ਦਾ ਨਾਮ ਮਿਲਦਾ ਹੈ, ਤੇ) ਉਸ ਦਾ ਮਾਇਆ ਦੇ ਮੋਹ ਵਾਲਾ ਤਾਪ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Когда вечный Господь становится милостив, уходит страдание от привязанности к миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31968,
          "is_rahao": true,
          "gurmukhi": "ਭਗਤਾ ਕੀ ਟੇਕ ਤੂੰ ਸੰਤਾ ਕੀ ਓਟ ਤੂੰ ਸਚਾ ਸਿਰਜਨਹਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bhagtā kī ṭek tū santā kī oṭ tū sachā sirjanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਸਿਰਜਣਹਾਰ! ਤੂੰ (ਤੇਰਾ ਨਾਮ) ਤੇਰੇ ਭਗਤਾਂ ਦਾ ਸਹਾਰਾ ਹੈ, ਤੇਰਾ ਨਾਮ ਤੇਰੇ ਸੰਤਾਂ ਦਾ ਆਸਰਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О вечный Творец! Ты — опора преданных и прибежище святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31969,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਤੇਰੀ ਸਾਮਗਰੀ ਸਚੁ ਤੇਰਾ ਦਰਬਾਰਾ ॥",
          "roman": "sach terī sāmagarī sach terā darbārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਦਰਬਾਰ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ, ਤੇਰੇ ਖ਼ਜ਼ਾਨੇ ਸਦਾ ਭਰਪੂਰ ਰਹਿਣ ਵਾਲੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твой двор вечен, и Твои сокровища вечны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 31970,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਤੇਰੇ ਖਾਜੀਨਿਆ ਸਚੁ ਤੇਰਾ ਪਾਸਾਰਾ ॥੨॥",
          "roman": "sach tere khājinīā sach terā pāsārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰੇ ਖ਼ਜ਼ਾਨਿਆਂ ਵਿਚ) ਤੇਰੇ ਪਦਾਰਥ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਹਨ, ਤੇਰਾ ਰਚਿਆ ਜਗਤ-ਖਿਲਾਰਾ ਅਟੱਲ ਨਿਯਮਾਂ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Твои богатства вечны, и Твоё творение установлено неизменным законом."
            },
