{
  "ang": 792,
  "shabads": [
    {
      "shabad_id": 2977,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33643,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਨ ਮਰੀਜੈ ਰੋਇ ਜਾ ਲਗੁ ਚਿਤਿ ਨ ਆਵਹੀ ॥੧॥",
          "roman": "kiu na marījē roi jā lag chit na āvahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਤੂੰ ਮੇਰੇ ਚਿੱਤ ਵਿਚ ਨਾਹ ਵਸੇਂ, ਕਿਉਂ ਨ ਰੋ ਕੇ ਮਰਾਂ? (ਤੈਨੂੰ ਵਿਸਾਰ ਕੇ ਦੁੱਖਾਂ ਵਿਚ ਹੀ ਖਪੀਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Пока Ты не пребываешь в моём сердце, почему бы мне не умереть, плача?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2978,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33644,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੨ ॥",
          "roman": "mahla 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33645,
          "is_rahao": false,
          "gurmukhi": "ਜਾਂ ਸੁਖੁ ਤਾ ਸਹੁ ਰਾਵਿਓ ਦੁਖਿ ਭੀ ਸੰਮੑਾਲਿਓਇ ॥",
          "roman": "jā sukh tā sah rāvio dukh bhī samhāliōi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਸੁਖ ਹੈ ਤਾਂ ਭੀ ਖਸਮ-ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਕਰੀਏ, ਦੁੱਖ ਵਿਚ ਭੀ ਮਾਲਕ ਨੂੰ ਚੇਤੇ ਰੱਖੀਏ,"
            },
            "sahib_singh_ru": {
              "main": "И в радости вспоминай Господа-супруга, и в горе помни Его,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33646,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਕਹੈ ਸਿਆਣੀਏ ਇਉ ਕੰਤ ਮਿਲਾਵਾ ਹੋਇ ॥੨॥",
          "roman": "nānak kahē siāṇīe iu kant milāvā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ, ਨਾਨਕ ਆਖਦਾ ਹੈ, ਹੇ ਸਿਆਣੀ ਜੀਵ-ਇਸਤ੍ਰੀਏ! ਇਸ ਤਰ੍ਹਾਂ ਖਸਮ ਨਾਲ ਮੇਲ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так, говорит Нанак, о мудрая душа-жена, происходит встреча с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2979,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33647,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33648,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਕਿਆ ਸਾਲਾਹੀ ਕਿਰਮ ਜੰਤੁ ਵਡੀ ਤੇਰੀ ਵਡਿਆਈ ॥",
          "roman": "hau kiā sālāhī kiram jant vaḍī terī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਇਕ ਕੀੜਾ ਜਿਹਾ ਹਾਂ, ਤੇਰੀ ਵਡਿਆਈ ਵੱਡੀ ਹੈ, ਮੈਂ ਤੇਰੇ ਕੀਹ ਕੀਹ ਗੁਣ ਬਿਆਨ ਕਰਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Я всего лишь маленькое существо, Твоя слава велика — как мне восхвалить Тебя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33649,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਅਗਮ ਦਇਆਲੁ ਅਗੰਮੁ ਹੈ ਆਪਿ ਲੈਹਿ ਮਿਲਾਈ ॥",
          "roman": "tū agam daīāl agam hē āp lēh milāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਬੜਾ ਹੀ ਦਿਆਲ ਹੈਂ, ਅਪਹੁੰਚ ਹੈਂ ਤੂੰ ਆਪ ਹੀ ਆਪਣੇ ਨਾਲ ਮਿਲਾਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты непостижим и милостив, Ты Сам соединяешь с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33650,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਤੁਝ ਬਿਨੁ ਬੇਲੀ ਕੋ ਨਹੀ ਤੂ ਅੰਤਿ ਸਖਾਈ ॥",
          "roman": "mē tujh bin bēlī ko nahī tū ant sakhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਤੈਥੋਂ ਬਿਨਾ ਕੋਈ ਬੇਲੀ ਨਹੀਂ ਦਿੱਸਦਾ, ਆਖ਼ਰ ਤੂੰ ਹੀ ਸਾਥੀ ਹੋ ਕੇ ਪੁਕਾਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Без Тебя у меня нет никого, в конце Ты становишься истинным спутником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33651,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਤੇਰੀ ਸਰਣਾਗਤੀ ਤਿਨ ਲੈਹਿ ਛਡਾਈ ॥",
          "roman": "jo terī saraṇāgat tin lēh chhaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਜੋ ਜੀਵ ਤੇਰੀ ਸਰਨ ਆਉਂਦਾ ਹੈ ਉਹਨਾਂ ਨੂੰ (ਹਉਮੈ ਦੇ ਗੇੜ ਤੋਂ) ਬਚਾ ਲੈਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Тех, кто приходит в Твоё прибежище, Ты освобождаешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33652,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵੇਪਰਵਾਹੁ ਹੈ ਤਿਸੁ ਤਿਲੁ ਨ ਤਮਾਈ ॥੨੦॥੧॥",
          "roman": "nānak veparvāh hē tis til na tamāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਆਪ ਬੇ-ਮੁਥਾਜ ਹੈ, ਉਸ ਨੂੰ ਰਤਾ ਭੀ ਕੋਈ ਲਾਲਚ ਨਹੀਂ ਹੈ ॥੨੦॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Господь независим, в Нём нет ни малейшего желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2980,
      "rahao_verse_id": 33659,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33653,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੂਹੀ ਬਾਣੀ ਸ੍ਰੀ ਕਬੀਰ ਜੀਉ ਤਥਾ ਸਭਨਾ ਭਗਤਾ ਕੀ ॥",
          "roman": "rāg sūhī bāṇī srī kabīr jīu tathā sabhnā bhagtā kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਸੂਹੀ ਵਿੱਚ ਭਗਤ ਕਬੀਰ ਜੀ ਦੀ ਤੇ ਸਾਰੇ ਭਗਤਾਂ ਦੀ ਬਾਣੀ। ਭਗਤ ਕਬੀਰ ਜੀ ਦੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи: бани Бхагата Кабира Джи и всех бхагатов. Бани Бхагата Кабира Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33654,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਕੇ",
          "roman": "kabīr ke",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33655,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōankar satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акаал Пуракх один и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33656,
          "is_rahao": false,
          "gurmukhi": "ਅਵਤਰਿ ਆਇ ਕਹਾ ਤੁਮ ਕੀਨਾ ॥",
          "roman": "avtar āy kahā tum kīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜਗਤ ਵਿਚ ਆ ਕੇ ਜਨਮ ਲੈ ਕੇ ਤੂੰ ਕੀਹ ਕੀਤਾ? (ਭਾਵ, ਤੂੰ ਕੁਝ ਭੀ ਨਾਹ ਖੱਟਿਆ)"
            },
            "sahib_singh_ru": {
              "main": "О брат! Придя в мир и родившись, что ты сделал? (то есть ты ничего не приобрёл)"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33657,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਕੋ ਨਾਮੁ ਨ ਕਬਹੂ ਲੀਨਾ ॥੧॥",
          "roman": "rām ko nām na kabhū līnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਤਾਂ) ਕਦੇ ਸਿਮਰਿਆ ਨਹੀਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Ты никогда не помнил Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33658,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨ ਜਪਹੁ ਕਵਨ ਮਤਿ ਲਾਗੇ ॥",
          "roman": "rām na japah kavan mat lāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਨਹੀਂ ਸਿਮਰਦਾ, ਕਿਹੜੀ (ਕੋਝੀ) ਮੱਤੇ ਲੱਗਾ ਹੋਇਆ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "Ты не поминаешь Имя Господа — какой дурной мысли ты предался?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33659,
          "is_rahao": true,
          "gurmukhi": "ਮਰਿ ਜਇਬੇ ਕਉ ਕਿਆ ਕਰਹੁ ਅਭਾਗੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mar jaibē kau kiyā karah abhāge",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਗ-ਹੀਣ ਬੰਦੇ! ਤੂੰ ਮਰਨ ਦੇ ਵੇਲੇ ਲਈ ਕੀਹ ਤਿਆਰੀ ਕਰ ਰਿਹਾ ਹੈਂ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О несчастный человек! Что ты готовишь для момента смерти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33660,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਸੁਖ ਕਰਿ ਕੈ ਕੁਟੰਬੁ ਜੀਵਾਇਆ ॥",
          "roman": "dukh sukh kar kē kuṭamb jīvāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਈ ਤਰ੍ਹਾਂ ਦੀਆਂ ਔਖਿਆਈਆਂ ਸਹਾਰ ਕੇ ਤੂੰ (ਸਾਰੀ ਉਮਰ) ਕੁਟੰਬ ਹੀ ਪਾਲਦਾ ਰਿਹਾ,"
            },
            "sahib_singh_ru": {
              "main": "Перенося разные трудности, ты всю жизнь лишь содержал семью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33661,
          "is_rahao": false,
          "gurmukhi": "ਮਰਤੀ ਬਾਰ ਇਕਸਰ ਦੁਖੁ ਪਾਇਆ ॥੨॥",
          "roman": "martī bār iksar dukh pāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮਰਨ ਵੇਲੇ ਤੈਨੂੰ ਇਕੱਲਿਆਂ ਹੀ (ਆਪਣੀਆਂ ਗ਼ਲਤੀਆਂ ਬਦਲੇ) ਦੁੱਖ ਸਹਾਰਨਾ ਪਿਆ (ਭਾਵ, ਪਏਗਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "но в момент смерти тебе одному пришлось (придётся) страдать за свои ошибки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33662,
          "is_rahao": false,
          "gurmukhi": "ਕੰਠ ਗਹਨ ਤਬ ਕਰਨ ਪੁਕਾਰਾ ॥",
          "roman": "kanṭh gahan tab karan pukārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਜਮਾਂ ਨੇ ਤੈਨੂੰ) ਗਲੋਂ ਆ ਫੜਿਆ (ਭਾਵ, ਜਦੋਂ ਮੌਤ ਸਿਰ ਤੇ ਆ ਗਈ), ਤਦੋਂ ਰੋਣ ਪੁਕਾਰਨ (ਤੋਂ ਕੋਈ ਲਾਭ ਨਹੀਂ ਹੋਵੇਗਾ);"
            },
            "sahib_singh_ru": {
              "main": "Когда смерть схватила за горло, тогда плач и крик уже не принесут пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33663,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਆਗੇ ਤੇ ਨ ਸੰਮੑਾਰਾ ॥੩॥੧॥",
          "roman": "kah kabīr āge te na sammhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- (ਉਹ ਵੇਲਾ ਆਉਣ ਤੋਂ) ਪਹਿਲਾਂ ਹੀ ਕਿਉਂ ਤੂੰ ਪਰਮਾਤਮਾ ਨੂੰ ਯਾਦ ਨਹੀਂ ਕਰਦਾ? ॥੩॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: почему ты заранее не вспоминаешь Бога?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2981,
      "rahao_verse_id": 33668,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33664,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਕਬੀਰ ਜੀ ॥",
          "roman": "sūhī kabīr jī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33665,
          "is_rahao": false,
          "gurmukhi": "ਥਰਹਰ ਕੰਪੈ ਬਾਲਾ ਜੀਉ ॥",
          "roman": "tharhar kampē bālā jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਤਨੀ ਉਮਰ ਭਗਤੀ ਤੋਂ ਬਿਨਾ ਲੰਘ ਜਾਣ ਕਰਕੇ ਹੁਣ) ਮੇਰੀ ਅੰਞਾਣ ਜਿੰਦ ਬਹੁਤ ਸਹਿਮੀ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Моя невежественная душа теперь сильно испугана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33666,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਜਾਨਉ ਕਿਆ ਕਰਸੀ ਪੀਉ ॥੧॥",
          "roman": "nā jānau kiyā karsī pīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪਤਾ ਨਹੀਂ ਪਤੀ ਪ੍ਰਭੂ (ਮੇਰੇ ਨਾਲ) ਕੀਹ ਸਲੂਕ ਕਰੇਗਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "я не знаю, как со мной поступит Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33667,
          "is_rahao": true,
          "gurmukhi": "ਰੈਨਿ ਗਈ ਮਤ ਦਿਨੁ ਭੀ ਜਾਇ ॥",
          "roman": "rēn gaī mat din bhī jāy",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਤੋਂ ਬਿਨਾ ਹੀ ਮੇਰੀ) ਜੁਆਨੀ ਦੀ ਉਮਰ ਲੰਘ ਗਈ ਹੈ। (ਮੈਨੂੰ ਹੁਣ ਇਹ ਡਰ ਹੈ ਕਿ) ਕਿਤੇ (ਇਸੇ ਤਰ੍ਹਾਂ) ਬੁਢੇਪਾ ਭੀ ਨਾਹ ਲੰਘ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "Моя молодость прошла без поминания Бога, и теперь я боюсь, что и старость так же пройдёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33668,
          "is_rahao": true,
          "gurmukhi": "ਭਵਰ ਗਏ ਬਗ ਬੈਠੇ ਆਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bhavar gae bag bēṭhe āy",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ) ਕਾਲੇ ਕੇਸ ਚਲੇ ਗਏ ਹਨ (ਉਹਨਾਂ ਦੇ ਥਾਂ) ਧੌਲੇ ਆ ਗਏ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Чёрные волосы ушли, а белые пришли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33669,
          "is_rahao": false,
          "gurmukhi": "ਕਾਚੈ ਕਰਵੈ ਰਹੈ ਨ ਪਾਨੀ ॥",
          "roman": "kāchē karvē rahē na pānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੁਣ ਤਕ ਬੇ-ਪਰਵਾਹੀ ਵਿਚ ਖ਼ਿਆਲ ਹੀ ਨਾਹ ਕੀਤਾ ਕਿ ਇਹ ਸਰੀਰ ਤਾਂ ਕੱਚੇ ਭਾਂਡੇ ਵਾਂਗ ਹੈ) ਕੱਚੇ ਕੁੱਜੇ ਵਿਚ ਪਾਣੀ ਟਿਕਿਆ ਨਹੀਂ ਰਹਿ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "В непрочном сосуде вода не удерживается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33670,
          "is_rahao": false,
          "gurmukhi": "ਹੰਸੁ ਚਲਿਆ ਕਾਇਆ ਕੁਮਲਾਨੀ ॥੨॥",
          "roman": "hans chaliā kāiā kumlānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੁਆਸ ਬੀਤਦੇ ਗਏ, ਹੁਣ) ਸਰੀਰ ਕੁਮਲਾ ਰਿਹਾ ਹੈ ਤੇ (ਜੀਵ-) ਭੌਰ ਉਡਾਰੀ ਮਾਰਨ ਨੂੰ ਤਿਆਰ ਹੈ (ਪਰ ਆਪਣਾ ਕੁੱਝ ਭੀ ਨਾਹ ਸਵਾਰਿਆ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тело слабеет, а душа готова улететь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33671,
          "is_rahao": false,
          "gurmukhi": "ਕੁਆਰ ਕੰਨਿਆ ਜੈਸੇ ਕਰਤ ਸੀਗਾਰਾ ॥",
          "roman": "kuār kanniā jēsē karat sīgārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੁਆਰੀ ਲੜਕੀ ਸ਼ਿੰਗਾਰ ਕਰਦੀ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "Как незамужняя девушка занимается украшением,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33672,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਰਲੀਆ ਮਾਨੈ ਬਾਝੁ ਭਤਾਰਾ ॥੩॥",
          "roman": "kiu raliā mānē bājh bhatārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਤੀ ਮਿਲਣ ਤੋਂ ਬਿਨਾ (ਇਹਨਾਂ ਸ਼ਿੰਗਾਰਾਂ ਦਾ) ਉਸ ਨੂੰ ਕੋਈ ਅਨੰਦ ਨਹੀਂ ਆ ਸਕਦਾ, (ਤਿਵੇਂ ਮੈਂ ਭੀ ਸਾਰੀ ਉਮਰ ਨਿਰੇ ਸਰੀਰ ਦੀ ਖ਼ਾਤਰ ਹੀ ਆਹਰ-ਪਾਹਰ ਕੀਤੇ, ਪ੍ਰਭੂ ਨੂੰ ਵਿਸਾਰਨ ਕਰਕੇ ਕੋਈ ਆਤਮਕ ਸੁਖ ਨਾਹ ਮਿਲਿਆ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так и без встречи с мужем она не получает радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33673,
          "is_rahao": false,
          "gurmukhi": "ਕਾਗ ਉਡਾਵਤ ਭੁਜਾ ਪਿਰਾਨੀ ॥",
          "roman": "kāg uḍāvat bhujā pirānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ-(ਹੇ ਪਤੀ-ਪ੍ਰਭੂ! ਹੁਣ ਤਾਂ ਆ ਮਿਲ, ਤੇਰੀ ਉਡੀਕ ਵਿਚ) ਕਾਂ ਉਡਾਂਦਿਆਂ ਮੇਰੀ ਬਾਂਹ ਭੀ ਥੱਕ ਗਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Отгоняя ворон в ожидании, моя рука устала,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33674,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਇਹ ਕਥਾ ਸਿਰਾਨੀ ॥੪॥੨॥",
          "roman": "kah kabīr ih kathā sirānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਉਧਰੋਂ ਮੇਰੀ ਉਮਰ ਦੀ) ਕਹਾਣੀ ਹੀ ਮੁੱਕਣ ਤੇ ਆ ਗਈ ਹੈ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и история моей жизни подходит к концу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2982,
      "rahao_verse_id": 33681,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33675,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਕਬੀਰ ਜੀਉ ॥",
          "roman": "sūhī kabīr jīu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33676,
          "is_rahao": false,
          "gurmukhi": "ਅਮਲੁ ਸਿਰਾਨੋ ਲੇਖਾ ਦੇਨਾ ॥",
          "roman": "amal sirāno lekhā denā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਜੀਵ! ਜਗਤ ਵਿਚ) ਮੁਲਾਜ਼ਮਤ ਦਾ ਸਮਾ (ਭਾਵ, ਉਮਰ ਦਾ ਨਿਯਤ ਸਮਾ) ਲੰਘ ਗਿਆ ਹੈ, (ਇੱਥੇ ਜੇ ਕੁਝ ਕਰਦਾ ਰਿਹਾ ਹੈਂ) ਉਸ ਦਾ ਹਿਸਾਬ ਦੇਣਾ ਪਏਗਾ;"
            },
            "sahib_singh_ru": {
              "main": "Срок жизни прошёл, и теперь придётся дать отчёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33677,
          "is_rahao": false,
          "gurmukhi": "ਆਏ ਕਠਿਨ ਦੂਤ ਜਮ ਲੇਨਾ ॥",
          "roman": "āe kaṭhin dūt jam lenā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਰੜੇ ਜਮ-ਦੂਤ ਲੈਣ ਆ ਗਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Жестокие посланники смерти пришли забрать тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33678,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਤੈ ਖਟਿਆ ਕਹਾ ਗਵਾਇਆ ॥",
          "roman": "kiyā tē khaṭiā kahā gavāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਆਖਣਗੇ-) ਇੱਥੇ ਰਹਿ ਕੇ ਤੂੰ ਕੀਹ ਖੱਟੀ ਖੱਟੀ ਹੈ, ਤੇ ਕਿੱਥੇ ਗਵਾਇਆ ਹੈ?"
            },
            "sahib_singh_ru": {
              "main": "Что ты приобрёл и что растратил?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33679,
          "is_rahao": false,
          "gurmukhi": "ਚਲਹੁ ਸਿਤਾਬ ਦੀਬਾਨਿ ਬੁਲਾਇਆ ॥੧॥",
          "roman": "chalah sitāb dībāni bulāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਛੇਤੀ ਚੱਲ, ਧਰਮਰਾਜ ਨੇ ਸੱਦਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Иди скорее — тебя призвали на суд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33680,
          "is_rahao": true,
          "gurmukhi": "ਚਲੁ ਦਰਹਾਲੁ ਦੀਵਾਨਿ ਬੁਲਾਇਆ ॥",
          "roman": "chal darahāl dīvān bulāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਛੇਤੀ ਚੱਲ, ਧਰਮ-ਰਾਜ ਨੇ ਸੱਦਿਆ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Иди скорее — тебя вызвали на суд;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33681,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਫੁਰਮਾਨੁ ਦਰਗਹ ਕਾ ਆਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har furmān dargah kā āyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੀ ਦਰਗਾਹ ਦਾ ਹੁਕਮ ਆਇਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "пришёл приказ из Божьего двора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33682,
          "is_rahao": false,
          "gurmukhi": "ਕਰਉ ਅਰਦਾਸਿ ਗਾਵ ਕਿਛੁ ਬਾਕੀ ॥",
          "roman": "karau ardās gāv kichh bākī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਬੇਨਤੀ ਕਰਦਾ ਹਾਂ ਕਿ ਕੁਝ ਪਿੰਡ ਦਾ ਹਿਸਾਬ-ਕਿਤਾਬ ਰਹਿ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я прошу: у меня осталось немного дел,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33683,
          "is_rahao": false,
          "gurmukhi": "ਲੇਉ ਨਿਬੇਰਿ ਆਜੁ ਕੀ ਰਾਤੀ ॥",
          "roman": "leu nibēr āj kī rātī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਆਗਿਆ ਦੇਵੋ) ਤਾਂ ਮੈਂ ਅੱਜ ਰਾਤ ਹੀ ਉਹ ਹਿਸਾਬ ਮੁਕਾ ਲਵਾਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "позволь мне закончить их сегодня ночью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33684,
          "is_rahao": false,
          "gurmukhi": "ਕਿਛੁ ਭੀ ਖਰਚੁ ਤੁਮੑਾਰਾ ਸਾਰਉ ॥",
          "roman": "kichh bhī kharch tumhārā sārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੁਝ ਤੁਹਾਡੇ ਲਈ ਭੀ ਖ਼ਰਚ ਦਾ ਪ੍ਰਬੰਧ ਕਰ ਲਵਾਂਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "я устрою и ваши расходы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33685,
          "is_rahao": false,
          "gurmukhi": "ਸੁਬਹ ਨਿਵਾਜ ਸਰਾਇ ਗੁਜਾਰਉ ॥੨॥",
          "roman": "subah nivāj sarāi gujārau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਸਵੇਰ ਦੀ ਨਿਮਾਜ਼ ਰਾਹ ਵਿਚ ਪੜ੍ਹ ਲਵਾਂਗਾ (ਭਾਵ, ਬਹੁਤ ਸਵਖਤੇ ਹੀ ਤੁਹਾਡੇ ਨਾਲ ਤੁਰ ਪਵਾਂਗਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и утреннюю молитву совершу по дороге."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33686,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਜਾ ਕਉ ਹਰਿ ਰੰਗੁ ਲਾਗਾ ॥ ਧਨੁ ਧਨੁ ਸੋ ਜਨੁ ਪੁਰਖੁ ਸਭਾਗਾ ॥",
          "roman": "sādhsang jā kau har rang lāgā dhan dhan so jan purakh sabhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਸਤਸੰਗ ਵਿਚ ਰਹਿ ਕੇ ਪ੍ਰਭੂ ਦਾ ਪਿਆਰ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਧੰਨ ਹੈ, ਭਾਗਾਂ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто в обществе святых обретает любовь к Богу, — благословен и счастлив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33687,
          "is_rahao": false,
          "gurmukhi": "ਈਤ ਊਤ ਜਨ ਸਦਾ ਸੁਹੇਲੇ ॥",
          "roman": "īt ūt jan sadā suhele",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਸੌਖੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Слуги Бога пребывают в покое и здесь, и там,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33688,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਜੀਤਿ ਅਮੋਲੇ ॥੩॥",
          "roman": "janam padārath jīt amole",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਉਂਕਿ ਉਹ ਇਸ ਅਮੋਲਕ ਜਨਮ-ਰੂਪ ਕੀਮਤੀ ਸ਼ੈ ਨੂੰ ਜਿੱਤ ਲੈਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "потому что они побеждают эту драгоценную человеческую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33689,
          "is_rahao": false,
          "gurmukhi": "ਜਾਗਤੁ ਸੋਇਆ ਜਨਮੁ ਗਵਾਇਆ ॥",
          "roman": "jāgat soiā janam gavāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਜਾਗਦਾ ਹੀ (ਮਾਇਆ ਦੀ ਨੀਂਦ ਵਿਚ) ਸੁੱਤਾ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਮਨੁੱਖਾ ਜੀਵਨ ਅਜਾਈਂ ਗਵਾ ਲੈਂਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто бодрствуя спит в иллюзии, теряет свою жизнь напрасно;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33690,
          "is_rahao": false,
          "gurmukhi": "ਮਾਲੁ ਧਨੁ ਜੋਰਿਆ ਭਇਆ ਪਰਾਇਆ ॥",
          "roman": "māl dhan joriā bhaiā parāyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਸ ਦਾ ਸਾਰਾ ਮਾਲ ਧਨ ਇਕੱਠਾ ਕੀਤਾ ਹੋਇਆ (ਤਾਂ ਆਖ਼ਰ) ਬਿਗਾਨਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "всё накопленное богатство становится чужим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33691,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਕਬੀਰ ਤੇਈ ਨਰ ਭੂਲੇ ॥",
          "roman": "kah kabīr teī nar bhūle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ- ਉਹ ਮਨੁੱਖ ਖੁੰਝ ਗਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: эти люди заблудились,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33692,
          "is_rahao": false,
          "gurmukhi": "ਖਸਮੁ ਬਿਸਾਰਿ ਮਾਟੀ ਸੰਗਿ ਰੂਲੇ ॥੪॥੩॥",
          "roman": "khasam bisār māṭī sang rūle",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਿੱਟੀ ਵਿਚ ਹੀ ਰੁਲ ਗਏ ਹਨ ਜਿਨ੍ਹਾਂ ਨੇ ਪਰਮਾਤਮਾ-ਪਤੀ ਨੂੰ ਵਿਸਾਰਿਆ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "забыв Господа, они смешались с прахом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
