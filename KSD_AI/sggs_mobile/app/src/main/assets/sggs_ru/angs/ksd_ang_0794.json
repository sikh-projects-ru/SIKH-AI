{
  "ang": 794,
  "shabads": [
    {
      "shabad_id": 2986,
      "rahao_verse_id": 33737,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33736,
          "is_rahao": true,
          "gurmukhi": "ਕਿਆ ਤੂ ਸੋਇਆ ਜਾਗੁ ਇਆਨਾ ॥",
          "roman": "kiā tū soiā jāg iānā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Зачем ты спишь? Проснись, неразумный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33737,
          "is_rahao": true,
          "gurmukhi": "ਤੈ ਜੀਵਨੁ ਜਗਿ ਸਚੁ ਕਰਿ ਜਾਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tē jīvan jag sach kar jānā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты счёл жизнь в мире истинной и постоянной. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33738,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜੀਉ ਦੀਆ ਸੁ ਰਿਜਕੁ ਅੰਬਰਾਵੈ ॥",
          "roman": "jin jīu dīā so rijak aṃbarāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто дал жизнь, сам доставляет и пропитание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33739,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਘਟ ਭੀਤਰਿ ਹਾਟੁ ਚਲਾਵੈ ॥",
          "roman": "sabh ghaṭ bhītar hāṭ chalāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во всех сердцах Он ведёт внутренний торг жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33740,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਬੰਦਿਗੀ ਛਾਡਿ ਮੈ ਮੇਰਾ ॥",
          "roman": "kar baṃdigī chhāḍ mē merā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершай служение и оставь чувство «я» и «моё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33741,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਨਾਮੁ ਸਮੑਾਰਿ ਸਵੇਰਾ ॥੨॥",
          "roman": "hirdē nām samhār saverā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С ранней поры храни в сердце Имя. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33742,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਸਿਰਾਨੋ ਪੰਥੁ ਨ ਸਵਾਰਾ ॥",
          "roman": "janam sirāno paṃth na savārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жизнь прошла, но путь ты не подготовил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33743,
          "is_rahao": false,
          "gurmukhi": "ਸਾਂਝ ਪਰੀ ਦਹ ਦਿਸ ਅੰਧਿਆਰਾ ॥",
          "roman": "sāñjh parī dah dis aṃdhiārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наступил вечер, и во всех десяти направлениях стало темно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33744,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਰਵਿਦਾਸ ਨਿਦਾਨਿ ਦਿਵਾਨੇ ॥",
          "roman": "kah ravidās nidān divāne.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Равидас говорит: о безумец, в самом конце"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33745,
          "is_rahao": false,
          "gurmukhi": "ਚੇਤਸਿ ਨਾਹੀ ਦੁਨੀਆ ਫਨ ਖਾਨੇ ॥੩॥੨॥",
          "roman": "chetas nāhī dunīā fan khāne. ||3||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "ты всё ещё не помнишь, что этот мир — дом исчезновения. ||3||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2987,
      "rahao_verse_id": 33750,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33746,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ॥",
          "roman": "sūhī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33747,
          "is_rahao": false,
          "gurmukhi": "ਊਚੇ ਮੰਦਰ ਸਾਲ ਰਸੋਈ ॥",
          "roman": "ūche maṃdar sāl rasoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть есть высокие прочные дома и кухни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33748,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਘਰੀ ਫੁਨਿ ਰਹਨੁ ਨ ਹੋਈ ॥੧॥",
          "roman": "ek gharī phun rahan na hoī. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но когда приходит смерть, в них нельзя остаться даже ещё на одно мгновение. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33749,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਤਨੁ ਐਸਾ ਜੈਸੇ ਘਾਸ ਕੀ ਟਾਟੀ ॥",
          "roman": "ih tan ēsā jēse ghās kī ṭāṭī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это тело подобно соломенному навесу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33750,
          "is_rahao": true,
          "gurmukhi": "ਜਲਿ ਗਇਓ ਘਾਸੁ ਰਲਿ ਗਇਓ ਮਾਟੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jal gaio ghās ral gaio māṭī. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Трава сгорает и смешивается с землёй; таков и удел тела. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33751,
          "is_rahao": false,
          "gurmukhi": "ਭਾਈ ਬੰਧ ਕੁਟੰਬ ਸਹੇਰਾ ॥ ਓਇ ਭੀ ਲਾਗੇ ਕਾਢੁ ਸਵੇਰਾ ॥੨॥",
          "roman": "bhāī baṃdh kuṭaṃb saherā. oi bhī lāge kāḍh saverā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек умирает, родственники, семья, друзья и спутники начинают говорить: поскорее вынесите его наружу. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33752,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਕੀ ਨਾਰਿ ਉਰਹਿ ਤਨ ਲਾਗੀ ॥",
          "roman": "ghar kī nār urah tan lāgī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже жена, которая всегда была прижата к его груди,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33753,
          "is_rahao": false,
          "gurmukhi": "ਉਹ ਤਉ ਭੂਤੁ ਭੂਤੁ ਕਰਿ ਭਾਗੀ ॥੩॥",
          "roman": "uh tau bhūt bhūt kar bhāgī. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "отступает, говоря: он уже мёртв, мёртв. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33754,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਰਵਿਦਾਸ ਸਭੈ ਜਗੁ ਲੂਟਿਆ ॥",
          "roman": "kah ravidās sabhē jag lūṭiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Равидас говорит: весь мир обманывается, считая тело, имущество и родных своими."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33755,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਤਉ ਏਕ ਰਾਮੁ ਕਹਿ ਛੂਟਿਆ ॥੪॥੩॥",
          "roman": "ham tau ek rām kahi chhūṭiā. ||4||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А я, вспоминая одно Имя Рама, спасся от этого обмана. ||4||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2988,
      "rahao_verse_id": 33763,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33756,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oaṅkār satgur prasād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33757,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਸੂਹੀ ਬਾਣੀ ਸੇਖ ਫਰੀਦ ਜੀ ਕੀ ॥",
          "roman": "rāg sūhī bāṇī sekh pharīd jī kī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи, бани шейха Фарида-джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33758,
          "is_rahao": false,
          "gurmukhi": "ਤਪਿ ਤਪਿ ਲੁਹਿ ਲੁਹਿ ਹਾਥ ਮਰੋਰਉ ॥",
          "roman": "tap tap luh luh hāth marorau.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сильно страдая и мучительно томясь, теперь я заламываю руки в раскаянии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33759,
          "is_rahao": false,
          "gurmukhi": "ਬਾਵਲਿ ਹੋਈ ਸੋ ਸਹੁ ਲੋਰਉ ॥",
          "roman": "bāval hoī so sah lorau.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Став словно безумной, я ищу того Господа-Супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33760,
          "is_rahao": false,
          "gurmukhi": "ਤੈ ਸਹਿ ਮਨ ਮਹਿ ਕੀਆ ਰੋਸੁ ॥",
          "roman": "tē sah man mah kīā ros.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь-Супруг, Ты разгневался на меня в Своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33761,
          "is_rahao": false,
          "gurmukhi": "ਮੁਝੁ ਅਵਗਨ ਸਹ ਨਾਹੀ ਦੋਸੁ ॥੧॥",
          "roman": "mujh avgan sah nāhī dos. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но вина не в Тебе: пороки были во мне. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33762,
          "is_rahao": true,
          "gurmukhi": "ਤੈ ਸਾਹਿਬ ਕੀ ਮੈ ਸਾਰ ਨ ਜਾਨੀ ॥",
          "roman": "tē sāhib kī mē sār na jānī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Владыка, я не узнала Твоей ценности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33763,
          "is_rahao": true,
          "gurmukhi": "ਜੋਬਨੁ ਖੋਇ ਪਾਛੈ ਪਛੁਤਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "joban khoi pāchhē pachhutānī. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Потеряв время юности, теперь я сожалею. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33764,
          "is_rahao": false,
          "gurmukhi": "ਕਾਲੀ ਕੋਇਲ ਤੂ ਕਿਤ ਗੁਨ ਕਾਲੀ ॥",
          "roman": "kālī koil tū kit gun kālī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О чёрная кукушка, по какой причине ты стала чёрной?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33765,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਪ੍ਰੀਤਮ ਕੇ ਹਉ ਬਿਰਹੈ ਜਾਲੀ ॥",
          "roman": "apne prītam ke hau birhē jālī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Меня сожгла разлука с моим Возлюбленным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33766,
          "is_rahao": false,
          "gurmukhi": "ਪਿਰਹਿ ਬਿਹੂਨ ਕਤਹਿ ਸੁਖੁ ਪਾਏ ॥",
          "roman": "pirah bihūn katah sukh pāe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как может кто-либо найти покой, будучи разлучённым с Супругом?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33767,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਹੋਇ ਕ੍ਰਿਪਾਲੁ ਤਾ ਪ੍ਰਭੂ ਮਿਲਾਏ ॥੨॥",
          "roman": "jā hoi kripāl tā prabhū milāe. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда сам Господь становится милостивым, Он сам соединяет с Собой. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33768,
          "is_rahao": false,
          "gurmukhi": "ਵਿਧਣ ਖੂਹੀ ਮੁੰਧ ਇਕੇਲੀ ॥",
          "roman": "vidhaṇ khūhī muṃdh ikelī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этой страшной колодезной яме мира я, душа-женщина, лежала одна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33769,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕੋ ਸਾਥੀ ਨਾ ਕੋ ਬੇਲੀ ॥",
          "roman": "nā ko sāthī nā ko belī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ни спутника у меня не было, ни помощника в моих страданиях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33770,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਸਾਧਸੰਗਿ ਮੇਲੀ ॥",
          "roman": "kar kirpā prabh sādhsaṅg melī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь, проявив милость, соединил меня с Сатсангом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33771,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਫਿਰਿ ਦੇਖਾ ਤਾ ਮੇਰਾ ਅਲਹੁ ਬੇਲੀ ॥੩॥",
          "roman": "jā phir dekhā tā merā alah belī. ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И когда я взглянула вновь, я увидела, что мой Аллах — мой помощник. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33772,
          "is_rahao": false,
          "gurmukhi": "ਵਾਟ ਹਮਾਰੀ ਖਰੀ ਉਡੀਣੀ ॥",
          "roman": "vāṭ hamārī kharī uḍīṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наш путь жизни очень страшен и исполнен тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33773,
          "is_rahao": false,
          "gurmukhi": "ਖੰਨਿਅਹੁ ਤਿਖੀ ਬਹੁਤੁ ਪਿਈਣੀ ॥",
          "roman": "khanniah tikhī bahut pieṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он острее меча и с очень тонким, острым лезвием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33774,
          "is_rahao": false,
          "gurmukhi": "ਉਸੁ ਊਪਰਿ ਹੈ ਮਾਰਗੁ ਮੇਰਾ ॥",
          "roman": "us ūpar hē mārag merā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И по нему мне предстоит пройти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33775,
          "is_rahao": false,
          "gurmukhi": "ਸੇਖ ਫਰੀਦਾ ਪੰਥੁ ਸਮੑਾਰਿ ਸਵੇਰਾ ॥੪॥੧॥",
          "roman": "sekh pharīdā paṃth samhār saverā. ||4||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шейх Фарид, с ранней поры заботься о своём пути. ||4||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 2989,
      "rahao_verse_id": 33779,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 33776,
          "is_rahao": false,
          "gurmukhi": "ਸੂਹੀ ਲਲਿਤ ॥",
          "roman": "sūhī lalit.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Сухи Лалит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33777,
          "is_rahao": false,
          "gurmukhi": "ਬੇੜਾ ਬੰਧਿ ਨ ਸਕਿਓ ਬੰਧਨ ਕੀ ਵੇਲਾ ॥",
          "roman": "beṛā baṃdh na sakio baṃdhan kī velā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В возрасте, когда нужно было готовить лодку Имени, человек не смог её подготовить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33778,
          "is_rahao": false,
          "gurmukhi": "ਭਰਿ ਸਰਵਰੁ ਜਬ ਊਛਲੈ ਤਬ ਤਰਣੁ ਦੁਹੇਲਾ ॥੧॥",
          "roman": "bhar sarvar jab ūchhalē tab taraṇ duhelā. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда озеро, наполнившись до краёв пороками, начинает переливаться, переплыть его становится трудно. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33779,
          "is_rahao": true,
          "gurmukhi": "ਹਥੁ ਨ ਲਾਇ ਕਸੁੰਭੜੈ ਜਲਿ ਜਾਸੀ ਢੋਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "hath na lāi kasuṃbhaṛē jal jāsī ḍholā. ||1|| rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг, не прикасайся к сафлору-майе: он сгорит, то есть радость майи недолговечна. ||1|| Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33780,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਆਪੀਨੑੈ ਪਤਲੀ ਸਹ ਕੇਰੇ ਬੋਲਾ ॥",
          "roman": "ik āpīnhē patalī sah kere bolā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторые души-женщины, привязавшись к майе, становятся духовно слабыми и получают от Господа-Супруга слова неодобрения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33781,
          "is_rahao": false,
          "gurmukhi": "ਦੁਧਾ ਥਣੀ ਨ ਆਵਈ ਫਿਰਿ ਹੋਇ ਨ ਮੇਲਾ ॥੨॥",
          "roman": "dudhā thaṇī na āvaī phir hoi na melā. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "К ним не приходит состояние супружеского соединения, и после упущенного времени человеческой жизни соединение с Господом уже не происходит. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33782,
          "is_rahao": false,
          "gurmukhi": "ਕਹੈ ਫਰੀਦੁ ਸਹੇਲੀਹੋ ਸਹੁ ਅਲਾਏਸੀ ॥",
          "roman": "kahē pharīd sahelīho sah alāesī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Фарид говорит: о подруги, когда Господь-Супруг пошлёт зов покинуть этот мир,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 33783,
          "is_rahao": false,
          "gurmukhi": "ਹੰਸੁ ਚਲਸੀ ਡੁੰਮਣਾ ਅਹਿ ਤਨੁ ਢੇਰੀ ਥੀਸੀ ॥੩॥੨॥",
          "roman": "haṃs chalasī ḍuṃmaṇā ahi tan ḍherī thīsī. ||3||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "лебедь-душа, охваченный сомнением и привязанностью к майе, уйдёт отсюда, а это тело станет грудой земли. ||3||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
