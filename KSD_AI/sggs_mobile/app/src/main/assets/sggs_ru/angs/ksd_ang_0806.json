        },
        {
          "verse_id": 34296,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਅਨੰਦੁ ਕੀਆ ਪਰਮੇਸਰਿ ਅਪਣਾ ਬਿਰਦੁ ਸਮੑਾਰਿਆ ॥",
          "roman": "sagal anand kīā parmesar apṇā birad samhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਇਹ ਯਕੀਨ ਜਾਣੋ ਕਿ) ਪਰਮਾਤਮਾ ਆਪਣਾ ਮੁੱਢ-ਕਦੀਮਾਂ ਦਾ (ਭਗਤਿ-ਵਛਲ ਹੋਣ ਦਾ) ਸੁਭਾਉ ਸਦਾ ਚੇਤੇ ਰੱਖਦਾ ਹੈ, ਉਹਨਾਂ (ਭਗਤ ਜਨਾਂ) ਨੂੰ ਹਰੇਕ ਕਿਸਮ ਦਾ ਸੁਖ-ਆਨੰਦ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь, помня Свою изначальную природу, дарует Своим преданным всякое блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34297,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਹੋਏ ਕਿਰਪਾਲਾ ਬਿਗਸੇ ਸਭਿ ਪਰਵਾਰਿਆ ॥੧॥",
          "roman": "sādh janā hoe kirpālā bigse sabh parvāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸੰਤ ਜਨਾਂ ਉਤੇ ਸਦਾ ਦਇਆਵਾਨ ਰਹਿੰਦਾ ਹੈ, ਉਹਨਾਂ ਦੇ ਸਾਰੇ ਪਰਵਾਰ (ਸਾਰੇ ਗਿਆਨ-ਇੰਦ੍ਰੇ ਭੀ) ਆਨੰਦ-ਭਰਪੂਰ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он милостив к святым, и все их окружение пребывает в радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34298,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜੁ ਸਤਿਗੁਰਿ ਆਪਿ ਸਵਾਰਿਆ ॥",
          "roman": "kāraj satigur āp savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਲੋਕ ਤਾਂ ਦੇਵੀ ਆਦਿਕ ਦੀ ਪੂਜਾ ਦੀ ਕੋਈ ਪ੍ਰੇਰਨਾ ਕਰਦੇ ਸਨ। ਪਰ ਵੇਖੋ, ਹਰਿਗੋਬਿੰਦ ਨੂੰ ਚੀਚਕ ਦੇ ਤਾਪ ਤੋਂ ਅਰੋਗਤਾ ਦੇਣ ਵਾਲਾ ਇਹ ਵੱਡਾ) ਕੰਮ (ਮੇਰੇ) ਸਤਿਗੁਰੂ ਨੇ ਆਪ ਹੀ ਸਿਰੇ ਚਾੜ੍ਹ ਦਿੱਤਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сатгуру Сам довел это дело до завершения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
