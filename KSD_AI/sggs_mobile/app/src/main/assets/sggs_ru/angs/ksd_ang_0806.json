{
  "ang": 806,
  "shabads": [
    {
      "shabad_id": 3023,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34253,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੀ ਭਈ ਸਿਮਰਿ ਸਿਮਰਿ ਬਿਧਾਤਾ ॥੩॥",
          "roman": "pūrī bhaī simar simar bidhātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਸਿਰਜਣਹਾਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰ ਸਿਮਰ ਕੇ (ਸਿਮਰਨ ਦੀ) ਘਾਲ-ਕਮਾਈ ਸਫਲ ਹੋ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Постоянно помня Создателя, духовные усилия становятся совершенными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34254,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਨਾਨਕਿ ਰੰਗੁ ਮਾਣਿਆ ॥",
          "roman": "sādhsaṅg nānak rang māṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਨਕ ਨੇ (ਤਾਂ) ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Нанак обрел духовное блаженство, пребывая в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34255,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਆਇਆ ਪੂਰੈ ਗੁਰਿ ਆਣਿਆ ॥੪॥੧੨॥੧੭॥",
          "roman": "ghar āiā pūrē gur āṇiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਪਰਮਾਤਮਾ (ਨਾਨਕ ਦੇ) ਹਿਰਦੇ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈ, ਪੂਰੇ ਗੁਰੂ ਨੇ ਲਿਆ ਕੇ ਵਸਾ ਦਿੱਤਾ ਹੈ ॥੪॥੧੨॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "По милости совершенного Гуру Господь пришёл и поселился в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3024,
      "rahao_verse_id": 34257,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34256,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34257,
          "is_rahao": true,
          "gurmukhi": "ਸ੍ਰਬ ਨਿਧਾਨ ਪੂਰਨ ਗੁਰਦੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarab nidhān pūran gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪਿਆਂ ਸਾਰੇ ਖ਼ਜ਼ਾਨਿਆਂ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਮਿਲ ਪੈਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Придя в прибежище совершенного Гуру, обретается Господь — владыка всех сокровищ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34258,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪਤ ਨਰ ਜੀਵੇ ॥",
          "roman": "har har nām japat nar jīve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣ ਨਾਲ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਲੱਭ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Человек, повторяя Имя Бога, обретает духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34259,
          "is_rahao": false,
          "gurmukhi": "ਮਰਿ ਖੁਆਰੁ ਸਾਕਤ ਨਰ ਥੀਵੇ ॥੧॥",
          "roman": "mar khuār sākat nar thīve",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਟੁੱਟੇ ਹੋਏ ਮਨੁੱਖ ਆਤਮਕ ਮੌਤ ਸਹੇੜ ਕੇ ਦੁਖੀ ਹੁੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "А оторванный от Бога человек, претерпевая духовную смерть, становится несчастным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34260,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਹੋਆ ਰਖਵਾਰਾ ॥",
          "roman": "rām nām hoā rakhvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ) ਹਰਿ-ਨਾਮ (ਹਰ ਥਾਂ ਉਸ ਦਾ) ਰਾਖਾ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога становится его защитником повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34261,
          "is_rahao": false,
          "gurmukhi": "ਝਖ ਮਾਰਉ ਸਾਕਤੁ ਵੇਚਾਰਾ ॥੨॥",
          "roman": "jhakh mārau sākat vechārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨਾਲੋਂ ਟੁੱਟਾ ਹੋਇਆ ਮਨੁੱਖ ਵਿਚਾਰਾ (ਉਸ ਦੀ ਨਿੰਦਾ ਆਦਿਕ ਕਰਨ ਵਾਸਤੇ) ਪਿਆ ਝਖਾਂ ਮਾਰੇ (ਉਸ ਦਾ ਕੁਝ ਵਿਗਾੜ ਨਹੀਂ ਸਕਦਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "А оторванный от Бога человек напрасно старается вредить — ничего сделать не может."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34262,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਾ ਕਰਿ ਕਰਿ ਪਚਹਿ ਘਨੇਰੇ ॥",
          "roman": "nindā kar kar pachah ghanere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਬੰਦੇ (ਹਰਿ-ਨਾਮ ਸਿਮਰਨ ਵਾਲੇ ਮਨੁੱਖ ਦੀ) ਨਿੰਦਾ ਕਰ ਕਰ ਕੇ (ਸਗੋਂ) ਖਿੱਝਦੇ (ਹੀ) ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Многие, постоянно порицая, лишь сами изнывают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34263,
          "is_rahao": false,
          "gurmukhi": "ਮਿਰਤਕ ਫਾਸ ਗਲੈ ਸਿਰਿ ਪੈਰੇ ॥੩॥",
          "roman": "mirtak phās galē sir pēre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ) ਮੌਤ ਦੀ ਫਾਹੀ ਉਹਨਾਂ ਦੇ ਗਲ ਵਿਚ ਉਹਨਾਂ ਦੇ ਪੈਰਾਂ ਵਿਚ ਪਈ ਰਹਿੰਦੀ ਹੈ, ਆਤਮਕ ਮੌਤ ਉਹਨਾਂ ਦੇ ਸਿਰ ਉਤੇ ਸਵਾਰ ਰਹਿੰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Петля духовной смерти висит у них на шее, на ногах, смерть властвует над ними."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34264,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਪਹਿ ਜਨ ਨਾਮ ॥",
          "roman": "kah nānak japah jan nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਬੇ-ਸ਼ੱਕ) ਆਖ-ਜੇਹੜੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: те люди, что повторяют Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34265,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੇ ਨਿਕਟਿ ਨ ਆਵੈ ਜਾਮ ॥੪॥੧੩॥੧੮॥",
          "roman": "tā ke nikat na āvē jām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਮ ਭੀ ਉਹਨਾਂ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕ ਸਕਦਾ ॥੪॥੧੩॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "к ним даже Ям не может приблизиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3025,
      "rahao_verse_id": 34271,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34266,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ਘਰੁ ੪ ਦੁਪਦੇ",
          "roman": "rāg bilāval mehlā 5 ghar 4 dupade",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਿਲਾਵਲੁ, ਘਰ ੪ ਵਿੱਚ ਗੁਰੂ ਅਰਜਨਦੇਵ ਜੀ ਦੀ ਦੋ-ਬੰਦਾਂ ਵਾਲੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Билавал, дом 4, двустишия Гуру Арджандева."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34267,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oṅkār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Единый Бог, достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34268,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਸੰਜੋਗ ਮਿਲਉ ਪ੍ਰਭ ਅਪਨੇ ॥",
          "roman": "kavan sanjog milau prabh apne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਹ ਕੇਹੜੇ ਮੁਹੂਰਤ ਹਨ ਜਦੋਂ ਮੈਂ ਆਪਣੇ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਸਕਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! В какой момент я могу встретить своего Господа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34269,
          "is_rahao": false,
          "gurmukhi": "ਪਲੁ ਪਲੁ ਨਿਮਖ ਸਦਾ ਹਰਿ ਜਪਨੇ ॥੧॥",
          "roman": "pal pal nimakh sadā har japne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਲਗਨ ਮੁਹੂਰਤ ਤਾਂ ਹਰ ਵੇਲੇ ਹੀ ਹਨ) ਇਕ ਇਕ ਪਲ, ਅੱਖ ਝਮਕਣ ਜਿਤਨਾ ਸਮਾ ਭਰ ਭੀ ਸਦਾ ਹੀ ਹਰਿ-ਨਾਮ ਜਪਣ ਨਾਲ (ਪਰਮਾਤਮਾ ਨਾਲ ਮਿਲਾਪ ਹੋ ਸਕਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Каждое мгновение, даже на миг — всегда повторяя Имя Бога, можно соединиться с Ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34270,
          "is_rahao": true,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਪ੍ਰਭ ਕੇ ਨਿਤ ਧਿਆਵਉ ॥",
          "roman": "charan kamal prabh ke nit dhiāvao",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਉਹ ਕੇਹੜੀ ਸੁਮਤਿ ਹੈ ਜਿਸ ਦੀ ਰਾਹੀਂ) ਮੈਂ ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਹਰ ਵੇਲੇ ਧਿਆਨ ਧਰਦਾ ਰਹਾਂ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Каким образом я могу постоянно созерцать прекрасные стопы Господа?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34271,
          "is_rahao": true,
          "gurmukhi": "ਕਵਨ ਸੁ ਮਤਿ ਜਿਤੁ ਪ੍ਰੀਤਮੁ ਪਾਵਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kavan su mat jit prītam pāvao",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕੇਹੜੀ ਸੁਚੱਜੀ ਮਤਿ ਹੈ ਜਿਸ ਦੀ ਬਰਕਤ ਨਾਲ ਮੈਂ ਆਪਣੇ ਪਿਆਰੇ ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਸਕਾਂ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Какое это верное понимание, благодаря которому я могу обрести своего Возлюбленного?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34272,
          "is_rahao": false,
          "gurmukhi": "ਐਸੀ ਕ੍ਰਿਪਾ ਕਰਹੁ ਪ੍ਰਭ ਮੇਰੇ ॥",
          "roman": "aisī kirpā karah prabh mere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਪ੍ਰਭੂ ਦੀ ਆਪਣੀ ਹੀ ਮੇਹਰ ਹੋਵੇ, ਤਾਂ ਹੀ ਸਿਮਰਨ ਹੋ ਸਕਦਾ ਹੈ। ਇਸ ਵਾਸਤੇ ਉਸ ਦੇ ਦਰ ਤੇ ਸਦਾ ਅਰਦਾਸ ਕਰੀਏ-) ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! (ਮੇਰੇ ਉਤੇ) ਇਹੋ ਜਿਹੀ ਮੇਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Окажи такую милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34273,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਨਕ ਬਿਸਰੁ ਨ ਕਾਹੂ ਬੇਰੇ ॥੨॥੧॥੧੯॥",
          "roman": "har nānak bisar na kāhū bere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ, ਹੇ ਹਰੀ! ਮੈਨੂੰ ਨਾਨਕ ਨੂੰ ਤੇਰਾ ਨਾਮ ਕਦੇ ਭੀ ਨਾਹ ਭੁੱਲੇ ॥੨॥੧॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы, о Господь, я, Нанак, никогда Тебя не забывал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3026,
      "rahao_verse_id": 34278,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34274,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34275,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਪ੍ਰਭ ਹਿਰਦੈ ਧਿਆਏ ॥",
          "roman": "charan kamal prabh hirdē dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਜਿਸ ਮਨੁੱਖ ਨੇ ਆਪਣੇ) ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਧਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто начал в сердце созерцать прекрасные стопы Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34276,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗ ਗਏ ਸਗਲੇ ਸੁਖ ਪਾਏ ॥੧॥",
          "roman": "rog gae sagle sukh pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਰੋਗ ਦੂਰ ਹੋ ਗਏ, ਉਸ ਨੇ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਕਰ ਲਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "у того исчезли все болезни, и он обрел все блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34277,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਿ ਦੁਖੁ ਕਾਟਿਆ ਦੀਨੋ ਦਾਨੁ ॥",
          "roman": "gur dukh kāṭiā dīno dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਨੇ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ) ਦਾਤ ਦੇ ਦਿੱਤੀ, ਉਸ ਦਾ ਸਾਰਾ ਦੁੱਖ ਭੀ ਗੁਰੂ ਨੇ ਦੂਰ ਕਰ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру, даровав Имя Бога, устранил все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34278,
          "is_rahao": true,
          "gurmukhi": "ਸਫਲ ਜਨਮੁ ਜੀਵਨ ਪਰਵਾਨੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "safal janam jīvan parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਕਾਮਯਾਬ ਹੋ ਗਈ, (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਉਸ ਦਾ ਜੀਵਨ ਕਬੂਲ ਹੋ ਗਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Жизнь стала успешной, и она была принята."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34279,
          "is_rahao": false,
          "gurmukhi": "ਅਕਥ ਕਥਾ ਅੰਮ੍ਰਿਤ ਪ੍ਰਭ ਬਾਨੀ ॥",
          "roman": "akath kathā amrit prabh bānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੇਅੰਤ ਗੁਣਾਂ ਦੇ ਮਾਲਕ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਵਾਲੀ ਬਾਣੀ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Божественное Слово — это невыразимая речь, дающая духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34280,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਪਿ ਜੀਵੇ ਗਿਆਨੀ ॥੨॥੨॥੨੦॥",
          "roman": "kah nānak jap jīve giānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-  ਪ੍ਰਭੂ ਨਾਲ ਡੂੰਘੀ ਜਾਣ-ਪਛਾਣ ਵਾਲਾ ਮਨੁੱਖ ਪ੍ਰਭੂ ਦੇ ਗੁਣਾਂ ਨੂੰ ਚੇਤੇ ਕਰ ਕਰ ਕੇ ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ ॥੨॥੨॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: знающий, помня Бога, обретает духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3027,
      "rahao_verse_id": 34283,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34281,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34282,
          "is_rahao": true,
          "gurmukhi": "ਸਾਂਤਿ ਪਾਈ ਗੁਰਿ ਸਤਿਗੁਰਿ ਪੂਰੇ ॥",
          "roman": "sānt pāī gur satigur pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰੇ ਗੁਰੂ ਨੇ, ਸਤਿਗੁਰੂ ਨੇ (ਹਰਿ-ਨਾਮ ਦੀ ਦਾਤ ਦੇ ਕੇ ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਠੰਡ ਵਰਤਾ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Сатгуру даровал покой в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34283,
          "is_rahao": true,
          "gurmukhi": "ਸੁਖ ਉਪਜੇ ਬਾਜੇ ਅਨਹਦ ਤੂਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sukh upje bāje anhad tūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਸਾਰੇ ਸੁਖ ਪੈਦਾ ਹੋ ਗਏ (ਮਾਨੋ, ਉਸ ਦੇ ਅੰਦਰ) ਇਕ-ਰਸ ਸਾਰੇ ਵਾਜੇ ਵੱਜਣ ਲੱਗ ਪਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Внутри возникли все радости, словно зазвучали непрерывные божественные звуки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34284,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪ ਪਾਪ ਸੰਤਾਪ ਬਿਨਾਸੇ ॥",
          "roman": "tāp pāp santāp bināse",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਸਿਮਰਦਿਆਂ ਉਸ ਦੇ ਮਨੁੱਖ ਸਾਰੇ ਪਾਪ ਨਾਸ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Все грехи исчезли,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34285,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਕਿਲਵਿਖ ਸਭਿ ਨਾਸੇ ॥੧॥",
          "roman": "har simrat kilvikh sabh nāse",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਨੇ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਹਰਿ-ਨਾਮ ਸਿਮਰਨਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ, ਉਸ ਦੇ ਸਾਰੇ) ਦੁੱਖ ਕਲੇਸ਼ ਦੂਰ ਹੋ ਗਏ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "при поминании Бога исчезли все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34286,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦੁ ਕਰਹੁ ਮਿਲਿ ਸੁੰਦਰ ਨਾਰੀ ॥",
          "roman": "anand karah mil sundar nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਸੋਹਣੇ (ਬਣ ਚੁਕੇ) ਹੇ ਮੇਰੇ ਗਿਆਨ-ਇੰਦ੍ਰਿਓ! ਤੁਸੀਂ ਹੁਣ ਰਲ ਕੇ (ਸਤਸੰਗ ਮਨਾ ਕੇ ਆਪਣੇ ਅੰਦਰ) ਆਤਮਕ ਆਨੰਦ ਪੈਦਾ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "О прекрасные чувства! Соединившись, создавайте духовную радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34287,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਨਾਨਕਿ ਮੇਰੀ ਪੈਜ ਸਵਾਰੀ ॥੨॥੩॥੨੧॥",
          "roman": "gur nānak merī pēj savārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨਾਨਕ ਨੇ (ਮੈਨੂੰ ਤਾਪ ਪਾਪ ਸੰਤਾਪ ਤੋਂ ਬਚਾ ਕੇ) ਮੇਰੀ ਇੱਜ਼ਤ ਰੱਖ ਲਈ ਹੈ ॥੨॥੩॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "Гуру Нанак сохранил мою честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3028,
      "rahao_verse_id": 34292,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34288,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34289,
          "is_rahao": false,
          "gurmukhi": "ਮਮਤਾ ਮੋਹ ਧ੍ਰੋਹ ਮਦਿ ਮਾਤਾ ਬੰਧਨਿ ਬਾਧਿਆ ਅਤਿ ਬਿਕਰਾਲ ॥",
          "roman": "mamtā moh dhroh mad mātā bandhan bādhia at bikrāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਫਸ ਕੇ ਜੀਵ) ਅਪਣੱਤ ਦੇ ਮਦ ਵਿਚ, ਮੋਹ ਦੇ ਨਸ਼ੇ ਵਿਚ, ਠੱਗੀ-ਚਾਲਾਕੀ ਦੇ ਮਦ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ। ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਜਕੜ ਨਾਲ ਬੱਝਾ ਹੋਇਆ ਜੀਵ ਬੜੇ ਡਰਾਉਣੇ ਜੀਵਨ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Существо опьянено эгоизмом, привязанностью и обманом, сковано узами иллюзии и становится страшным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34290,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨੁ ਦਿਨੁ ਛਿਜਤ ਬਿਕਾਰ ਕਰਤ ਅਉਧ ਫਾਹੀ ਫਾਥਾ ਜਮ ਕੈ ਜਾਲ ॥੧॥",
          "roman": "din din chhijat bikār karat audh fāhī fāthā jam kē jāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰ ਰੋਜ਼ ਵਿਕਾਰ ਕਰਦਿਆਂ ਇਸ ਦੀ ਉਮਰ ਘਟਦੀ ਜਾਂਦੀ ਹੈ, ਇਹ ਜਮ ਦੀ ਫਾਹੀ ਵਿਚ ਜਮ ਦੇ ਜਾਲ ਵਿਚ ਸਦਾ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "День за днем, совершая пороки, жизнь убывает, и оно постоянно поймано в сеть Ямы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34291,
          "is_rahao": true,
          "gurmukhi": "ਤੇਰੀ ਸਰਣਿ ਪ੍ਰਭ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "terī saran prabh dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О милостивый к бедным Господь! Я пришел в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34292,
          "is_rahao": true,
          "gurmukhi": "ਮਹਾ ਬਿਖਮ ਸਾਗਰੁ ਅਤਿ ਭਾਰੀ ਉਧਰਹੁ ਸਾਧੂ ਸੰਗਿ ਰਵਾਲਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mahā bikham sāgar ati bhārī udharah sādhū sang ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ (ਸੰਸਾਰ-) ਸਮੁੰਦਰ ਬਹੁਤ ਵੱਡਾ ਹੈ, (ਇਸ ਵਿਚੋਂ ਪਾਰ ਲੰਘਣਾ) ਬੜਾ ਔਖਾ ਹੈ। ਹੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ (ਰੱਖ ਕੇ) ਮੈਨੂੰ ਗੁਰੂ ਦੀ ਚਰਨ-ਧੂੜ ਦੇ ਕੇ ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ ਡੁੱਬਣੋਂ) ਬਚਾ ਲੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Этот океан мира очень велик и труден; спаси меня, удерживая в обществе святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34293,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸੁਖਦਾਤੇ ਸਮਰਥ ਸੁਆਮੀ ਜੀਉ ਪਿੰਡੁ ਸਭੁ ਤੁਮਰਾ ਮਾਲ ॥",
          "roman": "prabh sukhdāte samrath suāmī jīo piṇḍ sabh tumrā māl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਸੁਖ ਦੇਣ ਵਾਲੇ ਪ੍ਰਭੂ! ਹੇ ਸਭ ਤਾਕਤਾਂ ਦੇ ਮਾਲਕ ਸੁਆਮੀ! (ਜੀਵਾਂ ਨੂੰ ਮਿਲੇ ਹੋਏ) ਇਹ ਜਿੰਦ ਤੇ ਸਰੀਰ ਸਭ ਕੁਝ ਤੇਰਾ ਹੀ ਦਿੱਤਾ ਹੋਇਆ ਸਰਮਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, дарующий счастье, всемогущий Владыка! Душа и тело — всё Твое достояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34294,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮ ਕੇ ਬੰਧਨ ਕਾਟਹੁ ਪਰਮੇਸਰ ਨਾਨਕ ਕੇ ਪ੍ਰਭ ਸਦਾ ਕ੍ਰਿਪਾਲ ॥੨॥੪॥੨੨॥",
          "roman": "bhram ke bandhan kāṭah parmesar nānak ke prabh sadā kripāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ ਦੇ ਪ੍ਰਭੂ! ਹੇ ਸਦਾ ਕਿਰਪਾਲ ਪ੍ਰਭੂ! ਹੇ ਪਰਮੇਸਰ! (ਜੀਵ ਮਾਇਆ ਵਿਚ ਭਟਕ ਰਹੇ ਹਨ, ਜੀਵਾਂ ਦੇ ਇਹ) ਭਟਕਣਾ ਦੇ ਬੰਧਨ ਕੱਟ ਦੇਹ ॥੨॥੪॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "О милостивый Господь Нанака! Разруби узы заблуждения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
