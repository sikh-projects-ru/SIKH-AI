{
  "ang": 817,
  "shabads": [
    {
      "shabad_id": 3069,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34708,
          "is_rahao": false,
          "gurmukhi": "ਤੋਟਿ ਨ ਆਵੈ ਕਦੇ ਮੂਲਿ ਪੂਰਨ ਭੰਡਾਰ ॥",
          "roman": "ṭoṭ na āvē kadē mūl pūran bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В полных сокровищницах никогда, совсем, не бывает недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34709,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਮਨਿ ਤਨਿ ਬਸੇ ਪ੍ਰਭ ਅਗਮ ਅਪਾਰ ॥੨॥",
          "roman": "charaṇ kamal man tan basē prabh agam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лотосные стопы недостижимого, бесконечного Господа пребывают в уме и теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34710,
          "is_rahao": false,
          "gurmukhi": "ਬਸਤ ਕਮਾਵਤ ਸਭਿ ਸੁਖੀ ਕਿਛੁ ਊਨ ਨ ਦੀਸੈ ॥",
          "roman": "basat kamāvat sabh sukhī kichh ūn na dīsē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живя и трудясь, все пребывают в счастье; никакого недостатка не видно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34711,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਭੇਟੇ ਪ੍ਰਭੂ ਪੂਰਨ ਜਗਦੀਸੈ ॥੩॥",
          "roman": "sant prasād bheṭē prabhū pūran jagdīsē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости святых встретили Господа, совершенного Владыку мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34712,
          "is_rahao": false,
          "gurmukhi": "ਜੈ ਜੈ ਕਾਰੁ ਸਭੈ ਕਰਹਿ ਸਚੁ ਥਾਨੁ ਸੁਹਾਇਆ ॥",
          "roman": "jē jē kār sabhē karah sach thān suhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все возглашают славу; истинное место стало прекрасным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34713,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਨਾਨਕ ਨਾਮੁ ਨਿਧਾਨ ਸੁਖ ਪੂਰਾ ਗੁਰੁ ਪਾਇਆ ॥੪॥੩੩॥੬੩॥",
          "roman": "jap Nānak nām nidhān sukh pūrā gur pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: воспевая Имя, сокровищницу счастья, обрёл совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3070,
      "rahao_verse_id": 34716,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34714,
          "is_rahao": true,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34715,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਹਰਿ ਆਰਾਧੀਐ ਹੋਈਐ ਆਰੋਗ ॥",
          "roman": "har har har ārādhīai hoīai ārog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нужно всегда вспоминать Имя Бога; благодаря этому становишься свободным от болезней, то есть от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34716,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮਚੰਦ ਕੀ ਲਸਟਿਕਾ ਜਿਨਿ ਮਾਰਿਆ ਰੋਗੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Rāmchand kī lasṭikā jin māriā rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это вспоминание — словно посох Шри Рамчандра; оно уничтожает всякую внутреннюю болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34717,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਹਰਿ ਜਾਪੀਐ ਨਿਤ ਕੀਚੈ ਭੋਗੁ ॥",
          "roman": "gur pūrā har jāpīē nit kīchē bhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следует искать прибежище у совершенного Гуру и повторять Имя Господа; так всегда можно вкушать духовное блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34718,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕੈ ਵਾਰਣੈ ਮਿਲਿਆ ਸੰਜੋਗੁ ॥੧॥",
          "roman": "sādhsangat kē vāraṇē miliā sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нужно жертвенно склониться перед Садхсангат; по его милости появляется возможность соединения с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34719,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਸੁਖੁ ਪਾਈਐ ਬਿਨਸੈ ਬਿਓਗੁ ॥",
          "roman": "jis simrat sukh pāīē binsē biog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вспоминая Его, обретают духовное блаженство, и разлука с Господом исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34720,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਗਤੀ ਕਰਣ ਕਾਰਣ ਜੋਗੁ ॥੨॥੩੪॥੬੪॥",
          "roman": "Nānak prabh sarṇāgatī karaṇ kāraṇ jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: следует пребывать в прибежище Господа, способного создать весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3071,
      "rahao_verse_id": 34726,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34721,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ਦੁਪਦੇ ਘਰੁ ੫",
          "roman": "rāg bilāval mahallā 5 dupadē ghar 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Билавал, Махала 5, дупаде, дом 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34722,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34723,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰਿ ਉਪਾਵ ਸਭਿ ਤਿਆਗਿਆ ਦਾਰੂ ਨਾਮੁ ਲਇਆ ॥",
          "roman": "avar upāv sabh tiāgiā dārū nām laiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек оставил все прочие средства и принял Имя Бога как лекарство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34724,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪ ਪਾਪ ਸਭਿ ਮਿਟੇ ਰੋਗ ਸੀਤਲ ਮਨੁ ਭਇਆ ॥੧॥",
          "roman": "tāp pāp sabh miṭē rog sītal man bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все его страдания, грехи и болезни исчезли; его ум, спасённый от жара пороков, стал прохладно-спокойным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34725,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਆਰਾਧਿਆ ਸਗਲਾ ਦੁਖੁ ਗਇਆ ॥",
          "roman": "gur pūrā ārādhiā saglā dukh gaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто хранит совершенного Гуру в своём сердце, у того уходит всякое страдание и скорбь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34726,
          "is_rahao": true,
          "gurmukhi": "ਰਾਖਨਹਾਰੈ ਰਾਖਿਆ ਅਪਨੀ ਕਰਿ ਮਇਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rākhanhārē rākhiā apnī kar mēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Способный защищать Господь, проявив милость, всегда оберегает его от страданий и скорбей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34727,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹ ਪਕੜਿ ਪ੍ਰਭਿ ਕਾਢਿਆ ਕੀਨਾ ਅਪਨਇਆ ॥",
          "roman": "bāh pakaṛ prabh kāḍhiā kīnā apnaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь взял его за руку, вывел его и сделал своим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34728,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਮਨ ਤਨ ਸੁਖੀ ਨਾਨਕ ਨਿਰਭਇਆ ॥੨॥੧॥੬੫॥",
          "roman": "simar simar man tan sukhī Nānak nirbhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: снова и снова вспоминая Имя Господа, его ум и сердце наполнились блаженством, и в нём не осталось страха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3072,
      "rahao_verse_id": 34733,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34729,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34730,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਧਰਿ ਮਸਤਕਿ ਥਾਪਿਆ ਨਾਮੁ ਦੀਨੋ ਦਾਨਿ ॥",
          "roman": "kar dhar mastak thāpiā nām dīno dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь кладёт руку на чело своих преданных, утверждает их и даром даёт им своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34731,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਸੇਵਾ ਪਾਰਬ੍ਰਹਮ ਕੀ ਤਾ ਕੀ ਨਹੀ ਹਾਨਿ ॥੧॥",
          "roman": "safal sēvā pārbrahm kī tā kī nahī hān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Служение Парабрахму исполняет цель жизни; такое служение не пропадает впустую."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34732,
          "is_rahao": true,
          "gurmukhi": "ਆਪੇ ਹੀ ਪ੍ਰਭੁ ਰਾਖਤਾ ਭਗਤਨ ਕੀ ਆਨਿ ॥",
          "roman": "āpē hī prabh rākhtā bhagtan kī ān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь сам сохраняет честь своих преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34733,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਜੋ ਚਿਤਵਹਿ ਸਾਧ ਜਨ ਸੋ ਲੇਤਾ ਮਾਨਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo jo chitvah sādh jan so lētā mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что бы святые люди ни держали в уме, Господь принимает это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34734,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਪਰੇ ਚਰਣਾਰਬਿੰਦ ਜਨ ਪ੍ਰਭ ਕੇ ਪ੍ਰਾਨ ॥",
          "roman": "saraṇ parē charaṇārbind jan prabh kē prān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святые, принимающие прибежище у прекрасных лотосных стоп Господа, становятся Ему дороги как сама жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34735,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਸੁਭਾਇ ਨਾਨਕ ਮਿਲੇ ਜੋਤੀ ਜੋਤਿ ਸਮਾਨ ॥੨॥੨॥੬੬॥",
          "roman": "sahaj subhāi Nānak milē jotī jot samān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: пребывая в духовной устойчивости и любви, они соединяются с Господом, и их душа сливается с Его Светом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3073,
      "rahao_verse_id": 34740,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34736,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34737,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਕਾ ਆਸਰਾ ਦੀਨੋ ਪ੍ਰਭਿ ਆਪਿ ॥",
          "roman": "charaṇ kamal kā āsrā dīno prabh āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем служителям Господь сам дал прибежище своих прекрасных лотосных стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34738,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਰਣਾਗਤਿ ਜਨ ਪਰੇ ਤਾ ਕਾ ਸਦ ਪਰਤਾਪੁ ॥੧॥",
          "roman": "prabh sarṇāgat jan parē tā kā sad partāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Видя Его вечно пребывающее величие, эти служители остаются в прибежище Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34739,
          "is_rahao": true,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਅਪਾਰ ਪ੍ਰਭ ਤਾ ਕੀ ਨਿਰਮਲ ਸੇਵ ॥",
          "roman": "rākhanhār apār prabh tā kī nirmal sēv",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь бесконечен и способен защищать; служение Ему делает жизнь чистой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34740,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਰਾਜ ਰਾਮਦਾਸ ਪੁਰਿ ਕੀਨੑੇ ਗੁਰਦੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Rām rāj Rāmdās pur kīnhe gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурдев установил духовное царство в Рамдаспуре, то есть в Садхсангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34741,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਹਰਿ ਧਿਆਈਐ ਕਿਛੁ ਬਿਘਨੁ ਨ ਲਾਗੈ ॥",
          "roman": "sadā sadā har dhiāīē kichh bighan na lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда следует сосредоточиваться на Господе; тогда на пути жизни не возникает препятствий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34742,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਸਲਾਹੀਐ ਭਇ ਦੁਸਮਨ ਭਾਗੈ ॥੨॥੩॥੬੭॥",
          "roman": "Nānak nām salāhīē bhē dusman bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: следует прославлять Имя Бога; из страха перед Господом все враги, такие как страсть и прочие пороки, убегают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3074,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 34743,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੫ ॥",
          "roman": "bilāval mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Билавал, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34744,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਪ੍ਰਭੁ ਆਰਾਧੀਐ ਮਿਲਿ ਸਾਧ ਸਮਾਗੈ ॥",
          "roman": "man tan prabh ārādhīē mil sādh samāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Садхсангат следует всем умом и сердцем совершать поклонное вспоминание Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34745,
          "is_rahao": false,
          "gurmukhi": "ਉਚਰਤ ਗੁਨ ਗੋਪਾਲ ਜਸੁ ਦੂਰ ਤੇ ਜਮੁ ਭਾਗੈ ॥੧॥",
          "roman": "uchrat gun Gopāl jas dūr tē jam bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда произносят качества и славу Господа, Защитника мира, даже Джам убегает издалека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 34746,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਜੋ ਜਨੁ ਜਪੈ ਅਨਦਿਨੁ ਸਦ ਜਾਗੈ ॥",
          "roman": "Rām nām jo jan japē andin sad jāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, который повторяет Имя Господа, всё время остаётся бодрствующим и внимательным к порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
