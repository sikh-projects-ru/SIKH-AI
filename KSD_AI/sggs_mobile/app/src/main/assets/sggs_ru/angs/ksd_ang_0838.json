{
  "ang": 838,
  "shabads": [
    {
      "shabad_id": 3149,
      "rahao_verse_id": 35489,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35486,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਦਇਆ ਲੇਹੁ ਲੜਿ ਲਾਇ ॥",
          "roman": "kar dayā leh laṛ lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਆਪਣੇ ਲੜ ਨਾਲ ਲਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "Смилуйся и привяжи меня к Своему краю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35487,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕਾ ਨਾਮੁ ਧਿਆਇ ॥੧॥",
          "roman": "nānakā nām dhiāi.1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Созерцай Имя Господа. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35488,
          "is_rahao": true,
          "gurmukhi": "ਦੀਨਾ ਨਾਥ ਦਇਆਲ ਮੇਰੇ ਸੁਆਮੀ ਦੀਨਾ ਨਾਥ ਦਇਆਲ ॥",
          "roman": "dīnā nāth dayāl mere suāmī dīnā nāth dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗ਼ਰੀਬਾਂ ਦੇ ਖਸਮ! ਹੇ ਦਇਆ ਦੇ ਸੋਮੇ! ਹੇ ਮੇਰੇ ਸੁਆਮੀ! ਹੇ ਦੀਨਾ ਨਾਥ! ਹੇ ਦਇਆਲ!"
            },
            "sahib_singh_ru": {
              "main": "О Владыка бедных! О Источник милости! О мой Господин! О Владыка бедных! О Милосердный!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35489,
          "is_rahao": true,
          "gurmukhi": "ਜਾਚਉ ਸੰਤ ਰਵਾਲ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jāchau sant ravāl.1. rahāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੇ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Я прошу пыль у стоп Твоих святых. ||1|| Пауза ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35490,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰੁ ਬਿਖਿਆ ਕੂਪ ॥",
          "roman": "sansār bikhia kūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਜਗਤ ਮਾਇਆ (ਦੇ ਮੋਹ) ਦਾ ਖੂਹ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот мир — колодец майи и привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35491,
          "is_rahao": false,
          "gurmukhi": "ਤਮ ਅਗਿਆਨ ਮੋਹਤ ਘੂਪ ॥",
          "roman": "tam agiān mohat ghūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ ਬੇ-ਸਮਝੀ ਦਾ ਘੁੱਪ ਹਨੇਰਾ (ਮੈਨੂੰ) ਮੋਹ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "густая тьма неведения к духовной жизни околдовывает меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35492,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿ ਭੁਜਾ ਪ੍ਰਭ ਜੀ ਲੇਹੁ ॥",
          "roman": "gah bhujā prabh jī leh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੀ) ਬਾਂਹ ਫੜ ਕੇ (ਮੈਨੂੰ) ਬਚਾ ਲੈ"
            },
            "sahib_singh_ru": {
              "main": "Возьми меня за руку и спаси."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35493,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਅਪੁਨਾ ਦੇਹੁ ॥",
          "roman": "har nām apunā deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼!"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Даруй мне Своё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35494,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਤੁਝ ਬਿਨਾ ਨਹੀ ਠਾਉ ॥",
          "roman": "prabh tujh binā nahī ṭhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਥੋਂ ਬਿਨਾ ਮੇਰਾ ਕੋਈ ਹੋਰ ਆਸਰਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя, у меня нет никакой иной опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35495,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕਾ ਬਲਿ ਬਲਿ ਜਾਉ ॥੨॥",
          "roman": "nānakā bal bal jāu.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਪ੍ਰਭੂ ਦੇ ਦਰ ਤੇ ਅਰਦਾਸ ਕਰ, ਤੇ, ਆਖ-) ਹੇ ਪ੍ਰਭੂ! ਮੈਂ (ਤੇਰੇ ਨਾਮ ਤੋਂ) ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, молись у двери Господа и говори: О Господь! Я жертвую собой ради Твоего Имени, я иду в жертву снова и снова. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35496,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭਿ ਮੋਹਿ ਬਾਧੀ ਦੇਹ ॥",
          "roman": "lobh moh bādhī deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਸਰੀਰ ਲੋਭ ਵਿਚ ਮੋਹ ਵਿਚ ਬੱਝਾ ਪਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Моё тело связано жадностью и привязанностью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35497,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਭਜਨ ਹੋਵਤ ਖੇਹ ॥",
          "roman": "bin bhajan hovat kheh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ) ਭਜਨ ਕਰਨ ਤੋਂ ਬਿਨਾ ਮਿੱਟੀ ਹੁੰਦਾ ਜਾ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и без Твоего бхажана оно обращается в прах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35498,
          "is_rahao": false,
          "gurmukhi": "ਜਮਦੂਤ ਮਹਾ ਭਇਆਨ ॥",
          "roman": "jamdūt mahā bhaiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਨੂੰ) ਜਮਦੂਤ ਬੜੇ ਡਰਾਉਣੇ (ਲੱਗ ਰਹੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Ямдуты кажутся мне очень страшными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35499,
          "is_rahao": false,
          "gurmukhi": "ਚਿਤ ਗੁਪਤ ਕਰਮਹਿ ਜਾਨ ॥",
          "roman": "chit gupt karmah jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚਿੱਤ੍ਰ ਗੁਪਤ (ਮੇਰੇ) ਕਰਮਾਂ ਨੂੰ ਜਾਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Читр Гупт знает мои дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35500,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨੁ ਰੈਨਿ ਸਾਖਿ ਸੁਨਾਇ ॥",
          "roman": "din rēn sākh sunāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਿਨ ਅਤੇ ਰਾਤ (ਇਹ ਭੀ ਮੇਰੇ ਕਰਮਾਂ ਦੀ) ਗਵਾਹੀ ਦੇ ਕੇ (ਇਹੀ ਕਹਿ ਰਹੇ ਹਨ ਕਿ ਮੈਂ ਮੰਦ-ਕਰਮੀ ਹਾਂ)"
            },
            "sahib_singh_ru": {
              "main": "День и ночь тоже свидетельствуют о моих поступках и говорят, что я дурно поступающий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35501,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕਾ ਹਰਿ ਸਰਨਾਇ ॥੩॥",
          "roman": "nānakā har sarnāi.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਹੇ ਹਰੀ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: О Хари! Я пришёл в Твоё прибежище. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35502,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਭੰਜਨਾ ਮੁਰਾਰਿ ॥",
          "roman": "bhē bhanjnā murār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਾਰੇ ਡਰਾਂ ਦੇ ਨਾਸ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О Господь, разрушающий все страхи!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35503,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਦਇਆ ਪਤਿਤ ਉਧਾਰਿ ॥",
          "roman": "kar dayā patit udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ (ਮੈਨੂੰ) ਵਿਕਾਰੀ ਨੂੰ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲੈ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Своей спаси меня, порочного, от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35504,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੇ ਦੋਖ ਗਨੇ ਨ ਜਾਹਿ ॥",
          "roman": "mere dokh gane na jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਵਿਕਾਰ ਗਿਣੇ ਨਹੀਂ ਜਾ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Мои пороки невозможно сосчитать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35505,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਬਿਨਾ ਕਤਹਿ ਸਮਾਹਿ ॥",
          "roman": "har binā kateh samāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਤੈਥੋਂ ਬਿਨਾ ਹੋਰ ਕਿਸੇ ਦਰ ਤੇ ਭੀ ਇਹ ਬਖ਼ਸ਼ੇ ਨਹੀਂ ਜਾ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "О Хари! Кроме Тебя, ни у какой другой двери они не могут быть прощены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35506,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿ ਓਟ ਚਿਤਵੀ ਨਾਥ ॥",
          "roman": "gah oṭ chitvī nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਥ! ਮੈਂ ਤੇਰਾ ਆਸਰਾ ਹੀ ਸੋਚਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Владыка! Я помыслил лишь о Твоей защите,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35507,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕਾ ਦੇ ਰਖੁ ਹਾਥ ॥੪॥",
          "roman": "nānakā de rakh hāth.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਹਰੀ! ਮੇਰੀ ਬਾਂਹ) ਫੜ ਲੈ, (ਆਪਣਾ) ਹੱਥ ਦੇ ਕੇ ਮੇਰੀ ਰੱਖਿਆ ਕਰ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: О Хари! Возьми меня за руку, дай Свою руку и защити меня. ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35508,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਗੁਣ ਨਿਧੇ ਗੋਪਾਲ ॥",
          "roman": "har guṇ nidhe gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! ਹੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ! ਹੇ ਧਰਤੀ ਦੇ ਰੱਖਿਅਕ!"
            },
            "sahib_singh_ru": {
              "main": "О Хари! О сокровищница добродетелей! О хранитель земли!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35509,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਘਟ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "sarab ghaṭ pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਸਰੀਰਾਂ ਦੇ ਪਾਲਣਹਾਰ!"
            },
            "sahib_singh_ru": {
              "main": "О питающий все тела!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35510,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਪ੍ਰੀਤਿ ਦਰਸਨ ਪਿਆਸ ॥",
          "roman": "man prīt darsan piās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ) ਮਨ ਵਿਚ (ਤੇਰੀ) ਪ੍ਰੀਤ (ਬਣੀ ਰਹੇ, ਤੇਰੇ) ਦਰਸਨ ਦੀ ਤਾਂਘ (ਬਣੀ ਰਹੇ),"
            },
            "sahib_singh_ru": {
              "main": "Пусть в моём сердце сохраняется любовь к Тебе и жажда Твоего даршана,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35511,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਪੂਰਨ ਆਸ ॥",
          "roman": "gobind pūran ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੋਬਿੰਦ! (ਮੇਰੇ ਮਨ ਦੀ) ਆਸ ਪੂਰੀ ਕਰ!"
            },
            "sahib_singh_ru": {
              "main": "О Гобинд! Исполни надежду моего сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35512,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਨਿਮਖ ਰਹਨੁ ਨ ਜਾਇ ॥",
          "roman": "ik nimakh rahan na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਦਰਸਨ ਤੋਂ ਬਿਨਾ ਮੈਥੋਂ) ਇਕ ਪਲ ਭਰ ਭੀ ਰਿਹਾ ਨਹੀਂ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без Твоего даршана я не могу прожить даже одного мгновения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35513,
          "is_rahao": false,
          "gurmukhi": "ਵਡ ਭਾਗਿ ਨਾਨਕ ਪਾਇ ॥੫॥",
          "roman": "vaḍ bhāg nānak pāi.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਹੀ ਕੋਈ (ਤੇਰਾ) ਮਿਲਾਪ ਪ੍ਰਾਪਤ ਕਰਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: лишь по великой судьбе кто-либо обретает встречу с Тобой. ||5||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35514,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਤੁਝ ਬਿਨਾ ਨਹੀ ਹੋਰ ॥",
          "roman": "prabh tujh binā nahī hor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਬਿਨਾ (ਮੇਰਾ ਕੋਈ) ਹੋਰ (ਆਸਰਾ) ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Кроме Тебя, у меня нет иного прибежища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35515,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਪ੍ਰੀਤਿ ਚੰਦ ਚਕੋਰ ॥",
          "roman": "man prīt chand chakor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰੇ) ਮਨ ਵਿਚ (ਤੇਰੇ ਚਰਨਾਂ ਦੀ) ਪ੍ਰੀਤ ਹੈ (ਜਿਵੇਂ) ਚਕੋਰ ਨੂੰ ਚੰਦ ਨਾਲ ਪਿਆਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В моём сердце любовь к Твоим стопам, как у чакора любовь к луне,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35516,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮੀਨ ਜਲ ਸਿਉ ਹੇਤੁ ॥",
          "roman": "jiu mīn jal siu het",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਛਲੀ ਦਾ ਪਾਣੀ ਨਾਲ ਪਿਆਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как у рыбы любовь к воде,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35517,
          "is_rahao": false,
          "gurmukhi": "ਅਲਿ ਕਮਲ ਭਿੰਨੁ ਨ ਭੇਤੁ ॥",
          "roman": "al kamal bhinn na bhet",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਵੇਂ) ਭੌਰ ਦਾ ਕੌਲ ਫੁੱਲ ਨਾਲੋਂ ਕੋਈ ਫ਼ਰਕ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "как шмель уже неотделим от цветка лотоса,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35518,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਚਕਵੀ ਸੂਰਜ ਆਸ ॥",
          "roman": "jiu chakvī sūraj ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਚਕਵੀ ਨੂੰ ਸੂਰਜ (ਦੇ ਚੜ੍ਹਨ) ਦੀ ਉਡੀਕ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как чакви постоянно ожидает восхода солнца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35519,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਚਰਨ ਪਿਆਸ ॥੬॥",
          "roman": "nānak charan piās.6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ- ਇਸੇ ਤਰ੍ਹਾਂ, ਹੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਤੇਰੇ) ਚਰਨਾਂ ਦੀ ਤਾਂਘ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: так и я жажду Твоих стоп. ||6||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35520,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਤਰੁਨਿ ਭਰਤ ਪਰਾਨ ॥",
          "roman": "jiu tarun bharat parān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਜੁਆਨ ਇਸਤ੍ਰੀ ਨੂੰ (ਆਪਣਾ) ਖਸਮ ਬਹੁਤ ਪਿਆਰਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как для молодой женщины её муж очень дорог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35521,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਲੋਭੀਐ ਧਨੁ ਦਾਨੁ ॥",
          "roman": "jiu lobhīai dhan dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਲਾਲਚੀ ਮਨੁੱਖ ਨੂੰ ਧਨ-ਪ੍ਰਾਪਤੀ (ਤੋਂ ਖ਼ੁਸ਼ੀ ਹੁੰਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "как жадному человеку доставляет радость приобретение богатства,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35522,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਦੂਧ ਜਲਹਿ ਸੰਜੋਗੁ ॥",
          "roman": "jiu dūdh jaleh sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਦੁੱਧ ਦਾ ਪਾਣੀ ਨਾਲ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как молоко соединяется с водой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35523,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮਹਾ ਖੁਧਿਆਰਥ ਭੋਗੁ ॥",
          "roman": "jiu mahā khudhiārath bhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਬਹੁਤ ਭੁੱਖੇ ਨੂੰ ਭੋਜਨ (ਤ੍ਰਿਪਤ ਕਰਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "как очень голодного насыщает пища,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35524,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮਾਤ ਪੂਤਹਿ ਹੇਤੁ ॥",
          "roman": "jiu māt pūteh het",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਾਂ ਦਾ ਪੁੱਤਰ ਨਾਲ ਪਿਆਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как мать любит сына,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35525,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਿ ਨਾਨਕ ਨੇਤ ॥੭॥",
          "roman": "har simar nānak net.7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ) ਤਿਵੇਂ ਸਦਾ ਪਰਮਾਤਮਾ ਨੂੰ (ਪਿਆਰ ਨਾਲ) ਸਿਮਰਿਆ ਕਰ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: так же всегда с любовью помни Бога. ||7||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35526,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਦੀਪ ਪਤਨ ਪਤੰਗ ॥",
          "roman": "jiu dīp patan pataṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਪ੍ਰੇਮ ਦੇ ਬੱਝੇ) ਭੰਬਟ ਦੀਵੇ ਉਤੇ ਡਿੱਗਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Как мотыльки, связанные любовью, падают на светильник,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35527,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਚੋਰੁ ਹਿਰਤ ਨਿਸੰਗ ॥",
          "roman": "jiu chor hirat nisaṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਚੋਰ ਝਾਕਾ ਲਾਹ ਕੇ ਚੋਰੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как вор, улучив возможность, совершает кражу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35528,
          "is_rahao": false,
          "gurmukhi": "ਮੈਗਲਹਿ ਕਾਮੈ ਬੰਧੁ ॥",
          "roman": "mēglah kāmē bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹਾਥੀ ਦਾ ਕਾਮ-ਵਾਸਨਾ ਨਾਲ ਜੋੜ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как слон связан с похотью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35529,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਗ੍ਰਸਤ ਬਿਖਈ ਧੰਧੁ ॥",
          "roman": "jiu grasat bikhī dhanḍh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਵਿਸ਼ਿਆਂ ਦਾ) ਧੰਧਾ ਵਿਸ਼ਈ ਮਨੁੱਖ ਨੂੰ ਗ੍ਰਸੀ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как дела чувственных наслаждений держат во власти чувственного человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35530,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਜੂਆਰ ਬਿਸਨੁ ਨ ਜਾਇ ॥",
          "roman": "jiu jūār bisan na jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਜੁਆਰੀਏ ਦੀ (ਜੂਆ ਖੇਡਣ ਦੀ) ਭੈੜੀ ਆਦਤ ਦੂਰ ਨਹੀਂ ਹੁੰਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "как у игрока не исчезает дурная привычка играть в азартные игры,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35531,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਨਕ ਇਹੁ ਮਨੁ ਲਾਇ ॥੮॥",
          "roman": "har nānak ihu man lāi.8.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਤਿਵੇਂ (ਆਪਣੇ) ਇਸ ਮਨ ਨੂੰ (ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਪਿਆਰ ਨਾਲ) ਜੋੜੀ ਰੱਖੀਂ ॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: так же удерживай это сердце соединённым с любовью к стопам Господа. ||8||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35532,
          "is_rahao": false,
          "gurmukhi": "ਕੁਰੰਕ ਨਾਦੈ ਨੇਹੁ ॥",
          "roman": "kuraṅk nādē neh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹਰਨ ਦਾ ਘੰਡੇਹੇੜੇ ਦੀ ਆਵਾਜ਼ ਨਾਲ ਪਿਆਰ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как олень любит звук манка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35533,
          "is_rahao": false,
          "gurmukhi": "ਚਾਤ੍ਰਿਕੁ ਚਾਹਤ ਮੇਹੁ ॥",
          "roman": "chātrik chāhat meh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਪੀਹਾ (ਹਰ ਵੇਲੇ) ਮੀਂਹ ਮੰਗਦਾ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "как папиха всё время жаждет дождя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35534,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਜੀਵਨਾ ਸਤਸੰਗਿ ॥",
          "roman": "jan jīvnā satsang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦੇ) ਸੇਵਕ ਦਾ (ਸੁਖੀ) ਜੀਵ ਸਾਧ ਸੰਗਤਿ ਵਿਚ (ਹੀ ਹੁੰਦਾ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "так и счастливое существование слуги Божьего — в садх-сангате,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35535,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿਦੁ ਭਜਨਾ ਰੰਗਿ ॥",
          "roman": "gobid bhajnā raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੇਵਕ ਪਿਆਰ ਨਾਲ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਨੂੰ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "слуга с любовью повторяет Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35536,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਬਖਾਨੈ ਨਾਮੁ ॥",
          "roman": "rasnā bakhānē nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਪਣੀ) ਜੀਭ ਨਾਲ (ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "своим языком продолжает произносить Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35537,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਸਨ ਦਾਨੁ ॥੯॥",
          "roman": "nānak darsan dān.9.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ! (ਪਰਮਾਤਮਾ ਦੇ) ਦਰਸਨ ਦੀ ਦਾਤ (ਮੰਗਦਾ ਰਹਿੰਦਾ ਹੈ) ॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Он продолжает просить дар даршана Господа. ||9||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35538,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਇ ਸੁਨਿ ਲਿਖਿ ਦੇਇ ॥",
          "roman": "gun gāi sun likh dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾ ਕੇ, ਸੁਣ ਕੇ, ਲਿਖ ਕੇ (ਇਹ ਦਾਤ ਹੋਰਨਾਂ ਨੂੰ ਭੀ) ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, воспевая, слушая и записывая добродетели Господа, даёт этот дар и другим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35539,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਰਬ ਫਲ ਹਰਿ ਲੇਇ ॥",
          "roman": "so sarab phal har lei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਾਰੇ ਫਲ ਦੇਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਮਿਲਾਪ ਪ੍ਰਾਪਤ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "обретает встречу с Господом, Дающим все плоды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35540,
          "is_rahao": false,
          "gurmukhi": "ਕੁਲ ਸਮੂਹ ਕਰਤ ਉਧਾਰੁ ॥",
          "roman": "kul samūh karat udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਆਪਣੀਆਂ) ਸਾਰੀਆਂ ਕੁਲਾਂ ਦਾ (ਹੀ) ਪਾਰ-ਉਤਾਰਾ ਕਰਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой человек переправляет и все свои роды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35541,
          "is_rahao": false,
          "gurmukhi": "ਸੰਸਾਰੁ ਉਤਰਸਿ ਪਾਰਿ ॥",
          "roman": "sansār utras pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "он переходит через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35542,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਚਰਨ ਬੋਹਿਥ ਤਾਹਿ ॥",
          "roman": "har charan bohith tāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾਣ ਲਈ) ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਉਹਨਾਂ ਵਾਸਤੇ ਜਹਾਜ਼ (ਦਾ ਕੰਮ ਦੇਂਦੇ) ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Для них стопы Господа служат кораблём, чтобы переправиться через мировой океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35543,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਾਧਸੰਗਿ ਜਸੁ ਗਾਹਿ ॥",
          "roman": "mil sādhsang jas gāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਮਿਲ ਕੇ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "для тех людей, которые, соединившись в обществе Гуру, продолжают петь песни хвалы Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35544,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪੈਜ ਰਖੈ ਮੁਰਾਰਿ ॥",
          "roman": "har pēj rakhē murār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁਰਾਰੀ ਪ੍ਰਭੂ ਉਹਨਾਂ ਦੀ ਲਾਜ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь Мурари сохраняет их честь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35545,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਨਕ ਸਰਨਿ ਦੁਆਰਿ ॥੧੦॥੨॥",
          "roman": "har nānak saran duār.10.2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਹਰੀ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ, ਉਹ ਹਰੀ ਦੇ ਦਰ ਤੇ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ ॥੧੦॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Они пребывают в прибежище Хари, они пребывают у двери Хари. ||10||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3150,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 35546,
          "is_rahao": false,
          "gurmukhi": "ਬਿਲਾਵਲੁ ਮਹਲਾ ੧ ਥਿਤੀ ਘਰੁ ੧੦ ਜਤਿ",
          "roman": "bilāval mehlā 1 thitī ghar 10 jat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਿਲਾਵਲੁ, ਘਰ ੧੦ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਬਾਣੀ 'ਥਿਤੀ', ਜਤਿ ਦੀ ਤਾਲ ਨਾਲ ਗਾਵਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Рааг Билавал, в доме 10 — bani Guru Nanak Dev Ji «Тхити», поётся в ритме джати."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35547,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik ōankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и достигается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35548,
          "is_rahao": false,
          "gurmukhi": "ਏਕਮ ਏਕੰਕਾਰੁ ਨਿਰਾਲਾ ॥",
          "roman": "ekam ekaṅkār nirālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਇੱਕ ਹੈ (ਉਸ ਦੇ ਬਰਾਬਰ ਦਾ ਹੋਰ ਕੋਈ ਨਹੀਂ)। ਉਸ ਦਾ ਕੋਈ ਖ਼ਾਸ ਘਰ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Параматма один, и нет никого равного Ему. У Него нет какого-то особого места пребывания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35549,
          "is_rahao": false,
          "gurmukhi": "ਅਮਰੁ ਅਜੋਨੀ ਜਾਤਿ ਨ ਜਾਲਾ ॥",
          "roman": "amar ajonī jāt na jālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਕਦੇ ਮਰਦਾ ਨਹੀਂ, ਉਹ ਜੂਨਾਂ ਵਿਚ ਨਹੀਂ ਆਉਂਦਾ, ਉਸ ਦੀ ਕੋਈ ਖ਼ਾਸ ਜਾਤਿ ਨਹੀਂ, ਉਸ ਨੂੰ (ਮਾਇਆ ਆਦਿਕ ਦਾ) ਕੋਈ ਬੰਧਨ ਨਹੀਂ (ਵਿਆਪਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Он никогда не умирает, не приходит в рождения, у Него нет особой касты, и никакие узы, подобные майе, не охватывают Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35550,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰੁ ਰੂਪੁ ਨ ਰੇਖਿਆ ॥",
          "roman": "agam agochar rūp na rekhiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਇੱਕ ਪਰਮਾਤਮਾ ਅਪਹੁੰਚ ਹੈ, (ਮਨੁੱਖ ਦੇ) ਗਿਆਨ-ਇੰਦ੍ਰਿਆਂ ਦੀ ਉਸ ਤਕ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, (ਕਿਉਂਕਿ) ਉਸ ਦੀ ਕੋਈ ਖ਼ਾਸ ਸ਼ਕਲ ਨਹੀਂ, ਕੋਈ ਖ਼ਾਸ ਨਿਸ਼ਾਨ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Параматма недостижим, чувства человека не могут достичь Его, ибо у Него нет особой формы и особого знака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 35551,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਖੋਜਤ ਘਟਿ ਘਟਿ ਦੇਖਿਆ ॥",
          "roman": "khojat khojat ghaṭ ghaṭ dekhiyā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਭਾਲ ਕਰਦਿਆਂ ਕਰਦਿਆਂ ਉਸ ਨੂੰ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵੇਖ ਸਕੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но, продолжая искать, Его можно увидеть в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
