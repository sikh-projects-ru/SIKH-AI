{
  "ang": 862,
  "shabads": [
    {
      "shabad_id": 3225,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36456,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੁ ਮਿਲੁ ਸਖੀ ਗੁਣ ਕਹੁ ਮੇਰੇ ਪ੍ਰਭ ਕੇ ਲੇ ਸਤਿਗੁਰ ਕੀ ਮਤਿ ਧੀਰ ॥੩॥",
          "roman": "mil mil sakhī guṇ kah mere prabh ke le satgur kī mat dhīr ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О подруга, снова и снова соединяйся с Ним; произноси достоинства моего Прабху и, приняв наставление Сатгуру, обрети стойкость. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36457,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਕੀ ਹਰਿ ਆਸ ਪੁਜਾਵਹੁ ਹਰਿ ਦਰਸਨਿ ਸਾਂਤਿ ਸਰੀਰ ॥੪॥੬॥",
          "roman": "jan Nānak kī har ās pujāvah har darsan sāṅt sarīr ||4||6||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Хар, исполни надежду раба Нанака: от даршана Хар всё тело обретает покой. ||4||6||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3226,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36458,
          "is_rahao": false,
          "gurmukhi": "ਛਕਾ ੧॥",
          "roman": "chhakā 1 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чхака первая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3227,
      "rahao_verse_id": 36461,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36459,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਮਹਲਾ ੫ ਚਉਪਦੇ ਘਰੁ ੧",
          "roman": "rāg Goṇḍ mahalā 5 chaupadē ghar 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, пятый Махала, чаупады, дом первый."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36460,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oaṅkār satgur prasād ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36461,
          "is_rahao": true,
          "gurmukhi": "ਸਭੁ ਕਰਤਾ ਸਭੁ ਭੁਗਤਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sabh kartā sabh bhugtā ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма сам создаёт каждую вещь и, пребывая во всём, сам переживает всё. ||1|| пауза ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36462,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਤੋ ਕਰਤਾ ਪੇਖਤ ਕਰਤਾ ॥",
          "roman": "sunato kartā pekhat kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма, пребывая во всём, сам является слышащим и сам является видящим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36463,
          "is_rahao": false,
          "gurmukhi": "ਅਦ੍ਰਿਸਟੋ ਕਰਤਾ ਦ੍ਰਿਸਟੋ ਕਰਤਾ ॥",
          "roman": "adriṣṭo kartā driṣṭo kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё видимое — тоже форма Параматмы, и невидимый мир — тоже Его форма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36464,
          "is_rahao": false,
          "gurmukhi": "ਓਪਤਿ ਕਰਤਾ ਪਰਲਉ ਕਰਤਾ ॥",
          "roman": "opat kartā parlau kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам является творцом рождения всего мира и сам является тем, кто совершает его уничтожение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36465,
          "is_rahao": false,
          "gurmukhi": "ਬਿਆਪਤ ਕਰਤਾ ਅਲਿਪਤੋ ਕਰਤਾ ॥੧॥",
          "roman": "biāpat kartā alipto kartā ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху сам пронизывает всех и, даже пронизывая всё, остаётся непривязанным. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36466,
          "is_rahao": false,
          "gurmukhi": "ਬਕਤੋ ਕਰਤਾ ਬੂਝਤ ਕਰਤਾ ॥",
          "roman": "bakto kartā būjhat kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В каждом существе Прабху сам является говорящим и сам является понимающим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36467,
          "is_rahao": false,
          "gurmukhi": "ਆਵਤੁ ਕਰਤਾ ਜਾਤੁ ਭੀ ਕਰਤਾ ॥",
          "roman": "āvat kartā jāt bhī kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мир приходит тоже Он, и уходит отсюда тоже тот же Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36468,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਗੁਨ ਕਰਤਾ ਸਰਗੁਨ ਕਰਤਾ ॥",
          "roman": "nirgun kartā sargun kartā ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху пребывает и за пределами трёх качеств майи, и вместе с этими тремя качествами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36469,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਨਾਨਕ ਸਮਦ੍ਰਿਸਟਾ ॥੨॥੧॥",
          "roman": "gur prasād Nānak samadriṣṭā ||2||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, способность видеть Параматму во всех обретается по милости Гуру. ||2||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3228,
      "rahao_verse_id": 36474,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36470,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "Goṇḍ mahalā 5 ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гонд, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36471,
          "is_rahao": false,
          "gurmukhi": "ਫਾਕਿਓ ਮੀਨ ਕਪਿਕ ਕੀ ਨਿਆਈ ਤੂ ਉਰਝਿ ਰਹਿਓ ਕਸੁੰਭਾਇਲੇ ॥",
          "roman": "fākio mīn kapik kī niāī tū urajh rahio kasuṅbhāile ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, ты запутался в привязанности к тленной майе, подобной кусумбху, как рыба из-за вкуса языка и как обезьяна из-за горсти зёрен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36472,
          "is_rahao": false,
          "gurmukhi": "ਪਗ ਧਾਰਹਿ ਸਾਸੁ ਲੇਖੈ ਲੈ ਤਉ ਉਧਰਹਿ ਹਰਿ ਗੁਣ ਗਾਇਲੇ ॥੧॥",
          "roman": "pag dhārah sās lekhē lē tau udhrah har guṇ gāile ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый шаг, который ты делаешь в привязанности, и каждый вдох, который ты берёшь, записываются в счёт; пой достоинства Хар, только тогда ты спасёшься от этого मोह. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36473,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਸਮਝੁ ਛੋਡਿ ਆਵਾਇਲੇ ॥",
          "roman": "man samajh chhoḍ āvāile ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, опомнись, оставь своё упрямое неразумие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36474,
          "is_rahao": true,
          "gurmukhi": "ਅਪਨੇ ਰਹਨ ਕਉ ਠਉਰੁ ਨ ਪਾਵਹਿ ਕਾਏ ਪਰ ਕੈ ਜਾਇਲੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "apne rahan kau ṭhaur na pāvah kāe par kē jāile ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не можешь найти здесь постоянного места для своего пребывания; почему же ты устремляешься к чужому богатству и имуществу? ||1|| пауза ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36475,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮੈਗਲੁ ਇੰਦ੍ਰੀ ਰਸਿ ਪ੍ਰੇਰਿਓ ਤੂ ਲਾਗਿ ਪਰਿਓ ਕੁਟੰਬਾਇਲੇ ॥",
          "roman": "jiu mēgal indrī ras prerio tū lāg pario kuṭambāile ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, как слон побуждаем страстью и попадает в чужую неволю, так и ты застрял в привязанности к семье."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36476,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪੰਖੀ ਇਕਤ੍ਰ ਹੋਇ ਫਿਰਿ ਬਿਛੁਰੈ ਥਿਰੁ ਸੰਗਤਿ ਹਰਿ ਹਰਿ ਧਿਆਇਲੇ ॥੨॥",
          "roman": "jiu paṅkhī ikatr hoi phir bichhurē thir saṅgat har har dhiāile ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как птицы собираются вместе, а затем каждая разлетается отдельно, так и каждый член семьи расстанется; пребывай в святом собрании и помни Хар-Хар — только это устойчивое духовное пристанище. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36477,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਮੀਨੁ ਰਸਨ ਸਾਦਿ ਬਿਨਸਿਓ ਓਹੁ ਮੂਠੌ ਮੂੜ ਲੋਭਾਇਲੇ ॥",
          "roman": "jēse mīn rasan sād binsio oh mūṭhau mūṛ lobhāile ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как рыба погибает из-за вкуса языка, так этот глупец оказывается обманут и разграблен из-за жадности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36478,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਹੋਆ ਪੰਚ ਵਾਸਿ ਵੈਰੀ ਕੈ ਛੂਟਹਿ ਪਰੁ ਸਰਨਾਇਲੇ ॥੩॥",
          "roman": "tū hoā pañch vās vērī kē chhūṭah par sarnāile ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты оказался во власти пяти врагов; приди под защиту Прабху, только тогда освободишься из их когтей. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36479,
          "is_rahao": false,
          "gurmukhi": "ਹੋਹੁ ਕ੍ਰਿਪਾਲ ਦੀਨ ਦੁਖ ਭੰਜਨ ਸਭਿ ਤੁਮੑਰੇ ਜੀਅ ਜੰਤਾਇਲੇ ॥",
          "roman": "hoh kripāl dīn dukh bhañjan sabh tumhre jīa jantāile ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О разрушитель страданий бедных, будь милостив к нам, живым существам; все эти души и создания принадлежат Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36480,
          "is_rahao": false,
          "gurmukhi": "ਪਾਵਉ ਦਾਨੁ ਸਦਾ ਦਰਸੁ ਪੇਖਾ ਮਿਲੁ ਨਾਨਕ ਦਾਸ ਦਸਾਇਲੇ ॥੪॥੨॥",
          "roman": "pāvau dān sadā dars pekhā mil Nānak dās dasāile ||4||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встреться с Нанаком, рабом Твоих рабов; я желаю получить лишь этот дар — всегда созерцать Твой даршан. ||4||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3229,
      "rahao_verse_id": 36488,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36481,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਗੋਂਡ ਮਹਲਾ ੫ ਚਉਪਦੇ ਘਰੁ ੨",
          "roman": "rāg Goṇḍ mahalā 5 chaupadē ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Гонд, пятый Махала, чаупады, дом второй."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36482,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oaṅkār satgur prasād ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36483,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਨ ਕੀਏ ਜਿਨਿ ਸਾਜਿ ॥",
          "roman": "jīa prān kīe jin sāj ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Прабху создал тебя и дал тебе жизнь и дыхание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36484,
          "is_rahao": false,
          "gurmukhi": "ਮਾਟੀ ਮਹਿ ਜੋਤਿ ਰਖੀ ਨਿਵਾਜਿ ॥",
          "roman": "māṭī mah jot rakhī nivāj ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Прабху по милости вложил Свою джот в это тело из земли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36485,
          "is_rahao": false,
          "gurmukhi": "ਬਰਤਨ ਕਉ ਸਭੁ ਕਿਛੁ ਭੋਜਨ ਭੋਗਾਇ ॥",
          "roman": "bartan kau sabh kichh bhojan bhogāi ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для пользования Он дал тебе всякую вещь и кормит тебя множеством видов пищи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36486,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪ੍ਰਭੁ ਤਜਿ ਮੂੜੇ ਕਤ ਜਾਇ ॥੧॥",
          "roman": "so prabh taj mūṛe kat jāi ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глупец, забыв такого Прабху, куда ещё блуждает твой ум? ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36487,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਕੀ ਲਾਗਉ ਸੇਵ ॥",
          "roman": "pārbraham kī lāgau sev ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я хочу быть занят служением и бхагти Парабрахма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36488,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਤੇ ਸੁਝੈ ਨਿਰੰਜਨ ਦੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur te sujhē nirañjan dev ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только от Гуру может прийти понимание бхагти того сияющего Прабху, который свободен от влияния майи. ||1|| пауза ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36489,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕੀਏ ਰੰਗ ਅਨਿਕ ਪਰਕਾਰ ॥",
          "roman": "jin kīe raṅg anik parkār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум, всегда помни того Прабху, который создал в мире бесчисленные виды красок и форм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36490,
          "is_rahao": false,
          "gurmukhi": "ਓਪਤਿ ਪਰਲਉ ਨਿਮਖ ਮਝਾਰ ॥",
          "roman": "opat parlau nimakh majhār ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он может в одно мгновение уничтожить созданное Им творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36491,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਗਤਿ ਮਿਤਿ ਕਹੀ ਨ ਜਾਇ ॥",
          "roman": "jā kī gat mit kahī na jāi ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нём невозможно сказать, каков Он и насколько велик."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36492,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪ੍ਰਭੁ ਮਨ ਮੇਰੇ ਸਦਾ ਧਿਆਇ ॥੨॥",
          "roman": "so prabh man mere sadā dhiāi ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум, всегда пребывай в созерцании того Прабху. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36493,
          "is_rahao": false,
          "gurmukhi": "ਆਇ ਨ ਜਾਵੈ ਨਿਹਚਲੁ ਧਨੀ ॥",
          "roman": "āi na jāvē nihchal dhanī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, тот Владыка-Прабху вечно устойчив; Он не рождается и не умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36494,
          "is_rahao": false,
          "gurmukhi": "ਬੇਅੰਤ ਗੁਨਾ ਤਾ ਕੇ ਕੇਤਕ ਗਨੀ ॥",
          "roman": "beant gunā tā ke ketak ganī ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сколько Его достоинств я могу сосчитать? Он владеет бесконечными достоинствами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
