      "lines": [
        {
          "verse_id": 36495,
          "is_rahao": false,
          "gurmukhi": "ਲਾਲ ਨਾਮ ਜਾ ਕੈ ਭਰੇ ਭੰਡਾਰ ॥",
          "roman": "lāl nām jā kē bhare bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਘਰ ਵਿਚ ਉਸ ਦੇ ਗੁਣਾਂ-ਰੂਪ ਲਾਲਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਭਰੇ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Его сокровищницы полны драгоценных качеств."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36496,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਦੇਵੈ ਆਧਾਰ ॥੩॥",
          "roman": "sagal ghaṭā devē ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਭ ਜੀਵਾਂ ਨੂੰ ਆਸਰਾ ਦੇਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он даёт опору всем существам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36497,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿ ਪੁਰਖੁ ਜਾ ਕੋ ਹੈ ਨਾਉ ॥",
          "roman": "sat purakh jā ko hē nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਜਿਸ ਪ੍ਰਭੂ ਦਾ ਨਾਮ (ਹੀ ਦੱਸਦਾ ਹੈ ਕਿ ਉਹ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ ਅਤੇ ਸਰਬ-ਵਿਆਪਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Его указывает на вечность и всепроникающую сущность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36498,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਹਿ ਕੋਟਿ ਅਘ ਨਿਮਖ ਜਸੁ ਗਾਉ ॥",
          "roman": "miṭah koṭ agh nimakh jas gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਜਸ ਹਰ ਵੇਲੇ ਗਾਇਆ ਕਰ, (ਉਸ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀ ਬਰਕਤ ਨਾਲ) ਕ੍ਰੋੜਾਂ ਪਾਪ ਮਿਟ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Пой Его славу всегда, и миллионы грехов исчезнут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36499,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲ ਸਖਾਈ ਭਗਤਨ ਕੋ ਮੀਤ ॥",
          "roman": "bāl sakhāī bhagtan ko mīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਹਰੇਕ ਜੀਵ ਦਾ) ਮੁੱਢ ਦਾ ਸਾਥੀ ਹੈ, ਭਗਤਾਂ ਦਾ ਮਿੱਤਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он изначальный спутник и друг преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36500,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਨ ਅਧਾਰ ਨਾਨਕ ਹਿਤ ਚੀਤ ॥੪॥੧॥੩॥",
          "roman": "prān adhār nānak hit chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਹਰੇਕ ਦੀ) ਜਿੰਦ ਦਾ ਆਸਰਾ ਹੈ। ਹੇ ਨਾਨਕ! ਆਪਣੇ ਚਿੱਤ ਵਿਚ ਉਸ ਪ੍ਰਭੂ ਦਾ ਪਿਆਰ ਪੈਦਾ ਕਰ ॥੪॥੧॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Он опора жизни. О Нанак, наполни сердце любовью к Нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
