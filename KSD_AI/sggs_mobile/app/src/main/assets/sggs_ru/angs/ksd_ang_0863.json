            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36506,
          "is_rahao": true,
          "gurmukhi": "ਰਾਸਿ ਦੀਈ ਹਰਿ ਏਕੋ ਨਾਮੁ ॥",
