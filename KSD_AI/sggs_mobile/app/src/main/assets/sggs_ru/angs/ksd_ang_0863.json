              "main": ""
            }
          }
        },
        {
          "verse_id": 36503,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੋੁ ਹੀ ਇਸੁ ਮਨ ਕਾ ਅਧਾਰੁ ॥",
