{
  "ang": 866,
  "shabads": [
    {
      "shabad_id": 3239,
      "rahao_verse_id": 36678,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36673,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੇ ਚਰਨ ਕਮਲ ਨਮਸਕਾਰਿ ॥",
          "roman": "gur ke charan kamal namaskār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਆਪਣੇ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਉਤੇ ਆਪਣਾ ਸਿਰ ਰੱਖਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! преклоняй голову к стопам Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36674,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਇਸੁ ਤਨ ਤੇ ਮਾਰਿ ॥",
          "roman": "kām krodh is tan te mār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਆਪਣੇ) ਇਸ ਸਰੀਰ ਵਿਚੋਂ ਕਾਮ ਅਤੇ ਕ੍ਰੋਧ (ਆਦਿਕ ਵਿਕਾਰਾਂ) ਨੂੰ ਮਾਰ ਮੁਕਾ।"
            },
            "sahib_singh_ru": {
              "main": "Уничтожь в себе похоть и гнев."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36675,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਰਹੀਐ ਸਗਲ ਕੀ ਰੀਨਾ ॥",
          "roman": "hoi rahīai sagal kī rīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਭਨਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਹੋ ਕੇ ਰਹਿਣਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Стань пылью под ногами всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36676,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਰਮਈਆ ਸਭ ਮਹਿ ਚੀਨਾ ॥੧॥",
          "roman": "ghaṭ ghaṭ ramaīā sabh meh chīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਸਭ ਜੀਵਾਂ ਵਿਚ ਸੋਹਣੇ ਰਾਮ ਨੂੰ ਵੱਸਦਾ ਵੇਖ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "В каждом существе видь пребывающего Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36677,
          "is_rahao": true,
          "gurmukhi": "ਇਨ ਬਿਧਿ ਰਮਹੁ ਗੋਪਾਲ ਗੋੁਬਿੰਦੁ ॥",
          "roman": "in bidh ramah gopāl gobind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਇਸ ਤਰ੍ਹਾਂ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਕ ਗੋਬਿੰਦ ਦਾ ਨਾਮ ਜਪਦੇ ਰਹੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! так поминай Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36678,
          "is_rahao": true,
          "gurmukhi": "ਤਨੁ ਧਨੁ ਪ੍ਰਭ ਕਾ ਪ੍ਰਭ ਕੀ ਜਿੰਦੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tan dhan prabh kā prabh kī jind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿ) ਇਸ ਸਰੀਰ ਨੂੰ, ਇਸ ਧਨ ਨੂੰ, ਪ੍ਰਭੂ ਦਾ ਬਖ਼ਸ਼ਿਆ ਹੋਇਆ ਜਾਣੋ, ਇਸ ਜਿੰਦ ਨੂੰ (ਭੀ) ਪ੍ਰਭੂ ਦੀ ਦਿੱਤੀ ਹੋਈ ਸਮਝੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "считай тело, богатство и жизнь даром Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36679,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਕੇ ਗੁਣ ਗਾਉ ॥",
          "roman": "āṭh pahar har ke guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅੱਠੇ ਪਹਿਰ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਿਹਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! постоянно пой хвалу Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36680,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਨ ਕੋ ਇਹੈ ਸੁਆਉ ॥",
          "roman": "jīa prān ko ihē suāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਜਿੰਦ-ਜਾਨ ਦਾ (ਸੰਸਾਰ ਵਿਚ) ਇਹੀ (ਸਭ ਤੋਂ ਵੱਡਾ) ਮਨੋਰਥ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это главная цель жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36681,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਅਭਿਮਾਨੁ ਜਾਨੁ ਪ੍ਰਭੁ ਸੰਗਿ ॥",
          "roman": "taj abhimān jān prabh saṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਅਹੰਕਾਰ ਦੂਰ ਕਰ ਕੇ ਪ੍ਰਭੂ ਨੂੰ ਆਪਣੇ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਸਮਝ।"
            },
            "sahib_singh_ru": {
              "main": "Отбрось гордость и знай, что Бог рядом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36682,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਪ੍ਰਸਾਦਿ ਹਰਿ ਸਿਉ ਮਨੁ ਰੰਗਿ ॥੨॥",
          "roman": "sādh prasād har siu man raṅg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਆਪਣੇ ਮਨ ਨੂੰ ਪਰਮਾਤਮਾ (ਦੇ ਪ੍ਰੇਮ-ਰੰਗ) ਨਾਲ ਰੰਗ ਲੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру окрась ум любовью к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36683,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਤੂੰ ਕੀਆ ਤਿਸ ਕਉ ਜਾਨੁ ॥",
          "roman": "jin tū kīā tis kau jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਤੈਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ ਉਸ ਨਾਲ ਸਾਂਝ ਪਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! знай Того, кто тебя создал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36684,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਦਰਗਹ ਪਾਵੈ ਮਾਨੁ ॥",
          "roman": "āgē dargah pāvē mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਇਹ ਉੱਦਮ ਕਰਦਾ ਹੈ, ਉਹ) ਅਗਾਂਹ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਆਦਰ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тогда получишь честь в Его присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36685,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਨਿਰਮਲ ਹੋਇ ਨਿਹਾਲੁ ॥",
          "roman": "man tan nirmal hoi nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਮਨੁੱਖ ਦਾ) ਮਨ ਤਨ ਪਵਿੱਤਰ ਹੋ ਜਾਂਦਾ ਹੈ, ਮਨ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ, ਸਰੀਰ ਭੀ ਖਿੜਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ум и тело становятся чистыми и радостными,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36686,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਨਾਮੁ ਜਪਤ ਗੋਪਾਲ ॥੩॥",
          "roman": "rasnā nām japat gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਜੀਭ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "когда язык повторяет Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36687,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੇਰੇ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "kar kirpā mere dīn dayālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲੇ ਮੇਰੇ ਪ੍ਰਭੂ! (ਮੇਰੇ ਉਤੇ) ਮੇਹਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О милостивый Господь, прояви милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36688,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਕੀ ਮਨੁ ਮੰਗੈ ਰਵਾਲਾ ॥",
          "roman": "sādhū kī man maṅgē ravālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰਾ) ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਮੰਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Моё сердце просит пыль стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36689,
          "is_rahao": false,
          "gurmukhi": "ਹੋਹੁ ਦਇਆਲ ਦੇਹੁ ਪ੍ਰਭ ਦਾਨੁ ॥",
          "roman": "hoh dayāl deh prabh dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਨਾਨਕ ਉਤੇ) ਦਇਆਵਾਨ ਹੋ ਅਤੇ ਇਹ ਖ਼ੈਰ ਪਾ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! будь милостив и даруй этот дар,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36690,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਪਿ ਜੀਵੈ ਪ੍ਰਭ ਨਾਮੁ ॥੪॥੧੧॥੧੩॥",
          "roman": "nānak jap jīvē prabh nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ (ਤੇਰਾ ਦਾਸ) ਨਾਨਕ, ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਜਪ ਕੇ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰਦਾ ਰਹੇ ॥੪॥੧੧॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Нанак жил, повторяя Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3240,
      "rahao_verse_id": 36697,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 36691,
          "is_rahao": false,
          "gurmukhi": "ਗੋਂਡ ਮਹਲਾ ੫ ॥",
          "roman": "goṇḍ mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36692,
          "is_rahao": false,
          "gurmukhi": "ਧੂਪ ਦੀਪ ਸੇਵਾ ਗੋਪਾਲ ॥",
          "roman": "dhūp dīp sevā gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਕਰਮ ਕਾਂਡੀ ਲੋਕ ਦੇਵੀ ਦੇਵਤਿਆਂ ਦੀ ਪੂਜਾ ਕਰਦੇ ਹਨ, ਉਹਨਾਂ ਦੇ ਅੱਗੇ ਧੂਪ ਧੁਖਾਂਦੇ ਹਨ ਅਤੇ ਦੀਵੇ ਬਾਲਦੇ ਹਨ, ਪਰ) ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਨੀ ਹੀ ਉਸ ਮਨੁੱਖ ਵਾਸਤੇ 'ਧੂਪ ਦੀਪ' ਦੀ ਕ੍ਰਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "(ਹੇ ਭਾਈ! ਕਰਮ ਕਾਂਡੀ ਲੋਕ ਦੇਵੀ ਦੇਵਤਿਆਂ ਦੀ ਪੂਜਾ ਕਰਦੇ ਹਨ, ਉਹਨਾਂ ਦੇ ਅੱਗੇ ਧੂਪ ਧੁਖਾਂਦੇ ਹਨ ਅਤੇ ਦੀਵੇ ਬਾਲਦੇ ਹਨ, ਪਰ) ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਨੀ ਹੀ ਉਸ ਮਨੁੱਖ ਵਾਸਤੇ ‘ਧੂਪ ਦੀਪ’ ਦੀ ਕ੍ਰਿਆ ਹੈ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 36693,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਾਰ ਬੰਦਨ ਕਰਤਾਰ ॥",
          "roman": "anik bār bandan kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਗਤੀ ਕਰਦਾ ਹੋਇਆ ਉਹ ਮਾਨੋ) ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਹਰ ਵੇਲੇ ਸਿਰ ਨਿਵਾਈ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "(ਭਗਤੀ ਕਰਦਾ ਹੋਇਆ ਉਹ ਮਾਨੋ) ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਹਰ ਵੇਲੇ ਸਿਰ ਨਿਵਾਈ ਰੱਖਦਾ ਹੈ।"
            },
