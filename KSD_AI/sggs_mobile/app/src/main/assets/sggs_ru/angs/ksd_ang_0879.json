{
  "ang": 879,
  "shabads": [
    {
      "shabad_id": 3279,
      "rahao_verse_id": 37337,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37336,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਗਿਆਨੁ ਬੀਚਾਰੈ ਕੋਈ ॥",
          "roman": "ēsā giān bīchārey koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такое знание размышляет лишь редкий гурмукх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37337,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸ ਤੇ ਮੁਕਤਿ ਪਰਮ ਗਤਿ ਹੋਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tis tē mukat param gat hoī. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От восхваления того всетворящего и всепроникающего Господа человек получает освобождение от пороков и достигает высшего духовного состояния. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37338,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨ ਮਹਿ ਰੈਣਿ ਰੈਣਿ ਮਹਿ ਦਿਨੀਅਰੁ ਉਸਨ ਸੀਤ ਬਿਧਿ ਸੋਈ ॥",
          "roman": "din meh rēṇ rēṇ meh dinīar usan sīt bidh soī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В свете дня растворяется ночная тьма, а в ночной тьме исчезает солнечный свет; таков же порядок жара и холода."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37339,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਗਤਿ ਮਿਤਿ ਅਵਰੁ ਨ ਜਾਣੈ ਗੁਰ ਬਿਨੁ ਸਮਝ ਨ ਹੋਈ ॥੨॥",
          "roman": "tā kī gat mit avar na jāṇē gur bin samajh na hoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каков тот Господь и насколько Он велик, кроме Него Самого никто не знает; без Гуру это понимание не приходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37340,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਖ ਮਹਿ ਨਾਰਿ ਨਾਰਿ ਮਹਿ ਪੁਰਖਾ ਬੂਝਹੁ ਬ੍ਰਹਮ ਗਿਆਨੀ ॥",
          "roman": "purakh meh nār nār meh purkhā būjhah brahm giānī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О знающий Брахма, пойми чудесную игру: от семени мужчин рождаются женщины, а от женщин рождаются мужчины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37341,
          "is_rahao": false,
          "gurmukhi": "ਧੁਨਿ ਮਹਿ ਧਿਆਨੁ ਧਿਆਨ ਮਹਿ ਜਾਨਿਆ ਗੁਰਮੁਖਿ ਅਕਥ ਕਹਾਨੀ ॥੩॥",
          "roman": "dhun meh dhiān dhiān meh jāniā gurmukh akath kahānī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх соединяет внимание со словом хвалы Господу и через это внимание познаёт Бога; история Неизреченного не может быть полностью рассказана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37342,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਜੋਤਿ ਜੋਤਿ ਮਹਿ ਮਨੂਆ ਪੰਚ ਮਿਲੇ ਗੁਰ ਭਾਈ ॥",
          "roman": "man meh jot jot meh manūā pañch miley gur bhāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В их уме проявляется свет Акал Пуракха, их ум пребывает в Божьей памяти, и пять органов познания, словно ученики одного Гуру, перестают блуждать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37343,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਕੈ ਸਦ ਬਲਿਹਾਰੀ ਜਿਨ ਏਕ ਸਬਦਿ ਲਿਵ ਲਾਈ ॥੪॥੯॥",
          "roman": "nānak tin kē sad balihārī jin ek sabad liv lāī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак всегда жертвует собой ради тех, кто сосредоточил любовь в Слове хвалы единого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3280,
      "rahao_verse_id": 37349,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37344,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੧ ॥",
          "roman": "rāmkalī mahalā pehlā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37345,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਹਰਿ ਪ੍ਰਭਿ ਕਿਰਪਾ ਧਾਰੀ ॥",
          "roman": "jā har prabh kirpā dhārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь-Бог Сам проявил милость к живому существу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37346,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਹਉਮੈ ਵਿਚਹੁ ਮਾਰੀ ॥",
          "roman": "tā haumē vichah mārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда оно устранило изнутри Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37347,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਕਿ ਰਾਮ ਪਿਆਰੀ ॥ ਜੋ ਗੁਰ ਸਬਦੀ ਬੀਚਾਰੀ ॥੧॥",
          "roman": "so sevak rām piārī. jo gur sabdī bīchārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та служанка, которая через Слово Гуру стала рассудительной и смогла убить в себе Хоумэ и мирской стыд, стала дорогой Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37348,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਹਰਿ ਜਨੁ ਹਰਿ ਪ੍ਰਭ ਭਾਵੈ ॥",
          "roman": "so har jan har prabh bhāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот слуга Господа приятен Господу-Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37349,
          "is_rahao": true,
          "gurmukhi": "ਅਹਿਨਿਸਿ ਭਗਤਿ ਕਰੇ ਦਿਨੁ ਰਾਤੀ ਲਾਜ ਛੋਡਿ ਹਰਿ ਕੇ ਗੁਣ ਗਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ahinis bhagat karey din rātī lāj chhoḍ har kē guṇ gāvē. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он, оставив мирской стыд и Хоумэ, день и ночь непрестанно совершает преданное служение и поёт качества Господа. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37350,
          "is_rahao": false,
          "gurmukhi": "ਧੁਨਿ ਵਾਜੇ ਅਨਹਦ ਘੋਰਾ ॥",
          "roman": "dhun vāje anhad ghorā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри зазвучала глубокая сладкая мелодия непрерывно звучащих инструментов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37351,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਮਾਨਿਆ ਹਰਿ ਰਸਿ ਮੋਰਾ ॥",
          "roman": "man māniā har ras morā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой ум погрузился во вкус восхваления Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37352,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੈ ਸਚੁ ਸਮਾਇਆ ॥",
          "roman": "gur pūrey sach samāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через совершенного Гуру вечный Господь вошёл и утвердился в моём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37353,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਆਦਿ ਪੁਰਖੁ ਹਰਿ ਪਾਇਆ ॥੨॥",
          "roman": "gur ād purakh har pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Гуру я обрёл Господа, изначального Пурукха, высшую Сущность, пребывающую во всём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37354,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਨਾਦ ਬੇਦ ਗੁਰਬਾਣੀ ॥",
          "roman": "sabh nād bed gurbāṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для того, чей ум окрашен через Гурбани, все йогические звуки и все Веды уже заключены в Гурбани."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37355,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਰਾਤਾ ਸਾਰਿਗਪਾਣੀ ॥",
          "roman": "man rātā sārangpāṇī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его ум окрашен любовью к Сарангапани, к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37356,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਤੀਰਥ ਵਰਤ ਤਪ ਸਾਰੇ ॥",
          "roman": "tah tīrath varat tap sārey.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В том духовном состоянии для него словно уже совершены все омовения в тиртхах, все посты и аскезы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37357,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿਆ ਹਰਿ ਨਿਸਤਾਰੇ ॥੩॥",
          "roman": "gur miliā har nistārey.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кто встретил Гуру, Господь переправляет через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37358,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਆਪੁ ਗਇਆ ਭਉ ਭਾਗਾ ॥",
          "roman": "jah āp gaiā bhau bhāgā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из сердца, где исчезло чувство самости, убежали все страхи и тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37359,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚਰਣੀ ਸੇਵਕੁ ਲਾਗਾ ॥",
          "roman": "gur charṇī sevak lāgā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой слуга полностью прилепился к стопам Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37360,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਸਤਿਗੁਰਿ ਭਰਮੁ ਚੁਕਾਇਆ ॥",
          "roman": "gur satgur bharam chukāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру, Сатгуру, устранил его блуждание и заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37361,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਬਦਿ ਮਿਲਾਇਆ ॥੪॥੧੦॥",
          "roman": "kah nānak sabad milāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: Гуру соединил его со своим Словом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3281,
      "rahao_verse_id": 37368,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37362,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੧ ॥",
          "roman": "rāmkalī mahalā pehlā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37363,
          "is_rahao": false,
          "gurmukhi": "ਛਾਦਨੁ ਭੋਜਨੁ ਮਾਗਤੁ ਭਾਗੈ ॥",
          "roman": "chhādan bhojan māgat bhāgē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот йоги бегает и просит только одежду и пищу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37364,
          "is_rahao": false,
          "gurmukhi": "ਖੁਧਿਆ ਦੁਸਟ ਜਲੈ ਦੁਖੁ ਆਗੈ ॥",
          "roman": "khudhiā dusṭ jalē dukh āgē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Здесь он горит в дурном огне голода, а дальше, в ином мире, тоже получает страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37365,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਨਹੀ ਲੀਨੀ ਦੁਰਮਤਿ ਪਤਿ ਖੋਈ ॥",
          "roman": "gurmat nahī līnī durmat pat khoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Не приняв наставления Гуру, он пошёл за дурным разумом и потерял свою честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37366,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮਤਿ ਭਗਤਿ ਪਾਵੈ ਜਨੁ ਕੋਈ ॥੧॥",
          "roman": "gurmat bhagat pāvē jan koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий человек, следуя учению Гуру, обретает пользу преданности Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37367,
          "is_rahao": true,
          "gurmukhi": "ਜੋਗੀ ਜੁਗਤਿ ਸਹਜ ਘਰਿ ਵਾਸੈ ॥",
          "roman": "jogī jugat sahaj ghar vāsē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Образ жизни истинного йоги таков: он пребывает в доме равновесия и внутреннего покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37368,
          "is_rahao": true,
          "gurmukhi": "ਏਕ ਦ੍ਰਿਸਟਿ ਏਕੋ ਕਰਿ ਦੇਖਿਆ ਭੀਖਿਆ ਭਾਇ ਸਬਦਿ ਤ੍ਰਿਪਤਾਸੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ek drisṭ ekō kar dekhiā bhīkhiā bhāi sabad triptāsē. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он ровным взглядом видит во всех существах одного Господа; соединяясь со Словом Гуру, он насыщает свой духовный голод милостыней любви. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37369,
          "is_rahao": false,
          "gurmukhi": "ਪੰਚ ਬੈਲ ਗਡੀਆ ਦੇਹ ਧਾਰੀ ॥",
          "roman": "pañch bēl gaḍīā deh dhārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человеческое тело словно маленькая повозка, которую тянут пять быков, пять органов познания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37370,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਕਲਾ ਨਿਬਹੈ ਪਤਿ ਸਾਰੀ ॥",
          "roman": "rām kalā nibhē pat sārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пока в нём присутствует свет и сила всепроникающего Господа, всё его достоинство сохраняется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37371,
          "is_rahao": false,
          "gurmukhi": "ਧਰ ਤੂਟੀ ਗਾਡੋ ਸਿਰ ਭਾਰਿ ॥",
          "roman": "dhar tūṭī gāḍo sir bhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда ломается ось повозки, она переворачивается и становится бесполезной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37372,
          "is_rahao": false,
          "gurmukhi": "ਲਕਰੀ ਬਿਖਰਿ ਜਰੀ ਮੰਝ ਭਾਰਿ ॥੨॥",
          "roman": "lakrī bikhar jarī mañjh bhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Её деревяшки рассыпаются, и под собственным грузом она гниёт и сгорает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37373,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਵੀਚਾਰਿ ਜੋਗੀ ॥",
          "roman": "gur kā sabad vīchār jogī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О йоги, осмысли Слово Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37374,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖੁ ਸੁਖੁ ਸਮ ਕਰਣਾ ਸੋਗ ਬਿਓਗੀ ॥",
          "roman": "dukh sukh sam karṇā sog biogī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Под руководством этого Слова научись одинаково переносить боль и радость, скорбь отчаяния и боль разлуки, смешанную с надеждой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37375,
          "is_rahao": false,
          "gurmukhi": "ਭੁਗਤਿ ਨਾਮੁ ਗੁਰ ਸਬਦਿ ਬੀਚਾਰੀ ॥",
          "roman": "bhugat nām gur sabad bīchārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Слово Гуру посели в сознании Имя Господа — пусть оно станет твоей пищей и духовным пиром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37376,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਰੁ ਕੰਧੁ ਜਪੈ ਨਿਰੰਕਾਰੀ ॥੩॥",
          "roman": "asthir kandh japē nirankārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяй Имя Ниракара; благодаря этому органы познания останутся устойчивыми и не будут колебаться к порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37377,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਜਗੋਟਾ ਬੰਧਨ ਤੇ ਛੂਟਾ ॥",
          "roman": "sahaj jagoṭā bandhan tē chhūṭā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот йоги, кто сделал внутреннее равновесие своим поясом, освободился от уз Майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37378,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਗੁਰ ਸਬਦੀ ਲੂਟਾ ॥",
          "roman": "kām krodh gur sabdī lūṭā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соединившись со Словом Гуру, он взял под власть похоть, гнев и прочие пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37379,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਮਹਿ ਮੁੰਦ੍ਰਾ ਹਰਿ ਗੁਰ ਸਰਣਾ ॥",
          "roman": "man meh mundrā har gur sarṇā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто пребывает в прибежище Господа и Гуру, носит серьги в уме, то есть защищает ум от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37380,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਮ ਭਗਤਿ ਜਨ ਤਰਣਾ ॥੪॥੧੧॥",
          "roman": "nānak rām bhagat jan tarṇā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: через поток пороков мирского океана переправляются те люди, которые совершают преданность Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
