{
  "ang": 887,
  "shabads": [
    {
      "shabad_id": 3302,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37667,
          "is_rahao": false,
          "gurmukhi": "ਪੀਵਤ ਅਮਰ ਭਏ ਨਿਹਕਾਮ ॥",
          "roman": "pīvat amar bhae nihkām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਨੂੰ ਪੀਂਦਿਆਂ ਹੀ ਮਨੁੱਖ ਅਟੱਲ ਆਤਮਕ ਜੀਵਨ ਵਾਲੇ ਅਤੇ ਵਾਸਨਾ-ਰਹਿਤ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Пьющий его становится бессмертным и безжеланным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37668,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਸੀਤਲੁ ਅਗਨਿ ਨਿਵਾਰੀ ॥",
          "roman": "tan man sītal agan nivārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦਾ ਤਨ ਉਹਨਾਂ ਦਾ ਮਨ ਸ਼ਾਂਤ ਹੋ ਜਾਂਦਾ ਹੈ। ਪਰਮਾਤਮਾ (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ ਤ੍ਰਿਸ਼ਨਾ ਦੀ) ਅੱਗ ਬੁਝਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тело и ум становятся спокойными, огонь угасает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37669,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਰੂਪ ਪ੍ਰਗਟੇ ਸੰਸਾਰੀ ॥੨॥",
          "roman": "anad rūp pragṭe saṅsārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹਰ ਵੇਲੇ ਆਨੰਦ-ਭਰਪੂਰ ਰਹਿੰਦੇ ਹਨ, ਅਤੇ ਜਗਤ ਵਿਚ ਨਾਮਣੇ ਵਾਲੇ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он становится воплощением блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37670,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਦੇਵਉ ਜਾ ਸਭੁ ਕਿਛੁ ਤੇਰਾ ॥",
          "roman": "kiā devau jā sabh kichh terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਉਹ ਨਾਮ-ਅੰਮ੍ਰਿਤ ਪ੍ਰਾਪਤ ਕਰਨ ਵਾਸਤੇ) ਮੈਂ ਤੇਰੇ ਅੱਗੇ ਕੀਹ ਲਿਆ ਧਰਾਂ, ਕਿਉਂਕਿ (ਮੇਰੇ ਪਾਸ ਤਾਂ) ਸਭ ਕੁਝ ਤੇਰਾ ਹੀ ਦਿੱਤਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Что могу я дать, если всё твоё?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37671,
          "is_rahao": false,
          "gurmukhi": "ਸਦ ਬਲਿਹਾਰਿ ਜਾਉ ਲਖ ਬੇਰਾ ॥",
          "roman": "sad balihār jāu lakh berā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੈਥੋਂ ਸਦਾ ਹੀ ਲੱਖਾਂ ਵਾਰੀ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Я предан тебе снова и снова."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37672,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਜੀਉ ਪਿੰਡੁ ਦੇ ਸਾਜਿਆ ॥",
          "roman": "tan man jīo piṇḍ de sājiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਤਨ ਇਹ ਮਨ, ਇਹ ਜਿੰਦ ਇਹ ਸਰੀਰ ਦੇ ਕੇ ਤੂੰ ਮੈਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ты дал тело, ум и жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37673,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਿਰਪਾ ਤੇ ਨੀਚੁ ਨਿਵਾਜਿਆ ॥੩॥",
          "roman": "gur kirpā te nīch nivājiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਗੁਰੂ ਦੀ ਮੇਹਰ ਨਾਲ ਤੂੰ ਮੈਨੂੰ ਨਕਾਰੇ ਨੂੰ ਵਡਿਆਈ ਦਿੱਤੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру возвысил меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37674,
          "is_rahao": false,
          "gurmukhi": "ਖੋਲਿ ਕਿਵਾਰਾ ਮਹਲਿ ਬੁਲਾਇਆ ॥",
          "roman": "khol kivārā mahal bulāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਮੇਰੇ ਮਨ ਦੇ) ਕਿਵਾੜ ਖੋਲ੍ਹ ਕੇ ਤੂੰ ਮੈਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Открыв двери, ты привёл меня к себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37675,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸਾ ਸਾ ਤੈਸਾ ਦਿਖਲਾਇਆ ॥",
          "roman": "jēsā sā tēsā dikhlāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਮੈਨੂੰ ਸਾਖਿਆਤ ਆਪਣਾ ਦੀਦਾਰ ਬਖ਼ਸ਼ਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ты показал себя таким, как есть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37676,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸਭੁ ਪੜਦਾ ਤੂਟਾ ॥",
          "roman": "kah nānak sabh paṛdā ṭūṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-  (ਤੇਰੇ ਨਾਲੋਂ ਵਿੱਥ ਪਾਣ ਵਾਲਾ ਮੇਰੇ ਅੰਦਰੋਂ) ਸਾਰਾ ਪਰਦਾ ਹੁਣ ਟੁੱਟ ਗਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит, вся преграда исчезла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37677,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਤੇਰਾ ਤੂ ਮੈ ਮਨਿ ਵੂਠਾ ॥੪॥੩॥੧੪॥",
          "roman": "hau terā tū mē man vūṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਤੂੰ ਮੇਰੇ ਮਨ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈਂ, ਮੈਂ ਤੇਰਾ ਹੋ ਚੁਕਾ ਹਾਂ ॥੪॥੩॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "Ты живёшь в моём сердце, и я стал твоим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3303,
      "rahao_verse_id": 37684,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37678,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37679,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕੁ ਲਾਇਓ ਅਪੁਨੀ ਸੇਵ ॥",
          "roman": "sevak lāio apunī sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ (ਗੁਰੂ) ਨੇ (ਮੈਨੂੰ ਆਪਣਾ) ਸੇਵਕ (ਬਣਾ ਕੇ) ਆਪਣੀ (ਇਸ) ਸੇਵਾ ਵਿਚ ਲਾਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот (Гуру), кто сделал меня своим слугой и поставил в это своё служение,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37680,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤੁ ਨਾਮੁ ਦੀਓ ਮੁਖਿ ਦੇਵ ॥",
          "roman": "amrit nām dīo mukh dev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਚਾਨਣ-ਰੂਪ ਪ੍ਰਭੂ ਦਾ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ (ਜਪਣ ਵਾਸਤੇ ਮੇਰੇ) ਮੂੰਹ ਵਿਚ ਦਿੱਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто вложил в мои уста имя, дающее духовную жизнь, имя Света-Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37681,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੀ ਚਿੰਤਾ ਆਪਿ ਨਿਵਾਰੀ ॥",
          "roman": "saglī chintā āp nivārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ (ਮੇਰੇ ਅੰਦਰੋਂ) ਸਾਰੀ ਚਿੰਤਾ ਆਪ (ਮੇਹਰ ਕਰ ਕੇ) ਦੂਰ ਕਰ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто сам, по милости, устранил из меня всякую тревогу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37682,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਗੁਰ ਕਉ ਹਉ ਸਦ ਬਲਿਹਾਰੀ ॥੧॥",
          "roman": "tis gur kau hau sad balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тому Гуру я всегда приношу себя в жертву ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37683,
          "is_rahao": true,
          "gurmukhi": "ਕਾਜ ਹਮਾਰੇ ਪੂਰੇ ਸਤਗੁਰ ॥",
          "roman": "kāj hamāre pūre satgur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਤਿਗੁਰੂ! ਤੂੰ ਮੇਰੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚਾੜ੍ਹ ਦਿੱਤੇ ਹਨ (ਤੇਰੀ ਮੇਹਰ ਨਾਲ ਮੈਂ ਬੇ-ਗ਼ਰਜ਼ ਹੋ ਗਿਆ ਹਾਂ)।"
            },
            "sahib_singh_ru": {
              "main": "О Сатгуру! Ты завершил все мои дела (по твоей милости я стал бескорыстным)."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37684,
          "is_rahao": true,
          "gurmukhi": "ਬਾਜੇ ਅਨਹਦ ਤੂਰੇ ਸਤਗੁਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bāje anhad tūre satgur",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਤਿਗੁਰੂ! (ਹੁਣ ਇਉਂ ਪ੍ਰਤੀਤ ਹੋ ਰਿਹਾ ਹੈ, ਜਿਵੇਂ ਮੇਰੇ ਅੰਦਰ) ਇੱਕ-ਰਸ (ਖ਼ੁਸ਼ੀ ਦੇ) ਵਾਜੇ ਵੱਜ ਰਹੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О Сатгуру! Теперь ощущается, будто внутри меня звучат непрерывные инструменты радости ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37685,
          "is_rahao": false,
          "gurmukhi": "ਮਹਿਮਾ ਜਾ ਕੀ ਗਹਿਰ ਗੰਭੀਰ ॥",
          "roman": "mahimā jā kī gahir gambhīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਦੀ ਵਡਿਆਈ ਬੇਅੰਤ ਅਥਾਹ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Чья слава безгранична и глубока,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37686,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਨਿਹਾਲੁ ਦੇਇ ਜਿਸੁ ਧੀਰ ॥",
          "roman": "hoi nihāl dei jis dhīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਜਿਸ (ਮਨੁੱਖ) ਨੂੰ ਧੀਰਜ ਬਖ਼ਸ਼ਦਾ ਹੈ, ਉਹ ਮਨੁੱਖ ਲੂੰ-ਲੂੰ ਖ਼ੁਸ਼ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "того, кому Он дарует терпение, тот человек становится полностью счастливым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37687,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਬੰਧਨ ਕਾਟੇ ਰਾਇ ॥",
          "roman": "jā ke bandhan kāṭe rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ-ਪਾਤਿਸ਼ਾਹ ਜਿਸ ਮਨੁੱਖ ਦੇ (ਮਾਇਆ ਦੇ) ਬੰਧਨ ਕੱਟ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь-Царь, который разрывает у человека оковы (майи),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37688,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਨਰੁ ਬਹੁਰਿ ਨ ਜੋਨੀ ਪਾਇ ॥੨॥",
          "roman": "so nar bahur na jonī pāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਮੁੜ ਜਨਮਾਂ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਪੈਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек больше не попадает в круг перерождений ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37689,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਅੰਤਰਿ ਪ੍ਰਗਟਿਓ ਆਪ ॥",
          "roman": "jā kē antar pragatyo āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਰਮਾਤਮਾ ਆਪ ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆਪਣਾ ਪ੍ਰਕਾਸ਼ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! В чьём сердце Сам Бог раскрывает Себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37690,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਨਾਹੀ ਦੂਖ ਸੰਤਾਪ ॥",
          "roman": "tā kau nāhī dūkh santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਕੋਈ ਦੁੱਖ-ਕਲੇਸ਼ ਪੋਹ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "того не касается никакая боль и страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37691,
          "is_rahao": false,
          "gurmukhi": "ਲਾਲੁ ਰਤਨੁ ਤਿਸੁ ਪਾਲੈ ਪਰਿਆ ॥",
          "roman": "lāl ratan tis pālē pariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ-ਲਾਲ ਲੱਭ ਪੈਂਦਾ ਹੈ, ਨਾਮ-ਰਤਨ ਮਿਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот человек обретает драгоценность Имени — драгоценный камень."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37692,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਕੁਟੰਬ ਓਹੁ ਜਨੁ ਲੈ ਤਰਿਆ ॥੩॥",
          "roman": "sagal kuṭamb oh jan lē tariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਸਾਰੇ ਪਰਵਾਰ ਨੂੰ (ਭੀ ਆਪਣੇ ਨਾਲ) ਲੈ ਕੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и он переправляется через океан мира вместе со всей своей семьёй ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37693,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕਿਛੁ ਭਰਮੁ ਨ ਦੁਬਿਧਾ ਦੂਜਾ ॥",
          "roman": "nā kichh bharam na dubidhā dūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਨੁੱਖ ਨੂੰ ਕੋਈ ਭਟਕਣਾ ਨਹੀਂ ਰਹਿੰਦੀ, ਉਸ ਦੇ ਅੰਦਰ ਦੁਚਿੱਤਾ-ਪਨ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ, ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਮੇਰ-ਤੇਰ ਨਹੀਂ ਹੁੰਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! У такого человека не остаётся заблуждений, нет двойственности, нет чувства «моё–твоё»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37694,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਏਕੁ ਨਿਰੰਜਨ ਪੂਜਾ ॥",
          "roman": "eko ek niranjan pūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਸਿਰਫ਼ ਇੱਕ ਮਾਇਆ ਤੋਂ ਨਿਰਲੇਪ ਪ੍ਰਭੂ ਦੀ ਬੰਦਗੀ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тот, кто поклоняется только Единому, свободному от майи Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37695,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਦੇਖਉ ਆਪਿ ਦਇਆਲ ॥",
          "roman": "jat kat dekhau āp dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਜਿਧਰ ਕਿਧਰ ਵੇਖਦਾ ਹਾਂ, ਮੈਨੂੰ ਉਹ ਦਇਆ ਦਾ ਘਰ ਪ੍ਰਭੂ ਹੀ ਦਿੱਸ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни смотрел, я вижу лишь Милостивого Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37696,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭ ਮਿਲੇ ਰਸਾਲ ॥੪॥੪॥੧੫॥",
          "roman": "kah nānak prabh mile rasāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਨੂੰ) ਆਨੰਦ ਦਾ ਸੋਮਾ ਪ੍ਰਭੂ ਜੀ ਮਿਲ ਪਏ ਹਨ ॥੪॥੪॥੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: благодаря милости Гуру я обрел Бога — источник блаженства ॥4॥4॥15॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3304,
      "rahao_verse_id": 37703,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37697,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37698,
          "is_rahao": false,
          "gurmukhi": "ਤਨ ਤੇ ਛੁਟਕੀ ਅਪਨੀ ਧਾਰੀ ॥",
          "roman": "tan te chhuṭkī apnī dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ) ਮੇਰੇ ਸਰੀਰ ਵਿਚੋਂ ਇਹ ਮਿੱਥ ਮੁੱਕ ਗਈ ਹੈ ਕਿ ਇਹ ਸਰੀਰ ਮੇਰਾ ਹੈ, ਇਹ ਸਰੀਰ ਮੇਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру из моего тела исчезло это убеждение «это тело моё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37699,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਆਗਿਆ ਲਗੀ ਪਿਆਰੀ ॥",
          "roman": "prabh kī āgiā lagī piārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਨੂੰ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਮਿੱਠੀ ਲੱਗਣ ਲੱਗ ਪਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Теперь мне стала сладка воля Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37700,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕਰੈ ਸੁ ਮਨਿ ਮੇਰੈ ਮੀਠਾ ॥",
          "roman": "jo kichh karē so man merē mīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਕੁਝ ਪਰਮਾਤਮਾ ਕਰਦਾ ਹੈ, ਉਹ (ਹੁਣ) ਮੇਰੇ ਮਨ ਵਿਚ ਮਿੱਠਾ ਲੱਗ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что делает Бог, теперь кажется моему сердцу сладким."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37701,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਇਹੁ ਅਚਰਜੁ ਨੈਨਹੁ ਡੀਠਾ ॥੧॥",
          "roman": "tā ihu acharaj nēnah dīṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਆਤਮਕ ਤਬਦੀਲੀ ਦਾ) ਇਹ ਅਚਰਜ ਤਮਾਸ਼ਾ ਮੈਂ ਪਰਤੱਖ ਵੇਖ ਲਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Это удивительное изменение я увидел собственными глазами ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37702,
          "is_rahao": true,
          "gurmukhi": "ਅਬ ਮੋਹਿ ਜਾਨੀ ਰੇ ਮੇਰੀ ਗਈ ਬਲਾਇ ॥",
          "roman": "ab moh jānī re merī gaī balāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਹੁਣ ਮੈਂ (ਆਤਮਕ ਜੀਵਨ ਦੀ ਮਰਯਾਦਾ) ਸਮਝ ਲਈ ਹੈ, ਮੇਰੇ ਅੰਦਰੋਂ (ਚਿਰਾਂ ਦੀ ਚੰਬੜੀ ਹੋਈ ਮਮਤਾ ਦੀ) ਡੈਣ ਨਿਕਲ ਗਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Теперь я понял духовную жизнь — из меня ушла привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37703,
          "is_rahao": true,
          "gurmukhi": "ਬੁਝਿ ਗਈ ਤ੍ਰਿਸਨ ਨਿਵਾਰੀ ਮਮਤਾ ਗੁਰਿ ਪੂਰੈ ਲੀਓ ਸਮਝਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bujh gaī trisan nivārī mamtā gur pūrē līo samjhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਮੈਨੂੰ (ਜੀਵਨ ਦੀ) ਸੂਝ ਬਖ਼ਸ਼ ਦਿੱਤੀ ਹੈ। (ਮੇਰੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦੇ ਲਾਲਚ ਦੀ ਅੱਗ ਬੁੱਝ ਗਈ ਹੈ, ਗੁਰੂ ਨੇ ਮੇਰਾ ਮਾਇਆ ਦਾ ਮੋਹ ਦੂਰ ਕਰ ਦਿੱਤਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Совершенный Гуру дал мне понимание: огонь жажды угас, Гуру устранил мою привязанность к майе ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37704,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਰਾਖਿਓ ਗੁਰਿ ਸਰਨਾ ॥",
          "roman": "kar kirpā rākhiō gur sarnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਨੇ ਮੇਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਆਪਣੀ ਸਰਨ ਵਿਚ ਰੱਖਿਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! По милости Гуру держит меня в своей защите."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37705,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪਕਰਾਏ ਹਰਿ ਕੇ ਚਰਨਾ ॥",
          "roman": "gur pakrāe har ke charnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਪ੍ਰਭੂ ਦੇ ਚਰਨ ਫੜਾ ਦਿੱਤੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру привёл меня к стопам Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37706,
          "is_rahao": false,
          "gurmukhi": "ਬੀਸ ਬਿਸੁਏ ਜਾ ਮਨ ਠਹਰਾਨੇ ॥",
          "roman": "bīs bisue jā man ṭhahrāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਜਦੋਂ ਮੇਰਾ ਮਨ ਪੂਰੇ ਤੌਰ ਤੇ ਠਹਿਰ ਗਿਆ ਹੈ, (ਟਿਕ ਗਿਆ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Когда мой ум полностью успокоился,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37707,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਾਰਬ੍ਰਹਮ ਏਕੈ ਹੀ ਜਾਨੇ ॥੨॥",
          "roman": "gur pārbrahm ekē hī jāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਗੁਰੂ ਅਤੇ ਪਰਮਾਤਮਾ ਇੱਕ-ਰੂਪ ਦਿੱਸ ਰਹੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "я увидел Гуру и Бога как единое ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37708,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜੋ ਕੀਨੋ ਹਮ ਤਿਸ ਕੇ ਦਾਸ ॥",
          "roman": "jo jo kīno ham tis ke dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਜੇਹੜਾ ਜੇਹੜਾ ਜੀਵ ਪਰਮਾਤਮਾ ਨੇ ਪੈਦਾ ਕੀਤਾ ਹੈ ਮੈਂ ਹਰੇਕ ਦਾ ਸੇਵਕ ਬਣ ਗਿਆ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Все существа, которых создал Бог — я стал слугой каждого,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37709,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਮੇਰੇ ਕੋ ਸਗਲ ਨਿਵਾਸ ॥",
          "roman": "prabh mere ko sagal nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਨੂੰ ਦਿੱਸ ਪਿਆ ਹੈ ਕਿ) ਸਾਰੇ ਹੀ ਜੀਵਾਂ ਵਿਚ ਮੇਰੇ ਪਰਮਾਤਮਾ ਦਾ ਨਿਵਾਸ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что я увидел: во всех обитает мой Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37710,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕੋ ਦੂਤੁ ਨਹੀ ਬੈਰਾਈ ॥",
          "roman": "nā ko dūt nahī bērāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਕੋਈ ਭੀ ਜੀਵ ਆਪਣਾ ਦੁਸ਼ਮਨ ਵੈਰੀ ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никто не кажется мне врагом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37711,
          "is_rahao": false,
          "gurmukhi": "ਗਲਿ ਮਿਲਿ ਚਾਲੇ ਏਕੈ ਭਾਈ ॥੩॥",
          "roman": "gal mil chāle ekē bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਮੈਂ ਸਭਨਾਂ ਦੇ ਗਲ ਨਾਲ ਮਿਲ ਕੇ ਤੁਰਦਾ ਹਾਂ (ਜਿਵੇਂ ਅਸੀ) ਇੱਕੋ ਪਿਤਾ (ਦੇ ਪੁੱਤਰ) ਭਰਾ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Я иду, обнимая всех, как братьев от одного отца ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37712,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਗੁਰਿ ਹਰਿ ਦੀਏ ਸੂਖਾ ॥",
          "roman": "jā kau gur har dīe sūkhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਨੇ ਪ੍ਰਭੂ ਨੇ (ਇਹ) ਸੁਖ ਦੇ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому Гуру и Бог дали это счастье,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37713,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਬਹੁਰਿ ਨ ਲਾਗਹਿ ਦੂਖਾ ॥",
          "roman": "tā kau bahur na lāgeh dūkhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਉੱਤੇ ਦੁੱਖ ਮੁੜ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "страдания больше не могут коснуться его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37714,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਸਰਬ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "āpe āp sarab pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਇਹ ਦਿੱਸ ਪੈਂਦਾ ਹੈ ਕਿ) ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਸਭਨਾਂ ਦੀ ਪਾਲਣਾ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он видит, что Сам Бог поддерживает всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37715,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਾਤਉ ਰੰਗਿ ਗੋਪਾਲ ॥੪॥੫॥੧੬॥",
          "roman": "nānak rātau raṅg gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਰੱਖਿਅਕ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ ॥੪॥੫॥੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такой человек окрашен любовью к Богу ॥4॥5॥16॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3305,
      "rahao_verse_id": 37722,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37716,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37717,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖ ਤੇ ਪੜਤਾ ਟੀਕਾ ਸਹਿਤ ॥",
          "roman": "mukh te paṛtā ṭīkā sahit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇਹੜਾ ਮਨੁੱਖ ਧਰਮ-ਪੁਸਤਕਾਂ ਨੂੰ) ਮੂੰਹੋਂ ਤਾਂ ਅਰਥਾਂ ਸਮੇਤ ਪੜ੍ਹਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто читает священные тексты с объяснением,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37718,
          "is_rahao": false,
          "gurmukhi": "ਹਿਰਦੈ ਰਾਮੁ ਨਹੀ ਪੂਰਨ ਰਹਤ ॥",
          "roman": "hirdē rām nahī pūran rahat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਨਹੀਂ ਵੱਸਦਾ, ਨਾਹ ਹੀ ਉਸ ਦੀ ਰਹਿਣੀ ਬੇ-ਦਾਗ਼ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но в его сердце не пребывает Бог, и его жизнь не чиста,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37719,
          "is_rahao": false,
          "gurmukhi": "ਉਪਦੇਸੁ ਕਰੇ ਕਰਿ ਲੋਕ ਦ੍ਰਿੜਾਵੈ ॥",
          "roman": "updes kare kar lok driṛāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਲੋਕਾਂ ਨੂੰ (ਧਰਮ-ਪੁਸਤਕਾਂ ਦਾ) ਉਪਦੇਸ਼ ਕਰਦਾ ਹੈ (ਅਤੇ ਉਪਦੇਸ਼) ਕਰ ਕੇ ਉਹਨਾਂ ਦੇ ਮਨ ਵਿਚ (ਉਹ ਉਪਦੇਸ਼) ਪੱਕੀ ਤਰ੍ਹਾਂ ਬਿਠਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "он наставляет других и укрепляет их в этом учении,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37720,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਕਹਿਆ ਆਪਿ ਨ ਕਮਾਵੈ ॥੧॥",
          "roman": "apnā kahiā āp na kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਆਪਣਾ ਇਹ ਦੱਸਿਆ ਹੋਇਆ ਉਪਦੇਸ਼ ਆਪ ਨਹੀਂ ਕਮਾਂਦਾ (ਉਸ ਨੂੰ ਪੰਡਿਤ ਨਹੀਂ ਆਖਿਆ ਜਾ ਸਕਦਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "но сам не следует тому, что говорит ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37721,
          "is_rahao": true,
          "gurmukhi": "ਪੰਡਿਤ ਬੇਦੁ ਬੀਚਾਰਿ ਪੰਡਿਤ ॥",
          "roman": "pandit bed bīchār pandit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪੰਡਿਤ! ਵੇਦ (ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕ ਦੇ ਉਪਦੇਸ਼) ਨੂੰ (ਆਪਣੇ) ਮਨ ਵਿਚ ਵਸਾਈ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О пандит! Размышляй над ведами и держи их в своём уме,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37722,
          "is_rahao": true,
          "gurmukhi": "ਮਨ ਕਾ ਕ੍ਰੋਧੁ ਨਿਵਾਰਿ ਪੰਡਿਤ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "man kā krodh nivār pandit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਹੇ ਪੰਡਿਤ! ਆਪਣੇ ਮਨ ਦਾ ਗੁੱਸਾ ਦੂਰ ਕਰ ਦੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "и устрани гнев из своего ума ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37723,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਰਾਖਿਓ ਸਾਲ ਗਿਰਾਮੁ ॥",
          "roman": "āgē rākhiō sāl girām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਆਤਮਕ ਜੀਵਨ ਵਲੋਂ) ਅੰਨ੍ਹਾ (ਮਨੁੱਖ) ਸਾਲਗਰਾਮ ਦੀ ਮੂਰਤੀ ਆਪਣੇ ਸਾਹਮਣੇ ਰੱਖ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слепой в духовном смысле человек ставит перед собой идол,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
