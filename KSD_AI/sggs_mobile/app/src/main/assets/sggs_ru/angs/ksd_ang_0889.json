{
  "ang": 889,
  "shabads": [
    {
      "shabad_id": 3308,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37783,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲ ਆਸਨੁ ਬੇਸੁਮਾਰੁ ॥੨॥",
          "roman": "nihchal āsan besumār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਆਤਮਕ ਅਵਸਥਾ ਦਾ ਆਸਣ (ਮਾਇਆ ਦੇ ਅੱਗੇ) ਕਦੇ ਡੋਲਦਾ ਨਹੀਂ। ਉਹ ਅਵਸਥਾ ਕੈਸੀ ਹੈ-ਇਸਦਾ ਅੰਦਾਜ਼ਾ ਨਹੀਂ ਲਾਇਆ ਜਾ ਸਕਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! это состояние устойчиво и неизмеримо ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37784,
          "is_rahao": false,
          "gurmukhi": "ਡਿਗਿ ਨ ਡੋਲੈ ਕਤਹੂ ਨ ਧਾਵੈ ॥",
          "roman": "ḍig na ḍolē katahū na dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਅਵਸਥਾ ਵਿਚ ਪਹੁੰਚਿਆ ਹੋਇਆ ਮਨੁੱਖ (ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ) ਡਿੱਗ ਕੇ ਡੋਲਦਾ ਨਹੀਂ ਹੈ, (ਉਸ ਟਿਕਾਣੇ ਨੂੰ ਛੱਡ ਕੇ) ਕਿਸੇ ਹੋਰ ਪਾਸੇ ਨਹੀਂ ਭਟਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! достигший этого состояния не падает и не колеблется, не блуждает в стороны,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37785,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪ੍ਰਸਾਦਿ ਕੋ ਇਹੁ ਮਹਲੁ ਪਾਵੈ ॥",
          "roman": "gur prasād ko ihu mahal pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਹ ਟਿਕਾਣਾ ਹਾਸਲ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но лишь редкий достигает этого состояния по милости Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37786,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮ ਭੈ ਮੋਹ ਨ ਮਾਇਆ ਜਾਲ ॥",
          "roman": "bhram bhē moh na māiā jāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਥੇ ਦੁਨੀਆ ਦੀਆਂ ਭਟਕਣਾਂ, ਦੁਨੀਆ ਦੇ ਡਰ, ਮਾਇਆ ਦਾ ਮੋਹ, ਮਾਇਆ ਦੇ ਜਾਲ-ਇਹ ਕੋਈ ਭੀ ਪੋਹ ਨਹੀਂ ਸਕਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "там не действуют заблуждения, страхи и сети майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37787,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਮਾਧਿ ਪ੍ਰਭੂ ਕਿਰਪਾਲ ॥੩॥",
          "roman": "sunn samādh prabhū kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਦੇ ਸੋਮੇ ਪ੍ਰਭੂ ਵਿਚ ਮਨੁੱਖ ਦੀ ਐਸੀ ਸੁਰਤ ਜੁੜਦੀ ਹੈ ਕਿ ਕੋਈ ਭੀ ਮਾਇਕ ਫੁਰਨਾ ਨੇੜੇ ਨਹੀਂ ਢੁਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ум соединяется с милостивым Богом в глубоком покое ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37788,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਅੰਤੁ ਨ ਪਾਰਾਵਾਰੁ ॥",
          "roman": "tā kā ant na pārāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਅੰਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ, ਜਿਸ ਦੇ ਸਰੂਪ ਦਾ ਪਾਰਲਾ ਉਰਲਾ ਬੰਨਾ ਨਹੀਂ ਦਿੱਸ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! у Бога нет конца, невозможно постичь Его пределы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37789,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਗੁਪਤੁ ਆਪੇ ਪਾਸਾਰੁ ॥",
          "roman": "āpe gupt āpe pasār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਇਸ ਜਗਤ-ਖਿਲਾਰੇ ਵਿਚ ਆਪ ਹੀ ਲੁਕਿਆ ਦਿੱਸਦਾ ਹੈ, ਇਹ ਜਗਤ-ਖਿਲਾਰਾ ਉਸ ਪ੍ਰਭੂ ਦਾ ਆਪਣਾ ਹੀ ਰੂਪ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он Сам скрыт и Сам проявлен в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37790,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਅੰਤਰਿ ਹਰਿ ਹਰਿ ਸੁਆਦੁ ॥",
          "roman": "jā kē antar har har suād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਸੁਆਦ ਟਿਕ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в чьём сердце поселяется вкус Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37791,
          "is_rahao": false,
          "gurmukhi": "ਕਹਨੁ ਨ ਜਾਈ ਨਾਨਕ ਬਿਸਮਾਦੁ ॥੪॥੯॥੨੦॥",
          "roman": "kahan na jāī nānak bismād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਹਰਿ-ਨਾਮ ਦਾ ਸੁਆਦ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ। ਉਹ ਸੁਆਦ ਅਸਚਰਜ ਹੀ ਹੁੰਦਾ ਹੈ ॥੪॥੯॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! этот вкус невозможно описать — он изумителен ॥4॥9॥20॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3309,
      "rahao_verse_id": 37798,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37792,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37793,
          "is_rahao": false,
          "gurmukhi": "ਭੇਟਤ ਸੰਗਿ ਪਾਰਬ੍ਰਹਮੁ ਚਿਤਿ ਆਇਆ ॥",
          "roman": "bheṭat sang pārbrahm chit āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਨਾਲ ਮਿਲਦਿਆਂ ਪਰਮਾਤਮਾ (ਮੇਰੇ) ਚਿਤ ਵਿਚ ਆ ਵੱਸਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! встречаясь с сантом, Парабрахман пришёл и поселился в моём сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37794,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਤਿ ਕਰਤ ਸੰਤੋਖੁ ਮਨਿ ਪਾਇਆ ॥",
          "roman": "sangat karat santokh man pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਕਰਦਿਆਂ ਮੈਂ ਮਨ ਵਿਚ ਸੰਤੋਖ ਪ੍ਰਾਪਤ ਕਰ ਲਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "общаясь с сантом, я обрёл удовлетворение в уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37795,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਹ ਚਰਨ ਮਾਥਾ ਮੇਰੋ ਪਉਤ ॥",
          "roman": "santah charan māthā mero paut",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਮੇਹਰ ਕਰੇ) ਮੇਰਾ ਮੱਥਾ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨਾਂ ਤੇ ਪਿਆ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "пусть моя голова пребывает у стоп святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37796,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਬਾਰ ਸੰਤਹ ਡੰਡਉਤ ॥੧॥",
          "roman": "anik bār santah dandaut",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਅਨੇਕਾਂ ਵਾਰੀ ਸੰਤ ਜਨਾਂ ਨੂੰ ਨਮਸਕਾਰ ਕਰਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "я многократно кланяюсь святым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37797,
          "is_rahao": true,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਸੰਤਨ ਕੈ ਬਲਿਹਾਰੀ ॥",
          "roman": "ih man santan kē balihārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮੇਰਾ ਇਹ ਮਨ ਸੰਤ-ਜਨਾਂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "о брат! мой ум предан святым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37798,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕੀ ਓਟ ਗਹੀ ਸੁਖੁ ਪਾਇਆ ਰਾਖੇ ਕਿਰਪਾ ਧਾਰੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā kī oṭ gahī sukh pāiā rākhe kirpā dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦਾ ਆਸਰਾ ਲੈ ਕੇ ਮੈਂ (ਆਤਮਕ) ਆਨੰਦ ਹਾਸਲ ਕੀਤਾ ਹੈ। ਸੰਤ ਜਨ ਕਿਰਪਾ ਕਰ ਕੇ (ਵਿਕਾਰ ਆਦਿਕਾਂ ਤੋਂ) ਰੱਖਿਆ ਕਰਦੇ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "опираясь на которых, я обрёл духовную радость, они по милости защищают от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37799,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਹ ਚਰਣ ਧੋਇ ਧੋਇ ਪੀਵਾ ॥",
          "roman": "santah charan dhoī dhoī pīvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਜੇ ਪ੍ਰਭੂ ਕਿਰਪਾ ਕਰੇ, ਤਾਂ) ਮੈਂ ਸੰਤ ਜਨਾਂ ਦੇ ਚਰਨ ਧੋ ਧੋ ਕੇ ਪੀਂਦਾ ਰਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "о брат! если будет милость, я буду омывать стопы святых и пить эту воду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37800,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਹ ਦਰਸੁ ਪੇਖਿ ਪੇਖਿ ਜੀਵਾ ॥",
          "roman": "santah dars pekh pekh jīvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦਾ ਦਰਸਨ ਕਰ ਕਰ ਕੇ ਮੈਨੂੰ ਆਤਮਕ ਜੀਵਨ ਮਿਲਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "созерцая святых, я обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37801,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਹ ਕੀ ਮੇਰੈ ਮਨਿ ਆਸ ॥",
          "roman": "santah kī merē man ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਮਨ ਵਿਚ ਸੰਤ ਜਨਾਂ ਦੀ ਸਹਾਇਤਾ ਦਾ ਧਰਵਾਸ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в моём уме есть надежда на поддержку святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37802,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਹਮਾਰੀ ਨਿਰਮਲ ਰਾਸਿ ॥੨॥",
          "roman": "sant hamārī nirmal rās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਹੀ ਮੇਰੇ ਵਾਸਤੇ ਪਵਿੱਤ੍ਰ ਸਰਮਾਇਆ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "общение со святыми — моё чистое богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37803,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਹਮਾਰਾ ਰਾਖਿਆ ਪੜਦਾ ॥",
          "roman": "sant hamārā rākhiā paṛdā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਨੇ (ਵਿਕਾਰ ਆਦਿਕਾਂ ਤੋਂ) ਮੇਰੀ ਇੱਜ਼ਤ ਬਚਾ ਲਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "о брат! святые сохранили мою честь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37804,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਮੋਹਿ ਕਬਹੂ ਨ ਕੜਦਾ ॥",
          "roman": "sant prasād moh kabhū na kaṛdā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮੈਨੂੰ ਕਦੇ ਭੀ ਕੋਈ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਨਹੀਂ ਵਿਆਪਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "по милости святых меня никогда не тревожит беспокойство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37805,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਹ ਸੰਗੁ ਦੀਆ ਕਿਰਪਾਲ ॥",
          "roman": "santah sang dīā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਦੇ ਸੋਮੇ ਪਰਮਾਤਮਾ ਨੇ ਆਪ ਹੀ ਮੈਨੂੰ ਸੰਤ ਜਨਾਂ ਦਾ ਸਾਥ ਬਖ਼ਸ਼ਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "милостивый Господь Сам даровал мне общество святых,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37806,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਹਾਈ ਭਏ ਦਇਆਲ ॥੩॥",
          "roman": "sant sahāī bhe dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਸੰਤ ਜਨ ਮਦਦਗਾਰ ਬਣਦੇ ਹਨ, ਤਾਂ ਪ੍ਰਭੂ ਦਇਆਵਾਨ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "когда святые становятся помощниками, Господь становится милостивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37807,
          "is_rahao": false,
          "gurmukhi": "ਸੁਰਤਿ ਮਤਿ ਬੁਧਿ ਪਰਗਾਸੁ ॥",
          "roman": "surat mat budh pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਦੀ ਸੰਗਤਿ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮੇਰੀ) ਸੁਰਤ ਵਿਚ ਮਤਿ ਵਿਚ ਬੁੱਧਿ ਵਿਚ (ਆਤਮਕ ਜੀਵਨ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "благодаря обществу святых в моей душе, уме и разуме появляется свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37808,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿਰ ਗੰਭੀਰ ਅਪਾਰ ਗੁਣਤਾਸੁ ॥",
          "roman": "gahir gambhīr apār guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਥਾਹ, ਬੇਅੰਤ, ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ,"
            },
            "sahib_singh_ru": {
              "main": "безграничный, глубокий кладезь добродетелей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37809,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਗਲੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "jīa jant sagle pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਾਰੇ ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ ਕਰਨ ਵਾਲਾ ਪਰਮਾਤਮਾ-"
            },
            "sahib_singh_ru": {
              "main": "Он — питающий всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37810,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੰਤਹ ਦੇਖਿ ਨਿਹਾਲ ॥੪॥੧੦॥੨੧॥",
          "roman": "nānak santah dekh nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਪਣੇ) ਸੰਤ ਜਨਾਂ ਨੂੰ ਵੇਖ ਕੇ ਖ਼ੁਸ਼ ਹੋ ਜਾਂਦਾ ਹੈ ॥੪॥੧੦॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! видя святых, человек становится счастливым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3310,
      "rahao_verse_id": 37817,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37811,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37812,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਕਾਜਿ ਨ ਗ੍ਰਿਹੁ ਰਾਜੁ ਮਾਲੁ ॥",
          "roman": "terē kāj na grih rāj māl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਇਹ ਘਰ, ਇਹ ਹਕੂਮਤ, ਇਹ ਧਨ (ਇਹਨਾਂ ਵਿਚੋਂ ਕੋਈ ਭੀ) ਤੇਰੇ (ਆਤਮਕ ਜੀਵਨ ਦੇ) ਕੰਮ ਨਹੀਂ ਆ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "о друг! этот дом, власть и богатство не пригодятся тебе для духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37813,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਕਾਜਿ ਨ ਬਿਖੈ ਜੰਜਾਲੁ ॥",
          "roman": "terē kāj na bikhē janjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਕ ਪਦਾਰਥਾਂ ਦਾ ਝੰਬੇਲਾ ਭੀ ਤੈਨੂੰ ਆਤਮਕ ਜੀਵਨ ਵਿਚ ਲਾਭ ਨਹੀਂ ਦੇ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "и путаница мирских вещей не принесёт пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37814,
          "is_rahao": false,
          "gurmukhi": "ਇਸਟ ਮੀਤ ਜਾਣੁ ਸਭ ਛਲੈ ॥",
          "roman": "iṣṭ mīt jāṇ sabh chhalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੇਤਾ ਰੱਖ ਕਿ ਇਹ ਸਾਰੇ ਪਿਆਰੇ ਮਿੱਤਰ (ਤੇਰੇ ਵਾਸਤੇ) ਛਲ-ਰੂਪ ਹੀ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "знай, что все близкие и друзья — лишь обман,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37815,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਸੰਗਿ ਤੇਰੈ ਚਲੈ ॥੧॥",
          "roman": "har har nām sang terē chalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਤੇਰੇ ਨਾਲ ਸਾਥ ਕਰ ਸਕਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "только Имя Господа пойдёт с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37816,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਗੁਣ ਗਾਇ ਲੇ ਮੀਤਾ ਹਰਿ ਸਿਮਰਤ ਤੇਰੀ ਲਾਜ ਰਹੈ ॥",
          "roman": "rām nām guṇ gāi le mītā har simrat terī lāj rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੇ ਗੁਣ (ਇਸ ਵੇਲੇ) ਗਾ ਲੈ। ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਹੀ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਤੇਰੀ ਇੱਜ਼ਤ ਰਹਿ ਸਕਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "о друг! воспой качества Имени Господа, только памятуя Его, сохранится твоя честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37817,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਜਮੁ ਕਛੁ ਨ ਕਹੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har simrat jam kachh na kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਜਮਰਾਜ ਭੀ ਕੁਝ ਨਹੀਂ ਆਖਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "памятуя Господа, даже Яма ничего не скажет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37818,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਸਗਲ ਨਿਰਾਰਥ ਕਾਮ ॥",
          "roman": "bin har sagal nirārath kām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਸਾਰੇ ਹੀ ਕੰਮ ਵਿਅਰਥ (ਹੋ ਜਾਂਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "о друг! без Имени Господа все дела напрасны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37819,
          "is_rahao": false,
          "gurmukhi": "ਸੁਇਨਾ ਰੁਪਾ ਮਾਟੀ ਦਾਮ ॥",
          "roman": "suinā rupā māṭī dām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਸਿਮਰਦਾ, ਤਾਂ) ਸੋਨਾ, ਚਾਂਦੀ, ਰੁਪਇਆ-ਪੈਸੇ (ਤੇਰੇ ਵਾਸਤੇ) ਮਿੱਟੀ (-ਸਮਾਨ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "золото, серебро и деньги становятся как пыль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37820,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਜਾਪਿ ਮਨ ਸੁਖਾ ॥",
          "roman": "gur kā sabad jāp man sukhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਚੇਤੇ ਕਰਦਾ ਰਿਹਾ ਕਰ, ਤੇਰੇ ਮਨ ਨੂੰ ਆਨੰਦ ਮਿਲੇਗਾ;"
            },
            "sahib_singh_ru": {
              "main": "о друг! повторяй Слово Гуру — ум обретёт радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37821,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਤੇਰੋ ਊਜਲ ਮੁਖਾ ॥੨॥",
          "roman": "īhā ūhā tero ūjal mukhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਵਿਚ ਅਤੇ ਪਰਲੋਕ ਵਿਚ ਤੂੰ ਸੁਰਖ਼ਰੂ ਹੋਵੇਂਗਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и здесь, и в ином мире твоё лицо будет светлым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37822,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਰਿ ਥਾਕੇ ਵਡੇ ਵਡੇਰੇ ॥",
          "roman": "kar kar thāke vaḍe vaḍere",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਤੈਥੋਂ ਪਹਿਲਾਂ ਹੋ ਚੁਕੇ ਸਭ ਬੰਦੇ ਮਾਇਆ ਦੇ ਧੰਧੇ ਕਰ ਕਰ ਕੇ ਥੱਕਦੇ ਰਹੇ,"
            },
            "sahib_singh_ru": {
              "main": "о друг! все предшественники уставали, занимаясь мирскими делами,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37823,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨ ਹੀ ਨ ਕੀਏ ਕਾਜ ਮਾਇਆ ਪੂਰੇ ॥",
          "roman": "kin hī na kīe kāj māiā pūre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਨੇ ਭੀ ਇਹ ਧੰਧੇ ਸਿਰੇ ਨਾਹ ਚਾੜ੍ਹੇ (ਕਿਸੇ ਦੀ ਭੀ ਤ੍ਰਿਸ਼ਨਾ ਨਾਹ ਮੁੱਕੀ)।"
            },
            "sahib_singh_ru": {
              "main": "никто не довёл их до конца, жажда не исчезла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37824,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪੈ ਜਨੁ ਕੋਇ ॥",
          "roman": "har har nām japē jan koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "редкий человек повторяет Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37825,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਆਸਾ ਪੂਰਨ ਹੋਇ ॥੩॥",
          "roman": "tā kī āsā pūran hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਆਸ ਪੂਰੀ ਹੋ ਜਾਂਦੀ ਹੈ (ਉਸ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਮੁੱਕ ਜਾਂਦੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "его желания исполняются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37826,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਭਗਤਨ ਕੋ ਨਾਮੁ ਅਧਾਰੁ ॥",
          "roman": "har bhagtan ko nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਵਾਸਤੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਜੀਵਨ ਦਾ ਆਸਰਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "о друг! для преданных Имя Господа — опора жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37827,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤੀ ਜੀਤਾ ਜਨਮੁ ਅਪਾਰੁ ॥",
          "roman": "santī jītā janam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਹੀਏਂ ਸੰਤ ਜਨਾਂ ਨੇ ਹੀ ਅਮੋਲਕ ਮਨੁੱਖਾ ਜੀਵਨ ਦੀ ਬਾਜ਼ੀ ਜਿੱਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "поэтому святые выиграли бесценную человеческую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37828,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸੰਤੁ ਕਰੇ ਸੋਈ ਪਰਵਾਣੁ ॥",
          "roman": "har sant kare soī parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਸੰਤ ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ, ਉਹ (ਪਰਮਾਤਮਾ ਦੀਆਂ ਨਜ਼ਰਾਂ ਵਿਚ) ਕਬੂਲ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то, что делает святой Господа, принимается Им."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37829,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸੁ ਤਾ ਕੈ ਕੁਰਬਾਣੁ ॥੪॥੧੧॥੨੨॥",
          "roman": "nānak dās tā kē kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਮੈਂ) ਦਾਸ ਉਸ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੪॥੧੧॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак! слуга жертвует собой ради него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3311,
      "rahao_verse_id": 37838,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 37830,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37831,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਚਹਿ ਦਰਬੁ ਦੇਹਿ ਦੁਖੁ ਲੋਗ ॥",
          "roman": "sincheh darb deh dukh log",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੂਰਖ!) ਤੂੰ ਧਨ ਇਕੱਠਾ ਕਰੀ ਜਾਂਦਾ ਹੈਂ, (ਅਤੇ ਧਨ ਜੋੜਨ ਦੇ ਉੱਦਮ ਵਿਚ) ਲੋਕਾਂ ਨੂੰ ਦੁੱਖ ਦੇਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "о глупец! ты собираешь богатство, причиняя людям страдания,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37832,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਕਾਜਿ ਨ ਅਵਰਾ ਜੋਗ ॥",
          "roman": "terē kāj na avarā jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੌਤ ਆਉਣ ਤੇ ਇਹ ਧਨ) ਤੇਰੇ ਕੰਮ ਨਹੀਂ ਆਵੇਗਾ, ਹੋਰਨਾਂ (ਦੇ ਵਰਤਣ) ਜੋਗਾ ਰਹਿ ਜਾਇਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "при смерти оно тебе не пригодится, останется другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37833,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਅਹੰਕਾਰੁ ਹੋਇ ਵਰਤਹਿ ਅੰਧ ॥",
          "roman": "kar ahankār hoi vartah andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੂਰਖ! ਇਸ ਧਨ ਦਾ) ਮਾਣ ਕਰ ਕੇ (ਇਸ ਧਨ ਦੇ ਨਸ਼ੇ ਵਿਚ) ਅੰਨ੍ਹਾ ਹੋ ਕੇ ਤੂੰ (ਲੋਕਾਂ ਨਾਲ) ਵਰਤਾਰਾ ਕਰਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "гордясь этим богатством, ты слепо ведёшь себя с людьми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37834,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਕੀ ਜੇਵੜੀ ਤੂ ਆਗੈ ਬੰਧ ॥੧॥",
          "roman": "jam kī jevṛī tū āgē bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ) ਮੌਤ ਦੀ ਫਾਹੀ (ਤੇਰੇ ਗਲ ਵਿਚ ਪਈ, ਉਸ ਫਾਹੀ ਵਿਚ) ਬੱਝੇ ਹੋਏ ਨੂੰ ਤੈਨੂੰ ਪਰਲੋਕ ਵਿਚ (ਲੈ ਜਾਣਗੇ, ਤੇ ਧਨ ਇਥੇ ਹੀ ਰਹਿ ਜਾਇਗਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "когда петля смерти затянется, тебя уведут связанным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37835,
          "is_rahao": true,
          "gurmukhi": "ਛਾਡਿ ਵਿਡਾਣੀ ਤਾਤਿ ਮੂੜੇ ॥",
          "roman": "chhāḍ viḍāṇī tāt mūṛe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ! ਦੂਜਿਆਂ ਨਾਲ ਈਰਖਾ ਕਰਨੀ ਛੱਡ ਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "о глупец! оставь зависть к другим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37836,
          "is_rahao": true,
          "gurmukhi": "ਈਹਾ ਬਸਨਾ ਰਾਤਿ ਮੂੜੇ ॥",
          "roman": "īhā basnā rāt mūṛe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੂਰਖ! ਇਸ ਦੁਨੀਆ ਵਿਚ (ਪੰਛੀਆਂ ਵਾਂਗ) ਰਾਤ-ਮਾਤ੍ਰ ਹੀ ਵੱਸਣਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "о глупец! в этом мире пребывание лишь на одну ночь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37837,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਕੇ ਮਾਤੇ ਤੈ ਉਠਿ ਚਲਨਾ ॥",
          "roman": "māiā ke māte tē uṭh chalnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਵਿਚ ਮਸਤ ਹੋਏ ਹੇ ਮੂਰਖ! (ਇਥੋਂ ਆਖ਼ਰ) ਉੱਠ ਕੇ ਤੂੰ ਚਲੇ ਜਾਣਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "о глупец, опьянённый майей! ты уйдёшь отсюда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37838,
          "is_rahao": true,
          "gurmukhi": "ਰਾਚਿ ਰਹਿਓ ਤੂ ਸੰਗਿ ਸੁਪਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rāch rahiō tū sang supnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ) ਤੂੰ (ਇਸ ਜਗਤ-) ਸੁਪਨੇ ਨਾਲ ਰੁੱਝਾ ਪਿਆ ਹੈਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "но ты погружён в этот сон мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37839,
          "is_rahao": false,
          "gurmukhi": "ਬਾਲ ਬਿਵਸਥਾ ਬਾਰਿਕੁ ਅੰਧ ॥",
          "roman": "bāl bivasthā bārik andh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਲ ਉਮਰੇ ਜੀਵ ਬੇ-ਸਮਝ ਬਾਲਕ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в детстве человек остаётся неразумным ребёнком,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 37840,
          "is_rahao": false,
          "gurmukhi": "ਭਰਿ ਜੋਬਨਿ ਲਾਗਾ ਦੁਰਗੰਧ ॥",
          "roman": "bhar joban lāgā durgandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਰ-ਜਵਾਨੀ ਵੇਲੇ ਵਿਕਾਰਾਂ ਵਿਚ ਲੱਗਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в юности погружается в пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
