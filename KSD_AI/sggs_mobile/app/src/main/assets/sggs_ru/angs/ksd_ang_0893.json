{
  "ang": 893,
  "shabads": [
    {
      "shabad_id": 3320,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38009,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਸੁਨਤ ਜਨੁ ਬਿਛੂਅ ਡਸਾਨਾ ॥੨॥",
          "roman": "nām sunat jan bichhūa ḍasānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸੁਣਦਿਆਂ ਤਾਂ ਇਉਂ ਹੁੰਦਾ ਹੈ ਜਿਵੇਂ ਇਸ ਨੂੰ ਠੂੰਹਾਂ ਡੰਗ ਮਾਰ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Услышав Имя Бога, он словно ужален скорпионом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38010,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਕਾਰਣਿ ਸਦ ਹੀ ਝੂਰੈ ॥",
          "roman": "māiā kāraṇ sad hī jhūrē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਸਾਕਤ ਮਨੁੱਖ) ਸਦਾ ਹੀ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਚਿੰਤਾ-ਫ਼ਿਕਰ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он постоянно беспокоится из-за майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38011,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਮੁਖਿ ਕਬਹਿ ਨ ਉਸਤਤਿ ਕਰੈ ॥",
          "roman": "man mukh kabah na ustat karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਕਦੇ ਭੀ ਆਪਣੇ ਮਨ ਵਿਚ ਆਪਣੇ ਮੂੰਹ ਨਾਲ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਨਹੀਂ ਕਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Никогда не восхваляет Бога ни в уме, ни устами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38012,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਨਿਰੰਕਾਰ ਦਾਤਾਰੁ ॥",
          "roman": "nirbhau nirankār dātār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਪਰਮਾਤਮਾ ਸਭ ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈ, ਜਿਸ ਨੂੰ ਕਿਸੇ ਦਾ ਡਰ-ਭਉ ਨਹੀਂ ਹੈ, ਜੋ ਸਰੀਰਾਂ ਦੀ ਕੈਦ ਤੋਂ ਪਰੇ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Бог — бесстрашный, бесформенный даритель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38013,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸਿਉ ਪ੍ਰੀਤਿ ਨ ਕਰੈ ਗਵਾਰੁ ॥੩॥",
          "roman": "tis siu prīt na karē gavār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨਾਲ ਇਹ ਮੂਰਖ ਸਾਕਤ ਕਦੇ ਪਿਆਰ ਨਹੀਂ ਪਾਂਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Но глупец не любит Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38014,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਸਾਹਾ ਸਿਰਿ ਸਾਚਾ ਸਾਹੁ ॥",
          "roman": "sabh sāhā sir sāchā sāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ!) ਤੂੰ ਸਭ ਸਭ ਸ਼ਾਹਾਂ ਤੋਂ ਵੱਡਾ ਅਤੇ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਸ਼ਾਹ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты — истинный Царь над всеми царями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38015,
          "is_rahao": false,
          "gurmukhi": "ਵੇਮੁਹਤਾਜੁ ਪੂਰਾ ਪਾਤਿਸਾਹੁ ॥",
          "roman": "vēmuhatāj pūrā pātisāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਕਿਸੇ ਦੀ ਮੁਥਾਜੀ ਨਹੀਂ, ਤੂੰ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਪਾਤਿਸ਼ਾਹ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты независимый и совершенный владыка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38016,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹ ਮਗਨ ਲਪਟਿਓ ਭ੍ਰਮ ਗਿਰਹ ॥",
          "roman": "moh magan lapaṭiō bhram girah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਪੈਦਾ ਕੀਤਾ ਜੀਵ ਸਦਾ ਮਾਇਆ ਦੇ) ਮੋਹ ਵਿਚ ਡੁੱਬਾ ਹੋਇਆ (ਮਾਇਆ ਨਾਲ ਹੀ) ਚੰਬੜਿਆ ਰਹਿੰਦਾ ਹੈ, (ਇਸ ਦੇ ਮਨ ਵਿਚ) ਭਟਕਣਾ ਦੀ ਗੰਢ ਬੱਝੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Существо погружено в привязанность и связано узлом заблуждения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38017,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਰੀਐ ਤੇਰੀ ਮਿਹਰ ॥੪॥੨੧॥੩੨॥",
          "roman": "nānak tarīai terī mihr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ- ਹੇ ਪ੍ਰਭੂ! ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚੋਂ) ਤੇਰੀ ਮਿਹਰ ਨਾਲ ਹੀ ਤਰ ਸਕੀਦਾ ਹੈ ॥੪॥੨੧॥੩੨॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! переплыть можно только по Твоей милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3321,
      "rahao_verse_id": 38024,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38018,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38019,
          "is_rahao": false,
          "gurmukhi": "ਰੈਣਿ ਦਿਨਸੁ ਜਪਉ ਹਰਿ ਨਾਉ ॥",
          "roman": "rēṇ dinas japau har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਕਿਰਪਾ ਕਰ) ਮੈਂ ਦਿਨ ਰਾਤ ਹਰਿ-ਨਾਮ ਜਪਦਾ ਰਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! по милости Твоей я днём и ночью повторял бы Имя Хари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38020,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਦਰਗਹ ਪਾਵਉ ਥਾਉ ॥",
          "roman": "āgē dargeh pāvau thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਇਸ ਤਰ੍ਹਾਂ) ਪਰਲੋਕ ਵਿਚ ਤੇਰੀ ਹਜ਼ੂਰੀ ਵਿਚ ਥਾਂ ਪ੍ਰਾਪਤ ਕਰ ਲਵਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "и таким образом в мире ином получил бы место в Твоём присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38021,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਅਨੰਦੁ ਨ ਹੋਵੀ ਸੋਗੁ ॥",
          "roman": "sadā anand na hovī sog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਨਾਮ ਜਪਦਾ ਹੈ, ਉਸ ਨੂੰ) ਸਦਾ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ, ਕਦੇ ਉਸ ਨੂੰ ਚਿੰਤਾ ਨਹੀਂ ਵਾਪਰਦੀ;"
            },
            "sahib_singh_ru": {
              "main": "У того, кто повторяет Имя, всегда пребывает радость, его никогда не охватывает печаль;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38022,
          "is_rahao": false,
          "gurmukhi": "ਕਬਹੂ ਨ ਬਿਆਪੈ ਹਉਮੈ ਰੋਗੁ ॥੧॥",
          "roman": "kabahū na biāpē haumē rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਉਮੈ ਦਾ ਰੋਗ ਕਦੇ ਉਸ ਉਤੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "болезнь эго никогда не может одолеть его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38023,
          "is_rahao": true,
          "gurmukhi": "ਖੋਜਹੁ ਸੰਤਹੁ ਹਰਿ ਬ੍ਰਹਮ ਗਿਆਨੀ ॥",
          "roman": "khojah santah har brahm giānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨਾਲ ਡੂੰਘੀ ਸਾਂਝ ਰੱਖਣ ਵਾਲੇ ਹੇ ਸੰਤ ਜਨੋ! ਸਦਾ ਪਰਮਾਤਮਾ ਦੀ ਖੋਜ ਕਰਦੇ ਰਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "О святые, имеющие глубокую связь с Богом! всегда продолжайте искать Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38024,
          "is_rahao": true,
          "gurmukhi": "ਬਿਸਮਨ ਬਿਸਮ ਭਏ ਬਿਸਮਾਦਾ ਪਰਮ ਗਤਿ ਪਾਵਹਿ ਹਰਿ ਸਿਮਰਿ ਪਰਾਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bisman bisam bhae bismādā param gat pāvahi har simar parānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀ! (ਸਦਾ) ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਰਹੁ; (ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਬੜੀ ਹੀ ਹੈਰਾਨ ਕਰਨ ਵਾਲੀ ਅਸਚਰਜ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਇਗੀ, ਤੂੰ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਪ੍ਰਾਪਤ ਕਰ ਲਏਂਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О человек! постоянно помни Бога; благодаря этому возникнет удивительное, поразительное духовное состояние, и ты достигнешь высшего состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38025,
          "is_rahao": false,
          "gurmukhi": "ਗਨਿ ਮਿਨਿ ਦੇਖਹੁ ਸਗਲ ਬੀਚਾਰਿ ॥",
          "roman": "gan min dekhah sagal bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਸਾਰੇ ਗਹੁ ਨਾਲ ਚੰਗੀ ਤਰ੍ਹਾਂ ਵਿਚਾਰ ਕੇ ਵੇਖ ਲਵੋ,"
            },
            "sahib_singh_ru": {
              "main": "О святые! тщательно обдумав всё, посмотрите,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38026,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕੋ ਸਕੈ ਨ ਤਾਰਿ ॥",
          "roman": "nām binā ko sakē na tār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕੋਈ ਭੀ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਨਹੀਂ ਲੰਘਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "без Имени Бога никто не может переправить через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38027,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਉਪਾਵ ਨ ਚਾਲਹਿ ਸੰਗਿ ॥",
          "roman": "sagal upāv na chāleh sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਾਮ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਸਾਰੇ ਹੀ ਹੀਲੇ (ਮਨੁੱਖ ਦੇ) ਨਾਲ ਨਹੀਂ ਜਾਂਦੇ (ਸਹਾਇਤਾ ਨਹੀਂ ਕਰਦੇ)।"
            },
            "sahib_singh_ru": {
              "main": "все прочие средства не идут вместе с человеком и не помогают ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38028,
          "is_rahao": false,
          "gurmukhi": "ਭਵਜਲੁ ਤਰੀਐ ਪ੍ਰਭ ਕੈ ਰੰਗਿ ॥੨॥",
          "roman": "bhavjal tarīē prabh kē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰਿਹਾਂ ਹੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "только пребывая в любви Господа можно переправиться через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38029,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹੀ ਧੋਇ ਨ ਉਤਰੈ ਮੈਲੁ ॥",
          "roman": "dehī dho-e na utarē mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਸੰਤ ਜਨੋ! ਤੀਰਥ ਆਦਿਕਾਂ ਤੇ) ਸਰੀਰ ਨੂੰ ਧੋਤਿਆਂ (ਮਨ ਦੀ ਵਿਕਾਰਾਂ ਵਾਲੀ) ਮੈਲ ਦੂਰ ਨਹੀਂ ਹੁੰਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "омывая тело, нечистота ума не устраняется,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38030,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਬਿਆਪੈ ਦੁਬਿਧਾ ਫੈਲੁ ॥",
          "roman": "haumē biāpē dubidhā phēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਗੋਂ ਇਹ) ਹਉਮੈ ਆਪਣਾ ਦਬਾਉ ਪਾ ਲੈਂਦੀ ਹੈ (ਕਿ ਮੈਂ ਤੀਰਥਾਂ ਦੇ ਇਸ਼ਨਾਨ ਕਰ ਆਇਆ ਹਾਂ। ਮਨੁੱਖ ਦੇ ਅੰਦਰ) ਅੰਦਰੋਂ ਹੋਰ ਤੇ ਬਾਹਰੋਂ ਹੋਰ ਹੋਣ ਦਾ ਪਸਾਰਾ ਪਸਰ ਜਾਂਦਾ ਹੈ (ਮਨੁੱਖ ਪਖੰਡੀ ਹੋ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "напротив, эго усиливается, и распространяется двойственность, лицемерие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38031,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਅਉਖਧੁ ਜੋ ਜਨੁ ਖਾਇ ॥",
          "roman": "har har aukhad jo jan khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸੰਤ ਜਨੋ! ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਦਵਾਈ ਖਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который принимает лекарство Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38032,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਰੋਗੁ ਸਗਲ ਮਿਟਿ ਜਾਇ ॥੩॥",
          "roman": "tā kā rog sagal miṭ jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਸਾਰਾ (ਮਾਨਸਕ) ਰੋਗ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "у того вся болезнь ума исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38033,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪਾਰਬ੍ਰਹਮ ਦਇਆਲ ॥",
          "roman": "kar kirpā pārbrahm dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਾਰਬ੍ਰਹਮ! ਹੇ ਦਇਆ ਦੇ ਘਰ! (ਮੇਰੇ ਉਤੇ) ਕਿਰਪਾ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман, Милосердный! прояви ко мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38034,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤੇ ਕਬਹੁ ਨ ਬਿਸਰੁ ਗੋੁਪਾਲ ॥",
          "roman": "man te kabah na bisar gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੋਪਾਲ! ਤੂੰ ਮੇਰੇ ਮਨ ਤੋਂ ਕਦੇ ਭੀ ਨਾਹ ਵਿੱਸਰ।"
            },
            "sahib_singh_ru": {
              "main": "О Гопал! никогда не исчезай из моего ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38035,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਦਾਸ ਕੀ ਹੋਵਾ ਧੂਰਿ ॥",
          "roman": "tere dās kī hovā dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਦਾਸਾਂ ਦੇ ਚਰਨਾਂ ਦੀ ਧੂੜ ਬਣਿਆ ਰਹਾਂ-"
            },
            "sahib_singh_ru": {
              "main": "О Господь! пусть я буду пылью под ногами Твоих слуг,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38036,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕੀ ਪ੍ਰਭ ਸਰਧਾ ਪੂਰਿ ॥੪॥੨੨॥੩੩॥",
          "roman": "nānak kī prabh sardhā pūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਦੀ ਇਹ ਤਾਂਘ ਪੂਰੀ ਕਰ ॥੪॥੨੨॥੩੩॥"
            },
            "sahib_singh_ru": {
              "main": "исполнить это стремление Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3322,
      "rahao_verse_id": 38043,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38037,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38038,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਸਰਣਿ ਪੂਰੇ ਗੁਰਦੇਵ ॥",
          "roman": "terī saraṇ pūre gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਰਬ-ਗੁਣ ਭਰਪੂਰ ਤੇ ਸਭ ਤੋਂ ਵੱਡੇ ਦੇਵਤੇ! ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О совершенный Гуру-Бог! я пришёл в Твоё убежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38039,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਬਿਨੁ ਦੂਜਾ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "tudh bin dūjā nāhī koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਥੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ (ਸਹਾਈ) ਨਹੀਂ (ਦਿੱਸਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "кроме Тебя я не вижу никакого иного помощника."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38040,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਸਮਰਥੁ ਪੂਰਨ ਪਾਰਬ੍ਰਹਮੁ ॥",
          "roman": "tū samrath pūran pārbrahm",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਹਰ ਥਾਂ ਵਿਆਪਕ ਪਰਮੇਸ਼ਰ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — обладатель всей силы, Ты — вездесущий Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38041,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਿਆਏ ਪੂਰਾ ਜਿਸੁ ਕਰਮੁ ॥੧॥",
          "roman": "so dhiāe pūrā jis karam",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ ਤੇਰਾ ਧਿਆਨ ਧਰ ਸਕਦਾ ਹੈ ਜਿਸ ਉਤੇ ਤੇਰੀ ਪੂਰੀ ਬਖ਼ਸ਼ਸ਼ ਹੋਵੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "только тот человек может медитировать на Тебя, на кого нисходит Твоя полная милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38042,
          "is_rahao": true,
          "gurmukhi": "ਤਰਣ ਤਾਰਣ ਪ੍ਰਭ ਤੇਰੋ ਨਾਉ ॥",
          "roman": "taraṇ tāraṇ prabh tero nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ (ਜੀਵਾਂ ਨੂੰ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾਣ ਲਈ ਜਹਾਜ਼ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твоё Имя — это корабль для переправы через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38043,
          "is_rahao": true,
          "gurmukhi": "ਏਕਾ ਸਰਣਿ ਗਹੀ ਮਨ ਮੇਰੈ ਤੁਧੁ ਬਿਨੁ ਦੂਜਾ ਨਾਹੀ ਠਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ekā saraṇ gahī man merē tudh bin dūjā nāhī thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੇ ਮਨ ਨੇ ਇਕ ਤੇਰੀ ਹੀ ਓਟ ਲਈ ਹੈ। ਹੇ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ (ਆਸਰੇ ਵਾਲੀ) ਥਾਂ ਨਹੀਂ ਸੁੱਝਦੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Мой ум принял только Твоё прибежище; кроме Тебя нет иного места опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38044,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਜੀਵਾ ਤੇਰਾ ਨਾਉ ॥",
          "roman": "jap jap jīvā terā nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਗੁਰਦੇਵ! ਤੇਰਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਮੈਂ (ਇਥੇ) ਆਤਮਕ ਜੀਵਨ ਹਾਸਲ ਕਰ ਰਿਹਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Твоё Имя, я обретаю духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38045,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਦਰਗਹ ਪਾਵਉ ਠਾਉ ॥",
          "roman": "āgē dargeh pāvau thāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਗਾਂਹ ਤੇਰੀ ਹਜ਼ੂਰੀ ਵਿਚ ਮੈਂ (ਟਿਕਣ ਜੋਗਾ) ਥਾਂ ਪ੍ਰਾਪਤ ਕਰ ਸਕਾਂਗਾ।"
            },
            "sahib_singh_ru": {
              "main": "и впереди получу место в Твоём присутствии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38046,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਅੰਧੇਰਾ ਮਨ ਤੇ ਜਾਇ ॥",
          "roman": "dūkh andherā man te jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਉਸ ਮਨੁੱਖ ਦੇ ਮਨ ਤੋਂ ਦੁੱਖ-ਕਲੇਸ਼ ਤੇ (ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ) ਹਨੇਰਾ ਚਲਾ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "из ума такого человека исчезают страдания и тьма привязанности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38047,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਬਿਨਸੈ ਰਾਚੈ ਹਰਿ ਨਾਇ ॥੨॥",
          "roman": "durmat binsē rāchē har nāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਤੇਰੇ ਨਾਮ ਵਿਚ ਲੀਨ ਹੁੰਦਾ ਹੈ, (ਉਸ ਦੇ ਅੰਦਰੋਂ) ਭੈੜੀ ਮਤਿ ਦੂਰ ਹੋ ਜਾਂਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "его дурной ум уничтожается, и он погружается в Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38048,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "charan kamal siu lāgī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) (ਪਰਮਾਤਮਾ ਦੇ) ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ ਪਿਆਰ ਬਣ ਜਾਣਾ-"
            },
            "sahib_singh_ru": {
              "main": "Любовь к прекрасным стопам Бога —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38049,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "gur pūre kī nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਹੀ) ਪੂਰੇ ਗੁਰੂ ਦੀ ਪਵਿੱਤਰ ਜੀਵਨ-ਮਰਯਾਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "это чистый образ жизни совершенного Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38050,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਭਾਗਾ ਨਿਰਭਉ ਮਨਿ ਬਸੈ ॥",
          "roman": "bhau bhāgā nirbhau man basē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਡਰ-ਰਹਿਤ ਪ੍ਰਭੂ ਉਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ, ਉਸ ਦਾ ਹਰੇਕ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в сердце поселяется бесстрашный Бог, и весь страх исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38051,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਰਸਨਾ ਨਿਤ ਜਪੈ ॥੩॥",
          "roman": "amrit nām rasnā nit japē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਆਪਣੀ ਜੀਭ ਨਾਲ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਨਾਮ ਨਿੱਤ ਜਪਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "у того, кто постоянно повторяет языком дающее жизнь Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38052,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਜਨਮ ਕੇ ਕਾਟੇ ਫਾਹੇ ॥",
          "roman": "koṭ janam ke kāṭe fāhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਗਤੀ ਦਾ ਸਦਕਾ ਉਹਨਾਂ ਦੇ ਪਹਿਲੇ ਕ੍ਰੋੜਾਂ ਜਨਮਾਂ ਦੇ (ਮਾਇਆ ਦੇ) ਬੰਧਨ ਕੱਟੇ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "разрушаются узы миллионов прошлых рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38053,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇਆ ਲਾਭੁ ਸਚਾ ਧਨੁ ਲਾਹੇ ॥",
          "roman": "pāiā lābh sachā dhan lāhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਇਥੇ ਜਗਤ ਵਿਚ ਹਰਿ-ਨਾਮ-ਧਨ ਦਾ ਵਣਜ ਕਰਨ ਆਉਂਦੇ ਹਨ। ਪ੍ਰਭੂ ਦੀ ਭਗਤੀ ਕਰਨ ਵਾਲੇ ਬੰਦੇ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਨਾਮ-ਧਨ-ਨਫ਼ਾ ਖੱਟ ਲੈਂਦੇ ਹਨ"
            },
            "sahib_singh_ru": {
              "main": "он приобретает истинное богатство Имени и извлекает прибыль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38054,
          "is_rahao": false,
          "gurmukhi": "ਤੋਟਿ ਨ ਆਵੈ ਅਖੁਟ ਭੰਡਾਰ ॥",
          "roman": "toṭ na āvē akhuṭ bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਪਾਸ ਇਸ ਨਾਮ-ਧਨ ਦੇ) ਕਦੇ ਨਾਹ ਮੁੱਕਣ ਵਾਲੇ ਖ਼ਜ਼ਾਨੇ (ਭਰ ਜਾਂਦੇ ਹਨ ਜਿਨ੍ਹਾਂ ਵਿਚ) ਕਦੇ ਘਾਟਾ ਨਹੀਂ ਪੈਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "его сокровищница неисчерпаема и никогда не истощается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38055,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਭਗਤ ਸੋਹਹਿ ਹਰਿ ਦੁਆਰ ॥੪॥੨੩॥੩੪॥",
          "roman": "nānak bhagat sohahi har duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਕਰਨ ਵਾਲੇ ਬੰਦੇ ਪਰਮਾਤਮਾ ਦੇ ਦਰ ਤੇ ਸੋਭਾ ਪਾਂਦੇ ਹਨ ॥੪॥੨੩॥੩੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! преданные сияют у двери Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3323,
      "rahao_verse_id": 38061,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38056,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38057,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨ ਜਵੇਹਰ ਨਾਮ ॥",
          "roman": "ratan javehar nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਿਆਰੇ ਪ੍ਰਭੂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਐਸਾ ਹੈ ਜਿਸ ਵਿਚ ਉਸ ਦਾ) ਨਾਮ (ਹੀ) ਰਤਨ ਤੇ ਜਵਾਹਰਾਤ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога — это драгоценности и самоцветы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38058,
          "is_rahao": false,
          "gurmukhi": "ਸਤੁ ਸੰਤੋਖੁ ਗਿਆਨ ॥",
          "roman": "sat santokh giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਵਿਚ ਸਤ ਸੰਤੋਖ ਤੇ ਉੱਚੇ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਕੀਮਤੀ ਪਦਾਰਥ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "истина, удовлетворённость и духовное знание — ценные сокровища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38059,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਦਇਆ ਕਾ ਪੋਤਾ ॥ ਹਰਿ ਭਗਤਾ ਹਵਾਲੈ ਹੋਤਾ ॥੧॥",
          "roman": "sūkh sahaj dayā kā potā har bhagtā havālē hotā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਖ਼ਜ਼ਾਨਾ ਸੁਖ, ਆਤਮਕ ਅਡੋਲਤਾ ਤੇ ਦਇਆ ਦਾ ਸੋਮਾ ਹੈ। ਪਰ ਉਹ ਖ਼ਜ਼ਾਨਾ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਦੇ ਸਪੁਰਦ ਹੋਇਆ ਹੋਇਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "это сокровище — источник покоя, внутреннего равновесия и сострадания, но оно доверено преданным Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38060,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਰਾਮ ਕੋ ਭੰਡਾਰੁ ॥",
          "roman": "mere rām ko bhaṇḍār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਪਿਆਰੇ ਪ੍ਰਭੂ ਦਾ ਖ਼ਜ਼ਾਨਾ (ਐਸਾ ਹੈ ਕਿ ਉਸ ਨੂੰ)"
            },
            "sahib_singh_ru": {
              "main": "Сокровищница моего Господа такова,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38061,
          "is_rahao": true,
          "gurmukhi": "ਖਾਤ ਖਰਚਿ ਕਛੁ ਤੋਟਿ ਨ ਆਵੈ ਅੰਤੁ ਨਹੀ ਹਰਿ ਪਾਰਾਵਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "khāt kharach kachh toṭ na āvē ant nahī har pārāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪ ਵਰਤਦਿਆਂ ਤੇ ਹੋਰਨਾਂ ਨੂੰ ਵੰਡਦਿਆਂ (ਉਸ ਵਿਚ) ਕਮੀ ਨਹੀਂ ਆਉਂਦੀ। ਉਸ ਪਰਮਾਤਮਾ ਦੇ ਖ਼ਜ਼ਾਨੇ ਦਾ ਅੰਤ ਨਹੀਂ ਲੱਭਦਾ, ਉਸ ਦੀ ਹਸਤੀ ਦਾ ਉਰਲਾ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что, пользуясь и раздавая её, она не уменьшается; нет конца этому богатству, нет границ Его сущности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38062,
          "is_rahao": false,
          "gurmukhi": "ਕੀਰਤਨੁ ਨਿਰਮੋਲਕ ਹੀਰਾ ॥",
          "roman": "kīrtan nirmolak hīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਿਆਰੇ ਪ੍ਰਭੂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਐਸਾ ਹੈ ਜਿਸ ਵਿਚ ਉਸ ਦਾ) ਕੀਰਤਨ ਇਕ ਅਜਿਹਾ ਹੀਰਾ ਹੈ ਜਿਸ ਦਾ ਮੁੱਲ ਨਹੀਂ ਪੈ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Киртан — это бесценный алмаз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38063,
          "is_rahao": false,
          "gurmukhi": "ਆਨੰਦ ਗੁਣੀ ਗਹੀਰਾ ॥",
          "roman": "ānand guṇī gahīrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਕੀਰਤਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਗੁਣਾਂ ਦੇ ਮਾਲਕ ਸਮੁੰਦਰ-ਪ੍ਰਭੂ (ਦੇ ਮਿਲਾਪ) ਦਾ ਆਨੰਦ (ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "благодаря ему приходит радость встречи с Господом — океаном добродетелей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38064,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਬਾਣੀ ਪੂੰਜੀ ॥",
          "roman": "anahad bāṇī pūnjī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕੀਰਤਨ ਦੀ ਬਰਕਤ ਨਾਲ ਪੈਦਾ ਹੋਈ) ਇੱਕ-ਰਸ ਜਾਰੀ ਰਹਿਣ ਵਾਲੀ ਸਿਫ਼ਤਿ-ਸਾਲਾਹ ਦੀ ਰੌ (ਉਸ ਖ਼ਜ਼ਾਨੇ ਵਿਚ ਮਨੁੱਖ ਲਈ) ਸਰਮਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "непрерывное звучание хвалы становится капиталом человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38065,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਹਥਿ ਰਾਖੀ ਕੂੰਜੀ ॥੨॥",
          "roman": "santan hath rākhī kūñjī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਪਰਮਾਤਮਾ ਨੇ ਇਸ ਖ਼ਜ਼ਾਨੇ ਦੀ) ਕੁੰਜੀ ਸੰਤਾਂ ਦੇ ਹੱਥ ਵਿਚ ਰੱਖੀ ਹੋਈ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "ключ к этому сокровищу Бог держит в руках святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
