          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38287,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨ ਕਉ ਜਾਈਐ ਕੁਰਬਾਨੁ ॥",
          "roman": "darsan kau jāīai kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ) ਦਰਸ਼ਨ ਤੋਂ ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ (ਦਰਸ਼ਨ ਦੀ ਖ਼ਾਤਰ ਆਪਾ-ਭਾਵ ਕੁਰਬਾਨ ਕਰ ਦੇਣਾ ਚਾਹੀਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Следует полностью отдать себя ради даршана Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38288,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਹਿਰਦੈ ਧਰਿ ਧਿਆਨੁ ॥",
          "roman": "charan kamal hirdē dhar dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੇ) ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਧਿਆਨ ਹਿਰਦੇ ਵਿਚ ਧਰ ਕੇ (ਗੁਰੂ ਦੀ ਦੱਸੀ ਭਗਤੀ ਕਰਨੀ ਚਾਹੀਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Нужно удерживать в сердце медитацию на прекрасные стопы Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38289,
          "is_rahao": false,
          "gurmukhi": "ਧੂਰਿ ਸੰਤਨ ਕੀ ਮਸਤਕਿ ਲਾਇ ॥",
          "roman": "dhūr santan kī mastak lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਦਰ ਤੇ ਰਹਿਣ ਵਾਲੇ) ਸੰਤ ਜਨਾਂ ਦੀ ਚਰਨ-ਧੂੜ ਮੱਥੇ ਉਤੇ ਲਾਇਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Возлагай на голову пыль стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38290,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੀ ਦੁਰਮਤਿ ਮਲੁ ਜਾਇ ॥੧॥",
          "roman": "janam janam kī durmat mal jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਤਰ੍ਹਾਂ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੀ ਖੋਟੀ ਮਤਿ ਦੀ ਮੈਲ ਲਹਿ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Так исчезает нечистота дурного ума, накопленная за многие рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38291,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਭੇਟਤ ਮਿਟੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "jis bheṭat miṭē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ (ਮਨ ਵਿਚੋਂ) ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "При встрече с тем Гуру исчезает гордыня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38292,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਸਭੁ ਨਦਰੀ ਆਵੈ ਕਰਿ ਕਿਰਪਾ ਪੂਰਨ ਭਗਵਾਨ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pārbrahm sabh nadrī āvē kar kirpā pūran bhagvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪਾਰਬ੍ਰਹਮ ਪ੍ਰਭੂ ਹਰ ਥਾਂ ਦਿੱਸ ਪੈਂਦਾ ਹੈ, ਹੇ ਸਭ ਗੁਣਾਂ ਵਾਲੇ ਭਗਵਾਨ! (ਮੇਰੇ ਉਤੇ) ਕਿਰਪਾ ਕਰ (ਮੈਨੂੰ ਉਹ ਗੁਰੂ ਮਿਲਾ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "И тогда Верховный Бог видится повсюду; о совершенный Господь, прояви милость и даруй встречу с таким Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38293,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਕੀਰਤਿ ਜਪੀਐ ਹਰਿ ਨਾਉ ॥",
          "roman": "gur kī kīrat japīai har nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣਾ ਚਾਹੀਦਾ ਹੈ-ਇਹੀ ਹੈ ਗੁਰੂ ਦੀ ਸੋਭਾ (ਕਰਨੀ)।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда воспевай Имя Бога — в этом и есть слава Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38294,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਭਗਤਿ ਸਦਾ ਗੁਣ ਗਾਉ ॥",
          "roman": "gur kī bhagat sadā guṇ gāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਦਾ ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ- ਇਹੀ ਹੈ ਗੁਰੂ ਦੀ ਭਗਤੀ! ਹੇ ਭਾਈ!"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всегда пой качества Бога — в этом и есть преданность Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38295,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਸੁਰਤਿ ਨਿਕਟਿ ਕਰਿ ਜਾਨੁ ॥",
          "roman": "gur kī surat nikaṭ kar jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੂੰ ਸਦਾ ਆਪਣੇ ਨੇੜੇ ਵੱਸਦਾ ਜਾਣ-ਇਹੀ ਹੈ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਧਿਆਨ ਧਰਨਾ।"
            },
            "sahib_singh_ru": {
              "main": "Считай Бога всегда пребывающим рядом — это и есть сосредоточение на Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38296,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਸਤਿ ਕਰਿ ਮਾਨੁ ॥੨॥",
          "roman": "gur kā sabad sat kar mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ (ਸਦਾ) ਸੱਚਾ ਕਰਕੇ ਮੰਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О брат! Признавай Слово Гуру истинным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38297,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਬਚਨੀ ਸਮਸਰਿ ਸੁਖ ਦੂਖ ॥",
          "roman": "gur bachnī samsar sukh dūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੇ ਬਚਨਾਂ ਦੀ ਰਾਹੀਂ (ਸਾਰੇ) ਸੁਖ ਦੁਖ ਇਕੋ ਜਿਹੇ ਜਾਪਣ ਲੱਗ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Через слова Гуру радость и страдание становятся равными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38298,
          "is_rahao": false,
          "gurmukhi": "ਕਦੇ ਨ ਬਿਆਪੈ ਤ੍ਰਿਸਨਾ ਭੂਖ ॥",
          "roman": "kade na biāpē trisanā bhūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਮਾਇਆ ਦੀ ਭੁੱਖ ਕਦੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Жажда и голод майи больше не могут одолеть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38299,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਸੰਤੋਖੁ ਸਬਦਿ ਗੁਰ ਰਾਜੇ ॥",
          "roman": "man santokh sabad gur rāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਮਨ ਵਿਚ ਸੰਤੋਖ ਪੈਦਾ ਹੋ ਜਾਂਦਾ ਹੈ, (ਮਨ) ਰੱਜ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Через Слово Гуру в уме рождается удовлетворённость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38300,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਗੋਬਿੰਦੁ ਪੜਦੇ ਸਭਿ ਕਾਜੇ ॥੩॥",
          "roman": "jap gobind paṛde sabh kāje",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਸਾਰੇ ਪੜਦੇ ਕੱਜੇ ਜਾਂਦੇ ਹਨ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ ਇੱਜ਼ਤ ਬਣ ਜਾਂਦੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Воспевая Имя Бога, все дела покрываются и становятся завершёнными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38301,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਗੁਰੁ ਗੋਵਿੰਦੁ ॥",
          "roman": "gur parmesar gur govind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਪਰਮਾਤਮਾ (ਦਾ ਰੂਪ) ਹੈ, ਗੁਰੂ ਗੋਬਿੰਦ (ਦਾ ਰੂਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Гуру есть Сам Бог, Гуру есть Говинд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38302,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਦਾਤਾ ਦਇਆਲ ਬਖਸਿੰਦੁ ॥",
          "roman": "gur dātā dayāl bakhsind",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾਤਾਰ (ਪ੍ਰਭੂ ਦਾ ਰੂਪ) ਹੈ, ਗੁਰੂ ਦਇਆ ਦੇ ਸੋਮੇ ਬਖ਼ਸ਼ਣਹਾਰ ਪ੍ਰਭੂ (ਦਾ ਰੂਪ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру — даритель, милостивый и прощающий Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38303,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਚਰਨੀ ਜਾ ਕਾ ਮਨੁ ਲਾਗਾ ॥",
          "roman": "gur charnī jā kā man lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਮਨ ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਵਿਚ ਟਿਕ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей ум привязан к стопам Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38304,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤਿਸੁ ਪੂਰਨ ਭਾਗਾ ॥੪॥੩੬॥੪੭॥",
          "roman": "nānak dās tis pūran bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦਾਸ ਦੇ ਪੂਰੇ ਭਾਗ ਜਾਗ ਪੈਂਦੇ ਹਨ ॥੪॥੩੬॥੪੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот слуга обретает совершенную удачу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
