      "rahao_verse_id": 38424,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38418,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38419,
          "is_rahao": false,
          "gurmukhi": "ੲੰੀਧਨ ਤੇ ਬੈਸੰਤਰੁ ਭਾਗੈ ॥",
          "roman": "īndhan te bēsantar bhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮਨ! ਵੇਖ ਉਸ ਪ੍ਰਭੂ ਦੀਆਂ ਅਸਚਰਜ ਤਾਕਤਾਂ!) ਲੱਕੜੀ ਤੋਂ ਅੱਗ ਪਰੇ ਭੱਜਦੀ ਹੈ (ਲੱਕੜੀ ਵਿਚ ਅੱਗ ਹਰ ਵੇਲੇ ਮੌਜੂਦ ਹੈ, ਪਰ ਉਸ ਨੂੰ ਸਾੜਦੀ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Посмотри на удивительные силы Бога: огонь убегает от дерева, хотя всегда в нём присутствует и не сжигает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38420,
          "is_rahao": false,
          "gurmukhi": "ਮਾਟੀ ਕਉ ਜਲੁ ਦਹ ਦਿਸ ਤਿਆਗੈ ॥",
          "roman": "māṭī kau jal dah dis tiyāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਮੁੰਦਰ ਦਾ) ਪਾਣੀ ਧਰਤੀ ਨੂੰ ਹਰ ਪਾਸੇ ਵਲੋਂ ਤਿਆਗੀ ਰੱਖਦਾ ਹੈ (ਧਰਤੀ ਸਮੁੰਦਰ ਦੇ ਵਿਚ ਰਹਿੰਦੀ ਹੈ, ਪਰ ਸਮੁੰਦਰ ਇਸ ਨੂੰ ਡੋਬਦਾ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "Вода океана со всех сторон оставляет землю, хотя земля находится в океане и он её не топит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38421,
          "is_rahao": false,
          "gurmukhi": "ਊਪਰਿ ਚਰਨ ਤਲੈ ਆਕਾਸੁ ॥",
          "roman": "ūpar charan talē ākās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰੁੱਖ ਦੇ) ਪੈਰ (ਜੜ੍ਹਾਂ) ਉਪਰ ਵਲ ਹਨ, ਤੇ ਸਿਰ ਹੇਠਲੇ ਪਾਸੇ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "У дерева корни направлены вверх, а верх — вниз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38422,
          "is_rahao": false,
          "gurmukhi": "ਘਟ ਮਹਿ ਸਿੰਧੁ ਕੀਓ ਪਰਗਾਸੁ ॥੧॥",
          "roman": "ghaṭ meh sindh kīo pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘੜੇ ਵਿਚ (ਨਿੱਕੇ ਨਿੱਕੇ ਸਰੀਰਾਂ ਵਿਚ) ਸਮੁੰਦਰ-ਪ੍ਰਭੂ ਆਪਣਾ ਆਪ ਪਰਕਾਸ਼ਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "В сосуде, в малых телах, океан-Бог проявляет Себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38423,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਸੰਮ੍ਰਥੁ ਹਰਿ ਜੀਉ ਆਪਿ ॥",
          "roman": "aisā samrath har jīu āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਪਰਮਾਤਮਾ ਆਪ ਬੜੀਆਂ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум! Сам Бог обладает великой силой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38424,
          "is_rahao": true,
          "gurmukhi": "ਨਿਮਖ ਨ ਬਿਸਰੈ ਜੀਅ ਭਗਤਨ ਕੈ ਆਠ ਪਹਰ ਮਨ ਤਾ ਕਉ ਜਾਪਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nimakh na bisrē jīa bhagtan kē āṭh pahar man tā kau jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਆਪਣੇ ਭਗਤਾਂ ਦੇ ਮਨ ਤੋਂ ਅੱਖ ਝਮਕਣ ਜਿਤਨੇ ਸਮੇ ਲਈ ਭੀ ਨਹੀਂ ਵਿਸਰਦਾ। ਹੇ ਮਨ! ਤੂੰ ਭੀ ਉਸ ਨੂੰ ਅੱਠੇ ਪਹਿਰ ਜਪਿਆ ਕਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он не забывается в умах преданных даже на мгновение. О ум! И ты помни Его восемь страж."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38425,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਥਮੇ ਮਾਖਨੁ ਪਾਛੈ ਦੂਧੁ ॥",
          "roman": "prathme mākhan pāchhē dūdh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਪਹਿਲਾਂ ਦੁੱਧ ਹੁੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਰਿੜਕਿਆਂ ਉਸ ਦੁੱਧ ਦਾ ਤੱਤ-ਮੱਖਣ ਪਿੱਛੋਂ ਨਿਕਲਦਾ ਹੈ। ਪਰ ਵੇਖ! ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਤੱਤ-) ਮੱਖਣ ਪਰਮਾਤਮਾ ਪਹਿਲਾਂ ਮੌਜੂਦ ਹੈ, ਤੇ (ਉਸ ਦਾ ਪਸਾਰਾ-ਜਗਤ) ਦੁੱਧ ਪਿਛੋਂ (ਬਣਦਾ) ਹੈ (ਜਗਤ-ਪਸਾਰੇ ਰੂਪ ਦੁੱਧ ਵਿਚ ਤੱਤ-ਪ੍ਰਭੂ-ਮੱਖਣ ਸਰਬ-ਵਿਆਪਕ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Сначала существует сущность — масло-Бог, а затем проявляется мир как молоко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38426,
          "is_rahao": false,
          "gurmukhi": "ਮੈਲੂ ਕੀਨੋ ਸਾਬੁਨੁ ਸੂਧੁ ॥",
          "roman": "mēlū kīno sābun sūdh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਦੀ ਪਾਲਣਾ ਵਾਸਤੇ) ਮੈਲ ਨੂੰ (ਮਾਂ ਦੇ ਲਹੂ ਨੂੰ) ਸੁੱਧ ਸਾਬਣ ਵਰਗਾ ਚਿੱਟਾ ਦੁੱਧ ਬਣਾ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он превращает нечистое в чистое, как молоко становится белым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38427,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਤੇ ਨਿਰਭਉ ਡਰਤਾ ਫਿਰੈ ॥",
          "roman": "bhē te nirbhau ḍartā phirē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਿਰਭਉ-ਪ੍ਰਭੂ ਦੀ ਅੰਸ ਜੀਵ ਦੁਨੀਆ ਦੇ ਅਨੇਕਾਂ ਡਰਾਂ ਤੋਂ ਡਰਦਾ ਫਿਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек, будучи частью бесстрашного Бога, всё же боится многих страхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38428,
          "is_rahao": false,
          "gurmukhi": "ਹੋਂਦੀ ਕਉ ਅਣਹੋਂਦੀ ਹਿਰੈ ॥੨॥",
          "roman": "hondī kau aṇhondī hirē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਂਦ ਵਾਲੀ ਜਿੰਦ ਨੂੰ ਅਣਹੋਂਦੀ ਮਾਇਆ, ਜਿਸ ਦੀ (ਵੱਖਰੀ) ਹਸਤੀ ਕੋਈ ਨਹੀਂ, ਜੀਵ ਨੂੰ ਭਜਾਈ ਫਿਰਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Существующее существо захватывается иллюзией, не имеющей собственной сущности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38429,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹੀ ਗੁਪਤ ਬਿਦੇਹੀ ਦੀਸੈ ॥",
          "roman": "dehī gupt bidehī dīsē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਸਰੀਰ ਦਾ ਮਾਲਕ ਆਤਮਾ (ਸਰੀਰ ਵਿਚ) ਲੁਕਿਆ ਰਹਿੰਦਾ ਹੈ, ਸਿਰਫ਼ ਸਰੀਰ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В теле скрыта душа, но видимо только тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38430,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਸਾਜਿ ਕਰਤ ਜਗਦੀਸੈ ॥",
          "roman": "sagle sāj karat jagdīsē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵਾਂ ਨੂੰ ਪੈਦਾ ਕਰ ਕੇ ਜਗਤ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ (ਅਨੇਕਾਂ ਕੌਤਕ) ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Создав всё, Господь мира совершает свои деяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38431,
          "is_rahao": false,
          "gurmukhi": "ਠਗਣਹਾਰ ਅਣਠਗਦਾ ਠਾਗੈ ॥",
          "roman": "ṭhagaṇhār aṇṭhagda ṭhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਠਗਣੀ-ਮਾਇਆ ਜੀਵ ਨੂੰ ਸਦਾ ਠੱਗਦੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Обманчивая майя постоянно обманывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38432,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਵਖਰ ਫਿਰਿ ਫਿਰਿ ਉਠਿ ਲਾਗੈ ॥੩॥",
          "roman": "bin vakhar phir phir uṭh lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਦੀ ਪੂੰਜੀ ਤੋਂ ਸੱਖਣਾ ਜੀਵ ਮੁੜ ਮੁੜ ਮਾਇਆ ਨੂੰ ਚੰਬੜਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Без богатства Имени человек снова и снова привязывается к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38433,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਭਾ ਮਿਲਿ ਕਰਹੁ ਬਖਿਆਣ ॥",
          "roman": "sant sabhā mil karah bakhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ!) ਸੰਤ-ਸਭਾ ਵਿਚ ਮਿਲ ਕੇ (ਧਰਮ ਸ਼ਾਸਤ੍ਰਾਂ ਦੀ ਬੇਸ਼ੱਕ) ਵਿਆਖਿਆ ਕਰ ਕੇ ਵੇਖ ਲਵੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Собравшись в обществе святых, исследуй и обсуждай."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38434,
          "is_rahao": false,
          "gurmukhi": "ਸਿੰਮ੍ਰਿਤਿ ਸਾਸਤ ਬੇਦ ਪੁਰਾਣ ॥",
          "roman": "simrit sāstat bed purān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵੇਂ) ਸਿੰਮ੍ਰਿਤੀਆਂ ਸ਼ਾਸਤ੍ਰਾਂਵੇਦਾਂ ਪੁਰਾਣਾਂ ਦੀ (ਦੀ ਵੀਚਾਰ ਕਰ ਲਉ, ਇਸ ਠਗਣੀ ਮਾਇਆ ਤੋਂ ਬਚਾਉ ਨਹੀਂ ਹੋ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Даже изучая смрити, шастры, веды и пураны, нельзя избежать обмана майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38435,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮ ਬੀਚਾਰੁ ਬੀਚਾਰੇ ਕੋਇ ॥",
          "roman": "brahm bīchār bīchāre koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਕੋਈ ਮਨੁੱਖ ਸਤਸੰਗ ਵਿਚ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦੀ ਵਿਚਾਰ ਵਿਚਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто размышляет о качествах Бога в святом собрании,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38436,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕੀ ਪਰਮ ਗਤਿ ਹੋਇ ॥੪॥੪੩॥੫੪॥",
          "roman": "nānak tā kī param gat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-) ਉਸੇ ਦੀ ਹੀ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣਦੀ ਹੈ ॥੪॥੪੩॥੫੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, достигает высшего духовного состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
