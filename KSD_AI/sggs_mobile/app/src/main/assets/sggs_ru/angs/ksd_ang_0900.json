            }
          }
        },
        {
          "verse_id": 38438,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਤਿਸੁ ਭਾਵੈ ਸੋ ਥੀਆ ॥",
          "roman": "jo tis bhāvē so thīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੋ ਕੁਝ ਪ੍ਰਭੂ ਨੂੰ ਚੰਗਾ ਲੱਗਦਾ ਹੈ ਉਹੀ ਹੋ ਰਿਹਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат! Всё происходит так, как угодно Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38439,
          "is_rahao": true,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਹਰਿ ਕੀ ਸਰਣਾਈ ਪ੍ਰਭ ਬਿਨੁ ਨਾਹੀ ਆਨ ਬੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sadā sadā har kī saraṇāī prabh bin nāhī ān bīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਸਦਾ ਹੀ ਉਸ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹੁ। ਪ੍ਰਭੂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਹੋਰ ਦੂਜਾ (ਕੁਝ ਕਰਨ-ਜੋਗਾ) ਨਹੀਂ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Всегда пребывай в Его прибежище, кроме Бога нет другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38440,
          "is_rahao": false,
          "gurmukhi": "ਪੁਤੁ ਕਲਤ੍ਰੁ ਲਖਿਮੀ ਦੀਸੈ ਇਨ ਮਹਿ ਕਿਛੂ ਨ ਸੰਗਿ ਲੀਆ ॥",
          "roman": "put kalatr lakhimī dīsē in meh kichhū na sang līā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੁੱਤਰ, ਇਸਤ੍ਰੀ, ਮਾਇਆ-ਇਹ ਜੋ ਕੁਝ ਦਿੱਸ ਰਿਹਾ ਹੈ, ਇਹਨਾਂ ਵਿਚੋਂ ਕੁਝ ਭੀ (ਅੰਤ ਵੇਲੇ ਜੀਵ) ਆਪਣੇ ਨਾਲ ਨਹੀਂ ਲੈ ਜਾਂਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Сын, жена, богатство — ничто из этого не уходит с человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38441,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖੈ ਠਗਉਰੀ ਖਾਇ ਭੁਲਾਨਾ ਮਾਇਆ ਮੰਦਰੁ ਤਿਆਗਿ ਗਇਆ ॥੧॥",
          "roman": "bikhē ṭhagaurī khāi bhulānā māiā mandar tiyāg gēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਸ਼ੇ-ਵਿਕਾਰਾਂ ਦੀ ਠਗਬੂਟੀ ਖਾ ਕੇ ਜੀਵ ਕੁਰਾਹੇ ਪਿਆ ਰਹਿੰਦਾ ਹੈ, ਆਖ਼ਰ ਇਹ ਮਾਇਆ, ਇਹ ਸੋਹਣਾ ਘਰ (ਸਭ ਕੁਝ) ਛੱਡ ਕੇ ਤੁਰ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Под влиянием желаний человек заблуждается и в конце оставляет всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38442,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਾ ਕਰਿ ਕਰਿ ਬਹੁਤੁ ਵਿਗੂਤਾ ਗਰਭ ਜੋਨਿ ਮਹਿ ਕਿਰਤਿ ਪਇਆ ॥",
          "roman": "nindā kar kar bahut vigūtā garabh jon meh kirat paiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜੀਵ ਦੂਜਿਆਂ ਦੀ ਨਿੰਦਾ ਕਰ ਕਰ ਕੇ ਬਹੁਤ ਖ਼ੁਆਰ ਹੁੰਦਾ ਰਹਿੰਦਾ ਹੈ, ਤੇ ਆਪਣੇ ਇਸ ਕੀਤੇ ਅਨੁਸਾਰ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਵਿਚ ਜਾ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Клевеща, человек страдает и попадает в цикл рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38443,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਬ ਕਮਾਣੇ ਛੋਡਹਿ ਨਾਹੀ ਜਮਦੂਤਿ ਗ੍ਰਾਸਿਓ ਮਹਾ ਭਇਆ ॥੨॥",
          "roman": "purb kamāṇe chhoḍeh nāhī jamdūt grāsio mahā bhaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਆਮ ਅਸੂਲ ਦੀ ਗੱਲ ਹੈ ਕਿ) ਪੂਰਬਲੇ ਕੀਤੇ ਕਰਮਾਂ ਦੇ ਸੰਸਕਾਰ ਜੀਵ ਨੂੰ ਛੱਡਦੇ ਨਹੀਂ ਹਨ, ਤੇ ਵੱਡਾ ਭਿਆਨਕ ਜਮਦੂਤ ਇਸ ਨੂੰ ਕਾਬੂ ਕਰੀ ਰੱਖਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Прошлые деяния не покидают его, и он охвачен страхом смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38444,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਝੂਠੁ ਕਮਾਵੈ ਅਵਰਾ ਤ੍ਰਿਸਨ ਨ ਬੂਝੈ ਬਹੁਤੁ ਹਇਆ ॥",
          "roman": "bolē jhūṭh kamāvē avrā trisn na būjhē bahut hēā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਠਗਬੂਟੀ ਖਾ ਕੇ ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਜੀਵ) ਝੂਠ ਬੋਲਦਾ ਹੈ (ਮੂੰਹੋਂ ਆਖਦਾ ਹੋਰ ਹੈ, ਤੇ) ਕਮਾਂਦਾ ਕੁਝ ਹੋਰ ਹੈ, ਇਸ ਦੀ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਬੁੱਝਦੀ ਨਹੀਂ, ਮਾਇਆ ਦੀ 'ਹਾਇ ਹਾਇ' ਸਦਾ ਇਸ ਨੂੰ ਲੱਗੀ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он говорит ложь и действует иначе, его жажда не угасает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38445,
          "is_rahao": false,
          "gurmukhi": "ਅਸਾਧ ਰੋਗੁ ਉਪਜਿਆ ਸੰਤ ਦੂਖਨਿ ਦੇਹ ਬਿਨਾਸੀ ਮਹਾ ਖਇਆ ॥੩॥",
          "roman": "asādh rog upjiā sant dūkhan deh bināsī mahā khaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਜਨਾਂ ਦੀ ਨਿੰਦਾ ਕਰਨ ਦੇ ਕਾਰਨ (ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਦਾ) ਲਾ-ਇਲਾਜ ਰੋਗ (ਜੀਵ ਦੇ ਅੰਦਰ) ਪੈਦਾ ਹੋ ਜਾਂਦਾ ਹੈ, ਇਸ ਵੱਡੇ ਖਈ ਰੋਗ ਦੇ ਵਿਚ ਹੀ ਇਸ ਦਾ ਸਰੀਰ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Оскорбляя святых, он поражается неизлечимой болезнью и погибает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38446,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਹਿ ਨਿਵਾਜੇ ਤਿਨ ਹੀ ਸਾਜੇ ਆਪੇ ਕੀਨੇ ਸੰਤ ਜਇਆ ॥",
          "roman": "jinah nivāje tin hī sāje āpe kīne sant jaiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਹੇ ਭਾਈ! ਸੰਤ ਜਨਾਂ ਦੀ ਨਿੰਦਾ ਤੋਂ ਜੀਵ ਨੂੰ ਹਾਸਲ ਕੁਝ ਨਹੀਂ ਹੁੰਦਾ) ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਸੰਤ ਜਨਾਂ ਨੂੰ ਜਿੱਤ ਦਾ ਮਾਲਕ ਬਣਾਇਆ ਹੁੰਦਾ ਹੈ, ਉਹਨਾਂ ਨੂੰ ਉਸੇ ਪ੍ਰਭੂ ਨੇ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈ ਜਿਸ ਨੇ ਉਹਨਾਂ ਨੂੰ ਆਦਰ-ਸਤਕਾਰ ਦਿੱਤਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог сам возвысил святых и даровал им победу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38447,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਕੰਠਿ ਲਾਇ ਰਾਖੇ ਕਰਿ ਕਿਰਪਾ ਪਾਰਬ੍ਰਹਮ ਮਇਆ ॥੪॥੪੪॥੫੫॥",
          "roman": "nānak dās kanth lāi rākhe kar kirpā pārbrahm maiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਪਰਮਾਤਮਾ ਮਿਹਰ ਕਰ ਕੇ ਦਇਆ ਕਰ ਕੇ ਆਪਣੇ ਦਾਸਾਂ ਨੂੰ ਆਪ ਹੀ ਆਪਣੇ ਗਲ ਨਾਲ ਲਾਈ ਰੱਖਦਾ ਹੈ ॥੪॥੪੪॥੫੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, по милости Бог обнимает своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3344,
      "rahao_verse_id": 38450,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38448,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38449,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਪੂਰਾ ਗੁਰਦੇਉ ਸਹਾਈ ॥",
          "roman": "aisā pūrā gurdeu sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪੂਰਾ ਗੁਰੂ ਇਹੋ ਜਿਹਾ ਮਦਦਗਾਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Совершенный Гуру — такой помощник,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38450,
          "is_rahao": true,
          "gurmukhi": "ਜਾ ਕਾ ਸਿਮਰਨੁ ਬਿਰਥਾ ਨ ਜਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jā kā simran birthā na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਉਸ ਦਾ ਦਿੱਤਾ ਹੋਇਆ ਹਰਿ-ਸਿਮਰਨ ਦਾ ਉਪਦੇਸ਼ ਵਿਅਰਥ ਨਹੀਂ ਜਾਂਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что память о нём никогда не бывает напрасной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38451,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਪੇਖਤ ਹੋਇ ਨਿਹਾਲੁ ॥",
          "roman": "darsan pekhat hoi nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਭਾਈ! ਗੁਰੂ ਦਾ) ਦਰਸ਼ਨ ਕਰਦਿਆਂ (ਮਨੁੱਖ ਤਨੋ ਮਨੋ) ਖਿੜ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Видя Гуру, человек радуется душой и телом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38452,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਧੂਰਿ ਕਾਟੈ ਜਮ ਜਾਲੁ ॥",
          "roman": "jā kī dhūr kāṭē jam jāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੁਰੂ ਦੀ ਚਰਨ-ਧੂੜ ਜਮ ਦੀ ਫਾਹੀ ਕੱਟ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Пыль его стоп уничтожает сеть смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38453,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਬਸੇ ਮੇਰੇ ਮਨ ਕੇ ॥",
          "roman": "charan kamal base mere man ke",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਪਿਆਰੇ ਗੁਰੂ ਦੇ ਸੋਹਣੇ ਚਰਨ (ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ) ਆ ਵੱਸਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Когда стопы Гуру поселяются в сердце,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38454,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜ ਸਵਾਰੇ ਸਗਲੇ ਤਨ ਕੇ ॥੧॥",
          "roman": "kāraj savāre sagle tan ke",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ) ਮਨ ਦੇ (ਉਸ ਦੇ) ਸਰੀਰ ਦੇ ਸਾਰੇ ਕੰਮ (ਗੁਰੂ) ਸੰਵਾਰ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "все дела тела и ума устраиваются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38455,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਸਤਕਿ ਰਾਖੈ ਹਾਥੁ ॥",
          "roman": "jā kē mastak rākhe hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਦੇ ਮੱਥੇ ਉਤੇ (ਗੁਰੂ ਆਪਣਾ) ਹੱਥ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, на чьей голове Гуру держит руку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38456,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਮੇਰੋ ਅਨਾਥ ਕੋ ਨਾਥੁ ॥",
          "roman": "prabh mero anāth ko nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਮੇਰਾ ਉਹ ਪ੍ਰਭੂ (ਮਿਲ ਪੈਂਦਾ ਹੈ) ਜੋ ਨਿਆਸਰਿਆਂ ਦਾ ਆਸਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "обретает Бога — покровителя беспомощных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38457,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਉਧਾਰਣੁ ਕ੍ਰਿਪਾ ਨਿਧਾਨੁ ॥",
          "roman": "patit udhāran kripā nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਵਿਕਾਰਾਂ ਵਿਚ ਡਿੱਗੇ ਹੋਇਆਂ ਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਾਣ ਵਾਲਾ ਹੈ, ਗੁਰੂ ਕਿਰਪਾ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Гуру спасает падших и является сокровищем милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38458,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਜਾਈਐ ਕੁਰਬਾਨੁ ॥੨॥",
          "roman": "sadā sadā jāīai kurbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਤੋਂ ਸਦਾ ਹੀ ਸਦਕੇ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ему следует всегда приносить себя в жертву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38459,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਮੰਤੁ ਦੇਇ ਜਿਸੁ ਦਾਨੁ ॥",
          "roman": "nirmal mant de jis dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਆਪਣਾ ਪਵਿੱਤਰ ਉਪਦੇਸ਼ ਬਖ਼ਸ਼ਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кому Гуру даёт чистое наставление,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38460,
          "is_rahao": false,
          "gurmukhi": "ਤਜਹਿ ਬਿਕਾਰ ਬਿਨਸੈ ਅਭਿਮਾਨੁ ॥",
          "roman": "tajeh bikār binsē abhimān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਵਿਕਾਰ ਉਸ ਨੂੰ ਛੱਡ ਜਾਂਦੇ ਹਨ ਉਸ ਦਾ ਅਹੰਕਾਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "оставляет пороки и теряет эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38461,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਧਿਆਈਐ ਸਾਧ ਕੈ ਸੰਗਿ ॥",
          "roman": "ek dhiāīē sādh kē sang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸੰਗਤਿ ਵਿਚ ਰਹਿ ਕੇ ਇੱਕ ਪਰਮਾਤਮਾ ਦਾ ਧਿਆਨ ਧਰਨਾ ਚਾਹੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В обществе святых следует медитировать на Единого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38462,
          "is_rahao": false,
          "gurmukhi": "ਪਾਪ ਬਿਨਾਸੇ ਨਾਮ ਕੈ ਰੰਗਿ ॥੩॥",
          "roman": "pāp bināse nām kē rang",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਰਾਹੀਂ) ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰਿਹਾਂ ਸਾਰੇ ਪਾਪਾਂ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В любви к Имени все грехи уничтожаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38463,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਮੇਸੁਰ ਸਗਲ ਨਿਵਾਸ ॥",
          "roman": "gur parmesur sagal nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਗੁਰੂ-ਪਰਮਾਤਮਾ ਸਭ ਜੀਵਾਂ ਵਿਚ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Гуру-Бог пребывает во всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38464,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਰਵਿ ਰਹਿਆ ਗੁਣਤਾਸ ॥",
          "roman": "ghaṭ ghaṭ rav rahiā guṇtās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹਰੇਕ ਹਿਰਦੇ ਵਿਚ ਮੌਜੂਦ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сокровище добродетелей присутствует в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38465,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸੁ ਦੇਹਿ ਧਾਰਉ ਪ੍ਰਭ ਆਸ ॥",
          "roman": "dars deh dhārau prabh ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਨੂੰ ਆਪਣਾ ਦਰਸ਼ਨ ਦੇਹ, ਮੈਂ ਤੇਰੇ ਦਰਸ਼ਨ ਦੀ ਆਸ ਰੱਖੀ ਬੈਠਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, даруй мне даршан, я надеюсь на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38466,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਨਾਨਕੁ ਚਿਤਵੈ ਸਚੁ ਅਰਦਾਸਿ ॥੪॥੪੫॥੫੬॥",
          "roman": "nit nānak chitvē sach ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀ ਇਹੀ ਅਰਦਾਸ ਹੈ ਕਿ (ਤੇਰਾ ਸੇਵਕ) ਨਾਨਕ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਕਰਦਾ ਰਹੇ ॥੪॥੪੫॥੫੬॥"
            },
            "sahib_singh_ru": {
              "main": "Это молитва: пусть Нанак всегда помнит Истинного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
