      "lines": [
        {
          "verse_id": 38999,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39000,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਰੰਗ ਰਸ ਰੂਪ ॥",
          "roman": "kāhū bihāvē rang ras rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭਾਵੇਂ ਪਰਮਾਤਮਾ ਹੀ ਹਰੇਕ ਜੀਵ ਦਾ ਮਾਲਕ ਹੈ ਫਿਰ ਭੀ) ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਦੁਨੀਆ ਦੇ ਰੰਗ-ਤਮਾਸ਼ਿਆਂ, ਦੁਨੀਆ ਦੇ ਸੋਹਣੇ ਰੂਪਾਂ ਅਤੇ ਪਦਾਰਥਾਂ ਦੇ ਰਸਾਂ-ਸੁਆਦਾਂ ਵਿਚ ਬੀਤ ਰਹੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у кого-то жизнь проходит в наслаждении красотой и удовольствиями"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
