{
  "ang": 913,
  "shabads": [
    {
      "shabad_id": 3366,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38945,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਕਹਿਆ ਬਾਹ ਬਹੁ ਭਾਈ ॥",
          "roman": "kinhī kahiā bāh bah bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਨੇ ਆਖਿਆ ਹੈ ਕਿ ਮੇਰੇ ਬੜੇ ਭਰਾ ਹਨ, ਮੇਰੇ ਬੜੇ ਸਾਥੀ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "кто-то говорит, что у него много братьев и сторонников."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38946,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਕਹੈ ਮੈ ਧਨਹਿ ਪਸਾਰਾ ॥",
          "roman": "koī kahē mē dhanah pasārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਆਖਦਾ ਹੈ ਮੈਂ ਬਹੁਤ ਧਨ ਕਮਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то говорит, что накопил много богатства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38947,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਦੀਨ ਹਰਿ ਹਰਿ ਆਧਾਰਾ ॥੪॥",
          "roman": "mohi dīn har har ādhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਨੂੰ ਗ਼ਰੀਬ ਨੂੰ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Но у меня, бедного, есть только опора на Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38948,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਘੂਘਰ ਨਿਰਤਿ ਕਰਾਈ ॥",
          "roman": "kinhī ghūghar nirat karāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਨੇ ਘੁੰਘਰੂ ਬੰਨ੍ਹ ਕੇ (ਦੇਵਤਿਆਂ ਅੱਗੇ) ਨਾਚ ਸ਼ੁਰੂ ਕੀਤੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Кто-то привязал колокольчики и начал танцевать (перед богами),"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38949,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੂ ਵਰਤ ਨੇਮ ਮਾਲਾ ਪਾਈ ॥",
          "roman": "kinhū varat nēm mālā pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਨੇ (ਗਲ ਵਿਚ) ਮਾਲਾ ਪਾਈ ਹੋਈ ਹੈ ਅਤੇ ਵਰਤ ਰੱਖਣ ਦੇ ਨੇਮ ਧਾਰੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "кто-то носит чётки и соблюдает посты и обеты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38950,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਤਿਲਕੁ ਗੋਪੀ ਚੰਦਨ ਲਾਇਆ ॥",
          "roman": "kinhī tilak gopī chandan lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਨੇ (ਮੱਥੇ ਉਤੇ) ਗੋਪੀ ਚੰਦਨ ਦਾ ਟਿੱਕਾ ਲਾਇਆ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кто-то нанес на лоб знак из гопи-чандана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38951,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਦੀਨ ਹਰਿ ਹਰਿ ਹਰਿ ਧਿਆਇਆ ॥੫॥",
          "roman": "mohi dīn har har har dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗ਼ਰੀਬ ਤਾਂ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਸਿਮਰਦਾ ਹਾਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Но я, бедный, лишь помню имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38952,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਸਿਧ ਬਹੁ ਚੇਟਕ ਲਾਏ ॥",
          "roman": "kinhī sidh bah cheṭak lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਨੇ ਸਿੱਧਾਂ ਵਾਲੇ ਨਾਟਕ-ਚੇਟਕ ਵਿਖਾਲਣੇ ਸ਼ੁਰੂ ਕੀਤੇ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Кто-то показывает чудеса и фокусы, как сиддхи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38953,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਭੇਖ ਬਹੁ ਥਾਟ ਬਨਾਏ ॥",
          "roman": "kinhī bhekh bah thāṭ banāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਨੇ ਸਾਧੂਆਂ ਵਾਲੇ ਕਈ ਭੇਖ ਬਣਾਏ ਹੋਏ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "кто-то принял множество внешних религиозных обликов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38954,
          "is_rahao": false,
          "gurmukhi": "ਕਿਨਹੀ ਤੰਤ ਮੰਤ ਬਹੁ ਖੇਵਾ ॥",
          "roman": "kinhī tant mant bah khēvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਨੇ ਅਨੇਕਾਂ ਤੰਤ੍ਰਾਂ ਮੰਤ੍ਰਾਂ ਦੀ ਦੁਕਾਨ ਚਲਾਈ ਹੋਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто-то занимается множеством тантр и мантр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38955,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਦੀਨ ਹਰਿ ਹਰਿ ਹਰਿ ਸੇਵਾ ॥੬॥",
          "roman": "mohi dīn har har har sēvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗ਼ਰੀਬ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਹੀ ਕਰਦਾ ਹਾਂ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "но я, бедный, служу только Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38956,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਚਤੁਰੁ ਕਹਾਵੈ ਪੰਡਿਤ ॥",
          "roman": "koī chatur kahāvē paṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ (ਆਪਣੇ ਆਪ ਨੂੰ) ਸਿਆਣਾ ਪੰ​‍ਡਿਤ ਅਖਵਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Кто-то называет себя мудрым пандитом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38957,
          "is_rahao": false,
          "gurmukhi": "ਕੋ ਖਟੁ ਕਰਮ ਸਹਿਤ ਸਿਉ ਮੰਡਿਤ ॥",
          "roman": "ko khaṭ karam sahit siu maṇḍit",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ (ਆਪਣੇ ਆਪ ਨੂੰ) ਸ਼ਾਸਤ੍ਰਾਂ ਦੇ ਦੱਸੇ ਹੋਏ ਛੇ ਕਰਮਾਂ ਨਾਲ ਸਜਾਈ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто-то украшает себя выполнением шести обрядов из шастр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38958,
          "is_rahao": false,
          "gurmukhi": "ਕੋਈ ਕਰੈ ਆਚਾਰ ਸੁਕਰਣੀ ॥",
          "roman": "koī karē āchār sukarṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ (ਸ਼ਾਸਤ੍ਰਾਂ ਦੇ ਕਰਮ-ਕਾਂਡ ਨੂੰ) ਸ੍ਰੇਸ਼ਟ ਕਰਣੀ ਸਮਝ ਕੇ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "кто-то считает обрядовые действия высшим делом и продолжает их совершать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38959,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਦੀਨ ਹਰਿ ਹਰਿ ਹਰਿ ਸਰਣੀ ॥੭॥",
          "roman": "mohi dīn har har har saraṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗ਼ਰੀਬ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਿਆ ਰਹਿੰਦਾ ਹਾਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "Но я, бедный, пребываю только в прибежище Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38960,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਕਰਮ ਧਰਮ ਜੁਗ ਸੋਧੇ ॥",
          "roman": "saglē karam dharam jug sōdhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਾਂ) ਸਾਰੇ ਜੁਗਾਂ ਦੇ ਸਾਰੇ ਕਰਮ ਧਰਮ ਪਰਖ ਵੇਖੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Мы исследовали все обряды и религиозные практики всех эпох,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38961,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਇਹੁ ਮਨੁ ਨ ਪ੍ਰਬੋਧੇ ॥",
          "roman": "bin nāvē ih man na prabōdhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ ਸੁੱਤਾ ਹੋਇਆ) ਇਹ ਮਨ ਜਾਗਦਾ ਨਹੀਂ।"
            },
            "sahib_singh_ru": {
              "main": "но без имени Бога этот ум не пробуждается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38962,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਉ ਸਾਧਸੰਗੁ ਪਾਇਆ ॥",
          "roman": "kah nānak jau sādhsaṅg pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਦੋਂ (ਕਿਸੇ ਮਨੁੱਖ ਨੇ) ਸਾਧ ਸੰਗਤ ਪ੍ਰਾਪਤ ਕਰ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: когда человек обретает святое собрание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38963,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝੀ ਤ੍ਰਿਸਨਾ ਮਹਾ ਸੀਤਲਾਇਆ ॥੮॥੧॥",
          "roman": "būjhī trisnā mahā sītalāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ ਬੁੱਝ ਗਈ, ਉਸ ਦਾ ਮਨ ਠੰਢਾ-ਠਾਰ ਹੋ ਗਿਆ ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "его жажда исчезает, и его ум становится прохладным и спокойным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3367,
      "rahao_verse_id": 38970,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 38964,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkali mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38965,
          "is_rahao": false,
          "gurmukhi": "ਇਸੁ ਪਾਨੀ ਤੇ ਜਿਨਿ ਤੂ ਘਰਿਆ ॥",
          "roman": "is pānī te jin tū ghariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਪਿਤਾ ਦੀ ਬੂੰਦ ਤੋਂ ਤੈਨੂੰ ਬਣਾਇਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который создал тебя из семени отца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38966,
          "is_rahao": false,
          "gurmukhi": "ਮਾਟੀ ਕਾ ਲੇ ਦੇਹੁਰਾ ਕਰਿਆ ॥",
          "roman": "māṭī kā le dehurā kariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਇਹ ਮਿੱਟੀ ਦਾ ਪੁਤਲਾ ਘੜ ਦਿੱਤਾ;"
            },
            "sahib_singh_ru": {
              "main": "сотворил это твоё тело из глины;"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38967,
          "is_rahao": false,
          "gurmukhi": "ਉਕਤਿ ਜੋਤਿ ਲੈ ਸੁਰਤਿ ਪਰੀਖਿਆ ॥",
          "roman": "ukat jot lē surat parikhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਬੁੱਧੀ, ਜਿੰਦ ਅਤੇ ਪਰਖਣ ਦੀ ਤਾਕਤ ਤੇਰੇ ਅੰਦਰ ਪਾ ਕੇ-"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который вложил в тебя разум, жизнь и способность различать —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38968,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਗਰਭ ਮਹਿ ਜਿਨਿ ਤੂ ਰਾਖਿਆ ॥੧॥",
          "roman": "māt garabh meh jin tū rākhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਮਾਂ ਦੇ ਪੇਟ ਵਿਚ (ਸਹੀ ਸਲਾਮਤ) ਰੱਖਿਆ (ਉਸ ਨੂੰ ਸਦਾ ਯਾਦ ਰੱਖ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "который сохранил тебя в чреве матери в целости — помни Его всегда"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38969,
          "is_rahao": true,
          "gurmukhi": "ਰਾਖਨਹਾਰੁ ਸਮ੍ਹਾਰਿ ਜਨਾ ॥",
          "roman": "rākhanhār samhār janā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਰੱਖਿਆ ਕਰ ਸਕਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੂੰ ਯਾਦ ਕਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда помни Бога, который способен защищать"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38970,
          "is_rahao": true,
          "gurmukhi": "ਸਗਲੇ ਛੋਡਿ ਬੀਚਾਰ ਮਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sagle chhoḍ vichār manā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! (ਪ੍ਰਭੂ ਦੀ ਯਾਦ ਤੋਂ ਬਿਨਾ) ਹੋਰ ਸਾਰੇ ਵਿਚਾਰ (ਜਿਹੜੇ ਵਿਚਾਰ ਪ੍ਰਭੂ ਦੀ ਯਾਦ ਭੁਲਾਂਦੇ ਹਨ, ਉਹ) ਛੱਡ ਦੇਹ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, оставь все прочие мысли, которые уводят от памяти о Боге"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38971,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਏ ਤੁਧੁ ਬਾਪ ਮਹਤਾਰੀ ॥",
          "roman": "jin dīe tudh bāp mahtārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਮਾਪੇ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который дал тебе родителей"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38972,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਏ ਭ੍ਰਾਤ ਪੁਤ ਹਾਰੀ ॥",
          "roman": "jin dīe bhrāt put hārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਭਰਾ ਪੁੱਤਰ ਤੇ ਨੌਕਰ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "который дал тебе братьев, детей и слуг"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38973,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਏ ਤੁਧੁ ਬਨਿਤਾ ਅਰੁ ਮੀਤਾ ॥",
          "roman": "jin dīe tudh banitā aru mītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਇਸਤ੍ਰੀ ਅਤੇ ਸੱਜਣ-ਮਿੱਤਰ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "который дал тебе супругу и друзей"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38974,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਠਾਕੁਰ ਕਉ ਰਖਿ ਲੇਹੁ ਚੀਤਾ ॥੨॥",
          "roman": "tis ṭhākur kau rakh leh chītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਆਪਣੇ ਚਿੱਤ ਵਿਚ ਟਿਕਾਈ ਰੱਖ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "этого Владыку держи в своём сознании"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38975,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਆ ਤੁਧੁ ਪਵਨੁ ਅਮੋਲਾ ॥",
          "roman": "jin dīā tudh pavan amolā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਕਿਸੇ ਭੀ ਮੁੱਲ ਤੋਂ ਨਾਹ ਮਿਲ ਸਕਣ ਵਾਲੀ ਹਵਾ ਦਿੱਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который дал тебе бесценный воздух"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38976,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਆ ਤੁਧੁ ਨੀਰੁ ਨਿਰਮੋਲਾ ॥",
          "roman": "jin dīā tudh nīr nirmolā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਨਿਰਮੋਲਕ ਪਾਣੀ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "который дал тебе драгоценную воду"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38977,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਦੀਆ ਤੁਧੁ ਪਾਵਕੁ ਬਲਨਾ ॥",
          "roman": "jin dīā tudh pāvak balnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪ੍ਰਭੂ ਨੇ ਤੈਨੂੰ ਅੱਗ ਦਿੱਤੀ, ਬਾਲਣ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "который дал тебе огонь и топливо"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38978,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਠਾਕੁਰ ਕੀ ਰਹੁ ਮਨ ਸਰਨਾ ॥੩॥",
          "roman": "tis ṭhākur kī rah man sarnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੂੰ ਉਸ ਮਾਲਕ-ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਿਆ ਰਹੁ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "о ум, пребывай в прибежище этого Владыки"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38979,
          "is_rahao": false,
          "gurmukhi": "ਛਤੀਹ ਅੰਮ੍ਰਿਤ ਜਿਨਿ ਭੋਜਨ ਦੀਏ ॥",
          "roman": "chhatīh amrit jin bhojan dīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਤੈਨੂੰ ਅਨੇਕਾਂ ਕਿਸਮਾਂ ਦੇ ਸੁਆਦਲੇ ਖਾਣੇ ਦਿੱਤੇ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который дал тебе множество вкусных блюд"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38980,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਥਾਨ ਠਹਰਾਵਨ ਕਉ ਕੀਏ ॥",
          "roman": "antar thān ṭhahrāvan kau kīe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਖਾਣਿਆਂ ਨੂੰ ਹਜ਼ਮ ਕਰਨ ਲਈ ਤੇਰੇ ਅੰਦਰ ਮਿਹਦਾ ਆਦਿਕ ਅੰਗ ਬਣਾਏ,"
            },
            "sahib_singh_ru": {
              "main": "и создал внутри тебя органы для их переваривания"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38981,
          "is_rahao": false,
          "gurmukhi": "ਬਸੁਧਾ ਦੀਓ ਬਰਤਨਿ ਬਲਨਾ ॥",
          "roman": "basudhā dīo bartan balnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਨੂੰ ਧਰਤੀ ਦਿੱਤੀ, ਤੈਨੂੰ ਹੋਰ ਵਰਤਣ-ਵਲੇਵਾ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "дал тебе землю и средства для пользования"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38982,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਠਾਕੁਰ ਕੇ ਚਿਤਿ ਰਖੁ ਚਰਨਾ ॥੪॥",
          "roman": "tis ṭhākur ke chit rakh charnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਾਲਕ-ਪ੍ਰਭੂ ਦੇ ਚਰਨ ਆਪਣੇ ਚਿੱਤ ਵਿੱਚ ਪ੍ਰੋ ਰੱਖ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "держи в сердце стопы этого Владыки"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38983,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਨ ਕਉ ਨੇਤ੍ਰ ਸੁਨਨ ਕਉ ਕਰਨਾ ॥",
          "roman": "pekhan kau netr sunan kau karnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੇਰੇ ਮਨ! ਜਿਸ ਨੇ) ਤੈਨੂੰ (ਦੁਨੀਆ ਦੇ ਰੰਗ-ਤਮਾਸ਼ੇ) ਵੇਖਣ ਵਾਸਤੇ ਅੱਖਾਂ ਦਿੱਤੀਆਂ ਹਨ ਅਤੇ ਸੁਣਨ ਵਾਸਤੇ ਕੰਨ ਦਿੱਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Он дал тебе глаза, чтобы видеть, и уши, чтобы слышать"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38984,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤ ਕਮਾਵਨ ਬਾਸਨ ਰਸਨਾ ॥",
          "roman": "hast kamāvan bāsan rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਕਾਰ ਕਰਨ ਲਈ ਤੈਨੂੰ ਹੱਥ ਦਿੱਤੇ ਹਨ, ਅਤੇ ਨੱਕ ਤੇ ਜੀਭ ਦਿੱਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "дал тебе руки для действий, нос и язык"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38985,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਚਲਨ ਕਉ ਸਿਰੁ ਕੀਨੋ ਮੇਰਾ ॥",
          "roman": "charan chalan kau sir kīno merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਤੁਰਨ ਲਈ ਤੈਨੂੰ ਪੈਰ ਦਿੱਤੇ ਹਨ ਅਤੇ ਸਿਰ (ਸਾਰੇ ਅੰਗਾਂ ਵਿਚੋਂ) ਸ਼ਿਰੋਮਣੀ ਬਣਾਇਆ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "дал тебе ноги для ходьбы и сделал голову главной"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38986,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਿਸੁ ਠਾਕੁਰ ਕੇ ਪੂਜਹੁ ਪੈਰਾ ॥੫॥",
          "roman": "man tis ṭhākur ke pūjah pērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਾਲਕ-ਪ੍ਰਭੂ ਦੇ ਪੈਰ ਸਦਾ ਪੂਜਦਾ ਰਹੁ (ਨਿਮ੍ਰਤਾ ਧਾਰਨ ਕਰ ਕੇ ਉਸ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਰਹੁ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "о ум, поклоняйся стопам этого Владыки"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38987,
          "is_rahao": false,
          "gurmukhi": "ਅਪਵਿਤ੍ਰ ਪਵਿਤ੍ਰੁ ਜਿਨਿ ਤੂ ਕਰਿਆ ॥",
          "roman": "apavitr pavitr jin tū kariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਸਿਮਰਿਆ ਕਰ) ਜਿਸ ਨੇ ਗੰਦ ਤੋਂ ਤੈਨੂੰ ਪਵਿੱਤਰ ਬਣਾ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто сделал тебя чистым из нечистоты"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38988,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਜੋਨਿ ਮਹਿ ਤੂ ਸਿਰਿ ਧਰਿਆ ॥",
          "roman": "sagal jon meh tū sir dhariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਤੈਨੂੰ ਸਾਰੀਆਂ ਜੂਨੀਆਂ ਉਤੇ ਸਰਦਾਰ ਬਣਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "сделал тебя главным среди всех форм жизни"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38989,
          "is_rahao": false,
          "gurmukhi": "ਅਬ ਤੂ ਸੀਝੁ ਭਾਵੈ ਨਹੀ ਸੀਝੈ ॥",
          "roman": "ab tū sījh bhāvē nahī sījhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੀ ਮਰਜ਼ੀ ਹੈ ਹੁਣ ਤੂੰ (ਉਸ ਦਾ ਸਿਮਰਨ ਕਰ ਕੇ ਜ਼ਿੰਦਗੀ ਵਿਚ) ਕਾਮਯਾਬ ਹੋ ਚਾਹੇ ਨਾਹ ਹੋ।"
            },
            "sahib_singh_ru": {
              "main": "теперь от тебя зависит, достигнешь ли ты успеха или нет"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38990,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਜੁ ਸਵਰੈ ਮਨ ਪ੍ਰਭੁ ਧਿਆਈਜੈ ॥੬॥",
          "roman": "kāraj savrē man prabh dhiāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਹੇ ਮਨ! ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ, (ਸਿਮਰਨ ਕੀਤੀਆਂ ਹੀ ਮਨੁੱਖਾ ਜੀਵਨ ਦਾ) ਮਨੋਰਥ ਸਫਲ ਹੁੰਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "о ум, помни Бога — только так цель жизни исполняется"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38991,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾ ਊਹਾ ਏਕੈ ਓਹੀ ॥",
          "roman": "īhā ūhā ekē ohī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਵਿਚ ਤੇ ਪਰਲੋਕ ਵਿਚ ਇਕ ਉਹ ਪਰਮਾਤਮਾ ਹੀ (ਸਹਾਈ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "в этом мире и в ином есть только один Бог"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38992,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਦੇਖੀਐ ਤਤ ਤਤ ਤੋਹੀ ॥",
          "roman": "jat kat dekhiē tat tat tohī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿੱਥੇ ਕਿੱਥੇ ਝਾਤੀ ਮਾਰੀ ਜਾਏ ਉਥੇ ਉਥੇ (ਪਰਮਾਤਮਾ ਹੀ) ਤੇਰੇ ਨਾਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "куда ни посмотри — везде Он с тобой"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38993,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਸੇਵਤ ਮਨਿ ਆਲਸੁ ਕਰੈ ॥",
          "roman": "tis sevat man ālas karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਵੇਖੋ ਮਨੁੱਖ ਦੀ ਮੰਦ-ਭਾਗਤਾ!) ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਸਿਮਰਦਿਆਂ (ਮਨੁੱਖ) ਮਨ ਵਿਚ ਆਲਸ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но человек ленится помнить Его"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38994,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਵਿਸਰਿਐ ਇਕ ਨਿਮਖ ਨ ਸਰੈ ॥੭॥",
          "roman": "jis visrē ik nimakh na sarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੂੰ ਵਿਸਾਰਿਆਂ ਇਕ ਪਲ-ਭਰ ਸਮਾ ਭੀ ਸੌਖਾ ਨਹੀਂ ਲੰਘ ਸਕਦਾ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "хотя без Него нельзя прожить даже мгновение"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38995,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਅਪਰਾਧੀ ਨਿਰਗੁਨੀਆਰੇ ॥",
          "roman": "ham aprādhī nirgunīāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਵਿਚ ਫਸ ਕੇ) ਅਸੀਂ ਸੰਸਾਰੀ ਜੀਵ ਪਾਪੀ ਬਣ ਜਾਂਦੇ ਹਾਂ, ਗੁਣ-ਹੀਣ ਹੋ ਜਾਂਦੇ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "мы становимся грешными и лишёнными добродетелей"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38996,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕਿਛੁ ਸੇਵਾ ਨਾ ਕਰਮਾਰੇ ॥",
          "roman": "nā kichh sevā nā karmāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸੀਂ ਨਾਹ ਕੋਈ ਸੇਵਾ-ਭਗਤੀ ਕਰਦੇ ਹਾਂ, ਨਾਹ ਹੀ ਸਾਡੇ ਕੰਮ ਚੰਗੇ ਹੁੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "мы не служим и не совершаем добрых дел"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38997,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਬੋਹਿਥੁ ਵਡਭਾਗੀ ਮਿਲਿਆ ॥",
          "roman": "gur bohith vaḍbhāgī miliā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਗੁਰੂ-ਜਹਾਜ਼ ਮਿਲ ਪਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "тем, кому по великой удаче встретился Гуру-корабль"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 38998,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸੰਗਿ ਪਾਥਰ ਤਰਿਆ ॥੮॥੨॥",
          "roman": "nānak dās sang pāthar tariā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! (ਉਸ ਜਹਾਜ਼ ਦੀ ਸੰਗਤ ਵਿਚ ਉਹ) ਪੱਥਰ-ਦਿਲ ਮਨੁੱਖ ਭੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਗਏ ॥੮॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "говорит Нанак — даже каменные сердца переправились через океан"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3368,
