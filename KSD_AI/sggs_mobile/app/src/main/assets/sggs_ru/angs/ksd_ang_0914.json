{
  "ang": 914,
  "shabads": [
    {
      "shabad_id": 3368,
      "rahao_verse_id": 39005,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 39001,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਮਾਇ ਬਾਪ ਪੂਤ ॥",
          "roman": "kāhū bihāvē māi bāp poot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਦੀ ਉਮਰ ਮਾਂ ਪਿਉ ਪੁੱਤਰ ਆਦਿਕ ਪਰਵਾਰ ਦੇ ਮੋਹ ਵਿਚ ਗੁਜ਼ਰ ਰਹੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у кого-то — в привязанности к семье"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39002,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਰਾਜ ਮਿਲਖ ਵਾਪਾਰਾ ॥",
          "roman": "kāhū bihāvē rāj milakh vāparā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਰਾਜ ਮਾਣਨ, ਭੁਇਂ ਦੀ ਮਾਲਕੀ, ਵਪਾਰ ਆਦਿਕ ਕਰਨ ਵਿਚ ਲੰਘ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у кого-то — в власти, владении землёй и делах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39003,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਿਹਾਵੈ ਹਰਿ ਨਾਮ ਅਧਾਰਾ ॥੧॥",
          "roman": "sant bihāvē har nām adhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਰਫ਼) ਸੰਤ ਦੀ ਉਮਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੇ ਆਸਰੇ ਬੀਤਦੀ ਗੁਜ਼ਰਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а у святого — в опоре на Имя Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39004,
          "is_rahao": true,
          "gurmukhi": "ਰਚਨਾ ਸਾਚੁ ਬਨੀ ॥",
          "roman": "rachnā sāch banī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਹੈ। ਇਹ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਉਸੇ ਦੀ ਪੈਦਾ ਕੀਤੀ ਹੋਈ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Бог вечен, и всё творение создано Им"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39005,
          "is_rahao": true,
          "gurmukhi": "ਸਭ ਕਾ ਏਕੁ ਧਨੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sabh kā ek dhanī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਕ ਉਹੀ ਹਰੇਕ ਜੀਵ ਦਾ ਮਾਲਕ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Он — единственный владыка всех"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39006,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਬੇਦ ਅਰੁ ਬਾਦਿ ॥",
          "roman": "kāhū bihāvē bed aru bād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਵੇਦ ਆਦਿਕ ਧਰਮ-ਪੁਸਤਕ ਪੜ੍ਹਨ ਅਤੇ (ਧਾਰਮਿਕ) ਚਰਚਾ ਵਿਚ ਗੁਜ਼ਰ ਰਹੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у кого-то жизнь проходит в изучении писаний и спорах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39007,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਰਸਨਾ ਸਾਦਿ ॥",
          "roman": "kāhū bihāvē rasnā sād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਜੀਭ ਦੇ ਸੁਆਦ ਵਿਚ ਬੀਤ ਰਹੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у кого-то — в наслаждении вкусами"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39008,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਲਪਟਿ ਸੰਗਿ ਨਾਰੀ ॥",
          "roman": "kāhū bihāvē lapaṭ sang nārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਦੀ ਉਮਰ ਇਸਤ੍ਰੀ ਨਾਲ ਕਾਮ-ਪੂਰਤੀ ਵਿਚ ਲੰਘਦੀ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "у кого-то — в страстях"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39009,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਰਚੇ ਕੇਵਲ ਨਾਮ ਮੁਰਾਰੀ ॥੨॥",
          "roman": "sant rache keval nām murārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਹੀ ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਮਸਤ ਰਹਿੰ​‍ਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а святые погружены только в Имя Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39010,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਖੇਲਤ ਜੂਆ ॥",
          "roman": "kāhū bihāvē khelt jūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਜੂਆ ਖੇਡਦਿਆਂ ਲੰਘ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "у кого-то жизнь проходит в игре в азартные игры"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39011,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਅਮਲੀ ਹੂਆ ॥",
          "roman": "kāhū bihāvē amlī hūā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਮਨੁੱਖ ਅਫ਼ੀਮ ਆਦਿਕ ਨਸ਼ੇ ਦਾ ਆਦੀ ਹੋ ਜਾਂਦਾ ਹੈ ਉਸ ਦੀ ਉਮਰ ਨਸ਼ਿਆਂ ਵਿਚ ਹੀ ਗੁਜ਼ਰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то проводит жизнь в наркотическом опьянении"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39012,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਪਰ ਦਰਬ ਚੋੁਰਾਏ ॥",
          "roman": "kāhū bihāvē par darb chorāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਦੀ ਉਮਰ ਪਰਾਇਆ ਧਨ ਚੁਰਾਂਦਿਆਂ ਬੀਤਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то ворует чужое богатство"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39013,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜਨ ਬਿਹਾਵੈ ਨਾਮ ਧਿਆਏ ॥੩॥",
          "roman": "har jan bihāvē nām dhiāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪ੍ਰਭੂ ਦੇ ਭਗਤਾਂ ਦੀ ਉਮਰ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਗੁਜ਼ਰਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "а преданные проводят жизнь в памятовании Имени"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39014,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਜੋਗ ਤਪ ਪੂਜਾ ॥",
          "roman": "kāhū bihāvē jog tap pūjā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਜੋਗ-ਸਾਧਨ ਕਰਦਿਆਂ, ਕਿਸੇ ਦੀ ਧੂਣੀਆਂ ਤਪਾਂਦਿਆਂ, ਕਿਸੇ ਦੀ ਦੇਵ-ਪੂਜਾ ਕਰਦਿਆਂ ਗੁਜ਼ਰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то в йоге, аскезе и поклонении"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39015,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਰੋਗ ਸੋਗ ਭਰਮੀਜਾ ॥",
          "roman": "kāhū rog sog bharmījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਬੰਦੇ ਦੀ ਉਮਰ ਰੋਗਾਂ ਵਿਚ, ਗ਼ਮਾਂ ਵਿਚ, ਅਨੇਕਾਂ ਭਟਕਣਾਂ ਵਿਚ ਬੀਤਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в болезнях и печалях"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39016,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਪਵਨ ਧਾਰ ਜਾਤ ਬਿਹਾਏ ॥",
          "roman": "kāhū pavan dhār jāt bihāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਸਾਰੀ ਉਮਰ ਪ੍ਰਾਣਾਯਾਮ ਕਰਦਿਆਂ ਲੰਘ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в дыхательных практиках"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39017,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਿਹਾਵੈ ਕੀਰਤਨੁ ਗਾਏ ॥੪॥",
          "roman": "sant bihāvē kīrtan gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਸੰਤ ਦੀ ਉਮਰ ਗੁਜ਼ਰਦੀ ਹੈ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੇ ਗੀਤ ਗਾਂਦਿਆਂ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "а святые поют хвалу Богу"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39018,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਦਿਨੁ ਰੈਨਿ ਚਾਲਤ ॥",
          "roman": "kāhū bihāvē din rēn chālat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਦੀ ਉਮਰ ਬੀਤਦੀ ਹੈ ਦਿਨੇ ਰਾਤ ਤੁਰਦਿਆਂ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то проводит жизнь в постоянном движении"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39019,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਸੋ ਪਿੜੁ ਮਾਲਤ ॥",
          "roman": "kāhū bihāvē so piṛ mālat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਕਿਸੇ ਦੀ ਲੰਘਦੀ ਹੈ ਇਕੋ ਥਾਂ ਮੱਲ ਕੇ ਬੈਠੇ ਰਿਹਾਂ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — сидя на одном месте"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39020,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਬਾਲ ਪੜਾਵਤ ॥",
          "roman": "kāhū bihāvē bāl paṛāvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਉਮਰ ਮੁੰ​‍ਡੇ ਪੜ੍ਹਾਉਂਦਿਆਂ ਲੰਘ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — обучая детей"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39021,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਿਹਾਵੈ ਹਰਿ ਜਸੁ ਗਾਵਤ ॥੫॥",
          "roman": "sant bihāvē har jas gāvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਉਮਰ ਬੀਤਦੀ ਹੈ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦਾ ਗੀਤ ਗਾਂਦਿਆਂ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "а святые поют славу Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39022,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਨਟ ਨਾਟਿਕ ਨਿਰਤੇ ॥",
          "roman": "kāhū bihāvē naṭ nāṭik nirte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਨਟਾਂ ਵਾਲੇ ਨਾਟਕ ਅਤੇ ਨਾਚ ਕਰਦਿਆਂ ਗੁਜ਼ਰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то проводит жизнь в играх и танцах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39023,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਜੀਆਇਹ ਹਿਰਤੇ ॥",
          "roman": "kāhū bihāvē jīāeh hirte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਇਹ ਉਮਰ ਡਾਕੇ ਮਾਰਦਿਆਂ ਲੰਘ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в грабежах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39024,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਰਾਜ ਮਹਿ ਡਰਤੇ ॥",
          "roman": "kāhū bihāvē rāj meh ḍarte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਰਾਜ-ਦਰਬਾਰ ਵਿਚ (ਰਹਿ ਕੇ) ਥਰ-ਥਰ ਕੰਬਦਿਆਂ ਹੀ ਗੁਜ਼ਰਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в страхе при дворе"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39025,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਿਹਾਵੈ ਹਰਿ ਜਸੁ ਕਰਤੇ ॥੬॥",
          "roman": "sant bihāvē har jas karte",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਉਮਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦਿਆਂ ਲੰਘਦੀ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "а святые славят Бога"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39026,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਮਤਾ ਮਸੂਰਤਿ ॥",
          "roman": "kāhū bihāvē matā masūrat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੀਆਂ ਔਖਿਆਈਆਂ ਦੇ ਕਾਰਨ) ਕਿਸੇ ਦੀ ਉਮਰ ਗਿਣਤੀਆਂ ਗਿਣਦਿਆਂ ਲੰਘ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то проводит жизнь в расчётах"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39027,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਸੇਵਾ ਜਰੂਰਤਿ ॥",
          "roman": "kāhū bihāvē sevā zarūrat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜ਼ਿੰਦਗੀ ਦੀਆਂ) ਲੋੜਾਂ ਪੂਰੀਆਂ ਕਰਨ ਲਈ ਕਿਸੇ ਦੀ ਜ਼ਿੰਦਗੀ ਨੌਕਰੀ ਕਰਦਿਆਂ ਗੁਜ਼ਰ ਜਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в службе ради нужд"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39028,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੂ ਬਿਹਾਵੈ ਸੋਧਤ ਜੀਵਤ ॥",
          "roman": "kāhū bihāvē sodhat jīvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਸੇ ਮਨੁੱਖ ਦੀ ਸਾਰੀ ਉਮਰ ਖੋਜ-ਭਾਲ ਕਰਦਿਆਂ ਬੀਤਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "кто-то — в поисках и исследованиях"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39029,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਿਹਾਵੈ ਹਰਿ ਰਸੁ ਪੀਵਤ ॥੭॥",
          "roman": "sant bihāvē har ras pīvat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੰਤ ਦੀ ਉਮਰ ਬੀਤਦੀ ਹੈ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ-ਅੰ​‍ਮ੍ਰਿਤ ਪੀਂਦਿਆਂ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "а святые вкушают нектар Имени"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39030,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਕੋ ਲਾਇਆ ਤਿਤ ਹੀ ਲਗਾਨਾ ॥",
          "roman": "jit ko lāiā tit hī lagānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਕੰਮ ਵਿਚ ਪਰਮਾਤਮਾ ਨੇ ਕਿਸੇ ਨੂੰ ਲਾਇਆ ਹੈ ਉਸੇ ਵਿਚ ਹੀ ਉਹ ਲੱਗਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "каждый занят тем, куда его направил Бог"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39031,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕੋ ਮੂੜੁ ਨਹੀ ਕੋ ਸਿਆਨਾ ॥",
          "roman": "nā ko mūṛ nahī ko siānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਹ ਕੋਈ ਜੀਵ ਮੂਰਖ ਹੈ, ਨਾਹ ਕੋਈ ਸਿਆਣਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "нет ни глупого, ни мудрого"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39032,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਦੇਵੈ ਨਾਉ ॥ ਨਾਨਕ ਤਾ ਕੈ ਬਲਿ ਬਲਿ ਜਾਉ ॥੮॥੩॥",
          "roman": "kar kirpā jis devē nāu nānak tā kē bal bal jāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਮਿਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ਦਾ ਹੈ, ਹੇ ਨਾਨਕ! ਮੈਂ ਉਸ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ਕੁਰਬਾਨ ਜਾਂਦਾ ਹਾਂ ॥੮॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "кому Бог по милости дарует Имя — говорит Нанак — я пред ним склоняюсь и жертвую себя"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3369,
      "rahao_verse_id": 39039,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 39033,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਮਹਲਾ ੫ ॥",
          "roman": "rāmkalī mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39034,
          "is_rahao": false,
          "gurmukhi": "ਦਾਵਾ ਅਗਨਿ ਰਹੇ ਹਰਿ ਬੂਟ ॥",
          "roman": "dāvā agan rahē har būṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੰਗਲ ਦੀ ਅੱਗ ਹਰੇ ਬੂਟੇ ਵਿਚ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ (ਉਸ ਨੂੰ ਨਹੀਂ ਸਾੜਦੀ। ਬਾਕੀ ਜੰਗਲ ਨੂੰ ਸਾੜਦੀ ਹੈ);"
            },
            "sahib_singh_ru": {
              "main": "Лесной огонь остаётся в зелёных растениях (не сжигает их, а сжигает остальной лес);"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39035,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਗਰਭ ਸੰਕਟ ਤੇ ਛੂਟ ॥",
          "roman": "māt garabh saṅkaṭ tē chhūṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੱਚਾ ਮਾਂ ਦੇ ਪੇਟ ਦੇ ਦੁੱਖਾਂ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Ребёнок остаётся защищённым от страданий в утробе матери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39036,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾ ਨਾਮੁ ਸਿਮਰਤ ਭਉ ਜਾਇ ॥",
          "roman": "jā kā nām simrat bhau jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਪਾਤਿਸ਼ਾਹ ਜਿਸ ਦਾ ਨਾਮ ਸਿਮਰਿਆਂ ਹਰੇਕ ਕਿਸਮ ਦਾ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Господь-Царь, при памятовании имени Которого исчезает всякий страх,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39037,
          "is_rahao": false,
          "gurmukhi": "ਤੈਸੇ ਸੰਤ ਜਨਾ ਰਾਖੈ ਹਰਿ ਰਾਇ ॥੧॥",
          "roman": "tēsē sant janā rākhae har rāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਸੰਤ ਜਨਾਂ ਦੀ ਇਸੇ ਤਰ੍ਹਾਂ ਰੱਖਿਆ ਕਰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "так же Он оберегает Своих святых людей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39038,
          "is_rahao": true,
          "gurmukhi": "ਐਸੇ ਰਾਖਨਹਾਰ ਦਇਆਲ ॥",
          "roman": "aisē rākhanhār dayāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੀ ਰੱਖਿਆ ਕਰਨ ਦੇ ਸਮਰੱਥ ਪ੍ਰਭੂ! ਤੂੰ ਬੜਾ ਹੀ ਦਇਆ ਦਾ ਘਰ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, способный защитить всех! Ты — обитель великой милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39039,
          "is_rahao": true,
          "gurmukhi": "ਜਤ ਕਤ ਦੇਖਉ ਤੁਮ ਪ੍ਰਤਿਪਾਲ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jat kat dēkhau tum pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਜਿੱਧਰ ਵੇਖਦਾ ਹਾਂ, ਤੂੰ ਹੀ ਸਭ ਦੀ ਪਾਲਣਾ ਕਰਦਾ ਹੈਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни посмотрел, Ты везде поддерживаешь всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39040,
          "is_rahao": false,
          "gurmukhi": "ਜਲੁ ਪੀਵਤ ਜਿਉ ਤਿਖਾ ਮਿਟੰਤ ॥",
          "roman": "jal pīvat jiu tikhā miṭant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਪੀਤਿਆਂ ਤ੍ਰੇਹ ਮਿਟ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как при питье воды утоляется жажда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39041,
          "is_rahao": false,
          "gurmukhi": "ਧਨ ਬਿਗਸੈ ਗ੍ਰਿਹਿ ਆਵਤ ਕੰਤ ॥",
          "roman": "dhan bigsē grih āvat kant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਤੀ ਘਰ ਆਇਆਂ ਇਸਤ੍ਰੀ ਖ਼ੁਸ਼ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как женщина радуется, когда муж приходит домой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39042,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭੀ ਕਾ ਧਨੁ ਪ੍ਰਾਣ ਅਧਾਰੁ ॥",
          "roman": "lobhī kā dhan prāṇ adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਧਨ-ਪਦਾਰਥ ਲੋਭੀ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਦਾ ਸਹਾਰਾ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как богатство становится опорой жизни жадного человека,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39043,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨ ਹਰਿ ਹਰਿ ਨਾਮ ਪਿਆਰੁ ॥੨॥",
          "roman": "tiu har jan har har nām piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪ੍ਰਭੂ ਦੇ ਭਗਤਾਂ ਦਾ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਨਾਲ ਪਿਆਰ ਹੁੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "так и преданные Господа любят Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39044,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਸਾਨੀ ਜਿਉ ਰਾਖੈ ਰਖਵਾਲਾ ॥",
          "roman": "kirsānī jiu rākhae rakhvālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਰਾਖਾ ਖੇਤੀ ਦੀ ਰਾਖੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как сторож охраняет поле,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39045,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਪਿਤਾ ਦਇਆ ਜਿਉ ਬਾਲਾ ॥",
          "roman": "māt pitā dayā jiu bālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮਾਪੇ ਆਪਣੇ ਬੱਚੇ ਨਾਲ ਪਿਆਰ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "как родители проявляют любовь к своему ребёнку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39046,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੀਤਮੁ ਦੇਖਿ ਪ੍ਰੀਤਮੁ ਮਿਲਿ ਜਾਇ ॥",
          "roman": "prītam dēkh prītam mil jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕੋਈ ਮਿੱਤਰ ਆਪਣੇ ਮਿੱਤਰ ਨੂੰ ਵੇਖ ਕੇ (ਉਸ ਨੂੰ) ਮਿਲ ਕੇ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как друг, увидев друга, идёт к нему навстречу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39047,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਜਨ ਰਾਖੈ ਕੰਠਿ ਲਾਇ ॥੩॥",
          "roman": "tiu har jan rākhae kanṭh lāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਆਪਣੇ ਭਗਤਾਂ ਨੂੰ ਆਪਣੇ ਗਲ ਨਾਲ ਲਾ ਰੱਖਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "так и Господь держит Своих преданных, прижимая их к Себе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39048,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਅੰਧੁਲੇ ਪੇਖਤ ਹੋਇ ਅਨੰਦ ॥",
          "roman": "jiu andhulē phekhat hoi anand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਜੇ ਕਿਸੇ ਅੰ​‍ਨ੍ਹੇ ਨੂੰ ਵੇਖ ਸਕਣ ਦੀ ਸ਼ਕਤੀ ਮਿਲ ਜਾਏ ਤਾਂ ਉਹ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как слепой радуется, если получает способность видеть,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39049,
          "is_rahao": false,
          "gurmukhi": "ਗੂੰਗਾ ਬਕਤ ਗਾਵੈ ਬਹੁ ਛੰਦ ॥",
          "roman": "gūṅgā bakat gāvē bah chhand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੂੰਗਾ ਬੋਲਣ ਲੱਗ ਪਏ (ਤਾਂ ਉਹ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ, ਤੇ) ਕਈ ਗੀਤ ਗਾਣ ਲੱਗ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как немой, начав говорить, радуется и поёт множество песен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39050,
          "is_rahao": false,
          "gurmukhi": "ਪਿੰਗੁਲ ਪਰਬਤ ਪਰਤੇ ਪਾਰਿ ॥",
          "roman": "piṅgul parbat partē pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਲੂਲ੍ਹਾ ਪਹਾੜਾਂ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕਣ ਨਾਲ ਖ਼ੁਸ਼ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как хромой радуется, если может перейти через горы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39051,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੈ ਨਾਮਿ ਸਗਲ ਉਧਾਰਿ ॥੪॥",
          "roman": "har kē nām sagal udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸੇ ਤਰ੍ਹਾਂ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਜਿਹੜੀ) ਲੋਕਾਈ ਦਾ ਨਿਸਤਾਰਾ ਹੁੰਦਾ ਹੈ (ਉਹ ਬਹੁਤ ਪ੍ਰਸੰਨ ਹੁੰਦੀ ਹੈ) ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "так и благодаря Имени Господа всё человечество спасается и радуется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39052,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਪਾਵਕ ਸੰਗਿ ਸੀਤ ਕੋ ਨਾਸ ॥",
          "roman": "jiu pāvak saṅg sīt ko nās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਅੱਗ ਨਾਲ ਠੰਢ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как огонь уничтожает холод,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39053,
          "is_rahao": false,
          "gurmukhi": "ਐਸੇ ਪ੍ਰਾਛਤ ਸੰਤਸੰਗਿ ਬਿਨਾਸ ॥",
          "roman": "aisē prāchhat santsaṅg binās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਸੰਤਾਂ ਦੀ ਸੰਗਤ ਕੀਤਿਆਂ ਪਾਪਾਂ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "так и в обществе святых исчезают грехи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39054,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਸਾਬੁਨਿ ਕਾਪਰ ਊਜਲ ਹੋਤ ॥",
          "roman": "jiu sābun kāpar ūjal hot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਸਾਬਣ ਨਾਲ ਕੱਪੜੇ ਸਾਫ਼-ਸੁਥਰੇ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Как с мылом одежда становится чистой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39055,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਜਪਤ ਸਭੁ ਭ੍ਰਮੁ ਭਉ ਖੋਤ ॥੫॥",
          "roman": "nām japat sabh bhram bhau khot",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ ਹਰੇਕ ਵਹਿਮ ਹਰੇਕ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "так и при повторении Имени исчезают все сомнения и страхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39056,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਚਕਵੀ ਸੂਰਜ ਕੀ ਆਸ ॥",
          "roman": "jiu chakvī sūraj kī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਚਕਵੀ (ਚਕਵੇ ਨੂੰ ਮਿਲਣ ਵਾਸਤੇ) ਸੂਰਜ (ਦੇ ਚੜ੍ਹਨ) ਦੀ ਉਡੀਕ ਕਰਦੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как чакви ожидает восхода солнца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39057,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਚਾਤ੍ਰਿਕ ਬੂੰਦ ਕੀ ਪਿਆਸ ॥",
          "roman": "jiu chātrik būnd kī piās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ (ਪਿਆਸ ਬੁਝਾਣ ਲਈ) ਪਪੀਹੇ ਨੂੰ ਵਰਖਾ ਦੀਆਂ ਬੂੰਦਾਂ ਦੀ ਲਾਲਸਾ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как папиха жаждет капель дождя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39058,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਕੁਰੰਕ ਨਾਦ ਕਰਨ ਸਮਾਨੇ ॥",
          "roman": "jiu kuraṅk nād karan samāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਹਰਨ ਦੇ ਕੰਨ ਘੰ​‍ਡੇਹੇੜੇ ਦੀ ਆਵਾਜ਼ ਵਿਚ ਮਸਤ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "как олень очарован звуком колокольчика,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 39059,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਹਰਿ ਨਾਮ ਹਰਿ ਜਨ ਮਨਹਿ ਸੁਖਾਨੇ ॥੬॥",
          "roman": "tiu har nām har jan manah sukhāne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਸੰਤ ਜਨਾਂ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪਿਆਰਾ ਲੱਗਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "так и Имя Господа приятно сердцу Его преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
