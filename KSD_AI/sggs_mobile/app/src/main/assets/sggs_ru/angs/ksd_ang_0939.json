{
  "ang": 939,
  "shabads": [
    {
      "shabad_id": 3410,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40022,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥਿ ਨਾਈਐ ਸੁਖੁ ਫਲੁ ਪਾਈਐ ਮੈਲੁ ਨ ਲਾਗੈ ਕਾਈ ॥",
          "roman": "tīrath nāīē sukh phal pāīē mēl na lāgē kāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если омыться в святом месте, получают плод покоя, и никакая скверна не пристаёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40023,
          "is_rahao": false,
          "gurmukhi": "ਗੋਰਖ ਪੂਤੁ ਲੋਹਾਰੀਪਾ ਬੋਲੈ ਜੋਗ ਜੁਗਤਿ ਬਿਧਿ ਸਾਈ ॥੭॥",
          "roman": "gorakh pūt lohārīpā bolē jog jugat bidh sāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лохарипа, сын Горакха, говорит: таков способ и путь йоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40024,
          "is_rahao": false,
          "gurmukhi": "ਹਾਟੀ ਬਾਟੀ ਨੀਦ ਨ ਆਵੈ ਪਰ ਘਰਿ ਚਿਤੁ ਨ ਡੋੁਲਾਈ ॥",
          "roman": "hāṭī bāṭī nīd na āvē par ghar chit na ḍulāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Среди дел мира человек не должен засыпать, то есть погружаться в них; и не должен позволять уму колебаться к чужому дому."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40025,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਮਨੁ ਟੇਕ ਨ ਟਿਕਈ ਨਾਨਕ ਭੂਖ ਨ ਜਾਈ ॥",
          "roman": "bin nāvē man ṭēk na ṭikī nanak bhūkh na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но без Имени ум не может обрести устойчивую опору; о Нанак, жажда майи не уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40026,
          "is_rahao": false,
          "gurmukhi": "ਹਾਟੁ ਪਟਣੁ ਘਰੁ ਗੁਰੂ ਦਿਖਾਇਆ ਸਹਜੇ ਸਚੁ ਵਾਪਾਰੋ ॥",
          "roman": "hāṭ paṭaṇ ghar gurū dikhāiā sahjē sach vāpāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кому Сатгуру показал истинную лавку, город и дом для торговли Именем, тот, оставаясь в сахадже, торгует Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40027,
          "is_rahao": false,
          "gurmukhi": "ਖੰਡਿਤ ਨਿਦ੍ਰਾ ਅਲਪ ਅਹਾਰੰ ਨਾਨਕ ਤਤੁ ਬੀਚਾਰੋ ॥੮॥",
          "roman": "khaṇḍit nidrā alap āhāraṅ nanak tat bīchāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У такого человека сон уменьшен и пища мала; о Нанак, в этом состоит размышление о сути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3411,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40028,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨੁ ਭੇਖ ਕਰਹੁ ਜੋਗਿੰਦ੍ਰਾ ਮੁੰਦ੍ਰਾ ਝੋਲੀ ਖਿੰਥਾ ॥",
          "roman": "darsan bhēkh karah jogiṅdrā mundrā jholī khinthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Йог говорит: прими учение и облик великого йога, надень серьги, суму и лоскутную накидку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40029,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰਹ ਅੰਤਰਿ ਏਕੁ ਸਰੇਵਹੁ ਖਟੁ ਦਰਸਨ ਇਕ ਪੰਥਾ ॥",
          "roman": "bārah antar ēk sarēvah khaṭ darsan ik panthā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Среди двенадцати йогических ветвей прими одну, наш путь Ай-пантх; среди шести обличий есть один путь йогов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40030,
          "is_rahao": false,
          "gurmukhi": "ਇਨ ਬਿਧਿ ਮਨੁ ਸਮਝਾਈਐ ਪੁਰਖਾ ਬਾਹੁੜਿ ਚੋਟ ਨ ਖਾਈਐ ॥",
          "roman": "in bidh man samjhāīai purakhā bāhuṛ choṭ na khāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Пурукх, таким способом можно наставить ум, и тогда он снова не получит удара майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40031,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਬੋਲੈ ਗੁਰਮੁਖਿ ਬੂਝੈ ਜੋਗ ਜੁਗਤਿ ਇਵ ਪਾਈਐ ॥੯॥",
          "roman": "nanak bolē gurmukh būjhē jog jugat iv pāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак отвечает: став гурмукхом, человек понимает способ наставить ум; так обретается истинная югат йоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40032,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਸਬਦੁ ਨਿਰੰਤਰਿ ਮੁਦ੍ਰਾ ਹਉਮੈ ਮਮਤਾ ਦੂਰਿ ਕਰੀ ॥",
          "roman": "antar sabad nirantar mudrā haumē mamtā dūr karī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Непрерывно поселить внутри слово Сатгуру — это и есть серьги; так человек удаляет Хоумэ и привязанное «моё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40033,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਅਹੰਕਾਰੁ ਨਿਵਾਰੈ ਗੁਰ ਕੈ ਸਬਦਿ ਸੁ ਸਮਝ ਪਰੀ ॥",
          "roman": "kām krodh ahaṅkār nivārē gur kē sabad su samajh parī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он устраняет похоть, гнев и гордыню; через слово Гуру в нём появляется верное понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40034,
          "is_rahao": false,
          "gurmukhi": "ਖਿੰਥਾ ਝੋਲੀ ਭਰਿਪੁਰਿ ਰਹਿਆ ਨਾਨਕ ਤਾਰੈ ਏਕੁ ਹਰੀ ॥",
          "roman": "khinthā jholī bharpur rahiā nanak tārē ēk harī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, видеть Единого Хари наполненным во всём и пребывающим повсюду — вот его накидка и сума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40035,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਾ ਸਾਹਿਬੁ ਸਾਚੀ ਨਾਈ ਪਰਖੈ ਗੁਰ ਕੀ ਬਾਤ ਖਰੀ ॥੧੦॥",
          "roman": "sāchā sāhib sāchī nāī parkhē gur kī bāt kharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через истинное слово Гуру он распознаёт, что спасает лишь один Господь: вечный Владыка, чья слава вечна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3412,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40036,
          "is_rahao": false,
          "gurmukhi": "ਊਂਧਉ ਖਪਰੁ ਪੰਚ ਭੂ ਟੋਪੀ ॥",
          "roman": "ūṅdhau khapar pañch bhū ṭopī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сознание, отвернувшееся от мирских желаний, — его чаша; божественные качества пяти элементов — его шапка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40037,
          "is_rahao": false,
          "gurmukhi": "ਕਾਂਇਆ ਕੜਾਸਣੁ ਮਨੁ ਜਾਗੋਟੀ ॥",
          "roman": "kāiā kaṛāsaṇ man jāgoṭī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело, сохранённое чистым от пороков, — его соломенное сиденье; покорённый ум — его набедренная повязка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40038,
          "is_rahao": false,
          "gurmukhi": "ਸਤੁ ਸੰਤੋਖੁ ਸੰਜਮੁ ਹੈ ਨਾਲਿ ॥",
          "roman": "sat santokh sanjam hē nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинность, довольство и самообуздание сопровождают его как три ученика."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40039,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਸਮਾਲਿ ॥੧੧॥",
          "roman": "nanak gurmukh nām samāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, таков человек, который через Гуру хранит в памяти Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40040,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਗੁਪਤਾ ਕਵਨੁ ਸੁ ਮੁਕਤਾ ॥",
          "roman": "kavan su gupatā kavan su muktā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вопрос: кто скрыт? Кто освобождён?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40041,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਅੰਤਰਿ ਬਾਹਰਿ ਜੁਗਤਾ ॥",
          "roman": "kavan su antar bāhar jugtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто соединён с Ним внутри и снаружи, умом и телесными чувствами?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40042,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਆਵੈ ਕਵਨੁ ਸੁ ਜਾਇ ॥",
          "roman": "kavan su āvē kavan su jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто приходит и уходит, то есть рождается и умирает?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40043,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਸੁ ਤ੍ਰਿਭਵਣਿ ਰਹਿਆ ਸਮਾਇ ॥੧੨॥",
          "roman": "kavan su tribhavaṇ rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто пребывает слитым с Владыкой трёх миров?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3413,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40044,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਗੁਪਤਾ ਗੁਰਮੁਖਿ ਮੁਕਤਾ ॥",
          "roman": "ghaṭ ghaṭ gupatā gurmukh muktā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ответ: Тот, кто присутствует в каждом теле, скрыт; человек, идущий путём Гуру, свободен от уз майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40045,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਸਬਦਿ ਸੁ ਜੁਗਤਾ ॥",
          "roman": "antar bāhar sabad su jugtā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто соединён с гур-шабдом, соединён с Господом и внутри, и снаружи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40046,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਬਿਨਸੈ ਆਵੈ ਜਾਇ ॥",
          "roman": "manmukh binsē āvē jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх гибнет и продолжает приходить и уходить, рождаясь и умирая."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40047,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਸਾਚਿ ਸਮਾਇ ॥੧੩॥",
          "roman": "nanak gurmukh sāch samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, гурмукх пребывает слитым с вечной Истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40048,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਬਾਧਾ ਸਰਪਨਿ ਖਾਧਾ ॥",
          "roman": "kioṅ kar bādhā sarpan khādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вопрос: как это существо оказалось связанным так, что змея-майя пожирает его?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40049,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਖੋਇਆ ਕਿਉ ਕਰਿ ਲਾਧਾ ॥",
          "roman": "kioṅ kar khoiā kioṅ kar lādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как оно потеряло пользу жизни, и как может вновь её обрести?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40050,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਨਿਰਮਲੁ ਕਿਉ ਕਰਿ ਅੰਧਿਆਰਾ ॥",
          "roman": "kioṅ kar nirmal kioṅ kar andhiārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как оно может стать чистым, и как перед ним держится тьма?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40051,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਤਤੁ ਬੀਚਾਰੈ ਸੁ ਗੁਰੂ ਹਮਾਰਾ ॥੧੪॥",
          "roman": "ih tat bīchārē su gurū hamārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто верно рассмотрит эту сущность, того мы признаем своим Гуру и склонимся перед ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3414,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40052,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਬਾਧਾ ਸਰਪਨਿ ਖਾਧਾ ॥",
          "roman": "durmat bādhā sarpan khādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ответ: он связан дурным пониманием, и змея-майя пожирает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40053,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਖੋਇਆ ਗੁਰਮੁਖਿ ਲਾਧਾ ॥",
          "roman": "manmukh khoiā gurmukh lādhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх потерял пользу жизни; гурмукх её обрёл."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40054,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਮਿਲੈ ਅੰਧੇਰਾ ਜਾਇ ॥",
          "roman": "satigur milē andhērā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда встречается Сатгуру, тьма уходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40055,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਉਮੈ ਮੇਟਿ ਸਮਾਇ ॥੧੫॥",
          "roman": "nanak haumē mēṭ samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, лишь стерев Хоумэ, человек сливается с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40056,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਨਿਰੰਤਰਿ ਦੀਜੈ ਬੰਧੁ ॥",
          "roman": "sunn nirantar dījē bandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если поставить непрерывную, нерушимую преграду памяти безмолвного, ниргунного Господа против нападений майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40057,
          "is_rahao": false,
          "gurmukhi": "ਉਡੈ ਨ ਹੰਸਾ ਪੜੈ ਨ ਕੰਧੁ ॥",
          "roman": "uḍē na haṅsā paṛē na kandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда ум-лебедь не блуждает, и стена тела не рушится, то есть сила тела не разрушается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40058,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਗੁਫਾ ਘਰੁ ਜਾਣੈ ਸਾਚਾ ॥",
          "roman": "sahaj gufā ghar jāṇē sāchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто считает пещеру сахаджа своим истинным постоянным домом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40059,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਚੇ ਭਾਵੈ ਸਾਚਾ ॥੧੬॥",
          "roman": "nanak sāchē bhāvē sāchā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "о Нанак, тот, став образом Истинного, начинает быть угодным Истинному Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3415,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40060,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੁ ਕਾਰਣਿ ਗ੍ਰਿਹੁ ਤਜਿਓ ਉਦਾਸੀ ॥",
          "roman": "kis kāraṇ grih tajio udāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вопрос: если не следует оставлять мирские дела, то ради чего ты оставил дом и стал удаси?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40061,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੁ ਕਾਰਣਿ ਇਹੁ ਭੇਖੁ ਨਿਵਾਸੀ ॥",
          "roman": "kis kāraṇ ih bhēkh nivāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ради чего ты принял это обличье удаси?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40062,
          "is_rahao": false,
          "gurmukhi": "ਕਿਸੁ ਵਖਰ ਕੇ ਤੁਮ ਵਣਜਾਰੇ ॥",
          "roman": "kis vakhar kē tum vaṇjārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Торговцами какого товара вы являетесь?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40063,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਸਾਥੁ ਲੰਘਾਵਹੁ ਪਾਰੇ ॥੧੭॥",
          "roman": "kioṅ kar sāth laṅghāvahu pārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каким способом вы переправите свою общину через труднопроходимый океан мира?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40064,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਖੋਜਤ ਭਏ ਉਦਾਸੀ ॥",
          "roman": "gurmukh khojat bhaē udāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ответ: мы стали удаси, чтобы искать гурмукхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40065,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨ ਕੈ ਤਾਈ ਭੇਖ ਨਿਵਾਸੀ ॥",
          "roman": "darsan kē tāī bhēkh nivāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы приняли это обличье ради даршана гурмукхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40066,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਵਖਰ ਕੇ ਹਮ ਵਣਜਾਰੇ ॥",
          "roman": "sāch vakhar kē ham vaṇjārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы — торговцы товаром Истинного Имени Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40067,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਉਤਰਸਿ ਪਾਰੇ ॥੧੮॥",
          "roman": "nanak gurmukh utaras pārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто идёт путём Гуру, переправится на другой берег."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3416,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40068,
          "is_rahao": false,
          "gurmukhi": "ਕਿਤੁ ਬਿਧਿ ਪੁਰਖਾ ਜਨਮੁ ਵਟਾਇਆ ॥",
          "roman": "kit bidh purakhā janam vaṭāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вопрос: о Пурукх, каким способом ты изменил свою жизнь?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40069,
          "is_rahao": false,
          "gurmukhi": "ਕਾਹੇ ਕਉ ਤੁਝੁ ਇਹੁ ਮਨੁ ਲਾਇਆ ॥",
          "roman": "kāhē kau tujh ih man lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "С чем ты соединил этот свой ум?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
