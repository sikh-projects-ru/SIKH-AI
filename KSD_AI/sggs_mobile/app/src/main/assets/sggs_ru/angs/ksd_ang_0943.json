{
  "ang": 943,
  "shabads": [
    {
      "shabad_id": 3428,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40218,
          "is_rahao": false,
          "gurmukhi": "ਪਵਨ ਅਰੰਭੁ ਸਤਿਗੁਰ ਮਤਿ ਵੇਲਾ ॥",
          "roman": "pavan araṃbh satigur mat velā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Праны — начало существования; это время человеческого рождения предназначено для принятия наставления Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40219,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਗੁਰੂ ਸੁਰਤਿ ਧੁਨਿ ਚੇਲਾ ॥",
          "roman": "sabad gurū surat dhun chelā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шабад — мой Гуру, а устойчивое сосредоточение моей сурти — ученик этого Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40220,
          "is_rahao": false,
          "gurmukhi": "ਅਕਥ ਕਥਾ ਲੇ ਰਹਉ ਨਿਰਾਲਾ ॥",
          "roman": "akath kathā le rahau nirālā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества неописуемого Прабху, я остаюсь непривязанным к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40221,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੁਗਿ ਜੁਗਿ ਗੁਰ ਗੋਪਾਲਾ ॥",
          "roman": "nānak jug jug gur gopālā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, этот Гур-Гопал пребывает во всякую эпоху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40222,
          "is_rahao": false,
          "gurmukhi": "ਏਕੁ ਸਬਦੁ ਜਿਤੁ ਕਥਾ ਵੀਚਾਰੀ ॥",
          "roman": "ek sabad jit kathā vīchārī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только через единый Гур-шабад можно размышлять о качествах Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40223,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਹਉਮੈ ਅਗਨਿ ਨਿਵਾਰੀ ॥੪੪॥",
          "roman": "gurmukh haumē agan nivārī. ||44||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через этот Шабад гурмукх устраняет изнутри огонь Хоумэ, эгоистической самости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3429,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40224,
          "is_rahao": false,
          "gurmukhi": "ਮੈਣ ਕੇ ਦੰਤ ਕਿਉ ਖਾਈਐ ਸਾਰੁ ॥",
          "roman": "mēṇ ke daṃt kiu khāīē sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как можно восковыми зубами есть железо?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40225,
          "is_rahao": false,
          "gurmukhi": "ਜਿਤੁ ਗਰਬੁ ਜਾਇ ਸੁ ਕਵਣੁ ਆਹਾਰੁ ॥",
          "roman": "jit garab jāe so kavaṇ āhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какая это пища, посредством которой уходит гордость ума?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40226,
          "is_rahao": false,
          "gurmukhi": "ਹਿਵੈ ਕਾ ਘਰੁ ਮੰਦਰੁ ਅਗਨਿ ਪਿਰਾਹਨੁ ॥",
          "roman": "hivē kā ghar mandar agan pirāhan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если есть ледяной дворец и на нём одежда из огня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40227,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਗੁਫਾ ਜਿਤੁ ਰਹੈ ਅਵਾਹਨੁ ॥",
          "roman": "kavan gufā jit rahē avāhan.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то в какой пещере его сохранить, чтобы он оставался неподвижным?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40228,
          "is_rahao": false,
          "gurmukhi": "ਇਤ ਉਤ ਕਿਸ ਕਉ ਜਾਣਿ ਸਮਾਵੈ ॥",
          "roman": "it ut kis kau jāṇ samāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого познав здесь и там, всюду, этот ум может быть погружён в Него?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40229,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਧਿਆਨੁ ਮਨੁ ਮਨਹਿ ਸਮਾਵੈ ॥੪੫॥",
          "roman": "kavan dhiān man maneh samāvē. ||45||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какое устойчивое созерцание удерживает ум внутри самого себя, чтобы он не блуждал вовне?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40230,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਹਉ ਮੈ ਮੈ ਵਿਚਹੁ ਖੋਵੈ ॥",
          "roman": "hau hau mē mē vichah khovē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обращён к Гуру, устраняет изнутри самость и эгоистическое «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40231,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜਾ ਮੇਟੈ ਏਕੋ ਹੋਵੈ ॥",
          "roman": "dūjā meṭē eko hovē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он стирает двойственность, различение «моё-твоё», и входит в единство со всеми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40232,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਕਰੜਾ ਮਨਮੁਖੁ ਗਾਵਾਰੁ ॥",
          "roman": "jag karaṛā manmukh gāvār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для неразумного манмукха, идущего за умом, мир суров, а жизнь становится кладезем страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40233,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਕਮਾਈਐ ਖਾਈਐ ਸਾਰੁ ॥",
          "roman": "sabad kamāīai khāīai sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это железо можно съесть лишь тогда, когда практикуешь Шабад, то есть живёшь по повелению Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40234,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਏਕੋ ਜਾਣੈ ॥",
          "roman": "aṃtar bāhar eko jāṇē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек внутри себя и вовне, во всём мире, видит присутствие одного Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40235,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਗਨਿ ਮਰੈ ਸਤਿਗੁਰ ਕੈ ਭਾਣੈ ॥੪੬॥",
          "roman": "nānak agan marē satigur kē bhāṇē. ||46||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, огонь его жажды угасает, когда он следует воле Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3430,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40236,
          "is_rahao": false,
          "gurmukhi": "ਸਚ ਭੈ ਰਾਤਾ ਗਰਬੁ ਨਿਵਾਰੈ ॥",
          "roman": "sach bhē rātā garab nivārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто пропитан страхом перед вечно пребывающим Прабху, устраняет гордость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40237,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਜਾਤਾ ਸਬਦੁ ਵੀਚਾਰੈ ॥",
          "roman": "eko jātā sabad vīchārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Размышляя над Шабадом Сатгуру, он познаёт Единого Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40238,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਵਸੈ ਸਚੁ ਅੰਤਰਿ ਹੀਆ ॥",
          "roman": "sabad vasē sach aṃtar hīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Шабад Гуру живёт в сердце человека, в его сердце пребывает сам истинный Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40239,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਸੀਤਲੁ ਰੰਗਿ ਰੰਗੀਆ ॥",
          "roman": "tan man sītal raṅg raṅgīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Окрашенный любовью Прабху, его тело и ум становятся прохладными и умиротворёнными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40240,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਬਿਖੁ ਅਗਨਿ ਨਿਵਾਰੇ ॥",
          "roman": "kām krodh bikh agan nivāre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он устраняет изнутри яд похоти и гнева, а также огонь жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40241,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਦਰੀ ਨਦਰਿ ਪਿਆਰੇ ॥੪੭॥",
          "roman": "nānak nadrī nadar piāre. ||47||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой человек пребывает под взглядом милостивого, любимого Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40242,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਮੁਖਿ ਚੰਦੁ ਹਿਵੈ ਘਰੁ ਛਾਇਆ ॥",
          "roman": "kavan mukh chaṃd hivē ghar chhāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каким способом в уме может удержаться луна, дом прохлады, то есть постоянная внутренняя тишина?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40243,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਮੁਖਿ ਸੂਰਜੁ ਤਪੈ ਤਪਾਇਆ ॥",
          "roman": "kavan mukh sūraj tapē tapāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каким способом в уме может постоянно сиять солнце знания?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40244,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਮੁਖਿ ਕਾਲੁ ਜੋਹਤ ਨਿਤ ਰਹੈ ॥",
          "roman": "kavan mukh kāl johat nit rahē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каким способом смерть перестаёт постоянно подстерегать, то есть исчезает непрерывный страх смерти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40245,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨ ਬੁਧਿ ਗੁਰਮੁਖਿ ਪਤਿ ਰਹੈ ॥",
          "roman": "kavan budh gurmukh pat rahē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Какая мудрость сохраняет честь гурмукха?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40246,
          "is_rahao": false,
          "gurmukhi": "ਕਵਨੁ ਜੋਧੁ ਜੋ ਕਾਲੁ ਸੰਘਾਰੈ ॥",
          "roman": "kavan jodh jo kāl saṅghārē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто тот воин, который побеждает смерть, то есть страх смерти?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40247,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਬਾਣੀ ਨਾਨਕੁ ਬੀਚਾਰੈ ॥੪੮॥",
          "roman": "bolē bāṇī nānak bīchārē. ||48||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит это как слово размышления в ходе этой Гост."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3431,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40248,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੁ ਭਾਖਤ ਸਸਿ ਜੋਤਿ ਅਪਾਰਾ ॥",
          "roman": "sabad bhākhat sas jot apārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда произносится Шабад Сатгуру, в сердце раскрывается безмерный свет луны, то есть рождается мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40249,
          "is_rahao": false,
          "gurmukhi": "ਸਸਿ ਘਰਿ ਸੂਰੁ ਵਸੈ ਮਿਟੈ ਅੰਧਿਆਰਾ ॥",
          "roman": "sas ghar sūr vasē miṭē aṃdhiārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В доме луны поселяется солнце знания, и тьма неведения исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40250,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਦੁਖੁ ਸਮ ਕਰਿ ਨਾਮੁ ਅਧਾਰਾ ॥",
          "roman": "sukh dukh sam kar nām adhārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гурмукх считает радость и страдание одинаковыми и делает Naam опорой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40251,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਪਾਰਿ ਉਤਾਰਣਹਾਰਾ ॥",
          "roman": "āpe pār utāraṇhārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда Прабху, сам Переправляющий, сам переносит его через труднопроходимый океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40252,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਚੈ ਮਨੁ ਸਾਚਿ ਸਮਾਇ ॥",
          "roman": "gur parchē man sāch samāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через глубокую связь с Сатгуру ум гурмукха остаётся погружённым в истинного Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40253,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਣਵਤਿ ਨਾਨਕੁ ਕਾਲੁ ਨ ਖਾਇ ॥੪੯॥",
          "roman": "praṇavat nānak kāl na khāi. ||49||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак смиренно говорит: такого человека не поглощает страх смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40254,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਤਤੁ ਸਭ ਹੀ ਸਿਰਿ ਜਾਪੈ ॥",
          "roman": "nām tat sabh hī sir jāpē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Осознание истины Naam в сердце — высшее из всех повторений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40255,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਦੁਖੁ ਕਾਲੁ ਸੰਤਾਪੈ ॥",
          "roman": "bin nāvē dukh kāl saṃtāpē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Naam человека мучат страдания, и страх смерти причиняет боль."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40256,
          "is_rahao": false,
          "gurmukhi": "ਤਤੋ ਤਤੁ ਮਿਲੈ ਮਨੁ ਮਾਨੈ ॥",
          "roman": "tato tat milē man mānē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда в сердце раскрывается чистая истина Naam, ум удовлетворяется этой истиной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40257,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜਾ ਜਾਇ ਇਕਤੁ ਘਰਿ ਆਨੈ ॥",
          "roman": "dūjā jāi ikat ghar ānē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Двойственный, разделяющий нрав уходит, и человек приходит в дом единства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40258,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਪਵਨਾ ਗਗਨੁ ਗਰਜੈ ॥",
          "roman": "bolē pavanā gagan garjē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поднимается волна божественной жизни, и состояние встречи с Прабху становится сильным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40259,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਿਹਚਲੁ ਮਿਲਣੁ ਸਹਜੈ ॥੫੦॥",
          "roman": "nānak nihchal milaṇ sahjē. ||50||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, пребывая в состоянии сахадж, соединение души с Прабху становится прочным навсегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3432,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40260,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਸੁੰਨੰ ਬਾਹਰਿ ਸੁੰਨੰ ਤ੍ਰਿਭਵਣ ਸੁੰਨ ਮਸੁੰਨੰ ॥",
          "roman": "aṃtar suṃnaṃ bāhar suṃnaṃ tribhavaṇ suṃn masuṃnaṃ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри и вовне, во всей трилоки, повсюду пребывает только тот Прабху, в котором не поднимаются майические побуждения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40261,
          "is_rahao": false,
          "gurmukhi": "ਚਉਥੇ ਸੁੰਨੈ ਜੋ ਨਰੁ ਜਾਣੈ ਤਾ ਕਉ ਪਾਪੁ ਨ ਪੁੰਨੰ ॥",
          "roman": "chauthe suṃnē jo nar jāṇē tā kau pāp na puṃnaṃ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кто истинно познаёт Прабху, стоящего выше влияния трёхгунной майи, не затрагивают ни грех, ни заслуга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40262,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸੁੰਨ ਕਾ ਜਾਣੈ ਭੇਉ ॥ ਆਦਿ ਪੁਰਖੁ ਨਿਰੰਜਨ ਦੇਉ ॥",
          "roman": "ghaṭ ghaṭ suṃn kā jāṇē bheu. ād purakh nirañjan deu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто постигает тайну ниргун-Прабху, присутствующего в каждом сердце и вместе с тем непривязанного, тот становится образом изначального, незапятнанного Прабху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40263,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨੁ ਨਾਮ ਨਿਰੰਜਨ ਰਾਤਾ ॥",
          "roman": "jo jan nām nirañjan rātā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который опьянён Naam незапятнанного, свободного от майи Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40264,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋਈ ਪੁਰਖੁ ਬਿਧਾਤਾ ॥੫੧॥",
          "roman": "nānak soī purakh bidhātā. ||51||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "о Нанак, становится образом самого Прабху-Создателя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40265,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨੋ ਸੁੰਨੁ ਕਹੈ ਸਭੁ ਕੋਈ ॥",
          "roman": "suṃno suṃn kahē sabh koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый говорит об афур-авастхе, состоянии без майических побуждений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40266,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਤ ਸੁੰਨੁ ਕਹਾ ਤੇ ਹੋਈ ॥",
          "roman": "anhat suṃn kahā te hoī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но редкий знает на практике, как возникает неизменная афур-авастха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40267,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਤ ਸੁੰਨਿ ਰਤੇ ਸੇ ਕੈਸੇ ॥",
          "roman": "anhat suṃn rate se kēse.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если спросить, каковы люди, соединённые с этой афур-авастхой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40268,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਤੇ ਉਪਜੇ ਤਿਸ ਹੀ ਜੈਸੇ ॥",
          "roman": "jis te upje tis hī jēse.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то ответ таков: они становятся подобны той Параматме, из которой произошли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40269,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਜਨਮਿ ਨ ਮਰਹਿ ਨ ਆਵਹਿ ਜਾਹਿ ॥",
          "roman": "oi janam na mareh na āveh jāh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они уже не рождаются и не умирают; круг их прихода и ухода заканчивается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40270,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਮਨੁ ਸਮਝਾਹਿ ॥੫੨॥",
          "roman": "nānak gurmukh man samjhāh. ||52||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это те, кто, идя по повелению Гуру, направляет ум к доброму пониманию."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3433,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40271,
          "is_rahao": false,
          "gurmukhi": "ਨਉ ਸਰ ਸੁਭਰ ਦਸਵੈ ਪੂਰੇ ॥",
          "roman": "nau sar subhar dasvē pūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда девять врат, подобные полным водоёмам, прекращают свои внешние потоки и входят в десятое озеро, состояние встречи с Прабху,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40272,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਅਨਹਤ ਸੁੰਨ ਵਜਾਵਹਿ ਤੂਰੇ ॥",
          "roman": "tah anhat suṃn vajāvah tūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "там гурмукхи играют трубы неизменной афур-авастхи, и никакая иная мысль не может войти внутрь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40273,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੈ ਰਾਚੇ ਦੇਖਿ ਹਜੂਰੇ ॥",
          "roman": "sāchē rāche dekh hajūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этом состоянии они видят вечно пребывающего Прабху рядом с собой и остаются погружёнными в Него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40274,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਸਾਚੁ ਰਹਿਆ ਭਰਪੂਰੇ ॥",
          "roman": "ghaṭ ghaṭ sāch rahiā bharpūre.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они видят истинного Прабху наполненно пребывающим в каждом сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
