{
  "ang": 944,
  "shabads": [
    {
      "shabad_id": 3433,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40275,
          "is_rahao": false,
          "gurmukhi": "ਗੁਪਤੀ ਬਾਣੀ ਪਰਗਟੁ ਹੋਇ ॥",
          "roman": "guptī bāṇī pargaṭ hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сокрытая Бани становится явной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40276,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਰਖਿ ਲਏ ਸਚੁ ਸੋਇ ॥੫੩॥",
          "roman": "nānak parakh laē sach soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: распознав, человек постигает того Истинного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40277,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜ ਭਾਇ ਮਿਲੀਐ ਸੁਖੁ ਹੋਵੈ ॥",
          "roman": "sahaj bhāe milīē sukh hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если, пребывая в устойчивой सहजности, соединиться с Господом, приходит полный покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40278,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਾਗੈ ਨੀਦ ਨ ਸੋਵੈ ॥",
          "roman": "gurmukh jāgē nīd na sovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт по воле Гуру, остаётся пробуждённым и не спит сном майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40279,
          "is_rahao": false,
          "gurmukhi": "ਸੁੰਨ ਸਬਦੁ ਅਪਰੰਪਰਿ ਧਾਰੈ ॥",
          "roman": "sunn sabad aprampar dhārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бани хвалы нергунного Господа удерживает его в бесконечном Господе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40280,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤੇ ਮੁਕਤੁ ਸਬਦਿ ਨਿਸਤਾਰੈ ॥",
          "roman": "kahtē mukat sabad nistārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Произнося эту Бани, гурмукх освобождается от Хоумэ и через Шабад освобождает других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40281,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਦੀਖਿਆ ਸੇ ਸਚਿ ਰਾਤੇ ॥",
          "roman": "gur kī dīkhiā sē sach rātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто приняли наставление Гуру, окрашены в Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40282,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਆਪੁ ਗਵਾਇ ਮਿਲਣ ਨਹੀ ਭ੍ਰਾਤੇ ॥੫੪॥",
          "roman": "nānak āp gavāe milaṇ nahī bhrātē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: утратив чувство самости, они соединяются с Господом, и блуждание ума исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3434,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40283,
          "is_rahao": false,
          "gurmukhi": "ਕੁਬੁਧਿ ਚਵਾਵੈ ਸੋ ਕਿਤੁ ਠਾਇ ॥",
          "roman": "kubudh chavāvē so kit ṭhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Где может случиться так, чтобы человек устранил свою дурную мысль?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40284,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਤਤੁ ਨ ਬੂਝੈ ਚੋਟਾ ਖਾਇ ॥",
          "roman": "kiu tat na būjhē choṭā khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Почему человек не понимает сущности и продолжает получать удары страдания?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40285,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਦਰਿ ਬਾਧੇ ਕੋਇ ਨ ਰਾਖੈ ॥",
          "roman": "jam dar bādhē koi na rākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда он связан у двери Джама, никто не может ему помочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40286,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਸਬਦੈ ਨਾਹੀ ਪਤਿ ਸਾਖੈ ॥",
          "roman": "bin sabdē nāhī pat sākhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Шабада Сатгуру у него нигде нет ни чести, ни доверия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40287,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਬੂਝੈ ਪਾਵੈ ਪਾਰੁ ॥",
          "roman": "kiu kar būjhē pāvē pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как ему понять и достичь дальнего берега труднопроходимого океана?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40288,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਨਮੁਖਿ ਨ ਬੁਝੈ ਗਵਾਰੁ ॥੫੫॥",
          "roman": "nānak manmukh na bujhē gavār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: глупый манмукх не понимает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40289,
          "is_rahao": false,
          "gurmukhi": "ਕੁਬੁਧਿ ਮਿਟੈ ਗੁਰ ਸਬਦੁ ਬੀਚਾਰਿ ॥",
          "roman": "kubudh miṭē gur sabad bīchār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дурная мысль исчезает, когда человек размышляет над Шабадом Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40290,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਭੇਟੈ ਮੋਖ ਦੁਆਰ ॥",
          "roman": "satgur bhēṭē mokh duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда встречается Сатгуру, открывается путь освобождения от этой дурной мысли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40291,
          "is_rahao": false,
          "gurmukhi": "ਤਤੁ ਨ ਚੀਨੈ ਮਨਮੁਖੁ ਜਲਿ ਜਾਇ ॥",
          "roman": "tat na chīnē manmukh jal jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх не распознаёт сущности и сгорает в пороках."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40292,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਮਤਿ ਵਿਛੁੜਿ ਚੋਟਾ ਖਾਇ ॥",
          "roman": "durmat vichhuṛ choṭā khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за дурного разума, отделившись от Господа, он страдает и получает удары."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40293,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨੈ ਹੁਕਮੁ ਸਭੇ ਗੁਣ ਗਿਆਨ ॥",
          "roman": "mānē hukam sabhē guṇ giān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто принимает повеление Гуру, обретает все добродетели и полное понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40294,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਗਹ ਪਾਵੈ ਮਾਨੁ ॥੫੬॥",
          "roman": "nānak dargah pāvē mān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: такой человек получает почёт в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3435,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40295,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚੁ ਵਖਰੁ ਧਨੁ ਪਲੈ ਹੋਇ ॥",
          "roman": "sāch vakhar dhan palē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У кого в руках есть истинный товар, богатство Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40296,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਤਰੈ ਤਾਰੇ ਭੀ ਸੋਇ ॥",
          "roman": "āp tarē tārē bhī soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тот сам переправляется через трудный океан и переправляет других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40297,
          "is_rahao": false,
          "gurmukhi": "ਸਹਜਿ ਰਤਾ ਬੂਝੈ ਪਤਿ ਹੋਇ ॥",
          "roman": "sahaj ratā būjhē pat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая опьянённым устойчивой सहजностью, он понимает сущность и получает честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40298,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਰੈ ਨ ਕੋਇ ॥",
          "roman": "tā kī kīmat karē na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто не может определить ценность такого человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40299,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਦੇਖਾ ਤਹ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "jah dēkhā tah rahiā samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Куда бы он ни смотрел, он видит Господа, пребывающего повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40300,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਰਿ ਪਰੈ ਸਚ ਭਾਇ ॥੫੭॥",
          "roman": "nānak pār parē sach bhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: живя в воле Истинного, он переходит на дальний берег."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40301,
          "is_rahao": false,
          "gurmukhi": "ਸੁ ਸਬਦ ਕਾ ਕਹਾ ਵਾਸੁ ਕਥੀਅਲੇ ਜਿਤੁ ਤਰੀਐ ਭਵਜਲੁ ਸੰਸਾਰੋ ॥",
          "roman": "su sabad kā kahā vās kathīalē jit tarīai bhavjal sansāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Где можно назвать обитель того Шабада, через который переправляются через океан мира?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40302,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਸਤ ਅੰਗੁਲ ਵਾਈ ਕਹੀਐ ਤਿਸੁ ਕਹੁ ਕਵਨੁ ਅਧਾਰੋ ॥",
          "roman": "trē sat angul vāī kahīē tis kah kavan adhāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прана, говорят, имеет меру в десять пальцев; скажите, на что она опирается?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40303,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਖੇਲੈ ਅਸਥਿਰੁ ਹੋਵੈ ਕਿਉ ਕਰਿ ਅਲਖੁ ਲਖਾਏ ॥",
          "roman": "bolē khēlē asthir hovē kiu kar alakh lakhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как живатма, которая говорит и играет в теле, может стать навсегда устойчивой и как увидеть Невидимого?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40304,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਸੁਆਮੀ ਸਚੁ ਨਾਨਕੁ ਪ੍ਰਣਵੈ ਅਪਣੇ ਮਨ ਸਮਝਾਏ ॥",
          "roman": "suṇ suāmī sach nānak praṇavē apṇē man samjhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о Свами, услышав истину, как человек может направить свой ум к верному пониманию?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40305,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਬਦੇ ਸਚਿ ਲਿਵ ਲਾਗੈ ਕਰਿ ਨਦਰੀ ਮੇਲਿ ਮਿਲਾਏ ॥",
          "roman": "gurmukh sabdē sach liv lāgē kar nadrī mēl milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт по воле Гуру, через Шабад соединяет свою любовь с Истинным, и Господь милостивым взглядом соединяет его с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40306,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਦਾਨਾ ਆਪੇ ਬੀਨਾ ਪੂਰੈ ਭਾਗਿ ਸਮਾਏ ॥੫੮॥",
          "roman": "āpē dānā āpē bīnā pūrē bhāg samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Сам знает сердце и Сам распознаёт; по высокой судьбе гурмукх пребывает в Нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3436,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40307,
          "is_rahao": false,
          "gurmukhi": "ਸੁ ਸਬਦ ਕਉ ਨਿਰੰਤਰਿ ਵਾਸੁ ਅਲਖੰ ਜਹ ਦੇਖਾ ਤਹ ਸੋਈ ॥",
          "roman": "su sabad kau nirantar vās alakhã jah dēkhā tah soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Шабад имеет непрерывное обитание повсюду; он есть форма Невидимого, и куда я ни смотрю, везде он."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40308,
          "is_rahao": false,
          "gurmukhi": "ਪਵਨ ਕਾ ਵਾਸਾ ਸੁੰਨ ਨਿਵਾਸਾ ਅਕਲ ਕਲਾ ਧਰ ਸੋਈ ॥",
          "roman": "pavan kā vāsā sunn nivāsā akal kalā dhar soī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как обитание безмолвного Господа повсюду, так и обитание Шабада повсюду; Шабад есть тот же совершенный Владыка силы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40309,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਸਬਦੁ ਘਟ ਮਹਿ ਵਸੈ ਵਿਚਹੁ ਭਰਮੁ ਗਵਾਏ ॥",
          "roman": "nadar karē sabad ghaṭ mah vasē vichah bharam gavāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господь дарует милостивый взгляд, Шабад поселяется в сердце, и человек устраняет изнутри заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40310,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਨਿਰਮਲੁ ਨਿਰਮਲ ਬਾਣੀ ਨਾਮੋੁ ਮੰਨਿ ਵਸਾਏ ॥",
          "roman": "tan man nirmal nirmal bāṇī nāmo mann vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его тело, ум и речь становятся чистыми, и он держит в своём уме только Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40311,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦਿ ਗੁਰੂ ਭਵਸਾਗਰੁ ਤਰੀਐ ਇਤ ਉਤ ਏਕੋ ਜਾਣੈ ॥",
          "roman": "sabad gurū bhavsāgar tarīē it ut ēko jāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Шабад Сатгуру переправляются через океан мира; переправившийся знает Единого Господа и здесь, и там."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40312,
          "is_rahao": false,
          "gurmukhi": "ਚਿਹਨੁ ਵਰਨੁ ਨਹੀ ਛਾਇਆ ਮਾਇਆ ਨਾਨਕ ਸਬਦੁ ਪਛਾਣੈ ॥੫੯॥",
          "roman": "chihan varan nahī chhāiā māiā nānak sabad pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: тот, кто распознаёт Шабад и входит с ним в глубокую связь, выходит из-под влияния майи, и его отдельный знак и цвет исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40313,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਸਤ ਅੰਗੁਲ ਵਾਈ ਅਉਧੂ ਸੁੰਨ ਸਚੁ ਆਹਾਰੋ ॥",
          "roman": "trē sat angul vāī audhū sunn sach āhāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О йог, пища и опора пран, мерою в десять пальцев, — безмолвный Истинный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40314,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਬੋਲੈ ਤਤੁ ਬਿਰੋਲੈ ਚੀਨੈ ਅਲਖ ਅਪਾਰੋ ॥",
          "roman": "gurmukh bolē tat birolē chīnē alakh apāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идя по воле Гуру и повторяя Имя с каждым дыханием, человек добывает сущность и распознаёт Невидимого, бесконечного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40315,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰੈ ਗੁਣ ਮੇਟੈ ਸਬਦੁ ਵਸਾਏ ਤਾ ਮਨਿ ਚੂਕੈ ਅਹੰਕਾਰੋ ॥",
          "roman": "trē guṇ mēṭē sabad vasāe tā man chūkē ahaṅkāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек поселяeт Шабад в сердце и стирает влияние трёх гун майи, тогда из его ума исчезает эго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40316,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਏਕੋ ਜਾਣੈ ਤਾ ਹਰਿ ਨਾਮਿ ਲਗੈ ਪਿਆਰੋ ॥",
          "roman": "antar bāhar ēko jāṇē tā har nām lagē piāro",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда он познаёт Единого внутри себя и вовне, тогда его любовь обращается к Имени Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40317,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖਮਨਾ ਇੜਾ ਪਿੰਗੁਲਾ ਬੂਝੈ ਜਾ ਆਪੇ ਅਲਖੁ ਲਖਾਏ ॥",
          "roman": "sukhmana iṛā pingulā būjhē jā āpē alakh lakhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Невидимый Сам даёт Себя понять, гурмукх понимает Иру, Пингалу и Сукхману."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40318,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਹੁ ਤੇ ਊਪਰਿ ਸਾਚਾ ਸਤਿਗੁਰ ਸਬਦਿ ਸਮਾਏ ॥੬੦॥",
          "roman": "nānak tih tē ūpar sāchā satgur sabad samāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: Истинный Господь выше этих трёх практик, и в Него погружаются только через Шабад Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3437,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40319,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਜੀਉ ਪਵਨੁ ਕਥੀਅਲੇ ਪਵਨੁ ਕਹਾ ਰਸੁ ਖਾਈ ॥",
          "roman": "man kā jīu pavan kathīalē pavan kahā ras khāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Опорой ума называют праны; откуда праны получают свою пищу?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40320,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨ ਕੀ ਮੁਦ੍ਰਾ ਕਵਨ ਅਉਧੂ ਸਿਧ ਕੀ ਕਵਨ ਕਮਾਈ ॥",
          "roman": "giān kī mudrā kavan audhū sidh kī kavan kamāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О йог, какое средство ведёт к знанию, и что получает йог, достигший успеха в йогических практиках?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
