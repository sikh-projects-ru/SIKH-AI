{
  "ang": 947,
  "shabads": [
    {
      "shabad_id": 3443,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40397,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satigur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40398,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਕੀ ਵਾਰ ਮਹਲਾ ੩ ॥",
          "roman": "rāmkalī kī vār mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вар в раге Рамкали, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40399,
          "is_rahao": false,
          "gurmukhi": "ਜੋਧੈ ਵੀਰੈ ਪੂਰਬਾਣੀ ਕੀ ਧੁਨੀ ॥",
          "roman": "jodhē vīrē pūrabāṇī kī dhunī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури этой Вари следует петь на ту же мелодию, на которую пелись паури Вари о Джодхе и Вире, сыновьях Пурабана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3444,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40400,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40401,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰੁ ਸਹਜੈ ਦਾ ਖੇਤੁ ਹੈ ਜਿਸ ਨੋ ਲਾਏ ਭਾਉ ॥",
          "roman": "satigur sahjē dā khēt hē jis no lāē bhāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру — поле устойчивости и покоя; кому Господь дарует любовь к этому полю Сатгуру, тот сам тоже становится полем сахаджа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40402,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਬੀਜੇ ਨਾਉ ਉਗਵੈ ਨਾਮੇ ਰਹੈ ਸਮਾਇ ॥",
          "roman": "nāu bījē nāu ugvē nāmē rahē samāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сеет в этом поле Имя Господа; там вырастает Имя, и такой человек остаётся утверждённым в Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40403,
          "is_rahao": false,
          "gurmukhi": "ਹਉਮੈ ਏਹੋ ਬੀਜੁ ਹੈ ਸਹਸਾ ਗਇਆ ਵਿਲਾਇ ॥",
          "roman": "haumē ēho bīj hē sahsā gaē vilāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хоумэ — корень сомнений; но в таком человеке Хоумэ нет, поэтому сомнение, рождаемое ею, уходит прочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40404,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕਿਛੁ ਬੀਜੇ ਨ ਉਗਵੈ ਜੋ ਬਖਸੇ ਸੋ ਖਾਇ ॥",
          "roman": "nā kichh bījē na ugvē jo bakhsē so khāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не сеет такого семени, и там не вырастает сомнение; он вкушает плод милости, дарованной Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40405,
          "is_rahao": false,
          "gurmukhi": "ਅੰਭੈ ਸੇਤੀ ਅੰਭੁ ਰਲਿਆ ਬਹੁੜਿ ਨ ਨਿਕਸਿਆ ਜਾਇ ॥",
          "roman": "ambhē sētī ambh raliā bahuṛ na niksiā jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как вода, смешавшись с водой, уже не может быть отделена, таково состояние человека, который идёт по воле Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40406,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਚਲਤੁ ਹੈ ਵੇਖਹੁ ਲੋਕਾ ਆਇ ॥",
          "roman": "nānak gurmukh chalat hē vēkhah lokā āē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это игра человека, обращённого к Гуру; о люди, придите и посмотрите, испытайте это."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40407,
          "is_rahao": false,
          "gurmukhi": "ਲੋਕੁ ਕਿ ਵੇਖੈ ਬਪੁੜਾ ਜਿਸ ਨੋ ਸੋਝੀ ਨਾਹਿ ॥",
          "roman": "lok k vēkhē bapuṛā jis no sojhī nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но что может увидеть бедный мир? У него нет понимания, чтобы это распознать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40408,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਵੇਖਾਲੇ ਸੋ ਵੇਖੈ ਜਿਸੁ ਵਸਿਆ ਮਨ ਮਾਹਿ ॥੧॥",
          "roman": "jis vēkhālē so vēkhē jis vasiā man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Увидеть это может лишь тот, кому Господь сам показывает способ видеть, тот, в чьём уме сам Господь поселился."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3445,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40409,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40410,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖੁ ਦੁਖ ਕਾ ਖੇਤੁ ਹੈ ਦੁਖੁ ਬੀਜੇ ਦੁਖੁ ਖਾਇ ॥",
          "roman": "manmukh dukh kā khēt hē dukh bījē dukh khāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, идущий за своим умом, словно поле страданий: он сеет страдание и пожинает, вкушает страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40411,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਵਿਚਿ ਜੰਮੈ ਦੁਖਿ ਮਰੈ ਹਉਮੈ ਕਰਤ ਵਿਹਾਇ ॥",
          "roman": "dukh vich jammē dukh marē haumē karat vihāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх рождается в страдании и умирает в страдании; вся его жизнь проходит в делании «я, я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40412,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣੁ ਜਾਣੁ ਨ ਸੁਝਈ ਅੰਧਾ ਅੰਧੁ ਕਮਾਇ ॥",
          "roman": "āvaṇ jāṇ na sujhaī andhā andh kamāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он не понимает, что находится в круговороте рождения и смерти; слепой, он продолжает делать дела неведения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40413,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੇਵੈ ਤਿਸੈ ਨ ਜਾਣਈ ਦਿਤੇ ਕਉ ਲਪਟਾਇ ॥",
          "roman": "jo dēvē tisē na jāṇaī ditē kau lapaṭāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Манмукх не узнаёт Владыку, который даёт дары, но цепляется за данные Им вещи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40414,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪੂਰਬਿ ਲਿਖਿਆ ਕਮਾਵਣਾ ਅਵਰੁ ਨ ਕਰਣਾ ਜਾਇ ॥੨॥",
          "roman": "nānak pūrab likhiā kamāvaṇā avar na karṇā jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, человек действует под влиянием того, что по прежним делам отпечатано в уме; иначе поступить он не может."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3446,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40415,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40416,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਮਿਲਿਐ ਸਦਾ ਸੁਖੁ ਜਿਸ ਨੋ ਆਪੇ ਮੇਲੇ ਸੋਇ ॥",
          "roman": "satigur miliai sadā sukh jis no āpē mēlē soē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если встретится Сатгуру, наступает вечный покой; но Гуру встречает тот, кого сам Господь соединяет с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40417,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੈ ਏਹੁ ਬਿਬੇਕੁ ਹੈ ਅੰਤਰੁ ਨਿਰਮਲੁ ਹੋਇ ॥",
          "roman": "sukhē ēh bibēk hē antar nirmal hoē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Признак этого покоя таков: внутреннее существо человека становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40418,
          "is_rahao": false,
          "gurmukhi": "ਅਗਿਆਨ ਕਾ ਭ੍ਰਮੁ ਕਟੀਐ ਗਿਆਨੁ ਪਰਾਪਤਿ ਹੋਇ ॥",
          "roman": "agiān kā bhram kaṭīai giān parāpat hoē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Заблуждение невежества относительно духовной жизни отсекается, и человек получает знание духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40419,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਏਕੋ ਨਦਰੀ ਆਇਆ ਜਹ ਦੇਖਾ ਤਹ ਸੋਇ ॥੩॥",
          "roman": "nānak ēko nadrī āiā jah dēkhā tah soē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, повсюду видится только один Господь; куда ни посмотришь, там Он."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3447,
      "rahao_verse_id": 40426,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40420,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40421,
          "is_rahao": false,
          "gurmukhi": "ਸਚੈ ਤਖਤੁ ਰਚਾਇਆ ਬੈਸਣ ਕਉ ਜਾਂਈ ॥",
          "roman": "sachē takhat rachāiā bēsaṇ kau jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вечно пребывающий Господь создал этот трон в образе мира как место для своего пребывания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40422,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਆਪੇ ਆਪਿ ਹੈ ਗੁਰ ਸਬਦਿ ਸੁਣਾਈ ॥",
          "roman": "sabh kichh āpē āp hē gur sabad suṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этом мире всякая вещь есть Его собственный образ — это открыло Слово Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40423,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕੁਦਰਤਿ ਸਾਜੀਅਨੁ ਕਰਿ ਮਹਲ ਸਰਾਈ ॥",
          "roman": "āpē kudrat sājīan kar mahal sarāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всю эту природу Он сам сотворил; деревья и всё в природе Он словно сделал дворцами и жилищами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40424,
          "is_rahao": false,
          "gurmukhi": "ਚੰਦੁ ਸੂਰਜੁ ਦੁਇ ਚਾਨਣੇ ਪੂਰੀ ਬਣਤ ਬਣਾਈ ॥",
          "roman": "chand sūraj dui chāṇaṇē pūrī baṇat baṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этих дворцах луна и солнце — два светильника; Господь создал всё устройство совершенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40425,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵੇਖੈ ਸੁਣੇ ਆਪਿ ਗੁਰ ਸਬਦਿ ਧਿਆਈ ॥੧॥",
          "roman": "āpē vēkhē suṇē āp gur sabad dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сидя в этом устройстве, Он сам видит и сам слышит; этого Господа можно созерцать через Слово Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40426,
          "is_rahao": true,
          "gurmukhi": "ਵਾਹੁ ਵਾਹੁ ਸਚੇ ਪਾਤਿਸਾਹ ਤੂ ਸਚੀ ਨਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "vāh vāh sachē pātisāh tū sachī nāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О вечно пребывающий Патишах! Ты дивен, Ты дивен; Твоя слава вечно истинна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3448,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40427,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40428,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਮਹਿਦੀ ਕਰਿ ਕੈ ਘਾਲਿਆ ਆਪੁ ਪੀਸਾਇ ਪੀਸਾਇ ॥",
          "roman": "kabīr mahdī kar kē ghāliā āp pīsāē pīsāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, я сделал себя хной и, растирая себя снова и снова, совершал труд-служение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40429,
          "is_rahao": false,
          "gurmukhi": "ਤੈ ਸਹ ਬਾਤ ਨ ਪੁਛੀਆ ਕਬਹੂ ਨ ਲਾਈ ਪਾਇ ॥੧॥",
          "roman": "tē sah bāt na puchhīā kabhū na lāī pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Супруг-Господь, Ты даже не спросил обо мне, не позаботился обо мне, и никогда не приложил меня к своим стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3449,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40430,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40431,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਮਹਿਦੀ ਕਰਿ ਕੈ ਰਖਿਆ ਸੋ ਸਹੁ ਨਦਰਿ ਕਰੇਇ ॥",
          "roman": "nānak mahdī kar kē rakhiā so sah nadar karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Он сам сделал нас хной; когда этот Супруг-Господь бросает взгляд милости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40432,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਪੀਸੈ ਆਪੇ ਘਸੈ ਆਪੇ ਹੀ ਲਾਇ ਲਏਇ ॥",
          "roman": "āpē pīsē āpē ghasē āpē hī lāē laē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам перемалывает, сам растирает и сам прикладывает к своим стопам, то есть сам вовлекает человека в труд преданного служения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40433,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਪਿਰਮ ਪਿਆਲਾ ਖਸਮ ਕਾ ਜੈ ਭਾਵੈ ਤੈ ਦੇਇ ॥੨॥",
          "roman": "ih piram piālā khasam kā jē bhāvē tē dēē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эта чаша любви принадлежит Владыке-Господу; Он даёт её тому человеку, который Ему мил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3450,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40434,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40435,
          "is_rahao": false,
          "gurmukhi": "ਵੇਕੀ ਸ੍ਰਿਸਟਿ ਉਪਾਈਅਨੁ ਸਭ ਹੁਕਮਿ ਆਵੈ ਜਾਇ ਸਮਾਹੀ ॥",
          "roman": "vēkī srisṭ upāīan sabh hukam āvē jāē samāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сотворил многоцветное, различное творение; все живые существа по Его хукам рождаются и растворяются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40436,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵੇਖਿ ਵਿਗਸਦਾ ਦੂਜਾ ਕੋ ਨਾਹੀ ॥",
          "roman": "āpē vēkh vigasdā dūjā ko nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господь, видя своё творение, радуется; у Него нет соперника, нет второго."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40437,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਖੁ ਤੂ ਗੁਰ ਸਬਦਿ ਬੁਝਾਹੀ ॥",
          "roman": "jiu bhāvē tiu rakh tū gur sabad bujhāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, как Тебе угодно, так и содержи живых существ; Ты сам через Слово Гуру даёшь им понимание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40438,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨਾ ਤੇਰਾ ਜੋਰੁ ਹੈ ਜਿਉ ਭਾਵੈ ਤਿਵੈ ਚਲਾਹੀ ॥",
          "roman": "sabhnā tērā jor hē jiu bhāvē tivē chalāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все живые существа держатся Твоей опорой; как Тебе угодно, так Ты и ведёшь их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40439,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧੁ ਜੇਵਡ ਮੈ ਨਾਹਿ ਕੋ ਕਿਸੁ ਆਖਿ ਸੁਣਾਈ ॥੨॥",
          "roman": "tudh jēvaḍ mē nāh ko kis ākh suṇāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, я не вижу никого столь великого, как Ты; о ком я могу сказать и поведать, что он равен Тебе?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3451,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40440,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahalā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Махала 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40441,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮਿ ਭੁਲਾਈ ਸਭੁ ਜਗੁ ਫਿਰੀ ਫਾਵੀ ਹੋਈ ਭਾਲਿ ॥",
          "roman": "bharam bhulāī sabh jag phirī phāvī hoī bhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Весь мир, сбитый с пути заблуждением, блуждает в поиске и, изнемогая от этой тщетной погони, становится безумным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
