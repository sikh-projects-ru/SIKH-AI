{
  "ang": 948,
  "shabads": [
    {
      "shabad_id": 3451,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40442,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਹੁ ਸਾਂਤਿ ਨ ਦੇਵਈ ਕਿਆ ਚਲੈ ਤਿਸੁ ਨਾਲਿ ॥",
          "roman": "so sah sānt na devēī kiā chalē tis nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой поиск не заставляет Господа даровать мир сердцу; с Ним нельзя действовать силой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40443,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਰਿ ਧਿਆਈਐ ਅੰਤਰਿ ਰਖੀਐ ਉਰ ਧਾਰਿ ॥",
          "roman": "gur parsādī har dhiāīai antar rakhīai ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Сатгуру можно вспоминать Бога и хранить Его внутри, прочно удерживая в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40444,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਘਰਿ ਬੈਠਿਆ ਸਹੁ ਪਾਇਆ ਜਾ ਕਿਰਪਾ ਕੀਤੀ ਕਰਤਾਰਿ ॥੧॥",
          "roman": "nānak ghar bēṭhiā sah pāiā jā kirpā kītī kartār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда Творец проявил милость, сидя дома, внутри самого себя, я нашёл Господа-Супруга."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3452,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40445,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahlā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40446,
          "is_rahao": false,
          "gurmukhi": "ਧੰਧਾ ਧਾਵਤ ਦਿਨੁ ਗਇਆ ਰੈਣਿ ਗਵਾਈ ਸੋਇ ॥",
          "roman": "dhandhā dhāvat din gēā rēṇ gavāī soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У человека, идущего за своим умом, весь день проходит в беготне мирских дел, а ночь он теряет во сне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40447,
          "is_rahao": false,
          "gurmukhi": "ਕੂੜੁ ਬੋਲਿ ਬਿਖੁ ਖਾਇਆ ਮਨਮੁਖਿ ਚਲਿਆ ਰੋਇ ॥",
          "roman": "kūṛ bol bikh khāiā manmukh chaliā roi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он говорит ложь, вкушает яд мирских наслаждений и, как манмукх, в конце уходит отсюда плача."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40448,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰੈ ਉਪਰਿ ਜਮ ਡੰਡੁ ਹੈ ਦੂਜੈ ਭਾਇ ਪਤਿ ਖੋਇ ॥",
          "roman": "sirē upar jam ḍaṇḍ hē dūjē bhāi pat khoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Над его головой стоит жезл смерти; из-за любви к иному, забыв Господа, он теряет свою честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40449,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਕਦੇ ਨ ਚੇਤਿਓ ਫਿਰਿ ਆਵਣ ਜਾਣਾ ਹੋਇ ॥",
          "roman": "har nām kadē na chetio phir āvaṇ jāṇā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он никогда не вспоминал Имя Бога, поэтому снова и снова попадает в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40450,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਰਿ ਮਨਿ ਵਸੈ ਜਮ ਡੰਡੁ ਨ ਲਾਗੈ ਕੋਇ ॥",
          "roman": "gur parsādī har man vasē jam ḍaṇḍ na lāgē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но в чьём уме по милости Сатгуру пребывает Бог, того не касается никакой жезл смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40451,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਹਜੇ ਮਿਲਿ ਰਹੈ ਕਰਮਿ ਪਰਾਪਤਿ ਹੋਇ ॥੨॥",
          "roman": "nānak sahjē mil rahē karam parāpat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой человек остаётся соединённым с Господом в состоянии сахадж; это достигается через Божью милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3453,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40452,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40453,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਆਪਣੀ ਸਿਫਤੀ ਲਾਇਅਨੁ ਦੇ ਸਤਿਗੁਰ ਮਤੀ ॥",
          "roman": "ik āpaṇī sifatī lāian de satigur matī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторых существ Господь, дав им наставление Сатгуру, привлёк к Своей хвале и прославлению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40454,
          "is_rahao": false,
          "gurmukhi": "ਇਕਨਾ ਨੋ ਨਾਉ ਬਖਸਿਓਨੁ ਅਸਥਿਰੁ ਹਰਿ ਸਤੀ ॥",
          "roman": "iknā no nāo bakhsion asthir har satī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторым вечный Господь даровал Своё вечно пребывающее Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40455,
          "is_rahao": false,
          "gurmukhi": "ਪਉਣੁ ਪਾਣੀ ਬੈਸੰਤਰੋ ਹੁਕਮਿ ਕਰਹਿ ਭਗਤੀ ॥",
          "roman": "pauṇ pāṇī bēsantaro hukam karah bhagtī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воздух, вода и огонь тоже, следуя Его Хукам, совершают Его служение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40456,
          "is_rahao": false,
          "gurmukhi": "ਏਨਾ ਨੋ ਭਉ ਅਗਲਾ ਪੂਰੀ ਬਣਤ ਬਣਤੀ ॥",
          "roman": "enā no bhau aglā pūrī baṇat baṇtī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В них пребывает великий страх перед Владыкой; поэтому совершенное устройство мира установлено должным образом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40457,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਇਕੋ ਹੁਕਮੁ ਵਰਤਦਾ ਮੰਨਿਐ ਸੁਖੁ ਪਾਈ ॥੩॥",
          "roman": "sabh iko hukam varatdā manniai sukh pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повсюду действует один Хукам Господа; признавая Его и живя в Нём, человек обретает мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3454,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40458,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40459,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਕਸਉਟੀ ਰਾਮ ਕੀ ਝੂਠਾ ਟਿਕੈ ਨ ਕੋਇ ॥",
          "roman": "kabīr kasauṭī rām kī jhūṭhā ṭikē na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, проверочный камень Бога таков, что ложный человек не может на нём устоять."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40460,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਕਸਉਟੀ ਸੋ ਸਹੈ ਜੋ ਮਰਜੀਵਾ ਹੋਇ ॥੧॥",
          "roman": "rām kasauṭī so sahē jo marjīvā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Проверку Бога выдерживает только тот, кто умер для мирских привязанностей и ожил к Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3455,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40461,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahlā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40462,
          "is_rahao": false,
          "gurmukhi": "ਕਿਉ ਕਰਿ ਇਹੁ ਮਨੁ ਮਾਰੀਐ ਕਿਉ ਕਰਿ ਮਿਰਤਕੁ ਹੋਇ ॥",
          "roman": "kio kar ih man mārīai kio kar mirtak hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как усмирить этот ум? Как сделать его мёртвым для мирских соблазнов?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40463,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿਆ ਸਬਦੁ ਨ ਮਾਨਈ ਹਉਮੈ ਛਡੈ ਨ ਕੋਇ ॥",
          "roman": "kahiā śabad na mānaī haumē chhaḍē na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто лишь по словам не принимает Шабад Гуру и не оставляет Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40464,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਉਮੈ ਛੁਟੈ ਜੀਵਨ ਮੁਕਤੁ ਸੋ ਹੋਇ ॥",
          "roman": "gur parsādī haumē chhuṭē jīvan mukat so hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Сатгуру Хоумэ исчезает; тот, у кого она уничтожена, становится освобождённым при жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40465,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸ ਨੋ ਬਖਸੇ ਤਿਸੁ ਮਿਲੈ ਤਿਸੁ ਬਿਘਨੁ ਨ ਲਾਗੈ ਕੋਇ ॥੨॥",
          "roman": "nānak jis no bakhsē tis milē tis bighan na lāgē koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, кому Господь дарует милость, тот получает это состояние, и никакая преграда не мешает ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3456,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40466,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahlā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40467,
          "is_rahao": false,
          "gurmukhi": "ਜੀਵਤ ਮਰਣਾ ਸਭੁ ਕੋ ਕਹੈ ਜੀਵਨ ਮੁਕਤਿ ਕਿਉ ਹੋਇ ॥",
          "roman": "jīvat marṇā sabh ko kahē jīvan mukt kio hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждый говорит о смерти к миру ещё при жизни, но как достигается состояние освобождения при жизни?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40468,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਕਾ ਸੰਜਮੁ ਜੇ ਕਰੇ ਦਾਰੂ ਭਾਉ ਲਾਏਇ ॥",
          "roman": "bhē kā sañjam je karē dārū bhāu lāēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если человек сделает страх перед Богом своей дисциплиной, а любовь к Нему применит как лекарство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40469,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਗੁਣ ਗਾਵੈ ਸੁਖ ਸਹਜੇ ਬਿਖੁ ਭਵਜਲੁ ਨਾਮਿ ਤਰੇਇ ॥",
          "roman": "andin guṇ gāvē sukh sahjē bikh bhavjal nām tarēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если он день и ночь в радости и сахадж воспевает достоинства Господа, то через Имя переправляется через ядовитый океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40470,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਪਾਈਐ ਜਾ ਕਉ ਨਦਰਿ ਕਰੇਇ ॥੩॥",
          "roman": "nānak gurmukh pāīai jā kau nadar karēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это состояние обретается через Гуру, когда Господь обращает на человека взор милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3457,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40471,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40472,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜਾ ਭਾਉ ਰਚਾਇਓਨੁ ਤ੍ਰੈ ਗੁਣ ਵਰਤਾਰਾ ॥",
          "roman": "dūjā bhāu rachāion trē guṇ vartārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Любовь к иному, к майе, и действие трёх гун тоже созданы Самим Творцом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40473,
          "is_rahao": false,
          "gurmukhi": "ਬ੍ਰਹਮਾ ਬਿਸਨੁ ਮਹੇਸੁ ਉਪਾਇਅਨੁ ਹੁਕਮਿ ਕਮਾਵਨਿ ਕਾਰਾ ॥",
          "roman": "brahmā bisan mahes upāian hukam kamāvan kārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Брахму, Вишну и Шиву Он Сам создал; они выполняют свои дела в Его Хукам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40474,
          "is_rahao": false,
          "gurmukhi": "ਪੰਡਿਤ ਪੜਦੇ ਜੋਤਕੀ ਨਾ ਬੂਝਹਿ ਬੀਚਾਰਾ ॥",
          "roman": "paṇḍit paṛdē jotkī nā būjhah bīchārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пандиты и астрологи читают учёные книги, но не понимают сути этого Божьего замысла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40475,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤੇਰਾ ਖੇਲੁ ਹੈ ਸਚੁ ਸਿਰਜਣਹਾਰਾ ॥",
          "roman": "sabh kichh terā khel hē sach sirjaṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О истинный Творец, всё это — Твоя игра; Ты — Создатель и вечно пребывающий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40476,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸੁ ਬਖਸਿ ਲੈਹਿ ਸਚਿ ਸਬਦਿ ਸਮਾਈ ॥੪॥",
          "roman": "jis bhāvē tis bakhas lēh sach śabad samāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто Тебе угоден, того Ты прощаешь и принимаешь; через истинный Шабад он пребывает в Твоём истинном Сущем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3458,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40477,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੩ ॥",
          "roman": "salok mahlā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40478,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਝੂਠਾ ਝੂਠੁ ਕਮਾਵੈ ॥",
          "roman": "man kā jhūṭhā jhūṭh kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек, ложный в уме, совершает ложные дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40479,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਨੋ ਫਿਰੈ ਤਪਾ ਸਦਾਵੈ ॥",
          "roman": "māiā no phirē tapā sadāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он странствует ради майи, но велит называть себя тапой, подвижником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40480,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮੇ ਭੂਲਾ ਸਭਿ ਤੀਰਥ ਗਹੈ ॥",
          "roman": "bharmē bhūlā sabh tīrath gahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Заблудившись в иллюзии, он обходит все места паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40481,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਤਪਾ ਕੈਸੇ ਪਰਮ ਗਤਿ ਲਹੈ ॥",
          "roman": "oh tapā kēsē param gat lahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как такой подвижник может достичь высшего духовного состояния?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40482,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਕੋ ਸਚੁ ਕਮਾਵੈ ॥",
          "roman": "gur parsādī ko sach kamāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но тот подвижник, кто по милости Гуру практикует истину и делает Божью реальность частью своей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40483,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਤਪਾ ਮੋਖੰਤਰੁ ਪਾਵੈ ॥੧॥",
          "roman": "nānak so tapā mokhantar pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой подвижник обретает внутреннее освобождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3459,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40484,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahlā tījā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40485,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਤਪਾ ਜਿ ਇਹੁ ਤਪੁ ਘਾਲੇ ॥",
          "roman": "so tapā j ih tap ghālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот истинный подвижник, кто совершает именно этот тап, эту духовную практику."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40486,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਨੋ ਮਿਲੈ ਸਬਦੁ ਸਮਾਲੇ ॥",
          "roman": "satigur no milē śabad samālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он встречает Сатгуру, входит в Его прибежище и бережно хранит Шабад в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40487,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰ ਕੀ ਸੇਵਾ ਇਹੁ ਤਪੁ ਪਰਵਾਣੁ ॥",
          "roman": "satigur kī sevā ih tap parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Служение, указанное Сатгуру, — вот тап, принимаемый Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40488,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋ ਤਪਾ ਦਰਗਹਿ ਪਾਵੈ ਮਾਣੁ ॥੨॥",
          "roman": "nānak so tapā dargah pāvē māṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой подвижник получает честь в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3460,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40489,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40490,
          "is_rahao": false,
          "gurmukhi": "ਰਾਤਿ ਦਿਨਸੁ ਉਪਾਇਅਨੁ ਸੰਸਾਰ ਕੀ ਵਰਤਣਿ ॥",
          "roman": "rāt dinas upāian sansār kī vartaṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он создал ночь и день как порядок и образ действия мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
