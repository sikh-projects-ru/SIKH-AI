{
  "ang": 952,
  "shabads": [
    {
      "shabad_id": 3478,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40628,
          "is_rahao": false,
          "gurmukhi": "ਵਿਣੁ ਗੁਰ ਪੀਰੈ ਕੋ ਥਾਇ ਨ ਪਾਈ ॥",
          "roman": "viṇ gur pīrē ko thāe na pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Гуру-Пира никто не получает принятого места."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40629,
          "is_rahao": false,
          "gurmukhi": "ਰਾਹੁ ਦਸਾਇ ਓਥੈ ਕੋ ਜਾਇ ॥",
          "roman": "rāh dasāe othē ko jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда путь указан, тогда кто-либо может туда идти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40630,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੀ ਬਾਝਹੁ ਭਿਸਤਿ ਨ ਪਾਇ ॥",
          "roman": "karṇī bājhah bhisat na pāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без праведного образа жизни рай не обретается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40631,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਕੈ ਘਰਿ ਜੁਗਤਿ ਦਸਾਈ ॥",
          "roman": "jogī kē ghar jugat dasāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В доме йогина была показана йогическая метода."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40632,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤੁ ਕਾਰਣਿ ਕਨਿ ਮੁੰਦ੍ਰਾ ਪਾਈ ॥",
          "roman": "tit kāraṇ kan mundrā pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ради этого он надел серьги в уши."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40633,
          "is_rahao": false,
          "gurmukhi": "ਮੁੰਦ੍ਰਾ ਪਾਇ ਫਿਰੈ ਸੰਸਾਰਿ ॥",
          "roman": "mundrā pāe phirē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Надев серьги, он странствует по миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40634,
          "is_rahao": false,
          "gurmukhi": "ਜਿਥੈ ਕਿਥੈ ਸਿਰਜਣਹਾਰੁ ॥",
          "roman": "jithē kithē sirjaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но Творец присутствует везде и всюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40635,
          "is_rahao": false,
          "gurmukhi": "ਜੇਤੇ ਜੀਅ ਤੇਤੇ ਵਾਟਾਊ ॥",
          "roman": "jetē jīa tetē vāṭāū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сколько есть живых существ, столько и путников."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40636,
          "is_rahao": false,
          "gurmukhi": "ਚੀਰੀ ਆਈ ਢਿਲ ਨ ਕਾਊ ॥",
          "roman": "chīrī āī ḍhil na kāū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У каждого уже пришло записанное предписание; никому не бывает задержки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40637,
          "is_rahao": false,
          "gurmukhi": "ਏਥੈ ਜਾਣੈ ਸੁ ਜਾਇ ਸਿਞਾਣੈ ॥",
          "roman": "ethē jāṇē so jāe siñāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто познаёт здесь, тот, уйдя туда, будет распознан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40638,
          "is_rahao": false,
          "gurmukhi": "ਹੋਰੁ ਫਕੜੁ ਹਿੰਦੂ ਮੁਸਲਮਾਣੈ ॥",
          "roman": "hor phakaṛ hindū musalmāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прочее — пустые споры индусов и мусульман."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40639,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨਾ ਕਾ ਦਰਿ ਲੇਖਾ ਹੋਇ ॥",
          "roman": "sabhnā kā dar lekhā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У всех у Двора будет произведён расчёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40640,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣੀ ਬਾਝਹੁ ਤਰੈ ਨ ਕੋਇ ॥",
          "roman": "karṇī bājhah tarē na koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без праведного образа жизни никто не переправляется."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40641,
          "is_rahao": false,
          "gurmukhi": "ਸਚੋ ਸਚੁ ਵਖਾਣੈ ਕੋਇ ॥",
          "roman": "sacho sach vakhāṇē koe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лишь редкий произносит Истинного — истинно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40642,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਅਗੈ ਪੁਛ ਨ ਹੋਇ ॥੨॥",
          "roman": "nānak agē puchh na hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, впереди такого уже не станут допрашивать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3479,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40643,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40644,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਮੰਦਰੁ ਆਖੀਐ ਕਾਇਆ ਕੋਟੁ ਗੜੁ ॥",
          "roman": "har kā mandar ākhīai kāiā koṭ gaṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это тело следует называть прекрасным домом, где пребывает Бог, крепостью и твердыней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40645,
          "is_rahao": false,
          "gurmukhi": "ਅੰਦਰਿ ਲਾਲ ਜਵੇਹਰੀ ਗੁਰਮੁਖਿ ਹਰਿ ਨਾਮੁ ਪੜੁ ॥",
          "roman": "andar lāl javēharī gurmukh har nām paṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если, идя по повелению Гуру, будешь повторять Имя Бога, то внутри этого тела найдёшь драгоценности добрых качеств, подобные рубинам и самоцветам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40646,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਮੰਦਰੁ ਸਰੀਰੁ ਅਤਿ ਸੋਹਣਾ ਹਰਿ ਹਰਿ ਨਾਮੁ ਦਿੜੁ ॥",
          "roman": "har kā mandar sarīr at sohṇā har har nām diṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Закрепи Имя Бога в сердце; только тогда это тело, этот храм Господа, может стать очень прекрасным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40647,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖ ਆਪਿ ਖੁਆਇਅਨੁ ਮਾਇਆ ਮੋਹ ਨਿਤ ਕੜੁ ॥",
          "roman": "manmukh āp khuāian māiā moh nit kaṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но тех, кто следует за собственным умом, Господь Сам сбил с пути; их постоянно мучит тревога привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40648,
          "is_rahao": false,
          "gurmukhi": "ਸਭਨਾ ਸਾਹਿਬੁ ਏਕੁ ਹੈ ਪੂਰੈ ਭਾਗਿ ਪਾਇਆ ਜਾਈ ॥੧੧॥",
          "roman": "sabhnā sāhib ek hē pūrē bhāg pāiā jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Владыка всех существ — тот один Бог, но обретается Он лишь полной судьбой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3480,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40649,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок, Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40650,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸਤਿ ਦੁਖੀਆ ਨਾ ਸਤਿ ਸੁਖੀਆ ਨਾ ਸਤਿ ਪਾਣੀ ਜੰਤ ਫਿਰਹਿ ॥",
          "roman": "nā sat dukhīā nā sat sukhīā nā sat pāṇī jant phirah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Достижение и величие не приходят ни через страдание от аскезы, ни через удобную жизнь, ни через стояние в воде; иначе бесчисленные водные существа уже обрели бы совершенство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40651,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸਤਿ ਮੂੰਡ ਮੁਡਾਈ ਕੇਸੀ ਨਾ ਸਤਿ ਪੜਿਆ ਦੇਸ ਫਿਰਹਿ ॥",
          "roman": "nā sat mūṇḍ muḍāī kesī nā sat paṛiā des phirah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенство не в том, чтобы сбрить волосы на голове, и не в том, чтобы, став учёным, ходить по странам и побеждать других в спорах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40652,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸਤਿ ਰੁਖੀ ਬਿਰਖੀ ਪਥਰ ਆਪੁ ਤਛਾਵਹਿ ਦੁਖ ਸਹਹਿ ॥",
          "roman": "nā sat rukhī birkhī pathar āp tachhāvah dukh sahah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенство не в деревьях, растениях и камнях: они дают себя рубить и терпят разные страдания; так и через неподвижное терпение мучений цель рождения не достигается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40653,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਸਤਿ ਹਸਤੀ ਬਧੇ ਸੰਗਲ ਨਾ ਸਤਿ ਗਾਈ ਘਾਹੁ ਚਰਹਿ ॥",
          "roman": "nā sat hastī badhē saṅgal nā sat gāī ghāh charah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершенство не в цепях, ведь и слоны бывают скованы цепями; и не в питании кореньями и травой, ведь коровы и так пасутся на траве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40654,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਹਥਿ ਸਿਧਿ ਦੇਵੈ ਜੇ ਸੋਈ ਜਿਸ ਨੋ ਦੇਇ ਤਿਸੁ ਆਇ ਮਿਲੈ ॥",
          "roman": "jis hath sidh dēvē je soī jis no dēe tis āe milē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Успех находится в руке Господа: если Он Сам дарует его, то тот, кому Он даёт, получает его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40655,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਾ ਕਉ ਮਿਲੈ ਵਡਾਈ ਜਿਸੁ ਘਟ ਭੀਤਰਿ ਸਬਦੁ ਰਵੈ ॥",
          "roman": "nānak tā kau milē vaḍāī jis ghaṭ bhītar shabad ravē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, величие получает тот человек, в чьём сердце всегда присутствует Шабад хвалы Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40656,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਘਟ ਮੇਰੇ ਹਉ ਸਭਨਾ ਅੰਦਰਿ ਜਿਸਹਿ ਖੁਆਈ ਤਿਸੁ ਕਉਣੁ ਕਹੈ ॥",
          "roman": "sabh ghaṭ mērē hau sabhnā andar jisah khuāī tis kauṇ kahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь говорит: все тела живых существ — Мои, Я пребываю во всех; кого Я сбиваю с пути, того кто может наставить?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40657,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਦਿਖਾਲਾ ਵਾਟੜੀ ਤਿਸਹਿ ਭੁਲਾਵੈ ਕਉਣੁ ॥",
          "roman": "jisah dikhālā vāṭṛī tisah bhulāvē kauṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кому Я показываю прекрасный путь, того кто может сбить?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40658,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਭੁਲਾਈ ਪੰਧ ਸਿਰਿ ਤਿਸਹਿ ਦਿਖਾਵੈ ਕਉਣੁ ॥੧॥",
          "roman": "jisah bhulāī pandh sir tisah dikhāvē kauṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого Я сбиваю уже в начале жизненного пути, тому кто может показать дорогу?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3481,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40659,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40660,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਗਿਰਹੀ ਜੋ ਨਿਗ੍ਰਹੁ ਕਰੈ ॥",
          "roman": "so girahī jo nigrah karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный домохозяин — тот, кто удерживает чувства от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40661,
          "is_rahao": false,
          "gurmukhi": "ਜਪੁ ਤਪੁ ਸੰਜਮੁ ਭੀਖਿਆ ਕਰੈ ॥",
          "roman": "jap tap sanjam bhīkhiā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он просит у Господа подаяния в виде Джапа, аскезы и самообуздания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40662,
          "is_rahao": false,
          "gurmukhi": "ਪੁੰਨ ਦਾਨ ਕਾ ਕਰੇ ਸਰੀਰੁ ॥",
          "roman": "punn dān kā karē sarīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он делает своё тело телом благого дела, служения и помощи творению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40663,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਗਿਰਹੀ ਗੰਗਾ ਕਾ ਨੀਰੁ ॥",
          "roman": "so girahī gaṅgā kā nīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой домохозяин становится чистым, как вода Ганги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40664,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਈਸਰੁ ਸਤਿ ਸਰੂਪੁ ॥",
          "roman": "bolē īsar sat sarūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Ишар-йогин, применив эту подлинную методу домохозяина, будет воспевать вечного Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40665,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਤੰਤ ਮਹਿ ਰੇਖ ਨ ਰੂਪੁ ॥੨॥",
          "roman": "param tant mah rēkh na rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то и он сольётся с Высшим Брахманом, и у него не останется отдельной формы или очертания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3482,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40666,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40667,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਅਉਧੂਤੀ ਜੋ ਧੂਪੈ ਆਪੁ ॥",
          "roman": "so audhūtī jo dhūpē āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный авадхут — тот, кто сжигает чувство собственного «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40668,
          "is_rahao": false,
          "gurmukhi": "ਭਿਖਿਆ ਭੋਜਨੁ ਕਰੈ ਸੰਤਾਪੁ ॥",
          "roman": "bhikhiā bhojan karē santāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он делает раздражение своей пищей, добытой как подаяние, то есть не питает его, а поглощает и уничтожает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40669,
          "is_rahao": false,
          "gurmukhi": "ਅਉਹਠ ਪਟਣ ਮਹਿ ਭੀਖਿਆ ਕਰੈ ॥",
          "roman": "auhaṭh paṭaṇ mah bhīkhiā karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он, пребывая в городе сердца, просит у Господа подаяния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40670,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਅਉਧੂਤੀ ਸਿਵ ਪੁਰਿ ਚੜੈ ॥",
          "roman": "so audhūtī siv pur chaṛē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой авадхут достигает обители Господа, являющегося благом и освобождением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40671,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਗੋਰਖੁ ਸਤਿ ਸਰੂਪੁ ॥",
          "roman": "bolē gorakh sat sarūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Горакх-йогин, применив эту методу авадхута, будет воспевать Господа, Образ Истины,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40672,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਤੰਤ ਮਹਿ ਰੇਖ ਨ ਰੂਪੁ ॥੩॥",
          "roman": "param tant mah rēkh na rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то и Горакх сольётся с Высшим Брахманом, и у него не останется отдельной формы или очертания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3483,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40673,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40674,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਉਦਾਸੀ ਜਿ ਪਾਲੇ ਉਦਾਸੁ ॥",
          "roman": "so udāsī j pālē udās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный отрешённый — тот, кто всегда сохраняет отстранённость от майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40675,
          "is_rahao": false,
          "gurmukhi": "ਅਰਧ ਉਰਧ ਕਰੇ ਨਿਰੰਜਨ ਵਾਸੁ ॥",
          "roman": "aradh uradh karē nirañjan vās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он знает, что свободный от майи Господь обитает везде — близко и высоко, во всех местах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40676,
          "is_rahao": false,
          "gurmukhi": "ਚੰਦ ਸੂਰਜ ਕੀ ਪਾਏ ਗੰਢਿ ॥",
          "roman": "chand sūraj kī pāē gaṇḍh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он соединяет в своём сердце прохладу покоя и сияние знания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40677,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਉਦਾਸੀ ਕਾ ਪੜੈ ਨ ਕੰਧੁ ॥",
          "roman": "tis udāsī kā paṛē na kandh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тело такого отрешённого человека не падает в пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40678,
          "is_rahao": false,
          "gurmukhi": "ਬੋਲੈ ਗੋਪੀ ਚੰਦੁ ਸਤਿ ਸਰੂਪੁ ॥",
          "roman": "bolē gopī chand sat sarūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Гопи Чанд, применив эту методу отрешённости, будет воспевать Господа, Образ Истины,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40679,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਤੰਤ ਮਹਿ ਰੇਖ ਨ ਰੂਪੁ ॥੪॥",
          "roman": "param tant mah rēkh na rūp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то и Гопи Чанд сольётся с Высшим Брахманом, и у него не останется отдельной формы или очертания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3484,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40680,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahallā pahilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Первый Махалла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40681,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਾਖੰਡੀ ਜਿ ਕਾਇਆ ਪਖਾਲੇ ॥",
          "roman": "so pākhaṇḍī j kāiā pakhālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный «паханди» — не тот, кто отрицает Бога, а тот, кто очищает тело, то есть уничтожает в нём существование грехов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40682,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਕੀ ਅਗਨਿ ਬ੍ਰਹਮੁ ਪਰਜਾਲੇ ॥",
          "roman": "kāiā kī agan brahm parjālē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он в своём теле ярко разжигает божественный свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40683,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨੈ ਬਿੰਦੁ ਨ ਦੇਈ ਝਰਣਾ ॥",
          "roman": "supnē bind na deī jharṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже во сне он не позволяет семени пролиться, то есть даже во сне не отдаётся во власть похоти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
