{
  "ang": 955,
  "shabads": [
    {
      "shabad_id": 3500,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40790,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40791,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਅੰਦਰਿ ਗੜੁ ਕੋਟੁ ਹੈ ਸਭਿ ਦਿਸੰਤਰ ਦੇਸਾ ॥",
          "roman": "kāiā andar gaṛ koṭ hē sabh disantar dēsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри человеческого тела находится крепость, твердыня сердца, принадлежащая тому Господу; и этот Господь присутствует во всех странах и землях."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40792,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਤਾੜੀ ਲਾਈਅਨੁ ਸਭ ਮਹਿ ਪਰਵੇਸਾ ॥",
          "roman": "āpē tāṛī lāīan sabh meh parvēsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Войдя во всех существ, Он Сам пребывает в них в глубоком сосредоточении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40793,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸ੍ਰਿਸਟਿ ਸਾਜੀਅਨੁ ਆਪਿ ਗੁਪਤੁ ਰਖੇਸਾ ॥",
          "roman": "āpē sriśaṭ sājīan āp gupat rakhēsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Сам сотворил мироздание и Сам скрыл Себя внутри этого мироздания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40794,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੇਵਾ ਤੇ ਜਾਣਿਆ ਸਚੁ ਪਰਗਟੀਏਸਾ ॥",
          "roman": "gur sēvā tē jāṇiā sach pargaṭīēsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Понимание этого Господа приходит через следование повелению Сатгуру; тогда Истинный Господь раскрывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40795,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਸਚੋ ਸਚੁ ਹੈ ਗੁਰਿ ਸੋਝੀ ਪਾਈ ॥੧੬॥",
          "roman": "sabh kichh sacho sach hē gur sojhī pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всюду есть только Истинный Господь, но это понимание приходит лишь через Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3501,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40796,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40797,
          "is_rahao": false,
          "gurmukhi": "ਸਾਵਣੁ ਰਾਤਿ ਅਹਾੜੁ ਦਿਹੁ ਕਾਮੁ ਕ੍ਰੋਧੁ ਦੁਇ ਖੇਤ ॥",
          "roman": "sāvaṇ rāt ahāṛ dih kām krodh dui khēt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того существа ночь подобна посеву сезона саван, а похоть — его поле; день подобен посеву сезона харх, а гнев — его поле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40798,
          "is_rahao": false,
          "gurmukhi": "ਲਬੁ ਵਤ੍ਰ ਦਰੋਗੁ ਬੀਉ ਹਾਲੀ ਰਾਹਕੁ ਹੇਤ ॥",
          "roman": "lab vatar darog bīu hālī rāhak hēt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для него жадность служит влагой для посева, ложь является семенем, а привязанность становится пахарем и сеятелем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40799,
          "is_rahao": false,
          "gurmukhi": "ਹਲੁ ਬੀਚਾਰੁ ਵਿਕਾਰ ਮਣ ਹੁਕਮੀ ਖਟੇ ਖਾਇ ॥",
          "roman": "hal bīchār vikār maṇ hukmī khaṭē khāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его плуг — размышление о пороках; он собирает сноп пороков и, по повелению Господа, вкушает плод своей такой заработанной кармы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40800,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਲੇਖੈ ਮੰਗਿਐ ਅਉਤੁ ਜਣੇਦਾ ਜਾਇ ॥੧॥",
          "roman": "nānak lēkhē maṅgiē aut jaṇēdā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда требуют счёт его поступков, тогда оказывается, что такой отец-сущность уходит из мира бесплодным, то есть напрасно теряет жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3502,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40801,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40802,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਭੁਇ ਪਵਿਤੁ ਪਾਣੀ ਸਤੁ ਸੰਤੋਖੁ ਬਲੇਦ ॥",
          "roman": "bhau bhue pavit pāṇī sat santokh balēd",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если страх перед Господом станет полем, чистое поведение — водой, а истина и довольство — быками для вспашки этого поля,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40803,
          "is_rahao": false,
          "gurmukhi": "ਹਲੁ ਹਲੇਮੀ ਹਾਲੀ ਚਿਤੁ ਚੇਤਾ ਵਤ੍ਰ ਵਖਤ ਸੰਜੋਗੁ ॥",
          "roman": "hal halēmī hālī chit chētā vatar vakhat sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "если смирение станет плугом, сосредоточенное сознание — пахарем, памятование Господа — влагой, а встреча с Гуру — временем посева,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40804,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਬੀਜੁ ਬਖਸੀਸ ਬੋਹਲ ਦੁਨੀਆ ਸਗਲ ਦਰੋਗ ॥",
          "roman": "nāu bīj bakhsīs bohal dunīā sagal darog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "если Имя Господа станет семенем, тогда собирается урожай Его милости, и весь мир начинает казаться преходящим и ложным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40805,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਦਰੀ ਕਰਮੁ ਹੋਇ ਜਾਵਹਿ ਸਗਲ ਵਿਜੋਗ ॥੨॥",
          "roman": "nānak nadrī karam hoe jāveh sagal vijog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда по Его милостивому взгляду приходит благодать, все разлуки с Ним исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3503,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40806,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40807,
          "is_rahao": false,
          "gurmukhi": "ਮਨਮੁਖਿ ਮੋਹੁ ਗੁਬਾਰੁ ਹੈ ਦੂਜੈ ਭਾਇ ਬੋਲੈ ॥",
          "roman": "manmukh moh gubār hē dūjē bhāe bolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри того, кто идёт за своим умом, царит густая тьма привязанности; что бы он ни говорил, он говорит в любви к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40808,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਸਦਾ ਦੁਖੁ ਹੈ ਨਿਤ ਨੀਰੁ ਵਿਰੋਲੈ ॥",
          "roman": "dūjē bhāe sadā dukh hē nit nīr virolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за любви к иному, кроме Господа, он всегда испытывает страдание; он словно постоянно взбивает одну воду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40809,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਧਿਆਈਐ ਮਥਿ ਤਤੁ ਕਢੋਲੈ ॥",
          "roman": "gurmukh nām dhiāīē math tat kaḍholē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто идёт путём Гуру, размышляет над Именем Господа и, взбивая, извлекает масло-истину Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40810,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪਰਗਾਸੁ ਘਟਿ ਚਾਨਣਾ ਹਰਿ ਲਧਾ ਟੋਲੈ ॥",
          "roman": "antar pargās ghaṭ chānaṇā har ladhā ṭolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В его сердце возникает свет, внутри становится озарение; через поиск по пути Гуру он находит Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40811,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਭਰਮਿ ਭੁਲਾਇਦਾ ਕਿਛੁ ਕਹਣੁ ਨ ਜਾਈ ॥੧੭॥",
          "roman": "āpē bharam bhulāidā kichh kahaṇ na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господь вводит в заблуждение через сомнение; ничего нельзя сказать и никого нельзя обвинить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3504,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40812,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੨ ॥",
          "roman": "salok mahalā 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40813,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਚਿੰਤਾ ਮਤਿ ਕਰਹੁ ਚਿੰਤਾ ਤਿਸ ਹੀ ਹੇਇ ॥",
          "roman": "nānak chintā mat karah chintā tis hī hēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, не беспокойтесь о пропитании; эта забота принадлежит Самому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40814,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਮਹਿ ਜੰਤ ਉਪਾਇਅਨੁ ਤਿਨਾ ਭਿ ਰੋਜੀ ਦੇਇ ॥",
          "roman": "jal meh jant upāian tinā bh rojī dēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он создал живых существ в воде и им тоже даёт пропитание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40815,
          "is_rahao": false,
          "gurmukhi": "ਓਥੈ ਹਟੁ ਨ ਚਲਈ ਨਾ ਕੋ ਕਿਰਸ ਕਰੇਇ ॥",
          "roman": "othē haṭ na chalaī nā ko kiras karēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Там, в воде, не работает никакая лавка и никто не занимается земледелием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40816,
          "is_rahao": false,
          "gurmukhi": "ਸਉਦਾ ਮੂਲਿ ਨ ਹੋਵਈ ਨਾ ਕੋ ਲਏ ਨ ਦੇਇ ॥",
          "roman": "saudā mūl na hovaī nā ko lae na dēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Там вовсе нет товара и торговли, никто не берёт и не даёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40817,
          "is_rahao": false,
          "gurmukhi": "ਜੀਆ ਕਾ ਆਹਾਰੁ ਜੀਅ ਖਾਣਾ ਏਹੁ ਕਰੇਇ ॥",
          "roman": "jīā kā āhār jīa khāṇā ēh karēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но там Он устроил такую пищу: живые существа становятся пищей для живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40818,
          "is_rahao": false,
          "gurmukhi": "ਵਿਚਿ ਉਪਾਏ ਸਾਇਰਾ ਤਿਨਾ ਭਿ ਸਾਰ ਕਰੇਇ ॥",
          "roman": "vich upāe sāirā tinā bh sār karēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тех, кого Он создал в морях, Он тоже бережёт и поддерживает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40819,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਚਿੰਤਾ ਮਤ ਕਰਹੁ ਚਿੰਤਾ ਤਿਸ ਹੀ ਹੇਇ ॥੧॥",
          "roman": "nānak chintā mat karah chintā tis hī hēe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, не предавайтесь тревоге о пропитании; Сам Господь заботится об этом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3505,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40820,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40821,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਇਹੁ ਜੀਉ ਮਛੁਲੀ ਝੀਵਰੁ ਤ੍ਰਿਸਨਾ ਕਾਲੁ ॥",
          "roman": "nānak ih jīu machhulī jhīvar trisnā kāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, эта душа подобна маленькой рыбе, а жажда-тришна, несущая духовную смерть, подобна рыбаку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40822,
          "is_rahao": false,
          "gurmukhi": "ਮਨੂਆ ਅੰਧੁ ਨ ਚੇਤਈ ਪੜੈ ਅਚਿੰਤਾ ਜਾਲੁ ॥",
          "roman": "manūā andh na chētaī paṛē achintā jāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Глупый ум, ослеплённый этой жаждой, не помнит Господа; в беспечности на него всё больше падает сеть духовной смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40823,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਚਿਤੁ ਅਚੇਤੁ ਹੈ ਚਿੰਤਾ ਬਧਾ ਜਾਇ ॥",
          "roman": "nānak chit achēt hē chintā badhā jāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, ум, пойманный жаждой, становится беспечным и остаётся связанным тревогой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40824,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਜੇ ਆਪਣੀ ਤਾ ਆਪੇ ਲਏ ਮਿਲਾਇ ॥੨॥",
          "roman": "nadar karē jē āpaṇī tā āpē lae milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Господь обратит Свой милостивый взгляд, Он Сам выводит душу из жажды и соединяет её с Собой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3506,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40825,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40826,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਜਨ ਸਾਚੇ ਸਦਾ ਸਦਾ ਜਿਨੀ ਹਰਿ ਰਸੁ ਪੀਤਾ ॥",
          "roman": "sē jan sāchē sadā sadā jinī har ras pītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые выпили нектар Имени Господа, навсегда остаются едиными с Господом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40827,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਚਾ ਮਨਿ ਵਸੈ ਸਚੁ ਸਉਦਾ ਕੀਤਾ ॥",
          "roman": "gurmukh sachā man vasē sach saudā kītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следуя повелению Гуру, Вечно Истинный Господь поселяется в их уме; они совершили истинную торговлю Именем Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40828,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਘਰ ਹੀ ਮਾਹਿ ਹੈ ਵਡਭਾਗੀ ਲੀਤਾ ॥",
          "roman": "sabh kichh ghar hī māh hē vaḍbhāgī lītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот товар Имени находится внутри самого человеческого сердца, но получают его только великие счастливцы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40829,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਤ੍ਰਿਸਨਾ ਮਰਿ ਗਈ ਹਰਿ ਗੁਣ ਗਾਵੀਤਾ ॥",
          "roman": "antar trisnā mar gaī har guṇ gāvītā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Господа, они умерщвляют внутреннюю жажду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40830,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਮੇਲਿ ਮਿਲਾਇਅਨੁ ਆਪੇ ਦੇਇ ਬੁਝਾਈ ॥੧੮॥",
          "roman": "āpē mēl milāian āpē dēe bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь Сам даёт понимание этой торговли Именем и Сам соединяет торговцев Именем со Своим единством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3507,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40831,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੧ ॥",
          "roman": "salok mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40832,
          "is_rahao": false,
          "gurmukhi": "ਵੇਲਿ ਪਿੰਞਾਇਆ ਕਤਿ ਵੁਣਾਇਆ ॥",
          "roman": "vēl piñāiā kat vuṇāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хлопок прокатывают и очищают, затем прядут и ткут из него ткань."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40833,
          "is_rahao": false,
          "gurmukhi": "ਕਟਿ ਕੁਟਿ ਕਰਿ ਖੁੰਬਿ ਚੜਾਇਆ ॥",
          "roman": "kaṭ kuṭ kar khumb chaṛāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Затем ткань режут на куски, отбивают и кладут на форму для окраски или обработки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40834,
          "is_rahao": false,
          "gurmukhi": "ਲੋਹਾ ਵਢੇ ਦਰਜੀ ਪਾੜੇ ਸੂਈ ਧਾਗਾ ਸੀਵੈ ॥",
          "roman": "lohā vaḍhē darjī pāṛē sūī dhāgā sīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ножницы режут её, портной кроит её, а игла с нитью сшивает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40835,
          "is_rahao": false,
          "gurmukhi": "ਇਉ ਪਤਿ ਪਾਟੀ ਸਿਫਤੀ ਸੀਪੈ ਨਾਨਕ ਜੀਵਤ ਜੀਵੈ ॥",
          "roman": "iu pat pāṭī siftī sīpē nānak jīvat jīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так же, о Нанак, потерянная честь человека восстанавливается через восхваление Господа, и он начинает жить настоящей жизнью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40836,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਪੁਰਾਣਾ ਕਪੜੁ ਪਾਟੈ ਸੂਈ ਧਾਗਾ ਗੰਢੈ ॥",
          "roman": "hoe purāṇā kapaṛ pāṭē sūī dhāgā gaṇḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Став старой, ткань рвётся; игла и нить снова соединяют её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40837,
          "is_rahao": false,
          "gurmukhi": "ਮਾਹੁ ਪਖੁ ਕਿਹੁ ਚਲੈ ਨਾਹੀ ਘੜੀ ਮੁਹਤੁ ਕਿਛੁ ਹੰਢੈ ॥",
          "roman": "māh pakh kih chalē nāhī ghaṛī muhat kichh haṇḍhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но такая заштопанная старая ткань не держится даже месяц или полмесяца; она служит лишь немного, всего час-другой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
