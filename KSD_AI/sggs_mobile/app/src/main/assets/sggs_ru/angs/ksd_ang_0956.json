{
  "ang": 956,
  "shabads": [
    {
      "shabad_id": 3507,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40838,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਪੁਰਾਣਾ ਹੋਵੈ ਨਾਹੀ ਸੀਤਾ ਕਦੇ ਨ ਪਾਟੈ ॥",
          "roman": "sach purāṇā hovē nāhī sītā kadē na pāṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истина не стареет; сшитое истиной никогда не рвётся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40839,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਾਹਿਬੁ ਸਚੋ ਸਚਾ ਤਿਚਰੁ ਜਾਪੀ ਜਾਪੈ ॥੧॥",
          "roman": "Nānak sāhib sacho sachā tichar jāpī jāpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Владыка истинный, совершенно истинный; Он познаётся лишь тогда, когда Его помнят и повторяют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3508,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40840,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40841,
          "is_rahao": false,
          "gurmukhi": "ਸਚ ਕੀ ਕਾਤੀ ਸਚੁ ਸਭੁ ਸਾਰੁ ॥",
          "roman": "sach kī kātī sach sabh sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если ножом будет Имя Бога, и само Имя Бога будет всем железом этого ножа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40842,
          "is_rahao": false,
          "gurmukhi": "ਘਾੜਤ ਤਿਸ ਕੀ ਅਪਰ ਅਪਾਰ ॥",
          "roman": "ghāṛat tis kī apar apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то отделка этого ножа бывает несравненно прекрасной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40843,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੇ ਸਾਣ ਰਖਾਈ ਲਾਇ ॥",
          "roman": "sabdē sāṇ rakhāī lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот нож затачивается, приложенный к точилу Слова Сатгуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40844,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਕੀ ਥੇਕੈ ਵਿਚਿ ਸਮਾਇ ॥",
          "roman": "guṇ kī thēkē vich samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и пребывает вложенным в ножны достоинств Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40845,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਦਾ ਕੁਠਾ ਹੋਵੈ ਸੇਖੁ ॥",
          "roman": "tis dā kuṭhā hovē sēkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если шейх окажется заколотым этим ножом, то есть если его жизнь будет сформирована Именем Бога, Словом Сатгуру и восхвалением Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40846,
          "is_rahao": false,
          "gurmukhi": "ਲੋਹੂ ਲਬੁ ਨਿਕਥਾ ਵੇਖੁ ॥",
          "roman": "lohū lab nikthā vēkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тогда кровь жадности обязательно выйдет из него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40847,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਹਲਾਲੁ ਲਗੈ ਹਕਿ ਜਾਇ ॥",
          "roman": "hoi halāl lagē hak jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так, став халал, он соединяется с вечным Богом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40848,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਰਿ ਦੀਦਾਰਿ ਸਮਾਇ ॥੨॥",
          "roman": "Nānak dar dīdār samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "и, о Нанак, достигнув двери Бога, растворяется в Его видении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3509,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40849,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40850,
          "is_rahao": false,
          "gurmukhi": "ਕਮਰਿ ਕਟਾਰਾ ਬੰਕੁੜਾ ਬੰਕੇ ਕਾ ਅਸਵਾਰੁ ॥",
          "roman": "kamar kaṭārā bankuṛā bankē kā asvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть на поясе будет красивый кинжал и человек будет всадником на красивом коне,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40851,
          "is_rahao": false,
          "gurmukhi": "ਗਰਬੁ ਨ ਕੀਜੈ ਨਾਨਕਾ ਮਤੁ ਸਿਰਿ ਆਵੈ ਭਾਰੁ ॥੩॥",
          "roman": "garab na kījē Nānakā mat sir āvē bhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "всё же, о Нанак, не следует гордиться: как знать, вдруг человек упадёт головой вниз, и вся тяжесть придётся ему на голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3510,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40852,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40853,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਤਸੰਗਤਿ ਸਬਦਿ ਮਿਲੈ ਜੋ ਗੁਰਮੁਖਿ ਚਲੈ ॥",
          "roman": "so satsangat sabad milē jo gurmukh chalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кто идёт по повелению Гуру, приходит в Садх-сангат и соединяется со Словом Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40854,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਧਿਆਇਨਿ ਸੇ ਸਚੇ ਜਿਨ ਹਰਿ ਖਰਚੁ ਧਨੁ ਪਲੈ ॥",
          "roman": "sach dhiāin se sachē jin har kharach dhan pallē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, у кого в запасе есть богатство Имени Бога как расход на путь жизни, помнят вечного Бога и становятся Его образом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40855,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਸੋਹਨਿ ਗੁਣ ਗਾਵਦੇ ਗੁਰਮਤਿ ਅਚਲੈ ॥",
          "roman": "bhagat sohan guṇ gāvdē gurmat achalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Преданные, воспевая достоинства Бога, прекрасны; приняв наставление Сатгуру, они становятся непоколебимыми."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40856,
          "is_rahao": false,
          "gurmukhi": "ਰਤਨ ਬੀਚਾਰੁ ਮਨਿ ਵਸਿਆ ਗੁਰ ਕੈ ਸਬਦਿ ਭਲੈ ॥",
          "roman": "ratan bīchār man vasiā gur kē sabad bhalē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через прекрасное Слово Сатгуру в их уме поселяется размышление о драгоценном Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40857,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਮੇਲਿ ਮਿਲਾਇਦਾ ਆਪੇ ਦੇਇ ਵਡਿਆਈ ॥੧੯॥",
          "roman": "āpē mēl milāidā āpē dēi vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог Сам соединяет их с Собою и Сам дарует им славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3511,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40858,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੩ ॥",
          "roman": "salok mahlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40859,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਅੰਦਰਿ ਸਭੁ ਕੋ ਕੋਇ ਨਿਰਾਸਾ ਹੋਇ ॥",
          "roman": "āsā andar sabh ko koi nirāsā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Каждое существо находится в надеждах; редок тот, кто остаётся свободным от надежд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40860,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜੋ ਮਰਿ ਜੀਵਿਆ ਸਹਿਲਾ ਆਇਆ ਸੋਇ ॥੧॥",
          "roman": "Nānak jo mar jīviā sahilā āiā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто умер для надежд и живёт в поминании Бога, пришёл в мир плодотворно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3512,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40861,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੩ ॥",
          "roman": "mahlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40862,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਕਿਛੁ ਆਸਾ ਹਥਿ ਹੈ ਕੇਉ ਨਿਰਾਸਾ ਹੋਇ ॥",
          "roman": "nā kichh āsā hath hē kio nirāsā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У надежды нет никакой силы в руках, чтобы самой ловить существ; поэтому и своими усилиями человек не может освободиться от надежды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40863,
          "is_rahao": false,
          "gurmukhi": "ਕਿਆ ਕਰੇ ਏਹ ਬਪੁੜੀ ਜਾਂ ਭੋੁਲਾਏ ਸੋਇ ॥੨॥",
          "roman": "kiā karē ēh bapuṛī jāṅ bholāē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Что может сделать эта бедная надежда? Заблуждение наводит Сам тот Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3513,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40864,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40865,
          "is_rahao": false,
          "gurmukhi": "ਧ੍ਰਿਗੁ ਜੀਵਣੁ ਸੰਸਾਰ ਸਚੇ ਨਾਮ ਬਿਨੁ ॥",
          "roman": "dhrig jīvaṇ sansār sachē nām bin",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без поминания Имени вечного Бога жизнь в мире достойна порицания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40866,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਦਾਤਾ ਦਾਤਾਰ ਨਿਹਚਲੁ ਏਹੁ ਧਨੁ ॥",
          "roman": "prabh dātā dātār nihchal ēh dhan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог — податель, дарующий все дары; это богатство Его Имени никогда не гибнет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40867,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਆਰਾਧੇ ਨਿਰਮਲੁ ਸੋਇ ਜਨੁ ॥",
          "roman": "sās sās ārādhē nirmal soi jan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чист тот человек, кто помнит Бога с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40868,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਅਗਮੁ ਰਸਨਾ ਏਕੁ ਭਨੁ ॥",
          "roman": "antarjāmī agam rasnā ēk bhan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Языком произноси имя Единого, который знает сердца и недостижим для существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40869,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿ ਰਹਿਆ ਸਰਬਤਿ ਨਾਨਕੁ ਬਲਿ ਜਾਈ ॥੨੦॥",
          "roman": "rav rahiā sarbat Nānak bal jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак жертвует собой тому Богу, который пребывает во всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3514,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40870,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ਮਃ ੧ ॥",
          "roman": "salok mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40871,
          "is_rahao": false,
          "gurmukhi": "ਸਰਵਰ ਹੰਸ ਧੁਰੇ ਹੀ ਮੇਲਾ ਖਸਮੈ ਏਵੈ ਭਾਣਾ ॥",
          "roman": "sarvar hans dhurē hī mēlā khasmē ēvē bhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Связь Гуру-саровора и гурмукха-лебедя существует изначально; Владыке-Богу это угодно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40872,
          "is_rahao": false,
          "gurmukhi": "ਸਰਵਰ ਅੰਦਰਿ ਹੀਰਾ ਮੋਤੀ ਸੋ ਹੰਸਾ ਕਾ ਖਾਣਾ ॥",
          "roman": "sarvar andar hīrā motī so hansā kā khāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Гуру-сароваре находятся алмазы и жемчуг хваления Бога; это пища хансов-гурмукхов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40873,
          "is_rahao": false,
          "gurmukhi": "ਬਗੁਲਾ ਕਾਗੁ ਨ ਰਹਈ ਸਰਵਰਿ ਜੇ ਹੋਵੈ ਅਤਿ ਸਿਆਣਾ ॥",
          "roman": "bagulā kāg na rahī sarvar jē hovē at siāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Цапля и ворона, то есть манмухи, как бы ни были умны, не могут оставаться в этом сароваре, в общении Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40874,
          "is_rahao": false,
          "gurmukhi": "ਓਨਾ ਰਿਜਕੁ ਨ ਪਇਓ ਓਥੈ ਓਨੑਾ ਹੋਰੋ ਖਾਣਾ ॥",
          "roman": "onā rijak na pēo othē onhā horo khāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Их пропитания там нет; их пища совсем иная."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40875,
          "is_rahao": false,
          "gurmukhi": "ਸਚਿ ਕਮਾਣੈ ਸਚੋ ਪਾਈਐ ਕੂੜੈ ਕੂੜਾ ਮਾਣਾ ॥",
          "roman": "sach kamāṇē sacho pāīē kūṛē kūṛā māṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если совершать труд поминания вечного Бога, обретается вечный Бог; гордость от заработка лжи тоже ложна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40876,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਨ ਕੌ ਸਤਿਗੁਰੁ ਮਿਲਿਆ ਜਿਨਾ ਧੁਰੇ ਪੈਯਾ ਪਰਵਾਣਾ ॥੧॥",
          "roman": "Nānak tin kau satgur miliā jinā dhurē pēyā parvāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Сатгуру встречается лишь тем, кому от начала пришло повеление Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3515,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40877,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੧ ॥",
          "roman": "mahlā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махла 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40878,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬੁ ਮੇਰਾ ਉਜਲਾ ਜੇ ਕੋ ਚਿਤਿ ਕਰੇਇ ॥",
          "roman": "sāhib mērā ujalā jē ko chit karēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой Владыка-Бог чист; кто помещает Его в сердце, тот тоже становится чистым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40879,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋਈ ਸੇਵੀਐ ਸਦਾ ਸਦਾ ਜੋ ਦੇਇ ॥",
          "roman": "Nānak soī sēvīai sadā sadā jo dēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, следует поминать того Бога, который всегда дарует дары."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40880,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੋਈ ਸੇਵੀਐ ਜਿਤੁ ਸੇਵਿਐ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "Nānak soī sēvīai jit sēviē dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, следует поминать того Бога, при поминании которого уходит страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40881,
          "is_rahao": false,
          "gurmukhi": "ਅਵਗੁਣ ਵੰਞਨਿ ਗੁਣ ਰਵਹਿ ਮਨਿ ਸੁਖੁ ਵਸੈ ਆਇ ॥੨॥",
          "roman": "avguṇ vañjan guṇ ravah man sukh vasē āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пороки удаляются, добродетели поселяются в сердце, и мир приходит в ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3516,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 40882,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40883,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਆਪਿ ਵਰਤਦਾ ਆਪਿ ਤਾੜੀ ਲਾਈਅਨੁ ॥",
          "roman": "āpē āp vartdā āp tāṛī lāīan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В творении Бог Сам повсюду присутствует; Он Сам пребывает скрыто, словно в созерцательном погружении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40884,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਹੀ ਉਪਦੇਸਦਾ ਗੁਰਮੁਖਿ ਪਤੀਆਈਅਨੁ ॥",
          "roman": "āpē hī updesdā gurmukh patīāīan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Став образом Гуру, Он Сам даёт наставление; через Гуру Он Сам убеждает творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40885,
          "is_rahao": false,
          "gurmukhi": "ਇਕਿ ਆਪੇ ਉਝੜਿ ਪਾਇਅਨੁ ਇਕਿ ਭਗਤੀ ਲਾਇਅਨੁ ॥",
          "roman": "ik āpē ujhaṛ pāian ik bhagtī lāian",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Одних существ Он Сам увёл на ложный путь, а других Сам привёл к преданному служению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40886,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਆਪਿ ਬੁਝਾਏ ਸੋ ਬੁਝਸੀ ਆਪੇ ਨਾਇ ਲਾਈਅਨੁ ॥",
          "roman": "jis āp bujhāē so bujhsī āpē nāi lāīan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кому Бог Сам даёт понимание, тот и понимает правильный путь; Он Сам направил творение к Своему Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 40887,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਈਐ ਸਚੀ ਵਡਿਆਈ ॥੨੧॥੧॥ ਸੁਧੁ ॥",
          "roman": "Nānak nām dhiāīai sachī vaḍiāī. 21.1. sudh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, следует поминать Имя Бога; это и есть вечная слава. 21.1. Судх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
