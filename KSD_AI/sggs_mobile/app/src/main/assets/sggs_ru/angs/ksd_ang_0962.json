{
  "ang": 962,
  "shabads": [
    {
      "shabad_id": 3544,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41107,
          "is_rahao": false,
          "gurmukhi": "ਤਿਥੈ ਤੂ ਸਮਰਥੁ ਜਿਥੈ ਕੋਇ ਨਾਹਿ ॥",
          "roman": "tithē tū samrath jithē koi nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, там, где нет никого другого, способного помочь, Ты один способен помочь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41108,
          "is_rahao": false,
          "gurmukhi": "ਓਥੈ ਤੇਰੀ ਰਖ ਅਗਨੀ ਉਦਰ ਮਾਹਿ ॥",
          "roman": "othē terī rakh agnī udar māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже в огне материнского чрева живое существо имеет только Твою защиту и опору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41109,
          "is_rahao": false,
          "gurmukhi": "ਸੁਣਿ ਕੈ ਜਮ ਕੇ ਦੂਤ ਨਾਇ ਤੇਰੈ ਛਡਿ ਜਾਹਿ ॥",
          "roman": "suṇ kē jam kē dūt nāeṅ terē chhaḍ jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Услышав Твоё Имя, посланцы смерти не приближаются и, по благословению Твоего Имени, уходят, оставив живое существо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41110,
          "is_rahao": false,
          "gurmukhi": "ਭਉਜਲੁ ਬਿਖਮੁ ਅਸਗਾਹੁ ਗੁਰ ਸਬਦੀ ਪਾਰਿ ਪਾਹਿ ॥",
          "roman": "bhaujal bikham asgāh gur sabdī pār pāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Трудный и бездонный океан мира живые существа пересекают при помощи Слова Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41111,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨ ਕਉ ਲਗੀ ਪਿਆਸ ਅੰਮ੍ਰਿਤੁ ਸੇਇ ਖਾਹਿ ॥",
          "roman": "jin kau lagī piās amrit sēi khāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только те вкушают нектарную воду Имени, дающую духовную жизнь, в ком возникла жажда этого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41112,
          "is_rahao": false,
          "gurmukhi": "ਕਲਿ ਮਹਿ ਏਹੋ ਪੁੰਨੁ ਗੁਣ ਗੋਵਿੰਦ ਗਾਹਿ ॥",
          "roman": "kal meh ēho punn guṇ govind gāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В этом мире они считают памятование Имени самым добрым делом и поют добродетели Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41113,
          "is_rahao": false,
          "gurmukhi": "ਸਭਸੈ ਨੋ ਕਿਰਪਾਲੁ ਸਮੑਾਲੇ ਸਾਹਿ ਸਾਹਿ ॥",
          "roman": "sabhsē no kirpāl samāle sāh sāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милостивый Господь заботится о каждом живом существе с каждым дыханием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41114,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਥਾ ਕੋਇ ਨ ਜਾਇ ਜਿ ਆਵੈ ਤੁਧੁ ਆਹਿ ॥੯॥",
          "roman": "birthā koi na jāe ji āvē tudh āh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, тот, кто приходит в Твоё прибежище, не уходит от Твоих дверей пустым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3545,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41115,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41116,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜਾ ਤਿਸੁ ਨ ਬੁਝਾਇਹੁ ਪਾਰਬ੍ਰਹਮ ਨਾਮੁ ਦੇਹੁ ਆਧਾਰੁ ॥",
          "roman": "dūjā tis na bujhāeh pārbrahm nām dēh ādhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Парабрахман, тому человеку, которому Ты даёшь опору Своего Имени, Ты не позволяешь видеть какую-либо иную опору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41117,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮੁ ਅਗੋਚਰੁ ਸਾਹਿਬੋ ਸਮਰਥੁ ਸਚੁ ਦਾਤਾਰੁ ॥",
          "roman": "agam agochar sāhibo samrath sach dātār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты недостижим, за пределами досягаемости чувств, Ты всемогущий истинный Владыка, вечно пребывающий Даритель."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41118,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਨਿਹਚਲੁ ਨਿਰਵੈਰੁ ਸਚੁ ਸਚਾ ਤੁਧੁ ਦਰਬਾਰੁ ॥",
          "roman": "tū nihchal nirvēr sach sachā tudh darbār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты неколебим, свободен от вражды, истинный; Твой дворец вечно пребывающий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41119,
          "is_rahao": false,
          "gurmukhi": "ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈਐ ਅੰਤੁ ਨ ਪਾਰਾਵਾਰੁ ॥",
          "roman": "kīmat kahaṇ na jāīē ant na pārāvār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твою цену невозможно выразить; невозможно постичь ни Твой конец, ни Твои пределы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41120,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਛੋਡਿ ਹੋਰੁ ਜਿ ਮੰਗਣਾ ਸਭੁ ਬਿਖਿਆ ਰਸ ਛਾਰੁ ॥",
          "roman": "prabh chhoḍ hor j maṅgṇā sabh bikhiā ras chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Просить иные вещи, забыв Бога, — всё это вкусы майи, подобные пеплу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41121,
          "is_rahao": false,
          "gurmukhi": "ਸੇ ਸੁਖੀਏ ਸਚੁ ਸਾਹ ਸੇ ਜਿਨ ਸਚਾ ਬਿਉਹਾਰੁ ॥",
          "roman": "sē sukhīē sach sāh sē jin sachā biuhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поистине счастливы те люди, и они истинные, вечно пребывающие богачи, кто ведёт торговлю вечно пребывающим Именем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41122,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਾ ਲਗੀ ਪ੍ਰੀਤਿ ਪ੍ਰਭ ਨਾਮ ਸਹਜ ਸੁਖ ਸਾਰੁ ॥",
          "roman": "jinā lagī prīt prabh nām sahaj sukh sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем, чья любовь утвердилась в Имени Господа, достаётся высший мир духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41123,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਇਕੁ ਆਰਾਧੇ ਸੰਤਨ ਰੇਣਾਰੁ ॥੧॥",
          "roman": "Nānak ik ārādhē santan rēṇār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такие люди, пребывая в пыли стоп гурмукхов, поклоняются Единому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3546,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41124,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41125,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਸੂਖ ਬਿਸ੍ਰਾਮ ਨਿਤ ਹਰਿ ਕਾ ਕੀਰਤਨੁ ਗਾਇ ॥",
          "roman": "anad sūkh bisrām nit har kā kīrtan gāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через пение хвалы Господу всегда сохраняются радость, покой и умиротворение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41126,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰ ਸਿਆਣਪ ਛਾਡਿ ਦੇਹਿ ਨਾਨਕ ਉਧਰਸਿ ਨਾਇ ॥੨॥",
          "roman": "avar siāṇap chhāḍ dēh Nānak udhras nāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, оставь прочие хитрости и мудрования: по благословению Имени ты переправишься через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3547,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41127,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41128,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਬਹੁਤੁ ਘਿਣਾਵਣੇ ॥",
          "roman": "nā tū āvēṅ vas bahut ghiṇāvaṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты не попадаешь под власть человека от множества показных мольб и униженных просьб."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41129,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਬੇਦ ਪੜਾਵਣੇ ॥",
          "roman": "nā tū āvēṅ vas bēd paṛāvaṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не попадаешь под власть человека через чтение и преподавание Вед."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41130,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਤੀਰਥਿ ਨਾਈਐ ॥",
          "roman": "nā tū āvēṅ vas tīrath nāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не попадаешь под власть человека через омовения в местах паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41131,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਧਰਤੀ ਧਾਈਐ ॥",
          "roman": "nā tū āvēṅ vas dhartī dhāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не попадаешь под власть человека, даже если он, подобно странствующему садху, обежит всю землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41132,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਕਿਤੈ ਸਿਆਣਪੈ ॥",
          "roman": "nā tū āvēṅ vas kitē siāṇpē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не попадаешь под власть человека никакой хитростью или рассудочной ловкостью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41133,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਤੂ ਆਵਹਿ ਵਸਿ ਬਹੁਤਾ ਦਾਨੁ ਦੇ ॥",
          "roman": "nā tū āvēṅ vas bahutā dān dē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты не попадаешь под власть человека даже через раздачу больших пожертвований."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41134,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕੋ ਤੇਰੈ ਵਸਿ ਅਗਮ ਅਗੋਚਰਾ ॥",
          "roman": "sabh ko terē vas agam agocharā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О недостижимый и непостижимый Господь, каждое живое существо находится под Твоей властью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41135,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਭਗਤਾ ਕੈ ਵਸਿ ਭਗਤਾ ਤਾਣੁ ਤੇਰਾ ॥੧੦॥",
          "roman": "tū bhagtā kē vas bhagtā tāṇ terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты благосклонен только к тем, кто всегда памятует о Тебе, ибо у Твоих преданных есть лишь Твоя опора."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3548,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41136,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41137,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵੈਦੁ ਆਪਿ ਨਾਰਾਇਣੁ ॥",
          "roman": "āpē vēd āp nārāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Господь является врачом, исцеляющим болезни души."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41138,
          "is_rahao": false,
          "gurmukhi": "ਏਹਿ ਵੈਦ ਜੀਅ ਕਾ ਦੁਖੁ ਲਾਇਣ ॥",
          "roman": "ēh vēd jīa kā dukh lāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти мирские лекари и лицемерные религиозные вожди, напротив, только прикрепляют к душе страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41139,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਅੰਮ੍ਰਿਤ ਰਸੁ ਖਾਇਣ ॥",
          "roman": "gur kā sabad amrit ras khāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для исцеления болезней души пригодной пищей является Слово Сатгуру, в котором ощущается вкус нектара."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41140,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸੁ ਮਨਿ ਵਸੈ ਤਿਸ ਕੇ ਸਭਿ ਦੂਖ ਮਿਟਾਇਣ ॥੧॥",
          "roman": "Nānak jis man vasē tis kē sabh dūkh miṭāiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, у того человека, в чьём уме пребывает Слово Гуру, все страдания исчезают."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3549,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41141,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41142,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮਿ ਉਛਲੈ ਹੁਕਮੇ ਰਹੈ ॥",
          "roman": "hukam uchhalē hukamē rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По повелению Господа живое существо мечется, и по Его же повелению оно остаётся устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41143,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਦੁਖੁ ਸੁਖੁ ਸਮ ਕਰਿ ਸਹੈ ॥",
          "roman": "hukamē dukh sukh sam kar sahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа живое существо переносит страдание и счастье, считая их равными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41144,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਨਾਮੁ ਜਪੈ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "hukamē nām japē din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа человек день и ночь повторяет Его Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41145,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਸ ਨੋ ਹੋਵੈ ਦਾਤਿ ॥",
          "roman": "Nānak jis no hovē dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, так бывает с тем человеком, на кого Господь изливает Свою милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41146,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮਿ ਮਰੈ ਹੁਕਮੇ ਹੀ ਜੀਵੈ ॥",
          "roman": "hukam marē hukamē hī jīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа живое существо умирает, и в Его же повелении живёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41147,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਨਾਨੑਾ ਵਡਾ ਥੀਵੈ ॥",
          "roman": "hukamē nānhā vaḍā thīvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа оно сначала бывает малым, а затем становится большим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41148,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਸੋਗ ਹਰਖ ਆਨੰਦ ॥",
          "roman": "hukamē sog harakh ānand",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа живому существу приходят забота, радость и блаженство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41149,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਜਪੈ ਨਿਰੋਧਰ ਗੁਰਮੰਤ ॥",
          "roman": "hukamē japē nirodhar gurmant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В повелении Господа живое существо повторяет наставление Гуру, способное отстранить пороки и страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41150,
          "is_rahao": false,
          "gurmukhi": "ਹੁਕਮੇ ਆਵਣੁ ਜਾਣੁ ਰਹਾਏ ॥",
          "roman": "hukamē āvaṇ jāṇ rahāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Своём повелении Господь прекращает его приход и уход, рождение и смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41151,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਾ ਕਉ ਭਗਤੀ ਲਾਏ ॥੨॥",
          "roman": "Nānak jā kau bhagtī lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это происходит с тем человеком, кого Господь соединяет со Своей преданностью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3550,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41152,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41153,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਤਿਸੁ ਢਾਢੀ ਕੁਰਬਾਣੁ ਜਿ ਤੇਰਾ ਸੇਵਦਾਰੁ ॥",
          "roman": "hau tis ḍhāḍhī kurbāṇ j terā sēvdār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, я жертвую собой ради того дхадхи, певца Твоей славы, который совершает Твоё служение и преданность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41154,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਤਿਸੁ ਢਾਢੀ ਬਲਿਹਾਰ ਜਿ ਗਾਵੈ ਗੁਣ ਅਪਾਰ ॥",
          "roman": "hau tis ḍhāḍhī balihār j gāvē guṇ apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву тому дхадхи, который поёт Твои бесконечные добродетели."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41155,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਢਾਢੀ ਧਨੁ ਧੰਨੁ ਜਿਸੁ ਲੋੜੇ ਨਿਰੰਕਾਰੁ ॥",
          "roman": "so ḍhāḍhī dhan dhann jis loṛē nirankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословен тот дхадхи, которого любит Сам Бесформенный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41156,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਢਾਢੀ ਭਾਗਠੁ ਜਿਸੁ ਸਚਾ ਦੁਆਰ ਬਾਰੁ ॥",
          "roman": "so ḍhāḍhī bhāgaṭh jis sachā duār bār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Счастлив тот дхадхи, которому открыт истинный двор Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41157,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਢਾਢੀ ਤੁਧੁ ਧਿਆਇ ਕਲਾਣੇ ਦਿਨੁ ਰੈਣਾਰ ॥",
          "roman": "oh ḍhāḍhī tudh dhiāe kalāṇē din rēṇār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, такой счастливый дхадхи всегда медитирует на Тебя и день и ночь поёт Твои хвалы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41158,
          "is_rahao": false,
          "gurmukhi": "ਮੰਗੈ ਅੰਮ੍ਰਿਤ ਨਾਮੁ ਨ ਆਵੈ ਕਦੇ ਹਾਰਿ ॥",
          "roman": "maṅgē amrit nām na āvē kadē hār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он просит у Тебя нектарную воду Имени, дающую духовную жизнь, и не приходит к Тебе проигравшим человеческое рождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41159,
          "is_rahao": false,
          "gurmukhi": "ਕਪੜੁ ਭੋਜਨੁ ਸਚੁ ਰਹਦਾ ਲਿਵੈ ਧਾਰ ॥",
          "roman": "kapaṛ bhojan sach rahdā livē dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твоё вечно пребывающее Имя является для него и одеждой, прикрывающей его, и духовной пищей; он постоянно остаётся соединённым с Твоей памятью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41160,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਢਾਢੀ ਗੁਣਵੰਤੁ ਜਿਸ ਨੋ ਪ੍ਰਭ ਪਿਆਰੁ ॥੧੧॥",
          "roman": "so ḍhāḍhī guṇvant jis no prabh piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинно добродетелен тот дхадхи, которому дарована любовь Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
