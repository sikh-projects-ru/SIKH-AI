{
  "ang": 963,
  "shabads": [
    {
      "shabad_id": 3551,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41161,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок пятого Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41162,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਾਣੀ ਅਮਿਉ ਰਸੁ ਅੰਮ੍ਰਿਤੁ ਹਰਿ ਕਾ ਨਾਉ ॥",
          "roman": "amrit bāṇī amiu ras amrit har kā nāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Господа — вода духовной жизни, оно даёт вкус амрита; через Бани Сатгуру обретается этот животворный нектар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41163,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਹਿਰਦੈ ਸਿਮਰਿ ਹਰਿ ਆਠ ਪਹਰ ਗੁਣ ਗਾਉ ॥",
          "roman": "man tan hirdē simar har āṭh pahar guṇ gāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В уме, теле и сердце помни Господа и все восемь страж суток воспевай Его славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41164,
          "is_rahao": false,
          "gurmukhi": "ਉਪਦੇਸੁ ਸੁਣਹੁ ਤੁਮ ਗੁਰਸਿਖਹੁ ਸਚਾ ਇਹੈ ਸੁਆਉ ॥",
          "roman": "updes suṇh tum gursikho sachā ihē suāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О гур-сикхи, слушайте это наставление: именно это — истинная цель жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41165,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਸਫਲੁ ਹੋਇ ਮਨ ਮਹਿ ਲਾਇਹੁ ਭਾਉ ॥",
          "roman": "janam padārath safal hoi man meh lāih bhāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Утвердите в уме любовь к Господу, и драгоценный дар человеческой жизни станет плодотворным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41166,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨਦੁ ਘਣਾ ਪ੍ਰਭ ਜਪਤਿਆ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "sūkh sahaj ānand ghaṇā prabh japatiā dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При памятовании о Господе страдание уходит, а покой, духовная устойчивость и великая радость обретаются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41167,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਜਪਤ ਸੁਖੁ ਊਪਜੈ ਦਰਗਹ ਪਾਈਐ ਥਾਉ ॥੧॥",
          "roman": "nānak nām japat sukh ūpjē dargah pāīē thāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, повторяя Имя, человек обретает покой в этом мире и место в присутствии Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3552,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41168,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41169,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਧਿਆਈਐ ਗੁਰੁ ਪੂਰਾ ਮਤਿ ਦੇਇ ॥",
          "roman": "nānak nām dhiāīai gur pūrā mat dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, полный Гуру даёт такое наставление: следует вспоминать Имя Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41170,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਜਪ ਤਪ ਸੰਜਮੋ ਭਾਣੈ ਹੀ ਕਢਿ ਲੇਇ ॥",
          "roman": "bhāṇē jap tap sanjamo bhāṇē hī kaḍh lei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Джап, тап и самообуздание происходят по Его воле; и по Своей воле Господь выводит живых существ из этих обрядовых дел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41171,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਜੋਨਿ ਭਵਾਈਐ ਭਾਣੈ ਬਖਸ ਕਰੇਇ ॥",
          "roman": "bhāṇē jon bhavāīē bhāṇē bakhas karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По воле Господа живое существо блуждает по лонам рождений, и по Его воле Господь дарует ему милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41172,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਦੁਖੁ ਸੁਖੁ ਭੋਗੀਐ ਭਾਣੈ ਕਰਮ ਕਰੇਇ ॥",
          "roman": "bhāṇē dukh sukh bhogīē bhāṇē karam karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Его воле приходится переживать страдание и радость; по Своей воле Господь оказывает милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41173,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਮਿਟੀ ਸਾਜਿ ਕੈ ਭਾਣੈ ਜੋਤਿ ਧਰੇਇ ॥",
          "roman": "bhāṇē miṭī sāj kē bhāṇē jot dharei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Своей воле Господь создаёт тело из земли и по Своей воле помещает в него жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41174,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਭੋਗ ਭੋਗਾਇਦਾ ਭਾਣੈ ਮਨਹਿ ਕਰੇਇ ॥",
          "roman": "bhāṇē bhog bhogāidā bhāṇē maneh karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Своей воле Он побуждает живых существ к наслаждениям, и по Своей воле удерживает их от них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41175,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਨਰਕਿ ਸੁਰਗਿ ਅਉਤਾਰੇ ਭਾਣੈ ਧਰਣਿ ਪਰੇਇ ॥",
          "roman": "bhāṇē narak surag autārei bhāṇē dharaṇ parei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По Своей воле Господь помещает кого-то в ад, кого-то в рай; по Его воле живое существо погибает и падает на землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41176,
          "is_rahao": false,
          "gurmukhi": "ਭਾਣੈ ਹੀ ਜਿਸੁ ਭਗਤੀ ਲਾਏ ਨਾਨਕ ਵਿਰਲੇ ਹੇ ॥੨॥",
          "roman": "bhāṇē hī jis bhagtī lāe nānak virle he",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кого Господь по Своей воле соединяет с преданным служением, тот служит Ему; но, о Нанак, такие преданные очень редки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3553,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41177,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41178,
          "is_rahao": false,
          "gurmukhi": "ਵਡਿਆਈ ਸਚੇ ਨਾਮ ਕੀ ਹਉ ਜੀਵਾ ਸੁਣਿ ਸੁਣੇ ॥",
          "roman": "vaḍiāī sache nām kī hau jīvā suṇ suṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слушая снова и снова славу истинного Имени Господа, я оживаю, то есть обретаю духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41179,
          "is_rahao": false,
          "gurmukhi": "ਪਸੂ ਪਰੇਤ ਅਗਿਆਨ ਉਧਾਰੇ ਇਕ ਖਣੇ ॥",
          "roman": "pasū paret agiān udhāre ik khaṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Имя Господа в одно мгновение спасает тех, кто подобен животным, призракам и лишённым знания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41180,
          "is_rahao": false,
          "gurmukhi": "ਦਿਨਸੁ ਰੈਣਿ ਤੇਰਾ ਨਾਉ ਸਦਾ ਸਦ ਜਾਪੀਐ ॥",
          "roman": "dinas rēṇ terā nāo sadā sad jāpīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, днём и ночью, всегда и постоянно, следует повторять Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41181,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਸਨਾ ਭੁਖ ਵਿਕਰਾਲ ਨਾਇ ਤੇਰੈ ਧ੍ਰਾਪੀਐ ॥",
          "roman": "trisnā bhukh vikarāl nāe terē dhrāpīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через Твоё Имя насыщается и утихает страшная жажда и голод майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41182,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਸੋਗੁ ਦੁਖੁ ਵੰਞੈ ਜਿਸੁ ਨਾਉ ਮਨਿ ਵਸੈ ॥",
          "roman": "rog sog dukh vañjē jis nāo man vasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, в чьём уме поселяется Имя Господа, уходят болезнь пороков, тревога и страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41183,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਪਰਾਪਤਿ ਲਾਲੁ ਜੋ ਗੁਰ ਸਬਦੀ ਰਸੈ ॥",
          "roman": "tiseh parāpat lāl jo gur sabdī rasē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот драгоценный рубин Имени получает только тот, кто с любовью растворяется в Слове Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41184,
          "is_rahao": false,
          "gurmukhi": "ਖੰਡ ਬ੍ਰਹਮੰਡ ਬੇਅੰਤ ਉਧਾਰਣਹਾਰਿਆ ॥",
          "roman": "khaṇḍ brahmaṇḍ beant udhāraṇhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Спаситель бесчисленных существ во всех частях мира и вселенных!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41185,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਸੋਭਾ ਤੁਧੁ ਸਚੇ ਮੇਰੇ ਪਿਆਰਿਆ ॥੧੨॥",
          "roman": "terī sobhā tudh sache mere piāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный, вечносущий Господь, Твоя слава подобает только Тебе; Ты Сам знаешь Своё величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3554,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41186,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок пятого Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41187,
          "is_rahao": false,
          "gurmukhi": "ਮਿਤ੍ਰੁ ਪਿਆਰਾ ਨਾਨਕ ਜੀ ਮੈ ਛਡਿ ਗਵਾਇਆ ਰੰਗਿ ਕਸੁੰਭੈ ਭੁਲੀ ॥",
          "roman": "mitr piārā nānak jī mē chhaḍ gavāiā raṅg kasumbhē bhulī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я ошиблась, увлекшись цветом майи, подобным цвету касумбхи, и забыла, потеряла возлюбленного Друга-Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41188,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਸਜਣ ਕੀ ਮੈ ਕੀਮ ਨ ਪਉਦੀ ਹਉ ਤੁਧੁ ਬਿਨੁ ਅਢੁ ਨ ਲਹਦੀ ॥੧॥",
          "roman": "tau sajaṇ kī mē kīm na paudī hau tudh bin aḍh na lahdī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О возлюбленный Господь, в этой ошибке я не смогла понять Твою ценность; но без Тебя я не стою даже полдамри."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3555,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41189,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41190,
          "is_rahao": false,
          "gurmukhi": "ਸਸੁ ਵਿਰਾਇਣਿ ਨਾਨਕ ਜੀਉ ਸਸੁਰਾ ਵਾਦੀ ਜੇਠੋ ਪਉ ਪਉ ਲੂਹੈ ॥",
          "roman": "sas virāiṇ nānak jīo sasurā vādī jeṭho pau pau lūhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, неведение — враг живой души-невесты; привязанность к телу постоянно спорит и требует своего, а страх смерти снова и снова мучит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41191,
          "is_rahao": false,
          "gurmukhi": "ਹਭੇ ਭਸੁ ਪੁਣੇਦੇ ਵਤਨੁ ਜਾ ਮੈ ਸਜਣੁ ਤੂਹੈ ॥੨॥",
          "roman": "habhe bhas puṇede vatan jā mē sajaṇ tūhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь, если Ты станешь моим Другом, пусть все они хоть прах просеивают: они уже не смогут одолеть меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3556,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41192,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41193,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂ ਵੁਠਾ ਚਿਤਿ ਤਿਸੁ ਦਰਦੁ ਨਿਵਾਰਣੋ ॥",
          "roman": "jis tū vuṭhā chit tis darad nivāraṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, у того человека, в чьём сознании Ты поселяешься, Ты устраняешь боль и страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41194,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਤੂ ਵੁਠਾ ਚਿਤਿ ਤਿਸੁ ਕਦੇ ਨ ਹਾਰਣੋ ॥",
          "roman": "jis tū vuṭhā chit tis kade na hāraṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, в чьём сознании Ты поселяешься, никогда не проигрывает игру человеческой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41195,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਿਲਿਆ ਪੂਰਾ ਗੁਰੂ ਸੁ ਸਰਪਰ ਤਾਰਣੋ ॥",
          "roman": "jis miliā pūrā gurū so sarpar tāraṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кому встретился полный Гуру, Гуру непременно спасает от мирового океана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41196,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਲਾਏ ਸਚਿ ਤਿਸੁ ਸਚੁ ਸਮੑਾਲਣੋ ॥",
          "roman": "jis no lāe sach tis sach samālhaṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кого Гуру соединяет с вечносущим Господом, тот всегда хранит Господа в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41197,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਆਇਆ ਹਥਿ ਨਿਧਾਨੁ ਸੁ ਰਹਿਆ ਭਾਲਣੋ ॥",
          "roman": "jis āiā hath nidhān so rahiā bhālaṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, в чьи руки попадает сокровище Имени, прекращается блуждание в поисках майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41198,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਇਕੋ ਰੰਗੁ ਭਗਤੁ ਸੋ ਜਾਨਣੋ ॥",
          "roman": "jis no iko raṅg bhagat so jāṇaṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинным бхагатом считай того, в чьём уме вместо майи есть любовь только к одному Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41199,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਸਭਨਾ ਕੀ ਰੇਣੁ ਬਿਰਹੀ ਚਾਰਣੋ ॥",
          "roman": "oh sabhnā kī reṇ birhī chāraṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой любящий стопы Господа остаётся прахом у ног всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41200,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਤੇਰੇ ਚੋਜ ਵਿਡਾਣ ਸਭੁ ਤੇਰਾ ਕਾਰਣੋ ॥੧੩॥",
          "roman": "sabh tere choj viḍāṇ sabh terā kāraṇo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, всё это — Твои удивительные игры; всё это — Твоё собственное устроение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3557,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41201,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок пятого Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41202,
          "is_rahao": false,
          "gurmukhi": "ਉਸਤਤਿ ਨਿੰਦਾ ਨਾਨਕ ਜੀ ਮੈ ਹਭ ਵਞਾਈ ਛੋੜਿਆ ਹਭੁ ਕਿਝੁ ਤਿਆਗੀ ॥",
          "roman": "ustat nindā nānak jī mē habh vañāī chhoṛiā habh kijh tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я оставила и отбросила всё это: хвалу и порицание, называние одного хорошим, другого плохим; всё это я отвергла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41203,
          "is_rahao": false,
          "gurmukhi": "ਹਭੇ ਸਾਕ ਕੂੜਾਵੇ ਡਿਠੇ ਤਉ ਪਲੈ ਤੈਡੈ ਲਾਗੀ ॥੧॥",
          "roman": "habhe sāk kūṛāve ḍiṭhe tau palē tēḍē lāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я увидела, что все мирские связи ложны и не идут до конца; поэтому, о Господь, я ухватилась за Твой край."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3558,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41204,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41205,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਦੀ ਫਿਰਦੀ ਨਾਨਕ ਜੀਉ ਹਉ ਫਾਵੀ ਥੀਈ ਬਹੁਤੁ ਦਿਸਾਵਰ ਪੰਧਾ ॥",
          "roman": "firdī firdī nānak jīo hau fāvī thīī bahut disāvar pandhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, блуждая и проходя многие пути по чужим странам, я стала словно безумной и встревоженной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41206,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਹਉ ਸੁਖਿ ਸੁਖਾਲੀ ਸੁਤੀ ਜਾ ਗੁਰ ਮਿਲਿ ਸਜਣੁ ਮੈ ਲਧਾ ॥੨॥",
          "roman": "tā hau sukh sukhālī sutī jā gur mil sajaṇ mē ladhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но когда, встретив Сатгуру, я нашла возлюбленного Господа, тогда я уснула в великом покое, то есть внутри меня возник полный духовный आनंद."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
