{
  "ang": 964,
  "shabads": [
    {
      "shabad_id": 3559,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41207,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41208,
          "is_rahao": false,
          "gurmukhi": "ਸਭੇ ਦੁਖ ਸੰਤਾਪ ਜਾਂ ਤੁਧਹੁ ਭੁਲੀਐ ॥",
          "roman": "sabhē dukh santāp jāṅ tudhah bhulīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда, о Господь, мы отпадаем от Твоей памяти, ум охватывают все страдания и муки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41209,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਕੀਚਨਿ ਲਖ ਉਪਾਵ ਤਾਂ ਕਹੀ ਨ ਘੁਲੀਐ ॥",
          "roman": "jē kīchan lakh upāv tāṅ kahī na ghulīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если предпринять сотни тысяч иных усилий, никаким средством не получается освободиться от этих страданий и мук."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41210,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਵਿਸਰੈ ਨਾਉ ਸੁ ਨਿਰਧਨੁ ਕਾਂਢੀਐ ॥",
          "roman": "jis nō visrē nāo so nirdhan kāṅḍhīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того человека, кто забывает Naam Господа, называют бедняком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41211,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਵਿਸਰੈ ਨਾਉ ਸੋ ਜੋਨੀ ਹਾਂਢੀਐ ॥",
          "roman": "jis nō visrē nāo so jonī hāṅḍhīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто забывает Naam, тот скитается по рождениям, словно нищий, который бродит от двери к двери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41212,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਖਸਮੁ ਨ ਆਵੈ ਚਿਤਿ ਤਿਸੁ ਜਮੁ ਡੰਡੁ ਦੇ ॥",
          "roman": "jis khasam na āvē chit tis jam ḍaṇḍ dē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, в чьём сознании не появляется Господин-Господь, Джамрадж наказывает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41213,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਖਸਮੁ ਨ ਆਵੀ ਚਿਤਿ ਰੋਗੀ ਸੇ ਗਣੇ ॥",
          "roman": "jis khasam na āvī chit rogī sē gaṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Люди, в чьём сознании не появляется Господин-Господь, считаются больными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41214,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਖਸਮੁ ਨ ਆਵੀ ਚਿਤਿ ਸੁ ਖਰੋ ਅਹੰਕਾਰੀਆ ॥",
          "roman": "jis khasam na āvī chit so kharo ahaṅkārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, в чьём сознании не появляется Господин-Господь, бывает очень гордым и всё время держится за своё «я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41215,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਦੁਹੇਲਾ ਜਗਿ ਜਿਨਿ ਨਾਉ ਵਿਸਾਰੀਆ ॥੧੪॥",
          "roman": "soī duhēlā jag jin nāo visārīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно тот человек несчастен в мире, кто забыл Naam Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3560,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41216,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41217,
          "is_rahao": false,
          "gurmukhi": "ਤੈਡੀ ਬੰਦਸਿ ਮੈ ਕੋਇ ਨ ਡਿਠਾ ਤੂ ਨਾਨਕ ਮਨਿ ਭਾਣਾ ॥",
          "roman": "tēḍī bandas mē kōi na ḍiṭhā tū Nānak man bhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Гуру Нанак, ни одно твоё слово не кажется мне путами; напротив, я увидел тебя как того, кто мил моему сердцу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41218,
          "is_rahao": false,
          "gurmukhi": "ਘੋਲਿ ਘੁਮਾਈ ਤਿਸੁ ਮਿਤ੍ਰ ਵਿਚੋਲੇ ਜੈ ਮਿਲਿ ਕੰਤੁ ਪਛਾਣਾ ॥੧॥",
          "roman": "ghol ghumāī tis mitar vicholē jē mil kant pachhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я жертвую собой ради того любимого посредника, Гуру: встретив его, я познал своего Господина-Господа и вступил с Ним в связь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3561,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41219,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41220,
          "is_rahao": false,
          "gurmukhi": "ਪਾਵ ਸੁਹਾਵੇ ਜਾਂ ਤਉ ਧਿਰਿ ਜੁਲਦੇ ਸੀਸੁ ਸੁਹਾਵਾ ਚਰਣੀ ॥",
          "roman": "pāv suhāvē jāṅ tau dhir juldē sīs suhāvā charṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прекрасны те стопы, что идут к Тебе; благословенна та голова, что падает к Твоим стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41221,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖੁ ਸੁਹਾਵਾ ਜਾਂ ਤਉ ਜਸੁ ਗਾਵੈ ਜੀਉ ਪਇਆ ਤਉ ਸਰਣੀ ॥੨॥",
          "roman": "mukh suhāvā jāṅ tau jas gāvē jīo pēā tau sarṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прекрасны уста, когда они поют Твою хвалу; прекрасна душа, когда она приходит в Твоё прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3562,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41222,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41223,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਨਾਰੀ ਸਤਸੰਗਿ ਮੰਗਲੁ ਗਾਵੀਆ ॥",
          "roman": "mil nārī satsang mangal gāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Та душа-женщина, которая, присоединившись к Сатсангу, поёт песнь хвалы Господу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41224,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਕਾ ਹੋਆ ਬੰਧਾਨੁ ਬਹੁੜਿ ਨ ਧਾਵੀਆ ॥",
          "roman": "ghar kā hoā bandhān bahuṛ na dhāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "обретает порядок в доме своего тела, то есть все её органы познания приходят под её власть, и она больше не бежит за Майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41225,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਠੀ ਦੁਰਮਤਿ ਦੁਰਤੁ ਸੋਇ ਕੂੜਾਵੀਆ ॥",
          "roman": "binaṭhī durmat durat soi kūṛāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Изнутри неё исчезают дурной разум, грех и надежда на преходящие вещи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41226,
          "is_rahao": false,
          "gurmukhi": "ਸੀਲਵੰਤਿ ਪਰਧਾਨਿ ਰਿਦੈ ਸਚਾਵੀਆ ॥",
          "roman": "sīlavant pardhān ridē sachāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такая душа-женщина становится добронравной, уважаемой среди подруг, и в её сердце прочно пребывает любовь к Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41227,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਬਾਹਰਿ ਇਕੁ ਇਕ ਰੀਤਾਵੀਆ ॥",
          "roman": "antar bāhar ik ik rītāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри себя и во всей вселенной она видит одного только Господа; это и становится её способом жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41228,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਦਰਸਨ ਕੀ ਪਿਆਸ ਚਰਣ ਦਾਸਾਵੀਆ ॥",
          "roman": "man darsan kī piās charaṇ dāsāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В её уме остаётся жажда видения Господа, и она остаётся служанкой Его стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41229,
          "is_rahao": false,
          "gurmukhi": "ਸੋਭਾ ਬਣੀ ਸੀਗਾਰੁ ਖਸਮਿ ਜਾਂ ਰਾਵੀਆ ॥",
          "roman": "sobhā baṇī sīgār khasam jāṅ rāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Господин-Господь соединяет её с Собой, этот союз становится для неё славой и украшением."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41230,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲੀਆ ਆਇ ਸੰਜੋਗਿ ਜਾਂ ਤਿਸੁ ਭਾਵੀਆ ॥੧੫॥",
          "roman": "milīā āi sanjog jāṅ tis bhāvīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда эта душа-невеста становится Ему любима, благодатью силы Его соединения она сливается со светом Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3563,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41231,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41232,
          "is_rahao": false,
          "gurmukhi": "ਹਭਿ ਗੁਣ ਤੈਡੇ ਨਾਨਕ ਜੀਉ ਮੈ ਕੂ ਥੀਏ ਮੈ ਨਿਰਗੁਣ ਤੇ ਕਿਆ ਹੋਵੈ ॥",
          "roman": "habh guṇ tēḍē Nānak jīo mē kū thīē mē nirguṇ tē kiā hovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: о Господь, все достоинства принадлежат Тебе; они пришли ко мне от Тебя, а от меня, лишённого достоинств, ничего не может произойти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41233,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਜੇਵਡੁ ਦਾਤਾਰੁ ਨ ਕੋਈ ਜਾਚਕੁ ਸਦਾ ਜਾਚੋਵੈ ॥੧॥",
          "roman": "tau jēvaḍ dātār na kōī jāchak sadā jāchovē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет дарителя, равного Тебе; я, нищий, всегда должен просить только у Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3564,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41234,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41235,
          "is_rahao": false,
          "gurmukhi": "ਦੇਹ ਛਿਜੰਦੜੀ ਊਣ ਮਝੂਣਾ ਗੁਰਿ ਸਜਣਿ ਜੀਉ ਧਰਾਇਆ ॥",
          "roman": "dēh chhijandarī ūṇ majhūṇā gur sajaṇ jīo dharāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моё тело разрушалось, в сердце была пустота, и ум был полон тревоги, но любимый Сатгуру дал душе утешение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41236,
          "is_rahao": false,
          "gurmukhi": "ਹਭੇ ਸੁਖ ਸੁਹੇਲੜਾ ਸੁਤਾ ਜਿਤਾ ਜਗੁ ਸਬਾਇਆ ॥੨॥",
          "roman": "habhē sukh suhēlaṛā sutā jitā jag sabāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Теперь пришли все радости, я пребываю в покое, и мне кажется, будто я победил весь мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3565,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41237,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41238,
          "is_rahao": false,
          "gurmukhi": "ਵਡਾ ਤੇਰਾ ਦਰਬਾਰੁ ਸਚਾ ਤੁਧੁ ਤਖਤੁ ॥",
          "roman": "vaḍā tērā darbār sachā tudh takhat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, велик Твой двор, и Твой престол вечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41239,
          "is_rahao": false,
          "gurmukhi": "ਸਿਰਿ ਸਾਹਾ ਪਾਤਿਸਾਹੁ ਨਿਹਚਲੁ ਚਉਰੁ ਛਤੁ ॥",
          "roman": "sir sāhā pātisāh nihchal chaur chhat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твои чавр и царский зонт неколебимы; Ты — Царь над головами всех царей мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41240,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਭਾਵੈ ਪਾਰਬ੍ਰਹਮ ਸੋਈ ਸਚੁ ਨਿਆਉ ॥",
          "roman": "jo bhāvē pārbrahm soī sach niāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только тот суд непреложен, который угоден Парабрахману."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41241,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਭਾਵੈ ਪਾਰਬ੍ਰਹਮ ਨਿਥਾਵੇ ਮਿਲੈ ਥਾਉ ॥",
          "roman": "jē bhāvē pārbrahm nithāvē milē thāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если Ему угодно, то безопорные получают опору."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41242,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕੀਨੑੀ ਕਰਤਾਰਿ ਸਾਈ ਭਲੀ ਗਲ ॥",
          "roman": "jo kīnhī kartār sāī bhalī gal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для живых существ хорошо именно то, что Создатель Сам совершил для них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41243,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑੀ ਪਛਾਤਾ ਖਸਮੁ ਸੇ ਦਰਗਾਹ ਮਲ ॥",
          "roman": "jinī pachhātā khasam sē dargāh mal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто познал Господина-Господа и вошёл с Ним в связь, становятся борцами Его присутствия; никакой порок не может коснуться их."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41244,
          "is_rahao": false,
          "gurmukhi": "ਸਹੀ ਤੇਰਾ ਫੁਰਮਾਨੁ ਕਿਨੈ ਨ ਫੇਰੀਐ ॥",
          "roman": "sahī tērā furmān kinē na phērīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твой приказ всегда верен; никто из живых никогда не мог его отменить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41245,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਣ ਕਰਣ ਕਰੀਮ ਕੁਦਰਤਿ ਤੇਰੀਐ ॥੧੬॥",
          "roman": "kāraṇ karaṇ karīm kudrat tērīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Творец творения, о Милостивый к живым, вся эта природа создана Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3566,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41246,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41247,
          "is_rahao": false,
          "gurmukhi": "ਸੋਇ ਸੁਣੰਦੜੀ ਮੇਰਾ ਤਨੁ ਮਨੁ ਮਉਲਾ ਨਾਮੁ ਜਪੰਦੜੀ ਲਾਲੀ ॥",
          "roman": "soi suṇandarī mērā tan man maulā nām japandarī lālī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, слыша вести о Тебе, мои тело и ум зеленеют свежестью; повторяя Твой Naam, я наполняюсь румянцем радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41248,
          "is_rahao": false,
          "gurmukhi": "ਪੰਧਿ ਜੁਲੰਦੜੀ ਮੇਰਾ ਅੰਦਰੁ ਠੰਢਾ ਗੁਰ ਦਰਸਨੁ ਦੇਖਿ ਨਿਹਾਲੀ ॥੧॥",
          "roman": "pandh julandarī mērā andar ṭhaṇḍhā gur darsan dēkh nihālī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идя по Твоему пути, моё сердце охлаждается, и, созерцая даршан Сатгуру, мой ум расцветает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3567,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41249,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahallā pañjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "М. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41250,
          "is_rahao": false,
          "gurmukhi": "ਹਠ ਮੰਝਾਹੂ ਮੈ ਮਾਣਕੁ ਲਧਾ ॥",
          "roman": "haṭh mañjhāhū mē māṇak ladhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В своём сердце я нашёл драгоценный рубин."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41251,
          "is_rahao": false,
          "gurmukhi": "ਮੁਲਿ ਨ ਘਿਧਾ ਮੈ ਕੂ ਸਤਿਗੁਰਿ ਦਿਤਾ ॥",
          "roman": "mul na ghidhā mē kū satgur ditā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я не купил его за цену; этот рубин дал мне Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41252,
          "is_rahao": false,
          "gurmukhi": "ਢੂੰਢ ਵਞਾਈ ਥੀਆ ਥਿਤਾ ॥",
          "roman": "ḍhūṇḍh vañāī thīā thitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря ему мои поиски и блуждания закончились, и я стал устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41253,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੁ ਪਦਾਰਥੁ ਨਾਨਕ ਜਿਤਾ ॥੨॥",
          "roman": "janam padārath Nānak jitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я получил благо драгоценной человеческой жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3568,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41254,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "paurī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41255,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕੈ ਮਸਤਕਿ ਕਰਮੁ ਹੋਇ ਸੋ ਸੇਵਾ ਲਾਗਾ ॥",
          "roman": "jis kē mastak karam hoi so sēvā lāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на чьём лбу записана милость Господа, посвящает себя служению и преданности Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41256,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰ ਮਿਲਿ ਕਮਲੁ ਪ੍ਰਗਾਸਿਆ ਸੋ ਅਨਦਿਨੁ ਜਾਗਾ ॥",
          "roman": "jis gur mil kamal pragāsiā so andin jāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, чей сердечный лотос расцветает после встречи с Гуру, всегда остаётся бодрствующим перед нападениями пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41257,
          "is_rahao": false,
          "gurmukhi": "ਲਗਾ ਰੰਗੁ ਚਰਣਾਰਬਿੰਦ ਸਭੁ ਭ੍ਰਮੁ ਭਉ ਭਾਗਾ ॥",
          "roman": "lagā rang charṇārbind sabh bhram bhau bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В ком возникает любовь к прекрасным лотосным стопам Господа, у того уходят все блуждания, страхи и тревоги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
