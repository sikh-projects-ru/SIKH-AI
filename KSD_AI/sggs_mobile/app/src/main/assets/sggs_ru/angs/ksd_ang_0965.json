{
  "ang": 965,
  "shabads": [
    {
      "shabad_id": 3568,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41258,
          "is_rahao": false,
          "gurmukhi": "ਆਤਮੁ ਜਿਤਾ ਗੁਰਮਤੀ ਆਗੰਜਤ ਪਾਗਾ ॥",
          "roman": "ātam jitā gurmatī āgañjat pāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто по наставлению Гуру победил себя, обретает несокрушимое духовное достоинство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41259,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਧਿਆਇਆ ਪਾਰਬ੍ਰਹਮੁ ਸੋ ਕਲਿ ਮਹਿ ਤਾਗਾ ॥",
          "roman": "jisah dhiāiā pārbraham so kal meh tāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто созерцает Всевышнего Парбрахма, в век Кали становится крепким и устойчивым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41260,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਤਿ ਨਿਰਮਲਾ ਅਠਸਠਿ ਮਜਨਾਗਾ ॥",
          "roman": "sādhū sangat nirmalā aṭhsaṭh majnāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Святая Сангат чиста: в ней — словно омовение во всех шестидесяти восьми местах паломничества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41261,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਭੁ ਮਿਲਿਆ ਆਪਣਾ ਸੋ ਪੁਰਖੁ ਸਭਾਗਾ ॥",
          "roman": "jis prabh miliā āpaṇā so purakh sabhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Счастлив тот человек, которому встретился его возлюбленный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41262,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਤਿਸੁ ਬਲਿਹਾਰਣੈ ਜਿਸੁ ਏਵਡ ਭਾਗਾ ॥੧੭॥",
          "roman": "nānak tis balihāraṇē jis ēvaḍ bhāgā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, я жертвую собой тому, у кого столь великая судьба."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3569,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41263,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41264,
          "is_rahao": false,
          "gurmukhi": "ਜਾਂ ਪਿਰੁ ਅੰਦਰਿ ਤਾਂ ਧਨ ਬਾਹਰਿ ॥",
          "roman": "jā̃ pir andar tā̃ dhan bāhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Супруг-Господь явно пребывает в сердце души-жены, она остаётся непривязанной к мирским заботам и суете."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41265,
          "is_rahao": false,
          "gurmukhi": "ਜਾਂ ਪਿਰੁ ਬਾਹਰਿ ਤਾਂ ਧਨ ਮਾਹਰਿ ॥",
          "roman": "jā̃ pir bāhar tā̃ dhan māhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Супруг-Господь удаляется из её памяти, душа-жена начинает погружаться в мирские дела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41266,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਬਹੁ ਫੇਰੁ ਫਿਰਾਹਰਿ ॥",
          "roman": "bin nāvē bah phēr phirāhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Господа живое существо блуждает во множестве скитаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41267,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਸੰਗਿ ਦਿਖਾਇਆ ਜਾਹਰਿ ॥",
          "roman": "satigur saṅg dikhāiā jāhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тому человеку Гуру явил Господа прямо внутри сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41268,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸਚੇ ਸਚਿ ਸਮਾਹਰਿ ॥੧॥",
          "roman": "jan nānak sachey sach samāhar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О раб Нанак, такой человек пребывает вечно укоренённым в неизменном Господе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3570,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41269,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41270,
          "is_rahao": false,
          "gurmukhi": "ਆਹਰ ਸਭਿ ਕਰਦਾ ਫਿਰੈ ਆਹਰੁ ਇਕੁ ਨ ਹੋਇ ॥",
          "roman": "āhar sabh kardā phirē āhar ik na hoē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек занимается всеми прочими делами, но не делает одного усилия — не старается помнить Единого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41271,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਤੁ ਆਹਰਿ ਜਗੁ ਉਧਰੈ ਵਿਰਲਾ ਬੂਝੈ ਕੋਇ ॥੨॥",
          "roman": "nānak jit āhar jag udharē virlā būjhey koē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, то усилие, благодаря которому мир может спастись от пороков, понимает лишь редкий человек."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3571,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41272,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41273,
          "is_rahao": false,
          "gurmukhi": "ਵਡੀ ਹੂ ਵਡਾ ਅਪਾਰੁ ਤੇਰਾ ਮਰਤਬਾ ॥",
          "roman": "vaḍī hū vaḍā apār terā martabā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, безмерно велик Твой бесконечный ранг и достоинство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41274,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗ ਪਰੰਗ ਅਨੇਕ ਨ ਜਾਪਨਿੑ ਕਰਤਬਾ ॥",
          "roman": "raṅg paraṅg anēk na jāpan karatabā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В мире совершаются Твои бесчисленные многообразные чудеса, которые невозможно постичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41275,
          "is_rahao": false,
          "gurmukhi": "ਜੀਆ ਅੰਦਰਿ ਜੀਉ ਸਭੁ ਕਿਛੁ ਜਾਣਲਾ ॥",
          "roman": "jīā andar jīu sabh kich jāṇlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри всех существ Ты Сам являешься жизнью и опорой; Ты знаешь каждое их дело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41276,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤੇਰੈ ਵਸਿ ਤੇਰਾ ਘਰੁ ਭਲਾ ॥",
          "roman": "sabh kich terē vas terā ghar bhalā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё находится в Твоей власти; прекрасно Твоё обиталище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41277,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੈ ਘਰਿ ਆਨੰਦੁ ਵਧਾਈ ਤੁਧੁ ਘਰਿ ॥",
          "roman": "terē ghar ānand vadhāī tudh ghar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Твоём доме всегда пребывают радость, блаженство и ликование."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41278,
          "is_rahao": false,
          "gurmukhi": "ਮਾਣੁ ਮਹਤਾ ਤੇਜੁ ਆਪਣਾ ਆਪਿ ਜਰਿ ॥",
          "roman": "māṇ mahatā tēj āpaṇā āp jar",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Свой великий почёт, величие и сияющее могущество Ты Сам выдерживаешь и несёшь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41279,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਕਲਾ ਭਰਪੂਰੁ ਦਿਸੈ ਜਤ ਕਤਾ ॥",
          "roman": "sarab kalā bharpūr disē jat katā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь, исполненный всех сил, виден повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41280,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸਨਿ ਦਾਸੁ ਤੁਧੁ ਆਗੈ ਬਿਨਵਤਾ ॥੧੮॥",
          "roman": "nānak dāsan dās tudh āgē binvatā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Нанак, раб Твоих рабов, возносит молитву и просьбу перед Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3572,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41281,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41282,
          "is_rahao": false,
          "gurmukhi": "ਛਤੜੇ ਬਾਜਾਰ ਸੋਹਨਿ ਵਿਚਿ ਵਪਾਰੀਏ ॥",
          "roman": "chhatṛe bājār sohan vich vapārīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Под небесным сводом прекрасны эти миры-рынки, и в них прекрасны торговцы Именем Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41283,
          "is_rahao": false,
          "gurmukhi": "ਵਖਰੁ ਹਿਕੁ ਅਪਾਰੁ ਨਾਨਕ ਖਟੇ ਸੋ ਧਣੀ ॥੧॥",
          "roman": "vakhar hik apār nānak khaṭē so dhaṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, в этой мировой лавке богат тот человек, кто приобретает один неистощимый товар — Хар-Нам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3573,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41284,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41285,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰਾ ਹਮਰਾ ਕੋ ਨਹੀ ਹਮ ਕਿਸ ਹੂ ਕੇ ਨਾਹਿ ॥",
          "roman": "kabīrā hamrā ko nahī̃ ham kis hū ke nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, никто не является нашим вечным спутником, и мы не можем быть вечными спутниками кого-либо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41286,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਇਹੁ ਰਚਨੁ ਰਚਾਇਆ ਤਿਸ ਹੀ ਮਾਹਿ ਸਮਾਹਿ ॥੨॥",
          "roman": "jin ih rachan rachāiā tis hī māh samāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мы пребываем в памятовании Того Самого Господа, Который сотворил это творение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3574,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41287,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41288,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲਿਉ ਬਿਰਖੁ ਸੁਹਾਵੜਾ ਹਰਿ ਸਫਲ ਅੰਮ੍ਰਿਤਾ ॥",
          "roman": "saphliō birakh suhāvaṛā har saphal amritā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь подобен прекрасному плодоносному дереву, на котором растут плоды, дарующие духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41289,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਲੋਚੈ ਉਨੑ ਮਿਲਣ ਕਉ ਕਿਉ ਵੰਞੈ ਘਿਤਾ ॥",
          "roman": "man lochey unh milaṇ kau kiu vañē ghitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой ум жаждет встретиться с Ним, но не знает, каким образом Его можно обрести."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41290,
          "is_rahao": false,
          "gurmukhi": "ਵਰਨਾ ਚਿਹਨਾ ਬਾਹਰਾ ਓਹੁ ਅਗਮੁ ਅਜਿਤਾ ॥",
          "roman": "varnā chihnā bāhrā oh agam ajitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У Него нет ни цвета, ни знака; Он недостижим и непобедим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41291,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਪਿਆਰਾ ਜੀਅ ਕਾ ਜੋ ਖੋਲੑੈ ਭਿਤਾ ॥",
          "roman": "oh piārā jīa kā jo kholē bhitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот друг, кто откроет мне этот тайный путь, станет дорогим моей душе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41292,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਾ ਕਰੀ ਤੁਸਾੜੀਆ ਮੈ ਦਸਿਹੁ ਮਿਤਾ ॥",
          "roman": "sēvā karī tusāṛīā mē dasih mitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друзья, расскажите мне этот секрет, и я буду служить вам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41293,
          "is_rahao": false,
          "gurmukhi": "ਕੁਰਬਾਣੀ ਵੰਞਾ ਵਾਰਣੈ ਬਲੇ ਬਲਿ ਕਿਤਾ ॥",
          "roman": "kurbāṇī vañā vāraṇē balē bal kitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я пойду на жертву вам, снова и снова отдам себя вам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41294,
          "is_rahao": false,
          "gurmukhi": "ਦਸਨਿ ਸੰਤ ਪਿਆਰਿਆ ਸੁਣਹੁ ਲਾਇ ਚਿਤਾ ॥",
          "roman": "dasan sant piāriā suṇah lāē chitā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Возлюбленные святые говорят: слушайте внимательно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41295,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਲਿਖਿਆ ਨਾਨਕ ਦਾਸ ਤਿਸੁ ਨਾਉ ਅੰਮ੍ਰਿਤੁ ਸਤਿਗੁਰਿ ਦਿਤਾ ॥੧੯॥",
          "roman": "jis likhiā nānak dās tis nāu amrit satigur ditā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О раб Нанак, тому, у кого проявляется предначертанная судьба, Сатгуру дарует Имя Господа, дающее духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3575,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41296,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਹਲਾ ੫ ॥",
          "roman": "salok mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41297,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਧਰਤੀ ਸਾਧ ਕੀ ਤਸਕਰ ਬੈਸਹਿ ਗਾਹਿ ॥",
          "roman": "kabīr dhartī sādh kī taskar bēsah gāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, если порочные люди, оставив другие стремления, искренне сядут в Сангате Сатгуру..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41298,
          "is_rahao": false,
          "gurmukhi": "ਧਰਤੀ ਭਾਰਿ ਨ ਬਿਆਪਈ ਉਨ ਕਉ ਲਾਹੂ ਲਾਹਿ ॥੧॥",
          "roman": "dhartī bhār na biāpī un kau lāhū lāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "то их порочность не подавит эту Сангат; напротив, они сами получат от неё пользу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3576,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41299,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੫ ॥",
          "roman": "mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41300,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਚਾਵਲ ਕਾਰਣੇ ਤੁਖ ਕਉ ਮੁਹਲੀ ਲਾਇ ॥",
          "roman": "kabīr chāval kāraṇē tukh kau muhlī lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Кабир, ради отделения риса шелуха получает удар пестом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41301,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਕੁਸੰਗੀ ਬੈਸਤੇ ਤਬ ਪੂਛੇ ਧਰਮ ਰਾਇ ॥੨॥",
          "roman": "saṅg kusaṅgī bēsatē tab pūchhē dharam rāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так же человек, сидящий в дурном обществе, начинает получать удары пороков, и тогда Дхарам Рай требует с него отчёт."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3577,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41302,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41303,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਹੀ ਵਡ ਪਰਵਾਰੁ ਆਪਿ ਇਕਾਤੀਆ ॥",
          "roman": "āpē hī vaḍ parvār āp ikātīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты Сам — обладатель великой семьи в образе мира, и Ты же Сам остаёшься одиноким и непривязанным к ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41304,
          "is_rahao": false,
          "gurmukhi": "ਆਪਣੀ ਕੀਮਤਿ ਆਪਿ ਆਪੇ ਹੀ ਜਾਤੀਆ ॥",
          "roman": "āpaṇī kīmat āp āpē hī jātīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты Сам устанавливаешь ценность Своего величия, и Ты Сам эту ценность знаешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41305,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਆਪੇ ਆਪਿ ਆਪਿ ਉਪੰਨਿਆ ॥",
          "roman": "sabh kich āpē āp āp upanniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Весь этот мир — Твой собственный проявленный образ; он вышел из Тебя Самого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41306,
          "is_rahao": false,
          "gurmukhi": "ਆਪਣਾ ਕੀਤਾ ਆਪਿ ਆਪਿ ਵਰੰਨਿਆ ॥",
          "roman": "āpaṇā kītā āp āp varanniā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всем Своим сотворённым миром Ты Сам наделяешь форму, цвет и описание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41307,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਤੇਰਾ ਥਾਨੁ ਜਿਥੈ ਤੂ ਵੁਠਾ ॥",
          "roman": "dhann so terā thān jithē tū vuṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благословенно то место, где, о Господь, Ты пребываешь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
