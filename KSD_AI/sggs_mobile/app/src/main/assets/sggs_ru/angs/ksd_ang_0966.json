{
  "ang": 966,
  "shabads": [
    {
      "shabad_id": 3577,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41308,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨੁ ਸੁ ਤੇਰੇ ਭਗਤ ਜਿਨੑੀ ਸਚੁ ਤੂੰ ਡਿਠਾ ॥",
          "roman": "dhan so tērē bhagat jinhīṅ sach tūṅ ḍiṭhā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Блаженны те Твои преданные, которые увидели Тебя как Истину."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41309,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਤੇਰੀ ਦਇਆ ਸਲਾਹੇ ਸੋਇ ਤੁਧੁ ॥",
          "roman": "jis nō tērī daiā salāhē soī tudh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кого касается Твоя милость, тот восхваляет именно Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41310,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਗੁਰ ਭੇਟੇ ਨਾਨਕ ਨਿਰਮਲ ਸੋਈ ਸੁਧੁ ॥੨੦॥",
          "roman": "jis gur bhēṭē Nānak nirmal soī sudh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот, кто встречает Гуру, становится чистым и очищенным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3578,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41311,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41312,
          "is_rahao": false,
          "gurmukhi": "ਫਰੀਦਾ ਭੂਮਿ ਰੰਗਾਵਲੀ ਮੰਝਿ ਵਿਸੂਲਾ ਬਾਗੁ ॥",
          "roman": "Farīdā bhūm rangāvalī mañjh visūlā bāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Фарид! Эта земля прекрасна, но из-за ям и бугров человеческого ума в ней растёт ядовитый сад, где горит огонь страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41313,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਨਰ ਪੀਰਿ ਨਿਵਾਜਿਆ ਤਿਨੑਾ ਅੰਚ ਨ ਲਾਗ ॥੧॥",
          "roman": "jo nar pīr nivājiā tinhāṅ añch na lāg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те люди, которых Сатгуру возвысил, не ощущают жара этого огня страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3579,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41314,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41315,
          "is_rahao": false,
          "gurmukhi": "ਫਰੀਦਾ ਉਮਰ ਸੁਹਾਵੜੀ ਸੰਗਿ ਸੁਵੰਨੜੀ ਦੇਹ ॥",
          "roman": "Farīdā umar suhāvaṛī sang suvaṇṇaṛī dēh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Фарид! Жизнь тех людей спокойна, и их тело прекрасно окрашено, то есть свободно от болезней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41316,
          "is_rahao": false,
          "gurmukhi": "ਵਿਰਲੇ ਕੇਈ ਪਾਈਅਨਿੑ ਜਿਨੑਾ ਪਿਆਰੇ ਨੇਹ ॥੨॥",
          "roman": "virlē kēī pāīan jinhāṅ piārē nēh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это те, чья любовь обращена к возлюбленному Параматме; ядовитый сад и огонь страданий не касаются их, но такие люди встречаются лишь редко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3580,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41317,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41318,
          "is_rahao": false,
          "gurmukhi": "ਜਪੁ ਤਪੁ ਸੰਜਮੁ ਦਇਆ ਧਰਮੁ ਜਿਸੁ ਦੇਹਿ ਸੁ ਪਾਏ ॥",
          "roman": "jap tap sanjam daiā dharam jis dēh so pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Человек, которому Ты даруешь дар Имени, тем самым обретает Джап, тап, самообуздание, сострадание и дхарму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41319,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਬੁਝਾਇਹਿ ਅਗਨਿ ਆਪਿ ਸੋ ਨਾਮੁ ਧਿਆਏ ॥",
          "roman": "jis bujhāih agan āp so nām dhiāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но Твоё Имя вспоминает лишь тот, чей огонь жажды Ты Сам гасишь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41320,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਅਗਮ ਪੁਰਖੁ ਇਕ ਦ੍ਰਿਸਟਿ ਦਿਖਾਏ ॥",
          "roman": "antarjāmī agam purakh ik drisaṭ dikhāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Недостижимый всепроникающий Прабху, знающий каждое сердце, обращает на такого человека один милостивый взгляд."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41321,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕੈ ਆਸਰੈ ਪ੍ਰਭ ਸਿਉ ਰੰਗੁ ਲਾਏ ॥",
          "roman": "sādhsangat kē āsrē prabh siu rang lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И он, опираясь на Сатсанг, обретает любовь к Параматме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41322,
          "is_rahao": false,
          "gurmukhi": "ਅਉਗਣ ਕਟਿ ਮੁਖੁ ਉਜਲਾ ਹਰਿ ਨਾਮਿ ਤਰਾਏ ॥",
          "roman": "auguṇ kaṭ mukh ujlā har nām tarāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Параматма, отсёкши все его недостатки, делает его лицо светлым и через Своё Имя переправляет его через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41323,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਭਉ ਕਟਿਓਨੁ ਫਿਰਿ ਜੋਨਿ ਨ ਪਾਏ ॥",
          "roman": "janam maraṇ bhau kaṭion phir jon na pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он устраняет страх рождения и смерти у этого человека и больше не помещает его в круговорот рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41324,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਕੂਪ ਤੇ ਕਾਢਿਅਨੁ ਲੜੁ ਆਪਿ ਫੜਾਏ ॥",
          "roman": "andh kūp tē kāḍhian laṛ āp phaṛāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху Сам даёт им держаться за Свой край одежды и выводит их из тёмного колодца майи и привязанности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41325,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਖਸਿ ਮਿਲਾਇਅਨੁ ਰਖੇ ਗਲਿ ਲਾਏ ॥੨੧॥",
          "roman": "Nānak bakhas milāian rakhē gal lāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! По Своей милости Прабху соединяет их с Собой и держит, прижав к Своей груди."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3581,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41326,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок, Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41327,
          "is_rahao": false,
          "gurmukhi": "ਮੁਹਬਤਿ ਜਿਸੁ ਖੁਦਾਇ ਦੀ ਰਤਾ ਰੰਗਿ ਚਲੂਲਿ ॥",
          "roman": "muhabat jis Khudāi dī ratā rang chalūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который обрёл любовь к Богу, окрашивается в глубокий цвет этой любви."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41328,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵਿਰਲੇ ਪਾਈਅਹਿ ਤਿਸੁ ਜਨ ਕੀਮ ਨ ਮੂਲਿ ॥੧॥",
          "roman": "Nānak virlē pāīah tis jan kīm na mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Такого человека невозможно оценить никакой ценой, но такие люди встречаются лишь редко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3582,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41329,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятый Махал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41330,
          "is_rahao": false,
          "gurmukhi": "ਅੰਦਰੁ ਵਿਧਾ ਸਚਿ ਨਾਇ ਬਾਹਰਿ ਭੀ ਸਚੁ ਡਿਠੋਮਿ ॥",
          "roman": "andar vidhā sach nāi bāhar bhī sach ḍiṭhom",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда моё внутреннее существо, то есть ум, было пронзено Истинным Именем, я увидел Сада-тхир Прабху и снаружи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41331,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਰਵਿਆ ਹਭ ਥਾਇ ਵਣਿ ਤ੍ਰਿਣਿ ਤ੍ਰਿਭਵਣਿ ਰੋਮਿ ॥੨॥",
          "roman": "Nānak raviā habh thāi vaṇ triṇ tribhavaṇ rom",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Теперь мне видится, что Параматма присутствует повсюду: в каждом лесу, в каждой травинке, во всех трёх мирах, в каждом волоске."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3583,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41332,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41333,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕੀਤੋ ਰਚਨੁ ਆਪੇ ਹੀ ਰਤਿਆ ॥",
          "roman": "āpē kīto rachan āpē hī ratiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху Сам сотворил это мироздание и Сам же пребывает, смешанный с ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41334,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਹੋਇਓ ਇਕੁ ਆਪੇ ਬਹੁ ਭਤਿਆ ॥",
          "roman": "āpē hoio ik āpē bah bhatiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Иногда, свернув творение, Он становится одним Самим Собой, а иногда принимает множество цветов и форм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41335,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਭਨਾ ਮੰਝਿ ਆਪੇ ਬਾਹਰਾ ॥",
          "roman": "āpē sabhnā mañjh āpē bāhrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Прабху Сам присутствует во всех существах, и Сам же остаётся незатронутым, вне всего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41336,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਜਾਣਹਿ ਦੂਰਿ ਆਪੇ ਹੀ ਜਾਹਰਾ ॥",
          "roman": "āpē jāṇeh dūr āpē hī jāhrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Ты Сам знаешь Себя отдельным от сотворённого, и Сам же присутствуешь явно повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41337,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਹੋਵਹਿ ਗੁਪਤੁ ਆਪੇ ਪਰਗਟੀਐ ॥",
          "roman": "āpē hovah gupat āpē pargaṭīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты Сам скрыт, и Ты Сам являешься открыто."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41338,
          "is_rahao": false,
          "gurmukhi": "ਕੀਮਤਿ ਕਿਸੈ ਨ ਪਾਇ ਤੇਰੀ ਥਟੀਐ ॥",
          "roman": "kīmat kisē na pāi tērī thaṭīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто не смог определить цену Твоего творения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41339,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿਰ ਗੰਭੀਰੁ ਅਥਾਹੁ ਅਪਾਰੁ ਅਗਣਤੁ ਤੂੰ ॥",
          "roman": "gahir gambhīr athāh apār agṇat tūṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты глубокий и серьёзный; Твоей глубины не достичь, Ты бесконечен, и Твои качества невозможно сосчитать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41340,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵਰਤੈ ਇਕੁ ਇਕੋ ਇਕੁ ਤੂੰ ॥੨੨॥੧॥੨॥ ਸੁਧੁ ॥",
          "roman": "Nānak vartē ik iko ik tūṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Повсюду присутствует один Прабху. О Прабху! Есть только Ты, Ты один."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3584,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41341,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਕੀ ਵਾਰ ਰਾਇ ਬਲਵੰਡਿ ਤਥਾ ਸਤੈ ਡੂਮਿ ਆਖੀ",
          "roman": "Rāmkalī kī vār Rāi Balvaṇḍ tathā Satē ḍūm ākhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это Вар в раге Рамкали, которую произнесли Рай Балванд и Сатта Дум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41342,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41343,
          "is_rahao": false,
          "gurmukhi": "ਨਾਉ ਕਰਤਾ ਕਾਦਰੁ ਕਰੇ ਕਿਉ ਬੋਲੁ ਹੋਵੈ ਜੋਖੀਵਦੈ ॥",
          "roman": "nāu kartā kādar karē kiu bol hovē jokhīvadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Творец-Кадар Сам возвышает чьё-либо имя и славу, никто не может произнести слово, способное взвесить эту славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41344,
          "is_rahao": false,
          "gurmukhi": "ਦੇ ਗੁਨਾ ਸਤਿ ਭੈਣ ਭਰਾਵ ਹੈ ਪਾਰੰਗਤਿ ਦਾਨੁ ਪੜੀਵਦੈ ॥",
          "roman": "dē gunā sat bhēṇ bharāv hē pārangat dān paṛīvadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те божественные качества, такие как истина, которые люди стараются развить в себе ради дара состояния, способного переправить через мирской океан, у Сатгуру естественно присутствуют как родные братья и сёстры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41345,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕਿ ਰਾਜੁ ਚਲਾਇਆ ਸਚੁ ਕੋਟੁ ਸਤਾਣੀ ਨੀਵ ਦੈ ॥",
          "roman": "Nānak rāj chalāiā sach koṭ satāṇī nīv dē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру Нанак Дев Джи, воздвигнув крепость Истины и положив прочное основание, установил царство дхармы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41346,
          "is_rahao": false,
          "gurmukhi": "ਲਹਣੇ ਧਰਿਓਨੁ ਛਤੁ ਸਿਰਿ ਕਰਿ ਸਿਫਤੀ ਅੰਮ੍ਰਿਤੁ ਪੀਵਦੈ ॥",
          "roman": "Lahṇē dharion chhat sir kar siftī amrit pīvadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру Нанак Дев Джи возложил зонт гурияйи на голову Бабы Лехны, который, совершая восхваление, пил нектар Имени, дарующий духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41347,
          "is_rahao": false,
          "gurmukhi": "ਮਤਿ ਗੁਰ ਆਤਮ ਦੇਵ ਦੀ ਖੜਗਿ ਜੋਰਿ ਪਰਾਕੁਇ ਜੀਅ ਦੈ ॥",
          "roman": "mat gur ātam dēv dī khaṛag jor parākui jīa dē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мечом мудрости, дарованной Гуру-Атмадевом, силой и могуществом Он вынул прежнюю жизнь изнутри и даровал духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41348,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਚੇਲੇ ਰਹਰਾਸਿ ਕੀਈ ਨਾਨਕਿ ਸਲਾਮਤਿ ਥੀਵਦੈ ॥",
          "roman": "gur chēlē raharās kīī Nānak salāmat thīvadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ещё при жизни Гуру Нанак Дев Джи поклонился своему ученику, Бабе Лехне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41349,
          "is_rahao": false,
          "gurmukhi": "ਸਹਿ ਟਿਕਾ ਦਿਤੋਸੁ ਜੀਵਦੈ ॥੧॥",
          "roman": "sah ṭikā ditos jīvadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сатгуру, будучи ещё живым, даровал ему тилак гурияйи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3585,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41350,
          "is_rahao": false,
          "gurmukhi": "ਲਹਣੇ ਦੀ ਫੇਰਾਈਐ ਨਾਨਕਾ ਦੋਹੀ ਖਟੀਐ ॥",
          "roman": "Lahṇē dī phērāīai Nānkā dohī khaṭīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда Гуру Нанак Дев Джи даровал Бабе Лехне тилак гурияйи, благодаря славе Гуру Нанака слава Бабы Лехны распространилась повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41351,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤਿ ਓਹਾ ਜੁਗਤਿ ਸਾਇ ਸਹਿ ਕਾਇਆ ਫੇਰਿ ਪਲਟੀਐ ॥",
          "roman": "jot ohā jugat sāi sah kāiā phēr palṭīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри Бабы Лехны была та же самая Джот, и образ жизни был тот же самый, что у Гуру Нанака; Гуру лишь переменил тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41352,
          "is_rahao": false,
          "gurmukhi": "ਝੁਲੈ ਸੁ ਛਤੁ ਨਿਰੰਜਨੀ ਮਲਿ ਤਖਤੁ ਬੈਠਾ ਗੁਰ ਹਟੀਐ ॥",
          "roman": "jhulē su chhat nirañjanī mal takhat bēṭhā gur haṭīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Над Бабой Лехной развевается прекрасный божественный зонт; в лавке Гуру Нанака он сел на престол, чтобы принимать и раздавать сокровище Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41353,
          "is_rahao": false,
          "gurmukhi": "ਕਰਹਿ ਜਿ ਗੁਰ ਫੁਰਮਾਇਆ ਸਿਲ ਜੋਗੁ ਅਲੂਣੀ ਚਟੀਐ ॥",
          "roman": "karah j gur phurmāiā sil jog alūṇī chaṭīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он исполняет то, что повелел Гуру Нанак; это делание йоги послушания Гуру подобно лизанию несолёного камня, то есть крайне суровому труду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
