{
  "ang": 971,
  "shabads": [
    {
      "shabad_id": 3599,
      "rahao_verse_id": 41504,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41503,
          "is_rahao": true,
          "gurmukhi": "ਗੋਬਿੰਦ ਹਮ ਐਸੇ ਅਪਰਾਧੀ ॥",
          "roman": "gobind ham aisē aprādhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Гобинд, мы такие грешники."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41504,
          "is_rahao": true,
          "gurmukhi": "ਜਿਨਿ ਪ੍ਰਭਿ ਜੀਉ ਪਿੰਡੁ ਥਾ ਦੀਆ ਤਿਸ ਕੀ ਭਾਉ ਭਗਤਿ ਨਹੀ ਸਾਧੀ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jin prabh jīo piṇḍ thā dīā tis kī bhāu bhagat nahī sādhī. rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Господь дал мне душу и тело, но я не утвердился в любовном поклонении Ему. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41505,
          "is_rahao": false,
          "gurmukhi": "ਪਰ ਧਨ ਪਰ ਤਨ ਪਰ ਤੀ ਨਿੰਦਾ ਪਰ ਅਪਬਾਦੁ ਨ ਛੂਟੈ ॥",
          "roman": "par dhan par tan par tī nindā par apbād na chhūṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я не оставляю чужого богатства, чужого тела, чужой жены, клеветы на других и обвинений против других."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41506,
          "is_rahao": false,
          "gurmukhi": "ਆਵਾ ਗਵਨੁ ਹੋਤੁ ਹੈ ਫੁਨਿ ਫੁਨਿ ਇਹੁ ਪਰਸੰਗੁ ਨ ਤੂਟੈ ॥੨॥",
          "roman": "āvā gavan hot hē phun phun ih parsaṅg na tūṭē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова продолжаются приход и уход; эта цепь не разрывается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41507,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਘਰਿ ਕਥਾ ਹੋਤ ਹਰਿ ਸੰਤਨ ਇਕ ਨਿਮਖ ਨ ਕੀਨੑੋ ਮੈ ਫੇਰਾ ॥",
          "roman": "jih ghar kathā hot har santan ik nimakh na kīno mē pherā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В тот дом, где святые говорят о Хари, я не зашёл даже на мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41508,
          "is_rahao": false,
          "gurmukhi": "ਲੰਪਟ ਚੋਰ ਦੂਤ ਮਤਵਾਰੇ ਤਿਨ ਸੰਗਿ ਸਦਾ ਬਸੇਰਾ ॥੩॥",
          "roman": "lampaṭ chor dūt matvārē tin saṅg sadā basērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моё постоянное жилище было среди распутников, воров, злодеев и опьянённых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41509,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਮਾਇਆ ਮਦ ਮਤਸਰ ਏ ਸੰਪੈ ਮੋ ਮਾਹੀ ॥",
          "roman": "kām krodh māiā mad matsar ē sampē mo māhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Похоть, гнев, майя, гордыня и зависть — вот какое богатство во мне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41510,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਧਰਮੁ ਅਰੁ ਗੁਰ ਕੀ ਸੇਵਾ ਏ ਸੁਪਨੰਤਰਿ ਨਾਹੀ ॥੪॥",
          "roman": "daiā dharam ar gur kī sēvā ē supnantar nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Милосердия, праведности и служения Гуру у меня нет даже во сне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41511,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਕ੍ਰਿਪਾਲ ਦਮੋਦਰ ਭਗਤਿ ਬਛਲ ਭੈ ਹਾਰੀ ॥",
          "roman": "dīn dēāl kripāl damodar bhagat bachhal bhē hārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Милостивый к бедным, Сострадательный, Дамодар, Любящий преданных, Устраняющий страх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41512,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਕਬੀਰ ਭੀਰ ਜਨ ਰਾਖਹੁ ਹਰਿ ਸੇਵਾ ਕਰਉ ਤੁਮੑਾਰੀ ॥੫॥੮॥",
          "roman": "kahat Kabīr bhīr jan rākhah har sēvā karau tumhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: защити слугу в беде, о Хари; пусть я совершаю служение Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3600,
      "rahao_verse_id": 41518,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41513,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਹੋਇ ਮੁਕਤਿ ਦੁਆਰੁ ॥",
          "roman": "jih simran hoi mukt duār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря тому Симрану становится видимой дверь освобождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41514,
          "is_rahao": false,
          "gurmukhi": "ਜਾਹਿ ਬੈਕੁੰਠਿ ਨਹੀ ਸੰਸਾਰਿ ॥",
          "roman": "jāh bēkunṭh nahī sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По этому пути ты достигнешь стоп Господа и не будешь блуждать в океане мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41515,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭਉ ਕੈ ਘਰਿ ਬਜਾਵਹਿ ਤੂਰ ॥",
          "roman": "nirbhau kē ghar bajāvah tūṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Достигнув состояния, где не касается страх, ты словно заиграешь на инструментах духовной радости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41516,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਬਜਹਿ ਸਦਾ ਭਰਪੂਰ ॥੧॥",
          "roman": "anhad bajahi sadā bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти инструменты будут в тебе звучать вечно и непрерывно, и в этой радости не будет никакого недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41517,
          "is_rahao": true,
          "gurmukhi": "ਐਸਾ ਸਿਮਰਨੁ ਕਰਿ ਮਨ ਮਾਹਿ ॥",
          "roman": "aisā simran kar man māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершай в своём уме такой Симран, обладающий этой силой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41518,
          "is_rahao": true,
          "gurmukhi": "ਬਿਨੁ ਸਿਮਰਨ ਮੁਕਤਿ ਕਤ ਨਾਹਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bin simran mukat kat nāh. rahāo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Симрана освобождение от уз майи не обретается никаким другим способом. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41519,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਨਾਹੀ ਨਨਕਾਰੁ ॥",
          "roman": "jih simran nāhī nankār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При том Симране пороки не смогут поставить препятствие на твоём пути."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41520,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਕਰੈ ਉਤਰੈ ਬਹੁ ਭਾਰੁ ॥",
          "roman": "mukt karē utrē bah bhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой Симран освобождает от уз майи, и тяжесть пороков спадает с ума."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41521,
          "is_rahao": false,
          "gurmukhi": "ਨਮਸਕਾਰੁ ਕਰਿ ਹਿਰਦੈ ਮਾਹਿ ॥",
          "roman": "namaskār kar hirdē māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда склоняйся перед Господом в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41522,
          "is_rahao": false,
          "gurmukhi": "ਫਿਰਿ ਫਿਰਿ ਤੇਰਾ ਆਵਨੁ ਨਾਹਿ ॥੨॥",
          "roman": "phir phir tērā āvan nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тогда тебе не придётся снова и снова приходить в мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41523,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਕਰਹਿ ਤੂ ਕੇਲ ॥",
          "roman": "jih simran karah tū kēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем Симраном ты наслаждаешься радостью и остаёшься свободным от тревог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41524,
          "is_rahao": false,
          "gurmukhi": "ਦੀਪਕੁ ਬਾਂਧਿ ਧਰਿਓ ਬਿਨੁ ਤੇਲ ॥",
          "roman": "dīpak bāndh dhario bin tēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри тебя постоянно горит светильник знания, и это не светильник на масле пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41525,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਦੀਪਕੁ ਅਮਰਕੁ ਸੰਸਾਰਿ ॥",
          "roman": "so dīpak amarak sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот светильник, когда загорается в человеке, делает его бессмертным в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41526,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਬਿਖੁ ਕਾਢੀਲੇ ਮਾਰਿ ॥੩॥",
          "roman": "kām krodh bikh kāḍhīlē mār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он убивает и выводит изнутри яд похоти, гнева и прочих пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41527,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਤੇਰੀ ਗਤਿ ਹੋਇ ॥",
          "roman": "jih simran tērī gat hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря тому Симрану у тебя возникает высокая духовная степень."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41528,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਮਰਨੁ ਰਖੁ ਕੰਠਿ ਪਰੋਇ ॥",
          "roman": "so simran rakh kanṭh paroi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанижи этот Симран, словно ожерелье, и всегда носи его на шее."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41529,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਮਰਨੁ ਕਰਿ ਨਹੀ ਰਾਖੁ ਉਤਾਰਿ ॥",
          "roman": "so simran kar nahī rākh utār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Совершай этот Симран и никогда не снимай его с себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41530,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਉਤਰਹਿ ਪਾਰਿ ॥੪॥",
          "roman": "gur parsādī utrahi pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру ты переправишься через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41531,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਨਾਹੀ ਤੁਹਿ ਕਾਨਿ ॥",
          "roman": "jih simran nāhī tuh kān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "При том Симране ты не остаёшься зависимым ни от кого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41532,
          "is_rahao": false,
          "gurmukhi": "ਮੰਦਰਿ ਸੋਵਹਿ ਪਟੰਬਰ ਤਾਨਿ ॥",
          "roman": "mandar sovah paṭambar tān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты беззаботно покоишься в своём внутреннем доме, словно укрывшись шёлковыми одеждами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41533,
          "is_rahao": false,
          "gurmukhi": "ਸੇਜ ਸੁਖਾਲੀ ਬਿਗਸੈ ਜੀਉ ॥",
          "roman": "sēj sukhālī bigsē jīo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В сердце становится покойно, и душа расцветает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41534,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਮਰਨੁ ਤੂ ਅਨਦਿਨੁ ਪੀਉ ॥੫॥",
          "roman": "so simran tū andin pīo",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пей этот нектар Симрана каждый день, во всякое время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41535,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਤੇਰੀ ਜਾਇ ਬਲਾਇ ॥",
          "roman": "jih simran tērī jāi balāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря тому Симрану твоя духовная болезнь отсекается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41536,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਤੁਝੁ ਪੋਹੈ ਨ ਮਾਇ ॥",
          "roman": "jih simran tujh pohē na māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря тому Симрану майя не может коснуться тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41537,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਹਰਿ ਹਰਿ ਮਨਿ ਗਾਈਐ ॥",
          "roman": "simar simar har har man gāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова совершай Симран Хари и в уме воспевай хвалу Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41538,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਸਿਮਰਨੁ ਸਤਿਗੁਰ ਤੇ ਪਾਈਐ ॥੬॥",
          "roman": "ih simran satgur tē pāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Этот Симран обретается только от Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41539,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਸਿਮਰਿ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "sadā sadā simar din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда, всегда вспоминай Господа днём и ночью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41540,
          "is_rahao": false,
          "gurmukhi": "ਊਠਤ ਬੈਠਤ ਸਾਸਿ ਗਿਰਾਸਿ ॥",
          "roman": "ūṭhat bēṭhat sās girās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вставая, садясь, с каждым дыханием и с каждым куском пищи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41541,
          "is_rahao": false,
          "gurmukhi": "ਜਾਗੁ ਸੋਇ ਸਿਮਰਨ ਰਸ ਭੋਗ ॥",
          "roman": "jāg soi simran ras bhog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бодрствуя и засыпая, во всякое время вкушай вкус Симрана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41542,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨੁ ਪਾਈਐ ਸੰਜੋਗ ॥੭॥",
          "roman": "har simran pāīai sanjog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Симран Господа обретается по счастливой доле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41543,
          "is_rahao": false,
          "gurmukhi": "ਜਿਹ ਸਿਮਰਨਿ ਨਾਹੀ ਤੁਝੁ ਭਾਰ ॥",
          "roman": "jih simran nāhī tujh bhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря тому Симрану с тебя спадёт тяжесть пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41544,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸਿਮਰਨੁ ਰਾਮ ਨਾਮ ਅਧਾਰੁ ॥",
          "roman": "so simran rām nām adhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сделай этот Симран имени Рама опорой своей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41545,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਜਾ ਕਾ ਨਹੀ ਅੰਤੁ ॥",
          "roman": "kah Kabīr jā kā nahī ant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: невозможно постичь конец качеств того Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41546,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੇ ਆਗੇ ਤੰਤੁ ਨ ਮੰਤੁ ॥੮॥੯॥",
          "roman": "tis kē āgē tant na mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Перед Ним не действуют ни заклинания, ни магические способы; без Его памяти Его нельзя достичь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3601,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 41547,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮਕਲੀ ਘਰੁ ੨ ਬਾਣੀ ਕਬੀਰ ਜੀ ਕੀ",
          "roman": "rāmkalī ghar 2 bāṇī Kabīr jī kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Рамкали, дом второй, бани Кабира Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41548,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар; по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41549,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਚਿ ਬੰਧਨੁ ਪਾਇਆ ॥",
          "roman": "bandhach bandhan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мукта Гуру поставил преграду майе, которая связывает узами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 41550,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤੈ ਗੁਰਿ ਅਨਲੁ ਬੁਝਾਇਆ ॥",
          "roman": "muktē gur anal bujhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Освобождённый Гуру погасил огонь моей жажды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
