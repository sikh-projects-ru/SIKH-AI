{
  "ang": 987,
  "shabads": [
    {
      "shabad_id": 3644,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42064,
          "is_rahao": false,
          "gurmukhi": "ਬੂਝਤ ਦੀਪਕ ਮਿਲਤ ਤਿਲਤ ॥",
          "roman": "būjhat dīpak milat tilat",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как гаснущая лампа, когда получает масло."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42065,
          "is_rahao": false,
          "gurmukhi": "ਜਲਤ ਅਗਨੀ ਮਿਲਤ ਨੀਰ ॥",
          "roman": "jalat agnī milat nīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как пылающий огонь, когда встречается с водой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42066,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਬਾਰਿਕ ਮੁਖਹਿ ਖੀਰ ॥੧॥",
          "roman": "jēsē bārik mukhah khīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как молоко у уст ребёнка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42067,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਰਣ ਮਹਿ ਸਖਾ ਭ੍ਰਾਤ ॥",
          "roman": "jēsē raṇ meh sakhā bhrāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как друг и брат на поле битвы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42068,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਭੂਖੇ ਭੋਜਨ ਮਾਤ ॥",
          "roman": "jēsē bhūkhē bhojan māt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как пища для голодного, дающая ему насыщение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42069,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਕਿਰਖਹਿ ਬਰਸ ਮੇਘ ॥",
          "roman": "jēsē kirakhah baras mēgh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как дождевое облако для посевов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42070,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਪਾਲਨ ਸਰਨਿ ਸੇਂਘ ॥੨॥",
          "roman": "jēsē pālan saran seṅgh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как защита того, кто пришёл под покров льва."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42071,
          "is_rahao": false,
          "gurmukhi": "ਗਰੁੜ ਮੁਖਿ ਨਹੀ ਸਰਪ ਤ੍ਰਾਸ ॥",
          "roman": "garuṛ mukh nahī sarap trās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как у змеи нет страха, когда она в устах Гаруды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42072,
          "is_rahao": false,
          "gurmukhi": "ਸੂਆ ਪਿੰਜਰਿ ਨਹੀ ਖਾਇ ਬਿਲਾਸੁ ॥",
          "roman": "sūā piñjar nahī khāē bilās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как попугай в клетке не вкушает наслаждений на свободе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42073,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੋ ਆਂਡੋ ਹਿਰਦੇ ਮਾਹਿ ॥",
          "roman": "jēso āṇḍo hirdē māh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как яйцо хранится внутри сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42074,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੋ ਦਾਨੋ ਚਕੀ ਦਰਾਹਿ ॥੩॥",
          "roman": "jēso dāno chakī darāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как зерно, попавшее между жерновами мельницы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42075,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁਤੁ ਓਪਮਾ ਥੋਰ ਕਹੀ ॥",
          "roman": "bahut opmā thor kahī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Много сравнений можно привести, но сказано лишь немногое."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42076,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਅਗਮ ਅਗਮ ਅਗਾਧਿ ਤੁਹੀ ॥",
          "roman": "har agam agam agādh tuhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Хари, Ты непостижимый, непостижимый, бездонно глубокий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42077,
          "is_rahao": false,
          "gurmukhi": "ਊਚ ਮੂਚੌ ਬਹੁ ਅਪਾਰ ॥",
          "roman": "ūch mūchau bah apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты высочайший, великий, безмерный и бесконечный."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42078,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਨਕ ਤਰੇ ਸਾਰ ॥੪॥੩॥",
          "roman": "simrat Nānak tarē sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Созерцая Тебя, Нанак переправляется через сущность этого мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3645,
      "rahao_verse_id": 42081,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42079,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
          "roman": "Mālī Gauṛā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42080,
          "is_rahao": true,
          "gurmukhi": "ਇਹੀ ਹਮਾਰੈ ਸਫਲ ਕਾਜ ॥",
          "roman": "ihī hamārē safal kāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это, прибежище у святых, для меня делает успешными все мои стремления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42081,
          "is_rahao": true,
          "gurmukhi": "ਅਪੁਨੇ ਦਾਸ ਕਉ ਲੇਹੁ ਨਿਵਾਜਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "apunē dās kau lēhu nivāj",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, прояви милость к Своему слуге Нанаку и даруй ему прибежище у святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42082,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਸੰਤਹ ਮਾਥ ਮੋਰ ॥",
          "roman": "charaṇ santah māth mor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, пусть мой лоб остаётся у стоп святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42083,
          "is_rahao": false,
          "gurmukhi": "ਨੈਨਿ ਦਰਸੁ ਪੇਖਉ ਨਿਸਿ ਭੋਰ ॥",
          "roman": "nēn daras pēkhau nis bhor",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть моими глазами я день и ночь созерцаю даршан святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42084,
          "is_rahao": false,
          "gurmukhi": "ਹਸਤ ਹਮਰੇ ਸੰਤ ਟਹਲ ॥",
          "roman": "hast hamrē sant ṭahal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть мои руки служат святым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42085,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਾਨ ਮਨੁ ਧਨੁ ਸੰਤ ਬਹਲ ॥੧॥",
          "roman": "prān man dhan sant bahal",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть моя жизнь, мой ум и моё богатство будут отданы святым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42086,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਮੇਰੇ ਮਨ ਕੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "santsang mērē man kī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, сделай так, чтобы любовь моего ума к святым всегда сохранялась."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42087,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਗੁਨ ਬਸਹਿ ਮੇਰੈ ਚੀਤਿ ॥",
          "roman": "sant gun baseh mērē chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть достоинства святых пребывают в моём сознании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42088,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਆਗਿਆ ਮਨਹਿ ਮੀਠ ॥",
          "roman": "sant āgiā maneh mīṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть повеление святых кажется мне сладким в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42089,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਕਮਲੁ ਬਿਗਸੈ ਸੰਤ ਡੀਠ ॥੨॥",
          "roman": "mērā kamal bigsē sant ḍīṭh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть при виде святых лотос моего сердца расцветает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42090,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਮੇਰਾ ਹੋਇ ਨਿਵਾਸੁ ॥",
          "roman": "santsang mērā hōē nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, сделай так, чтобы моё пребывание было среди святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42091,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਨ ਕੀ ਮੋਹਿ ਬਹੁਤੁ ਪਿਆਸ ॥",
          "roman": "santan kī moh bahut piās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть во мне пребывает сильная жажда даршана святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42092,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਬਚਨ ਮੇਰੇ ਮਨਹਿ ਮੰਤ ॥",
          "roman": "sant bachan mērē maneh mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть слова святых как мантры пребывают в моём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42093,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਪ੍ਰਸਾਦਿ ਮੇਰੇ ਬਿਖੈ ਹੰਤ ॥੩॥",
          "roman": "sant prasād mērē bikhē hant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть по милости святых все мои пороки будут уничтожены."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42094,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਜੁਗਤਿ ਏਹਾ ਨਿਧਾਨ ॥",
          "roman": "mukt jugat ēhā nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Общество святых для меня является всеми сокровищами, и общение со святыми есть способ получить освобождение от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42095,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਇਆਲ ਮੋਹਿ ਦੇਵਹੁ ਦਾਨ ॥",
          "roman": "prabh daiāl moh dēvah dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О милосердный Господь, даруй мне этот дар общества святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42096,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਦਇਆ ਧਾਰਿ ॥",
          "roman": "Nānak kau prabh daiā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, прояви милость к Нанаку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42097,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਸੰਤਨ ਕੇ ਮੇਰੇ ਰਿਦੇ ਮਝਾਰਿ ॥੪॥੪॥",
          "roman": "charaṇ santan kē mērē ridē majhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть стопы святых пребывают в сердце меня, Нанака."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3646,
      "rahao_verse_id": 42100,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42098,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ॥",
          "roman": "Mālī Gauṛā mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42099,
          "is_rahao": true,
          "gurmukhi": "ਸਭ ਕੈ ਸੰਗੀ ਨਾਹੀ ਦੂਰਿ ॥",
          "roman": "sabh kē sangī nāhī dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь пребывает со всеми живыми существами и не далёк ни от кого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42100,
          "is_rahao": true,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨ ਹਾਜਰਾ ਹਜੂਰਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "karan karāvan hājrā hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он Сам способен всё совершать и побуждать существ к действию; Он присутствует повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42101,
          "is_rahao": false,
          "gurmukhi": "ਸੁਨਤ ਜੀਓ ਜਾਸੁ ਨਾਮੁ ॥",
          "roman": "sunat jīo jās nām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слушая имя того Господа, человек получает духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42102,
          "is_rahao": false,
          "gurmukhi": "ਦੁਖ ਬਿਨਸੇ ਸੁਖ ਕੀਓ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "dukh binsē sukh kīo bisrām",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все страдания исчезают, и покой приходит поселиться в сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42103,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਨਿਧਿ ਹਰਿ ਹਰਿ ਹਰੇ ॥",
          "roman": "sagal nidh har har harē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все сокровища находятся у того Параматмы, Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42104,
          "is_rahao": false,
          "gurmukhi": "ਮੁਨਿ ਜਨ ਤਾ ਕੀ ਸੇਵ ਕਰੇ ॥੧॥",
          "roman": "mun jan tā kī sēv karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все мудрецы и отшельники совершают преданное служение Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42105,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਘਰਿ ਸਗਲੇ ਸਮਾਹਿ ॥",
          "roman": "jā kē ghar saglē samāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В доме того милостивого Господа пребывают все сокровища."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42106,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਤੇ ਬਿਰਥਾ ਕੋਇ ਨਾਹਿ ॥",
          "roman": "jis tē birthā kōē nāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От Его двери ни одно существо не уходит пустым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42107,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ੍ਰ ਕਰੇ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "jīa jantar karē pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он поддерживает и питает всех живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42108,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਸੇਵਹੁ ਕਿਰਪਾਲ ॥੨॥",
          "roman": "sadā sadā sēvahu kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всегда, всегда совершайте преданное служение этому милостивому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42109,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਧਰਮੁ ਜਾ ਕੈ ਦੀਬਾਣਿ ॥",
          "roman": "sadā dharam jā kē dībāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Его суде всегда царит справедливость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42110,
          "is_rahao": false,
          "gurmukhi": "ਬੇਮੁਹਤਾਜ ਨਹੀ ਕਿਛੁ ਕਾਣਿ ॥",
          "roman": "bēmuhatāj nahī kichh kāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он независим, Ему не нужна ничья поддержка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42111,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਕਿਛੁ ਕਰਨਾ ਆਪਨ ਆਪਿ ॥",
          "roman": "sabh kichh karnā āpan āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он Сам способен совершать всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42112,
          "is_rahao": false,
          "gurmukhi": "ਰੇ ਮਨ ਮੇਰੇ ਤੂ ਤਾ ਕਉ ਜਾਪਿ ॥੩॥",
          "roman": "rē man mērē tū tā kau jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой ум, повторяй имя этого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42113,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਕਉ ਹਉ ਬਲਿਹਾਰ ॥",
          "roman": "sādhsangat kau hau balihār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я приношу себя в жертву обществу Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42114,
          "is_rahao": false,
          "gurmukhi": "ਜਾਸੁ ਮਿਲਿ ਹੋਵੈ ਉਧਾਰੁ ॥",
          "roman": "jās mil hōvē udhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встретившись с ним, человек получает Имя Параматмы и переправляется через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42115,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਸੰਗਿ ਮਨ ਤਨਹਿ ਰਾਤ ॥",
          "roman": "nām sang man taneh rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кому Господь дарует дар Имени через Гуру, остаётся окрашенным Именем; Имя пребывает в его уме и теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42116,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭਿ ਕਰੀ ਦਾਤਿ ॥੪॥੫॥",
          "roman": "Nānak kau prabh karī dāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь даровал Нанаку этот дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3647,
      "rahao_verse_id": 42120,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42117,
          "is_rahao": true,
          "gurmukhi": "ਮਾਲੀ ਗਉੜਾ ਮਹਲਾ ੫ ਦੁਪਦੇ",
          "roman": "Mālī Gauṛā mahalā 5 dupadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мали Гаура, Пятый Махала, двустишия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42118,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один Эконкар, по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42119,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਸਮਰਥ ਕੀ ਸਰਨਾ ॥",
          "roman": "har samrath kī sarnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я пришёл под прибежище того Параматмы, который является обладателем всех сил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42120,
          "is_rahao": true,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਧਨੁ ਰਾਸਿ ਮੇਰੀ ਪ੍ਰਭ ਏਕ ਕਾਰਨ ਕਰਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jīo piṇḍ dhan rās mērī prabh ēk kāran karnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Моя жизнь, моё тело, моё богатство, весь мой капитал — всё это тот единый Господь, который является корнем всего мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42121,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸਦਾ ਸੁਖੁ ਪਾਈਐ ਜੀਵਣੈ ਕਾ ਮੂਲੁ ॥",
          "roman": "simar simar sadā sukh pāīē jīvaṇē kā mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Снова и снова вспоминая Имя Параматмы, человек всегда получает духовное блаженство; Имя Хари — опора жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42122,
          "is_rahao": false,
          "gurmukhi": "ਰਵਿ ਰਹਿਆ ਸਰਬਤ ਠਾਈ ਸੂਖਮੋ ਅਸਥੂਲ ॥੧॥",
          "roman": "rav rahiā sarbat ṭhāī sūkhamo asthūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во всех видимых и невидимых вещах, во всех местах присутствует один Параматма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
