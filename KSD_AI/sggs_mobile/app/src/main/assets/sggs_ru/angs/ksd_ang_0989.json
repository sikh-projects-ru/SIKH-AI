{
  "ang": 989,
  "shabads": [
    {
      "shabad_id": 3653,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42162,
          "is_rahao": false,
          "gurmukhi": "ਰਾਗੁ ਮਾਰੂ ਮਹਲਾ ੧ ਘਰੁ ੧ ਚਉਪਦੇ",
          "roman": "rāg mārū mahalā 1 ghar 1 chaupadē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Мару, Махала 1, дом 1, четверостишия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42163,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿ ਨਾਮੁ ਕਰਤਾ ਪੁਰਖੁ ਨਿਰਭਉ ਨਿਰਵੈਰੁ ਅਕਾਲ ਮੂਰਤਿ ਅਜੂਨੀ ਸੈਭੰ ਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār sat nām kartā purakh nirbhau nirvēr akāl mūrat ajūnī sēbhaṅ gur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар: Истинное Имя, Творец-Существо, без страха, без вражды, вне времени, нерождённый, самосущий; познаётся по милости Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42164,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕੁ ॥",
          "roman": "salok",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шлок."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42165,
          "is_rahao": false,
          "gurmukhi": "ਸਾਜਨ ਤੇਰੇ ਚਰਨ ਕੀ ਹੋਇ ਰਹਾ ਸਦ ਧੂਰਿ ॥",
          "roman": "sājan tērē charan kī hoi rahā sad dhūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Друг-Господь, дай мне способность всегда оставаться пылью Твоих стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42166,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਰਣਿ ਤੁਹਾਰੀਆ ਪੇਖਉ ਸਦਾ ਹਜੂਰਿ ॥੧॥",
          "roman": "nānak saraṇ tuhārīā pēkhau sadā hajūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: я пришёл в Твоё прибежище; дай мне всегда видеть Тебя рядом, вместе со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3654,
      "rahao_verse_id": 42172,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42167,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦ ॥",
          "roman": "sabad",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шабад."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42168,
          "is_rahao": false,
          "gurmukhi": "ਪਿਛਹੁ ਰਾਤੀ ਸਦੜਾ ਨਾਮੁ ਖਸਮ ਕਾ ਲੇਹਿ ॥",
          "roman": "pichha rātī sadṛā nām khasam kā lēh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те счастливые люди, которым в амрит-веле Сам Господь посылает зов любви, встают тогда и принимают Имя Хозяина-Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42169,
          "is_rahao": false,
          "gurmukhi": "ਖੇਮੇ ਛਤ੍ਰ ਸਰਾਇਚੇ ਦਿਸਨਿ ਰਥ ਪੀੜੇ ॥",
          "roman": "khēmē chhatar sarāichey disan rath pīṛē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шатры, царские зонты, навесы и готовые колесницы постоянно видны у их дверей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42170,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੀ ਤੇਰਾ ਨਾਮੁ ਧਿਆਇਆ ਤਿਨ ਕਉ ਸਦਿ ਮਿਲੇ ॥੧॥",
          "roman": "jinī tērā nām dhiāiā tin kau sad milē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все эти знаки мирской чести и славы сами приходят к тем, кто, о Господь, медитировал на Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42171,
          "is_rahao": true,
          "gurmukhi": "ਬਾਬਾ ਮੈ ਕਰਮਹੀਣ ਕੂੜਿਆਰ ॥",
          "roman": "bābā mē karamhīṇ kūṛiār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Господь, я оставался несчастливым и торговал только ложными вещами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42172,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮੁ ਨ ਪਾਇਆ ਤੇਰਾ ਅੰਧਾ ਭਰਮਿ ਭੂਲਾ ਮਨੁ ਮੇਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām na pāiā tērā andhā bharam bhūlā man mērā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ослеплённый привязанностью к майе, мой ум ради майи блуждал и сбивался с пути; я не смог обрести Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42173,
          "is_rahao": false,
          "gurmukhi": "ਸਾਦ ਕੀਤੇ ਦੁਖ ਪਰਫੁੜੇ ਪੂਰਬਿ ਲਿਖੇ ਮਾਇ ॥",
          "roman": "sād kītē dukh parphuṛē pūrab likhē māi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мать, я наслаждался вкусами многих мирских предметов; следы поступков прежних бесчисленных жизней отпечатывались в моём уме, и взамен этих наслаждений мои страдания возрастали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42174,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖ ਥੋੜੇ ਦੁਖ ਅਗਲੇ ਦੂਖੇ ਦੂਖਿ ਵਿਹਾਇ ॥੨॥",
          "roman": "sukh thōṛē dukh aglē dūkhē dūkh vihāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Радостей я испытал лишь немного, а страдания возникли безмерные; теперь моя жизнь проходит в одном лишь страдании."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42175,
          "is_rahao": false,
          "gurmukhi": "ਵਿਛੁੜਿਆ ਕਾ ਕਿਆ ਵੀਛੁੜੈ ਮਿਲਿਆ ਕਾ ਕਿਆ ਮੇਲੁ ॥",
          "roman": "vichhuṛiā kā kiā vīchhuṛē miliā kā kiā mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тем, кто отделён от Бога, от какого ещё дорогого предмета оставаться отделёнными? А тем, кто соединён со стопами Господа, с каким ещё высшим предметом остаётся соединяться?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42176,
          "is_rahao": false,
          "gurmukhi": "ਸਾਹਿਬੁ ਸੋ ਸਾਲਾਹੀਐ ਜਿਨਿ ਕਰਿ ਦੇਖਿਆ ਖੇਲੁ ॥੩॥",
          "roman": "sāhib so sālāhīai jin kar dēkhiā khēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следует всегда восхвалять того Владыку, который создал эту мировую игру и, создав, сам заботится о ней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42177,
          "is_rahao": false,
          "gurmukhi": "ਸੰਜੋਗੀ ਮੇਲਾਵੜਾ ਇਨਿ ਤਨਿ ਕੀਤੇ ਭੋਗ ॥",
          "roman": "sanjōgī mēlāvaṛā in tan kītē bhōg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По благословенному соединению от Бога человек получил прекрасную встречу с человеческим телом, но, придя в это тело, наслаждался только вкусами майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42178,
          "is_rahao": false,
          "gurmukhi": "ਵਿਜੋਗੀ ਮਿਲਿ ਵਿਛੁੜੇ ਨਾਨਕ ਭੀ ਸੰਜੋਗ ॥੪॥੧॥",
          "roman": "vijōgī mil vichhuṛē nānak bhī sanjōg",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда по Его воле пришла смерть, человек, встретившись с телом, снова отделился от него; из-за наслаждений майей ему вновь и вновь пришлось проходить круги многих рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3655,
      "rahao_verse_id": 42185,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42179,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੧ ॥",
          "roman": "mārū mahalā 1",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, Махала 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42180,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਮਾਤ ਪਿਤਾ ਪਿੰਡੁ ਕਮਾਇਆ ॥",
          "roman": "mil māt pitā piṇḍ kamāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "По воле Творца твои мать и отец соединились и создали твоё тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42181,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਕਰਤੈ ਲੇਖੁ ਲਿਖਾਇਆ ॥",
          "roman": "tin kartē lēkh likhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот же Творец написал на твоём челе предназначение твоих должных дел."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42182,
          "is_rahao": false,
          "gurmukhi": "ਲਿਖੁ ਦਾਤਿ ਜੋਤਿ ਵਡਿਆਈ ॥",
          "roman": "likh dāt jōt vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он назначил тебе помнить дары Светоносного Господа и совершать Его хвалу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42183,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਮਾਇਆ ਸੁਰਤਿ ਗਵਾਈ ॥੧॥",
          "roman": "mil māiā surat gavāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но ты, попав в привязанность к майе, потерял это памятование."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42184,
          "is_rahao": true,
          "gurmukhi": "ਮੂਰਖ ਮਨ ਕਾਹੇ ਕਰਸਹਿ ਮਾਣਾ ॥",
          "roman": "mūrakh man kāhē karsah māṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой глупый ум, почему ты гордишься этими мирскими владениями?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42185,
          "is_rahao": true,
          "gurmukhi": "ਉਠਿ ਚਲਣਾ ਖਸਮੈ ਭਾਣਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "uṭh chalṇā khasmē bhāṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда таков будет приказ Господа-Хозяина, тебе придётся подняться, оставить их и уйти из мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42186,
          "is_rahao": false,
          "gurmukhi": "ਤਜਿ ਸਾਦ ਸਹਜ ਸੁਖੁ ਹੋਈ ॥",
          "roman": "taj sād sahaj sukh hōī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О ум, отказавшись от вкусов майи, можно обрести радость духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42187,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਛਡਣੇ ਰਹੈ ਨ ਕੋਈ ॥",
          "roman": "ghar chhaḍṇē rahē na kōī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Эти дома и владения придётся оставить; ни одно существо не может оставаться здесь вечно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42188,
          "is_rahao": false,
          "gurmukhi": "ਕਿਛੁ ਖਾਜੈ ਕਿਛੁ ਧਰਿ ਜਾਈਐ ॥",
          "roman": "kichh khājē kichh dhar jāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты всё думаешь: часть богатства и вещей употребим, а часть будем хранить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42189,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਬਾਹੁੜਿ ਦੁਨੀਆ ਆਈਐ ॥੨॥",
          "roman": "jē bāhuṛ dunīā āīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но польза от сохранённого была бы лишь тогда, если бы можно было снова вернуться в мир и воспользоваться этим богатством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42190,
          "is_rahao": false,
          "gurmukhi": "ਸਜੁ ਕਾਇਆ ਪਟੁ ਹਢਾਏ ॥",
          "roman": "saj kāiā paṭ haḍhāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек носит на теле ожерелья, шёлковые одежды и другие украшения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42191,
          "is_rahao": false,
          "gurmukhi": "ਫੁਰਮਾਇਸਿ ਬਹੁਤੁ ਚਲਾਏ ॥",
          "roman": "phurmāis bahut chalāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он много распоряжается и проявляет власть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42192,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਸੇਜ ਸੁਖਾਲੀ ਸੋਵੈ ॥",
          "roman": "kar sēj sukhālī sōvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он устраивает мягкую постель и наслаждается её удобством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42193,
          "is_rahao": false,
          "gurmukhi": "ਹਥੀ ਪਉਦੀ ਕਾਹੇ ਰੋਵੈ ॥੩॥",
          "roman": "hathī paundī kāhē rōvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но когда он попадает в руки посланцев смерти, плач и сожаление уже не приносят никакой пользы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42194,
          "is_rahao": false,
          "gurmukhi": "ਘਰ ਘੁੰਮਣਵਾਣੀ ਭਾਈ ॥",
          "roman": "ghar ghumaṇvāṇī bhāī",
          "translations": {
