{
  "ang": 1004,
  "shabads": [
    {
      "shabad_id": 3697,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42721,
          "is_rahao": false,
          "gurmukhi": "ਬਾਝੁ ਗੁਰੂ ਗੁਬਾਰਾ ॥",
          "roman": "bājh gurū gubārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Без Гуру — густая тьма."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42722,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਸਤਿਗੁਰ ਨਿਸਤਾਰਾ ॥੨॥",
          "roman": "mil satigur nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Встретив Сатгуру, человек получает освобождение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42723,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਹਉ ਕਰਮ ਕਮਾਣੇ ॥",
          "roman": "hau hau karam kamāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Поступки, совершаемые в Хоумэ, с чувством «я, я»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42724,
          "is_rahao": false,
          "gurmukhi": "ਤੇ ਤੇ ਬੰਧ ਗਲਾਣੇ ॥",
          "roman": "tē tē bandh galāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все они становятся путами, надетыми на шею."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42725,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੀ ਮੇਰੀ ਧਾਰੀ ॥",
          "roman": "mērī mērī dhārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда человек держится за мысль «моё, моё»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42726,
          "is_rahao": false,
          "gurmukhi": "ਓਹਾ ਪੈਰਿ ਲੋਹਾਰੀ ॥",
          "roman": "ohā pēr lohārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно это становится железными оковами на его ногах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42727,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਗੁਰ ਮਿਲਿ ਏਕੁ ਪਛਾਣੈ ॥",
          "roman": "so gur mil ēk pachhāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, встретив Гуру, узнаёт Единого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42728,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਹੋਵੈ ਭਾਗੁ ਮਥਾਣੈ ॥੩॥",
          "roman": "jis hovē bhāg mathāṇē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У кого на челе есть такая доля судьбы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42729,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਮਿਲਿਆ ਜਿ ਹਰਿ ਮਨਿ ਭਾਇਆ ॥",
          "roman": "so miliā je har man bhāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соединяется с Богом тот, кто приятен сердцу Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42730,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਭੂਲਾ ਜਿ ਪ੍ਰਭੂ ਭੁਲਾਇਆ ॥",
          "roman": "so bhūlā je prabhū bhulāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Заблуждается тот, кого Сам Господь вводит в забвение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42731,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਆਪਹੁ ਮੂਰਖੁ ਗਿਆਨੀ ॥",
          "roman": "nah āph mūrakh giānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Никто сам по себе не бывает ни глупцом, ни мудрецом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42732,
          "is_rahao": false,
          "gurmukhi": "ਜਿ ਕਰਾਵੈ ਸੁ ਨਾਮੁ ਵਖਾਨੀ ॥",
          "roman": "je karāvē so nām vakhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Как Он заставляет, так человек и произносит Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42733,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰਾ ਅੰਤੁ ਨ ਪਾਰਾਵਾਰਾ ॥",
          "roman": "tērā ant na pārāvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет предела Тебе, нет ни дальнего, ни ближнего берега Твоего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42734,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਸਦ ਬਲਿਹਾਰਾ ॥੪॥੧॥੧੭॥",
          "roman": "jan Nānak sad balihārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак всегда приносит себя в жертву Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3698,
      "rahao_verse_id": 42740,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42735,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42736,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਨੀ ਮੋਹਿ ਲੀਏ ਤ੍ਰੈ ਗੁਨੀਆ ॥",
          "roman": "mohanī moh līē trē guṇīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Майя, очаровывающая сила, подчинила себе всех существ, находящихся под влиянием трёх гун."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42737,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭਿ ਵਿਆਪੀ ਝੂਠੀ ਦੁਨੀਆ ॥",
          "roman": "lobh viāpī jhūṭhī dunīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Весь мир увяз в жадности к этой преходящей вселенной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42738,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰੀ ਮੇਰੀ ਕਰਿ ਕੈ ਸੰਚੀ ਅੰਤ ਕੀ ਬਾਰ ਸਗਲ ਲੇ ਛਲੀਆ ॥੧॥",
          "roman": "mērī mērī kar kē sañchī ant kī bār sagal lē chhalīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все, цепляясь за «моё, моё», копят майю, но в последний миг она обманывает всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42739,
          "is_rahao": true,
          "gurmukhi": "ਨਿਰਭਉ ਨਿਰੰਕਾਰੁ ਦਇਅਲੀਆ ॥",
          "roman": "nirbhau niraṅkār daialīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог бесстрашен, бесформен и является обителью милости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42740,
          "is_rahao": true,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਸਗਲੇ ਪ੍ਰਤਿਪਲੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jīa jant saglē pratipalīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он питает и поддерживает всех живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42741,
          "is_rahao": false,
          "gurmukhi": "ਏਕੈ ਸ੍ਰਮੁ ਕਰਿ ਗਾਡੀ ਗਡਹੈ ॥",
          "roman": "ēkē sram kar gāḍī gaḍahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Один человек с большим трудом зарабатывает и зарывает богатство в землю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42742,
          "is_rahao": false,
          "gurmukhi": "ਏਕਹਿ ਸੁਪਨੈ ਦਾਮੁ ਨ ਛਡਹੈ ॥",
          "roman": "ēkeh supnē dām na chhaḍahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Другой даже во сне не выпускает деньги из рук."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42743,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜੁ ਕਮਾਇ ਕਰੀ ਜਿਨਿ ਥੈਲੀ ਤਾ ਕੈ ਸੰਗਿ ਨ ਚੰਚਲਿ ਚਲੀਆ ॥੨॥",
          "roman": "rāj kamāe karī jin thēlī tā kē saṅg na chañchal chalīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже с тем, кто правлением собрал казну, эта непостоянная майя не уходит вместе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42744,
          "is_rahao": false,
          "gurmukhi": "ਏਕਹਿ ਪ੍ਰਾਣ ਪਿੰਡ ਤੇ ਪਿਆਰੀ ॥",
          "roman": "ēkeh prāṇ piṇḍ tē piārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Для одного эта майя становится дороже жизни и тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42745,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਸੰਚੀ ਤਜਿ ਬਾਪ ਮਹਤਾਰੀ ॥",
          "roman": "ēk sañchī taj bāp mahatārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Другой, оставив отца и мать, продолжает копить её."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42746,
          "is_rahao": false,
          "gurmukhi": "ਸੁਤ ਮੀਤ ਭ੍ਰਾਤ ਤੇ ਗੁਹਜੀ ਤਾ ਕੈ ਨਿਕਟਿ ਨ ਹੋਈ ਖਲੀਆ ॥੩॥",
          "roman": "sut mīt bhrāt tē guhajī tā kē nikaṭ na hoī khalīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он прячет её от сыновей, друзей и братьев, но и возле него она не остаётся."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42747,
          "is_rahao": false,
          "gurmukhi": "ਹੋਇ ਅਉਧੂਤ ਬੈਠੇ ਲਾਇ ਤਾਰੀ ॥",
          "roman": "hoe audhūt bēṭhē lāe tārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Некоторые становятся отречёнными и сидят, погрузившись в самадхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42748,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਜਤੀ ਪੰਡਿਤ ਬੀਚਾਰੀ ॥",
          "roman": "jogī jatī paṇḍit bīchārī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Есть йоги, воздержанные подвижники и рассудительные пандиты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42749,
          "is_rahao": false,
          "gurmukhi": "ਗ੍ਰਿਹਿ ਮੜੀ ਮਸਾਣੀ ਬਨ ਮਹਿ ਬਸਤੇ ਊਠਿ ਤਿਨਾ ਕੈ ਲਾਗੀ ਪਲੀਆ ॥੪॥",
          "roman": "grih maṛī masāṇī ban meh bastē ūṭh tinā kē lāgī palīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Одни живут дома, другие в гробницах, местах кремации и лесах, но майя поднимается и цепляется даже к ним."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42750,
          "is_rahao": false,
          "gurmukhi": "ਕਾਟੇ ਬੰਧਨ ਠਾਕੁਰਿ ਜਾ ਕੇ ॥",
          "roman": "kāṭē bandhan ṭhākur jā kē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех людей, чьи путы привязанности к майе Владыка-Прабху разрубил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42751,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਬਸਿਓ ਜੀਅ ਤਾ ਕੈ ॥",
          "roman": "har har nām basiō jīa tā kē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В их сердцах навсегда поселилось Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42752,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਭਏ ਜਨ ਮੁਕਤੇ ਗਤਿ ਪਾਈ ਨਾਨਕ ਨਦਰਿ ਨਿਹਲੀਆ ॥੫॥੨॥੧੮॥",
          "roman": "sādhasaṅg bhaē jan muktē gat pāī Nānak nadar nihalīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В Садхсангате они стали свободны от сетей майи; о Нанак, когда Бог взглянул на них милостиво, они достигли высшего духовного состояния."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3699,
      "rahao_verse_id": 42767,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42753,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, пятый Махла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42754,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹੁ ਏਕੁ ਨਿਰੰਜਨ ਸੋਊ ॥",
          "roman": "simrah ēk nirañjan soū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Помните того единого незапятнанного майей Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42755,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਤੇ ਬਿਰਥਾ ਜਾਤ ਨ ਕੋਊ ॥",
          "roman": "jā tē birthā jāt na koū",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От Его двери никто не уходит пустым."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42756,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ ਗਰਭ ਮਹਿ ਜਿਨਿ ਪ੍ਰਤਿਪਾਰਿਆ ॥",
          "roman": "māt garabh meh jin pratipāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он заботился о тебе ещё в утробе матери."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42757,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪਿੰਡੁ ਦੇ ਸਾਜਿ ਸਵਾਰਿਆ ॥",
          "roman": "jīu piṇḍ dē sāj savāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дав жизнь и тело, Он создал тебя и украсил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42758,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਬਿਧਾਤਾ ਖਿਨੁ ਖਿਨੁ ਜਪੀਐ ॥",
          "roman": "soī bidhātā khin khin japīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Именно этого Творца следует повторять каждое мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42759,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਅਵਗੁਣ ਸਭਿ ਢਕੀਐ ॥",
          "roman": "jis simrat avguṇ sabh ḍhakīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Помня Его, можно покрыть все свои недостатки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42760,
          "is_rahao": false,
          "gurmukhi": "ਚਰਣ ਕਮਲ ਉਰ ਅੰਤਰਿ ਧਾਰਹੁ ॥",
          "roman": "charaṇ kamal ur antar dhārah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Утвердите прекрасные лотосные стопы Бога в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42761,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਿਆ ਬਨ ਤੇ ਜੀਉ ਉਧਾਰਹੁ ॥",
          "roman": "bikhiā ban tē jīu udhārah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так спасите свою душу из вод майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42762,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਪਲਾਹ ਮਿਟਹਿ ਬਿਲਲਾਟਾ ॥",
          "roman": "karaṇ palāh miṭah billāṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Благодаря симрану исчезают все плачи и скорбные вопли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42763,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਗੋਵਿਦ ਭਰਮੁ ਭਉ ਫਾਟਾ ॥",
          "roman": "jap govind bharam bhau phāṭā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Говинда, человек разрывает завесу блуждания и страха."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42764,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਵਿਰਲਾ ਕੋ ਪਾਏ ॥",
          "roman": "sādhasaṅg virlā ko pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но лишь редкий человек получает Имя в Садхсангате."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42765,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਤਾ ਕੈ ਬਲਿ ਬਲਿ ਜਾਏ ॥੧॥",
          "roman": "Nānak tā kē bal bal jāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак снова и снова приносит себя в жертву такому человеку."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42766,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਮਨਿ ਤਨਿ ਆਧਾਰਾ ॥",
          "roman": "rām nām man tan ādhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сделай Имя Рама опорой своего ума, тела и всей жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42767,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਸਿਮਰੈ ਤਿਸ ਕਾ ਨਿਸਤਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo simrē tis kā nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто помнит Имя, переправляется через мирской океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42768,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥਿਆ ਵਸਤੁ ਸਤਿ ਕਰਿ ਮਾਨੀ ॥",
          "roman": "mithiā vasat sat kar mānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты принимаешь преходящую вещь за вечную."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42769,
          "is_rahao": false,
          "gurmukhi": "ਹਿਤੁ ਲਾਇਓ ਸਠ ਮੂੜ ਅਗਿਆਨੀ ॥",
          "roman": "hit lāiō saṭh mūṛ agiānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О злой, глупый, неразумный человек, ты привязал к ней свою любовь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42770,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ ਮਦ ਮਾਤਾ ॥",
          "roman": "kām krodh lobh mad mātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты опьянён вожделением, гневом, жадностью и гордыней."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42771,
          "is_rahao": false,
          "gurmukhi": "ਕਉਡੀ ਬਦਲੈ ਜਨਮੁ ਗਵਾਤਾ ॥",
          "roman": "kauḍī badlē janam gavātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так ты теряешь драгоценное человеческое рождение в обмен на раковину каури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42772,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨਾ ਛੋਡਿ ਪਰਾਇਐ ਰਾਤਾ ॥",
          "roman": "apnā chhoḍ parāiē rātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставив своего истинного Спутника, Бога, ты влюбился в чужое, уходящее богатство."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42773,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮਦ ਮਨ ਤਨ ਸੰਗਿ ਜਾਤਾ ॥",
          "roman": "māiā mad man tan saṅg jātā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты опьянён майей и, следуя за умом, мечешься ради тела."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42774,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਸਨ ਨ ਬੂਝੈ ਕਰਤ ਕਲੋਲਾ ॥",
          "roman": "trisan na būjhē karat kalolā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наслаждаясь мирскими забавами, ты всё равно не утоляешь жажду желаний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42775,
          "is_rahao": false,
          "gurmukhi": "ਊਣੀ ਆਸ ਮਿਥਿਆ ਸਭਿ ਬੋਲਾ ॥",
          "roman": "ūṇī ās mithiā sabh bolā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твоя надежда никогда не исполняется, и все твои слова — только о преходящей майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42776,
          "is_rahao": false,
          "gurmukhi": "ਆਵਤ ਇਕੇਲਾ ਜਾਤ ਇਕੇਲਾ ॥",
          "roman": "āvat ikēlā jāt ikēlā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Живое существо приходит в этот мир одно и уходит отсюда одно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
