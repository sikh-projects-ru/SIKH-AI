{
  "ang": 1005,
  "shabads": [
    {
      "shabad_id": 3699,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42777,
          "is_rahao": false,
          "gurmukhi": "ਹਮ ਤੁਮ ਸੰਗਿ ਝੂਠੇ ਸਭਿ ਬੋਲਾ ॥",
          "roman": "ham tum saṅg jhūṭhē sabh bolā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все эти речи: «я с тобой, ты со мной» — ложны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42778,
          "is_rahao": false,
          "gurmukhi": "ਪਾਇ ਠਗਉਰੀ ਆਪਿ ਭੁਲਾਇਓ ॥",
          "roman": "pāi ṭhagaurī āp bhulāio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сам Он дал опьяняющее средство обмана и ввёл в заблуждение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42779,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਿਰਤੁ ਨ ਜਾਇ ਮਿਟਾਇਓ ॥੨॥",
          "roman": "Nānak kirat na jāi miṭāio",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак: плоды совершённых поступков не могут быть стёрты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42780,
          "is_rahao": false,
          "gurmukhi": "ਪਸੁ ਪੰਖੀ ਭੂਤ ਅਰੁ ਪ੍ਰੇਤਾ ॥",
          "roman": "pas paṅkhī bhūt ar pretā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат, ослеплённое привязанностью к майе существо блуждает в разных рождениях — как животное, птица, дух и призрак."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42781,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਬਿਧਿ ਜੋਨੀ ਫਿਰਤ ਅਨੇਤਾ ॥",
          "roman": "bah bidh jonī phirat anetā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ослеплённый живой скитается по многим видам утроб и рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42782,
          "is_rahao": false,
          "gurmukhi": "ਜਹ ਜਾਨੋ ਤਹ ਰਹਨੁ ਨ ਪਾਵੈ ॥",
          "roman": "jah jāno tah rahan na pāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Там, куда ему действительно следует прийти, у Стоп Господа, он не может обрести устойчивого пребывания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42783,
          "is_rahao": false,
          "gurmukhi": "ਥਾਨ ਬਿਹੂਨ ਉਠਿ ਉਠਿ ਫਿਰਿ ਧਾਵੈ ॥",
          "roman": "thān bihūn uṭh uṭh phir dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Оставшись без настоящего места, он снова и снова поднимается и мечется по другим рождениям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42784,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਤਨਿ ਬਾਸਨਾ ਬਹੁਤੁ ਬਿਸਥਾਰਾ ॥",
          "roman": "man tan bāsanā bahut bisthārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из-за привязанности к майе в уме и теле человека широко разрастаются многочисленные желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42785,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਮੇਵ ਮੂਠੋ ਬੇਚਾਰਾ ॥",
          "roman": "ahaṅmēv mūṭho bechārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хоумэ, чувство «я, только я», грабит духовную жизнь этого беспомощного."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42786,
          "is_rahao": false,
          "gurmukhi": "ਅਨਿਕ ਦੋਖ ਅਰੁ ਬਹੁਤੁ ਸਜਾਈ ॥",
          "roman": "anik dokh ar bahut sajāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В нём возникают многие пороки, и за них он получает тяжёлые наказания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42787,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈ ॥",
          "roman": "tā kī kīmat kahan na jāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нельзя назвать никакой цены, никакого мирского средства, которым можно было бы освободиться от этой кары."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42788,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਬਿਸਰਤ ਨਰਕ ਮਹਿ ਪਾਇਆ ॥",
          "roman": "Prabh bisrat narak meh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Забыв Имя Бога, существо бывает брошено в адское состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42789,
          "is_rahao": false,
          "gurmukhi": "ਤਹ ਮਾਤ ਨ ਬੰਧੁ ਨ ਮੀਤ ਨ ਜਾਇਆ ॥",
          "roman": "tah māt na bandh na mīt na jāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Там не могут помочь ни мать, ни родственник, ни друг, ни жена."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42790,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਉ ਹੋਤ ਕ੍ਰਿਪਾਲ ਸੁਆਮੀ ॥",
          "roman": "jis kau hot kirpāl suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, к кому Владыка-Господь становится милостивым..."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42791,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਨਾਨਕ ਪਾਰਗਰਾਮੀ ॥੩॥",
          "roman": "so jan Nānak pārgarāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: такой человек становится способным переправиться через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42792,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮਤ ਭ੍ਰਮਤ ਪ੍ਰਭ ਸਰਨੀ ਆਇਆ ॥",
          "roman": "bhramat bhramat Prabh sarnī āiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Блуждая и блуждая, живое существо в конце приходит под защиту Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42793,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨਾ ਨਾਥ ਜਗਤ ਪਿਤ ਮਾਇਆ ॥",
          "roman": "dīnā nāth jagat pit māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь — Владыка смиренных, отец и мать мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42794,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਦਇਆਲ ਦੁਖ ਦਰਦ ਬਿਦਾਰਣ ॥",
          "roman": "Prabh daiāl dukh darad bidāraṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь — дом милости, уничтожающий страдания и боли живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42795,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਭਾਵੈ ਤਿਸ ਹੀ ਨਿਸਤਾਰਣ ॥",
          "roman": "jis bhāvē tis hī nistāraṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Того, кто становится угоден Ему, Господь переправляет через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42796,
          "is_rahao": false,
          "gurmukhi": "ਅੰਧ ਕੂਪ ਤੇ ਕਾਢਨਹਾਰਾ ॥",
          "roman": "andh kūp te kāḍhanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь способен вывести существо из слепого колодца этого мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42797,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰੇਮ ਭਗਤਿ ਹੋਵਤ ਨਿਸਤਾਰਾ ॥",
          "roman": "prem bhagat hovat nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Через любящую преданность Господу живое существо получает спасительное переправление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42798,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਰੂਪ ਅਪਨਾ ਤਨੁ ਧਾਰਿਆ ॥",
          "roman": "sādh rūp apnā tan dhāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог Сам принял Своё тело в образе Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42799,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਅਗਨਿ ਤੇ ਆਪਿ ਉਬਾਰਿਆ ॥",
          "roman": "mahā agan te āp ubāriā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И Сам всегда спасает живых существ от великого огня майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42800,
          "is_rahao": false,
          "gurmukhi": "ਜਪ ਤਪ ਸੰਜਮ ਇਸ ਤੇ ਕਿਛੁ ਨਾਹੀ ॥",
          "roman": "jap tap sanjam is te kichh nāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Иначе это существо само не способно совершать ни Джап, ни тапас, ни труд самообуздания и чистого поведения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42801,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਅੰਤਿ ਪ੍ਰਭ ਅਗਮ ਅਗਾਹੀ ॥",
          "roman": "ād ant Prabh agam agāhī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, от начала до конца мира Ты один пребываешь; Ты недостижим и бездонен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42802,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਦੇਹਿ ਮਾਗੈ ਦਾਸੁ ਤੇਰਾ ॥",
          "roman": "nām deh māgē dās terā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твой слуга просит у Твоих Дверей дар Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42803,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਜੀਵਨ ਪਦੁ ਨਾਨਕ ਪ੍ਰਭੁ ਮੇਰਾ ॥੪॥੩॥੧੯॥",
          "roman": "Har jīvan pad Nānak Prabh merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: мой Хари-Господь — Податель состояния духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3700,
      "rahao_verse_id": 42807,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42804,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42805,
          "is_rahao": false,
          "gurmukhi": "ਕਤ ਕਉ ਡਹਕਾਵਹੁ ਲੋਗਾ ਮੋਹਨ ਦੀਨ ਕਿਰਪਾਈ ॥੧॥",
          "roman": "kat kau ḍahkāvahu logā mohan dīn kirpāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О люди, зачем вы колеблете свой ум? Прекрасный Господь милостив к смиренным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42806,
          "is_rahao": true,
          "gurmukhi": "ਐਸੀ ਜਾਨਿ ਪਾਈ ॥",
          "roman": "aisī jān pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я понял это именно так."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42807,
          "is_rahao": true,
          "gurmukhi": "ਸਰਣਿ ਸੂਰੋ ਗੁਰ ਦਾਤਾ ਰਾਖੈ ਆਪਿ ਵਡਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "saraṇ sūro gur dātā rākhē āp vaḍāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Бог — величайший Даритель, герой, помогающий тем, кто пришёл под Его защиту; Он Сам хранит честь Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42808,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਾ ਕਾ ਆਗਿਆਕਾਰੀ ਸਦਾ ਸਦਾ ਸੁਖਦਾਈ ॥੨॥",
          "roman": "bhagtā kā āgiākārī sadā sadā sukhdāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь принимает просьбу Своих преданных и всегда дарует им покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42809,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਕਉ ਕਿਰਪਾ ਕਰੀਅਹੁ ਇਕੁ ਨਾਮੁ ਧਿਆਈ ॥੩॥",
          "roman": "apne kau kirpā karīah ik nām dhiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, окажи милость Своему слуге, чтобы я, Твой слуга, созерцал только Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42810,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਦੀਨੁ ਨਾਮੁ ਮਾਗੈ ਦੁਤੀਆ ਭਰਮੁ ਚੁਕਾਈ ॥੪॥੪॥੨੦॥",
          "roman": "Nānak dīn nām māgē dutīā bharam chukāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, смиренный Нанак просит у Твоих Дверей Твоё Имя, устраняя заблуждение о каком-либо другом, подобном Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3701,
      "rahao_verse_id": 42815,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42811,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42812,
          "is_rahao": false,
          "gurmukhi": "ਮੇਰਾ ਠਾਕੁਰੁ ਅਤਿ ਭਾਰਾ ॥",
          "roman": "merā ṭhākur at bhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мой Владыка-Господь обладает великой силой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42813,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਸੇਵਕੁ ਬੇਚਾਰਾ ॥੧॥",
          "roman": "mohi sevak bechārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "А я — смиренный слуга у Его Дверей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42814,
          "is_rahao": true,
          "gurmukhi": "ਮੋਹਨੁ ਲਾਲੁ ਮੇਰਾ ਪ੍ਰੀਤਮ ਮਨ ਪ੍ਰਾਨਾ ॥",
          "roman": "Mohan lāl merā prītam man prānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Возлюбленный моего ума, о Возлюбленный моей жизни, Ты — мой прекрасный, драгоценный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42815,
          "is_rahao": true,
          "gurmukhi": "ਮੋ ਕਉ ਦੇਹੁ ਦਾਨਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mo kau deh dānā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даруй мне подаяние Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42816,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਮੈ ਦੇਖੇ ਜੋਈ ॥",
          "roman": "sagle mē dekhe joī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я рассмотрел и испытал все прочие опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42817,
          "is_rahao": false,
          "gurmukhi": "ਬੀਜਉ ਅਵਰੁ ਨ ਕੋਈ ॥੨॥",
          "roman": "bījau avar na koī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нет никого другого, равного тому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42818,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅਨ ਪ੍ਰਤਿਪਾਲਿ ਸਮਾਹੈ ॥",
          "roman": "jīan pratipāl samāhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь питает всех живых существ и доставляет всем пропитание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42819,
          "is_rahao": false,
          "gurmukhi": "ਹੈ ਹੋਸੀ ਆਹੇ ॥੩॥",
          "roman": "hē hosī āhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он существует сейчас, будет существовать и впредь, и существовал прежде."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42820,
          "is_rahao": false,
          "gurmukhi": "ਦਇਆ ਮੋਹਿ ਕੀਜੈ ਦੇਵਾ ॥",
          "roman": "dēā moh kījē devā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Светлый Господь, окажи мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42821,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਲਾਗੋ ਸੇਵਾ ॥੪॥੫॥੨੧॥",
          "roman": "Nānak lāgo sevā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: пусть я остаюсь занят Твоим служением и преданной любовью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3702,
      "rahao_verse_id": 42826,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 42822,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42823,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਉਧਾਰਨ ਤਾਰਨ ਬਲਿ ਬਲਿ ਬਲੇ ਬਲਿ ਜਾਈਐ ॥",
          "roman": "patit udhāran tāran bal bal bale bal jāīai",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Следует снова и снова жертвенно склоняться перед Богом, спасающим падших от пороков и переправляющим через мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42824,
          "is_rahao": false,
          "gurmukhi": "ਐਸਾ ਕੋਈ ਭੇਟੈ ਸੰਤੁ ਜਿਤੁ ਹਰਿ ਹਰੇ ਹਰਿ ਧਿਆਈਐ ॥੧॥",
          "roman": "ēsā koī bheṭē sant jit Har hare Har dhiāīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нужно молиться, чтобы встретился такой святой, через которого можно было бы постоянно созерцать Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42825,
          "is_rahao": true,
          "gurmukhi": "ਮੋ ਕਉ ਕੋਇ ਨ ਜਾਨਤ ਕਹੀਅਤ ਦਾਸੁ ਤੁਮਾਰਾ ॥",
          "roman": "mo kau koi na jānat kahīat dās tumārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, меня никто не знает, но я называюсь Твоим слугой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42826,
          "is_rahao": true,
          "gurmukhi": "ਏਹਾ ਓਟ ਆਧਾਰਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "ehā oṭ ādhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это и есть мой единственный покров и опора: что Ты сохранишь честь Своего слуги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42827,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਧਾਰਨ ਪ੍ਰਤਿਪਾਰਨ ਇਕ ਬਿਨਉ ਦੀਨਾ ॥",
          "roman": "sarab dhāran pratipāran ik binau dīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Поддерживающий всех, о Питающий всех, я, смиренный, обращаю к Тебе одну просьбу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42828,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮਰੀ ਬਿਧਿ ਤੁਮ ਹੀ ਜਾਨਹੁ ਤੁਮ ਜਲ ਹਮ ਮੀਨਾ ॥੨॥",
          "roman": "tumrī bidh tum hī jānah tum jal ham mīnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты Сам знаешь способ, как Ты будешь водой, а я останусь Твоей рыбой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42829,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਬਿਸਥੀਰਨ ਸੁਆਮੀ ਆਹਿ ਆਇਓ ਪਾਛੈ ॥",
          "roman": "pūran bisthīran suāmī āh āio pāchhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Всепроникающий, о Владыка всего простора, я с тоской пришёл под Твою защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 42830,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੋ ਭੂ ਮੰਡਲ ਖੰਡਲ ਪ੍ਰਭ ਤੁਮ ਹੀ ਆਛੈ ॥੩॥",
          "roman": "saglo bhū maṇḍal khaṇḍal Prabh tum hī āchhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, вся эта форма — земля, круги земель и части земли — всё это есть Ты Сам, всё создано из Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
