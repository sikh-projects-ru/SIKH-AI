{
  "ang": 1079,
  "shabads": [
    {
      "shabad_id": 3791,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 46072,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਖੰਡ ਦੀਪ ਸਭਿ ਲੋਆ ॥",
          "roman": "simrah khaṇḍ dīp sabh loā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все материки, острова и миры помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46073,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਪਾਤਾਲ ਪੁਰੀਆ ਸਚੁ ਸੋਆ ॥",
          "roman": "simrah pātāl purīā sach soā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Подземные миры и небесные обители помнят Того Истинного Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46074,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਖਾਣੀ ਸਿਮਰਹਿ ਬਾਣੀ ਸਿਮਰਹਿ ਸਗਲੇ ਹਰਿ ਜਨਾ ॥੨॥",
          "roman": "simrahi khāṇī simrahi bāṇī simrahi saglē har janā. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все виды рождений, все формы речи и все слуги Хари помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46075,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਬ੍ਰਹਮੇ ਬਿਸਨ ਮਹੇਸਾ ॥",
          "roman": "simrah brahmē bisan mahēsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Брахма, Вишну и Махеш помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46076,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਦੇਵਤੇ ਕੋੜਿ ਤੇਤੀਸਾ ॥",
          "roman": "simrah dēvtē koṛ tetīsā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тридцать три крора божеств помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46077,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਜਖੵਿ ਦੈਤ ਸਭਿ ਸਿਮਰਹਿ ਅਗਨਤੁ ਨ ਜਾਈ ਜਸੁ ਗਨਾ ॥੩॥",
          "roman": "simrahi jakhy dēt sabh simrahi aganat na jāī jas ganā. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Якши и демоны, все помнят Его; Его слава бесчисленна, её невозможно исчислить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46078,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਪਸੁ ਪੰਖੀ ਸਭਿ ਭੂਤਾ ॥",
          "roman": "simrah pas paṅkhī sabh bhūtā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Животные, птицы и все существа помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46079,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਬਨ ਪਰਬਤ ਅਉਧੂਤਾ ॥",
          "roman": "simrah ban parbat audhūtā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Леса, горы и отречённые аскеты помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46080,
          "is_rahao": false,
          "gurmukhi": "ਲਤਾ ਬਲੀ ਸਾਖ ਸਭ ਸਿਮਰਹਿ ਰਵਿ ਰਹਿਆ ਸੁਆਮੀ ਸਭ ਮਨਾ ॥੪॥",
          "roman": "latā balī sākh sabh simrahi rav rahiā suāmī sabh manā. 4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лианы, вьющиеся растения и все ветви помнят Его; Владыка пронизывает все умы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46081,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਥੂਲ ਸੂਖਮ ਸਭਿ ਜੰਤਾ ॥",
          "roman": "simrah thūl sūkham sabh jantā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О мой Господь! Все существа, от обладающих очень большими телами до имеющих самые малые тела, помнят Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46082,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਸਿਧ ਸਾਧਿਕ ਹਰਿ ਮੰਤਾ ॥",
          "roman": "simrah sidh sādhik har mantā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сиддхи и садхики, достигшие в йогических практиках и совершающие эти практики, повторяют Твой божественный мантр, Твоё имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46083,
          "is_rahao": false,
          "gurmukhi": "ਗੁਪਤ ਪ੍ਰਗਟ ਸਿਮਰਹਿ ਪ੍ਰਭ ਮੇਰੇ ਸਗਲ ਭਵਨ ਕਾ ਪ੍ਰਭ ਧਨਾ ॥੫॥",
          "roman": "gupat pragaṭ simrahi prabh mērē sagal bhavan kā prabh dhanā. 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все видимые и невидимые существа помнят Тебя, о мой Господь; о Господь, Ты Владыка всех миров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46084,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਨਰ ਨਾਰੀ ਆਸਰਮਾ ॥",
          "roman": "simrah nar nārī āsarmā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Мужчины и женщины всех четырёх ашрамов помнят Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46085,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਜਾਤਿ ਜੋਤਿ ਸਭਿ ਵਰਨਾ ॥",
          "roman": "simrah jāt jot sabh varnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все существа всех каст, родов и варн помнят Его."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46086,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਗੁਣੀ ਚਤੁਰ ਸਭਿ ਬੇਤੇ ਸਿਮਰਹਿ ਰੈਣੀ ਅਰੁ ਦਿਨਾ ॥੬॥",
          "roman": "simrahi guṇī chatur sabh bētē simrahi rēṇī ar dinā. 6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все добродетельные, проницательные и мудрые существа помнят Бога; все существа помнят Того Господа ночью и днём, во всякое время."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46087,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਘੜੀ ਮੂਰਤ ਪਲ ਨਿਮਖਾ ॥",
          "roman": "simrah ghaṛī mūrat pal nimkhā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Часы, мухурты, мгновения и нимкхи, все деления времени, проходят в порядке и законе Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46088,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰੈ ਕਾਲੁ ਅਕਾਲੁ ਸੁਚਿ ਸੋਚਾ ॥",
          "roman": "simrē kāl akāl such sochā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Смерть движется по повелению Господа, рождение движется по повелению Господа; чистота и телесные обряды также совершаются в этом повелении."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46089,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਹਿ ਸਉਣ ਸਾਸਤ੍ਰ ਸੰਜੋਗਾ ਅਲਖੁ ਨ ਲਖੀਐ ਇਕੁ ਖਿਨਾ ॥੭॥",
          "roman": "simrahi sauṇ sāstar sañjogā alakh na lakhīai ik khinā. 7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Астрологические и другие шастры, говорящие о знамениях и соединениях, действуют в Его повелении; но Сам Господь таков, что Его истинную сущность невозможно описать, даже на малую долю мгновения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46090,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨਹਾਰ ਸੁਆਮੀ ॥",
          "roman": "karan karāvanhār suāmī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка, способный Сам всё совершать и заставлять существ совершать!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46091,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "sagal ghaṭā kē antarjāmī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, знающий сердца всех существ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46092,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਭਗਤੀ ਲਾਵਹੁ ਜਨਮੁ ਪਦਾਰਥੁ ਸੋ ਜਿਨਾ ॥੮॥",
          "roman": "kar kirpā jis bhagtī lāvhu janam padārath so jinā. 8.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, кого Ты по милости приобщаешь к Своей бхагти, выигрывает драгоценную игру человеческого рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46093,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਵੂਠਾ ਪ੍ਰਭੁ ਅਪਨਾ ॥",
          "roman": "jā kē man vūṭhā prabh apnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! В чьём уме поселился возлюбленный Господь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46094,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਕਰਮਿ ਗੁਰ ਕਾ ਜਪੁ ਜਪਨਾ ॥",
          "roman": "pūrē karam gur kā jap japnā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "тот по полной милости Господа повторяет джап Имени, указанный Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46095,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਰੰਤਰਿ ਸੋ ਪ੍ਰਭੁ ਜਾਤਾ ਬਹੁੜਿ ਨ ਜੋਨੀ ਭਰਮਿ ਰੁਨਾ ॥੯॥",
          "roman": "sarab niraṅtar so prabh jātā bahuṛ na jonī bharam runā. 9.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такой человек узнаёт того Господа как пребывающего внутри всех; он больше не страдает, блуждая в круге рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46096,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਵਸੈ ਮਨਿ ਜਾ ਕੈ ॥ ਦੂਖੁ ਦਰਦੁ ਭ੍ਰਮੁ ਤਾ ਕਾ ਭਾਗੈ ॥",
          "roman": "gur kā sabad vasē man jā kē. dūkh darad bhram tā kā bhāgē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! У человека, в чьём уме утверждается Слово Гуру, уходят страдание и боль, и прекращается его блуждание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46097,
          "is_rahao": false,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਨਾਮ ਰਸੁ ਅਨਹਦ ਬਾਣੀ ਸਹਜ ਧੁਨਾ ॥੧੦॥",
          "roman": "sūkh sahaj ānand nām ras anahad bāṇī sahaj dhunā. 10.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Внутри него пребывают покой и радость духовной невозмутимости; он начинает вкушать сладость Имени Бога, и благодать Гурбани поддерживает в нём непрерывный поток духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46098,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਨਵੰਤਾ ਜਿਨਿ ਪ੍ਰਭੁ ਧਿਆਇਆ ॥",
          "roman": "so dhanvantā jin prabh dhiāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот, кто созерцал Господа, стал обладателем сокровища Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46099,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਤਿਵੰਤਾ ਜਿਨਿ ਸਾਧਸੰਗੁ ਪਾਇਆ ॥",
          "roman": "so pativantā jin sādhsaṅg pāiā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обрёл общество Гуру, стал почитаемым в этом мире и в ином."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46100,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਜਾ ਕੈ ਮਨਿ ਵੂਠਾ ਸੋ ਪੂਰ ਕਰੰਮਾ ਨਾ ਛਿਨਾ ॥੧੧॥",
          "roman": "pārbraham jā kē man vūṭhā so pūr karammā nā chhinā. 11.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! В чьём уме поселился Парабрахм, тот стал человеком великой удачи и прославился в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46101,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਸੁਆਮੀ ਸੋਈ ॥",
          "roman": "jal thal mahīal suāmī soī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! Тот же Владыка-Господь пребывает в воде, на земле и в небесном пространстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46102,
          "is_rahao": false,
          "gurmukhi": "ਅਵਰੁ ਨ ਕਹੀਐ ਦੂਜਾ ਕੋਈ ॥",
          "roman": "avar na kahīai dūjā koī.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Него невозможно назвать никакого другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46103,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਗਿਆਨ ਅੰਜਨਿ ਕਾਟਿਓ ਭ੍ਰਮੁ ਸਗਲਾ ਅਵਰੁ ਨ ਦੀਸੈ ਏਕ ਬਿਨਾ ॥੧੨॥",
          "roman": "gur giān añjan kāṭio bhram saglā avar na dīsē ēk binā. 12.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! У того, чьи глаза сурьма знания Гуру очистила от всей пелены заблуждения, не видно никого иного, кроме одного Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46104,
          "is_rahao": false,
          "gurmukhi": "ਊਚੇ ਤੇ ਊਚਾ ਦਰਬਾਰਾ ॥",
          "roman": "ūchē tē ūchā darbārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твой двор выше всех дворов."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46105,
          "is_rahao": false,
          "gurmukhi": "ਕਹਣੁ ਨ ਜਾਈ ਅੰਤੁ ਨ ਪਾਰਾ ॥",
          "roman": "kahaṇ na jāī ant na pārā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Его конец и дальний берег невозможно описать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46106,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿਰ ਗੰਭੀਰ ਅਥਾਹ ਸੁਆਮੀ ਅਤੁਲੁ ਨ ਜਾਈ ਕਿਆ ਮਿਨਾ ॥੧੩॥",
          "roman": "gahir gambhīr athāh suāmī atul na jāī kiā minā. 13.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О глубокий и бездонный, о великодушный Владыка! Ты несравним; Тебя невозможно взвесить, невозможно измерить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46107,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਕਰਤਾ ਤੇਰਾ ਸਭੁ ਕੀਆ ॥",
          "roman": "tū kartā tērā sabh kīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты Творец, весь мир создан Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46108,
          "is_rahao": false,
          "gurmukhi": "ਤੁਝੁ ਬਿਨੁ ਅਵਰੁ ਨ ਕੋਈ ਬੀਆ ॥",
          "roman": "tujh bin avar na koī bīā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Тебя нет никого другого, подобного Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46109,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਮਧਿ ਅੰਤਿ ਪ੍ਰਭੁ ਤੂਹੈ ਸਗਲ ਪਸਾਰਾ ਤੁਮ ਤਨਾ ॥੧੪॥",
          "roman": "ād madh ant prabh tūhē sagal pasārā tum tanā. 14.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "От начала творения, через середину и до конца Ты, Господь, пребываешь вечно; всё это мировое распространение есть проявление Твоего собственного Я."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46110,
          "is_rahao": false,
          "gurmukhi": "ਜਮਦੂਤੁ ਤਿਸੁ ਨਿਕਟਿ ਨ ਆਵੈ ॥",
          "roman": "jamdūt tis nikaṭ na āvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О брат! К тому человеку не приближается посланник смерти; смерть не может устрашить его, и духовная смерть не подходит к нему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46111,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹਰਿ ਕੀਰਤਨੁ ਗਾਵੈ ॥",
          "roman": "sādhsaṅg har kīrtan gāvē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это тот человек, который, пребывая в обществе Гуру, поёт песнь хвалы Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46112,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਮਨੋਰਥ ਤਾ ਕੇ ਪੂਰਨ ਜੋ ਸ੍ਰਵਣੀ ਪ੍ਰਭ ਕਾ ਜਸੁ ਸੁਨਾ ॥੧੫॥",
          "roman": "sagal manorath tā kē pūran jo sravaṇī prabh kā jas sunā. 15.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто своими ушами продолжает слушать славу Господа, все нужды и желания исполняются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46113,
          "is_rahao": false,
          "gurmukhi": "ਤੂ ਸਭਨਾ ਕਾ ਸਭੁ ਕੋ ਤੇਰਾ ॥ ਸਾਚੇ ਸਾਹਿਬ ਗਹਿਰ ਗੰਭੀਰਾ ॥",
          "roman": "tū sabhnā kā sabh ko tērā. sāchē sāhib gahir gambhīrā.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь! Ты Владыка всех существ; каждое существо создано Тобой. О вечно пребывающий Хозяин, о глубокий и великодушный Господь!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
