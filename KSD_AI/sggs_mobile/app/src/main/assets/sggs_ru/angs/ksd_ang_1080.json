{
  "ang": 1080,
  "shabads": [
    {
      "shabad_id": 3791,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 46114,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਸੇਈ ਜਨ ਊਤਮ ਜੋ ਭਾਵਹਿ ਸੁਆਮੀ ਤੁਮ ਮਨਾ ॥੧੬॥੧॥੮॥",
          "roman": "kah Nānak seī jan ūttam jo bhāvah suāmī tum manā ॥16॥1॥8॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Скажи, Нанак: только те люди возвышенны, которые приятны Тебе, о Владыка, Твоему сердцу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3792,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 46115,
          "is_rahao": false,
          "gurmukhi": "ਮਾਰੂ ਮਹਲਾ ੫ ॥",
          "roman": "Mārū mahallā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Мару, Пятый Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46116,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਮਰਥ ਸਰਬ ਸੁਖ ਦਾਨਾ ॥",
          "roman": "prabh samrath sarab sukh dānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка всех сил, о Податель всех благ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46117,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਉ ਨਾਮੁ ਹੋਹੁ ਮਿਹਰਵਾਨਾ ॥",
          "roman": "simarau nām hoh miharvānā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Будь милостив ко мне, чтобы я продолжал вспоминать Твоё Имя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46118,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਦਾਤਾ ਜੀਅ ਜੰਤ ਭੇਖਾਰੀ ਜਨੁ ਬਾਂਛੈ ਜਾਚੰਗਨਾ ॥੧॥",
          "roman": "har dātā jīa jant bhekhārī jan bāñchhē jāchangnā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Хари — Даритель, а все живые существа — просители у Его дверей; Его слуга, став просителем, желает и просит дара Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46119,
          "is_rahao": false,
          "gurmukhi": "ਮਾਗਉ ਜਨ ਧੂਰਿ ਪਰਮ ਗਤਿ ਪਾਵਉ ॥",
          "roman": "māgau jan dhūṛ param gat pāvau ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я прошу пыли стоп Его служителей, чтобы обрести высшее духовное состояние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46120,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੀ ਮੈਲੁ ਮਿਟਾਵਉ ॥",
          "roman": "janam janam kī mēl miṭāvau ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Так я смогу удалить грязь пороков, накопленную за многие рождения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46121,
          "is_rahao": false,
          "gurmukhi": "ਦੀਰਘ ਰੋਗ ਮਿਟਹਿ ਹਰਿ ਅਉਖਧਿ ਹਰਿ ਨਿਰਮਲਿ ਰਾਪੈ ਮੰਗਨਾ ॥੨॥",
          "roman": "dīragh rog miṭah har aukhadh har nirmal rāpē mangnā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лекарством Хар-Нама исчезают тяжкие болезни; я тоже прошу, чтобы мой ум был окрашен чистым Именем Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46122,
          "is_rahao": false,
          "gurmukhi": "ਸ੍ਰਵਣੀ ਸੁਣਉ ਬਿਮਲ ਜਸੁ ਸੁਆਮੀ ॥",
          "roman": "sravaṇī suṇau bimal jas suāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка, по милости Твоей пусть я своими ушами всегда слушаю Твою чистую славу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46123,
          "is_rahao": false,
          "gurmukhi": "ਏਕਾ ਓਟ ਤਜਉ ਬਿਖੁ ਕਾਮੀ ॥",
          "roman": "ekā oṭ tajau bikh kāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У меня есть только Твоё прибежище; по милости Твоей пусть я оставлю ядовитую похоть, приносящую духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46124,
          "is_rahao": false,
          "gurmukhi": "ਨਿਵਿ ਨਿਵਿ ਪਾਇ ਲਗਉ ਦਾਸ ਤੇਰੇ ਕਰਿ ਸੁਕ੍ਰਿਤੁ ਨਾਹੀ ਸੰਗਨਾ ॥੩॥",
          "roman": "niv niv pāe lagau dās tere kar sukrit nāhī sangnā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть я, склоняясь снова и снова, припадаю к стопам Твоих слуг; совершая это доброе деяние, пусть я никогда не испытываю смущения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46125,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਗੁਣ ਗਾਵੈ ਹਰਿ ਤੇਰੇ ॥",
          "roman": "rasnā guṇ gāvē har tere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Владыка, о Хари, пусть мой язык всегда поёт Твои достоинства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46126,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਹਿ ਕਮਾਤੇ ਅਵਗੁਣ ਮੇਰੇ ॥",
          "roman": "miṭah kamāte avguṇ mere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И пусть исчезнут мои прежние совершённые недостатки и пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46127,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਸਿਮਰਿ ਸੁਆਮੀ ਮਨੁ ਜੀਵੈ ਪੰਚ ਦੂਤ ਤਜਿ ਤੰਗਨਾ ॥੪॥",
          "roman": "simar simar suāmī man jīvē pañch dūt taj tangnā ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вспоминая Твоё Имя снова и снова, и силой этого Симрана, пусть мой ум обретёт духовную жизнь, оставив мучающих его пятерых врагов — вожделение и прочих."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46128,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਜਪਿ ਬੋਹਿਥਿ ਚਰੀਐ ॥",
          "roman": "charaṇ kamal jap bohith chaṛīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Чтобы переправиться через океан мира, следует сосредоточиться на прекрасных лотосных стопах Бога и взойти на корабль Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46129,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤਸੰਗਿ ਮਿਲਿ ਸਾਗਰੁ ਤਰੀਐ ॥",
          "roman": "santsang mil sāgar tarīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Соединившись с обществом Гуру, можно переправиться через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46130,
          "is_rahao": false,
          "gurmukhi": "ਅਰਚਾ ਬੰਦਨ ਹਰਿ ਸਮਤ ਨਿਵਾਸੀ ਬਾਹੁੜਿ ਜੋਨਿ ਨ ਨੰਗਨਾ ॥੫॥",
          "roman": "archā bandan har samat nivāsī bāhuṛ jon na nangnā ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Понимать, что Хари одинаково пребывает во всех существах, — это и есть Его поклонение и преклонение перед Ним; так человек не оказывается снова униженным, попадая в круг рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46131,
          "is_rahao": false,
          "gurmukhi": "ਦਾਸ ਦਾਸਨ ਕੋ ਕਰਿ ਲੇਹੁ ਗੋੁਪਾਲਾ ॥",
          "roman": "dās dāsan ko kar leh gupālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Гопал, сделай меня слугой Твоих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46132,
          "is_rahao": false,
          "gurmukhi": "ਕ੍ਰਿਪਾ ਨਿਧਾਨ ਦੀਨ ਦਇਆਲਾ ॥",
          "roman": "kripā nidhān dīn daiālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Сокровищница милости, о Милосердный к бедным!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46133,
          "is_rahao": false,
          "gurmukhi": "ਸਖਾ ਸਹਾਈ ਪੂਰਨ ਪਰਮੇਸੁਰ ਮਿਲੁ ਕਦੇ ਨ ਹੋਵੀ ਭੰਗਨਾ ॥੬॥",
          "roman": "sakhā sahāī pūran parmesur mil kade na hovī bhangnā ॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О всепроникающий Пармешар, Ты — мой друг, Ты — мой помощник; соедини меня с Собой, чтобы никогда не было разлуки с Тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46134,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਅਰਪਿ ਧਰੀ ਹਰਿ ਆਗੈ ॥",
          "roman": "man tan arap dharī har āgē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который посвятил свой ум и тело Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46135,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗੈ ॥",
          "roman": "janam janam kā soiā jāgē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "даже если он спал многие рождения, пробуждается и становится осознающим духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46136,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਕਾ ਸਾ ਸੋਈ ਪ੍ਰਤਿਪਾਲਕੁ ਹਤਿ ਤਿਆਗੀ ਹਉਮੈ ਹੰਤਨਾ ॥੭॥",
          "roman": "jis kā sā soī pratipālak hat tiāgī haumē hantnā ॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, Который создал его, становится его Хранителем, и этот человек навсегда отбрасывает Хоумэ, несущую духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46137,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਪੂਰਨ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "jal thal pūran antarjāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь, знающий сердца всех, пронизывает воду, землю и все места."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46138,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਰਵਿਆ ਅਛਲ ਸੁਆਮੀ ॥",
          "roman": "ghaṭ ghaṭ raviā achhal suāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Невозможно обманутый майей Владыка присутствует в каждом теле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46139,
          "is_rahao": false,
          "gurmukhi": "ਭਰਮ ਭੀਤਿ ਖੋਈ ਗੁਰਿ ਪੂਰੈ ਏਕੁ ਰਵਿਆ ਸਰਬੰਗਨਾ ॥੮॥",
          "roman": "bharam bhīt khoī gur pūrē ek raviā sarbangnā ॥8॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Полный Гуру разрушил стену заблуждения, отделявшую человека от Бога; тогда он видит Единого, пронизывающего всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46140,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਪੇਖਉ ਪ੍ਰਭ ਸੁਖ ਸਾਗਰ ॥",
          "roman": "jat kat pekhau prabh sukh sāgar ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни смотрел, всюду пребывает Бог, океан блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46141,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਤੋਟਿ ਭੰਡਾਰ ਨਾਹੀ ਰਤਨਾਗਰ ॥",
          "roman": "har toṭ bhanḍār nāhī ratnāgar ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В сокровищницах Хари, рудника драгоценностей, никогда нет недостатка."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46142,
          "is_rahao": false,
          "gurmukhi": "ਅਗਹ ਅਗਾਹ ਕਿਛੁ ਮਿਤਿ ਨਹੀ ਪਾਈਐ ਸੋ ਬੂਝੈ ਜਿਸੁ ਕਿਰਪੰਗਨਾ ॥੯॥",
          "roman": "agah agāh kichh mit nahī pāīē so būjhē jis kirpangnā ॥9॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нельзя найти предел сущности того Бога, Который недостижим и бездонен; это понимает лишь тот, на кого нисходит Его милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46143,
          "is_rahao": false,
          "gurmukhi": "ਛਾਤੀ ਸੀਤਲ ਮਨੁ ਤਨੁ ਠੰਢਾ ॥",
          "roman": "chhātī sītal man tan ṭhanḍhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У тех счастливцев сердце становится спокойным, ум и тело становятся прохладными и умиротворёнными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46144,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਕੀ ਮਿਟਵੀ ਡੰਝਾ ॥",
          "roman": "janam maraṇ kī miṭvī ḍañjhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У них исчезает жжение, которое вовлекает в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46145,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਗਹਿ ਕਾਢਿ ਲੀਏ ਪ੍ਰਭਿ ਅਪੁਨੈ ਅਮਿਓ ਧਾਰਿ ਦ੍ਰਿਸਟੰਗਨਾ ॥੧੦॥",
          "roman": "kar gah kāḍh līe prabh apunē amio dhār drisaṭangnā ॥10॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный Господь, бросив взгляд, дающий духовную жизнь, взял их за руку и вывел из океана мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46146,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਏਕੁ ਰਵਿਆ ਸਭ ਠਾਈ ॥",
          "roman": "eko ek raviā sabh ṭhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Им становится видно, что один только Бог пребывает во всех местах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46147,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਦੂਜਾ ਕੋਈ ਨਾਹੀ ॥",
          "roman": "tis bin dūjā koī nāhī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кроме Него нет никого другого, равного Ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46148,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਮਧਿ ਅੰਤਿ ਪ੍ਰਭੁ ਰਵਿਆ ਤ੍ਰਿਸਨ ਬੁਝੀ ਭਰਮੰਗਨਾ ॥੧੧॥",
          "roman": "ād madh ant prabh raviā trisan bujhī bharamangnā ॥11॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Когда по милости Гуру угасают жажда майи и блуждание, человек видит, что Бог был в начале творения, пребывает сейчас и будет в конце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46149,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਪਰਮੇਸਰੁ ਗੁਰੁ ਗੋਬਿੰਦੁ ॥",
          "roman": "gur parmesar gur gobind ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Такому человеку становится видно, что Гуру — образ Пармешара, Гуру — образ Гобинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46150,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰੁ ਕਰਤਾ ਗੁਰੁ ਸਦ ਬਖਸੰਦੁ ॥",
          "roman": "gur kartā gur sad bakhsand ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Гуру — образ Творца, Гуру всегда дарует прощение и благословения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46151,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਜਪੁ ਜਾਪਿ ਜਪਤ ਫਲੁ ਪਾਇਆ ਗਿਆਨ ਦੀਪਕੁ ਸੰਤ ਸੰਗਨਾ ॥੧੨॥",
          "roman": "gur jap jāp japat phal pāiā giān dīpak sant sangnā ॥12॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пребывая в Садх Сангат и повторяя Джап Хар-Нама, указанного Гуру, человек получает этот плод: внутри него загорается светильник знания духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46152,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਪੇਖਾ ਸੋ ਸਭੁ ਕਿਛੁ ਸੁਆਮੀ ॥",
          "roman": "jo pekhā so sabh kichh suāmī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё, что я вижу в мире, — всё это форма Владыки-Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46153,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਸੁਨਣਾ ਸੋ ਪ੍ਰਭ ਕੀ ਬਾਨੀ ॥",
          "roman": "jo suṇṇā so prabh kī bānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё, что я слышу, — это сам Бог говорит повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46154,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕੀਨੋ ਸੋ ਤੁਮਹਿ ਕਰਾਇਓ ਸਰਣਿ ਸਹਾਈ ਸੰਤਹ ਤਨਾ ॥੧੩॥",
          "roman": "jo kīno so tumah karāio saraṇ sahāī santah tanā ॥13॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, что бы ни делали существа, это Ты Сам заставляешь их делать; Ты — Помощник тех, кто приходит в Твоё прибежище, Ты — опора Своих святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46155,
          "is_rahao": false,
          "gurmukhi": "ਜਾਚਕੁ ਜਾਚੈ ਤੁਮਹਿ ਅਰਾਧੈ ॥",
          "roman": "jāchak jāchē tumah arādhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Проситель у Твоих дверей просит только у Тебя и поклоняется только Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46156,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿਤ ਪਾਵਨ ਪੂਰਨ ਪ੍ਰਭ ਸਾਧੈ ॥",
          "roman": "patit pāvan pūran prabh sādhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О очищающий падших Господь, о совершенный святой Господь!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 46157,
          "is_rahao": false,
          "gurmukhi": "ਏਕੋ ਦਾਨੁ ਸਰਬ ਸੁਖ ਗੁਣ ਨਿਧਿ ਆਨ ਮੰਗਨ ਨਿਹਕਿੰਚਨਾ ॥੧੪॥",
          "roman": "eko dān sarab sukh guṇ nidh ān mangan nihkiñchanā ॥14॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Податель всех благ, о Сокровищница добродетелей, Твой слуга просит только один дар — дар Твоего Имени; просить чего-либо другого бесполезно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
