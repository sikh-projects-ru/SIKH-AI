{
  "ang": 1100,
  "shabads": [
    {
      "shabad_id": 3929,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47044,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸੇ ਅਖੜੀਆ ਬਿਅੰਨਿ ਜਿਨੀ ਡਿਸੰਦੋ ਮਾ ਪਿਰੀ ॥੩॥",
          "roman": "Nānak sē akhṛīā biann jinī ḍisando mā pirī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, особенными являются те глаза, которыми виден мой Возлюбленный Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3930,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47045,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47046,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਜਨਿ ਗੁਰਮੁਖਿ ਸੇਵਿਆ ਤਿਨਿ ਸਭਿ ਸੁਖ ਪਾਈ ॥",
          "roman": "Jin jan gurmukh sēviā tin sabh sukh pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, обратившись к Гуру, вспоминал Господа, обрёл все блаженства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47047,
          "is_rahao": false,
          "gurmukhi": "ਓਹੁ ਆਪਿ ਤਰਿਆ ਕੁਟੰਬ ਸਿਉ ਸਭੁ ਜਗਤੁ ਤਰਾਈ ॥",
          "roman": "Oh āp tariā kuṭamb siu sabh jagat tarāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он сам вместе со своей семьёй переправляется через мирской океан и помогает переправиться всему миру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47048,
          "is_rahao": false,
          "gurmukhi": "ਓਨਿ ਹਰਿ ਨਾਮਾ ਧਨੁ ਸੰਚਿਆ ਸਭ ਤਿਖਾ ਬੁਝਾਈ ॥",
          "roman": "On har nāmā dhan sanchiā sabh tikhā bujhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он накопил такое богатство Имени Бога, что вся жажда майи в нём угасла."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47049,
          "is_rahao": false,
          "gurmukhi": "ਓਨਿ ਛਡੇ ਲਾਲਚ ਦੁਨੀ ਕੇ ਅੰਤਰਿ ਲਿਵ ਲਾਈ ॥",
          "roman": "On chhaḍē lālach dunī kē antar liv lāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он оставил все мирские алчности и соединил своё сознание со стопами Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47050,
          "is_rahao": false,
          "gurmukhi": "ਓਸੁ ਸਦਾ ਸਦਾ ਘਰਿ ਅਨੰਦੁ ਹੈ ਹਰਿ ਸਖਾ ਸਹਾਈ ॥",
          "roman": "Os sadā sadā ghar anand hē har sakhā sahāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В доме его сердца всегда радость и блаженство; Господь всегда его друг и помощник."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47051,
          "is_rahao": false,
          "gurmukhi": "ਓਨਿ ਵੈਰੀ ਮਿਤ੍ਰ ਸਮ ਕੀਤਿਆ ਸਭ ਨਾਲਿ ਸੁਭਾਈ ॥",
          "roman": "On vērī mitar sam kītiā sabh nāl subhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он стал одинаково смотреть на врага и друга, считает каждого другом и со всеми держится добрым нравом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47052,
          "is_rahao": false,
          "gurmukhi": "ਹੋਆ ਓਹੀ ਅਲੁ ਜਗ ਮਹਿ ਗੁਰ ਗਿਆਨੁ ਜਪਾਈ ॥",
          "roman": "Hoā ohīal jag mah gur giān japāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он всегда хранит в памяти наставление, полученное от Гуру, и становится известным в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47053,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਬਿ ਲਿਖਿਆ ਪਾਇਆ ਹਰਿ ਸਿਉ ਬਣਿ ਆਈ ॥੧੬॥",
          "roman": "Pūrab likhiā pāiā har siu baṇ āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Записи благих деяний прежних рождений проявляются на его челе, и в этой жизни у него устанавливается прочная любовь с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3931,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47054,
          "is_rahao": false,
          "gurmukhi": "ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "Ḍakhṇē mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дакханэ, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47055,
          "is_rahao": false,
          "gurmukhi": "ਸਚੁ ਸੁਹਾਵਾ ਕਾਢੀਐ ਕੂੜੈ ਕੂੜੀ ਸੋਇ ॥",
          "roman": "Sach suhāvā kāḍhīē kūṛē kūṛī soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все говорят, что богатство Имени Вечного Господа даёт покой, а от мирского, преходящего богатства слышна лишь дурная весть о ссорах и тревогах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47056,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਵਿਰਲੇ ਜਾਣੀਅਹਿ ਜਿਨ ਸਚੁ ਪਲੈ ਹੋਇ ॥੧॥",
          "roman": "Nānak virlē jāṇīah jin sach pallē hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, всё же редки те люди, у которых в запасе есть богатство Истинного Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3932,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47057,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47058,
          "is_rahao": false,
          "gurmukhi": "ਸਜਣ ਮੁਖੁ ਅਨੂਪੁ ਅਠੇ ਪਹਰ ਨਿਹਾਲਸਾ ॥",
          "roman": "Sajaṇ mukh anūp aṭhē pahar nihālsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лик возлюбленного Господа несравненно прекрасен; теперь моё желание — видеть этот лик все восемь страж суток."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47059,
          "is_rahao": false,
          "gurmukhi": "ਸੁਤੜੀ ਸੋ ਸਹੁ ਡਿਠੁ ਤੈ ਸੁਪਨੇ ਹਉ ਖੰਨੀਐ ॥੨॥",
          "roman": "Sutaṛī so sah ḍiṭh tē supnē hau khannīē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Во сне, будучи спящей, я увидела того Господа-Супруга; о сон, я жертвую собой ради тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3933,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47060,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47061,
          "is_rahao": false,
          "gurmukhi": "ਸਜਣ ਸਚੁ ਪਰਖਿ ਮੁਖਿ ਅਲਾਵਣੁ ਥੋਥਰਾ ॥",
          "roman": "Sajaṇ sach parakh mukh alāvaṇ thothrā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг, одни лишь слова устами бесполезны; проверь и взвесь богатство Имени в своём сердце."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47062,
          "is_rahao": false,
          "gurmukhi": "ਮੰਨ ਮਝਾਹੂ ਲਖਿ ਤੁਧਹੁ ਦੂਰਿ ਨ ਸੁ ਪਿਰੀ ॥੩॥",
          "roman": "Mann majhāhū lakh tudhah dūr na su pirī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Загляни внутрь своего ума: тот Господь-Супруг не далеко от тебя, Он обитает внутри тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3934,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47063,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47064,
          "is_rahao": false,
          "gurmukhi": "ਧਰਤਿ ਆਕਾਸੁ ਪਾਤਾਲੁ ਹੈ ਚੰਦੁ ਸੂਰੁ ਬਿਨਾਸੀ ॥",
          "roman": "Dharat ākās pātāl hē chand sūr bināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Земля, небо, подземные миры, луна и солнце — всё это преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47065,
          "is_rahao": false,
          "gurmukhi": "ਬਾਦਿਸਾਹ ਸਾਹ ਉਮਰਾਵ ਖਾਨ ਢਾਹਿ ਡੇਰੇ ਜਾਸੀ ॥",
          "roman": "Bādisāh sāh umrāv khān ḍhāh ḍērē jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Цари, шахи, знатные и владельцы владений — все покинут свои дворцы и жилища и уйдут отсюда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47066,
          "is_rahao": false,
          "gurmukhi": "ਰੰਗ ਤੁੰਗ ਗਰੀਬ ਮਸਤ ਸਭੁ ਲੋਕੁ ਸਿਧਾਸੀ ॥",
          "roman": "Rang tung garīb mast sabh lok sidhāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Нищие, богатые, бедные, опьянённые майей — весь мир уйдёт отсюда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47067,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਸੇਖ ਮਸਾਇਕਾ ਸਭੇ ਉਠਿ ਜਾਸੀ ॥",
          "roman": "Kājī sēkh masāikā sabhē uṭh jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кази, шейхи и называемые шейхами — все поднимутся и уйдут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47068,
          "is_rahao": false,
          "gurmukhi": "ਪੀਰ ਪੈਕਾਬਰ ਅਉਲੀਏ ਕੋ ਥਿਰੁ ਨ ਰਹਾਸੀ ॥",
          "roman": "Pīr pēkābar aulīē ko thir na rahāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пиры, пророки и великие религиозные вожди — никто из них не останется здесь навсегда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47069,
          "is_rahao": false,
          "gurmukhi": "ਰੋਜਾ ਬਾਗ ਨਿਵਾਜ ਕਤੇਬ ਵਿਣੁ ਬੁਝੇ ਸਭ ਜਾਸੀ ॥",
          "roman": "Rojā bāg nivāj katēb viṇ bujhē sabh jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Те, кто держал посты, возглашал призывы, совершал молитвы и читал религиозные книги, а также те, кто не понял их сути, — все в конце уйдут из мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47070,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਚਉਰਾਸੀਹ ਮੇਦਨੀ ਸਭ ਆਵੈ ਜਾਸੀ ॥",
          "roman": "Lakh chaurāsīh mēdnī sabh āvē jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Все живые существа восьмидесяти четырёх лакхов форм на земле приходят в мир и затем уходят отсюда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47071,
          "is_rahao": false,
          "gurmukhi": "ਨਿਹਚਲੁ ਸਚੁ ਖੁਦਾਇ ਏਕੁ ਖੁਦਾਇ ਬੰਦਾ ਅਬਿਨਾਸੀ ॥੧੭॥",
          "roman": "Nihchal sach khudāi ēk khudāi bandā abināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только один истинный Худа вечен; слуга Худа, Его преданный, тоже не входит в круг рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3935,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47072,
          "is_rahao": false,
          "gurmukhi": "ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "Ḍakhṇē mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Дакханэ, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47073,
          "is_rahao": false,
          "gurmukhi": "ਡਿਠੀ ਹਭ ਢੰਢੋਲਿ ਹਿਕਸੁ ਬਾਝੁ ਨ ਕੋਇ ॥",
          "roman": "Ḍiṭhī habh ḍhaṇḍhol hikas bā́jh na koi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Я обыскал и рассмотрел всё творение: кроме Твоего видения, о Господь, ничто не даёт мне духовного покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47074,
          "is_rahao": false,
          "gurmukhi": "ਆਉ ਸਜਣ ਤੂ ਮੁਖਿ ਲਗੁ ਮੇਰਾ ਤਨੁ ਮਨੁ ਠੰਢਾ ਹੋਇ ॥੧॥",
          "roman": "Āu sajaṇ tū mukh lag mērā tan man ṭhaṇḍhā hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О друг-Господь, приди, дай мне Своё видение; от Твоего видения моё тело и ум обретают прохладу и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3936,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47075,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47076,
          "is_rahao": false,
          "gurmukhi": "ਆਸਕੁ ਆਸਾ ਬਾਹਰਾ ਮੂ ਮਨਿ ਵਡੀ ਆਸ ॥",
          "roman": "Āsak āsā bāhrā mū man vaḍī ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинным любящим стопы Господа может быть тот, кого не затрагивают мирские надежды, но в моём уме есть большие надежды и желания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47077,
          "is_rahao": false,
          "gurmukhi": "ਆਸ ਨਿਰਾਸਾ ਹਿਕੁ ਤੂ ਹਉ ਬਲਿ ਬਲਿ ਬਲਿ ਗਈਆਸ ॥੨॥",
          "roman": "Ās nirāsā hik tū hau bal bal bal gaīās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только Ты один можешь сделать меня свободным от мирских надежд; я снова и снова жертвую собой ради Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3937,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47078,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "Mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47079,
          "is_rahao": false,
          "gurmukhi": "ਵਿਛੋੜਾ ਸੁਣੇ ਡੁਖੁ ਵਿਣੁ ਡਿਠੇ ਮਰਿਓਦਿ ॥",
          "roman": "Vichhoṛā suṇē ḍukh viṇ ḍiṭhē mariod",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинный любящий Господа тот, кто уже при одной вести о разлуке с Господом чувствует боль; без Его видения он ощущает духовную смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47080,
          "is_rahao": false,
          "gurmukhi": "ਬਾਝੁ ਪਿਆਰੇ ਆਪਣੇ ਬਿਰਹੀ ਨਾ ਧੀਰੋਦਿ ॥੩॥",
          "roman": "Bājh piārē āpaṇē birahī nā dhīrod",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "В разлуке со своим любимым Господом сердце влюблённого не находит опоры и покоя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3938,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47081,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "Pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47082,
          "is_rahao": false,
          "gurmukhi": "ਤਟ ਤੀਰਥ ਦੇਵ ਦੇਵਾਲਿਆ ਕੇਦਾਰੁ ਮਥੁਰਾ ਕਾਸੀ ॥",
          "roman": "Taṭ tīrath dēv dēvāliā Kēdār Mathurā Kāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Храмы богов, святые места у берегов рек, Кедар, Матхура и Каши — всё это в конце преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47083,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਤੇਤੀਸਾ ਦੇਵਤੇ ਸਣੁ ਇੰਦ੍ਰੈ ਜਾਸੀ ॥",
          "roman": "Koṭ tetīsā dēvtē saṇ Indrē jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тридцать три крор божеств вместе с Индрой тоже уйдут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47084,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮ੍ਰਿਤਿ ਸਾਸਤ੍ਰ ਬੇਦ ਚਾਰਿ ਖਟੁ ਦਰਸ ਸਮਾਸੀ ॥",
          "roman": "Simrit sāsatr bēd chār khaṭ daras samāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Четыре Веды, смрити, шастры и их читатели, а также садху шести облачений в конце уйдут."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47085,
          "is_rahao": false,
          "gurmukhi": "ਪੋਥੀ ਪੰਡਿਤ ਗੀਤ ਕਵਿਤ ਕਵਤੇ ਭੀ ਜਾਸੀ ॥",
          "roman": "Pothī paṇḍit gīt kavit kavtē bhī jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Книжные учёные, а также сочинители песен и стихов, поэты, тоже уйдут из мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47086,
          "is_rahao": false,
          "gurmukhi": "ਜਤੀ ਸਤੀ ਸੰਨਿਆਸੀਆ ਸਭਿ ਕਾਲੈ ਵਾਸੀ ॥",
          "roman": "Jatī satī sanniāsīā sabh kālē vāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Воздержанные, праведники и санньясины — все они находятся во власти смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47087,
          "is_rahao": false,
          "gurmukhi": "ਮੁਨਿ ਜੋਗੀ ਦਿਗੰਬਰਾ ਜਮੈ ਸਣੁ ਜਾਸੀ ॥",
          "roman": "Mun jogī digambrā jamē saṇ jāsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Муни, йоги, нагие аскеты и даже вместе с посланцами смерти — всё это преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47088,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਦੀਸੈ ਸੋ ਵਿਣਸਣਾ ਸਭ ਬਿਨਸਿ ਬਿਨਾਸੀ ॥",
          "roman": "Jo dīsē so viṇsaṇā sabh binas bināsī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Всё, что видно в мире, должно исчезнуть; всё непременно будет разрушено."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47089,
          "is_rahao": false,
          "gurmukhi": "ਥਿਰੁ ਪਾਰਬ੍ਰਹਮੁ ਪਰਮੇਸਰੋ ਸੇਵਕੁ ਥਿਰੁ ਹੋਸੀ ॥੧੮॥",
          "roman": "Thir Pārbrahm Parmēsaro sēvak thir hosī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Вечен только Парбрахм, Верховный Господь; Его слуга тоже становится свободным от рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3939,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47090,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "Salok Ḍakhṇē mahallā panjvā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Шалок Дакханэ, пятая Махала."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47091,
          "is_rahao": false,
          "gurmukhi": "ਸੈ ਨੰਗੇ ਨਹ ਨੰਗ ਭੁਖੇ ਲਖ ਨ ਭੁਖਿਆ ॥",
          "roman": "Sē nangē nah nang bhukhē lakh na bhukhiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, на кого Господь-Супруг смотрит благосклонным взглядом, не заботится о наготе, даже если сотни раз остаётся нагим; голод не жалит его, даже если ему приходится голодать сотни тысяч раз."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47092,
          "is_rahao": false,
          "gurmukhi": "ਡੁਖੇ ਕੋੜਿ ਨ ਡੁਖ ਨਾਨਕ ਪਿਰੀ ਪਿਖੰਦੋ ਸੁਭ ਦਿਸਟਿ ॥੧॥",
          "roman": "Ḍukhē koṛ na ḍukh Nānak pirī pikhandō subh disaṭ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, если Господь-Супруг смотрит на человека благосклонным взглядом, никакая боль не касается его, даже если случаются кроры страданий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
