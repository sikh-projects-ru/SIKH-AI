{
  "ang": 1102,
  "shabads": [
    {
      "shabad_id": 3950,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47142,
          "is_rahao": false,
          "gurmukhi": "ਗਿਆਨੁ ਰਾਸਿ ਨਾਮੁ ਧਨੁ ਸਉਪਿਓਨੁ ਇਸੁ ਸਉਦੇ ਲਾਇਕ ॥",
          "roman": "giān rās nām dhan saupion is saudē lāik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он вручил ему капитал знания и богатство Имени, сочтя его достойным этой духовной торговли."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47143,
          "is_rahao": false,
          "gurmukhi": "ਸਾਝੀ ਗੁਰ ਨਾਲਿ ਬਹਾਲਿਆ ਸਰਬ ਸੁਖ ਪਾਇਕ ॥",
          "roman": "sājhī gur nāl bahāliyā sarab sukh pāik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он посадил его в товарищество с Гуру; так он обрёл все блага и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47144,
          "is_rahao": false,
          "gurmukhi": "ਮੈ ਨਾਲਹੁ ਕਦੇ ਨ ਵਿਛੁੜੈ ਹਰਿ ਪਿਤਾ ਸਭਨਾ ਗਲਾ ਲਾਇਕ ॥੨੧॥",
          "roman": "mē nālo kadē na vichhuṛē har pitā sabhnā galā lāik",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Отец-Хари, способный исполнить всё, никогда не разлучается со мной."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3951,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47145,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਡਖਣੇ ਮਃ ੫ ॥",
          "roman": "salok ḍakhṇē mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Салоки Дакхане, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47146,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਚੜਿਆ ਸਿਉ ਤੋੜਿ ਢੂਢਿ ਸਜਣ ਸੰਤ ਪਕਿਆ ॥",
          "roman": "nānak kachṛiā siu toṛ ḍhūḍh sajaṇ sant pakiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, порви привязанность с теми, чья любовь непрочна; ищи друзей-святых, ибо их любовь твёрда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47147,
          "is_rahao": false,
          "gurmukhi": "ਓਇ ਜੀਵੰਦੇ ਵਿਛੁੜਹਿ ਓਇ ਮੁਇਆ ਨ ਜਾਹੀ ਛੋੜਿ ॥੧॥",
          "roman": "oi jīvaṅdē vichhuṛah oi muiā na jāhī chhoṛ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Корыстные близкие ещё при жизни остаются сердцем разлучёнными, а гурмукхи, спутники Сатсанга, даже после смерти не оставляют."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3952,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47148,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47149,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਬਿਜੁਲੀਆ ਚਮਕੰਨਿ ਘੁਰਨਿੑ ਘਟਾ ਅਤਿ ਕਾਲੀਆ ॥",
          "roman": "nānak bijulīā chamkann ghuran ghaṭā at kālīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, когда грохочут густо-чёрные тучи, среди них сверкают молнии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47150,
          "is_rahao": false,
          "gurmukhi": "ਬਰਸਨਿ ਮੇਘ ਅਪਾਰ ਨਾਨਕ ਸੰਗਮਿ ਪਿਰੀ ਸੁਹੰਦੀਆ ॥੨॥",
          "roman": "barsan mēgh apār nānak saṅgam pirī suhaṅdīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "И когда безмерно льются облака, это прекрасное время кажется красивым женщине только в соединении с мужем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3953,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47151,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47152,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਥਲ ਨੀਰਿ ਭਰੇ ਸੀਤਲ ਪਵਣ ਝੁਲਾਰਦੇ ॥",
          "roman": "jal thal nīr bharē sītal pavaṇ jhulārdē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть впадины и холмы наполнены дождевой водой, пусть веют прохладные ветры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47153,
          "is_rahao": false,
          "gurmukhi": "ਸੇਜੜੀਆ ਸੋਇੰਨ ਹੀਰੇ ਲਾਲ ਜੜੰਦੀਆ ॥",
          "roman": "sejṛīā soinn hīrē lāl jaṛaṅdīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Пусть стоит золотое ложе, усыпанное алмазами и рубинами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47154,
          "is_rahao": false,
          "gurmukhi": "ਸੁਭਰ ਕਪੜ ਭੋਗ ਨਾਨਕ ਪਿਰੀ ਵਿਹੂਣੀ ਤਤੀਆ ॥੩॥",
          "roman": "subhar kapaṛ bhog nānak pirī vihūṇī tatīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, пусть есть праздничные одежды и наслаждения, но если женщина разлучена с мужем, всё это вместо утешения рождает в сердце жжение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3954,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47155,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47156,
          "is_rahao": false,
          "gurmukhi": "ਕਾਰਣੁ ਕਰਤੈ ਜੋ ਕੀਆ ਸੋਈ ਹੈ ਕਰਣਾ ॥",
          "roman": "kāraṇ kartē jo kīā soī hē karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О существо, тот повод, который создал Творец, только он и должен совершиться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47157,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਸਉ ਧਾਵਹਿ ਪ੍ਰਾਣੀਆ ਪਾਵਹਿ ਧੁਰਿ ਲਹਣਾ ॥",
          "roman": "jē sau dhāvah prāṇīā pāvah dhur lahṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если ты будешь бегать сотни раз, получишь лишь то, что изначально записано тебе по твоим делам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47158,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਕਰਮਾ ਕਿਛੂ ਨ ਲਭਈ ਜੇ ਫਿਰਹਿ ਸਭ ਧਰਣਾ ॥",
          "roman": "bin karmā kichhū na labhaī jē phirah sabh dharṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Даже если ты будешь скитаться по всей земле, без милости Господа ничего не получишь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47159,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਭਉ ਗੋਵਿੰਦ ਕਾ ਭੈ ਡਰੁ ਦੂਰਿ ਕਰਣਾ ॥",
          "roman": "gur mil bhau govind kā bhē ḍar dūr karṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У того, кто встретил Гуру и поселил в сердце страх перед Говиндом, Господь удаляет тревогу перед мирскими страхами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47160,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਤੇ ਬੈਰਾਗੁ ਊਪਜੈ ਹਰਿ ਖੋਜਤ ਫਿਰਣਾ ॥",
          "roman": "bhē tē bērāg ūpajē har khojat phirṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Из страха перед Богом рождается отрешённость от мира, и человек начинает искать Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47161,
          "is_rahao": false,
          "gurmukhi": "ਖੋਜਤ ਖੋਜਤ ਸਹਜੁ ਉਪਜਿਆ ਫਿਰਿ ਜਨਮਿ ਨ ਮਰਣਾ ॥",
          "roman": "khojat khojat sahaj upjiā phir janam na marṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ища и ища Господа, человек обретает духовную устойчивость, и круг рождения и смерти прекращается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47162,
          "is_rahao": false,
          "gurmukhi": "ਹਿਆਇ ਕਮਾਇ ਧਿਆਇਆ ਪਾਇਆ ਸਾਧ ਸਰਣਾ ॥",
          "roman": "hiāē kamāē dhiāiā pāiā sādh sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обрёл прибежище Гуру, в сердце созерцал Имя и совершал практику Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47163,
          "is_rahao": false,
          "gurmukhi": "ਬੋਹਿਥੁ ਨਾਨਕ ਦੇਉ ਗੁਰੁ ਜਿਸੁ ਹਰਿ ਚੜਾਏ ਤਿਸੁ ਭਉਜਲੁ ਤਰਣਾ ॥੨੨॥",
          "roman": "bohith nānak dēu gur jis har chaṛāē tis bhaujal tarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Гуру — духовный корабль; кого Хари посадил на этот корабль, тот переправился через океан мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3955,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47164,
          "is_rahao": false,
          "gurmukhi": "ਸਲੋਕ ਮਃ ੫ ॥",
          "roman": "salok mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Салок, Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47165,
          "is_rahao": false,
          "gurmukhi": "ਪਹਿਲਾ ਮਰਣੁ ਕਬੂਲਿ ਜੀਵਣ ਕੀ ਛਡਿ ਆਸ ॥",
          "roman": "pahilā maraṇ kabūl jīvaṇ kī chhaḍ ās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Сначала прими смерть Хоумэ и привязанности, оставь надежду на жизнь, наполненную эгоистическими желаниями."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47166,
          "is_rahao": false,
          "gurmukhi": "ਹੋਹੁ ਸਭਨਾ ਕੀ ਰੇਣੁਕਾ ਤਉ ਆਉ ਹਮਾਰੈ ਪਾਸਿ ॥੧॥",
          "roman": "hoh sabhnā kī rēṇkā tau āu hamārē pās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Стань пылью у ног всех, и тогда приходи ко Мне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3956,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47167,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47168,
          "is_rahao": false,
          "gurmukhi": "ਮੁਆ ਜੀਵੰਦਾ ਪੇਖੁ ਜੀਵੰਦੇ ਮਰਿ ਜਾਨਿ ॥",
          "roman": "muā jīvaṅdā pēkh jīvaṅdē mar jān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Истинно живым считай того, кто умер для мирских желаний; те же, кто только наслаждаются красками мира, умирают духовной смертью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47169,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨੑਾ ਮੁਹਬਤਿ ਇਕ ਸਿਉ ਤੇ ਮਾਣਸ ਪਰਧਾਨ ॥੨॥",
          "roman": "jinhā muhabbat ik siu tē māṇas pardhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Лучшими среди людей называются те, чья любовь обращена к Единому Богу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3957,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47170,
          "is_rahao": false,
          "gurmukhi": "ਮਃ ੫ ॥",
          "roman": "mahalā panjvāṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Махала 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47171,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਨਿ ਵਸੈ ਪਾਰਬ੍ਰਹਮੁ ਨਿਕਟਿ ਨ ਆਵੈ ਪੀਰ ॥",
          "roman": "jis man vasē pārbrahm nikaṭ na āvē pīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "К человеку, в чьём уме пребывает Имя Парабрахма, не приближается никакое страдание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47172,
          "is_rahao": false,
          "gurmukhi": "ਭੁਖ ਤਿਖ ਤਿਸੁ ਨ ਵਿਆਪਈ ਜਮੁ ਨਹੀ ਆਵੈ ਨੀਰ ॥੩॥",
          "roman": "bhukh tikh tis na viāpaī jam nahī āvē nīr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жажда и голод майи не оказывают на него давления, и страх смерти не подходит к нему близко."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3958,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47173,
          "is_rahao": false,
          "gurmukhi": "ਪਉੜੀ ॥",
          "roman": "pauṛī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Паури."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47174,
          "is_rahao": false,
          "gurmukhi": "ਕੀਮਤਿ ਕਹਣੁ ਨ ਜਾਈਐ ਸਚੁ ਸਾਹ ਅਡੋਲੈ ॥",
          "roman": "kīmat kahaṇ na jāīē sach sāh aḍolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О вечно-истинный и непоколебимый Шах, Твою цену невозможно высказать."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47175,
          "is_rahao": false,
          "gurmukhi": "ਸਿਧ ਸਾਧਿਕ ਗਿਆਨੀ ਧਿਆਨੀਆ ਕਉਣੁ ਤੁਧੁਨੋ ਤੋਲੈ ॥",
          "roman": "sidh sādhik giānī dhiānīā kauṇ tudhno tolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Кто из достигших йогов, практикующих, знатоков и погружённых в медитацию сможет оценить Тебя?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47176,
          "is_rahao": false,
          "gurmukhi": "ਭੰਨਣ ਘੜਣ ਸਮਰਥੁ ਹੈ ਓਪਤਿ ਸਭ ਪਰਲੈ ॥",
          "roman": "bhaṅṇaṇ ghaṛaṇ samrath hē opat sabh parlē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Господь способен создавать и разрушать; Он Сам производит творение и Сам приводит его к уничтожению."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47177,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਸਮਰਥੁ ਹੈ ਘਟਿ ਘਟਿ ਸਭ ਬੋਲੈ ॥",
          "roman": "karaṇ kāraṇ samrath hē ghaṭ ghaṭ sabh bolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он — источник и Создатель мира, обладающий силой творить; в каждом сердце говорит Он Сам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47178,
          "is_rahao": false,
          "gurmukhi": "ਰਿਜਕੁ ਸਮਾਹੇ ਸਭਸੈ ਕਿਆ ਮਾਣਸੁ ਡੋਲੈ ॥",
          "roman": "rijak samāhē sabhsē kiā māṇas ḍolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он доставляет пропитание каждому существу; человек напрасно тревожится."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47179,
          "is_rahao": false,
          "gurmukhi": "ਗਹਿਰ ਗਭੀਰੁ ਅਥਾਹੁ ਤੂ ਗੁਣ ਗਿਆਨ ਅਮੋਲੈ ॥",
          "roman": "gahir gabhīr athāh tū guṇ giān amolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, Ты глубок, мудр и бездонен; цену Твоим качествам и Твоему знанию невозможно определить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47180,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਕੰਮੁ ਕਮਾਵਣਾ ਕੀਆ ਧੁਰਿ ਮਉਲੈ ॥",
          "roman": "soī kamm kamāvaṇā kīā dhur maulē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Существо делает только то дело, которое от начала назначил для него Творец."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47181,
          "is_rahao": false,
          "gurmukhi": "ਤੁਧਹੁ ਬਾਹਰਿ ਕਿਛੁ ਨਹੀ ਨਾਨਕੁ ਗੁਣ ਬੋਲੈ ॥੨੩॥੧॥੨॥",
          "roman": "tudhah bāhar kichh nahī nānak guṇ bolē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Господь, вне Тебя в мире ничего не действует; Нанак воспевает только Твои достоинства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 3959,
      "rahao_verse_id": 47185,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 47182,
          "is_rahao": true,
          "gurmukhi": "ਰਾਗੁ ਮਾਰੂ ਬਾਣੀ ਕਬੀਰ ਜੀਉ ਕੀ",
          "roman": "rāg mārū bāṇī kabīr jīu kī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Раг Мару, Бани Кабира Джи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47183,
          "is_rahao": true,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Единый Онкар, постигаемый по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47184,
          "is_rahao": true,
          "gurmukhi": "ਪਡੀਆ ਕਵਨ ਕੁਮਤਿ ਤੁਮ ਲਾਗੇ ॥",
          "roman": "paḍīā kavan kumat tum lāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О пандит, какой дурной мысли вы, люди, предались?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47185,
          "is_rahao": true,
          "gurmukhi": "ਬੂਡਹੁਗੇ ਪਰਵਾਰ ਸਕਲ ਸਿਉ ਰਾਮੁ ਨ ਜਪਹੁ ਅਭਾਗੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "būḍhūgē parvār sakal siu rām na japah abhāgē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О несчастный пандит, ты не вспоминаешь Имя Господа; вместе со всей семьёй утонешь в океане мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 47186,
          "is_rahao": false,
          "gurmukhi": "ਬੇਦ ਪੁਰਾਨ ਪੜੇ ਕਾ ਕਿਆ ਗੁਨੁ ਖਰ ਚੰਦਨ ਜਸ ਭਾਰਾ ॥",
          "roman": "bēd purān paṛē kā kiā gun khar chandan jas bhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Если ты остался лишён Имени, нет никакой пользы от чтения Вед и Пуран; это лишь груз на уме, как ноша сандала на осле."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
