{
  "ang": 1129,
  "shabads": [
    {
      "shabad_id": 4039,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48085,
          "is_rahao": false,
          "gurmukhi": "ਕਰਮੁ ਹੋਵੈ ਗੁਰੁ ਕਿਰਪਾ ਕਰੈ ॥",
          "roman": "karam hovē gur kirpā karē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਪਰਮਾਤਮਾ ਦੀ ਮਿਹਰ ਹੁੰਦੀ ਹੈ, ਗੁਰੂ (ਜੀਵ ਉੱਤੇ) ਕਿਰਪਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда приходит милость Бога, Гуру являет благодать к существу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48086,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਮਨੁ ਜਾਗੈ ਇਸੁ ਮਨ ਕੀ ਦੁਬਿਧਾ ਮਰੈ ॥੪॥",
          "roman": "ihu man jāgē isu man kī dubidhā marē ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਜੀਵ ਦਾ) ਇਹ ਮਨ (ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚੋਂ) ਜਾਗ ਪੈਂਦਾ ਹੈ, ਇਸ ਮਨ ਦੀ ਮੇਰ-ਤੇਰ ਮੁੱਕ ਜਾਂਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "тогда этот ум пробуждается от сна майи, и его двойственность исчезает ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48087,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਾ ਸੁਭਾਉ ਸਦਾ ਬੈਰਾਗੀ ॥",
          "roman": "man kā subhāu sadā bērāgī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵ ਦੇ) ਮਨ ਦਾ ਅਸਲਾ ਉਹ ਪ੍ਰਭੂ ਹੈ ਜੋ ਮਾਇਆ ਤੋਂ ਸਦਾ ਨਿਰਲੇਪ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Подлинная основа ума — тот Бог, Который всегда непривязан к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48088,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਮਹਿ ਵਸੈ ਅਤੀਤੁ ਅਨਰਾਗੀ ॥੫॥",
          "roman": "sabh mahi vasē atīt anrāgī ॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਭ ਵਿਚ ਵੱਸਦਾ ਹੈ ਜੋ ਵਿਰਕਤ ਹੈ ਜੋ ਨਿਰਮੋਹ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает во всех; Он отрешённый и без пристрастия ॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48089,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਨਾਨਕੁ ਜੋ ਜਾਣੈ ਭੇਉ ॥",
          "roman": "kahat nānak jo jāṇē bhēu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ ਕਿ ਜਿਹੜਾ ਮਨੁੱਖ (ਆਪਣੇ ਇਸ ਅਸਲੇ ਬਾਰੇ) ਇਹ ਭੇਤ ਸਮਝ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: тот человек, который постигает эту тайну о своей основе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48090,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖੁ ਨਿਰੰਜਨ ਦੇਉ ॥੬॥੫॥",
          "roman": "ādi purakh nirañjan dēu ॥6॥5॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ (ਪਰਮਾਤਮਾ ਦੀ ਯਾਦ ਵਿਚ ਜੁੜ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਬਰਕਤਿ ਨਾਲ ਆਪਣੇ ਅੰਦਰੋਂ ਮਮਤਾ ਦੀ ਦੁਬਿਧਾ ਆਦਿਕ ਨੂੰ ਮੁਕਾ ਕੇ) ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਰੂਪ ਬਣ ਜਾਂਦਾ ਹੈ ਜੋ ਸਭ ਦਾ ਮੁੱਢ ਹੈ ਜੋ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ ਅਤੇ ਜੋ ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ ਨਿਰਲੇਪ ਚਾਨਣ-ਰੂਪ ਹੈ ॥੬॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "становится образом того Бога, Который — Изначальный Пурукх, всепронизывающий и незапятнанный светом, свободный от привязанности к майе ॥6॥5॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4040,
      "rahao_verse_id": 48095,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48091,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੩ ॥",
          "roman": "Bhērau mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48092,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਜਗਤ ਨਿਸਤਾਰਾ ॥",
          "roman": "Rām nām jagat nistārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਦੁਨੀਆ ਦਾ ਪਾਰ-ਉਤਾਰਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Рама переправляет мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48093,
          "is_rahao": false,
          "gurmukhi": "ਭਵਜਲੁ ਪਾਰਿ ਉਤਾਰਣਹਾਰਾ ॥੧॥",
          "roman": "Bhavjal pār utāraṇhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ (ਜੀਵਾਂ ਨੂੰ) ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾਣ ਦੀ ਸਮਰਥਾ ਰੱਖਣ ਵਾਲਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Оно обладает силой переправить живых существ через мировой океан ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48094,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਹਰਿ ਨਾਮੁ ਸਮੑਾਲਿ ॥",
          "roman": "Gur parsādī har nām samhāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਦਾ ਪਾਤ੍ਰ ਬਣ ਕੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ) ਸੰਭਾਲ।"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру, став достойным его милости, храни в своём сердце Имя Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48095,
          "is_rahao": true,
          "gurmukhi": "ਸਦ ਹੀ ਨਿਬਹੈ ਤੇਰੈ ਨਾਲਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Sad hī nibhē terē nāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਹਰਿ-ਨਾਮ ਸਦਾ ਹੀ ਤੇਰੇ ਨਾਲ ਸਾਥ ਦੇਵੇਗਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Это Имя Хари всегда будет с тобой и поддержит тебя ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48096,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਨ ਚੇਤਹਿ ਮਨਮੁਖ ਗਾਵਾਰਾ ॥",
          "roman": "Nām na cheteh manmukh gāvārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮੂਰਖ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਸਿਮਰਦੇ।"
            },
            "sahib_singh_ru": {
              "main": "Глупые люди, идущие за своим умом, не помнят Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48097,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਕੈਸੇ ਪਾਵਹਿ ਪਾਰਾ ॥੨॥",
          "roman": "Bin nāvē kēse pāveh pārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਤੋਂ ਬਿਨਾ ਉਹ ਕਿਸੇ ਤਰ੍ਹਾਂ ਭੀ (ਸੰਸਾਰ ਦੇ ਵਿਕਾਰਾਂ ਤੋਂ) ਪਾਰ ਨਹੀਂ ਲੰਘ ਸਕਦੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени они никак не смогут переправиться через пороки мира ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48098,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਦਾਤਿ ਕਰੇ ਦਾਤਾਰੁ ॥",
          "roman": "Āpe dāt kare dātār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ, ਇਹ ਕਿਸੇ ਦੇ ਵੱਸ ਦੀ ਗੱਲ ਨਹੀਂ) ਨਾਮ ਦੀ ਬਖ਼ਸ਼ਸ਼ ਦਾਤਾਰ ਪ੍ਰਭੂ ਆਪ ਹੀ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но это не во власти человека: Даритель Сам даёт дар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48099,
          "is_rahao": false,
          "gurmukhi": "ਦੇਵਣਹਾਰੇ ਕਉ ਜੈਕਾਰੁ ॥੩॥",
          "roman": "Devaṇhāre kau jēkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਦੇਣ ਦੀ ਸਮਰਥਾ ਵਾਲੇ ਪ੍ਰਭੂ ਦੇ ਅੱਗੇ ਹੀ ਸਿਰ ਨਿਵਾਉਣਾ ਚਾਹੀਦਾ ਹੈ (ਪ੍ਰਭੂ ਪਾਸੋਂ ਹੀ ਨਾਮ ਦੀ ਦਾਤ ਮੰਗਣੀ ਚਾਹੀਦੀ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому склоняться следует только перед Тем, кто может даровать, и у Него же просить дар Имени ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48100,
          "is_rahao": false,
          "gurmukhi": "ਨਦਰਿ ਕਰੇ ਸਤਿਗੁਰੂ ਮਿਲਾਏ ॥",
          "roman": "Nadar kare Satgurū milāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪ੍ਰਭੂ ਮਿਹਰ ਦੀ ਨਿਗਾਹ ਕਰਦਾ ਹੈ, ਉਸ ਨੂੰ ਗੁਰੂ ਮਿਲਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "На кого Бог обращает милостивый взгляд, того Он приводит к Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48101,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਹਿਰਦੈ ਨਾਮੁ ਵਸਾਏ ॥੪॥੬॥",
          "roman": "Nānak hirdē nām vasāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਹ ਮਨੁੱਖ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵਸਾਂਦਾ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, такой человек поселяeт Имя Бога в своём сердце ॥4॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4041,
      "rahao_verse_id": 48106,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48102,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੩ ॥",
          "roman": "Bhērau mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48103,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਉਧਰੇ ਸਭਿ ਜਿਤਨੇ ਲੋਅ ॥",
          "roman": "Nāme udhare sabh jitne loe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੌਦਾਂ ਭਵਨਾਂ ਦੇ ਜਿਤਨੇ ਭੀ ਜੀਵ ਹਨ, ਉਹ ਸਾਰੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦੀ ਰਾਹੀਂ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Все существа во всех четырнадцати мирах спасаются от пороков через Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48104,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਿਨਾ ਪਰਾਪਤਿ ਹੋਇ ॥੧॥",
          "roman": "Gurmukh jinā parāpat hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਮਿਲ ਜਾਂਦਾ ਹੈ (ਉਹ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚ ਜਾਂਦੇ ਹਨ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которым через Гуру достаётся Имя Бога, спасаются от пороков ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48105,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਅਪਣੀ ਕ੍ਰਿਪਾ ਕਰੇਇ ॥",
          "roman": "Har jīo apṇī kirpā karei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ) ਪਰਮਾਤਮਾ ਆਪਣੀ ਕਿਰਪਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Господь простирает Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48106,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਵਡਿਆਈ ਦੇਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Gurmukh nām vaḍiāī dei",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਗੁਰੂ ਦੀ ਸਰਨ ਪਾ ਕੇ (ਆਪਣਾ) ਨਾਮ ਦੇਂਦਾ ਹੈ (ਇਹੀ ਹੈ ਅਸਲ) ਇੱਜ਼ਤ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тому, приведя к прибежищу Гуру, Он даёт Своё Имя. Это и есть истинная честь ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48107,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮਿ ਜਿਨ ਪ੍ਰੀਤਿ ਪਿਆਰੁ ॥",
          "roman": "Rām nām jin prīt piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੀ ਪ੍ਰੀਤ ਹੈ ਜਿਨ੍ਹਾਂ ਦਾ ਪਿਆਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, у которых есть любовь и привязанность к Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48108,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਉਧਰੇ ਸਭਿ ਕੁਲ ਉਧਾਰਣਹਾਰੁ ॥੨॥",
          "roman": "Āp udhare sabh kul udhāraṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚ ਗਏ। (ਉਹਨਾਂ ਵਿਚੋਂ ਹਰੇਕ ਆਪਣੀਆਂ) ਸਾਰੀਆਂ ਕੁਲਾਂ ਨੂੰ ਬਚਾਣ-ਜੋਗਾ ਹੋ ਗਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "сами спаслись от пороков и каждый из них стал способным спасать весь свой род ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48109,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਮਨਮੁਖ ਜਮ ਪੁਰਿ ਜਾਹਿ ॥",
          "roman": "Bin nāvē manmukh jam pur jāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਮਨ ਦੇ ਪਿੱਛੇ ਤੁਰਨ ਵਾਲੇ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਖੁੰਝ ਕੇ ਜਮਰਾਜ ਦੇ ਦੇਸ ਵਿਚ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Люди, идущие за своим умом, лишившись Имени Бога, попадают в страну Ямы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48110,
          "is_rahao": false,
          "gurmukhi": "ਅਉਖੇ ਹੋਵਹਿ ਚੋਟਾ ਖਾਹਿ ॥੩॥",
          "roman": "Aukhe hovahi choṭā khāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਦੁਖੀ ਹੁੰਦੇ, (ਤੇ ਨਿੱਤ ਵਿਕਾਰਾਂ ਦੀਆਂ) ਸੱਟਾਂ ਸਹਾਰਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "они страдают и терпят удары пороков ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48111,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਕਰਤਾ ਦੇਵੈ ਸੋਇ ॥",
          "roman": "Āpe kartā devē soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਕਰਤਾਰ ਆਪ ਹੀ (ਨਾਮ ਦੀ ਦਾਤਿ) ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, кому Творец Сам даёт этот дар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48112,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਪਰਾਪਤਿ ਹੋਇ ॥੪॥੭॥",
          "roman": "Nānak nām parāpat hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਉਸ ਨੂੰ ਹੀ ਉਸ ਦਾ) ਨਾਮ ਮਿਲਦਾ ਹੈ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, только тому и достаётся Его Имя ॥4॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4042,
      "rahao_verse_id": 48117,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48113,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੩ ॥",
          "roman": "Bhērau mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48114,
          "is_rahao": false,
          "gurmukhi": "ਗੋਵਿੰਦ ਪ੍ਰੀਤਿ ਸਨਕਾਦਿਕ ਉਧਾਰੇ ॥",
          "roman": "Govind prīt sanakādik udhāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਨਕ, ਸਨੰਦਨ, ਸਨਤਾਨ, ਸਨਤਕੁਮਾਰ-ਬ੍ਰਹਮਾ ਦੇ ਇਹਨਾਂ ਚਾਰ ਪੁੱਤਰਾਂ- ਨੂੰ ਪਰਮਾਤਮਾ ਦੇ (ਚਰਨਾਂ ਦੇ) ਪਿਆਰ ਨੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Санак, Санандан, Санатан и Санаткумар, четыре сына Брахмы, были переправлены через мировой океан любовью к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48115,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮ ਸਬਦਿ ਬੀਚਾਰੇ ॥੧॥",
          "roman": "Rām nām sabad bīchāre",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਨ੍ਹਾਂ ਨੇ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨੂੰ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਇਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "потому что через Слово Гуру они утвердили в уме Имя Бога ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48116,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਜੀਉ ਅਪਣੀ ਕਿਰਪਾ ਧਾਰੁ ॥",
          "roman": "Har jīo apṇī kirpā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ ਜੀ! (ਮੇਰੇ ਉਤੇ) ਆਪਣੀ ਕਿਰਪਾ ਕਰੀ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь, продолжай держать на мне Свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48117,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੇ ਲਗੈ ਪਿਆਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Gurmukh nāme lagē piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਕਿ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਮੇਰਾ) ਪਿਆਰ (ਤੇਰੇ) ਨਾਮ ਵਿਚ ਹੀ ਬਣਿਆ ਰਹੇ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы, придя в прибежище Гуру, моя любовь оставалась соединённой только с Твоим Именем ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48118,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਪ੍ਰੀਤਿ ਭਗਤਿ ਸਾਚੀ ਹੋਇ ॥",
          "roman": "Antar prīt bhagat sāchī hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਪਰਮਾਤਮਾ ਦੀ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੀ ਪ੍ਰੀਤਿ-ਭਗਤੀ ਪੈਦਾ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того человека, в котором возникает истинная, вечная любовь-преданность к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48119,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੈ ਗੁਰਿ ਮੇਲਾਵਾ ਹੋਇ ॥੨॥",
          "roman": "Pūrē gur melāvā hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਉਸ ਦਾ ਪਰਮਾਤਮਾ ਨਾਲ ਮਿਲਾਪ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "через совершенного Гуру происходит встреча с Богом ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48120,
          "is_rahao": false,
          "gurmukhi": "ਨਿਜ ਘਰਿ ਵਸੈ ਸਹਜਿ ਸੁਭਾਇ ॥",
          "roman": "Nij ghar vasē sahaj subhāe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕ ਕੇ, ਪ੍ਰਭੂ-ਪਿਆਰ ਵਿਚ ਟਿਕ ਕੇ, ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਨਿਵਾਸ ਕਰੀ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он пребывает в духовной устойчивости, в любви к Богу и живёт в Его присутствии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48121,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਨਾਮੁ ਵਸੈ ਮਨਿ ਆਇ ॥੩॥",
          "roman": "Gurmukh nām vasē man āe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆ ਵੱਸਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если в его уме, через прибежище Гуру, поселяется Имя Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48122,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵੇਖੈ ਵੇਖਣਹਾਰੁ ॥",
          "roman": "Āpe vekhē vekhaṇhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਜੀਵਾਂ ਦੀ ਸੰਭਾਲ ਕਰਨ ਦੇ ਸਮਰੱਥ ਜਿਹੜਾ ਪ੍ਰਭੂ ਆਪ ਹੀ (ਸਭ ਦੀ) ਸੰਭਾਲ ਕਰ ਰਿਹਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который Сам хранит и поддерживает всех существ,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48123,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਨਾਮੁ ਰਖਹੁ ਉਰ ਧਾਰਿ ॥੪॥੮॥",
          "roman": "Nānak nām rakhah ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਦਾ ਨਾਮ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰੋ ਕੇ ਰੱਖ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, держи Его Имя вплетённым в своём сердце ॥4॥8॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4043,
      "rahao_verse_id": 48128,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48124,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੩ ॥",
          "roman": "Bhērau mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48125,
          "is_rahao": false,
          "gurmukhi": "ਕਲਜੁਗ ਮਹਿ ਰਾਮ ਨਾਮੁ ਉਰ ਧਾਰੁ ॥",
          "roman": "Kaljug meh rām nām ur dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਵਿਕਾਰਾਂ-ਭਰੇ ਜਗਤ ਵਿਚ (ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਣ ਲਈ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੇ) ਹਿਰਦੇ ਵਿਚ ਵਸਾਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "В этом мире, полном пороков, держи в своём сердце Имя Бога, чтобы спастись от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48126,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਨਾਵੈ ਮਾਥੈ ਪਾਵੈ ਛਾਰੁ ॥੧॥",
          "roman": "Bin nāvē māthē pāvē chhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ) ਨਾਮ ਤੋਂ ਖ਼ਾਲੀ (ਰਹਿੰਦਾ ਹੈ, ਉਹ ਲੋਕ ਪਰਲੋਕ ਦੀ) ਨਿਰਾਦਰੀ ਹੀ ਖੱਟਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Кто остаётся без Имени, тот обретает лишь бесчестие и здесь, и в ином мире ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48127,
          "is_rahao": true,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਦੁਲਭੁ ਹੈ ਭਾਈ ॥",
          "roman": "Rām nām dulabh hē bhāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! (ਹੋਰ ਪਦਾਰਥਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਬੜੀ ਮੁਸ਼ਕਿਲ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О брат, Имя Бога получить очень трудно по сравнению с другими вещами."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48128,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਵਸੈ ਮਨਿ ਆਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Gur parsād vasē man āī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਤਾਂ) ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਕਿਸੇ ਭਾਗਾਂ ਵਾਲੇ ਦੇ) ਮਨ ਵਿਚ ਆ ਕੇ ਵੱਸਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Оно поселяется в уме только по милости Гуру, у счастливого человека ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48129,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਜਨ ਭਾਲਹਿ ਸੋਇ ॥",
          "roman": "Rām nām jan bhālah soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਉਹ ਮਨੁੱਖ ਹੀ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਭਾਲਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Только те люди ищут Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48130,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਤੇ ਪ੍ਰਾਪਤਿ ਹੋਇ ॥੨॥",
          "roman": "Pūre gur te parāpat hoe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਪਾਸੋਂ (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਦੇ ਭਾਗਾਂ ਵਿਚ) ਹਰਿ-ਨਾਮ ਦੀ ਪ੍ਰਾਪਤੀ (ਲਿਖੀ ਹੋਈ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "в чьей судьбе записано получить Имя Хари от совершенного Гуру ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48131,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਭਾਣਾ ਮੰਨਹਿ ਸੇ ਜਨ ਪਰਵਾਣੁ ॥",
          "roman": "Har kā bhāṇā maṅṇah se jan parvāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ (ਮਿੱਠਾ ਕਰਕੇ) ਮੰਨਦੇ ਹਨ, ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਸਤਕਾਰੇ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди принимают волю Бога как сладкую и бывают приняты в Его присутствии,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48132,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਨਾਮ ਨੀਸਾਣੁ ॥੩॥",
          "roman": "Gur kē sabad nām nīsāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਬਰਕਤਿ ਨਾਲ (ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ) ਹਰਿ-ਨਾਮ (ਦੀ ਪਰਾਪਤੀ) ਦਾ ਪਰਵਾਨਾ (ਮਿਲ ਜਾਂਦਾ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "благодаря слову Гуру они получают разрешение на достижение Имени Хари ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48133,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੇਵਹੁ ਜੋ ਕਲ ਰਹਿਆ ਧਾਰਿ ॥",
          "roman": "So sevah jo kal rahiā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ (ਪਰਮਾਤਮਾ) ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰੋ, ਗੁਰੂ ਦੀ ਰਾਹੀਂ ਉਸ ਦੇ ਨਾਮ ਨੂੰ ਪਿਆਰ ਕਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, служи и поклоняйся Тому Богу, через Гуру возлюби Его Имя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48134,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਗੁਰਮੁਖਿ ਨਾਮੁ ਪਿਆਰਿ ॥੪॥੯॥",
          "roman": "Nānak gurmukh nām piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਹੜਾ ਪਰਮਾਤਮਾ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਦੀ ਮਰਯਾਦਾ ਨੂੰ ਆਪਣੀ ਸੱਤਿਆ ਨਾਲ ਤੋਰ ਰਿਹਾ ਹੈ ॥੪॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, Тому, кто Своей силой поддерживает порядок всего творения ॥4॥9॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4044,
      "rahao_verse_id": 48139,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48135,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੩ ॥",
          "roman": "Bhērau mehlā 3",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48136,
          "is_rahao": false,
          "gurmukhi": "ਕਲਜੁਗ ਮਹਿ ਬਹੁ ਕਰਮ ਕਮਾਹਿ ॥",
          "roman": "Kaljug meh bah karam kamāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ (ਕਰਮ-ਕਾਂਡੀ ਲੋਕ) ਕਲਜੁਗ ਵਿਚ ਵਿਚ ਭੀ ਹੋਰ ਹੋਰ (ਮਿਥੇ ਧਾਰਮਿਕ) ਕਰਮ ਕਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те обрядовые люди, которые и в Кали-югу совершают всевозможные иные религиозные действия,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48137,
          "is_rahao": false,
          "gurmukhi": "ਨਾ ਰੁਤਿ ਨ ਕਰਮ ਥਾਇ ਪਾਹਿ ॥੧॥",
          "roman": "Nā rut na karam thāe pāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਉਹ ਕਰਮ (ਪਰਮਾਤਮਾ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ) ਕਬੂਲ ਨਹੀਂ ਹੁੰਦੇ (ਕਿਉਂਕਿ ਸ਼ਾਸਤ੍ਰਾਂ ਅਨੁਸਾਰ ਭੀ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਹੋਰ ਕਿਸੇ ਕਰਮ ਦੀ ਹੁਣ) ਰੁੱਤ ਨਹੀਂ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "их дела не принимаются в присутствии Бога, потому что даже по шастрам ныне не время для чего-либо иного, кроме симрана ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48138,
          "is_rahao": true,
          "gurmukhi": "ਕਲਜੁਗ ਮਹਿ ਰਾਮ ਨਾਮੁ ਹੈ ਸਾਰੁ ॥",
          "roman": "Kaljug meh rām nām hē sār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੇ ਸ਼ਾਸਤਰਾਂ ਦੀ ਮਰਯਾਦਾ ਵਲ ਭੀ ਵੇਖੋ, ਤਾਂ ਭੀ) ਕਲਜੁਗ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਜਪਣਾ ਹੀ) ਸ੍ਰੇਸ਼ਟ (ਕੰਮ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Если смотреть даже по мере шастр, то в Кали-югу высшее дело — это повторение Имени Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48139,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਸਾਚਾ ਲਗੈ ਪਿਆਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "Gurmukh sāchā lagē piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ (ਨਾਮ ਸਿਮਰਿਆਂ ਪਰਮਾਤਮਾ ਨਾਲ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪਿਆਰ ਬਣ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Придя в прибежище Гуру, человек обретает вечную любовь к Богу ॥1॥ ਰਹਾਉ ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48140,
          "is_rahao": false,
          "gurmukhi": "ਤਨੁ ਮਨੁ ਖੋਜਿ ਘਰੈ ਮਹਿ ਪਾਇਆ ॥",
          "roman": "Tan man khoj gharē meh pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੇ ਆਪਣਾ ਤਨ ਆਪਣਾ ਮਨ ਖੋਜ ਕੇ ਹਿਰਦੇ-ਘਰ ਵਿਚ ਹੀ ਪ੍ਰਭੂ ਨੂੰ ਲੱਭ ਲਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Исследовав своё тело и ум, тот человек нашёл Бога в доме своего сердца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48141,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਰਾਮ ਨਾਮਿ ਚਿਤੁ ਲਾਇਆ ॥੨॥",
          "roman": "Gurmukh rām nām chit lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਚਿੱਤ ਜੋੜਿਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "который, придя в прибежище Гуру, сосредоточил сознание на Имени Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
