          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48465,
          "is_rahao": true,
          "gurmukhi": "ਖੂਬੁ ਖੂਬੁ ਖੂਬੁ ਖੂਬੁ ਖੂਬੁ ਤੇਰੋ ਨਾਮੁ ॥",
          "roman": "khūb khūb khūb khūb khūb tero nām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਸੋਹਣਾ ਹੈ, ਤੇਰਾ ਨਾਮ ਮਿੱਠਾ ਹੈ, ਤੇਰਾ ਨਾਮ ਚੰਗਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твоё Имя прекрасно, сладостно, благо."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48466,
          "is_rahao": true,
          "gurmukhi": "ਝੂਠੁ ਝੂਠੁ ਝੂਠੁ ਝੂਠੁ ਦੁਨੀ ਗੁਮਾਨੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jhūṭh jhūṭh jhūṭh jhūṭh dunī gumān ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਹੇ ਭਾਈ!) ਦੁਨੀਆ ਦਾ ਮਾਣ ਝੂਠਾ ਹੈ, ਛੇਤੀ ਮੁੱਕ ਜਾਣ ਵਾਲਾ ਹੈ, ਦੁਨੀਆ ਦੇ ਮਾਣ ਦਾ ਕੀਹ ਭਰੋਸਾ? ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Но, о брат, гордость мира ложна, быстро исчезает — какая может быть надежда на мирскую славу? ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48467,
          "is_rahao": false,
          "gurmukhi": "ਨਗਜ ਤੇਰੇ ਬੰਦੇ ਦੀਦਾਰੁ ਅਪਾਰੁ ॥",
          "roman": "nagaj tere bande dīdār apār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਭਗਤੀ ਕਰਨ ਵਾਲੇ ਬੰਦੇ ਸੋਹਣੇ ਹਨ, ਉਹਨਾਂ ਦਾ ਦਰਸਨ ਬੇਅੰਤ (ਅਮੋਲਕ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои преданные прекрасны, и их даршан безмерно драгоценен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
