{
  "ang": 1137,
  "shabads": [
    {
      "shabad_id": 4067,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48414,
          "is_rahao": false,
          "gurmukhi": "ਖਟੁ ਸਾਸਤ੍ਰ ਮੂਰਖੈ ਸੁਨਾਇਆ ॥",
          "roman": "khaṭ sāstr mūrakhē suṇāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕਿਸੇ ਅਨਪੜ੍ਹ ਮੂਰਖ ਨੂੰ ਛੇ ਸ਼ਾਸਤ੍ਰ ਸੁਣਾਏ ਜਾਣ,"
            },
            "sahib_singh_ru": {
              "main": "Если неграмотному глупцу читать шесть шастр,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48415,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੇ ਦਹ ਦਿਸ ਪਵਨੁ ਝੁਲਾਇਆ ॥੩॥",
          "roman": "jēse dah dis pavan jhulāiā.3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਅਨਪੜ੍ਹ ਵਿਚਾਰਾ ਕੀਹ ਸਮਝੇ ਉਹਨਾਂ ਸ਼ਾਸਤ੍ਰਾਂ ਨੂੰ? ਉਸ ਦੇ ਭਾਣੇ ਤਾਂ ਇਉਂ ਹੈ) ਜਿਵੇਂ ਉਸ ਦੇ ਦਸੀਂ ਪਾਸੀਂ (ਨਿਰੀ) ਹਵਾ ਹੀ ਚੱਲ ਰਹੀ ਹੈ (ਇਹੀ ਹਾਲ ਹੈ ਸਾਕਤ ਦਾ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "что он поймёт в этих шастрах? Для него это так, словно со всех десяти сторон просто дует ветер; таково и состояние саката.3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48416,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਕਣ ਖਲਹਾਨੁ ਜੈਸੇ ਗਾਹਨ ਪਾਇਆ ॥",
          "roman": "bin kaṇ khalhān jēse gāhan pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਅੰਨ ਦੇ ਦਾਣਿਆਂ ਤੋਂ ਬਿਨਾ ਕੋਈ ਖਲਵਾੜਾ ਗਾਹਿਆ ਜਾਏ (ਉਸ ਵਿਚੋਂ ਦਾਣਿਆਂ ਦਾ ਬੋਹਲ ਨਹੀਂ ਬਣੇਗਾ),"
            },
            "sahib_singh_ru": {
              "main": "Как если бы молотили ток без зёрен хлеба, из него не получится кучи зерна,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48417,
          "is_rahao": false,
          "gurmukhi": "ਤਿਉ ਸਾਕਤ ਤੇ ਕੋ ਨ ਬਰਾਸਾਇਆ ॥੪॥",
          "roman": "tiu sākat te ko na barāsāiā.4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਹੀ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਨਾਲੋਂ ਟੁੱਟੇ ਹੋਏ ਮਨੁੱਖ ਪਾਸੋਂ ਕੋਈ ਮਨੁੱਖ ਆਤਮਕ ਜੀਵਨ ਦੀ ਖ਼ੁਰਾਕ ਪ੍ਰਾਪਤ ਨਹੀਂ ਕਰ ਸਕਦਾ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "так и от человека, оторванного от стоп Всевышнего, никто не может получить пищу для духовной жизни.4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48418,
          "is_rahao": false,
          "gurmukhi": "ਤਿਤ ਹੀ ਲਾਗਾ ਜਿਤੁ ਕੋ ਲਾਇਆ ॥",
          "roman": "tit hī lāgā jit ko lāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, (ਸਾਕਤ ਦੇ ਭੀ ਕੀਹ ਵੱਸ?) ਹਰ ਕੋਈ ਉਸ (ਕੰਮ) ਵਿਚ ਹੀ ਲੱਗਦਾ ਹੈ ਜਿਸ ਵਿਚ (ਪਰਮਾਤਮਾ ਵੱਲੋਂ) ਉਹ ਲਾਇਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но что может сделать и сакат? Каждый занят только тем делом, к которому его приставляет Всевышний."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48419,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭਿ ਬਣਤ ਬਣਾਇਆ ॥੫॥੫॥",
          "roman": "kah nānak prabh baṇat baṇāiā.5.5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- (ਕੋਈ ਸਾਕਤ ਹੈ ਤੇ ਕੋਈ ਸੰਤ ਹੈ-ਇਹ) ਖੇਡ ਪ੍ਰਭੂ ਨੇ ਆਪ ਹੀ ਬਣਾਈ ਹੋਈ ਹੈ ॥੫॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: эта игра, что один — сакат, а другой — святой, устроена самим Богом.5.5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4068,
      "rahao_verse_id": 48424,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48420,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48421,
          "is_rahao": false,
          "gurmukhi": "ਜੀਉ ਪ੍ਰਾਣ ਜਿਨਿ ਰਚਿਓ ਸਰੀਰ ॥",
          "roman": "jīu prāṇ jin rachio sarīr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪਰਮਾਤਮਾ) ਨੇ ਜਿੰਦ ਪ੍ਰਾਣ (ਦੇ ਕੇ ਜੀਵਾਂ ਦੇ) ਸਰੀਰ ਰਚੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто сотворил тела, дав живым существам душу и дыхание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48422,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਹਿ ਉਪਾਏ ਤਿਸ ਕਉ ਪੀਰ ॥੧॥",
          "roman": "jineh upāe tis kau pīr ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਨੇ ਜੀਵ ਪੈਦਾ ਕੀਤੇ ਹਨ, ਉਸ ਨੂੰ ਹੀ (ਜੀਵਾਂ ਦਾ) ਦਰਦ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "тот же самый Параматма, который создал существ, и чувствует их боль ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48423,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਗੋਬਿੰਦੁ ਜੀਅ ਕੈ ਕਾਮ ॥",
          "roman": "gur gobind jīa kē kām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰੂ (ਹੀ) ਉਹ ਗੋਬਿੰਦ (ਹੀ) ਜਿੰਦ ਦੀ ਸਹਾਇਤਾ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Именно Гуру, именно Гобинд — помощник души,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48424,
          "is_rahao": true,
          "gurmukhi": "ਹਲਤਿ ਪਲਤਿ ਜਾ ਕੀ ਸਦ ਛਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "halat palat jā kī sad chhām ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਦਾ ਜਿਸ (ਗੋਬਿੰਦ) ਦਾ ਇਸ ਲੋਕ ਵਿਚ ਅਤੇ ਪਰਲੋਕ ਵਿਚ ਸਦਾ (ਮਨੁੱਖ ਨੂੰ) ਆਸਰਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тот, чья защита и опора есть для человека всегда — и в этом мире, и в ином ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48425,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਆਰਾਧਨ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "prabh ārādhan nirmal rīt ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਪਰਮਾਤਮਾ ਨੂੰ ਸਿਮਰਨਾ ਹੀ ਪਵਿੱਤਰ ਜੀਵਨ-ਜੁਗਤਿ ਹੈ (ਇਹ ਜੀਵਨ-ਜੁਗਤਿ ਸਾਧ ਸੰਗਤ ਵਿਚ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Поминание того Параматмы — и есть чистый способ жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48426,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਬਿਨਸੀ ਬਿਪਰੀਤਿ ॥੨॥",
          "roman": "sādhsang binsī biprīt ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ (ਸਿਮਰਨ ਤੋਂ) ਉਲਟੀ ਜੀਵਨ-ਜੁਗਤਿ ਨਾਸ ਹੋ ਜਾਂਦੀ ਹੈ (ਭਾਵ, ਸਿਮਰਨ ਨਾਹ ਕਰਨ ਦੀ ਮਾੜੀ ਵਾਦੀ ਖ਼ਤਮ ਹੋ ਜਾਂਦੀ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "В са̄дх-сангате исчезает извращённый, противоположный этому образ жизни ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48427,
          "is_rahao": false,
          "gurmukhi": "ਮੀਤ ਹੀਤ ਧਨੁ ਨਹ ਪਾਰਣਾ ॥",
          "roman": "mīt hīt dhan nah pārṇā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿੱਤਰ, ਹਿਤੂ, ਧਨ-ਇਹ (ਮਨੁੱਖ ਦੀ ਜਿੰਦ ਦਾ) ਸਹਾਰਾ ਨਹੀਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Друзья, близкие, богатство — не опора для души человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48428,
          "is_rahao": false,
          "gurmukhi": "ਧੰਨਿ ਧੰਨਿ ਮੇਰੇ ਨਾਰਾਇਣਾ ॥੩॥",
          "roman": "dhañn dhañn mere nārāiṇā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪਰਮਾਤਮਾ! (ਤੂੰ ਹੀ ਅਸਾਂ ਜੀਵਾਂ ਦਾ ਆਸਰਾ ਹੈਂ) ਤੂੰ ਹੀ ਸਲਾਹੁਣ-ਜੋਗ ਹੈਂ, ਤੂੰ ਹੀ ਸਲਾਹੁਣ-ਜੋਗ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О мой Параматма! Ты один достоин хвалы, ты один достоин хвалы ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48429,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਬੋਲੈ ਅੰਮ੍ਰਿਤ ਬਾਣੀ ॥",
          "roman": "nānak bolē amrit bāṇī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ (ਇਹ) ਬਚਨ ਆਖਦਾ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Нанак произносит эти слова, дарующие духовную жизнь:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48430,
          "is_rahao": false,
          "gurmukhi": "ਏਕ ਬਿਨਾ ਦੂਜਾ ਨਹੀ ਜਾਣੀ ॥੪॥੬॥",
          "roman": "ek binā dūjā nahī jāṇī ॥4॥6॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਇਕ ਪਰਮਾਤਮਾ ਤੋਂ ਬਿਨਾ ਕਿਸੇ ਹੋਰ ਨੂੰ (ਜ਼ਿੰਦਗੀ ਦਾ ਸਹਾਰਾ) ਨਾਹ ਸਮਝੀਂ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "кроме Единого Параматмы не считай никого другого опорой жизни ॥4॥6॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4069,
      "rahao_verse_id": 48435,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48431,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48432,
          "is_rahao": false,
          "gurmukhi": "ਆਗੈ ਦਯੁ ਪਾਛੈ ਨਾਰਾਇਣ ॥",
          "roman": "āgē day pāchhē nārāiṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਗਾਂਹ ਆਉਣ ਵਾਲੇ ਸਮੇ ਵਿਚ ਪਰਮਾਤਮਾ ਹੀ (ਅਸਾਂ ਜੀਵਾਂ ਉਤੇ) ਤਰਸ ਕਰਨ ਵਾਲਾ ਹੈ, ਪਿੱਛੇ ਲੰਘ ਚੁਕੇ ਸਮੇ ਵਿਚ ਭੀ ਪਰਮਾਤਮਾ ਹੀ (ਸਾਡਾ ਰਾਖਾ ਸੀ)।"
            },
            "sahib_singh_ru": {
              "main": "В будущем только Параматма будет милостив к нам, живым существам, и в прошедшем времени тоже лишь Параматма был нашим защитником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48433,
          "is_rahao": false,
          "gurmukhi": "ਮਧਿ ਭਾਗਿ ਹਰਿ ਪ੍ਰੇਮ ਰਸਾਇਣ ॥੧॥",
          "roman": "madh bhāg har prem rasāiṇ ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਭੀ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਦਾਤਾ ਪ੍ਰਭੂ ਹੀ (ਸਾਡੇ ਨਾਲ) ਪਿਆਰ ਕਰਨ ਵਾਲਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "И сейчас только Господь, дарующий все блага, любит нас ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48434,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭੂ ਹਮਾਰੈ ਸਾਸਤ੍ਰ ਸਉਣ ॥",
          "roman": "prabhū hamārē sāstr saun ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਹੀ ਸਾਡੇ ਵਾਸਤੇ ਚੰਗਾ ਮੁਹੂਰਤ ਦੱਸਣ ਵਾਲਾ ਸ਼ਾਸਤ੍ਰ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Господа и есть для нас то писание, которое указывает добрый час,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48435,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਗ੍ਰਿਹ ਭਉਣ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sūkh sahaj ānand grih bhaun ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਹਿਰਦੇ ਵਿਚ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਵੱਸਦਾ ਹੈ, ਉਸ) ਹਿਰਦੇ-ਘਰ ਵਿਚ ਸਦਾ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਹਨ ਆਨੰਦ ਹਨ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "в доме-сердце, где пребывает Имя Господа, всегда есть покой, внутренняя устойчивость и радость ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48436,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਨਾਮੁ ਕਰਨ ਸੁਣਿ ਜੀਵੇ ॥",
          "roman": "rasnā nām karan suṇ jīve ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੀਭ ਨਾਲ ਨਾਮ (ਜਪ ਕੇ), ਕੰਨਾਂ ਨਾਲ (ਨਾਮ) ਸੁਣ ਕੇ (ਅਨੇਕਾਂ ਹੀ ਜੀਵ) ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя языком и слушая его ушами, многие обрели духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48437,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਸਿਮਰਿ ਸਿਮਰਿ ਅਮਰ ਥਿਰੁ ਥੀਵੇ ॥੨॥",
          "roman": "prabh simar simar amar thir thīve ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਦਾ ਸਿਮਰ ਕੇ (ਅਨੇਕਾਂ ਜੀਵ) ਆਤਮਕ ਮੌਤ ਤੋਂ ਬਚ ਗਏ, (ਵਿਕਾਰਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਅਡੋਲ-ਚਿੱਤ ਬਣੇ ਰਹੇ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Постоянно вспоминая Параматму, многие избежали духовной смерти и стали стойкими перед пороками ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48438,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੇ ਦੂਖ ਨਿਵਾਰੇ ॥",
          "roman": "janam janam ke dūkh nivāre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਨੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਨੂੰ ਜੀਵਨ ਦਾ ਆਸਰਾ ਬਣਾਇਆ, ਉਹਨਾਂ ਦੇ ਆਪਣੇ) ਅਨੇਕਾਂ ਹੀ ਜਨਮਾਂ ਦੇ ਦੁੱਖ-ਪਾਪ ਦੂਰ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Те, кто сделали Имя Параматмы опорой жизни, устранили страдания и грехи многих своих рождений,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48439,
          "is_rahao": false,
          "gurmukhi": "ਅਨਹਦ ਸਬਦ ਵਜੇ ਦਰਬਾਰੇ ॥੩॥",
          "roman": "anahad sabad vaje darbāre ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਹਿਰਦੇ-ਦਰਬਾਰ ਵਿਚ ਇਉਂ ਇਕ-ਰਸ ਆਨੰਦ ਬਣ ਗਿਆ ਜਿਵੇਂ ਪੰਜਾਂ ਹੀ ਕਿਸਮਾਂ ਦੇ ਸਾਜ਼ ਵੱਜਣ ਨਾਲ ਸੰਗੀਤਕ ਰਸ ਬਣਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "и в дворе их сердца установилась непрерывная радость, словно звучат все пять видов музыкальных инструментов ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48440,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪ੍ਰਭਿ ਲੀਏ ਮਿਲਾਏ ॥",
          "roman": "kar kirpā prabh līe milāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜਿਹੜੇ ਮਨੁੱਖ ਸਗਨ ਆਦਿਕਾਂ ਦੇ ਭਰਮ ਛੱਡ ਕੇ ਸਿੱਧੇ) ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਆ ਪਏ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Те люди, которые, оставив суеверия о приметах и прочем, прямо пришли в прибежище Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48441,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪ੍ਰਭ ਸਰਣਾਗਤਿ ਆਏ ॥੪॥੭॥",
          "roman": "nānak prabh saraṇāgat āe ॥4॥7॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਕਿਰਪਾ ਕਰ ਕੇ ਉਹਨਾਂ ਨੂੰ ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜ ਲਿਆ ॥੪॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "были по милости Параматмы соединены с Его стопами ॥4॥7॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4070,
      "rahao_verse_id": 48446,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48442,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48443,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮਨੋਰਥ ਆਵਹਿ ਹਾਥ ॥",
          "roman": "koṭ manorath āvah hāth ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਨਾਮ ਜਪਦਾ ਹੈ ਉਸ ਦੇ) ਮਨ ਦੀਆਂ ਕ੍ਰੋੜਾਂ ਮੰਗਾਂ ਪੂਰੀਆਂ ਹੋ ਜਾਂਦੀਆਂ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "У того, кто повторяет Имя, исполняются бесчисленные желания сердца."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48444,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਮਾਰਗ ਕੈ ਸੰਗੀ ਪਾਂਥ ॥੧॥",
          "roman": "jam mārag kē sangī pānth ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਰਨ ਤੋਂ ਪਿੱਛੋਂ ਭੀ ਇਹ ਨਾਮ ਹੀ ਉਸ ਦਾ ਸਾਥੀ ਬਣਦਾ ਹੈ ਸਹਾਇਕ ਬਣਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "И после смерти именно это Имя становится его спутником и помощником ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48445,
          "is_rahao": true,
          "gurmukhi": "ਗੰਗਾ ਜਲੁ ਗੁਰ ਗੋਬਿੰਦ ਨਾਮ ॥",
          "roman": "gaṅgā jal gur gobind nām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰ-ਗੋਬਿੰਦ ਦਾ ਨਾਮ (ਹੀ ਅਸਲ) ਗੰਗਾ-ਜਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Гур-Гобинда — и есть подлинная вода Ганги."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48446,
          "is_rahao": true,
          "gurmukhi": "ਜੋ ਸਿਮਰੈ ਤਿਸ ਕੀ ਗਤਿ ਹੋਵੈ ਪੀਵਤ ਬਹੁੜਿ ਨ ਜੋਨਿ ਭ੍ਰਮਾਮ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jo simrē tis kī gat hovē pīvat bahuṛ na jon bhramām ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ (ਗੋਬਿੰਦ ਦਾ ਨਾਮ) ਸਿਮਰਦਾ ਹੈ, ਉਸ ਦੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣ ਜਾਂਦੀ ਹੈ, ਜਿਹੜਾ (ਇਸ ਨਾਮ-ਜਲ ਗੰਗਾ-ਜਲ ਨੂੰ) ਪੀਂਦਾ ਹੈ ਉਹ ਮੁੜ ਜੂਨਾਂ ਵਿਚ ਨਹੀਂ ਭਟਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Кто помнит это Имя, тот достигает высокой духовной ступени, а кто пьёт эту воду Имени, тот больше не блуждает по рождениям ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48447,
          "is_rahao": false,
          "gurmukhi": "ਪੂਜਾ ਜਾਪ ਤਾਪ ਇਸਨਾਨ ॥",
          "roman": "pūjā jāp tāp isnān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਹੀ (ਦੇਵ-) ਪੂਜਾ ਹੈ, ਨਾਮ ਹੀ ਜਪ-ਤਪ ਹੈ, ਤਾਪ ਹੀ ਤੀਰਥ-ਇਸ਼ਨਾਨ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Имя Хари и есть поклонение, Имя и есть джап и тап, Имя и есть омовение в тиртхах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48448,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮ ਭਏ ਨਿਹਕਾਮ ॥੨॥",
          "roman": "simrat nām bhae nihkām ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਸਿਮਰਦਿਆਂ (ਸਿਮਰਨ ਕਰਨ ਵਾਲੇ) ਦੁਨੀਆ ਵਾਲੀਆਂ ਵਾਸਨਾਂ ਤੋਂ ਰਹਿਤ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поминая Имя, люди становятся свободными от мирских желаний ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48449,
          "is_rahao": false,
          "gurmukhi": "ਰਾਜ ਮਾਲ ਸਾਦਨ ਦਰਬਾਰ ॥",
          "roman": "rāj māl sādan darbār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਜ, ਮਾਲ, ਮਹਲ-ਮਾੜੀਆਂ, ਦਰਬਾਰ ਲਾਉਣੇ (ਜੋ ਸੁਖ ਇਹਨਾਂ ਵਿਚ ਹਨ, ਨਾਮ ਸਿਮਰਨ ਵਾਲਿਆਂ ਨੂੰ ਉਹ ਸੁਖ ਨਾਮ-ਸਿਮਰਨ ਤੋਂ ਪ੍ਰਾਪਤ ਹੁੰਦੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "Царство, богатство, дворцы и собрания двора — все удовольствия, которые есть в этом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48450,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਤ ਨਾਮ ਪੂਰਨ ਆਚਾਰ ॥੩॥",
          "roman": "simrat nām pūran āchār ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰਿ-ਨਾਮ ਸਿਮਰਦਿਆਂ ਮਨੁੱਖ ਦਾ ਆਚਰਨ ਸੁੱਚਾ ਬਣ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "для помнящих Имя приходят через само памятование Имени, и поведение человека становится чистым ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48451,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਇਹੁ ਕੀਆ ਬੀਚਾਰੁ ॥",
          "roman": "nānak dās ihu kīā bīchār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦਾਸ ਨਾਨਕ ਨੇ ਇਹ ਨਿਸ਼ਚਾ ਕੀਤਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Слуга Нанак пришёл к такому убеждению,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48452,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਹਰਿ ਨਾਮ ਮਿਥਿਆ ਸਭ ਛਾਰੁ ॥੪॥੮॥",
          "roman": "bin har nām mithiā sabh chhār ॥4॥8॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਹੋਰ ਸਾਰੀ (ਮਾਇਆ) ਨਾਸਵੰਤ ਹੈ ਸੁਆਹ (ਦੇ ਤੁੱਲ) ਹੈ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "что без Имени Хари всё остальное ложно, тленно и подобно пеплу ॥4॥8॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4071,
      "rahao_verse_id": 48457,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48453,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48454,
          "is_rahao": false,
          "gurmukhi": "ਲੇਪੁ ਨ ਲਾਗੋ ਤਿਲ ਕਾ ਮੂਲਿ ॥",
          "roman": "lep na lāgo til kā mūl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਦੀ ਮਿਹਰ ਆਪਣੇ ਸੇਵਕ ਉੱਤੇ ਹੋਈ ਹੈ, ਬਾਲਕ (ਗੁਰੂ) ਹਰਿਗੋਬਿੰਦ ਉੱਤੇ ਉਸ ਦੁਸ਼ਟ ਦੀ ਮੰਦੀ ਕਰਤੂਤ ਦਾ) ਬਿਲਕੁਲ ਰਤਾ ਭਰ ਭੀ ਮਾੜਾ ਅਸਰ ਨਹੀਂ ਹੋ ਸਕਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Параматмы на Его слугу не смогло лечь ни малейшего дурного воздействия от злого поступка того нечестивца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48455,
          "is_rahao": false,
          "gurmukhi": "ਦੁਸਟੁ ਬ੍ਰਾਹਮਣੁ ਮੂਆ ਹੋਇ ਕੈ ਸੂਲ ॥੧॥",
          "roman": "dusṭ brāhmaṇ mūā hoi kē sūl ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਗੁਰੂ ਦੇ ਪਰਤਾਪ ਨਾਲ ਉਹ) ਚੰਦਰਾ ਬ੍ਰਾਹਮਣ (ਪੇਟ ਵਿਚ) ਸੂਲ ਉੱਠਣ ਨਾਲ ਮਰ ਗਿਆ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "а тот злой брахман умер от рези в животе ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48456,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਜਨ ਰਾਖੇ ਪਾਰਬ੍ਰਹਮਿ ਆਪਿ ॥",
          "roman": "har jan rākhe pārbrahm āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੇ ਆਪਣੇ ਸੇਵਕਾਂ ਦੀ ਰੱਖਿਆ (ਸਦਾ ਹੀ) ਆਪ ਕੀਤੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Парабрахм Сам всегда защищал Своих слуг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48457,
          "is_rahao": true,
          "gurmukhi": "ਪਾਪੀ ਮੂਆ ਗੁਰ ਪਰਤਾਪਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "pāpī mūā gur partāp ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖੋ, ਵਿਸਾਹ-ਘਾਤੀ ਬ੍ਰਾਹਮਣ) ਦੁਸ਼ਟ ਗੁਰੂ ਦੇ ਪਰਤਾਪ ਨਾਲ (ਆਪ ਹੀ) ਮਰ ਗਿਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Смотрите: этот грешник, предательский брахман, сам погиб от славы и силы Гуру ॥1॥ пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48458,
          "is_rahao": false,
          "gurmukhi": "ਅਪਣਾ ਖਸਮੁ ਜਨਿ ਆਪਿ ਧਿਆਇਆ ॥",
          "roman": "apṇā khasam jan āp dhiāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਨੇ ਆਪਣੇ ਸੇਵਕ ਦੀ ਆਪ ਰੱਖਿਆ ਕੀਤੀ ਹੈ, ਕਿਉਂਕਿ) ਸੇਵਕ ਨੇ ਆਪਣੇ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਸਦਾ ਆਪਣੇ ਹਿਰਦੇ ਵਿਚ ਵਸਾਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Слуга всегда держал в своём сердце своего Владыку-Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48459,
          "is_rahao": false,
          "gurmukhi": "ਇਆਣਾ ਪਾਪੀ ਓਹੁ ਆਪਿ ਪਚਾਇਆ ॥੨॥",
          "roman": "iāṇā pāpī ohu āp pachāiā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਬੇਸਮਝ ਦੁਸ਼ਟ (ਇਸ ਰੱਬੀ ਭੇਤ ਨੂੰ ਸਮਝ ਨਾਹ ਸਕਿਆ, ਤੇ ਪਰਮਾਤਮਾ ਨੇ) ਆਪ ਹੀ ਉਸ ਨੂੰ ਮਾਰ ਮੁਕਾਇਆ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "а тот неразумный злодей сам был Им погублен ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48460,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਮਾਤ ਪਿਤਾ ਅਪਣੇ ਦਾਸ ਕਾ ਰਖਵਾਲਾ ॥",
          "roman": "prabh māt pitā apṇe dās kā rakhvālā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਂ ਪਿਉ (ਵਾਂਗ) ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦਾ ਸਦਾ ਆਪ ਰਾਖਾ ਬਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь, как мать и отец, Сам всегда становится защитником Своего слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48461,
          "is_rahao": false,
          "gurmukhi": "ਨਿੰਦਕ ਕਾ ਮਾਥਾ ਈਹਾਂ ਊਹਾ ਕਾਲਾ ॥੩॥",
          "roman": "nindak kā māthā īhāṅ ūhā kālā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ ਪ੍ਰਭੂ ਦੇ ਸੇਵਕ ਦੇ) ਦੋਖੀ ਦਾ ਮੂੰਹ ਲੋਕ ਪਰਲੋਕ ਦੁਹੀਂ ਸਰਾਈਂ ਕਾਲਾ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "поэтому лицо клеветника слуги Божьего чёрно и здесь, и в ином мире ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48462,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਕੀ ਪਰਮੇਸਰਿ ਸੁਣੀ ਅਰਦਾਸਿ ॥",
          "roman": "jan nānak kī parmesar suṇī ardās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਆਖ-ਹੇ ਭਾਈ!) ਆਪਣੇ ਸੇਵਕ ਦੀ ਪਰਮੇਸਰ ਨੇ (ਸਦਾ ਹੀ) ਅਰਦਾਸ ਸੁਣੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Пармесар всегда слышал молитву Своего слуги,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48463,
          "is_rahao": false,
          "gurmukhi": "ਮਲੇਛੁ ਪਾਪੀ ਪਚਿਆ ਭਇਆ ਨਿਰਾਸੁ ॥੪॥੯॥",
          "roman": "malechh pāpī pachiā bhaiā nirās ॥4॥9॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਵੇਖੋ, ਪਰਮੇਸਰ ਦੇ ਸੇਵਕ ਉੱਤੇ ਵਾਰ ਕਰਨ ਵਾਲਾ) ਦੁਸ਼ਟ ਪਾਪੀ (ਆਪ ਹੀ) ਮਰ ਮਿਟਿਆ, ਤੇ, ਬੇ-ਮੁਰਾਦਾ ਹੀ ਰਿਹਾ ॥੪॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "и тот нечестивый злодей сам погиб и остался ни с чем ॥4॥9॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4072,
