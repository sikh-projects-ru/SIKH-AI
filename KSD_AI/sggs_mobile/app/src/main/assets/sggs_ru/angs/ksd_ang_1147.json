        },
        {
          "verse_id": 48988,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਥਮੇ ਛੋਡੀ ਪਰਾਈ ਨਿੰਦਾ ॥",
          "roman": "prathme chhoḍī parāī nindā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਅਸਲ ਵੈਸ਼ਨਵ) ਸਭ ਤੋਂ ਪਹਿਲਾਂ ਦੂਜਿਆਂ ਦੇ ਐਬ ਲੱਭਣੇ ਛੱਡ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Настоящий вайшнав прежде всего перестаёт выискивать чужие недостатки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48989,
          "is_rahao": false,
          "gurmukhi": "ਉਤਰਿ ਗਈ ਸਭ ਮਨ ਕੀ ਚਿੰਦਾ ॥",
          "roman": "utar gaī sabh man kī chindā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਆਪਣੇ) ਮਨ ਦੀ ਸਾਰੀ ਚਿੰਤਾ ਲਹਿ ਜਾਂਦੀ ਹੈ (ਮਨ ਤੋਂ ਵਿਕਾਰਾਂ ਦਾ ਚਿੰਤਨ ਲਹਿ ਜਾਂਦਾ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Тогда вся тревога его собственного ума уходит, из ума уходит размышление о пороках,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48990,
          "is_rahao": false,
          "gurmukhi": "ਲੋਭੁ ਮੋਹੁ ਸਭੁ ਕੀਨੋ ਦੂਰਿ ॥",
          "roman": "lobh moh sabh kīno dūr ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਆਪਣੇ ਅੰਦਰੋਂ) ਲੋਭ ਅਤੇ ਮੋਹ ਸਾਰੇ ਦਾ ਸਾਰਾ ਦੂਰ ਕਰ ਦੇਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такой человек полностью удаляет изнутри себя жадность и привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48991,
          "is_rahao": false,
          "gurmukhi": "ਪਰਮ ਬੈਸਨੋ ਪ੍ਰਭ ਪੇਖਿ ਹਜੂਰਿ ॥੧॥",
          "roman": "param bēsno prabh pekh hajūr ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਨੂੰ ਅੰਗ-ਸੰਗ ਵੱਸਦਾ ਵੇਖ ਕੇ (ਮਨੁੱਖ) ਸਭ ਤੋਂ ਉੱਚਾ ਵੈਸ਼ਨਵ ਬਣ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Увидев Параматму пребывающим рядом, человек становится высочайшим вайшнавом ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48992,
          "is_rahao": true,
          "gurmukhi": "ਐਸੋ ਤਿਆਗੀ ਵਿਰਲਾ ਕੋਇ ॥",
          "roman": "aiso tiāgī virlā koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹੋ ਜਿਹਾ ਵੈਸ਼ਨਵ ਹੀ ਅਸਲ ਤਿਆਗੀ ਹੈ, ਪਰ) ਇਹੋ ਜਿਹਾ ਤਿਆਗੀ (ਜਗਤ ਵਿਚ) ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਹੀ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Такой вайшнав и есть истинный отречённый, но такой отречённый человек в мире встречается редко,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48993,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਜਪੈ ਜਨੁ ਸੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "har har nām japē jan soi ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਮਨੁੱਖ (ਸਹੀ ਅਰਥਾਂ ਵਿਚ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Именно такой человек в подлинном смысле повторяет Имя Параматмы ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48994,
          "is_rahao": false,
          "gurmukhi": "ਅਹੰਬੁਧਿ ਕਾ ਛੋਡਿਆ ਸੰਗੁ ॥",
          "roman": "ahaṃbudh kā chhoḍiā saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਨੂੰ ਹਾਜ਼ਰ-ਨਾਜ਼ਰ ਵੇਖ ਕੇ ਅਸਲ ਵੈਸ਼ਨਵ ਬਣ ਜਾਂਦਾ ਹੈ, ਉਹ) ਅਹੰਕਾਰ ਦਾ ਸਾਥ ਛੱਡ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто, увидев Параматму присутствующим, стал истинным вайшнавом, оставляет общество эгоизма,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48995,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਕਾ ਉਤਰਿਆ ਰੰਗੁ ॥",
          "roman": "kām krodh kā utriā raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਮਨ ਤੋਂ) ਕਾਮ ਅਤੇ ਕ੍ਰੋਧ ਦਾ ਅਸਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из его ума исчезает влияние страсти и гнева,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48996,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਧਿਆਏ ਹਰਿ ਹਰਿ ਹਰੇ ॥",
          "roman": "nām dhiāe har har hare ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такой человек всегда созерцает Имя Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48997,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧ ਜਨਾ ਕੈ ਸੰਗਿ ਨਿਸਤਰੇ ॥੨॥",
          "roman": "sādh janā kē saṅg nistare ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜਿਹੇ ਮਨੁੱਖ ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Такие люди, пребывая в са̄дх сангат, переправляются через океан мира ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48998,
          "is_rahao": false,
          "gurmukhi": "ਬੈਰੀ ਮੀਤ ਹੋਏ ਸੰਮਾਨ ॥",
          "roman": "bērī mīt hoe sammān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਵੈਰੀ ਅਤੇ ਮਿੱਤਰ ਇੱਕੋ ਜਿਹੇ (ਮਿੱਤਰ ਹੀ) ਦਿੱਸਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Для него враг и друг становятся одинаковыми, все видятся как друзья,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48999,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਮਹਿ ਪੂਰਨ ਭਗਵਾਨ ॥",
          "roman": "sarab mah pūran bhagvān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਭਗਵਾਨ ਸਭ ਜੀਵਾਂ ਵਿਚ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он видит Бхагвана присутствующим во всех существах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49000,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਆਗਿਆ ਮਾਨਿ ਸੁਖੁ ਪਾਇਆ ॥",
          "roman": "prabh kī āgiā mān sukh pāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੇ ਪਰਮਾਤਮਾ ਦੀ ਰਜ਼ਾ ਨੂੰ ਮਿੱਠਾ ਜਾਣ ਕੇ ਸਦਾ ਆਤਮਕ ਆਨੰਦ ਮਾਣਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Он, приняв волю Параматмы как сладкую, всегда вкушал духовную радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49001,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਹਰਿ ਨਾਮੁ ਦ੍ਰਿੜਾਇਆ ॥੩॥",
          "roman": "gur pūrē har nām driṛāiā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਹਿਰਦੇ ਵਿਚ ਪੂਰੇ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਪੱਕੇ ਤੌਰ ਤੇ ਟਿਕਾ ਦਿੱਤਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, в чьём сердце совершенный Гуру прочно утвердил Имя Параматмы ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49002,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਰਾਖੈ ਆਪਿ ॥",
          "roman": "kar kirpā jis rākhē āp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਆਪਣੀ ਮਿਹਰ ਕਰ ਕੇ ਜਿਸ ਮਨੁੱਖ ਦੀ ਆਪ ਰੱਖਿਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, которого Параматма по Своей милости Сам хранит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49003,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਭਗਤੁ ਜਪੈ ਨਾਮ ਜਾਪ ॥",
          "roman": "soī bhagat japē nām jāp ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹੀ ਹੈ ਅਸਲ ਭਗਤ, ਉਹੀ ਉਸ ਦੇ ਨਾਮ ਦਾ ਜਾਪ ਜਪਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только он и есть истинный бхагат, только он повторяет джап Его Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49004,
          "is_rahao": false,
          "gurmukhi": "ਮਨਿ ਪ੍ਰਗਾਸੁ ਗੁਰ ਤੇ ਮਤਿ ਲਈ ॥",
          "roman": "man pragās gur te mat laī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਪਾਸੋਂ (ਜੀਵਨ-ਜੁਗਤਿ ਦੀ) ਸਿੱਖਿਆ ਲੈ ਲਈ ਉਸ ਦੇ ਮਨ ਵਿਚ (ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦਾ) ਚਾਨਣ ਹੋ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто принял у Гуру наставление о пути жизни, в уме обретает свет понимания духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49005,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤਾ ਕੀ ਪੂਰੀ ਪਈ ॥੪॥੨੭॥੪੦॥",
          "roman": "kah Nānak tā kī pūrī paī ॥4॥27॥40॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਉਸ ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਕਾਮਯਾਬ ਹੋ ਗਈ ॥੪॥੨੭॥੪੦॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: жизнь такого человека стала успешной ॥4॥27॥40॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4103,
      "rahao_verse_id": 49012,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49006,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49007,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਹੀ ਬਹੁਤੈ ਧਨਿ ਖਾਟੇ ॥",
          "roman": "sukh nāhī bahutē dhan khāṭe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤਾ ਧਨ ਖੱਟਣ ਨਾਲ (ਆਤਮਕ) ਆਨੰਦ ਨਹੀਂ ਮਿਲਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "От накопления большого богатства не приходит духовная радость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49008,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਹੀ ਪੇਖੇ ਨਿਰਤਿ ਨਾਟੇ ॥",
          "roman": "sukh nāhī pekhe nirat nāṭe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਟਕਾਂ ਦੇ ਨਾਚ ਵੇਖਿਆਂ ਭੀ ਆਤਮਕ ਆਨੰਦ ਨਹੀਂ ਪ੍ਰਾਪਤ ਹੁੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "И от созерцания танцев и представлений тоже не обретается духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49009,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਹੀ ਬਹੁ ਦੇਸ ਕਮਾਏ ॥",
          "roman": "sukh nāhī bah des kamāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਹੁਤੇ ਦੇਸ ਜਿੱਤ ਲੈਣ ਨਾਲ ਭੀ ਸੁਖ ਨਹੀਂ ਮਿਲਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "И от завоевания многих стран счастье тоже не приходит."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49010,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਹਰਿ ਹਰਿ ਗੁਣ ਗਾਏ ॥੧॥",
          "roman": "sarab sukhā har har guṇ gāe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ, ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕੀਤਿਆਂ ਸਾਰੇ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но, воспевая хвалу Параматме, получают все радости ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49011,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਲਹਹੁ ॥",
          "roman": "sūkh sahaj ānand lahah ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤ ਵਿਚ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸੁਖ ਆਨੰਦ ਮਾਣੋ,"
            },
            "sahib_singh_ru": {
              "main": "Вкушайте радость и покой духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49012,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਪਾਈਐ ਵਡਭਾਗੀ ਗੁਰਮੁਖਿ ਹਰਿ ਹਰਿ ਨਾਮੁ ਕਹਹੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhsangat pāīai vaḍbhāgī gurmukh har har nām kahah ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਹੀ ਸਾਧ ਸੰਗਤ ਮਿਲਦੀ ਹੈ। ਹੇ ਭਾਈ! ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Но только великой удачей обретается са̄дх сангат. О брат! Припав к защите Гуру, всегда повторяй Имя Параматмы ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49013,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਮਾਤ ਪਿਤਾ ਸੁਤ ਬਨਿਤਾ ॥",
          "roman": "bandhan māt pitā sut banitā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਂ, ਪਿਉ, ਪੁੱਤਰ, ਇਸਤ੍ਰੀ (ਆਦਿਕ ਸੰਬੰਧੀ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਫਾਹੀਆਂ ਪਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Мать, отец, сын, жена и прочие родственники накладывают путы привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49014,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਰਮ ਧਰਮ ਹਉ ਕਰਤਾ ॥",
          "roman": "bandhan karam dharam hau kartā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ ਆਦਿਕ ਮਿਥੇ ਹੋਏ) ਧਾਰਮਿਕ ਕਰਮ ਭੀ ਫਾਹੀਆਂ ਪੈਦਾ ਕਰਦੇ ਹਨ (ਕਿਉਂਕਿ ਇਹਨਾਂ ਦੇ ਕਾਰਨ ਮਨੁੱਖ) ਅਹੰਕਾਰ ਕਰਦਾ ਹੈ (ਕਿ ਮੈਂ ਤੀਰਥ-ਜਾਤ੍ਰਾ ਆਦਿਕ ਕਰਮ ਕੀਤੇ ਹਨ)।"
            },
            "sahib_singh_ru": {
              "main": "И предписанные религиозные дела, вроде паломничеств, тоже создают путы, потому что из-за них человек впадает в эгоизм, думая, что это он совершил паломничества и прочие действия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49015,
          "is_rahao": false,
          "gurmukhi": "ਬੰਧਨ ਕਾਟਨਹਾਰੁ ਮਨਿ ਵਸੈ ॥",
          "roman": "bandhan kāṭanhār man vasē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜਦੋਂ ਇਹ ਫਾਹੀਆਂ ਕੱਟ ਸਕਣ ਵਾਲਾ ਪਰਮਾਤਮਾ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Но когда в уме человека поселяется Параматма, способный разрезать эти путы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49016,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਸੁਖੁ ਪਾਵੈ ਨਿਜ ਘਰਿ ਬਸੈ ॥੨॥",
          "roman": "tau sukh pāvē nij ghar basē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦੋਂ (ਮਾਂ ਪਿਉ ਪੁੱਤਰ ਇਸਤ੍ਰੀ ਆਦਿਕ ਸੰਬੰਧੀਆਂ ਵਿਚ ਰਹਿੰਦਾ ਹੋਇਆ ਹੀ) ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ (ਕਿਉਂਕਿ ਤਦੋਂ ਮਨੁੱਖ) ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜਿਆ ਰਹਿੰਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда он вкушает духовную радость, даже живя среди матери, отца, сына, жены и прочих родственников, потому что тогда человек остаётся связанным с стопами Параматмы ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49017,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜਾਚਿਕ ਪ੍ਰਭ ਦੇਵਨਹਾਰ ॥",
          "roman": "sabh jāchik prabh devanhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੇ ਜੀਵ ਸਭ ਕੁਝ ਦੇ ਸਕਣ ਵਾਲੇ ਪ੍ਰਭੂ (ਦੇ ਦਰ) ਦੇ (ਹੀ) ਮੰਗਤੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Все существа — лишь просители у Прабху, Который может дать всё,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49018,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਨਿਧਾਨ ਬੇਅੰਤ ਅਪਾਰ ॥",
          "roman": "guṇ nidhān beaṅt apār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਸਾਰੇ ਗੁਣਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ, ਬੇਅੰਤ ਹੈ, ਉਸ ਦੀ ਹਸਤੀ ਦਾ ਪਾਰਲਾ ਬੰਨਾ ਨਹੀਂ ਲੱਭ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Параматма — сокровищница всех качеств, Он безграничен, и невозможно найти предел Его бытия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49019,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸ ਨੋ ਕਰਮੁ ਕਰੇ ਪ੍ਰਭੁ ਅਪਨਾ ॥",
          "roman": "jis no karam kre prabh apnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਪਿਆਰਾ ਪ੍ਰਭੂ ਬਖ਼ਸ਼ਸ਼ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, на которого возлюбленный Прабху изливает милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49020,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਨਾਮੁ ਤਿਨੈ ਜਨਿ ਜਪਨਾ ॥੩॥",
          "roman": "har har nām tinē jan japnā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸੇ ਹੀ ਮਨੁੱਖ ਨੇ ਸਦਾ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Только тот человек и повторял всегда Имя Параматмы ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49021,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਅਪਨੇ ਆਗੈ ਅਰਦਾਸਿ ॥",
          "roman": "gur apne āgē ardās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਗੁਰੂ ਦੇ ਦਰ ਤੇ (ਸਦਾ) ਅਰਜ਼ੋਈ ਕਰਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "У дверей своего Гуру всегда возноси молитву,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49022,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਪੁਰਖ ਗੁਣਤਾਸਿ ॥",
          "roman": "kar kirpā purakh guṇtās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਆਖਦਾ ਰਹੁ- ਹੇ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਮਾਲਕ! ਹੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਅਕਾਲ ਪੁਰਖ! ਮਿਹਰ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "И продолжай говорить: о Владыка творения! О сокровищница качеств, Акал Пуракх! Прояви милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49023,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਤੁਮਰੀ ਸਰਣਾਈ ॥",
          "roman": "kah Nānak tumrī saraṇāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ-  ਮੈਂ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: я пришёл в Твоё прибежище,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49024,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਖਹੁ ਗੁਸਾਈ ॥੪॥੨੮॥੪੧॥",
          "roman": "jiu bhāvē tiu rakhah gusāī ॥4॥28॥41॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਤੇਰੀ ਰਜ਼ਾ ਹੈ ਤਿਵੇਂ ਮੈਨੂੰ (ਆਪਣੇ ਚਰਨਾਂ ਵਿਚ) ਰੱਖ ॥੪॥੨੮॥੪੧॥"
            },
            "sahib_singh_ru": {
              "main": "Какова Твоя воля, так и удержи меня у Своих стоп ॥4॥28॥41॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4104,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49025,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49026,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਤਿਆਗਿਓ ਦੂਜਾ ਭਾਉ ॥",
          "roman": "gur mil tiāgio dūjā bhāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਆਪਣੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦਾ ਮੋਹ ਛੱਡ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, встретив Гуру, отбросил изнутри себя привязанность к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
