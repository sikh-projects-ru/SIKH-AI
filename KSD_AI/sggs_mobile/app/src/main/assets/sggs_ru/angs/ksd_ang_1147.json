  "shabads": [
    {
      "shabad_id": 4100,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48967,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਨਾਨਕ ਸੁਖੁ ਪਾਏ ॥੪॥੨੫॥੩੮॥",
          "roman": "kar kirpā Nānak sukh pāe ॥4॥25॥38॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਮਿਹਰ ਕਰ ਕੇ (ਜਿਸ ਨੂੰ ਤੂੰ ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ਦਾ ਹੈਂ, ਉਹ ਮਨੁੱਖ) ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ ॥੪॥੨੫॥੩੮॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! По милости Его тот человек, которому Ты даруешь Своё Имя, вкушает духовную радость ॥4॥25॥38॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4101,
      "rahao_verse_id": 48974,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 48968,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48969,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਰਹਾ ਕਲਿ ਮਾਹਿ ॥",
          "roman": "terī ṭek rahā kal māh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਸ ਵਿਕਾਰ-ਭਰੇ ਜਗਤ ਵਿਚ ਮੈਂ ਤੇਰੇ ਆਸਰੇ ਹੀ ਜੀਊਂਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! В этом полном пороков мире я живу только опираясь на Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48970,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਤੇਰੇ ਗੁਣ ਗਾਹਿ ॥",
          "roman": "terī ṭek tere guṇ gāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਸਭ ਜੀਵ) ਤੇਰੇ ਹੀ ਸਹਾਰੇ ਹਨ, ਤੇਰੇ ਹੀ ਗੁਣ ਗਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Все существа держатся только Тобой и поют только Твои качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48971,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਨ ਪੋਹੈ ਕਾਲੁ ॥",
          "roman": "terī ṭek na pohē kāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਤੇਰਾ ਆਸਰਾ ਹੈ ਉਸ ਉਤੇ ਆਤਮਕ ਮੌਤ ਆਪਣਾ ਪ੍ਰਭਾਵ ਨਹੀਂ ਪਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! На человека, у которого есть Твоя опора, духовная смерть не может оказать своего действия."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48972,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਬਿਨਸੈ ਜੰਜਾਲੁ ॥੧॥",
          "roman": "terī ṭek binasē janjāl ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਆਸਰੇ (ਮਨੁੱਖ ਦੀ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਫਾਹੀ ਟੁੱਟ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "С Твоей опорой разрушается петля привязанности к майе ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48973,
          "is_rahao": true,
          "gurmukhi": "ਦੀਨ ਦੁਨੀਆ ਤੇਰੀ ਟੇਕ ॥",
          "roman": "dīn dunīā terī ṭek ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ (ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ) ਤੇਰਾ ਹੀ ਸਹਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! В этом мире и в ином мире у нас, существ, опора только Ты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48974,
          "is_rahao": true,
          "gurmukhi": "ਸਭ ਮਹਿ ਰਵਿਆ ਸਾਹਿਬੁ ਏਕ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sabh mahi raviā sāhib ek ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਵਿਚ ਮਾਲਕ-ਪ੍ਰਭੂ ਹੀ ਵਿਆਪਕ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Во всём творении пронизывает всё один Владыка-Прабху ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48975,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਕਰਉ ਆਨੰਦ ॥",
          "roman": "terī ṭek karau ānand ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੇ ਨਾਮ ਦਾ ਆਸਰਾ ਲੈ ਕੇ ਹੀ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹਾਂ"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Я вкушаю духовную радость, лишь приняв опору Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48976,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਜਪਉ ਗੁਰ ਮੰਤ ॥",
          "roman": "terī ṭek japau gur mant ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਤੇਰੇ ਨਾਮ ਦੇ ਆਸਰਾ ਲੈ ਕੇ ਹੀ ਗੁਰੂ ਦਾ ਦਿੱਤਾ ਹੋਇਆ ਤੇਰਾ ਨਾਮ-ਮੰਤ੍ਰ ਜਪਦਾ ਰਹਿੰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "И, опираясь на Твоё Имя, я продолжаю повторять данный Гуру Твой мантр-Нам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48977,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਤਰੀਐ ਭਉ ਸਾਗਰੁ ॥",
          "roman": "terī ṭek tarīai bhau sāgar ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ (ਨਾਮ ਦੇ) ਸਹਾਰੇ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਈਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! С опорой на Тебя, на Твоё Имя, переплывают океан мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48978,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਣਹਾਰੁ ਪੂਰਾ ਸੁਖ ਸਾਗਰੁ ॥੨॥",
          "roman": "rākhaṇhār pūrā sukh sāgar ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭ ਦੀ ਰੱਖਿਆ ਕਰਨ ਦੇ ਸਮਰੱਥ ਹੈਂ, ਤੂੰ ਸਾਰੇ ਸੁਖਾਂ ਦਾ (ਮਾਨੋ) ਸਮੁੰਦਰ ਹੈਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Ты способен защитить всех, Ты словно океан всех благ и радостей ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48979,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਨਾਹੀ ਭਉ ਕੋਇ ॥",
          "roman": "terī ṭek nāhī bhau koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਜਿਸ ਨੂੰ ਤੇਰੇ ਨਾਮ ਦਾ ਆਸਰਾ ਹੈ ਉਸ ਨੂੰ ਕੋਈ ਡਰ ਵਿਆਪ ਨਹੀਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Того, у кого есть опора Твоего Имени, не может охватить никакой страх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48980,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਜਾਮੀ ਸਾਚਾ ਸੋਇ ॥",
          "roman": "antarjāmī sāchā soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਪ੍ਰਭੂ ਹੀ ਸਭ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Этот вечно пребывающий Прабху и есть Знающий сердца всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48981,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਤੇਰਾ ਮਨਿ ਤਾਣੁ ॥",
          "roman": "terī ṭek terā man tāṇ ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਭ ਜੀਵਾਂ ਨੂੰ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ, ਸਭ ਦੇ ਮਨ ਵਿਚ ਤੇਰੇ ਨਾਮ ਦਾ ਹੀ ਸਹਾਰਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! У всех существ опора только Ты, в уме у всех поддержка только Твоего Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48982,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾਂ ਊਹਾਂ ਤੂ ਦੀਬਾਣੁ ॥੩॥",
          "roman": "īhāṅ ūhāṅ tū dībāṇ ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਲੋਕ ਤੇ ਪਰਲੋਕ ਵਿਚ ਤੂੰ ਹੀ ਜੀਵਾਂ ਦਾ ਆਸਰਾ ਹੈਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В этом мире и в ином мире Ты один — опора существ ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48983,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੀ ਟੇਕ ਤੇਰਾ ਭਰਵਾਸਾ ॥",
          "roman": "terī ṭek terā bharvāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਅਸਾਂ ਜੀਵਾਂ ਨੂੰ) ਤੇਰੀ ਹੀ ਟੇਕ ਹੈ ਤੇਰਾ ਹੀ ਆਸਰਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! У нас, существ, только Твоя опора и только Твоя надежда,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48984,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਧਿਆਵਹਿ ਪ੍ਰਭ ਗੁਣਤਾਸਾ ॥",
          "roman": "sagal dhiāvah prabh guṇtāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ! ਸਭ ਜੀਵ ਤੇਰਾ ਹੀ ਧਿਆਨ ਧਰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху, сокровищница качеств! Все существа сосредотачиваются только на Тебе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48985,
          "is_rahao": false,
          "gurmukhi": "ਜਪਿ ਜਪਿ ਅਨਦੁ ਕਰਹਿ ਤੇਰੇ ਦਾਸਾ ॥",
          "roman": "jap jap anad kareh tere dāsā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਦਾਸ ਤੇਰਾ ਨਾਮ ਜਪ ਜਪ ਕੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Твои слуги, повторяя и повторяя Твоё Имя, вкушают духовную радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 48986,
          "is_rahao": false,
          "gurmukhi": "ਸਿਮਰਿ ਨਾਨਕ ਸਾਚੇ ਗੁਣਤਾਸਾ ॥੪॥੨੬॥੩੯॥",
          "roman": "simar Nānak sāche guṇtāsā ॥4॥26॥39॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਤੂੰ ਭੀ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਅਤੇ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਿਆ ਕਰ ॥੪॥੨੬॥੩੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! И ты тоже помни Имя вечно пребывающего Прабху, сокровищницы качеств ॥4॥26॥39॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
