{
  "ang": 1148,
  "shabads": [
    {
      "shabad_id": 4104,
      "rahao_verse_id": 49031,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49027,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਮੁਖਿ ਜਪਿਓ ਹਰਿ ਕਾ ਨਾਉ ॥",
          "roman": "gurmukh japiō har kā nāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਣਾ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, припав к защите Гуру, начал повторять Имя Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49028,
          "is_rahao": false,
          "gurmukhi": "ਬਿਸਰੀ ਚਿੰਤ ਨਾਮਿ ਰੰਗੁ ਲਾਗਾ ॥",
          "roman": "bisrī chint nām raṅg lāgā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਮਨ ਦੀ) ਚਿੰਤਾ ਮੁੱਕ ਗਈ, ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਉਸ ਦਾ ਪਿਆਰ ਬਣ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тревога его ума исчезла, и в Имени Параматмы у него возникла любовь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49029,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕਾ ਸੋਇਆ ਜਾਗਾ ॥੧॥",
          "roman": "janam janam kā soiā jāgā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਨੇਕਾਂ ਜਨਮਾਂ ਦਾ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਨੀਂਦ ਵਿਚ ਸੁੱਤਾ ਹੋਇਆ ਹੁਣ ਉਹ ਜਾਗ ਪਿਆ (ਉਸ ਨੂੰ ਜੀਵਨ-ਜੁਗਤਿ ਦੀ ਸਮਝ ਆ ਗਈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Спавший многие рождения в сне привязанности к майе, теперь он пробудился, у него появилось понимание пути жизни ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49030,
          "is_rahao": true,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪਨੀ ਸੇਵਾ ਲਾਏ ॥",
          "roman": "kar kirpā apnī sevā lāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਪਰਮਾਤਮਾ (ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Того человека, которого Параматма по милости присоединяет к Своему служению и бхакти,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49031,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧੂ ਸੰਗਿ ਸਰਬ ਸੁਖ ਪਾਏ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhū saṅg sarab sukh pāe ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ ਟਿਕ ਕੇ ਸਾਰੇ ਆਤਮਕ ਆਨੰਦ ਮਾਣਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Такой человек, пребывая в сангате садху, вкушает все духовные радости ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49032,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗ ਦੋਖ ਗੁਰ ਸਬਦਿ ਨਿਵਾਰੇ ॥",
          "roman": "rog dokh gur sabad nivāre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਗੁਰੂ ਨੂੰ ਮਿਲ ਕੇ (ਆਪਣੇ ਮਨ ਵਿਚੋਂ) ਰੋਗ ਅਤੇ ਵਿਕਾਰ ਦੂਰ ਕਰ ਲਏ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто, встретив Гуру, удалил из своего ума болезни и пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49033,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਅਉਖਧੁ ਮਨ ਭੀਤਰਿ ਸਾਰੇ ॥",
          "roman": "nām aukhadh man bhītar sāre ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਨਾਮ-ਦਾਰੂ ਆਪਣੇ ਮਨ ਵਿਚ ਸਾਂਭ ਕੇ ਰੱਖਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто хранит в своём уме лекарство-Нам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49034,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਭੇਟਤ ਮਨਿ ਭਇਆ ਅਨੰਦ ॥",
          "roman": "gur bheṭat man bhaiā anand ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੂੰ ਮਿਲਿਆਂ ਉਸ ਦੇ ਮਨ ਵਿਚ ਆਨੰਦ ਬਣ ਆਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "При встрече с Гуру в его уме возникает радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49035,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਨਿਧਾਨ ਨਾਮ ਭਗਵੰਤ ॥੨॥",
          "roman": "sarab nidhān nām bhagvant ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਵਾਨ ਦਾ ਨਾਮ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਖ਼ਜ਼ਾਨਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Имя Бхагвана — сокровищница всех радостей ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49036,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਣ ਕੀ ਮਿਟੀ ਜਮ ਤ੍ਰਾਸ ॥",
          "roman": "janam maraṇ kī miṭī jam trās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਿਹਰ ਕਰ ਕੇ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈ, ਉਸ ਦੇ ਮਨ ਵਿਚੋਂ) ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦਾ ਸਹਿਮ ਜਮ-ਰਾਜ ਦਾ ਡਰ ਮਿਟ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У того, кого Прабху по милости присоединяет к Своему служению и бхакти, из ума исчезает страх круга рождения и смерти, страх перед Джам-раджем,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49037,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਊਂਧ ਕਮਲ ਬਿਗਾਸ ॥",
          "roman": "sādhsangat ūṅdh kamal bigās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਦੀ ਬਰਕਤਿ ਨਾਲ ਉਸ ਦਾ (ਪਹਿਲਾਂ ਮਾਇਆ ਦੇ ਮੋਹ ਵਲ) ਉਲਟਿਆ ਹੋਇਆ ਹਿਰਦਾ-ਕਮਲ ਖਿੜ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Благодаря са̄дх сангат его сердце-лотос, прежде обращённое к привязанности к майе, распускается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49038,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵਤ ਨਿਹਚਲੁ ਬਿਸ੍ਰਾਮ ॥",
          "roman": "guṇ gāvat nihchal bisrām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ (ਉਸ ਨੂੰ ਉਹ ਆਤਮਕ) ਟਿਕਾਣਾ (ਮਿਲ ਜਾਂਦਾ ਹੈ ਜਿਹੜਾ ਮਾਇਆ ਦੇ ਹੱਲਿਆਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਅਡੋਲ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Воспевая качества Параматмы, он обретает то духовное пристанище, которое остаётся недвижимым перед натиском майи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49039,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਹੋਏ ਸਗਲੇ ਕਾਮ ॥੩॥",
          "roman": "pūran hoe sagle kām ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਕੰਮ ਸਿਰੇ ਚੜ੍ਹ ਜਾਂਦੇ ਹਨ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "И все его дела приходят к завершению ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49040,
          "is_rahao": false,
          "gurmukhi": "ਦੁਲਭ ਦੇਹ ਆਈ ਪਰਵਾਨੁ ॥",
          "roman": "dulabh deh āī parvān ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਿਹਰ ਕਰ ਕੇ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਜੋੜਦਾ ਹੈ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਦਾ ਜਪ ਕੇ ਉਸ ਦਾ ਇਹ ਦੁਰਲੱਭ ਸਰੀਰ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਕਬੂਲ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кого Прабху по милости присоединяет к Своему служению и бхакти, постоянно повторяя Имя Параматмы, делает это редкое тело принятым в этом и ином мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49041,
          "is_rahao": false,
          "gurmukhi": "ਸਫਲ ਹੋਈ ਜਪਿ ਹਰਿ ਹਰਿ ਨਾਮੁ ॥",
          "roman": "safal hoī jap har har nām ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਕਾਇਆ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪ ਕੇ ਕਾਮਯਾਬ ਹੋ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его тело, повторяя Имя Параматмы, становится успешным."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49042,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਪ੍ਰਭਿ ਕਿਰਪਾ ਕਰੀ ॥",
          "roman": "kah Nānak prabh kirpā karī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਪ੍ਰਭੂ ਨੇ (ਮੇਰੇ ਉੱਤੇ) ਮਿਹਰ ਕੀਤੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: Прабху оказал мне милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49043,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਗਿਰਾਸਿ ਜਪਉ ਹਰਿ ਹਰੀ ॥੪॥੨੯॥੪੨॥",
          "roman": "sās girās japau har harī ॥4॥29॥42॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਭੀ ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ ਹਰੇਕ ਗਿਰਾਹੀ ਦੇ ਨਾਲ ਉਸ ਦਾ ਨਾਮ ਜਪ ਰਿਹਾ ਹਾਂ ॥੪॥੨੯॥੪੨॥"
            },
            "sahib_singh_ru": {
              "main": "И я тоже с каждым дыханием и с каждым куском пищи повторяю Его Имя ॥4॥29॥42॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4105,
      "rahao_verse_id": 49050,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49044,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49045,
          "is_rahao": false,
          "gurmukhi": "ਸਭ ਤੇ ਊਚਾ ਜਾ ਕਾ ਨਾਉ ॥",
          "roman": "sabh tē ūchā jā kā nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮਣਾ ਸਭ ਨਾਲੋਂ ਉੱਚਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Того — выше всего."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49046,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਸਦਾ ਤਾ ਕੇ ਗੁਣ ਗਾਉ ॥",
          "roman": "sadā sadā tā kē guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਦਾ ਹੀ ਉਸ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда, всегда пой Его достоинства."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49047,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਸਗਲਾ ਦੁਖੁ ਜਾਇ ॥",
          "roman": "jis simrat saglā dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਸਿਮਰਨ ਕਰਦਿਆਂ ਸਾਰਾ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "При памятовании о Ком уходит всякая боль,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49048,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਸੂਖ ਵਸਹਿ ਮਨਿ ਆਇ ॥੧॥",
          "roman": "sarab sūkh vaseh man āi ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਸਾਰੇ ਆਨੰਦ ਮਨ ਵਿਚ ਆ ਵੱਸਦੇ ਹਨ (ਉਸ ਦੇ ਗੁਣ ਗਾ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и все радости поселяются в сердце. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49049,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਿ ਮਨਾ ਤੂ ਸਾਚਾ ਸੋਇ ॥",
          "roman": "simar manā tū sāchā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ (ਮੇਰੇ) ਮਨ! ਤੂੰ ਉਸ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪਰਮਾਤਮਾ ਨੂੰ ਹੀ ਸਿਮਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, помни только Того, Кто вечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49050,
          "is_rahao": true,
          "gurmukhi": "ਹਲਤਿ ਪਲਤਿ ਤੁਮਰੀ ਗਤਿ ਹੋਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "halat palat tumrī gat hoi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ) ਇਸ ਲੋਕ ਅਤੇ ਪਰਲੋਕ ਵਿਚ ਤੇਰੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਬਣੀ ਰਹੇਗੀ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда и в этом мире, и в ином твоя духовная участь будет высокой. ||1|| Рахау ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49051,
          "is_rahao": false,
          "gurmukhi": "ਪੁਰਖ ਨਿਰੰਜਨ ਸਿਰਜਨਹਾਰ ॥",
          "roman": "purakh nirañjan sirjanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! (ਤੂੰ ਉਸ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਿਆ ਕਰ) ਜੋ ਸਰਬ-ਵਿਆਪਕ ਹੈ, ਜੋ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀ ਕਾਲਖ ਤੋਂ ਰਹਿਤ ਹੈ, ਜੋ ਸਭ ਨੂੰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум, помни Того вечного Господа, Который вездесущ, не запятнан скверной майи и является Творцом всего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49052,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਜੰਤ ਦੇਵੈ ਆਹਾਰ ॥",
          "roman": "jīa jant dēvē āhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਸਭ ਜੀਵਾਂ ਨੂੰ ਖਾਣ ਲਈ ਖ਼ੁਰਾਕ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Который даёт пищу всем существам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49053,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਖਤੇ ਖਿਨ ਬਖਸਨਹਾਰ ॥",
          "roman": "koṭ khatē khin bakhsanhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ (ਜੀਵਾਂ ਦੇ) ਕ੍ਰੋੜਾਂ ਪਾਪ ਇਕ ਖਿਨ ਵਿਚ ਬਖ਼ਸ਼ ਸਕਣ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Который способен в одно мгновение простить миллионы грехов,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49054,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਭਾਇ ਸਦਾ ਨਿਸਤਾਰ ॥੨॥",
          "roman": "bhagat bhāi sadā nistār ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਉਹਨਾਂ ਜੀਵਾਂ ਨੂੰ ਸਦਾ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘਾ ਦੇਂਦਾ ਹੈ ਜਿਹੜੇ ਪ੍ਰੇਮ ਵਿਚ ਟਿਕ ਕੇ ਉਸ ਦੀ ਭਗਤੀ ਕਰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Который всегда переправляет через мирской океан тех, кто пребывает в любви и преданности к Нему. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49055,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਾ ਧਨੁ ਸਾਚੀ ਵਡਿਆਈ ॥",
          "roman": "sāchā dhan sāchī vaḍiāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਨਾਮ-ਧਨ ਲੱਭ ਪਿਆ, ਉਸ ਨੂੰ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੀ (ਲੋਕ ਪਰਲੋਕ ਦੀ) ਸੋਭਾ ਮਿਲ ਗਈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек обретает вечное богатство Имени, и ему достаётся непреходящая слава и здесь, и в ином мире,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49056,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਤੇ ਨਿਹਚਲ ਮਤਿ ਪਾਈ ॥",
          "roman": "gur pūrē tē nihchal mat pāī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਪੂਰੇ ਗੁਰੂ ਪਾਸੋਂ ਵਿਕਾਰਾਂ ਵਲੋਂ ਅਡੋਲ ਰਹਿਣ ਵਾਲੀ ਸਿਮਰਨ ਦੀ ਮੱਤ ਪ੍ਰਾਪਤ ਕਰ ਲਈ।"
            },
            "sahib_singh_ru": {
              "main": "который от Совершенного Гуру получил такую мудрость памятования, что остаётся непоколебим перед пороками."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49057,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਰਾਖਨਹਾਰਾ ॥",
          "roman": "kar kirpā jis rākhanhārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਖਿਆ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਮਿਹਰ ਕਰ ਕੇ (ਸਿਮਰਨ ਦੀ ਦਾਤ ਦੇਂਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которому Господь-Защитник по милости дарует память о Себе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49058,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਾ ਸਗਲ ਮਿਟੈ ਅੰਧਿਆਰਾ ॥੩॥",
          "roman": "tā kā sagal miṭē andhiārā ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦਾ ਸਾਰਾ ਹਨੇਰਾ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "весь мрак привязанности к майе внутри исчезает. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49059,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਸਿਉ ਲਾਗੋ ਧਿਆਨ ॥",
          "roman": "pārbrahm siu lāgo dhiān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਸੁਰਤ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਜੁੜੀ ਰਹਿੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его сознание остаётся соединённым со стопами Всевышнего,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49060,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਪੂਰਿ ਰਹਿਓ ਨਿਰਬਾਨ ॥",
          "roman": "pūran pūr rahiō nirbān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਨੂੰ ਵਾਸਨਾ-ਰਹਿਤ ਪ੍ਰਭੂ ਸਭ ਥਾਈਂ ਵਿਆਪਕ ਦਿੱਸਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и он видит бесстрастного Господа всецело присутствующим повсюду,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49061,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮ ਭਉ ਮੇਟਿ ਮਿਲੇ ਗੋਪਾਲ ॥",
          "roman": "bhram bhau mēṭ milē gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਆਪਣੇ ਅੰਦਰੋਂ) ਹਰੇਕ ਕਿਸਮ ਦੀ ਭਟਕਣਾ ਅਤੇ ਡਰ ਮਿਟਾ ਕੇ ਸ੍ਰਿਸ਼ਟੀ ਦੇ ਪਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "устранив из себя всякое блуждание и страх, он встречает Господа — Хранителя мира,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49062,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਗੁਰ ਭਏ ਦਇਆਲ ॥੪॥੩੦॥੪੩॥",
          "roman": "nānak kau gur bhaē daīāl ||4||30||43||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਸਤਿਗੁਰੂ ਜੀ ਦਇਆਵਾਨ ਹੁੰਦੇ ਹਨ ॥੪॥੩੦॥੪੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, тот человек, к кому Сатгуру становятся милостивы. ||4||30||43||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4106,
      "rahao_verse_id": 49069,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49063,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49064,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਸਿਮਰਤ ਮਨਿ ਹੋਇ ਪ੍ਰਗਾਸੁ ॥",
          "roman": "jis simrat man hoi pragās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ (ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਪੈਦਾ ਹੋ ਜਾਂਦੀ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "При памятовании Имени Того Господа в сердце человека возникает понимание духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49065,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟਹਿ ਕਲੇਸ ਸੁਖ ਸਹਜਿ ਨਿਵਾਸੁ ॥",
          "roman": "miṭeh kalēs sukh sahaj nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦਾ ਸਿਮਰਨ ਕਰਦਿਆਂ ਸਾਰੇ) ਕਲੇਸ਼ ਮਿਟ ਜਾਂਦੇ ਹਨ, ਸੁਖਾਂ ਵਿਚ ਆਤਮਕ ਅਡੋਲਤਾ ਵਿਚ ਟਿਕਾਉ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "исчезают страдания, и он утверждается в покое, счастье и духовной уравновешенности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49066,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸਹਿ ਪਰਾਪਤਿ ਜਿਸੁ ਪ੍ਰਭੁ ਦੇਇ ॥",
          "roman": "tiseh parāpat jis prabh dēi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਸਿਮਰਨ ਦੀ ਦਾਤਿ) ਦੇਂਦਾ ਹੈ ਉਸੇ ਨੂੰ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "но это достаётся лишь тому, кому Сам Господь это даёт,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49067,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰੇ ਗੁਰ ਕੀ ਪਾਏ ਸੇਵ ॥੧॥",
          "roman": "pūrē gur kī pāē sēv ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰਮਾਤਮਾ ਉਸ ਮਨੁੱਖ ਨੂੰ) ਪੂਰੇ ਗੁਰੂ ਦੀ ਸੇਵਾ ਵਿਚ ਜੋੜ ਦੇਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и кого Он соединяет со служением Совершенному Гуру. ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49068,
          "is_rahao": true,
          "gurmukhi": "ਸਰਬ ਸੁਖਾ ਪ੍ਰਭ ਤੇਰੋ ਨਾਉ ॥",
          "roman": "sarab sukhā prabh tēro nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ ਸਾਰੇ ਸੁਖਾਂ ਦਾ ਮੂਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, Твоё Имя — источник всех благ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49069,
          "is_rahao": true,
          "gurmukhi": "ਆਠ ਪਹਰ ਮੇਰੇ ਮਨ ਗਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "āṭh pahar mērē man gāu ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਅੱਠੇ ਪਹਰ (ਹਰ ਵੇਲੇ) ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, воспевай достоинства Господа все восемь страж дня. ||1|| Рахау ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49070,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਇਛੈ ਸੋਈ ਫਲੁ ਪਾਏ ॥",
          "roman": "jo ichhē soī phal pāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਜੋ ਕੁਝ (ਪਰਮਾਤਮਾ ਪਾਸੋਂ) ਮੰਗਦਾ ਹੈ ਉਹੀ ਫਲ ਹਾਸਲ ਕਰ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек получает именно тот плод, о котором просит у Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49071,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਮੰਨਿ ਵਸਾਏ ॥",
          "roman": "har kā nām mann vasāē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ (ਆਪਣੇ) ਮਨ ਵਿਚ ਵਸਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если поселяе́т Имя Господа в своём уме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49072,
          "is_rahao": false,
          "gurmukhi": "ਆਵਣ ਜਾਣ ਰਹੇ ਹਰਿ ਧਿਆਇ ॥",
          "roman": "āvaṇ jāṇ rahē har dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਧਿਆਨ ਧਰ ਕੇ ਉਸ ਦੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਮੁੱਕ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Созерцая Господа, он выходит из круговорота рождения и смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49073,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਭਾਇ ਪ੍ਰਭ ਕੀ ਲਿਵ ਲਾਇ ॥੨॥",
          "roman": "bhagat bhāi prabh kī liv lāi ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਗਤੀ-ਭਾਵ ਨਾਲ ਪ੍ਰਭੂ ਵਿਚ ਸੁਰਤ ਜੋੜ ਕੇ (ਉਸ ਦਾ ਉਧਾਰ ਹੋ ਜਾਂਦਾ ਹੈ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Соединив своё сознание с Господом в чувстве преданности, он спасается. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49074,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੇ ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ ॥",
          "roman": "binsē kām krōdh ahaṅkār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਕਾਮ ਕ੍ਰੋਧ ਅਹੰਕਾਰ (ਇਹ ਸਾਰੇ ਵਿਕਾਰ) ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "В нём исчезают похоть, гнев и гордыня,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49075,
          "is_rahao": false,
          "gurmukhi": "ਤੂਟੇ ਮਾਇਆ ਮੋਹ ਪਿਆਰ ॥",
          "roman": "ṭūṭē māiā mōh piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਤਣਾਵਾਂ ਟੁੱਟ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "разрываются путы привязанности к майе,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49076,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਟੇਕ ਰਹੈ ਦਿਨੁ ਰਾਤਿ ॥",
          "roman": "prabh kī ṭēk rahē din rāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਦਿਨ ਰਾਤ ਪਰਮਾਤਮਾ ਦੇ ਹੀ ਆਸਰੇ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и день и ночь он опирается только на Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49077,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਕਰੇ ਜਿਸੁ ਦਾਤਿ ॥੩॥",
          "roman": "pārbrahm karē jis dāt ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਆਪਣੇ ਨਾਮ ਦੀ) ਦਾਤ ਦੇਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если Всевышний дарует ему дар Своего Имени. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49078,
          "is_rahao": false,
          "gurmukhi": "ਕਰਨ ਕਰਾਵਨਹਾਰ ਸੁਆਮੀ ॥",
          "roman": "karan karāvanhār suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਕੁਝ ਕਰਨ ਜੋਗ ਸੁਆਮੀ! ਹੇ ਜੀਵਾਂ ਪਾਸੋਂ ਸਭ ਕੁਝ ਕਰਾਵਣ ਦੇ ਸਮਰਥ ਸੁਆਮੀ!"
            },
            "sahib_singh_ru": {
              "main": "О Владыка, способный всё совершать и заставлять совершаться!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49079,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਘਟਾ ਕੇ ਅੰਤਰਜਾਮੀ ॥",
          "roman": "sagal ghaṭā kē antarjāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਜੀਵਾਂ ਦੇ ਦਿਲ ਦੀ ਜਾਣਨ ਵਾਲੇ!"
            },
            "sahib_singh_ru": {
              "main": "О Знающий сердца всех существ!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49080,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪਨੀ ਸੇਵਾ ਲਾਇ ॥",
          "roman": "kar kirpā apnī sēvā lāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ (ਮੈਨੂੰ) ਆਪਣੀ ਸੇਵਾ-ਭਗਤੀ ਵਿਚ ਜੋੜੀ ਰੱਖ,"
            },
            "sahib_singh_ru": {
              "main": "По милости удерживай меня в Своём служении и преданности,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49081,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਤੇਰੀ ਸਰਣਾਇ ॥੪॥੩੧॥੪੪॥",
          "roman": "nānak dās tērī saraṇāi ||4||31||44||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਤੇਰਾ) ਦਾਸ ਨਾਨਕ ਤੇਰੀ ਸਰਨ ਆਇਆ ਹਾਂ ॥੪॥੩੧॥੪੪॥"
            },
            "sahib_singh_ru": {
              "main": "я, Твой слуга Нанак, пришёл в Твоё прибежище. ||4||31||44||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4107,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49082,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49083,
          "is_rahao": false,
          "gurmukhi": "ਲਾਜ ਮਰੈ ਜੋ ਨਾਮੁ ਨ ਲੇਵੈ ॥",
          "roman": "lāj marē jo nām na lēvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਸਿਮਰਦਾ, ਉਹ ਆਪਣੇ ਆਪ ਵਿਚ ਸ਼ਰਮ ਨਾਲ ਹੌਲਾ ਪੈ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто не помнит Имя Господа, сам в себе становится жалок и посрамлён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49084,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਹੂਨ ਸੁਖੀ ਕਿਉ ਸੋਵੈ ॥",
          "roman": "nām bihūn sukhī kiu sōvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਮਨੁੱਖ ਸੁਖ ਦੀ ਨੀਂਦ ਨਹੀਂ ਸੌਂ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Господа человек не может спать с миром."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49085,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨੁ ਛਾਡਿ ਪਰਮ ਗਤਿ ਚਾਹੈ ॥",
          "roman": "har simran chhāḍ param gat chāhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ) ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ ਛੱਡ ਕੇ ਸਭ ਤੋਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ (ਹਾਸਲ ਕਰਨੀ) ਚਾਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто, оставив памятование Хари, хочет достичь высшего духовного состояния,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
