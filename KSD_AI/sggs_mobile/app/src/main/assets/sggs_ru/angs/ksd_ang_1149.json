{
  "ang": 1149,
  "shabads": [
    {
      "shabad_id": 4107,
      "rahao_verse_id": 49088,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49086,
          "is_rahao": false,
          "gurmukhi": "ਮੂਲ ਬਿਨਾ ਸਾਖਾ ਕਤ ਆਹੈ ॥੧॥",
          "roman": "mūl binā sākhā kat āhē ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਇਹ ਤਾਂਘ ਵਿਅਰਥ ਹੈ, ਜਿਵੇਂ ਰੁੱਖ ਦੇ) ਮੁੱਢ ਤੋਂ ਬਿਨਾ (ਉਸ ਉਤੇ) ਕੋਈ ਟਹਣੀ ਨਹੀਂ ਉੱਗ ਸਕਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "напрасно этого желает: как может вырасти ветвь без корня? ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49087,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਗੋਵਿੰਦੁ ਮੇਰੇ ਮਨ ਧਿਆਇ ॥",
          "roman": "gur govind mērē man dhiāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਗੁਰੂ ਨੂੰ ਗੋਵਿੰਦ ਨੂੰ (ਸਦਾ) ਸਿਮਰਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, всегда помни Гуру, помни Говинда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49088,
          "is_rahao": true,
          "gurmukhi": "ਜਨਮ ਜਨਮ ਕੀ ਮੈਲੁ ਉਤਾਰੈ ਬੰਧਨ ਕਾਟਿ ਹਰਿ ਸੰਗਿ ਮਿਲਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "janam janam kī mēl utārē bandhan kāṭ har saṅg milāi ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਏਹ ਸਿਮਰਨ) ਅਨੇਕਾਂ ਜਨਮਾਂ ਦੀ (ਵਿਕਾਰਾਂ ਦੀ) ਮੈਲ ਦੂਰ ਕਰ ਦੇਂਦਾ ਹੈ, ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਫਾਹੀਆਂ ਕੱਟ ਕੇ (ਮਨੁੱਖ ਨੂੰ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਲ ਜੋੜ ਦੇਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Это памятование смывает грязь пороков многих рождений, разрезает путы привязанности к майе и соединяет человека с Господом. ||1|| Рахау ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49089,
          "is_rahao": false,
          "gurmukhi": "ਤੀਰਥਿ ਨਾਇ ਕਹਾ ਸੁਚਿ ਸੈਲੁ ॥",
          "roman": "tīrath nāi kahā such sēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੱਥਰ (ਪੱਥਰ-ਦਿਲ ਮਨੁੱਖ) ਤੀਰਥ ਉੱਤੇ ਇਸ਼ਨਾਨ ਕਰ ਕੇ (ਆਤਮਕ) ਪਵਿੱਤ੍ਰਤਾ ਹਾਸਲ ਨਹੀਂ ਕਰ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Камень, каменное сердце, не может обрести духовную чистоту, омывшись на месте паломничества,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49090,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਕਉ ਵਿਆਪੈ ਹਉਮੈ ਮੈਲੁ ॥",
          "roman": "man kau viāpē haumē mēl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ) ਮਨ ਨੂੰ (ਇਹੀ) ਹਉਮੈ ਦੀ ਮੈਲ ਚੰਬੜੀ ਰਹਿੰਦੀ ਹੈ (ਕਿ ਮੈਂ ਤੀਰਥ-ਜਾਤ੍ਰਾ ਕਰ ਆਇਆ ਹਾਂ)।"
            },
            "sahib_singh_ru": {
              "main": "ведь к его уму по-прежнему липнет грязь Хоумэ: ‘я совершил паломничество’."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49091,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਕਰਮ ਬੰਧਨ ਕਾ ਮੂਲੁ ॥",
          "roman": "koṭ karam bandhan kā mūl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੀਰਥ-ਜਾਤ੍ਰਾ ਆਦਿਕ ਮਿਥੇ ਹੋਏ) ਕ੍ਰੋੜਾਂ ਧਾਰਮਿਕ ਕਰਮ (ਹਉਮੈ ਦੀਆਂ) ਫਾਹੀਆਂ ਦਾ (ਹੀ) ਕਾਰਨ ਬਣਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Миллионы предписанных религиозных действий сами становятся причиной пут Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49092,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਭਜਨ ਬਿਨੁ ਬਿਰਥਾ ਪੂਲੁ ॥੨॥",
          "roman": "har kē bhajan bin birthā pūl ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ (ਇਹ ਮਿਥੇ ਹੋਏ ਧਾਰਮਿਕ ਕਰਮ ਮਨੁੱਖ ਦੇ ਸਿਰ ਉੱਤੇ) ਵਿਅਰਥ ਪੰਡ ਹੀ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Без памятования Имени Господа все эти предписанные обряды — лишь бесполезная ноша на голове человека. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49093,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨੁ ਖਾਏ ਬੂਝੈ ਨਹੀ ਭੂਖ ॥",
          "roman": "bin khāē būjhē nahī bhūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਭੋਜਨ) ਖਾਣ ਤੋਂ ਬਿਨਾ (ਪੇਟ ਦੀ) ਭੁੱਖ (ਦੀ ਅੱਗ) ਨਹੀਂ ਬੁੱਝਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Без еды огонь голода не угасает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49094,
          "is_rahao": false,
          "gurmukhi": "ਰੋਗੁ ਜਾਇ ਤਾਂ ਉਤਰਹਿ ਦੂਖ ॥",
          "roman": "rōg jāi tāṅ utareh dūkh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਰੋਗ ਤੋਂ ਪੈਦਾ ਹੋਏ) ਸਰੀਰਕ ਦੁੱਖ ਤਦੋਂ ਹੀ ਦੂਰ ਹੁੰਦੇ ਹਨ, ਜੇ (ਅੰਦਰੋਂ) ਰੋਗ ਦੂਰ ਹੋ ਜਾਏ।"
            },
            "sahib_singh_ru": {
              "main": "Телесные страдания уходят лишь тогда, когда исчезает сама болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49095,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ ਮੋਹਿ ਬਿਆਪਿਆ ॥",
          "roman": "kām krōdh lōbh mōh biāpiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ ਮੋਹ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Человек остаётся захваченным похотью, гневом, жадностью и привязанностью,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49096,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਪ੍ਰਭਿ ਕੀਨਾ ਸੋ ਪ੍ਰਭੁ ਨਹੀ ਜਾਪਿਆ ॥੩॥",
          "roman": "jin prabh kīnā so prabh nahī jāpiā ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਉਸ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਜਪਦਾ ਜਿਸ ਨੇ ਉਸ ਨੂੰ ਪੈਦਾ ਕੀਤਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если не повторяет Имя того Господа, Который его создал. ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49097,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਧਨੁ ਸਾਧ ਧੰਨੁ ਹਰਿ ਨਾਉ ॥",
          "roman": "dhan dhan sādh dhann har nāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਗੁਰਮੁਖ ਮਨੁੱਖ ਭਾਗਾਂ ਵਾਲੇ ਹਨ, ਜਿਹੜੇ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Благословенны те гурсикхи, которые повторяют Имя Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49098,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਕੀਰਤਨੁ ਗੁਣ ਗਾਉ ॥",
          "roman": "āṭh pahar kīrtan guṇ gāu",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜੇ ਅੱਠੇ ਪਹਰ ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਕਰਦੇ ਹਨ, ਪਰਮਾਤਮਾ ਦੇ ਗੁਣਾਂ ਦਾ ਗਾਇਨ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "которые все восемь страж дня воспевают хвалу и достоинства Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49099,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਹਰਿ ਭਗਤਿ ਧਨੁ ਕਰਣੈਹਾਰ ॥",
          "roman": "dhan har bhagat dhan karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਪਾਸ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਦਾ ਧਨ ਸਿਰਜਣਹਾਰ ਦੇ ਨਾਮ ਦਾ ਧਨ (ਸਦਾ ਮੌਜੂਦ) ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "У них всегда есть богатство преданности Господу и богатство Имени Творца,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49100,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਨਾਨਕ ਪ੍ਰਭ ਪੁਰਖ ਅਪਾਰ ॥੪॥੩੨॥੪੫॥",
          "roman": "saraṇ nānak prabh purakh apār ||4||32||45||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਹੜੇ ਮਨੁੱਖ ਬੇਅੰਤ ਤੇ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ ॥੪॥੩੨॥੪੫॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак, это те люди, что пребывают в прибежище беспредельного и вездесущего Господа. ||4||32||45||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4108,
      "rahao_verse_id": 49107,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49101,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49102,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸੁਪ੍ਰਸੰਨ ਹੋਏ ਭਉ ਗਏ ॥",
          "roman": "gur suprasañn hoē bhau gaē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਤਿਗੁਰੂ ਜਿਸ ਮਨੁੱਖ ਉਤੇ ਬਹੁਤ ਪ੍ਰਸੰਨ ਹੁੰਦਾ ਹੈ, ਉਸ ਦਾ ਹਰੇਕ ਡਰ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если Сатгуру очень доволен человеком, всякий его страх исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49103,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਨਿਰੰਜਨ ਮਨ ਮਹਿ ਲਏ ॥",
          "roman": "nām nirañjan man meh laē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਉਹ ਮਨੁੱਖ (ਹਰ ਵੇਲੇ) ਮਾਇਆ-ਰਹਿਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਆਪਣੇ ਮਨ ਵਿਚ ਵਸਾਈ ਰੱਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "потому что такой человек постоянно хранит в своём уме Имя лишённого майи Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49104,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨ ਦਇਆਲ ਸਦਾ ਕਿਰਪਾਲ ॥",
          "roman": "dīn daiyāl sadā kirpāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਨਾਂ ਉਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਪ੍ਰਭੂ ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਕਿਰਪਾ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь, милующий униженных, являет человеку свою милость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49105,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸਿ ਗਏ ਸਗਲੇ ਜੰਜਾਲ ॥੧॥",
          "roman": "binas gaē sagle jañjāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰੋਂ) ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਸਾਰੇ ਬੰਧਨ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "все узы привязанности к майе внутри него уничтожаются. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49106,
          "is_rahao": true,
          "gurmukhi": "ਸੂਖ ਸਹਜ ਆਨੰਦ ਘਨੇ ॥",
          "roman": "sūkh sahaj ānand ghane",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੇ ਅੰਦਰ) ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਬੜੇ ਸੁਖ ਆਨੰਦ ਬਣੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Внутри него пребывают великие радость и покой духовной устойчивости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49107,
          "is_rahao": true,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਮਿਟੇ ਭੈ ਭਰਮਾ ਅੰਮ੍ਰਿਤੁ ਹਰਿ ਹਰਿ ਰਸਨ ਭਨੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sādhasaṅg miṭe bhē bharamā aṃmrit har har rasan bhane",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਧ ਸੰਗਤ ਵਿਚ ਰਹਿ ਕੇ ਉਸ ਦੇ ਸਾਰੇ ਡਰ ਵਹਿਮ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ, ਜਿਹੜਾ ਮਨੁੱਖ ਆਪਣੀ ਜੀਭ ਨਾਲ ਆਮਤਕ ਜੀਵਨ ਦੇਣ ਵਾਲਾ ਹਰਿ-ਨਾਮ ਉਚਾਰਦਾ ਰਹਿੰਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "живя в Садх Сангат, он избавляется от всех страхов и заблуждений, если своей речью постоянно произносит дающее бессмертную жизнь Имя Хари. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49108,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਸਿਉ ਲਾਗੋ ਹੇਤੁ ॥",
          "roman": "charan kamal siu lāgo het",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਨਾਲ ਜਿਸ ਮਨੁੱਖ ਦਾ ਪਿਆਰ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если у человека возникает любовь к прекрасным стопам Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49109,
          "is_rahao": false,
          "gurmukhi": "ਖਿਨ ਮਹਿ ਬਿਨਸਿਓ ਮਹਾ ਪਰੇਤੁ ॥",
          "roman": "khin meh binasio mahā paret",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰੋਂ (ਖੋਟਾ ਸੁਭਾਉ-ਰੂਪ) ਵੱਡਾ ਪ੍ਰੇਤ ਇਕ ਖਿਨ ਵਿਚ ਮੁੱਕ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "то великий призрак дурного нрава внутри него исчезает в одно мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49110,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਹਰਿ ਜਪੁ ਜਾਪਿ ॥",
          "roman": "āṭh pahar har har jap jāp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਅੱਠੇ ਪਹਿਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਜਾਪ ਜਪਿਆ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Ты повторяй джап Имени Параматмы все восемь пахаров суток,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49111,
          "is_rahao": false,
          "gurmukhi": "ਰਾਖਨਹਾਰ ਗੋਵਿਦ ਗੁਰ ਆਪਿ ॥੨॥",
          "roman": "rākhanhār govid gur āp",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਭ ਦੀ ਰੱਖਿਆ ਕਰ ਸਕਣ ਵਾਲਾ ਗੁਰੂ ਗੋਬਿੰਦ ਆਪ (ਤੇਰੀ ਭੀ ਰੱਖਿਆ ਕਰੇਗਾ) ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и Гуру-Говинд, Защитник всех, сам защитит и тебя. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49112,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਸੇਵਕ ਕਉ ਸਦਾ ਪ੍ਰਤਿਪਾਰੈ ॥",
          "roman": "apne sevak kau sadā pratipārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਸੇਵਕ ਦੀ ਆਪ ਰੱਖਿਆ ਕਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь сам всегда хранит своего слугу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49113,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਜਨਾ ਕੇ ਸਾਸ ਨਿਹਾਰੈ ॥",
          "roman": "bhagat janā ke sās nihārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਭਗਤਾਂ ਦੇ ਸੁਆਸਾਂ ਨੂੰ ਗਹੁ ਨਾਲ ਤੱਕਦਾ ਰਹਿੰਦਾ ਹੈ (ਭਾਵ, ਬੜੇ ਧਿਆਨ ਨਾਲ ਭਗਤ ਜਨਾਂ ਦੀ ਰਾਖੀ ਕਰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Он внимательно следит за дыханием своих бхагатов, то есть бережёт преданных с великой заботой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49114,
          "is_rahao": false,
          "gurmukhi": "ਮਾਨਸ ਕੀ ਕਹੁ ਕੇਤਕ ਬਾਤ ॥",
          "roman": "mānas kī kaho ketak bāt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੱਸ, ਮਨੁੱਖ ਵਿਚਾਰੇ ਭਗਤ ਜਨਾਂ ਦਾ ਕੀਹ ਵਿਗਾੜ ਸਕਦੇ ਹਨ?"
            },
            "sahib_singh_ru": {
              "main": "Скажи, что вообще могут сделать бедным бхагатам обычные люди?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49115,
          "is_rahao": false,
          "gurmukhi": "ਜਮ ਤੇ ਰਾਖੈ ਦੇ ਕਰਿ ਹਾਥ ॥੩॥",
          "roman": "jam te rākhē de kar hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਤਾਂ ਉਹਨਾਂ ਨੂੰ ਹੱਥ ਦੇ ਕੇ ਜਮਾਂ ਤੋਂ ਭੀ ਬਚਾ ਲੈਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Ведь Параматма, подав им руку, спасает их даже от ямов. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49116,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਸੋਭਾ ਨਿਰਮਲ ਰੀਤਿ ॥",
          "roman": "nirmal sobhā nirmal rīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਹਰ ਥਾਂ ਬੇ-ਦਾਗ਼ ਸੋਭਾ ਬਣੀ ਰਹਿੰਦੀ ਹੈ, ਉਸ ਦੀ ਜੀਵਨ-ਜੁਗਤਿ ਸਦਾ ਪਵਿੱਤਰ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Его незапятнанная слава пребывает повсюду, и образ его жизни всегда чист,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49117,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਆਇਆ ਮਨਿ ਚੀਤਿ ॥",
          "roman": "pārbrahm āiā man chīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਚਿੱਤ ਵਿਚ ਪਰਮਾਤਮਾ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "если Парабрахм поселяется в уме и сознании человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49118,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਗੁਰਿ ਦੀਨੋ ਦਾਨੁ ॥",
          "roman": "kar kirpā gur dīno dān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਗੁਰੂ ਨੇ ਜਿਸ ਮਨੁੱਖ ਨੂੰ (ਨਾਮ ਦੀ) ਦਾਤ ਬਖ਼ਸ਼ੀ,"
            },
            "sahib_singh_ru": {
              "main": "Тому, кому по милости Гуру даровал дар Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49119,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਇਆ ਨਾਮੁ ਨਿਧਾਨੁ ॥੪॥੩੩॥੪੬॥",
          "roman": "nānak pāiā nām nidhān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਉਸ ਨੇ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ ਹਾਸਲ ਕਰ ਲਿਆ ॥੪॥੩੩॥੪੬॥"
            },
            "sahib_singh_ru": {
              "main": "о Нанак, достаётся сокровище Имени. ॥4॥33॥46॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4109,
      "rahao_verse_id": 49126,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49120,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49121,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਸਮਰਥੁ ਗੁਰੁ ਮੇਰਾ ॥",
          "roman": "karaṇ kāraṇ samrath gur merā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰਾ ਗੁਰੂ-ਪਰਮੇਸਰ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਮੂਲ ਹੈ, ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Мой Гуру-Парамешар — корень всего творения и владыка всех сил,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49122,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਣ ਸੁਖਦਾਤਾ ਨੇਰਾ ॥",
          "roman": "jīa prāṇ sukhdātā nerā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਭ ਨੂੰ) ਜਿੰਦ ਦੇਣ ਵਾਲਾ ਹੈ, ਪ੍ਰਾਣ ਦੇਣ ਵਾਲਾ ਹੈ, ਸਾਰੇ ਸੁਖ ਦੇਣ ਵਾਲਾ ਹੈ, (ਸਭਨਾਂ ਦੇ) ਨੇੜੇ (ਵੱਸਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Он даёт жизнь, даёт дыхание, дарует все радости и пребывает близко ко всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49123,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਭੰਜਨ ਅਬਿਨਾਸੀ ਰਾਇ ॥",
          "roman": "bhē bhanjan abināsī rāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪਾਤਿਸ਼ਾਹ (ਜੀਵਾਂ ਦੇ ਸਾਰੇ) ਡਰ ਦੂਰ ਕਰਨ ਵਾਲਾ ਹੈ, ਉਹ ਆਪ ਨਾਸ-ਰਹਿਤ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот Царь устраняет все страхи существ, сам же Он неуничтожим,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49124,
          "is_rahao": false,
          "gurmukhi": "ਦਰਸਨਿ ਦੇਖਿਐ ਸਭੁ ਦੁਖੁ ਜਾਇ ॥੧॥",
          "roman": "darsan dekhiā sabh dukh jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਸ ਦਾ ਦਰਸਨ ਹੋ ਜਾਏ, (ਤਾਂ ਮਨੁੱਖ ਦਾ) ਸਾਰਾ ਦੁੱਖ ਦੂਰ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и если удостоиться Его даршана, всякое страдание человека уходит. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49125,
          "is_rahao": true,
          "gurmukhi": "ਜਤ ਕਤ ਪੇਖਉ ਤੇਰੀ ਸਰਣਾ ॥",
          "roman": "jat kat pekhau terī sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਮੈਂ ਹਰ ਥਾਂ ਤੇਰਾ ਹੀ ਆਸਰਾ ਤੱਕਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Где бы я ни смотрел, всюду ищу только Твою защиту."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49126,
          "is_rahao": true,
          "gurmukhi": "ਬਲਿ ਬਲਿ ਜਾਈ ਸਤਿਗੁਰ ਚਰਣਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "bal bal jāī satigur charṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਆਪਣੇ) ਗੁਰੂ ਦੇ ਚਰਨਾਂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ (ਜਿਸ ਗੁਰੂ ਨੇ ਮੈਨੂੰ ਤੇਰੇ ਚਰਨਾਂ ਵਿਚ ਜੋੜਿਆ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Я снова и снова иду в жертву стопам Сатгуру, который соединил меня с Твоими стопами. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49127,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਕਾਮ ਮਿਲੇ ਗੁਰਦੇਵ ॥",
          "roman": "pūran kām mile gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰਦੇਵ-ਪ੍ਰਭੂ ਨੂੰ ਮਿਲਿਆਂ ਸਾਰੀਆਂ ਕਾਮਨਾਂ ਪੂਰੀਆਂ ਹੋ ਜਾਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "При встрече с Гурдевом-Господом все желания исполняются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49128,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਫਲਦਾਤਾ ਨਿਰਮਲ ਸੇਵ ॥",
          "roman": "sabh phaldātā nirmal sev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਾਰੇ ਫਲ ਦੇਣ ਵਾਲਾ ਹੈ, ਉਸ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਜੀਵਨ ਨੂੰ ਪਵਿਤਰ ਕਰ ਦੇਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он дарует все плоды, а служение и бхагти Ему очищают жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49129,
          "is_rahao": false,
          "gurmukhi": "ਕਰੁ ਗਹਿ ਲੀਨੇ ਅਪੁਨੇ ਦਾਸ ॥",
          "roman": "kar gah līne apune dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਆਪਣੇ ਦਾਸਾਂ ਦਾ ਹੱਥ ਫੜ ਕੇ ਉਹਨਾਂ ਨੂੰ ਆਪਣੇ ਬਣਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Господь берёт своих слуг за руку и делает их своими,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49130,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਨਾਮੁ ਰਿਦ ਦੀਓ ਨਿਵਾਸ ॥੨॥",
          "roman": "rām nām rid dīo nivās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਉਹਨਾਂ ਦੇ ਹਿਰਦੇ ਵਿਚ ਆਪਣਾ ਨਾਮ ਟਿਕਾ ਦੇਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и утверждает своё Имя в их сердце. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49131,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਅਨੰਦੁ ਨਾਹੀ ਕਿਛੁ ਸੋਗੁ ॥",
          "roman": "sadā anand nāhī kichh sog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੇ ਹਿਰਦੇ ਵਿਚ ਤੂੰ ਆਪਣਾ ਨਾਮ ਟਿਕਾਂਦਾ ਹੈਂ, ਉਸ ਦੇ ਅੰਦਰ) ਸਦਾ ਆਨੰਦ ਬਣਿਆ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਨੂੰ ਕੋਈ ਗ਼ਮ (ਪੋਹ ਨਹੀਂ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "В том, в чьём сердце Ты утвердил своё Имя, всегда пребывает радость, и никакая печаль его не касается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49132,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖੁ ਦਰਦੁ ਨਹ ਬਿਆਪੈ ਰੋਗੁ ॥",
          "roman": "dūkh dard neh biāpē rog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਦੁੱਖ ਕੋਈ ਦਰਦ ਕੋਈ ਰੋਗ ਉਸ ਉਤੇ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Ни страдание, ни боль, ни болезнь не могут взять над ним верх."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49133,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕਿਛੁ ਤੇਰਾ ਤੂ ਕਰਣੈਹਾਰੁ ॥",
          "roman": "sabh kichh terā tū karṇēhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੋ ਕੁਝ ਦਿੱਸ ਰਿਹਾ ਹੈ, ਇਹ) ਸਭ ਕੁਝ ਤੇਰਾ ਪੈਦਾ ਕੀਤਾ ਹੋਇਆ ਹੈ, ਤੂੰ ਹੀ ਸਭ ਕੁਝ ਪੈਦਾ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Всё, что видно, создано Тобой; Ты один обладаешь силой всё творить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49134,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਗੁਰ ਅਗਮ ਅਪਾਰ ॥੩॥",
          "roman": "pārbrahm gur agam apār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਗੁਰੂ-ਪਾਰਬ੍ਰਹਮ! ਹੇ ਅਪਹੁੰਚ! ਹੇ ਬੇਅੰਤ! ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Гуру-Парабрахм! О Недосягаемый! О Безграничный! ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49135,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਮਲ ਸੋਭਾ ਅਚਰਜ ਬਾਣੀ ॥",
          "roman": "nirmal sobhā acharaj bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀ ਬੇ-ਦਾਗ਼ ਸੋਭਾ (ਹਰ ਥਾਂ ਪਸਰ ਜਾਂਦੀ ਹੈ, ਪਰਮਾਤਮਾ ਦੀ) ਵਿਸਮਾਦ ਪੈਦਾ ਕਰਨ ਵਾਲੀ ਬਾਣੀ-"
            },
            "sahib_singh_ru": {
              "main": "Его незапятнанная слава распространяется повсюду, а изумительная Бани Параматмы —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49136,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਪੂਰਨ ਮਨਿ ਭਾਣੀ ॥",
          "roman": "pārbrahm pūran man bhāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰਬ-ਵਿਆਪਕ ਪਰਮਾਤਮਾ ਦੀ (ਸਿਫ਼ਤ-ਸਾਲਾਹ) ਜਿਸ ਮਨੁੱਖ ਦੇ ਮਨ ਵਿਚ ਮਿੱਠੀ ਲੱਗ ਪੈਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "слава всепронизывающего Параматмы — становится сладостной в уме человека."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49137,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਰਵਿਆ ਸੋਇ ॥",
          "roman": "jal thal mahīal raviā soi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਜਲ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ ਸਭ ਥਾਂ ਮੌਜੂਦ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Этот Господь присутствует в воде, на земле и в небе — всюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49138,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਸਭੁ ਕਿਛੁ ਪ੍ਰਭ ਤੇ ਹੋਇ ॥੪॥੩੪॥੪੭॥",
          "roman": "nānak sabh kichh prabh te hoi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਜੋ ਕੁਝ ਜਗਤ ਵਿਚ ਹੋ ਰਿਹਾ ਹੈ) ਸਭ ਕੁਝ ਪ੍ਰਭੂ ਤੋਂ (ਪ੍ਰਭੂ ਦੇ ਹੁਕਮ ਨਾਲ ਹੀ) ਹੋ ਰਿਹਾ ਹੈ ॥੪॥੩੪॥੪੭॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Всё, что происходит в мире, происходит от Господа, по Его Хукаму. ॥4॥34॥47॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4110,
