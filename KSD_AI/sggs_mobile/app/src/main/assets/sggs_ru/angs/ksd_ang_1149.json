      "lines": [
        {
          "verse_id": 49139,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "bhērau mehlā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49140,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਤਨੁ ਰਾਤਾ ਰਾਮ ਰੰਗਿ ਚਰਣੇ ॥",
          "roman": "man tan rātā rām raṅg charṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦਾ ਮਨ ਉਸ ਦਾ ਤਨ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਦੇ ਪਿਆਰ ਵਿਚ ਮਸਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ум и тело такого человека опьянены любовью к стопам Параматмы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
