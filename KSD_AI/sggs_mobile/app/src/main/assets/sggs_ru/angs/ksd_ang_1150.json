{
  "ang": 1150,
  "shabads": [
    {
      "shabad_id": 4110,
      "rahao_verse_id": 49145,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49141,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਮਨੋਰਥ ਪੂਰਨ ਕਰਣੇ ॥",
          "roman": "sarab manorath pūran karṇe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਉਸ ਦੀਆਂ ਸਾਰੀਆਂ ਲੋੜਾਂ ਪੂਰੀਆਂ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "и Параматма постоянно исполняет все его нужды,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49142,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਗਾਵਤ ਭਗਵੰਤੁ ॥",
          "roman": "āṭh pahar gāvat bhagvant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਦੀ ਉਮਰ) ਅੱਠੇ ਪਹਰ ਭਗਵਾਨ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ (ਬੀਤਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "его жизнь проходит в пении качеств Бхагванта все восемь пахаров,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49143,
          "is_rahao": false,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਦੀਨੋ ਪੂਰਾ ਮੰਤੁ ॥੧॥",
          "roman": "satigur dīno pūrā mant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਨੇ (ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ) ਭਰਪੂਰ ਨਾਮ-ਮੰਤ੍ਰ ਦੇ ਦਿੱਤਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "если Гуру дал ему совершенный мантр Имени, полный всеми достоинствами. ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49144,
          "is_rahao": true,
          "gurmukhi": "ਸੋ ਵਡਭਾਗੀ ਜਿਸੁ ਨਾਮਿ ਪਿਆਰੁ ॥",
          "roman": "so vaḍbhāgī jis nām piār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਦਾ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਪਿਆਰ ਬਣ ਗਿਆ ਹੈ, ਉਹ ਵੱਡੇ ਭਾਗਾਂ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, у которого возникла любовь к Имени Параматмы, поистине велико счастлив."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49145,
          "is_rahao": true,
          "gurmukhi": "ਤਿਸ ਕੈ ਸੰਗਿ ਤਰੈ ਸੰਸਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "tis kē saṅg tarē sansār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ (ਮਨੁੱਖ) ਦੀ ਸੰਗਤ ਵਿਚ ਸਾਰਾ ਜਗਤ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "В его сангате весь мир переправляется через океан сансары. ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49146,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਗਿਆਨੀ ਜਿ ਸਿਮਰੈ ਏਕ ॥",
          "roman": "soī giānī j simrē ek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਇਕ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਹੀ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਵਾਲਾ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Лишь тот обладает пониманием духовной жизни, кто постоянно помнит Имя Единого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49147,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਧਨਵੰਤਾ ਜਿਸੁ ਬੁਧਿ ਬਿਬੇਕ ॥",
          "roman": "so dhanvaṅtā jis budh bibek",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਚੰਗੇ ਮੰਦੇ ਕਰਮ ਦੀ ਪਰਖ ਦੀ ਅਕਲ ਆ ਜਾਂਦੀ ਹੈ ਉਹ ਮਨੁੱਖ ਨਾਮ-ਧਨ ਦਾ ਮਾਲਕ ਬਣ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто обрёл разум различать добрые и дурные поступки, становится обладателем богатства Имени."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49148,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਕੁਲਵੰਤਾ ਜਿ ਸਿਮਰੈ ਸੁਆਮੀ ॥",
          "roman": "so kulvaṅtā j simrē suāmī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਮਾਲਕ-ਪ੍ਰਭੂ ਨੂੰ ਯਾਦ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ ਉਹ (ਸਭ ਤੋਂ ਉੱਚੇ ਪ੍ਰਭੂ ਨਾਲ ਛੁਹ ਕੇ) ਉੱਚੀ ਕੁਲ ਵਾਲਾ ਬਣ ਗਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто помнит Владыку-Господа, становится человеком высокой духовной линии."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49149,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਪਤਿਵੰਤਾ ਜਿ ਆਪੁ ਪਛਾਨੀ ॥੨॥",
          "roman": "so pativaṅtā j āp pachhānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਮਨੁੱਖ ਆਪਣੇ ਆਚਰਨ ਨੂੰ ਪੜਤਾਲਦਾ ਰਹਿੰਦਾ ਹੈ ਉਹ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Тот, кто исследует собственное поведение, становится достойным чести в этом мире и в ином. ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49150,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦਿ ਪਰਮ ਪਦੁ ਪਾਇਆ ॥",
          "roman": "gur parsād param pad pāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਸਭ ਤੋਂ ਉੱਚਾ ਆਤਮਕ ਦਰਜਾ ਮਿਲ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру такой человек достигает высочайшего духовного состояния,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49151,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗੋੁਪਾਲ ਦਿਨੁ ਰੈਨਿ ਧਿਆਇਆ ॥",
          "roman": "guṇ gopāl din rēn dhiāiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੇ ਦਿਨ ਰਾਤ (ਹਰ ਵੇਲੇ) ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਣੇ ਸ਼ੁਰੂ ਕਰ ਦਿੱਤੇ।"
            },
            "sahib_singh_ru": {
              "main": "если день и ночь начинает воспевать качества Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49152,
          "is_rahao": false,
          "gurmukhi": "ਤੂਟੇ ਬੰਧਨ ਪੂਰਨ ਆਸਾ ॥",
          "roman": "ṭūṭe bandhan pūran āsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੀਆਂ ਮਾਇਆ ਦੇ ਮੋਹ ਦੀਆਂ ਸਭ ਫਾਹੀਆਂ ਟੁੱਟ ਗਈਆਂ, ਉਸ ਦੀਆਂ ਸਭ ਆਸਾਂ ਪੂਰੀਆਂ ਹੋ ਗਈਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "Все петли привязанности к майе у него разрываются, и все его надежды исполняются,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49153,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਚਰਣ ਰਿਦ ਮਾਹਿ ਨਿਵਾਸਾ ॥੩॥",
          "roman": "har ke charaṇ rid māhi nivāsā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਚਰਨ ਉਸ ਦੇ ਹਿਰਦੇ ਵਿਚ (ਸਦਾ ਲਈ) ਟਿਕ ਗਏ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "ибо стопы Параматмы навсегда утверждаются в его сердце. ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49154,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਜਾ ਕੇ ਪੂਰਨ ਕਰਮਾ ॥",
          "roman": "kaho nānak jā ke pūran karmā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਜਿਸ ਮਨੁੱਖ ਦੇ ਪੂਰੇ ਭਾਗ ਜਾਗ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: когда у человека полностью пробуждается удача,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49155,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਜਨੁ ਆਇਆ ਪ੍ਰਭ ਕੀ ਸਰਨਾ ॥",
          "roman": "so jan āiā prabh kī sarṇā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਵਿਚ ਆ ਪੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "тогда он приходит в прибежище Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49156,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਪਵਿਤੁ ਪਾਵਨ ਸਭਿ ਕੀਨੇ ॥",
          "roman": "āp pavit pāvan sabh kīne",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪ ਸੁੱਚੇ ਆਚਰਨ ਵਾਲਾ ਬਣ ਜਾਂਦਾ ਹੈ (ਜਿਹੜੇ ਉਸ ਦੀ ਸੰਗਤ ਕਰਦੇ ਹਨ ਉਹਨਾਂ) ਸਾਰਿਆਂ ਨੂੰ ਭੀ ਪਵਿੱਤਰ ਜੀਵਨ ਵਾਲਾ ਬਣਾ ਲੈਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он сам становится человеком чистого поведения и делает чистой жизнь всех, кто пребывает в его сангате."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49157,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਰਸਾਇਣੁ ਰਸਨਾ ਚੀਨੑੇ ॥੪॥੩੫॥੪੮॥",
          "roman": "rām rasāin rasanā chīṇhe",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਆਪਣੀ ਜੀਭ ਨਾਲ ਸਭ ਰਸਾਂ ਤੋਂ ਸ੍ਰੇਸ਼ਟ ਨਾਮ-ਰਸ ਨੂੰ ਚੱਖਦਾ ਰਹਿੰਦਾ ਹੈ ॥੪॥੩੫॥੪੮॥"
            },
            "sahib_singh_ru": {
              "main": "Такой человек своей речью вкушает высший среди всех вкусов — вкус Имени. ॥4॥35॥48॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4111,
      "rahao_verse_id": 49164,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49158,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49159,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਕਿਛੁ ਬਿਘਨੁ ਨ ਲਾਗੈ ॥",
          "roman": "nām lēt kichh bighan na lāgē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਜ਼ਿੰਦਗੀ ਦੇ ਸਫ਼ਰ ਵਿਚ ਕਾਮਾਦਿਕ ਦੀ) ਕੋਈ ਰੁਕਾਵਟ ਨਹੀਂ ਪੈਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек повторяет Имя Бога, на жизненном пути не возникает никаких препятствий."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49160,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਸੁਣਤ ਜਮੁ ਦੂਰਹੁ ਭਾਗੈ ॥",
          "roman": "nām suṇat jam dūrah bhāgē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸੁਣਦਿਆਂ (ਜੀਵਨ ਇਤਨਾ ਉੱਚਾ ਹੋ ਜਾਂਦਾ ਹੈ ਕਿ ਨਾਮ ਜਪਣ ਵਾਲੇ ਮਨੁੱਖ ਪਾਸੋਂ) ਜਮਰਾਜ ਦੂਰੋਂ ਹੀ ਪਰੇ ਹਟ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Когда человек слышит Имя Бога, его жизнь становится столь возвышенной, что Ямрадж держится от него вдали."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49161,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਲੈਤ ਸਭ ਦੂਖਹ ਨਾਸੁ ॥",
          "roman": "nām lēt sabh dūkheh nās ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮ ਜਪਦਿਆਂ ਸਾਰੇ ਦੁੱਖਾਂ ਦਾ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек повторяет Имя, все страдания исчезают,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49162,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਹਰਿ ਚਰਣ ਨਿਵਾਸੁ ॥੧॥",
          "roman": "nām japat har charaṇ nivās ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਪਰਮਾਤਮਾ ਦੇ ਚਰਨਾਂ ਵਿਚ ਮਨ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и ум остаётся утверждённым у стоп Бога ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49163,
          "is_rahao": true,
          "gurmukhi": "ਨਿਰਬਿਘਨ ਭਗਤਿ ਭਜੁ ਹਰਿ ਹਰਿ ਨਾਉ ॥",
          "roman": "nirbighan bhagat bhaj har har nāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਭਗਤੀ ਜ਼ਿੰਦਗੀ ਦੇ ਰਾਹ ਵਿਚ (ਵਿਕਾਰਾਂ ਦੀ) ਕੋਈ ਰੁਕਾਵਟ ਨਹੀਂ ਪੈਣ ਦੇਂਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Такая бхакти не позволяет, чтобы на жизненном пути возникали препятствия от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49164,
          "is_rahao": true,
          "gurmukhi": "ਰਸਕਿ ਰਸਕਿ ਹਰਿ ਕੇ ਗੁਣ ਗਾਉ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "rasak rasak har ke guṇ gāu ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੜੇ ਪ੍ਰੇਮ ਨਾਲ ਸਦਾ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਿਹਾ ਕਰ, ਸਦਾ ਹਰੀ ਦਾ ਨਾਮ ਜਪਦਾ ਰਿਹਾ ਕਰ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "С великой любовью всегда пой достоинства Бога, всегда повторяй Имя Хари ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49165,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਕਿਛੁ ਚਾਖੁ ਨ ਜੋਹੈ ॥",
          "roman": "har simrat kichh chākh na johē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਕੋਈ ਭੈੜੀ ਨਜ਼ਰ ਨਹੀਂ ਲੱਗਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "Когда человек помнит Бога, никакой дурной глаз не пристаёт к нему,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49166,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਦੈਤ ਦੇਉ ਨ ਪੋਹੈ ॥",
          "roman": "har simrat dēt deu na pohē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਕੋਈ ਦੈਂਤ ਕੋਈ ਦੇਉ ਆਪਣਾ ਜ਼ੋਰ ਨਹੀਂ ਪਾ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "когда человек помнит Бога, ни демон, ни божество не могут проявить над ним своей силы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49167,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਮੋਹੁ ਮਾਨੁ ਨ ਬਧੈ ॥",
          "roman": "har simrat moh mān na badhē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਮਾਇਆ ਦਾ ਮੋਹ ਦੁਨੀਆ ਦਾ ਕੋਈ ਮਾਣ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਕੁਚਲ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "когда человек помнит Бога, привязанность к майе и мирская гордость не могут подавить его духовную жизнь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49168,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਤ ਗਰਭ ਜੋਨਿ ਨ ਰੁਧੈ ॥੨॥",
          "roman": "har simrat garabh jon na rudhē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਿਆਂ ਮਨੁੱਖ ਜੂਨਾਂ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਫਸਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "когда человек помнит Бога, он не попадает в круговорот перерождений ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49169,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨ ਕੀ ਸਗਲੀ ਬੇਲਾ ॥",
          "roman": "har simran kī saglī belā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਭੀ ਸਮਾ ਸਿਮਰਨ ਵਿਚ ਗੁਜ਼ਾਰਿਆ ਜਾਏ ਉਹੀ ਚੰਗਾ ਹੈ) ਹਰੇਕ ਸਮਾ ਸਿਮਰਨ ਵਾਸਤੇ ਢੁਕਵਾਂ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Любое время пригодно для памятования о Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49170,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨੁ ਬਹੁ ਮਾਹਿ ਇਕੇਲਾ ॥",
          "roman": "har simran bah māh ikelā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਅਨੇਕਾਂ ਵਿਚੋਂ ਕੋਈ ਵਿਰਲਾ ਮਨੁੱਖ ਹੀ ਹਰਿ-ਨਾਮ ਦਾ ਸਿਮਰਨ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "но среди многих лишь редкий человек совершает памятование Имени Хари."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49171,
          "is_rahao": false,
          "gurmukhi": "ਜਾਤਿ ਅਜਾਤਿ ਜਪੈ ਜਨੁ ਕੋਇ ॥",
          "roman": "jāt ajāt japē jan koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉੱਚੀ ਜਾਤਿ ਦਾ ਹੋਵੇ ਚਾਹੇ ਨੀਵੀਂ ਜਾਤਿ ਦਾ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Будь человек высокой касты или низкой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49172,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਾਪੈ ਤਿਸ ਕੀ ਗਤਿ ਹੋਇ ॥੩॥",
          "roman": "jo jāpē tis kī gat hoi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਭੀ ਮਨੁੱਖ ਨਾਮ ਜਪਦਾ ਹੈ ਉਸ ਦੀ ਆਤਮਕ ਅਵਸਥਾ ਉੱਚੀ ਹੋ ਜਾਂਦੀ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "если он повторяет Имя, его духовное состояние становится высоким ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49173,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕਾ ਨਾਮੁ ਜਪੀਐ ਸਾਧਸੰਗਿ ॥",
          "roman": "har kā nām japīai sādhsaṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਾਧ ਸੰਗਤ ਵਿਚ (ਰਹਿ ਕੇ) ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Имя Бога можно повторять, пребывая в Садх Сангат,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49174,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਕੇ ਨਾਮ ਕਾ ਪੂਰਨ ਰੰਗੁ ॥",
          "roman": "har ke nām kā pūran raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸਾਧ ਸੰਗਤ ਦੀ ਸਹਾਇਤਾ ਨਾਲ ਹੀ) ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਦਾ ਪੂਰਾ ਰੰਗ (ਮਨੁੱਖ ਦੀ ਜ਼ਿੰਦਗੀ ਉਤੇ ਚੜ੍ਹਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "и только с помощью Садх Сангат полный цвет Имени Бога восходит на человеческую жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49175,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਕਉ ਪ੍ਰਭ ਕਿਰਪਾ ਧਾਰਿ ॥",
          "roman": "Nānak kau prabh kirpā dhār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਆਪਣੇ ਦਾਸ) ਨਾਨਕ ਉਤੇ ਮਿਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху, окажи милость Нанаку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49176,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਹਰਿ ਦੇਹੁ ਚਿਤਾਰਿ ॥੪॥੩੬॥੪੯॥",
          "roman": "sās sās har deh chitār ॥4॥36॥49॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਰੀ! (ਮੈਨੂੰ ਆਪਣੇ ਨਾਮ ਦੀ ਦਾਤਿ) ਦੇਹ (ਤਾ ਕਿ) ਮੈਂ (ਆਪਣੇ) ਹਰੇਕ ਸਾਹ ਦੇ ਨਾਲ (ਤੇਰਾ ਨਾਮ) ਚੇਤੇ ਕਰਦਾ ਰਹਾਂ ॥੪॥੩੬॥੪੯॥"
            },
            "sahib_singh_ru": {
              "main": "О Хари, даруй мне дар Имени, чтобы с каждым дыханием я помнил Тебя ॥4॥36॥49॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4112,
      "rahao_verse_id": 49183,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49177,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49178,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਾਸਤੁ ਆਪੇ ਬੇਦੁ ॥",
          "roman": "āpe sāsat āpe bed ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਉਹ (ਪਰਮਾਤਮਾ) ਆਪ ਹੀ (ਤੇਰੇ ਵਾਸਤੇ) ਸ਼ਾਸਤ੍ਰ ਹੈ, ਉਹ (ਪਰਮਾਤਮਾ) ਆਪ ਹੀ (ਤੇਰੇ ਵਾਸਤੇ) ਵੇਦ ਹੈ (ਭਾਵ, ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਹੀ ਤੇਰੇ ਵਾਸਤੇ ਵੇਦ ਸ਼ਾਸਤ੍ਰ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, Он Сам и есть для тебя шастры, Он Сам и есть для тебя веды, то есть Имя Бога и есть для тебя веды и шастры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49179,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਘਟਿ ਘਟਿ ਜਾਣੈ ਭੇਦੁ ॥",
          "roman": "āpe ghaṭ ghaṭ jāṇē bhed ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਹ ਪਰਮਾਤਮਾ ਆਪ ਹੀ ਹਰੇਕ ਸਰੀਰ ਵਿਚ (ਵੱਸ ਰਿਹਾ ਹੈ), ਉਹ ਆਪ ਹੀ (ਹਰੇਕ ਜੀਵ ਦੇ ਦਿਲ ਦਾ) ਭੇਦ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О ум, этот Бог Сам пребывает в каждом теле и Сам знает тайну сердца каждого существа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49180,
          "is_rahao": false,
          "gurmukhi": "ਜੋਤਿ ਸਰੂਪ ਜਾ ਕੀ ਸਭ ਵਥੁ ॥",
          "roman": "jot sarūp jā kī sabh vath ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਇਹ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਜਿਸ (ਪਰਮਾਤਮਾ) ਦੀ (ਰਚੀ ਹੋਈ ਹੈ) ਉਹ ਨਿਰਾ ਨੂਰ ਹੀ ਨੂਰ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, вся эта вселенная сотворена Тем, Кто есть один лишь Свет."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49181,
          "is_rahao": false,
          "gurmukhi": "ਕਰਣ ਕਾਰਣ ਪੂਰਨ ਸਮਰਥੁ ॥੧॥",
          "roman": "karaṇ kāraṇ pūran samrath ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹੀ ਸਾਰੇ ਜਗਤ ਦਾ ਮੂਲ ਹੈ, ਉਹ ਸਭ ਥਾਈਂ ਮੌਜੂਦ ਹੈ, ਉਹ ਸਭ ਤਾਕਤਾਂ ਦਾ ਮਾਲਕ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Он и есть источник всего мира, Он присутствует повсюду, Он владыка всех сил ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49182,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਓਟ ਗਹਹੁ ਮਨ ਮੇਰੇ ॥",
          "roman": "prabh kī oṭ gahah man mere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਪਰਮਾਤਮਾ ਦਾ ਆਸਰਾ ਲਈ ਰੱਖ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, держись за опору Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49183,
          "is_rahao": true,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰਮੁਖਿ ਆਰਾਧਹੁ ਦੁਸਮਨ ਦੂਖੁ ਨ ਆਵੈ ਨੇਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "charaṇ kamal gurmukh ārādhah dusman dūkh na āvē nere ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨਾਂ ਦਾ ਆਰਾਧਨ ਕਰਿਆ ਕਰ, (ਜਿਹੜਾ ਮਨੁੱਖ ਇਹ ਉੱਦਮ ਕਰਦਾ ਹੈ, ਕੋਈ) ਵੈਰੀ (ਉਸ ਦੇ) ਨੇੜੇ ਨਹੀਂ ਆਉਂਦੇ, ਕੋਈ ਦੁੱਖ (ਉਸ ਦੇ) ਨੇੜੇ ਨਹੀਂ ਆਉਂਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Приняв прибежище Гуру, почитай прекрасные стопы Бога. Тому, кто совершает такое усилие, ни враг не подходит близко, ни страдание не подходит близко ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49184,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਵਣੁ ਤ੍ਰਿਣੁ ਤ੍ਰਿਭਵਣ ਸਾਰੁ ॥",
          "roman": "āpe vaṇ triṇ tribhavaṇ sār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਮਨ! ਉਹ (ਪ੍ਰਭੂ) ਆਪ ਹੀ (ਹਰੇਕ) ਜੰਗਲ (ਨੂੰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ) ਹੈ, (ਸਾਰੀ) ਵਨਸਪਤੀ (ਨੂੰ ਪੈਦਾ ਕਰਨ ਵਾਲਾ) ਹੈ, ਉਹ ਆਪ ਹੀ ਤਿੰਨਾਂ ਭਵਨਾਂ ਦਾ ਮੂਲ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О мой ум, Он Сам является Творцом каждого леса, Творцом всей растительности, Он Сам — основа трёх миров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49185,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸੂਤਿ ਪਰੋਇਆ ਸੰਸਾਰੁ ॥",
          "roman": "jā kē sūt paroiā sansār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ ਐਸਾ ਹੈ) ਜਿਸ ਦੇ ਹੁਕਮ ਵਿਚ ਸਾਰਾ ਜਗਤ ਪ੍ਰੋਤਾ ਹੋਇਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Весь мир нанизан на нить Его повеления."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49186,
          "is_rahao": false,
          "gurmukhi": "ਆਪੇ ਸਿਵ ਸਕਤੀ ਸੰਜੋਗੀ ॥",
          "roman": "āpe siv saktī sanjogī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਉਹ ਆਪ ਹੀ ਜੀਵਾਤਮਾ ਤੇ ਪ੍ਰਕ੍ਰਿਤੀ ਨੂੰ ਜੋੜਨ ਵਾਲਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О ум, Он Сам соединяет душу и природу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49187,
          "is_rahao": false,
          "gurmukhi": "ਆਪਿ ਨਿਰਬਾਣੀ ਆਪੇ ਭੋਗੀ ॥੨॥",
          "roman": "āp nirbāṇī āpe bhogī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਆਪ ਹੀ (ਸਭ ਤੋਂ ਵੱਖਰਾ) ਵਾਸਨਾ-ਰਹਿਤ ਹੈ, ਉਹ ਆਪ ਹੀ (ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੋ ਕੇ ਸਾਰੇ ਭੋਗ) ਭੋਗਣ ਵਾਲਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Он Сам свободен от желаний и Сам, пронизывая всё, вкушает все наслаждения ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49188,
          "is_rahao": false,
          "gurmukhi": "ਜਤ ਕਤ ਪੇਖਉ ਤਤ ਤਤ ਸੋਇ ॥",
          "roman": "jat kat pekhau tat tat soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਜਿਧਰ ਕਿਧਰ ਵੇਖਦਾ ਹਾਂ, ਹਰ ਥਾਂ ਉਹ ਪ੍ਰਭੂ ਆਪ ਹੀ ਮੌਜੂਦ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни посмотрел, всюду присутствует только Он,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49189,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਬਿਨੁ ਦੂਜਾ ਨਾਹੀ ਕੋਇ ॥",
          "roman": "tis bin dūjā nāhī koi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਤੋਂ ਬਿਨਾ (ਕਿਤੇ ਭੀ) ਕੋਈ ਹੋਰ ਦੂਜਾ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "кроме Него нет никого другого."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49190,
          "is_rahao": false,
          "gurmukhi": "ਸਾਗਰੁ ਤਰੀਐ ਨਾਮ ਕੈ ਰੰਗਿ ॥",
          "roman": "sāgar tarīē nām kē raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਪਰਮਾਤਮ ਦੇ) ਨਾਮ ਵਿਚ ਪਿਆਰ ਪਾਇਆਂ ਹੀ ਇਸ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਸਕੀਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только полюбив Его Имя, можно переправиться через этот мировой океан."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49191,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵੈ ਨਾਨਕੁ ਸਾਧਸੰਗਿ ॥੩॥",
          "roman": "guṇ gāvē Nānak sādhsaṅg ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ (ਭੀ) ਸਾਧ ਸੰਗਤ ਵਿਚ (ਰਹਿ ਕੇ ਉਸੇ ਪਰਮਾਤਮਾ ਦੇ) ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак тоже, пребывая в Садх Сангат, поёт достоинства того же Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49192,
          "is_rahao": false,
          "gurmukhi": "ਮੁਕਤਿ ਭੁਗਤਿ ਜੁਗਤਿ ਵਸਿ ਜਾ ਕੈ ॥",
          "roman": "mukt bhugat jugat vas jā kē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਾਂ ਨੂੰ) ਮੁਕਤੀ (ਦੇਣੀ, ਜੀਵਾਂ ਨੂੰ ਖਾਣ-ਪੀਣ ਨੂੰ) ਭੋਜਨ (ਦੇਣਾ, ਜੀਵਾਂ ਨੂੰ) ਜੀਵਨ-ਤੋਰੇ ਤੋਰਨਾ- ਇਹ ਸਭ ਕੁਝ ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਵੱਸ ਵਿਚ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Даровать освобождение, давать пищу существам, указывать существам способ жизни — всё это находится во власти Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49193,
          "is_rahao": false,
          "gurmukhi": "ਊਣਾ ਨਾਹੀ ਕਿਛੁ ਜਨ ਤਾ ਕੈ ॥",
          "roman": "ūṇā nāhī kichh jan tā kē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਘਰ ਵਿਚ (ਕਿਸੇ ਚੀਜ਼ ਦੀ) ਕੋਈ ਕਮੀ ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В Его доме нет недостатка ни в чём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49194,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਜਿਸੁ ਹੋਇ ਸੁਪ੍ਰਸੰਨ ॥",
          "roman": "kar kirpā jis hoi suprasann ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਜਿਸ ਜਿਸ ਮਨੁੱਖ ਉੱਤੇ ਪਰਮਾਤਮਾ ਦਇਆਵਾਨ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "На кого Бог по милости Своей становится благосклонен,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49195,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਦਾਸ ਸੇਈ ਜਨ ਧੰਨ ॥੪॥੩੭॥੫੦॥",
          "roman": "Nānak dās seī jan dhann ॥4॥37॥50॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਾਸ ਨਾਨਕ! ਉਹੀ ਸਾਰੇ ਬੰਦੇ (ਅਸਲ) ਭਾਗਾਂ ਵਾਲੇ ਹਨ ॥੪॥੩੭॥੫੦॥"
            },
            "sahib_singh_ru": {
              "main": "о слуга Нанак, только такие люди поистине благословенны ॥4॥37॥50॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4113,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49196,
          "is_rahao": false,
          "gurmukhi": "ਭੈਰਉ ਮਹਲਾ ੫ ॥",
          "roman": "Bhērau mehlā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49197,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਾ ਮਨਿ ਆਨੰਦੁ ਗੋਬਿੰਦ ॥",
          "roman": "bhagtā man ānand gobind ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਦੇ ਮਨ ਵਿਚ ਸਦਾ ਆਤਮਕ ਹੁਲਾਰਾ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В уме преданных Бога всегда пребывает духовная радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49198,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਤਿ ਭਏ ਬਿਨਸੀ ਸਭ ਚਿੰਦ ॥",
          "roman": "asthit bhae binsī sabh chind ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਦੁਨੀਆ ਦੇ ਡਰਾਂ, ਦੁਨੀਆ ਦੀਆਂ ਭਟਕਣਾਂ ਵਲੋਂ ਉਹਨਾਂ ਦੇ ਅੰਦਰ ਸਦਾ) ਅਡੋਲਤਾ ਰਹਿੰਦੀ ਹੈ (ਦੁਨੀਆ ਦੇ ਡਰਾਂ ਦਾ ਉਹਨਾਂ ਨੂੰ) ਚਿਤ-ਚੇਤਾ ਭੀ ਨਹੀਂ ਰਹਿੰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри них всегда сохраняется устойчивость перед страхами и блужданиями мира, и у них уже нет даже мысли о мирских страхах."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
