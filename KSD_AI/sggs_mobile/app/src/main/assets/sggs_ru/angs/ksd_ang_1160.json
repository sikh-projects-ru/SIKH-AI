{
  "ang": 1160,
  "shabads": [
    {
      "shabad_id": 4136,
      "rahao_verse_id": 49633,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49632,
          "is_rahao": true,
          "gurmukhi": "ਹੈ ਹਜੂਰਿ ਕਤ ਦੂਰਿ ਬਤਾਵਹੁ ॥",
          "roman": "hē hajūr kat dūr batāvah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਮੁੱਲਾਂ!) ਰੱਬ ਹਰ ਥਾਂ ਹਾਜ਼ਰ-ਨਾਜ਼ਰ ਹੈ, ਤੁਸੀਂ ਉਸ ਨੂੰ ਦੂਰ (ਕਿਤੇ ਸਤਵੇਂ ਅਸਮਾਨ ਤੇ) ਕਿਉਂ (ਬੈਠਾ) ਦੱਸਦੇ ਹੋ?"
            },
            "sahib_singh_ru": {
              "main": "О муллы, Бог присутствует везде — зачем же вы говорите, будто Он где-то далеко?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49633,
          "is_rahao": true,
          "gurmukhi": "ਦੁੰਦਰ ਬਾਧਹੁ ਸੁੰਦਰ ਪਾਵਹੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "dundar bādhah sundar pāvah ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਉਸ ਸੁਹਣੇ ਰੱਬ ਨੂੰ ਮਿਲਣਾ ਹੈ, ਤਾਂ ਕਾਮਾਦਿਕ ਰੌਲਾ ਪਾਣ ਵਾਲੇ ਵਿਕਾਰਾਂ ਨੂੰ ਕਾਬੂ ਵਿਚ ਰੱਖੋ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Если хотите встретить этого Прекрасного Бога, держите под контролем шумные страсти и пороки ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49634,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਸੋ ਜੁ ਕਾਇਆ ਬੀਚਾਰੈ ॥",
          "roman": "kājī so ju kāiā bīchārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਕਾਜ਼ੀ ਉਹ ਹੈ ਜੋ ਆਪਣੇ ਸਰੀਰ ਨੂੰ ਖੋਜੇ,"
            },
            "sahib_singh_ru": {
              "main": "Истинный кази — тот, кто исследует своё тело,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49635,
          "is_rahao": false,
          "gurmukhi": "ਕਾਇਆ ਕੀ ਅਗਨਿ ਬ੍ਰਹਮੁ ਪਰਜਾਰੈ ॥",
          "roman": "kāiā kī agan brahm parjārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਰੀਰ ਵਿਚ ਪ੍ਰਭੂ ਦੀ ਜੋਤ ਨੂੰ ਰੌਸ਼ਨ ਕਰੇ,"
            },
            "sahib_singh_ru": {
              "main": "кто разжигает в теле Божественный свет,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49636,
          "is_rahao": false,
          "gurmukhi": "ਸੁਪਨੈ ਬਿੰਦੁ ਨ ਦੇਈ ਝਰਨਾ ॥",
          "roman": "supnē bind na deī jharnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁਪਨੇ ਵਿਚ ਭੀ ਕਾਮ ਦੀ ਵਾਸ਼ਨਾ ਮਨ ਵਿਚ ਨਾਹ ਆਉਣ ਦੇਵੇ।"
            },
            "sahib_singh_ru": {
              "main": "кто даже во сне не позволяет возникнуть в уме похоти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49637,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਕਾਜੀ ਕਉ ਜਰਾ ਨ ਮਰਨਾ ॥੨॥",
          "roman": "tis kājī kau jarā na marnā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਜਿਹੇ ਕਾਜ਼ੀ ਨੂੰ ਬੁਢੇਪੇ ਤੇ ਮੌਤ ਦਾ ਡਰ ਨਹੀਂ ਰਹਿ ਜਾਂਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Такому кази уже не страшны старость и смерть ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49638,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਰਤਾਨੁ ਜੁ ਦੁਇ ਸਰ ਤਾਨੈ ॥",
          "roman": "so suratān ju dui sar tānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਸਲ ਸੁਲਤਾਨ (ਬਾਦਸ਼ਾਹ) ਉਹ ਹੈ ਜੋ (ਗਿਆਨ ਤੇ ਵੈਰਾਗ ਦੇ) ਦੋ ਤੀਰ ਤਾਣਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Истинный султан — тот, кто натягивает два стрелы — знания и отрешённости,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49639,
          "is_rahao": false,
          "gurmukhi": "ਬਾਹਰਿ ਜਾਤਾ ਭੀਤਰਿ ਆਨੈ ॥",
          "roman": "bāhar jātā bhītar ānē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਹਰ ਦੁਨੀਆ ਦੇ ਪਦਾਰਥਾਂ ਵਲ ਭਟਕਦੇ ਮਨ ਨੂੰ ਅੰਦਰ ਵਲ ਲੈ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "кто возвращает внутрь ум, блуждающий вовне среди мирских вещей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49640,
          "is_rahao": false,
          "gurmukhi": "ਗਗਨ ਮੰਡਲ ਮਹਿ ਲਸਕਰੁ ਕਰੈ ॥",
          "roman": "gagan maṇḍal mah laskar karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਜੁੜ ਕੇ ਆਪਣੇ ਅੰਦਰ ਭਲੇ ਗੁਣ ਪੈਦਾ ਕਰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "кто, соединившись со стопами Бога, порождает в себе добрые качества."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49641,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਰਤਾਨੁ ਛਤ੍ਰੁ ਸਿਰਿ ਧਰੈ ॥੩॥",
          "roman": "so suratān chhatr sir dharē ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਸੁਲਤਾਨ ਆਪਣੇ ਸਿਰ ਤੇ (ਅਸਲ) ਛਤਰ ਝੁਲਵਾਉਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Такой султан и носит над своей головой истинный царский зонт ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49642,
          "is_rahao": false,
          "gurmukhi": "ਜੋਗੀ ਗੋਰਖੁ ਗੋਰਖੁ ਕਰੈ ॥",
          "roman": "jogī Gorakh Gorakh karē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋਗੀ (ਪ੍ਰਭੂ ਨੂੰ ਵਿਸਾਰ ਕੇ) ਗੋਰਖ ਗੋਰਖ ਜਪਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Йог, забыв Бога, повторяет: «Горакх, Горакх»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49643,
          "is_rahao": false,
          "gurmukhi": "ਹਿੰਦੂ ਰਾਮ ਨਾਮੁ ਉਚਰੈ ॥",
          "roman": "hindū rām nām ucharē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਿੰਦੂ (ਸ੍ਰੀ ਰਾਮ ਚੰਦਰ ਦੀ ਮੂਰਤੀ ਵਿਚ ਹੀ ਮਿਥੇ ਹੋਏ) ਰਾਮ ਦਾ ਨਾਮ ਉਚਾਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "индус произносит имя Рам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49644,
          "is_rahao": false,
          "gurmukhi": "ਮੁਸਲਮਾਨ ਕਾ ਏਕੁ ਖੁਦਾਇ ॥",
          "roman": "musalmān kā eku khudāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੁਸਲਮਾਨ ਨੇ (ਸਤਵੇਂ ਅਸਮਾਨ ਵਿਚ ਬੈਠਾ ਹੋਇਆ) ਨਿਰਾ ਆਪਣਾ (ਮੁਸਲਮਾਨਾਂ ਦਾ ਹੀ) ਰੱਬ ਮੰਨ ਰੱਖਿਆ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "мусульманин признаёт только своего собственного Бога, будто сидящего на седьмом небе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49645,
          "is_rahao": false,
          "gurmukhi": "ਕਬੀਰ ਕਾ ਸੁਆਮੀ ਰਹਿਆ ਸਮਾਇ ॥੪॥੩॥੧੧॥",
          "roman": "Kabīr kā suāmī rahiā samāi ॥4॥3॥11॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੇਰਾ ਕਬੀਰ ਦਾ ਪ੍ਰਭੂ ਉਹ ਹੈ, ਜੋ ਸਭ ਵਿਚ ਵਿਆਪਕ ਹੈ (ਤੇ ਸਭ ਦਾ ਸਾਂਝਾ ਹੈ) ॥੪॥੩॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но Господь Кабира — Тот, Кто пронизывает всё и присутствует во всех ॥4॥3॥11॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4137,
      "rahao_verse_id": 49652,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49646,
          "is_rahao": false,
          "gurmukhi": "ਮਹਲਾ ੫ ॥",
          "roman": "mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49647,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਪਾਥਰ ਕਉ ਕਹਤੇ ਦੇਵ ॥",
          "roman": "jo pāthar kau kahte dev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪੱਥਰ (ਦੀ ਮੂਰਤੀ) ਨੂੰ ਰੱਬ ਆਖਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые называют камень «богом»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49648,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕੀ ਬਿਰਥਾ ਹੋਵੈ ਸੇਵ ॥",
          "roman": "tā kī birthā hovē sev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੀ ਕੀਤੀ ਸੇਵਾ ਵਿਅਰਥ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "их служение проходит напрасно."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49649,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਪਾਥਰ ਕੀ ਪਾਂਈ ਪਾਇ ॥",
          "roman": "jo pāthar kī pāṅī pāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੋ ਮਨੁੱਖ ਪੱਥਰ (ਦੀ ਮੂਰਤੀ) ਦੇ ਪੈਰੀਂ ਪੈਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Те люди, которые падают к ногам камня «идола»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49650,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸ ਕੀ ਘਾਲ ਅਜਾਂਈ ਜਾਇ ॥੧॥",
          "roman": "tis kī ghāl ajāṅī jāe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੀ ਮਿਹਨਤ ਅਜਾਈਂ ਚਲੀ ਜਾਂਦੀ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "их усилие уходит впустую ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49651,
          "is_rahao": true,
          "gurmukhi": "ਠਾਕੁਰੁ ਹਮਰਾ ਸਦ ਬੋਲੰਤਾ ॥",
          "roman": "ṭhākur hamrā sad bolantā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਾਡਾ ਠਾਕੁਰ ਸਦਾ ਬੋਲਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Наш Тхакур всегда говорит,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49652,
          "is_rahao": true,
          "gurmukhi": "ਸਰਬ ਜੀਆ ਕਉ ਪ੍ਰਭੁ ਦਾਨੁ ਦੇਤਾ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "sarab jīā kau prabh dān detā ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਪ੍ਰਭੂ ਸਾਰੇ ਜੀਵਾਂ ਨੂੰ ਦਾਤਾਂ ਦੇਣ ਵਾਲਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "этот Бог даёт дары всем существам ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49653,
          "is_rahao": false,
          "gurmukhi": "ਅੰਤਰਿ ਦੇਉ ਨ ਜਾਨੈ ਅੰਧੁ ॥",
          "roman": "antar deu na jānē andh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਨ੍ਹਾ ਮੂਰਖ ਆਪਣੇ ਅੰਦਰ-ਵੱਸਦੇ ਰੱਬ ਨੂੰ ਨਹੀਂ ਪਛਾਣਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Слепой глупец не узнаёт Бога, живущего внутри него,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49654,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਮ ਕਾ ਮੋਹਿਆ ਪਾਵੈ ਫੰਧੁ ॥",
          "roman": "bhram kā mohiā pāvē phandh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਭਰਮ ਦਾ ਮਾਰਿਆ ਹੋਇਆ ਹੋਰ ਹੋਰ ਜਾਲ ਵਿਛਾਉਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "и, поражённый заблуждением, расставляет всё новые сети."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49655,
          "is_rahao": false,
          "gurmukhi": "ਨ ਪਾਥਰੁ ਬੋਲੈ ਨਾ ਕਿਛੁ ਦੇਇ ॥",
          "roman": "na pāthar bolē nā kichh dei ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਪੱਥਰ ਨਾਹ ਬੋਲਦਾ ਹੈ, ਨਾਹ ਕੁਝ ਦੇ ਸਕਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот камень не говорит и не может ничего дать,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49656,
          "is_rahao": false,
          "gurmukhi": "ਫੋਕਟ ਕਰਮ ਨਿਹਫਲ ਹੈ ਸੇਵ ॥੨॥",
          "roman": "phokat karam nihphal hē sev ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਨੂੰ ਇਸ਼ਨਾਨ ਕਰਾਣ ਤੇ ਭੋਗ ਆਦਿਕ ਲਵਾਣ ਦੇ) ਸਾਰੇ ਕੰਮ ਵਿਅਰਥ ਹਨ, (ਇਸ ਦੀ ਸੇਵਾ ਵਿਚੋਂ ਕੋਈ ਫਲ ਨਹੀਂ ਮਿਲਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "все дела «омовение, подношения и прочее» напрасны, из служения ему не получается никакого плода ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49657,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਮਿਰਤਕ ਕਉ ਚੰਦਨੁ ਚੜਾਵੈ ॥",
          "roman": "je mirtak kau chandan chaṛhāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਕੋਈ ਮਨੁੱਖ ਮੁਰਦੇ ਨੂੰ ਚੰਦਨ (ਰਗੜ ਕੇ) ਲਾ ਦੇਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Если кто-то намажет мёртвого сандалом,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49658,
          "is_rahao": false,
          "gurmukhi": "ਉਸ ਤੇ ਕਹਹੁ ਕਵਨ ਫਲ ਪਾਵੈ ॥",
          "roman": "us te kahah kavan phal pāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮੁਰਦੇ ਨੂੰ ਕੋਈ (ਇਸ ਸੇਵਾ ਦਾ) ਫਲ ਨਹੀਂ ਮਿਲ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "то этот мёртвый не может получить никакого плода от такого служения."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49659,
          "is_rahao": false,
          "gurmukhi": "ਜੇ ਮਿਰਤਕ ਕਉ ਬਿਸਟਾ ਮਾਹਿ ਰੁਲਾਈ ॥",
          "roman": "je mirtak kau bisṭā māh rulāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ, ਜੇ ਕੋਈ ਮੁਰਦੇ ਨੂੰ ਗੰਦ ਵਿਚ ਰੋਲ ਦੇਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "А если кто-то вываляет мёртвого в грязи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49660,
          "is_rahao": false,
          "gurmukhi": "ਤਾਂ ਮਿਰਤਕ ਕਾ ਕਿਆ ਘਟਿ ਜਾਈ ॥੩॥",
          "roman": "tāṅ mirtak kā kiā ghaṭ jāī ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਉਸ ਮੁਰਦੇ ਦਾ ਕੋਈ ਵਿਗਾੜ ਨਹੀਂ ਹੋ ਸਕਦਾ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "то и тогда с этим мёртвым ничего не случится, ущерба не будет ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49661,
          "is_rahao": false,
          "gurmukhi": "ਕਹਤ ਕਬੀਰ ਹਉ ਕਹਉ ਪੁਕਾਰਿ ॥",
          "roman": "kahat Kabīr hau kahau pukār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ ਕਿ ਮੈਂ ਪੁਕਾਰ ਪੁਕਾਰ ਕੇ ਆਖਦਾ ਹਾਂ"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: я взываю и взываю,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49662,
          "is_rahao": false,
          "gurmukhi": "ਸਮਝਿ ਦੇਖੁ ਸਾਕਤ ਗਾਵਾਰ ॥",
          "roman": "samajh dekh sākat gavār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਰੱਬ ਨਾਲੋਂ ਟੁੱਟੇ ਹੋਏ ਮੂਰਖ! ਸਮਝ ਕੇ ਵੇਖ,"
            },
            "sahib_singh_ru": {
              "main": "эй, оторванный от Бога глупец, постарайся понять,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49663,
          "is_rahao": false,
          "gurmukhi": "ਦੂਜੈ ਭਾਇ ਬਹੁਤੁ ਘਰ ਗਾਲੇ ॥",
          "roman": "dūjē bhāe bahut ghar gāle ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੱਬ ਨੂੰ ਛੱਡ ਕੇ ਹੋਰ ਹੋਰ ਵਿਚ ਪਿਆਰ ਪਾ ਕੇ ਬਥੇਰੇ ਜੀਵ ਤਬਾਹ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "привязавшись с любовью ко всему иному, кроме Бога, многие существа погубили себя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49664,
          "is_rahao": false,
          "gurmukhi": "ਰਾਮ ਭਗਤ ਹੈ ਸਦਾ ਸੁਖਾਲੇ ॥੪॥੪॥੧੨॥",
          "roman": "rām bhagat hē sadā sukhāle ॥4॥4॥12॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਸੁਖੀ ਜੀਵਨ ਵਾਲੇ ਸਿਰਫ਼ ਉਹੀ ਹਨ ਜੋ ਪ੍ਰਭੂ ਦੇ ਭਗਤ ਹਨ' ॥੪॥੪॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "По-настоящему счастливы всегда только те, кто являются преданными Бога ॥4॥4॥12॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4138,
      "rahao_verse_id": 49670,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49665,
          "is_rahao": false,
          "gurmukhi": "ਜਲ ਮਹਿ ਮੀਨ ਮਾਇਆ ਕੇ ਬੇਧੇ ॥",
          "roman": "jal mah mīn māiā ke bedhe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਾਣੀ ਵਿਚ ਰਹਿਣ ਵਾਲੀਆਂ ਮੱਛੀਆਂ ਮਾਇਆ ਵਿਚ ਵਿੱਝੀਆਂ ਪਈਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Живущие в воде рыбы пронзены майей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49666,
          "is_rahao": false,
          "gurmukhi": "ਦੀਪਕ ਪਤੰਗ ਮਾਇਆ ਕੇ ਛੇਦੇ ॥",
          "roman": "dīpak pataṅg māiā ke chhede ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੀਵਿਆਂ ਉੱਤੇ (ਸੜਨ ਵਾਲੇ) ਭੰਬਟ ਮਾਇਆ ਵਿਚ ਪ੍ਰੋਤੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "мотыльки, сгорающие на огне светильника, тоже пронзены майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49667,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਮਾਇਆ ਕੁੰਚਰ ਕਉ ਬਿਆਪੈ ॥",
          "roman": "kām māiā kunchar kau biāpē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਾਮ-ਵਾਸ਼ਨਾ ਰੂਪ ਮਾਇਆ ਹਾਥੀ ਉੱਤੇ ਦਬਾਉ ਪਾਂਦੀ ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Майя в форме похоти давит на слона,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49668,
          "is_rahao": false,
          "gurmukhi": "ਭੁਇਅੰਗਮ ਭ੍ਰਿੰਗ ਮਾਇਆ ਮਹਿ ਖਾਪੇ ॥੧॥",
          "roman": "bhuiangam bhriṅg māiā mahi khāpe ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੱਪ ਤੇ ਭੌਰੇ ਭੀ ਮਾਇਆ ਵਿਚ ਦੁਖੀ ਹੋ ਰਹੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "змеи и шмели тоже мучаются в майе ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49669,
          "is_rahao": true,
          "gurmukhi": "ਮਾਇਆ ਐਸੀ ਮੋਹਨੀ ਭਾਈ ॥",
          "roman": "māiā aisī mohṇī bhāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਮਾਇਆ ਇਤਨੀ ਬਲ ਵਾਲੀ, ਮੋਹਣ ਵਾਲੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О брат, майя так сильна и так чарующа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49670,
          "is_rahao": true,
          "gurmukhi": "ਜੇਤੇ ਜੀਅ ਤੇਤੇ ਡਹਕਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jete jīa tete ḍahkāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਜਿਤਨੇ ਭੀ ਜੀਵ (ਜਗਤ ਵਿਚ) ਹਨ, ਸਭ ਨੂੰ ਡੁਲਾ ਦੇਂਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "что сколько ни есть существ в мире, всех она раскачивает и сбивает ॥1॥ Рахау ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49671,
          "is_rahao": false,
          "gurmukhi": "ਪੰਖੀ ਮ੍ਰਿਗ ਮਾਇਆ ਮਹਿ ਰਾਤੇ ॥",
          "roman": "paṅkhī mrig māiā mah rāte ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੰਛੀ, ਜੰਗਲ ਦੇ ਪਸ਼ੂ ਸਭ ਮਾਇਆ ਵਿਚ ਰੰਗੇ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Птицы и лесные звери все окрашены майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49672,
          "is_rahao": false,
          "gurmukhi": "ਸਾਕਰ ਮਾਖੀ ਅਧਿਕ ਸੰਤਾਪੇ ॥",
          "roman": "sākar mākhī adhik santāpe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ਼ੱਕਰ-ਰੂਪ ਮਾਇਆ ਮੱਖੀ ਨੂੰ ਬੜਾ ਦੁਖੀ ਕਰ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Майя, подобная сахару, сильно мучает муху."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49673,
          "is_rahao": false,
          "gurmukhi": "ਤੁਰੇ ਉਸਟ ਮਾਇਆ ਮਹਿ ਭੇਲਾ ॥",
          "roman": "ture usaṭ māiā mah bhelā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘੋੜੇ ਊਠ ਸਭ ਮਾਇਆ ਵਿਚ ਫਸੇ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Кони и верблюды все запутались в майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49674,
          "is_rahao": false,
          "gurmukhi": "ਸਿਧ ਚਉਰਾਸੀਹ ਮਾਇਆ ਮਹਿ ਖੇਲਾ ॥੨॥",
          "roman": "sidh chaurāsīh māiā mahi khelā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਚੌਰਾਸੀਹ ਸਿੱਧ ਭੀ ਮਾਇਆ ਵਿਚ ਖੇਡ ਰਹੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Даже восемьдесят четыре сиддха играют в майе ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49675,
          "is_rahao": false,
          "gurmukhi": "ਛਿਅ ਜਤੀ ਮਾਇਆ ਕੇ ਬੰਦਾ ॥",
          "roman": "chhiā jatī māiā ke bandā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਤੀ ਭੀ ਮਾਇਆ ਦੇ ਹੀ ਗ਼ੁਲਾਮ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Даже джати являются рабами майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49676,
          "is_rahao": false,
          "gurmukhi": "ਨਵੈ ਨਾਥ ਸੂਰਜ ਅਰੁ ਚੰਦਾ ॥",
          "roman": "navē nāth sūraj aru chandā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨੌ ਨਾਥ ਸੂਰਜ (ਦੇਵਤਾ) ਅਤੇ ਚੰਦ੍ਰਮਾ (ਦੇਵਤਾ)"
            },
            "sahib_singh_ru": {
              "main": "Девять натхов, солнце «божество» и луна «божество»"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49677,
          "is_rahao": false,
          "gurmukhi": "ਤਪੇ ਰਖੀਸਰ ਮਾਇਆ ਮਹਿ ਸੂਤਾ ॥",
          "roman": "tape rakhīsar māiā mah sūtā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੱਡੇ ਵੱਡੇ ਤਪੀ ਤੇ ਰਿਸ਼ੀ ਸਭ ਮਾਇਆ ਵਿਚ ਸੁੱਤੇ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "великие тапасы и риши «все» спят в майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49678,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਮਹਿ ਕਾਲੁ ਅਰੁ ਪੰਚ ਦੂਤਾ ॥੩॥",
          "roman": "māiā mahi kāl aru panch dūtā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੌਤ (ਦਾ ਸਹਿਮ) ਤੇ ਪੰਜੇ ਵਿਕਾਰ ਭੀ ਮਾਇਆ ਵਿਚ ਹੀ (ਜੀਵਾਂ ਨੂੰ ਵਿਆਪਦੇ ਹਨ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Страх смерти и пять пороков тоже действуют на существ именно через майю ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49679,
          "is_rahao": false,
          "gurmukhi": "ਸੁਆਨ ਸਿਆਲ ਮਾਇਆ ਮਹਿ ਰਾਤਾ ॥",
          "roman": "suān siāl māiā mah rātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੁੱਤੇ, ਗਿੱਦੜ, ਬਾਂਦਰ, ਚਿੱਤ੍ਰੇ, ਸ਼ੇਰ ਸਭ ਮਾਇਆ ਵਿਚ ਰੰਗੇ ਪਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Собаки, шакалы, обезьяны, гепарды и львы все окрашены майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49680,
          "is_rahao": false,
          "gurmukhi": "ਬੰਤਰ ਚੀਤੇ ਅਰੁ ਸਿੰਘਾਤਾ ॥",
          "roman": "bantar chīte aru siṅghātā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਂਦਰ, ਚਿੱਤ੍ਰੇ, ਸ਼ੇਰ (ਸਭ ਮਾਇਆ ਵਿਚ ਉਲਝੇ ਪਏ ਹਨ।)"
            },
            "sahib_singh_ru": {
              "main": "Обезьяны, гепарды и львы «все запутаны в майе»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49681,
          "is_rahao": false,
          "gurmukhi": "ਮਾਂਜਾਰ ਗਾਡਰ ਅਰੁ ਲੂਬਰਾ ॥",
          "roman": "māṅjār gāḍar aru lūbrā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਿੱਲੇ, ਭੇਡਾਂ, ਲੂੰਬੜ,"
            },
            "sahib_singh_ru": {
              "main": "Кошки, овцы, лисы,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49682,
          "is_rahao": false,
          "gurmukhi": "ਬਿਰਖ ਮੂਲ ਮਾਇਆ ਮਹਿ ਪਰਾ ॥੪॥",
          "roman": "birakh mūl māiā mahi parā ॥4॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰੁੱਖ, ਕੰਦ-ਮੂਲ ਸਭ ਮਾਇਆ ਦੇ ਅਧੀਨ ਹਨ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "деревья и коренья «всё» находится во власти майи ॥4॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49683,
          "is_rahao": false,
          "gurmukhi": "ਮਾਇਆ ਅੰਤਰਿ ਭੀਨੇ ਦੇਵ ॥",
          "roman": "māiā antar bhīne dev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੇਵਤੇ ਭੀ ਮਾਇਆ (ਦੇ ਮੋਹ) ਵਿਚ ਭਿੱਜੇ ਹੋਏ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Даже божества промокли в майе «её чаре»."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49684,
          "is_rahao": false,
          "gurmukhi": "ਸਾਗਰ ਇੰਦ੍ਰਾ ਅਰੁ ਧਰਤੇਵ ॥",
          "roman": "sāgar indrā aru dhartev ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਮੁੰਦਰ, ਸ੍ਵਰਗ, ਧਰਤੀ ਇਹਨਾਂ ਸਭਨਾਂ ਦੇ ਜੀਵ ਮਾਇਆ ਵਿਚ ਹੀ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Океан, небеса и земля «все существа в них» тоже находятся в майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49685,
          "is_rahao": false,
          "gurmukhi": "ਕਹਿ ਕਬੀਰ ਜਿਸੁ ਉਦਰੁ ਤਿਸੁ ਮਾਇਆ ॥",
          "roman": "kah Kabīr jis udar tis māiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਬੀਰ ਆਖਦਾ ਹੈ ਕਿ (ਮੁੱਕਦੀ ਗੱਲ ਇਹ ਹੈ ਕਿ) ਜਿਸ ਨੂੰ ਢਿੱਡ ਲੱਗਾ ਹੋਇਆ ਹੈ ਉਸ ਨੂੰ (ਭਾਵ, ਹਰੇਕ ਜੀਵ ਨੂੰ) ਮਾਇਆ ਵਿਆਪ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Кабир говорит: суть дела такова, что тот, у кого есть живот «то есть всякое существо», охвачен майей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49686,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਛੂਟੇ ਜਬ ਸਾਧੂ ਪਾਇਆ ॥੫॥੫॥੧੩॥",
          "roman": "tab chhūṭe jab sādhū pāiā ॥5॥5॥13॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਗੁਰੂ ਮਿਲੇ ਤਦੋਂ ਹੀ ਜੀਵ ਮਾਇਆ ਦੇ ਪ੍ਰਭਾਵ ਤੋਂ ਬਚਦਾ ਹੈ ॥੫॥੫॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "Только когда встречается Гуру, существо спасается от воздействия майи ॥5॥5॥13॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4139,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49687,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਲਗੁ ਮੇਰੀ ਮੇਰੀ ਕਰੈ ॥",
          "roman": "jab lag merī merī karē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦ ਤਕ ਮਨੁੱਖ ਮਮਤਾ ਦੇ ਗੇੜ ਵਿਚ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Пока человек остаётся в круге «моё, моё»,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49688,
          "is_rahao": false,
          "gurmukhi": "ਤਬ ਲਗੁ ਕਾਜੁ ਏਕੁ ਨਹੀ ਸਰੈ ॥",
          "roman": "tab lag kāj ek nahī sarē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਦ ਤਕ ਇਸ ਦਾ (ਆਤਮਕ ਜੀਵਨ ਦਾ) ਇੱਕ ਕੰਮ ਭੀ ਨਹੀਂ ਸੌਰਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "до тех пор у него не устраивается ни одно дело духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49689,
          "is_rahao": false,
          "gurmukhi": "ਜਬ ਮੇਰੀ ਮੇਰੀ ਮਿਟਿ ਜਾਇ ॥",
          "roman": "jab merī merī miṭ jāe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਦੋਂ ਇਸ ਦੀ ਮਮਤਾ ਮਿਟ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда же его чувство «моё» исчезает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
