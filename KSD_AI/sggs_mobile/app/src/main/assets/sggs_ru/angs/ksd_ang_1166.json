{
  "ang": 1166,
  "shabads": [
    {
      "shabad_id": 4155,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49950,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਸਰ ਭਰਿ ਸੋਨਾ ਲੇਹੁ ॥੧੦॥",
          "roman": "nāme sar bhari sonā leh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਨਾਲ ਸਾਵਾਂ ਤੋਲ ਕੇ ਸੋਨਾ ਲੈ ਲੈ (ਤੇ ਇਸ ਨੂੰ ਛੱਡ ਦੇ) ॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "возьми золото, равное весу Намдева, и отпусти его. ॥10॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49951,
          "is_rahao": false,
          "gurmukhi": "ਮਾਲੁ ਲੇਉ ਤਉ ਦੋਜਕਿ ਪਰਉ ॥",
          "roman": "māl leu tau dojak parau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੇ ਉੱਤਰ ਦਿੱਤਾ) ਜੇ ਮੈਂ ਵੱਢੀ ਲਵਾਂ ਤਾਂ ਦੋਜ਼ਕ ਵਿਚ ਪੈਂਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Он ответил: если я возьму взятку, то попаду в ад,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49952,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨੁ ਛੋਡਿ ਦੁਨੀਆ ਕਉ ਭਰਉ ॥੧੧॥",
          "roman": "dīn chhoḍi dunīā kau bharau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਇਸ ਤਰ੍ਹਾਂ ਤਾਂ) ਮੈਂ ਮਜ਼ਹਬ ਛੱਡ ਕੇ ਦੌਲਤ ਇਕੱਠੀ ਕਰਦਾ ਹਾਂ ॥੧੧॥"
            },
            "sahib_singh_ru": {
              "main": "потому что так я оставлю веру и стану копить богатство. ॥11॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49953,
          "is_rahao": false,
          "gurmukhi": "ਪਾਵਹੁ ਬੇੜੀ ਹਾਥਹੁ ਤਾਲ ॥",
          "roman": "pāvah beṛī hāthah tāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਦੇ ਪੈਰਾਂ ਵਿਚ ਬੇੜੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "На ногах Намдева цепи,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49954,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਾ ਗਾਵੈ ਗੁਨ ਗੋਪਾਲ ॥੧੨॥",
          "roman": "nāmā gāvē gun gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਫਿਰ ਭੀ ਉਹ ਹੱਥਾਂ ਨਾਲ ਤਾਲ ਦੇ ਦੇ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਹੈ ॥੧੨॥"
            },
            "sahib_singh_ru": {
              "main": "но всё равно, отбивая ладонями такт, он поёт славу Богу. ॥12॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49955,
          "is_rahao": false,
          "gurmukhi": "ਗੰਗ ਜਮੁਨ ਜਉ ਉਲਟੀ ਬਹੈ ॥",
          "roman": "gaṅg jamun jau ulaṭī bahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੰਗਾ ਤੇ ਜਮਨਾ ਉਲਟੀਆਂ ਭੀ ਵਗਣ ਲੱਗ ਪੈਣ,"
            },
            "sahib_singh_ru": {
              "main": "Даже если Ганг и Ямуна потекут вспять,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49956,
          "is_rahao": false,
          "gurmukhi": "ਤਉ ਨਾਮਾ ਹਰਿ ਕਰਤਾ ਰਹੈ ॥੧੩॥",
          "roman": "tau nāmā har kartā rahē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਭੀ ਨਾਮਾ ਹਰੀ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹੇਗਾ (ਤੇ ਦਬਾਉ ਵਿਚ ਆ ਕੇ ਖ਼ੁਦਾ ਖ਼ੁਦਾ ਨਹੀਂ ਆਖੇਗਾ) ॥੧੩॥"
            },
            "sahib_singh_ru": {
              "main": "Нама всё равно будет петь славу Хари и не поддастся давлению, чтобы произносить 'Худай'. ॥13॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49957,
          "is_rahao": false,
          "gurmukhi": "ਸਾਤ ਘੜੀ ਜਬ ਬੀਤੀ ਸੁਣੀ ॥",
          "roman": "sāt ghaṛī jab bītī suṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬਾਦਸ਼ਾਹ ਨੇ ਗਾਂ ਜਿਵਾਲਣ ਲਈ ਇਕ ਪਹਿਰ ਮੁਹਲਤ ਦਿੱਤੀ ਹੋਈ ਸੀ) ਜਦੋਂ (ਘੜਿਆਲ ਤੇ) ਸੱਤ ਘੜੀਆਂ ਗੁਜ਼ਰੀਆਂ ਸੁਣੀਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "Когда услышали, что прошло семь гхари,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49958,
          "is_rahao": false,
          "gurmukhi": "ਅਜਹੁ ਨ ਆਇਓ ਤ੍ਰਿਭਵਣ ਧਣੀ ॥੧੪॥",
          "roman": "ajah na āiō tribhavaṇ dhaṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ (ਮੈਂ ਨਾਮੇ ਨੇ ਸੋਚਿਆ ਕਿ) ਅਜੇ ਤਕ ਭੀ ਤ੍ਰਿਲੋਕੀ ਦਾ ਮਾਲਕ ਪ੍ਰਭੂ ਨਹੀਂ ਆਇਆ ॥੧੪॥"
            },
            "sahib_singh_ru": {
              "main": "тогда я, Нама, подумал: до сих пор ещё не пришёл Владыка трёх миров. ॥14॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49959,
          "is_rahao": false,
          "gurmukhi": "ਪਾਖੰਤਣ ਬਾਜ ਬਜਾਇਲਾ ॥",
          "roman": "pākhaṇṭaṇ bāj bajāilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਬੱਸ! ਉਸੇ ਵੇਲੇ) ਖੰਭਾਂ ਦੇ ਫੜਕਣ ਦਾ ਖੜਾਕ ਆਇਆ,"
            },
            "sahib_singh_ru": {
              "main": "И тут же раздался шум хлопающих крыльев,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49960,
          "is_rahao": false,
          "gurmukhi": "ਗਰੁੜ ਚੜੑੇ ਗੋਬਿੰਦ ਆਇਲਾ ॥੧੫॥",
          "roman": "garuṛ chaṛhe gobind āilā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵਿਸ਼ਨੂੰ ਭਗਵਾਨ ਗਰੁੜ ਤੇ ਚੜ੍ਹ ਕੇ ਆ ਗਿਆ ॥੧੫॥"
            },
            "sahib_singh_ru": {
              "main": "Гобинд прибыл верхом на Гаруде. ॥15॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49961,
          "is_rahao": false,
          "gurmukhi": "ਅਪਨੇ ਭਗਤ ਪਰਿ ਕੀ ਪ੍ਰਤਿਪਾਲ ॥",
          "roman": "apne bhagat par kī pratipāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਆਪਣੇ ਭਗਤ ਦੀ ਰੱਖਿਆ ਕਰ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Он защитил Своего преданного,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49962,
          "is_rahao": false,
          "gurmukhi": "ਗਰੁੜ ਚੜੑੇ ਆਏ ਗੋਪਾਲ ॥੧੬॥",
          "roman": "garuṛ chaṛhe āe gopāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਜੀ ਗਰੁੜ ਤੇ ਚੜ੍ਹ ਕੇ ਆ ਗਏ ॥੧੬॥"
            },
            "sahib_singh_ru": {
              "main": "Гопал прибыл верхом на Гаруде. ॥16॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49963,
          "is_rahao": false,
          "gurmukhi": "ਕਹਹਿ ਤ ਧਰਣਿ ਇਕੋਡੀ ਕਰਉ ॥",
          "roman": "kahah ta dharaṇ ikoḍī karau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੋਪਾਲ ਨੇ ਆਖਿਆ-ਹੇ ਨਾਮਦੇਵ!) ਜੇ ਤੂੰ ਆਖੇਂ ਤਾਂ ਮੈਂ ਧਰਤੀ ਟੇਢੀ ਕਰ ਦਿਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "Гопал сказал: о Намдев, если скажешь, я сделаю землю кривой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49964,
          "is_rahao": false,
          "gurmukhi": "ਕਹਹਿ ਤ ਲੇ ਕਰਿ ਊਪਰਿ ਧਰਉ ॥੧੭॥",
          "roman": "kahahi ta le kar ūpar dharau",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਆਖੇਂ ਤਾਂ ਇਸ ਨੂੰ ਫੜ ਕੇ ਉਲਟਾ ਦਿਆਂ ॥੧੭॥"
            },
            "sahib_singh_ru": {
              "main": "если скажешь, я схвачу её и переверну. ॥17॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49965,
          "is_rahao": false,
          "gurmukhi": "ਕਹਹਿ ਤ ਮੁਈ ਗਊ ਦੇਉ ਜੀਆਇ ॥",
          "roman": "kahah ta মুī gaū deu jīāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਤੂੰ ਆਖੇਂ ਤਾਂ ਮੋਈ ਹੋਈ ਗਾਂ ਜਿਵਾਲ ਦਿਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если скажешь, я оживлю мёртвую корову,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49966,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਕੋਈ ਦੇਖੈ ਪਤੀਆਇ ॥੧੮॥",
          "roman": "sabh koi dekhē patīāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਇੱਥੇ ਹਰੇਕ ਜਣਾ ਤਸੱਲੀ ਨਾਲ ਵੇਖ ਲਏ ॥੧੮॥"
            },
            "sahib_singh_ru": {
              "main": "и здесь каждый сможет удовлетворённо это увидеть. ॥18॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49967,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਾ ਪ੍ਰਣਵੈ ਸੇਲ ਮਸੇਲ ॥",
          "roman": "nāmā praṇvē sel masel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੋਪਾਲ ਦੀ ਇਸ ਕਿਰਪਾ ਤੇ) ਮੈਂ ਨਾਮੇ ਨੇ (ਉਹਨਾਂ ਲੋਕਾਂ ਨੂੰ) ਬੇਨਤੀ ਕੀਤੀ-(ਗਊ ਨੂੰ) ਨਿਆਣਾ ਪਾ ਦਿਉ।"
            },
            "sahib_singh_ru": {
              "main": "Нама с мольбой сказал тем людям: подведите телёнка к корове."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49968,
          "is_rahao": false,
          "gurmukhi": "ਗਊ ਦੁਹਾਈ ਬਛਰਾ ਮੇਲਿ ॥੧੯॥",
          "roman": "gaū duhāī bachhrā mel",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਂ ਉਹਨਾਂ) ਵੱਛਾ ਛੱਡ ਕੇ ਗਾਂ ਚੋ ਲਈ ॥੧੯॥"
            },
            "sahib_singh_ru": {
              "main": "Тогда, подпустив телёнка, они подоили корову. ॥19॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49969,
          "is_rahao": false,
          "gurmukhi": "ਦੂਧਹਿ ਦੁਹਿ ਜਬ ਮਟੁਕੀ ਭਰੀ ॥",
          "roman": "dūdhh duh jab maṭukī bharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁੱਧ ਚੋ ਕੇ ਜਦੋਂ ਉਹਨਾਂ ਮਟਕੀ ਭਰ ਲਈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда они надоили молока и наполнили кувшин,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49970,
          "is_rahao": false,
          "gurmukhi": "ਲੇ ਬਾਦਿਸਾਹ ਕੇ ਆਗੇ ਧਰੀ ॥੨੦॥",
          "roman": "le bādisāh ke āge dharī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਉਹ ਲੈ ਕੇ ਬਾਦਸ਼ਾਹ ਦੇ ਅੱਗੇ ਰੱਖ ਦਿੱਤੀ ॥੨੦॥"
            },
            "sahib_singh_ru": {
              "main": "то принесли его и поставили перед бадшахом. ॥20॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49971,
          "is_rahao": false,
          "gurmukhi": "ਬਾਦਿਸਾਹੁ ਮਹਲ ਮਹਿ ਜਾਇ ॥",
          "roman": "bādisāh mahal mah jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬਾਦਸ਼ਾਹ ਮਹਲਾਂ ਵਿਚ ਚਲਾ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Бадшах ушёл во дворец,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49972,
          "is_rahao": false,
          "gurmukhi": "ਅਉਘਟ ਕੀ ਘਟ ਲਾਗੀ ਆਇ ॥੨੧॥",
          "roman": "aughaṭ kī ghaṭ lāgī āi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇ ਉੱਥੇ ਉਸ ਉੱਤੇ) ਔਖੀ ਘੜੀ ਆ ਗਈ (ਭਾਵ, ਉਹ ਸਹਿਮ ਗਿਆ) ॥੨੧॥"
            },
            "sahib_singh_ru": {
              "main": "и там на него нашёл тяжёлый час, то есть он перепугался. ॥21॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49973,
          "is_rahao": false,
          "gurmukhi": "ਕਾਜੀ ਮੁਲਾਂ ਬਿਨਤੀ ਫੁਰਮਾਇ ॥",
          "roman": "kājī mulāṅ bintī furmāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਕਾਜ਼ੀਆਂ ਤੇ ਮੌਲਵੀਆਂ ਦੀ ਰਾਹੀਂ ਉਸ ਨੇ ਬੇਨਤੀ (ਕਰ ਘੱਲੀ),"
            },
            "sahib_singh_ru": {
              "main": "Через своих кади и мулл он передал просьбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49974,
          "is_rahao": false,
          "gurmukhi": "ਬਖਸੀ ਹਿੰਦੂ ਮੈ ਤੇਰੀ ਗਾਇ ॥੨੨॥",
          "roman": "bakhsī hindū mē terī gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਹਿੰਦੂ! ਮੈਨੂੰ ਹੁਕਮ ਕਰ (ਜੋ ਹੁਕਮ ਤੂੰ ਦੇਵੇਂਗਾ ਮੈਂ ਕਰਾਂਗਾ), ਮੈਨੂੰ ਬਖ਼ਸ਼, ਮੈਂ ਤੇਰੀ ਗਾਂ ਹਾਂ ॥੨੨॥"
            },
            "sahib_singh_ru": {
              "main": "«О индус, смилуйся надо мной, я твоя корова». ॥22॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49975,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਾ ਕਹੈ ਸੁਨਹੁ ਬਾਦਿਸਾਹ ॥",
          "roman": "nāmā kahē sunah bādisāh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਾ ਆਖਦਾ ਹੈ ਕਿ ਹੇ ਬਾਦਸ਼ਾਹ! ਸੁਣ,"
            },
            "sahib_singh_ru": {
              "main": "Нама говорит: слушай, о бадшах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49976,
          "is_rahao": false,
          "gurmukhi": "ਇਹੁ ਕਿਛੁ ਪਤੀਆ ਮੁਝੈ ਦਿਖਾਇ ॥੨੩॥",
          "roman": "ihu kichh patīā muzhē dikhāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਨੂੰ ਇਕ ਤਸੱਲੀ ਦਿਵਾ ਦੇਹ ॥੨੩॥"
            },
            "sahib_singh_ru": {
              "main": "дай мне одно подтверждение. ॥23॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49977,
          "is_rahao": false,
          "gurmukhi": "ਇਸ ਪਤੀਆ ਕਾ ਇਹੈ ਪਰਵਾਨੁ ॥",
          "roman": "is patīā kā ihē parvān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਇਕਰਾਰ ਦਾ ਮਾਪ ਇਹ ਹੋਵੇਗਾ,"
            },
            "sahib_singh_ru": {
              "main": "Мерой этого обещания будет вот что:"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49978,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚਿ ਸੀਲਿ ਚਾਲਹੁ ਸੁਲਿਤਾਨ ॥੨੪॥",
          "roman": "sāch sīl chālhu sulitān",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ ਹੇ ਬਾਦਸ਼ਾਹ! ਤੂੰ (ਅਗਾਂਹ ਨੂੰ) ਸੱਚ ਵਿਚ ਤੁਰੇਂ, ਚੰਗੇ ਸੁਭਾਉ ਵਿਚ ਰਹੇਂ ॥੨੪॥"
            },
            "sahib_singh_ru": {
              "main": "о бадшах, впредь ходи в истине и пребывай в добром нраве. ॥24॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49979,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਦੇਉ ਸਭ ਰਹਿਆ ਸਮਾਇ ॥",
          "roman": "nāmdeu sabh rahiā samāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਕੌਤਕ ਸੁਣ ਵੇਖ ਕੇ) ਘਰ ਘਰ ਵਿਚ ਨਾਮਦੇਵ ਦੀਆਂ ਗੱਲਾਂ ਹੋਣ ਲੱਗ ਪਈਆਂ,"
            },
            "sahib_singh_ru": {
              "main": "Увидев и услышав это чудо, в каждом доме стали говорить о Намдеве,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49980,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਹਿੰਦੂ ਸਭ ਨਾਮੇ ਪਹਿ ਜਾਹਿ ॥੨੫॥",
          "roman": "mil hindū sabh nāme peh jāhi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਨਗਰ ਦੇ) ਸਾਰੇ ਹਿੰਦੂ ਰਲ ਕੇ ਨਾਮਦੇਵ ਪਾਸ ਆਏ (ਤੇ ਆਖਣ ਲੱਗੇ-) ॥੨੫॥"
            },
            "sahib_singh_ru": {
              "main": "и все индусы города вместе пришли к Намдеву. ॥25॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49981,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਅਬ ਕੀ ਬਾਰ ਨ ਜੀਵੈ ਗਾਇ ॥",
          "roman": "jau ab kī bār na jīvē gāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਐਤਕੀਂ ਗਾਂ ਨਾ ਜੀਊਂਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "Если бы на этот раз корова не ожила,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49982,
          "is_rahao": false,
          "gurmukhi": "ਤ ਨਾਮਦੇਵ ਕਾ ਪਤੀਆ ਜਾਇ ॥੨੬॥",
          "roman": "ta nāmdev kā patīā jāi",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਾਂ ਨਾਮਦੇਵ ਦਾ ਇਤਬਾਰ ਜਾਂਦਾ ਰਹਿਣਾ ਸੀ ॥੨੬॥"
            },
            "sahib_singh_ru": {
              "main": "тогда доверие к Намдеву было бы потеряно. ॥26॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49983,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਕੀ ਕੀਰਤਿ ਰਹੀ ਸੰਸਾਰਿ ॥",
          "roman": "nāme kī kīrat rahī saṃsāri",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਮਦੇਵ ਦੀ ਸੋਭਾ ਜਗਤ ਵਿਚ ਬਣੀ ਰਹੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Слава Намдева осталась в мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49984,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਜਨਾਂ ਲੇ ਉਧਰਿਆ ਪਾਰਿ ॥੨੭॥",
          "roman": "bhagat janāṅ le udhariā pāri",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਭਗਤਾਂ ਨੂੰ, ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ ਚਰਨੀਂ ਲਾ ਕੇ ਪਾਰ ਕਰ ਦਿੱਤਾ ਹੈ ॥੨੭॥"
            },
            "sahib_singh_ru": {
              "main": "А Господь, приняв Своих преданных, Своих слуг, к Своим стопам, переправил их через мир. ॥27॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49985,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਕਲੇਸ ਨਿੰਦਕ ਭਇਆ ਖੇਦੁ ॥",
          "roman": "sagal kales nindak bhaiā khed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਹ ਸੋਭਾ ਸੁਣ ਕੇ) ਨਿੰਦਕਾਂ ਨੂੰ ਬੜੇ ਕਲੇਸ਼ ਤੇ ਬੜਾ ਦੁੱਖ ਹੋਇਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Услышав об этой славе, клеветники испытали великую муку и великое страдание,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49986,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੇ ਨਾਰਾਇਨ ਨਾਹੀ ਭੇਦੁ ॥੨੮॥੧॥੧੦॥",
          "roman": "nāme nārāin nāhī bhed",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ ਉਹ ਇਹ ਨਹੀਂ ਜਾਣਦੇ ਕਿ) ਨਾਮਦੇਵ ਅਤੇ ਪਰਮਾਤਮਾ ਵਿਚ ਕੋਈ ਵਿੱਥ ਨਹੀਂ ਰਹਿ ਗਈ ॥੨੮॥੧॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "ибо они не знают, что между Намдевом и Богом уже не осталось никакого различия. ॥28॥1॥10॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4156,
      "rahao_verse_id": 49993,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 49987,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ੨ ॥",
          "roman": "ghar 2",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49988,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਮਿਲੈ ਮੁਰਾਰਿ ॥",
          "roman": "jau gurdeu ta milē murār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਰੱਬ ਮਿਲ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда обретается Бог,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49989,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਉਤਰੈ ਪਾਰਿ ॥",
          "roman": "jau gurdeu ta utarē pār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਮਨੁੱਖ) ਪਾਰ ਲੰਘ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда человек переправляется через мирской океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49990,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਬੈਕੁੰਠ ਤਰੈ ॥",
          "roman": "jau gurdeu ta bēkuṇṭh tarē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਇੱਥੋਂ) ਤਰ ਕੇ ਬੈਕੁੰਠ ਵਿਚ ਜਾ ਅੱਪੜਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда, переправившись отсюда, достигают Байкунтха,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49991,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਜੀਵਤ ਮਰੈ ॥੧॥",
          "roman": "jau gurdeu ta jīvat marē ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਦੁਨੀਆ ਵਿਚ) ਰਹਿੰਦੇ ਹੋਇਆਂ (ਵਿਕਾਰਾਂ ਵਲੋਂ ਉਸ ਦਾ ਮਨ) ਮਰਿਆ ਰਹਿੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда, живя в мире, ум остаётся умершим для пороков ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49992,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿ ਸਤਿ ਸਤਿ ਸਤਿ ਸਤਿ ਗੁਰਦੇਵ ॥",
          "roman": "sat sat sat sat sat gurdev",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਯਕੀਨ ਜਾਣੋ ਕਿ ਗੁਰੂ ਦੀ ਸੇਵਾ ਹੀ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲਾ ਉੱਦਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Знай наверняка: служение Гуру — это и есть поистине вечное делание."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49993,
          "is_rahao": true,
          "gurmukhi": "ਝੂਠੁ ਝੂਠੁ ਝੂਠੁ ਝੂਠੁ ਆਨ ਸਭ ਸੇਵ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jhūṭh jhūṭh jhūṭh jhūṭh ān sabh sev ||1|| rahāu ||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੋਰ ਸਭ (ਦੇਵਤਿਆਂ ਦੀ) ਸੇਵਾ-ਪੂਜਾ ਵਿਅਰਥ ਹੈ, ਵਿਅਰਥ ਹੈ, ਵਿਅਰਥ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Всякое иное служение и поклонение богам — тщетно, тщетно, тщетно ||1|| пауза ||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49994,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਨਾਮੁ ਦ੍ਰਿੜਾਵੈ ॥",
          "roman": "jau gurdeu ta nām driṛāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਉਹ ਨਾਮ ਜਪਣ ਦਾ ਸੁਭਾਉ ਪਕਾ ਦੇਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда он утверждает привычку к повторению Имени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49995,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਨ ਦਹ ਦਿਸ ਧਾਵੈ ॥",
          "roman": "jau gurdeu na dah dis dhāvē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਫਿਰ ਮਨ) ਦਸੀਂ ਪਾਸੀਂ ਦੌੜਦਾ ਨਹੀਂ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда ум уже не мечется по десяти сторонам,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49996,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਪੰਚ ਤੇ ਦੂਰਿ ॥",
          "roman": "jau gurdeu panch te dūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਪੰਜ ਕਾਮਾਦਿਕਾਂ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда человек остаётся в стороне от пяти страстей,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49997,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਨ ਮਰਿਬੋ ਝੂਰਿ ॥੨॥",
          "roman": "jau gurdeu na maribo jhūr ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਚਿੰਤਾ ਫ਼ਿਕਰਾਂ ਵਿਚ) ਝੁਰ ਝੁਰ ਕੇ ਨਹੀਂ ਖਪਦਾ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда он не иссыхает и не изводится в тревогах и заботах ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49998,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਅੰਮ੍ਰਿਤ ਬਾਨੀ ॥",
          "roman": "jau gurdeu ta amrit bānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਮਨੁੱਖ ਦੇ ਬੋਲ ਮਿੱਠੇ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда речь человека становится сладостной,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 49999,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਅਕਥ ਕਹਾਨੀ ॥",
          "roman": "jau gurdeu ta akath kahānī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਅਕੱਥ ਪ੍ਰਭੂ ਦੀਆਂ ਗੱਲਾਂ ਕਰਨ ਲੱਗ ਪੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда он начинает говорить о невыразимом Боге,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50000,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਅੰਮ੍ਰਿਤ ਦੇਹ ॥",
          "roman": "jau gurdeu ta amrit deh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਸਰੀਰ ਪਵਿੱਤਰ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда тело пребывает в чистоте,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50001,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਨਾਮੁ ਜਪਿ ਲੇਹਿ ॥੩॥",
          "roman": "jau gurdeu nām jap leh ||3||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਿਉਂਕਿ) ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਇਹ ਸਦਾ) ਨਾਮ ਜਪਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Потому что, если встречается Гуру, тогда он постоянно повторяет Имя ||3||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50002,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਭਵਨ ਤ੍ਰੈ ਸੂਝੈ ॥",
          "roman": "jau gurdeu bhavan trē sūjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਮਨੁੱਖ ਨੂੰ ਤਿੰਨਾਂ ਭਵਨਾਂ ਦੀ ਸੂਝ ਹੋ ਜਾਂਦੀ ਹੈ (ਭਾਵ, ਇਹ ਸਮਝ ਆ ਜਾਂਦੀ ਹੈ ਕਿ ਪ੍ਰਭੂ ਤਿੰਨਾਂ ਭਵਨਾਂ ਵਿਚ ਹੀ ਮੌਜੂਦ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда человеку открывается понимание трёх миров, то есть он понимает, что Бог присутствует во всех трёх мирах,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50003,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਊਚ ਪਦ ਬੂਝੈ ॥",
          "roman": "jau gurdeu ūch pad būjhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਨਾਲ ਜਾਣ-ਪਛਾਣ ਹੋ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда приходит знание высокой духовной ступени,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50004,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਤ ਸੀਸੁ ਅਕਾਸਿ ॥",
          "roman": "jau gurdeu ta sīs akās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਮਨ ਪ੍ਰਭੂ-ਚਰਨਾਂ ਵਿਚ ਟਿਕਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда ум остаётся утверждённым у стоп Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50005,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਸਦਾ ਸਾਬਾਸਿ ॥੪॥",
          "roman": "jau gurdeu sadā sābās ||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ (ਹਰ ਥਾਂ ਤੋਂ) ਸਦਾ ਸੋਭਾ ਮਿਲਦੀ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда отовсюду всегда приходит слава ||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50006,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਸਦਾ ਬੈਰਾਗੀ ॥",
          "roman": "jau gurdeu sadā bērāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਮਨੁੱਖ (ਦੁਨੀਆ ਵਿਚ ਰਹਿੰਦਾ ਹੋਇਆ ਹੀ) ਸਦਾ ਵਿਰਕਤ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда человек, даже живя в мире, всегда остаётся отрешённым,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50007,
          "is_rahao": false,
          "gurmukhi": "ਜਉ ਗੁਰਦੇਉ ਪਰ ਨਿੰਦਾ ਤਿਆਗੀ ॥",
          "roman": "jau gurdeu par nindā tiāgī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇ ਗੁਰੂ ਮਿਲ ਪਏ ਤਾਂ ਕਿਸੇ ਦੀ ਨਿੰਦਾ ਨਹੀਂ ਕਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Если встречается Гуру, тогда он не злословит о других,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
