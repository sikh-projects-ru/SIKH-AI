{
  "ang": 1181,
  "shabads": [
    {
      "shabad_id": 4200,
      "rahao_verse_id": 50679,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50673,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50674,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਣ ਤੁਮੑ ਪਿੰਡ ਦੀਨੑ ॥",
          "roman": "jīa prāṇ tum piṇḍ dīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਸਭ ਜੀਵਾਂ ਨੂੰ) ਜਿੰਦ, ਪ੍ਰਾਣ, ਸਰੀਰ ਤੂੰ ਹੀ ਦਿੱਤੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Всем живым существам жизнь, дыхание и тело дал именно Ты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50675,
          "is_rahao": false,
          "gurmukhi": "ਮੁਗਧ ਸੁੰਦਰ ਧਾਰਿ ਜੋਤਿ ਕੀਨੑ ॥",
          "roman": "mugadh sundar dhār jot kīn.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ ਜੋਤਿ ਤੂੰ (ਸਰੀਰਾਂ ਵਿਚ) ਟਿਕਾ ਕੇ ਮੂਰਖਾਂ ਨੂੰ ਸੋਹਣੇ ਬਣਾ ਦੇਂਦਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Поместив в тела Свою Джот, Ты делаешь даже невежд прекрасными."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50676,
          "is_rahao": false,
          "gurmukhi": "ਸਭਿ ਜਾਚਿਕ ਪ੍ਰਭ ਤੁਮੑ ਦਇਆਲ ॥",
          "roman": "sabh jāchik prabh tum daiāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਸਾਰੇ ਜੀਵ (ਤੇਰੇ ਦਰ ਦੇ) ਮੰਗਤੇ ਹਨ, ਤੂੰ ਸਭ ਉੱਤੇ ਦਇਆ ਕਰਨ ਵਾਲਾ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Все существа — просящие у Твоего порога, Ты милостив ко всем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50677,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਹੋਵਤ ਨਿਹਾਲ ॥੧॥",
          "roman": "nām japat hovat nihāl. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਨਾਮ ਜਪਦਿਆਂ ਜੀਵ ਪ੍ਰਸੰਨ-ਚਿੱਤ ਹੋ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Твоё Имя, живые существа становятся радостными сердцем. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50678,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਪ੍ਰੀਤਮ ਕਾਰਣ ਕਰਣ ਜੋਗ ॥",
          "roman": "mere prītam kāraṇ karaṇ jog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਕੁਝ ਕਰਨ ਦੀ ਸਮਰਥਾ ਵਾਲੇ! ਹੇ ਮੇਰੇ ਪ੍ਰੀਤਮ!"
            },
            "sahib_singh_ru": {
              "main": "О способный совершить всё! О мой Возлюбленный!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50679,
          "is_rahao": true,
          "gurmukhi": "ਹਉ ਪਾਵਉ ਤੁਮ ਤੇ ਸਗਲ ਥੋਕ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "hau pāvau tum te sagal thok. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਤੇਰੇ ਪਾਸੋਂ ਹੀ ਸਾਰੇ ਪਦਾਰਥ ਹਾਸਲ ਕਰਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "От Тебя одного я получаю все вещи. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50680,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਹੋਵਤ ਉਧਾਰ ॥",
          "roman": "nām japat hovat udhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਜਗਤ ਤੋਂ) ਪਾਰ-ਉਤਾਰਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Повторяя Имя Параматмы, происходит переправа через мир."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50681,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਸੁਖ ਸਹਜ ਸਾਰ ॥",
          "roman": "nām japat sukh sahaj sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਸ੍ਰੇਸ਼ਟ ਸੁਖ ਪ੍ਰਾਪਤ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Обретаются высшие блаженства духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50682,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਪਤਿ ਸੋਭਾ ਹੋਇ ॥",
          "roman": "nām japat pat sobhā hoi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਇੱਜ਼ਤ ਸੋਭਾ ਮਿਲਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В этом мире и в ином обретаются честь и слава."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50683,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਬਿਘਨੁ ਨਾਹੀ ਕੋਇ ॥੨॥",
          "roman": "nām japat bighan nāhī koi. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜੀਵਨ-ਸਫ਼ਰ ਵਿਚ ਵਿਕਾਰਾਂ ਵਲੋਂ) ਕੋਈ ਰੁਕਵਾਟ ਨਹੀਂ ਪੈਂਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "На пути жизни не возникает никакого препятствия со стороны пороков. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50684,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਾਰਣਿ ਇਹ ਦੁਲਭ ਦੇਹ ॥",
          "roman": "jā kāraṇ ih dulabh deh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰਭੂ! ਜਿਸ ਹਰਿ-ਨਾਮ ਦੇ ਜਪਣ ਵਾਸਤੇ (ਤੇਰੀ ਮਿਹਰ ਨਾਲ) ਇਹ ਦੁਰਲੱਭ ਮਨੁੱਖਾ ਸਰੀਰ ਮਿਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О мой Прабху! Ради повторения того Хар-Нама, по Твоей милости, было получено это редкое человеческое тело."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50685,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਬੋਲੁ ਮੇਰੇ ਪ੍ਰਭੂ ਦੇਹਿ ॥",
          "roman": "so bol mere prabhū deh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਹਰਿ-ਨਾਮ ਮੈਨੂੰ ਬਖ਼ਸ਼।"
            },
            "sahib_singh_ru": {
              "main": "Даруй мне тот Хар-Нам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50686,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਮਹਿ ਇਹੁ ਬਿਸ੍ਰਾਮੁ ॥",
          "roman": "sādhsangat meh ih bisrām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਰਾ) ਇਹ (ਮਨ) ਸਾਧ ਸੰਗਤ ਵਿਚ ਟਿਕਾਣਾ ਪ੍ਰਾਪਤ ਕਰੀ ਰੱਖੇ।"
            },
            "sahib_singh_ru": {
              "main": "Пусть этот мой ум обретает пристанище в Садх Сангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50687,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਰਿਦੈ ਜਪੀ ਪ੍ਰਭ ਤੇਰੋ ਨਾਮੁ ॥੩॥",
          "roman": "sadā ridē japī prabh tero nām. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਮਿਹਰ ਕਰ) ਮੈਂ ਸਦਾ ਤੇਰਾ ਨਾਮ ਜਪਦਾ ਰਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Окажи милость, чтобы я всегда повторял Твоё Имя. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50688,
          "is_rahao": false,
          "gurmukhi": "ਤੁਝ ਬਿਨੁ ਦੂਜਾ ਕੋਇ ਨਾਹਿ ॥",
          "roman": "tujh bin dūjā koi nāh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੈਥੋਂ ਬਿਨਾ ਮੈਨੂੰ ਕੋਈ ਹੋਰ (ਆਸਰਾ) ਨਹੀਂ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Кроме Тебя, у меня нет иной опоры."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50689,
          "is_rahao": false,
          "gurmukhi": "ਸਭੁ ਤੇਰੋ ਖੇਲੁ ਤੁਝ ਮਹਿ ਸਮਾਹਿ ॥",
          "roman": "sabh tero khel tujh meh samāh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਸਾਰਾ ਜਗਤ-ਤਮਾਸ਼ਾ ਤੇਰਾ ਹੀ ਬਣਾਇਆ ਹੋਇਆ ਹੈ। ਸਾਰੇ ਜੀਵ ਤੇਰੇ ਵਿਚ ਹੀ ਲੀਨ ਹੋ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Вся эта игра мира создана Тобой. Все живые существа растворяются в Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50690,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਭਾਵੈ ਤਿਉ ਰਾਖਿ ਲੇ ॥",
          "roman": "jio bhāvē tio rākh le.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਤੈਨੂੰ ਚੰਗਾ ਲੱਗੇ ਤਿਵੇਂ (ਮੇਰੀ) ਰੱਖਿਆ ਕਰ।"
            },
            "sahib_singh_ru": {
              "main": "Как Тебе угодно, так и защити меня."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50691,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖੁ ਨਾਨਕ ਪੂਰਾ ਗੁਰੁ ਮਿਲੇ ॥੪॥੪॥",
          "roman": "sukh Nānak pūrā gur mile. 4. 4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ, ਉਸ ਨੂੰ ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਹੁੰਦਾ ਹੈ ॥੪॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Тот человек, которому встречается Совершенный Гуру, обретает духовное блаженство. 4. 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4201,
      "rahao_verse_id": 50698,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50692,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50693,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਪ੍ਰੀਤਮ ਮੇਰੈ ਸੰਗਿ ਰਾਇ ॥",
          "roman": "prabh prītam merē sang rāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰੀਤਮ ਪ੍ਰਭੂ, ਪ੍ਰਭੂ ਪਾਤਿਸ਼ਾਹ (ਜੋ ਉਂਞ ਤਾਂ ਹਰ ਵੇਲੇ) ਮੇਰੇ ਨਾਲ ਵੱਸਦਾ ਹੈ (ਪਰ ਮੈਨੂੰ ਦਿੱਸਦਾ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "Возлюбленный Прабху, Прабху-Патишах, который вообще-то всегда пребывает со мной, но мне не виден."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50694,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਦੇਖਿ ਹਉ ਜੀਵਾ ਮਾਇ ॥",
          "roman": "jiseh dekh hau jīvā māi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਂ! ਜਿਸ ਨੂੰ ਵੇਖ ਕੇ ਮੈਂ ਆਤਮਕ ਜੀਵਨ ਪ੍ਰਾਪਤ ਕਰ ਸਕਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "О мать! Увидев Его, я могу обрести духовную жизнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50695,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਦੁਖੁ ਨ ਹੋਇ ॥",
          "roman": "jā kē simran dukh na hoi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਸਿਮਰਨ ਦੀ ਬਰਕਤਿ ਨਾਲ ਕੋਈ ਦੁੱਖ ਪੋਹ ਨਹੀਂ ਸਕਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "По благодати памятования о Нём никакая боль не может коснуться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50696,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਦਇਆ ਮਿਲਾਵਹੁ ਤਿਸਹਿ ਮੋਹਿ ॥੧॥",
          "roman": "kar daiā milāvah tiseh moh. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਉਸ ਪ੍ਰਭੂ ਨਾਲ ਮਿਲਾ ਦੇ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Окажи милость и соедини меня с тем Прабху. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50697,
          "is_rahao": true,
          "gurmukhi": "ਮੇਰੇ ਪ੍ਰੀਤਮ ਪ੍ਰਾਨ ਅਧਾਰ ਮਨ ॥",
          "roman": "mere prītam prān adhār man.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੇ ਪ੍ਰੀਤਮ ਪ੍ਰਭੂ! ਹੇ ਮੇਰੀ ਜਿੰਦ ਤੇ ਮਨ ਦੇ ਆਸਰੇ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О мой возлюбленный Прабху! О Прабху, опора моей жизни и моего ума!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50698,
          "is_rahao": true,
          "gurmukhi": "ਜੀਉ ਪ੍ਰਾਨ ਸਭੁ ਤੇਰੋ ਧਨ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jīo prān sabh tero dhan. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀ ਇਹ ਜਿੰਦ ਮੇਰੇ ਇਹ ਪ੍ਰਾਣ-ਸਭ ਕੁਝ ਤੇਰਾ ਹੀ ਦਿੱਤਾ ਹੋਇਆ ਸਰਮਾਇਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Эта моя жизнь, эти мои дыхания — всё это богатство, данное только Тобой. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50699,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕਉ ਖੋਜਹਿ ਸੁਰਿ ਨਰ ਦੇਵ ॥",
          "roman": "jā kau khojeh sur nar dev.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਂ! ਜਿਸ ਪਰਮਾਤਮਾ ਨੂੰ ਦੈਵੀ ਗੁਣਾਂ ਵਾਲੇ ਮਨੁੱਖ ਅਤੇ ਦੇਵਤੇ ਭਾਲਦੇ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О мать! Того Параматму ищут люди с божественными качествами и дэвы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50700,
          "is_rahao": false,
          "gurmukhi": "ਮੁਨਿ ਜਨ ਸੇਖ ਨ ਲਹਹਿ ਭੇਵ ॥",
          "roman": "mun jan sekh na laheh bhev.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦਾ ਭੇਤ ਮੁਨੀ ਲੋਕ ਅਤੇ ਸ਼ੇਸ਼-ਨਾਗ ਭੀ ਨਹੀਂ ਪਾ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Его тайну не могут постичь даже муни и Шеш-Наг."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50701,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੀ ਗਤਿ ਮਿਤਿ ਕਹੀ ਨ ਜਾਇ ॥",
          "roman": "jā kī gat mit kahī na jāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੀ ਉੱਚੀ ਆਤਮਕ ਅਵਸਥਾ ਅਤੇ ਵਡੱਪਣ ਬਿਆਨ ਨਹੀਂ ਕੀਤੇ ਜਾ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Его высокая духовная степень и величие не могут быть описаны."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50702,
          "is_rahao": false,
          "gurmukhi": "ਘਟਿ ਘਟਿ ਘਟਿ ਘਟਿ ਰਹਿਆ ਸਮਾਇ ॥੨॥",
          "roman": "ghaṭ ghaṭ ghaṭ ghaṭ rahiā samāi. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਂ! ਉਹ ਪਰਮਾਤਮਾ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਵਿਆਪ ਰਿਹਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О мать! Тот Параматма пронизывает каждое тело. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50703,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਭਗਤ ਆਨੰਦ ਮੈ ॥",
          "roman": "jā ke bhagat ānand mē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਾਂ! ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਸਦਾ ਆਨੰਦ-ਭਰਪੂਰ ਰਹਿੰਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "О мать! Преданные того Параматмы всегда наполнены блаженством."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50704,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਭਗਤ ਕਉ ਨਾਹੀ ਖੈ ॥",
          "roman": "jā ke bhagat kau nāhī khē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਨੂੰ ਕਦੇ ਆਤਮਕ ਮੌਤ ਨਹੀਂ ਆਉਂਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "К преданным того Параматмы никогда не приходит духовная смерть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50705,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਭਗਤ ਕਉ ਨਾਹੀ ਭੈ ॥",
          "roman": "jā ke bhagat kau nāhī bhē.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਨੂੰ (ਦੁਨੀਆ ਦੇ ਕੋਈ) ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦੇ,"
            },
            "sahib_singh_ru": {
              "main": "Преданных того Параматмы не могут коснуться никакие мирские страхи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50706,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੇ ਭਗਤ ਕਉ ਸਦਾ ਜੈ ॥੩॥",
          "roman": "jā ke bhagat kau sadā jē. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤਾਂ ਨੂੰ (ਵਿਕਾਰਾਂ ਦੇ ਟਾਕਰੇ ਤੇ) ਸਦਾ ਜਿੱਤ ਹੁੰਦੀ ਹੈ (ਉਹ ਪਰਮਾਤਮਾ ਹਰੇਕ ਸਰੀਰ ਵਿਚ ਮੌਜੂਦ ਹੈ) ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Преданные того Параматмы всегда одерживают победу над пороками; тот Параматма присутствует в каждом теле. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50707,
          "is_rahao": false,
          "gurmukhi": "ਕਉਨ ਉਪਮਾ ਤੇਰੀ ਕਹੀ ਜਾਇ ॥",
          "roman": "kaun upmā terī kahī jāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੀ ਕੋਈ ਉਪਮਾ ਦੱਸੀ ਨਹੀਂ ਜਾ ਸਕਦੀ (ਤੇਰੇ ਵਰਗਾ ਕੋਈ ਦੱਸਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Никакое сравнение с Тобой не может быть сказано; нельзя указать никого подобного Тебе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50708,
          "is_rahao": false,
          "gurmukhi": "ਸੁਖਦਾਤਾ ਪ੍ਰਭੁ ਰਹਿਓ ਸਮਾਇ ॥",
          "roman": "sukhdātā prabh rahio samāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ (ਸਭ ਜੀਵਾਂ ਨੂੰ) ਸੁਖ ਦੇਣ ਵਾਲਾ ਮਾਲਕ ਹੈਂ, ਤੂੰ ਹਰ ਥਾਂ ਮੌਜੂਦ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты — Владыка, дающий счастье всем живым существам, Ты присутствуешь повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50709,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਜਾਚੈ ਏਕੁ ਦਾਨੁ ॥",
          "roman": "Nānak jāchē ek dān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! (ਤੇਰੇ ਪਾਸੋਂ) ਨਾਨਕ ਇਕ ਖ਼ੈਰ ਮੰਗਦਾ ਹੈ-"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Нанак просит у Тебя один дар."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50710,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਦੇਹੁ ਨਾਮੁ ॥੪॥੫॥",
          "roman": "kar kirpā moh deh nām. 4. 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਮੈਨੂੰ ਆਪਣਾ ਨਾਮ ਬਖ਼ਸ਼ ॥੪॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Окажи милость и даруй мне Своё Имя. 4. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4202,
      "rahao_verse_id": 50717,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50711,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50712,
          "is_rahao": false,
          "gurmukhi": "ਮਿਲਿ ਪਾਣੀ ਜਿਉ ਹਰੇ ਬੂਟ ॥",
          "roman": "mil pāṇī jio hare būṭ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਪਾਣੀ ਨੂੰ ਮਿਲ ਕੇ ਬੂਟੇ ਹਰੇ ਹੋ ਜਾਂਦੇ ਹਨ (ਤੇ, ਉਹਨਾਂ ਦਾ ਸੋਕਾ ਮੁੱਕ ਜਾਂਦਾ ਹੈ)"
            },
            "sahib_singh_ru": {
              "main": "Как растения, соприкоснувшись с водой, становятся зелёными, и их сухость исчезает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50713,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਤਿਉ ਹਉਮੈ ਛੂਟ ॥",
          "roman": "sādhsangat tio haumē chhūṭ.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਸਾਧ ਸੰਗਤ ਵਿਚ ਮਿਲ ਕੇ (ਮਨੁੱਖ ਦੇ ਅੰਦਰੋਂ) ਹਉਮੈ ਮੁੱਕ ਜਾਂਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Так же, соединившись с Садх Сангат, изнутри человека исчезает Хоумэ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50714,
          "is_rahao": false,
          "gurmukhi": "ਜੈਸੀ ਦਾਸੇ ਧੀਰ ਮੀਰ ॥",
          "roman": "jēsī dāse dhīr mīr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਕਿਸੇ ਦਾਸ ਨੂੰ ਆਪਣੇ ਮਾਲਕ ਦੀ ਧੀਰਜ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Как слуга имеет уверенность в своём господине."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50715,
          "is_rahao": false,
          "gurmukhi": "ਤੈਸੇ ਉਧਾਰਨ ਗੁਰਹ ਪੀਰ ॥੧॥",
          "roman": "tēse udhāran gurah pīr. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤਿਵੇਂ ਗੁਰੂ-ਪੀਰ (ਜੀਵਾਂ ਨੂੰ) ਪਾਰ ਉਤਾਰਨ ਲਈ ਆਸਰਾ ਹੁੰਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Так Гуру-Пир является опорой для переправы живых существ. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50716,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮ ਦਾਤੇ ਪ੍ਰਭ ਦੇਨਹਾਰ ॥",
          "roman": "tum dāte prabh denhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ (ਜੀਵਾਂ ਨੂੰ) ਸਭ ਕੁਝ ਦੇ ਸਕਣ ਵਾਲਾ ਦਾਤਾਰ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Ты — Даритель, способный дать живым существам всё."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50717,
          "is_rahao": true,
          "gurmukhi": "ਨਿਮਖ ਨਿਮਖ ਤਿਸੁ ਨਮਸਕਾਰ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nimakh nimakh tis namaskār. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਪਲ ਪਲ ਉਸ (ਦਾਤਾਰ ਪ੍ਰਭੂ) ਨੂੰ ਨਮਸਕਾਰ ਕਰਦਾ ਹਾਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Каждое мгновение я поклоняюсь тому Дарующему Прабху. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50718,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਪਰਾਪਤਿ ਸਾਧਸੰਗੁ ॥",
          "roman": "jiseh parāpat sādhsang.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਗੁਰੂ ਦੀ ਸੰਗਤ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который обретает общество Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50719,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਜਨ ਲਾਗਾ ਪਾਰਬ੍ਰਹਮ ਰੰਗੁ ॥",
          "roman": "tis jan lāgā pārbrahm rang.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ (ਦੇ ਮਨ) ਨੂੰ ਪਰਮਾਤਮਾ ਦਾ ਪ੍ਰੇਮ-ਰੰਗ ਚੜ੍ਹ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В ум того человека входит краска любви к Парабрахму."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50720,
          "is_rahao": false,
          "gurmukhi": "ਤੇ ਬੰਧਨ ਤੇ ਭਏ ਮੁਕਤਿ ॥",
          "roman": "te bandhan te bhae mukt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਨ੍ਹਾਂ ਮਨੁੱਖਾਂ ਨੂੰ ਨਾਮ-ਰੰਗ ਚੜ੍ਹ ਜਾਂਦਾ ਹੈ) ਉਹ ਮਨੁੱਖ ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਬੰਧਨਾਂ ਤੋਂ ਖ਼ਲਾਸੀ ਹਾਸਲ ਕਰ ਲੈਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Те люди, на которых ложится краска Имени, освобождаются от уз привязанности к майе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50721,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤ ਅਰਾਧਹਿ ਜੋਗ ਜੁਗਤਿ ॥੨॥",
          "roman": "bhagat arādheh jog jugat. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦੇ ਹਨ-ਇਹੀ ਉਸ ਨਾਲ ਮਿਲਾਪ ਦਾ ਸਹੀ ਤਰੀਕਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Преданные Параматмы вспоминают Имя Параматмы — именно это правильный способ соединения с Ним. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50722,
          "is_rahao": false,
          "gurmukhi": "ਨੇਤ੍ਰ ਸੰਤੋਖੇ ਦਰਸੁ ਪੇਖਿ ॥",
          "roman": "netr santokhe daras pekh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਦਰਸਨ ਕਰ ਕੇ (ਮਨੁੱਖ ਦੀਆਂ) ਅੱਖਾਂ ਨੂੰ (ਪਰਾਇਆ ਰੂਪ ਤੱਕਣ ਵੱਲੋਂ) ਸੰਤੋਖ ਆ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Увидев даршан Параматмы, глаза человека обретают удовлетворение и отворачиваются от созерцания чужой красоты."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50723,
          "is_rahao": false,
          "gurmukhi": "ਰਸਨਾ ਗਾਏ ਗੁਣ ਅਨੇਕ ॥",
          "roman": "rasnā gāe guṇ anek.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਉਂ ਜਿਉਂ ਮਨੁੱਖ ਦੀ) ਜੀਭ ਪਰਮਾਤਮਾ ਦੇ ਅਨੇਕਾਂ ਗੁਣ ਗਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По мере того как язык человека воспевает многочисленные качества Параматмы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50724,
          "is_rahao": false,
          "gurmukhi": "ਤ੍ਰਿਸਨਾ ਬੂਝੀ ਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "trisnā būjhī gur prasād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ (ਉਸ ਦੇ ਅੰਦਰੋਂ ਮਾਇਆ ਦੀ) ਤ੍ਰਿਸ਼ਨਾ (-ਅੱਗ) ਬੁੱਝ ਜਾਂਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру внутри него гаснет огонь жажды майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50725,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਆਘਾਨਾ ਹਰਿ ਰਸਹਿ ਸੁਆਦਿ ॥੩॥",
          "roman": "man āghānā har raseh suād. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ ਹਰਿ-ਨਾਮ-ਰਸ ਦੇ ਸੁਆਦ ਨਾਲ (ਮਾਇਆ ਵੱਲੋਂ) ਰੱਜ ਜਾਂਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Его ум насыщается, отворачиваясь от майи, вкусом нектара Хар-Нама. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50726,
          "is_rahao": false,
          "gurmukhi": "ਸੇਵਕੁ ਲਾਗੋ ਚਰਣ ਸੇਵ ॥",
          "roman": "sevak lāgo charaṇ sev.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਹੇ ਪ੍ਰਭੂ! ਜਿਹੜਾ ਤੇਰਾ) ਸੇਵਕ (ਤੇਰੇ) ਚਰਨਾਂ ਦੀ ਸੇਵਾ ਵਿਚ ਲੱਗਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Тот Твой слуга, который занят служением Твоим стопам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50727,
          "is_rahao": false,
          "gurmukhi": "ਆਦਿ ਪੁਰਖ ਅਪਰੰਪਰ ਦੇਵ ॥",
          "roman": "ād purakh aparanpar dev.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਸਭ ਦੇ ਮੁੰਢ ਪ੍ਰਭੂ! ਹੇ ਸਰਬ-ਵਿਆਪਕ ਪ੍ਰਭੂ! ਹੇ ਪਰੇ ਤੋਂ ਪਰੇ ਪ੍ਰਭੂ! ਹੇ ਪ੍ਰਕਾਸ਼-ਰੂਪ ਪ੍ਰਭੂ!"
            },
            "sahib_singh_ru": {
              "main": "О Изначальный Прабху всех! О Всепроникающий Прабху! О Прабху, запредельный запредельному! О Прабху, образ света!"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50728,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਉਧਾਰਣ ਤੇਰੋ ਨਾਮੁ ॥",
          "roman": "sagal udhāraṇ tero nām.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰਾ ਨਾਮ ਸਭ ਜੀਵਾਂ ਦਾ ਪਾਰ-ਉਤਾਰਾ ਕਰਨ ਵਾਲਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Твоё Имя переправляет всех живых существ."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50729,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਪਾਇਓ ਇਹੁ ਨਿਧਾਨੁ ॥੪॥੬॥",
          "roman": "Nānak pāio ih nidhān. 4. 6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਨੂੰ (ਤੇਰਾ) ਇਹ ਨਾਮ-ਖ਼ਜ਼ਾਨਾ ਮਿਲ ਗਿਆ ਹੈ ॥੪॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак обрёл это сокровище Твоего Имени. 4. 6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4203,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50730,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੫ ॥",
          "roman": "basant mahalā 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50731,
          "is_rahao": false,
          "gurmukhi": "ਤੁਮ ਬਡ ਦਾਤੇ ਦੇ ਰਹੇ ॥",
          "roman": "tum baḍ dāte de rahe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਭ ਤੋਂ ਵੱਡਾ ਦਾਤਾ ਹੈਂ, (ਸਭ ਜੀਵਾਂ ਨੂੰ ਤੂੰ ਸਭ ਪਦਾਰਥ) ਦੇ ਰਿਹਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Ты — величайший Даритель, Ты даёшь всем живым существам все предметы."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50732,
          "is_rahao": false,
          "gurmukhi": "ਜੀਅ ਪ੍ਰਾਣ ਮਹਿ ਰਵਿ ਰਹੇ ॥",
          "roman": "jīa prāṇ meh rav rahe.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਸਭਨਾਂ ਦੀ ਜਿੰਦ ਵਿਚ ਸਭਨਾਂ ਦੇ ਪ੍ਰਾਣਾਂ ਵਿਚ ਵਿਆਪਕ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "Ты пронизываешь жизнь всех, дыхание всех."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50733,
          "is_rahao": false,
          "gurmukhi": "ਦੀਨੇ ਸਗਲੇ ਭੋਜਨ ਖਾਨ ॥",
          "roman": "dīne sagle bhojan khān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਖਾਣ ਲਈ ਸਾਰੇ ਪਦਾਰਥ ਦੇ ਰਿਹਾ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "Ты даёшь все предметы для еды."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50734,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਿ ਨਿਰਗੁਨ ਇਕੁ ਗੁਨੁ ਨ ਜਾਨ ॥੧॥",
          "roman": "moh nirgun ik gun na jān. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਮੈਂ ਗੁਣ-ਹੀਨ ਨੇ ਤੇਰਾ ਇਕ ਭੀ ਉਪਕਾਰ ਨਹੀਂ ਸਮਝਿਆ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но я, лишённый достоинств, не понял ни одного Твоего благодеяния. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50735,
          "is_rahao": false,
          "gurmukhi": "ਹਉ ਕਛੂ ਨ ਜਾਨਉ ਤੇਰੀ ਸਾਰ ॥",
          "roman": "hau kachhū na jānaū terī sār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਇਆਲ ਪ੍ਰਭੂ! ਮੈਂ ਤੇਰੀ ਰਤਾ ਭਰ ਭੀ ਕਦਰ ਨਹੀਂ ਜਾਣਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "О милостивый Прабху! Я ни в малейшей мере не знаю Твоей ценности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
