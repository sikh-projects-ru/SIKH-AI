{
  "ang": 1187,
  "shabads": [
    {
      "shabad_id": 4221,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50985,
          "is_rahao": false,
          "gurmukhi": "ਤੈ ਸਾਚਾ ਮਾਨਿਆ ਕਿਹ ਬਿਚਾਰਿ ॥੧॥",
          "roman": "tē sāchā māniā kih bichār. ||1||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! ਤੂੰ ਕੀਹ ਸਮਝ ਕੇ (ਇਸ ਜਗਤ ਨੂੰ) ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲਾ ਮੰਨੀ ਬੈਠਾ ਹੈਂ? ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О ум! Что ты подумал, что считаешь этот мир вечно пребывающим? ||1||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50986,
          "is_rahao": false,
          "gurmukhi": "ਧਨੁ ਦਾਰਾ ਸੰਪਤਿ ਗ੍ਰੇਹ ॥",
          "roman": "dhan dārā sampat grēh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਨ! (ਚੰਗੀ ਤਰ੍ਹਾਂ ਸਮਝ ਲੈ ਕਿ) ਧਨ, ਇਸਤ੍ਰੀ, ਜਾਇਦਾਦ, ਘਰ-"
            },
            "sahib_singh_ru": {
              "main": "О ум! Хорошо пойми: богатство, жена, имущество, дом —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50987,
          "is_rahao": false,
          "gurmukhi": "ਕਛੁ ਸੰਗਿ ਨ ਚਾਲੈ ਸਮਝ ਲੇਹ ॥੨॥",
          "roman": "kachh saṅg na chālē samajh lēh. ||2||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹਨਾਂ ਵਿਚੋਂ ਕੋਈ ਭੀ ਚੀਜ਼ (ਮੌਤ ਵੇਲੇ ਜੀਵ ਦੇ) ਨਾਲ ਨਹੀਂ ਜਾਂਦੀ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "из всего этого ни одна вещь не идет с живым существом во время смерти. ||2||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50988,
          "is_rahao": false,
          "gurmukhi": "ਇਕ ਭਗਤਿ ਨਾਰਾਇਨ ਹੋਇ ਸੰਗਿ ॥",
          "roman": "ik bhagat nārāin hoi saṅg.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਹੀ ਮਨੁੱਖ ਦੇ ਨਾਲ ਰਹਿੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Только преданность Параматме остается с человеком."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50989,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਭਜੁ ਤਿਹ ਏਕ ਰੰਗਿ ॥੩॥੪॥",
          "roman": "kaho nānak bhaj tih ēk raṅg. ||3||4||",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਇਸ ਵਾਸਤੇ) ਨਾਨਕ ਆਖਦਾ ਹੈ- ਸਿਰਫ਼ ਪਰਮਾਤਮਾ ਦੇ ਪਿਆਰ ਵਿਚ (ਟਿਕ ਕੇ) ਉਸ ਦਾ ਭਜਨ ਕਰਿਆ ਕਰ ॥੩॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому Нанак говорит: пребывая только в любви к Параматме, совершай Его бхаджан. ||3||4||"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4222,
      "rahao_verse_id": 50992,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50990,
          "is_rahao": true,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੯ ॥",
          "roman": "basant mahalā 9.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50991,
          "is_rahao": true,
          "gurmukhi": "ਕਹਾ ਭੂਲਿਓ ਰੇ ਝੂਠੇ ਲੋਭ ਲਾਗ ॥",
          "roman": "kahā bhūlio rē jhūṭhē lobh lāg.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਨਾਸਵੰਤ ਦੁਨੀਆ ਦੇ ਲੋਭ ਵਿਚ ਫਸ ਕੇ (ਹਰਿ-ਨਾਮ ਤੋਂ) ਕਿੱਥੇ ਖੁੰਝਿਆ ਫਿਰਦਾ ਹੈਂ?"
            },
            "sahib_singh_ru": {
              "main": "О брат! Попав в жадную привязанность к преходящему миру, где ты блуждаешь, уклонившись от Имени Хари?"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50992,
          "is_rahao": true,
          "gurmukhi": "ਕਛੁ ਬਿਗਰਿਓ ਨਾਹਿਨ ਅਜਹੁ ਜਾਗ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kachh bigrio nāhin ajah jāg. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੁਣ ਹੀ ਸਿਆਣਾ ਬਣ, (ਤੇ, ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਿਆ ਕਰ। ਜੇ ਬਾਕੀ ਦੀ ਉਮਰ ਸਿਮਰਨ ਵਿਚ ਗੁਜ਼ਾਰੇਂ, ਤਾਂ ਭੀ ਤੇਰਾ) ਕੁਝ ਵਿਗੜਿਆ ਨਹੀਂ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Стань мудрым уже сейчас и повторяй Имя Бога. Если оставшуюся жизнь проведёшь в Симране, то и теперь у тебя ещё ничего не испорчено. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50993,
          "is_rahao": false,
          "gurmukhi": "ਸਮ ਸੁਪਨੈ ਕੈ ਇਹੁ ਜਗੁ ਜਾਨੁ ॥",
          "roman": "sam supnē kē ihu jag jān.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਸ ਜਗਤ ਨੂੰ ਸੁਪਨੇ (ਵਿਚ ਵੇਖੇ ਪਦਾਰਥਾਂ) ਦੇ ਬਰਾਬਰ ਸਮਝ।"
            },
            "sahib_singh_ru": {
              "main": "Считай этот мир равным вещам, увиденным во сне."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50994,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸੈ ਛਿਨ ਮੈ ਸਾਚੀ ਮਾਨੁ ॥੧॥",
          "roman": "binsē chhin mē sāchī mān. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਇਹ ਗੱਲ ਸੱਚੀ ਮੰਨ ਕਿ (ਇਹ ਜਗਤ) ਇਕ ਛਿਨ ਵਿਚ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Прими за истину, что этот мир исчезает в одно мгновение. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50995,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਤੇਰੈ ਹਰਿ ਬਸਤ ਨੀਤ ॥",
          "roman": "saṅg tērē har basat nīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮਿੱਤਰ! ਪਰਮਾਤਮਾ ਸਦਾ ਤੇਰੇ ਨਾਲ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "О друг! Бог всегда пребывает с тобой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50996,
          "is_rahao": false,
          "gurmukhi": "ਨਿਸ ਬਾਸੁਰ ਭਜੁ ਤਾਹਿ ਮੀਤ ॥੨॥",
          "roman": "nis bāsur bhaj tāh mīt. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੂੰ ਦਿਨ ਰਾਤ ਉਸ ਦਾ ਹੀ ਭਜਨ ਕਰਿਆ ਕਰ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "День и ночь совершай поклонение Ему одному. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50997,
          "is_rahao": false,
          "gurmukhi": "ਬਾਰ ਅੰਤ ਕੀ ਹੋਇ ਸਹਾਇ ॥",
          "roman": "bār ant kī hoi sahāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਖ਼ੀਰਲੇ ਸਮੇ ਪਰਮਾਤਮਾ ਹੀ ਮਦਦਗਾਰ ਬਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "В последний миг только Бог становится помощником."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 50998,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਨ ਤਾ ਕੇ ਗਾਇ ॥੩॥੫॥",
          "roman": "kah Nānak gun tā kē gāi. 3. 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਹੇ ਭਾਈ! ਤੂੰ (ਸਦਾ) ਉਸ ਦੇ ਗੁਣ ਗਾਇਆ ਕਰ ॥੩॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Нанак говорит: о брат! Всегда пой Его добродетели. 3. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4223,
      "rahao_verse_id": 51006,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 50999,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੧ ਅਸਟਪਦੀਆ ਘਰੁ ੧ ਦੁਤੁਕੀਆ",
          "roman": "basant mahalā 1 asaṭpadīā ghar 1 dutukīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਰਾਗ ਬਸੰਤੁ, ਘਰ ੧ ਵਿੱਚ ਗੁਰੂ ਨਾਨਕਦੇਵ ਜੀ ਦੀ ਅੱਠ-ਬੰਦਾਂ ਵਾਲੀ ਦੋ-ਤੁਕੀ ਬਾਣੀ।"
            },
            "sahib_singh_ru": {
              "main": "Раг Басант, дом 1, двухстрочная бани Гуру Нанак Дэв Джи из восьми строф."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51000,
          "is_rahao": false,
          "gurmukhi": "ੴ ਸਤਿਗੁਰ ਪ੍ਰਸਾਦਿ ॥",
          "roman": "ik oankār satgur prasād.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਕਾਲ ਪੁਰਖ ਇੱਕ ਹੈ ਅਤੇ ਸਤਿਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਮਿਲਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Акал Пуракх один, и Он обретается по милости Сатгуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51001,
          "is_rahao": false,
          "gurmukhi": "ਜਗੁ ਕਊਆ ਨਾਮੁ ਨਹੀ ਚੀਤਿ ॥",
          "roman": "jag kaūā nām nahī chīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਖ, ਜਿਸ ਦੇ ਚਿੱਤ ਵਿਚ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਨਹੀਂ ਹੈ ਉਹ ਮਾਇਆ-ਵੇੜ੍ਹਿਆ ਜੀਵ ਕਾਂ (ਦੇ ਸੁਭਾਵ ਵਾਲਾ) ਹੈ;"
            },
            "sahib_singh_ru": {
              "main": "Смотри: тот, в чьём сознании нет Имени Бога, тот опутанный майей живущий подобен вороне по своему нраву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51002,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਬਿਸਾਰਿ ਗਿਰੈ ਦੇਖੁ ਭੀਤਿ ॥",
          "roman": "nām bisār girē dēkh bhīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਭੁਲਾ ਕੇ (ਉਹ ਕਾਂ ਵਾਂਗ) ਚੋਗੇ ਤੇ ਡਿੱਗਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Забыв Имя Господа, он, как ворона, бросается на корм."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51003,
          "is_rahao": false,
          "gurmukhi": "ਮਨੂਆ ਡੋਲੈ ਚੀਤਿ ਅਨੀਤਿ ॥",
          "roman": "manūā ḍolē chīt anīt.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦਾ ਮਨ (ਮਾਇਆ ਵਲ ਹੀ) ਡੋਲਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਦੇ ਚਿੱਤ ਵਿਚ (ਸਦਾ) ਖੋਟ ਹੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Его ум всё время колеблется к майе, в его сознании всегда пребывает порочность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51004,
          "is_rahao": false,
          "gurmukhi": "ਜਗ ਸਿਉ ਤੂਟੀ ਝੂਠ ਪਰੀਤਿ ॥੧॥",
          "roman": "jag siu tūṭī jhūṭh parīt. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਦੁਨੀਆ ਦੀ ਮਾਇਆ ਨਾਲ ਇਹ ਪ੍ਰੀਤ ਝੂਠੀ ਹੈ, ਕਦੇ ਤੋੜ ਨਹੀਂ ਚੜ੍ਹਦੀ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Но эта любовь к мирской майе ложна, она никогда не приводит к завершению. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51005,
          "is_rahao": true,
          "gurmukhi": "ਕਾਮੁ ਕ੍ਰੋਧੁ ਬਿਖੁ ਬਜਰੁ ਭਾਰੁ ॥",
          "roman": "kām krodh bikh bajar bhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਕਾਮ ਤੇ ਕ੍ਰੋਧ (ਮਾਨੋ) ਜ਼ਹਰ ਹੈ (ਜੋ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਮੁਕਾ ਦੇਂਦਾ ਹੈ), ਇਹ (ਮਾਨੋ) ਇਕ ਕਰੜਾ ਬੋਝ ਹੈ (ਜਿਸ ਦੇ ਹੇਠ ਆਤਮਕ ਜੀਵਨ ਘੁੱਟ ਕੇ ਮਰ ਜਾਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "Похоть и гнев словно яд, уничтожающий духовную жизнь; это словно тяжёлая ноша, под которой духовная жизнь задыхается и умирает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51006,
          "is_rahao": true,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਕੈਸੇ ਗੁਨ ਚਾਰੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "nām binā kēsē gun chār. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਣਾਂ ਵਾਲਾ ਆਚਰਨ (ਆਤਮਕ ਜੀਵਨ) ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਤੋਂ ਬਿਨਾ ਕਦੇ ਬਣ ਹੀ ਨਹੀਂ ਸਕਦਾ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Без Симрана Имени Бога поведение, наполненное добродетелями, то есть духовная жизнь, никогда не может сформироваться. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51007,
          "is_rahao": false,
          "gurmukhi": "ਘਰੁ ਬਾਲੂ ਕਾ ਘੂਮਨ ਘੇਰਿ ॥",
          "roman": "ghar bālū kā ghūman ghēr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਵੇਖ, ਜਿਵੇਂ ਘੁੰਮਣ-ਘੇਰੀ ਵਿਚ ਰੇਤ ਦਾ ਘਰ ਬਣਿਆ ਹੋਇਆ ਹੋਵੇ,"
            },
            "sahib_singh_ru": {
              "main": "Смотри: как если бы в водовороте был построен дом из песка,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51008,
          "is_rahao": false,
          "gurmukhi": "ਬਰਖਸਿ ਬਾਣੀ ਬੁਦਬੁਦਾ ਹੇਰਿ ॥",
          "roman": "barkhas bāṇī budbudā hēr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਵਰਖਾ ਵੇਲੇ ਬੁਲਬੁਲਾ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "как во время дождя возникает пузырь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51009,
          "is_rahao": false,
          "gurmukhi": "ਮਾਤ੍ਰ ਬੂੰਦ ਤੇ ਧਰਿ ਚਕੁ ਫੇਰਿ ॥",
          "roman": "mātr būnd tē dhar chak phēr.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਿਵੇਂ ਇਸ ਸਰੀਰ ਦੀ ਪਾਂਇਆਂ ਹੈ, ਜਿਸ ਨੂੰ ਸਿਰਜਣਹਾਰ ਨੇ ਆਪਣੀ ਕੁਦਰਤਿ ਦਾ) ਚੱਕ ਘੁਮਾ ਕੇ (ਪਿਤਾ ਦੇ ਵੀਰਜ ਦੀ) ਬੂੰਦ ਮਾਤ੍ਰ ਤੋਂ ਰਚ ਦਿੱਤਾ ਹੈ (ਜਿਵੇਂ ਕੋਈ ਘੁਮਿਆਰ ਚੱਕ ਘੁਮਾ ਕੇ ਮਿੱਟੀ ਤੋਂ ਭਾਂਡਾ ਬਣਾ ਦੇਂਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "такова основа этого тела: Создатель, вращая круг Своей природы, создал его из одной лишь капли отцовского семени, как гончар, вращая круг, делает сосуд из глины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51010,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਜੋਤਿ ਨਾਮੈ ਕੀ ਚੇਰਿ ॥੨॥",
          "roman": "sarab jot nāmē kī chēr. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਸੋ, ਜੇ ਤੂੰ ਆਤਮਕ ਮੌਤ ਤੋਂ ਬਚਣਾ ਹੈ ਤਾਂ ਆਪਣੀ ਜਿੰਦ ਨੂੰ) ਉਸ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਦੀ ਦਾਸੀ ਬਣਾ ਜਿਸ ਦੀ ਜੋਤਿ ਸਭ ਜੀਵਾਂ ਵਿਚ ਮੌਜੂਦ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Поэтому, если хочешь спастись от духовной смерти, сделай свою жизнь служанкой Имени того Господа, чей свет присутствует во всех существах. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51011,
          "is_rahao": false,
          "gurmukhi": "ਸਰਬ ਉਪਾਇ ਗੁਰੂ ਸਿਰਿ ਮੋਰੁ ॥",
          "roman": "sarab upāi gurū sir mor.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੂੰ ਸਾਰੇ ਜੀਵ ਪੈਦਾ ਕਰ ਕੇ ਸਭ ਦੇ ਸਿਰ ਤੇ ਸ਼ਿਰੋਮਣੀ ਹੈਂ, ਗੁਰੂ ਹੈਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Создав всех существ, Ты — высший над всеми, Ты — Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51012,
          "is_rahao": false,
          "gurmukhi": "ਭਗਤਿ ਕਰਉ ਪਗ ਲਾਗਉ ਤੋਰ ॥",
          "roman": "bhagat karau pag lāgau tor.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੇਰੀ ਇਹ ਤਾਂਘ ਹੈ ਕਿ ਮੈਂ ਤੇਰੀ ਭਗਤੀ ਕਰਾਂ, ਮੈਂ ਤੇਰੇ ਚਰਨੀਂ ਲੱਗਾ ਰਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Моё желание таково: чтобы я совершал Твою бхагти, чтобы оставался у Твоих стоп."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51013,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮਿ ਰਤੋ ਚਾਹਉ ਤੁਝ ਓਰੁ ॥",
          "roman": "nām rato chāhau tujh or.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇਰੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਰਹਾਂ ਤੇ ਤੇਰਾ ਹੀ ਪੱਲਾ ਫੜੀ ਰੱਖਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Чтобы я был окрашен цветом Твоего Имени и держался только за Твой край."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51014,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਦੁਰਾਇ ਚਲੈ ਸੋ ਚੋਰੁ ॥੩॥",
          "roman": "nām durāi chalē so chor. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜਾ ਮਨੁੱਖ ਤੇਰੇ ਨਾਮ ਨੂੰ (ਆਪਣੀ ਜਿੰਦ ਤੋਂ) ਦੂਰ ਦੂਰ ਰੱਖ ਕੇ (ਜੀਵਨ-ਪੰਧ ਵਿਚ) ਤੁਰਦਾ ਹੈ ਉਹ ਤੇਰਾ ਚੋਰ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Человек, который держит Твоё Имя далеко от своей жизни и так идёт по жизненному пути, — Твой вор. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51015,
          "is_rahao": false,
          "gurmukhi": "ਪਤਿ ਖੋਈ ਬਿਖੁ ਅੰਚਲਿ ਪਾਇ ॥",
          "roman": "pat khoī bikh anchal pāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੇਰੀ ਮਾਂ! ਜੇਹੜਾ ਮਨੁੱਖ (ਵਿਕਾਰਾਂ ਦੀ) ਜ਼ਹਰ ਹੀ ਪੱਲੇ ਬੰਨ੍ਹਦਾ ਹੈ ਉਹ ਆਪਣੀ ਇੱਜ਼ਤ ਗਵਾ ਲੈਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О моя мать! Человек, который завязывает в своём подоле лишь яд пороков, теряет свою честь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51016,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਨਾਮਿ ਰਤੋ ਪਤਿ ਸਿਉ ਘਰਿ ਜਾਇ ॥",
          "roman": "sāch nām rato pat siu ghar jāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਹੜਾ ਬੰਦਾ ਸਦਾ-ਥਿਰ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਜਾਂਦਾ ਹੈ, ਉਹ ਪ੍ਰਭੂ ਦੇ ਦੇਸ ਵਿਚ ਇੱਜ਼ਤ ਨਾਲ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но тот, кто окрашивается цветом Имени вечно устойчивого Бога, уходит в страну Господа с честью."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51017,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਕਿਛੁ ਕੀਨੑਸਿ ਪ੍ਰਭੁ ਰਜਾਇ ॥",
          "roman": "jo kichh kīn̄has prabh rajāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਸ ਨੂੰ ਇਹ ਯਕੀਨ ਹੁੰਦਾ ਹੈ ਕਿ) ਪ੍ਰਭੂ ਜੋ ਕੁਝ ਕਰਦਾ ਹੈ ਆਪਣੀ ਰਜ਼ਾ ਵਿਚ ਕਰਦਾ ਹੈ (ਕਿਸੇ ਹੋਰ ਦਾ ਉਸ ਦੀ ਰਜ਼ਾ ਵਿਚ ਕੋਈ ਦਖ਼ਲ ਨਹੀਂ),"
            },
            "sahib_singh_ru": {
              "main": "У него есть уверенность, что всё, что делает Господь, Он делает по Своей воле; никто иной не имеет вмешательства в Его волю."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51018,
          "is_rahao": false,
          "gurmukhi": "ਭੈ ਮਾਨੈ ਨਿਰਭਉ ਮੇਰੀ ਮਾਇ ॥੪॥",
          "roman": "bhē mānē nirbhau mērī māi. 4.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਜੇਹੜਾ ਬੰਦਾ ਉਸ ਦੇ ਡਰ-ਅਦਬ ਵਿਚ ਰਹਿਣ ਗਿੱਝ ਜਾਂਦਾ ਹੈ ਉਹ (ਇਸ ਜੀਵਨ-ਸਫ਼ਰ ਵਿਚ ਕਾਮ ਕ੍ਰੋਧ ਆਦਿਕ ਵਲੋਂ) ਬੇ-ਫ਼ਿਕਰ ਹੋ ਕੇ ਤੁਰਦਾ ਹੈ ॥੪॥"
            },
            "sahib_singh_ru": {
              "main": "И тот, кто привыкает жить в Его страхе и почтении, идёт по этому жизненному пути без заботы о похоти, гневе и прочем. 4."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51019,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮਨਿ ਚਾਹੈ ਸੁੰਦਰਿ ਭੋਗੁ ॥",
          "roman": "kāman chāhē sundar bhog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੁੰਦਰ ਜੀਵ-ਇਸਤ੍ਰੀ ਦੁਨੀਆ ਦੇ ਚੰਗੇ ਪਦਾਰਥਾਂ ਦਾ ਭੋਗ ਲੋੜਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Прекрасная душа-женщина желает наслаждаться хорошими вещами мира."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51020,
          "is_rahao": false,
          "gurmukhi": "ਪਾਨ ਫੂਲ ਮੀਠੇ ਰਸ ਰੋਗ ॥",
          "roman": "pān phūl mīṭhē ras rog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਇਹ ਪਾਨ ਫੁੱਲ ਮਿੱਠੇ ਪਦਾਰਥਾਂ ਦੇ ਸੁਆਦ-ਇਹ ਸਭ ਹੋਰ ਹੋਰ ਵਿਕਾਰ ਤੇ ਰੋਗ ਹੀ ਪੈਦਾ ਕਰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Но бетель, цветы и вкусы сладких предметов — всё это порождает всё новые пороки и болезни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51021,
          "is_rahao": false,
          "gurmukhi": "ਖੀਲੈ ਬਿਗਸੈ ਤੇਤੋ ਸੋਗ ॥",
          "roman": "khīlē bigsē tēto sog.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਤਨਾ ਹੀ ਵਧੀਕ ਉਹ ਇਹਨਾਂ ਭੋਗਾਂ ਵਿਚ ਖਿੱਲੀਆਂ ਮਾਰਦੀ ਹੈ ਤੇ ਖ਼ੁਸ਼ ਹੁੰਦੀ ਹੈ ਉਤਨਾ ਹੀ ਵਧੀਕ ਦੁੱਖ-ਰੋਗ ਵਿਆਪਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Чем больше она предаётся этим наслаждениям и радуется им, тем больше её охватывают страдание и болезнь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51022,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਸਰਣਾਗਤਿ ਕੀਨੑਸਿ ਹੋਗ ॥੫॥",
          "roman": "prabh sarṇāgat kīn̄has hog. 5.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰ ਜੇਹੜੀ ਜੀਵ-ਇਸਤ੍ਰੀ ਪ੍ਰਭੂ ਦੀ ਸਰਨ ਆ ਜਾਂਦੀ ਹੈ (ਉਹ ਰਜ਼ਾ ਵਿਚ ਤੁਰਦੀ ਹੈ ਉਸ ਨੂੰ ਨਿਸ਼ਚਾ ਹੁੰਦਾ ਹੈ ਕਿ) ਜੋ ਕੁਝ ਪ੍ਰਭੂ ਕਰਦਾ ਹੈ ਉਹੀ ਹੁੰਦਾ ਹੈ ॥੫॥"
            },
            "sahib_singh_ru": {
              "main": "Но та душа-женщина, которая приходит в прибежище Господа, идёт в Его воле и имеет уверенность, что происходит только то, что делает Господь. 5."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51023,
          "is_rahao": false,
          "gurmukhi": "ਕਾਪੜੁ ਪਹਿਰਸਿ ਅਧਿਕੁ ਸੀਗਾਰੁ ॥",
          "roman": "kāpaṛ pahiras adhik sīgār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜੇਹੜੀ ਜੀਵ-ਇਸਤ੍ਰੀ ਸੋਹਣਾ ਸੋਹਣਾ ਕੱਪੜਾ ਪਹਿਨਦੀ ਹੈ ਵਧੀਕ ਵਧੀਕ ਸ਼ਿੰਗਾਰ ਕਰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Та душа-женщина, которая надевает красивую одежду и всё больше украшает себя,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51024,
          "is_rahao": false,
          "gurmukhi": "ਮਾਟੀ ਫੂਲੀ ਰੂਪੁ ਬਿਕਾਰੁ ॥",
          "roman": "māṭī phūlī rūp bikār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੀ ਕਾਂਇਆਂ ਨੂੰ ਵੇਖ ਵੇਖ ਕੇ ਫੁੱਲ ਫੁੱਲ ਬਹਿੰਦੀ ਹੈ, ਉਸ ਦਾ ਰੂਪ ਉਸ ਨੂੰ ਹੋਰ ਹੋਰ ਵਿਕਾਰ ਵਲ ਪ੍ਰੇਰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "смотрит на своё тело и раздувается от гордости; её красота всё больше побуждает её к порокам."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51025,
          "is_rahao": false,
          "gurmukhi": "ਆਸਾ ਮਨਸਾ ਬਾਂਧੋ ਬਾਰੁ ॥",
          "roman": "āsā mansā bāndho bār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਦੁਨੀਆ ਦੀਆਂ ਆਸਾਂ ਤੇ ਖ਼ਾਹਸ਼ਾਂ ਉਸ ਦੇ (ਦਸਵੇਂ) ਦਰਵਾਜ਼ੇ ਨੂੰ ਬੰਦ ਕਰ ਦੇਂਦੀਆਂ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "Мирские надежды и желания закрывают её десятые врата."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51026,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮ ਬਿਨਾ ਸੂਨਾ ਘਰੁ ਬਾਰੁ ॥੬॥",
          "roman": "nām binā sūnā ghar bār. 6.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਤੋਂ ਬਿਨਾ ਉਸ ਦਾ ਹਿਰਦਾ-ਘਰ ਸੁੰਞਾ ਹੀ ਰਹਿੰਦਾ ਹੈ ॥੬॥"
            },
            "sahib_singh_ru": {
              "main": "Без Имени Бога дом её сердца остаётся пустым. 6."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51027,
          "is_rahao": false,
          "gurmukhi": "ਗਾਛਹੁ ਪੁਤ੍ਰੀ ਰਾਜ ਕੁਆਰਿ ॥",
          "roman": "gāchhah putrī rāj kuār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਜਿੰਦੇ! ਉੱਠ ਉੱਦਮ ਕਰ, ਤੂੰ ਸਾਰੇ ਜਗਤ ਦੇ ਰਾਜੇ-ਪ੍ਰਭੂ ਦੀ ਅੰਸ ਹੈਂ, ਤੂੰ ਰਾਜ-ਪੁਤ੍ਰੀ ਹੈਂ, ਤੂੰ ਰਾਜ-ਕੁਮਾਰੀ ਹੈਂ,"
            },
            "sahib_singh_ru": {
              "main": "О жизнь! Встань и приложи усилие; ты — частица Господа, Царя всего мира, ты царская дочь, ты царевна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51028,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਭਣਹੁ ਸਚੁ ਦੋਤੁ ਸਵਾਰਿ ॥",
          "roman": "nām bhaṇah sach dot savār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅੰਮ੍ਰਿਤ ਵੇਲੇ ਦੀ ਸੰਭਾਲ ਕਰ ਕੇ ਨਿਤ ਉਸ ਸਦਾ-ਥਿਰ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਸਿਮਰ।"
            },
            "sahib_singh_ru": {
              "main": "Заботясь об амрит-веле, ежедневно совершай Симран Имени того вечно устойчивого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51029,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਿਉ ਸੇਵਹੁ ਪ੍ਰਭ ਪ੍ਰੇਮ ਅਧਾਰਿ ॥",
          "roman": "priu sēvah prabh prēm adhār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਦੇ ਆਸਰੇ ਰਹਿ ਕੇ ਉਸ ਪ੍ਰੀਤਮ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "Опираясь на любовь к Господу, совершай служение и бхагти тому Возлюбленному."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51030,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਸਬਦੀ ਬਿਖੁ ਤਿਆਸ ਨਿਵਾਰਿ ॥੭॥",
          "roman": "gur sabdī bikh tiās nivār. 7.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੇ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਵਿਚ ਜੁੜ ਕੇ ਮਾਇਆ ਦੀ ਤ੍ਰਿਸ਼ਨਾ ਨੂੰ ਦੂਰ ਕਰ ਇਹ ਤ੍ਰਿਸ਼ਨਾ ਜ਼ਹਰ ਹੈ ਜੋ ਤੇਰੇ ਆਤਮਕ ਜੀਵਨ ਨੂੰ ਮਾਰ ਦੇਵੇਗੀ ॥੭॥"
            },
            "sahib_singh_ru": {
              "main": "И, соединяясь со Словом Гуру, устрани жажду майи; эта жажда — яд, который убьёт твою духовную жизнь. 7."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51031,
          "is_rahao": false,
          "gurmukhi": "ਮੋਹਨਿ ਮੋਹਿ ਲੀਆ ਮਨੁ ਮੋਹਿ ॥",
          "roman": "mohan moh līā man moh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਤੈਂ ਮੋਹਨ ਨੇ (ਆਪਣੇ ਕੌਤਕਾਂ ਨਾਲ) ਮੇਰਾ ਮਨ ਮੋਹ ਲਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Ты, Мохан, Своими чудесами пленил мой ум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51032,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੈ ਸਬਦਿ ਪਛਾਨਾ ਤੋਹਿ ॥",
          "roman": "gur kē sabad pachhānā toh.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੇਹਰ ਕਰ ਤਾ ਕਿ) ਮੈਂ ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ ਤੈਨੂੰ ਪਛਾਣ ਸਕਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Прояви милость, чтобы через Слово Гуру я смог познать Тебя."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51033,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਠਾਢੇ ਚਾਹਹਿ ਪ੍ਰਭੂ ਦੁਆਰਿ ॥",
          "roman": "Nānak ṭhāḍhē chāhah prabhū duār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ ਅਰਦਾਸ ਕਰਦਾ ਹੈ- ਹੇ ਪ੍ਰਭੂ! ਅਸੀਂ ਜੀਵ ਤੇਰੇ ਦਰ ਤੇ ਖਲੋਤੇ (ਬੇਨਤੀ ਕਰਦੇ ਹਾਂ),"
            },
            "sahib_singh_ru": {
              "main": "Нанак совершает мольбу: о Господь! Мы, живые существа, стоим у Твоих дверей и молим."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51034,
          "is_rahao": false,
          "gurmukhi": "ਤੇਰੇ ਨਾਮਿ ਸੰਤੋਖੇ ਕਿਰਪਾ ਧਾਰਿ ॥੮॥੧॥",
          "roman": "tērē nām santokhē kirpā dhār. 8. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿਰਪਾ ਕਰ, ਤੇਰੇ ਨਾਮ ਵਿਚ ਜੁੜ ਕੇ ਅਸੀਂ ਸੰਤੋਖ ਧਾਰਨ ਕਰ ਸਕੀਏ ॥੮॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Прояви милость, чтобы, соединяясь с Твоим Именем, мы смогли обрести довольство. 8. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4224,
      "rahao_verse_id": 51041,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 51035,
          "is_rahao": false,
          "gurmukhi": "ਬਸੰਤੁ ਮਹਲਾ ੧ ॥",
          "roman": "basant mahalā 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51036,
          "is_rahao": false,
          "gurmukhi": "ਮਨੁ ਭੂਲਉ ਭਰਮਸਿ ਆਇ ਜਾਇ ॥",
          "roman": "man bhūlau bharamas āi jāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ) ਕੁਰਾਹੇ ਪਿਆ ਹੋਇਆ ਮਨ ਭਟਕਦਾ ਹੈ (ਮਾਇਆ ਦੀ ਖ਼ਾਤਰ ਹੀ) ਦੌੜ-ਭੱਜ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Из-за привязанности к майе сбившийся с пути ум блуждает и всё время мечется туда-сюда ради майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51037,
          "is_rahao": false,
          "gurmukhi": "ਅਤਿ ਲੁਬਧ ਲੁਭਾਨਉ ਬਿਖਮ ਮਾਇ ॥",
          "roman": "at lubadh lubhānau bikham māi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਬੜਾ ਲਾਲਚੀ ਹੋਇਆ ਰਹਿੰਦਾ ਹੈ, ਉਸ ਮਾਇਆ ਦੇ ਲਾਲਚ ਵਿਚ ਫਸਿਆ ਰਹਿੰਦਾ ਹੈ, ਜਿਸ ਦੀ ਫਾਹੀ ਵਿਚੋਂ ਨਿਕਲਣਾ ਬਹੁਤ ਔਖਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Он остаётся крайне жадным, остаётся пойманным в жадности к той майе, из петли которой очень трудно выбраться."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51038,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਅਸਥਿਰੁ ਦੀਸੈ ਏਕ ਭਾਇ ॥",
          "roman": "nah asthir dīsē ēk bhāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਤਨਾ ਚਿਰ ਮਨ ਮਾਇਆ ਦੇ ਅਧੀਨ ਰਹਿੰਦਾ ਹੈ, ਤਦ ਤਕ) ਇਹ ਕਦੇ ਟਿਕਵੀਂ ਹਾਲਤ ਵਿਚ ਨਹੀਂ ਦਿੱਸਦਾ, ਇਕ ਪ੍ਰਭੂ ਦੇ ਪ੍ਰੇਮ ਵਿਚ (ਮਗਨ) ਨਹੀਂ ਦਿੱਸਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Пока ум остаётся под властью майи, он никогда не выглядит устойчивым и не выглядит погружённым в любовь к единому Господу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51039,
          "is_rahao": false,
          "gurmukhi": "ਜਿਉ ਮੀਨ ਕੁੰਡਲੀਆ ਕੰਠਿ ਪਾਇ ॥੧॥",
          "roman": "jiu mīn kuṇḍalīā kanṭh pāi. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਵੇਂ ਮੱਛੀ (ਭਿੱਤੀ ਦੇ ਲਾਲਚ ਵਿਚ) ਆਪਣੇ ਗਲ ਕੁੰਡੀ ਪਵਾ ਲੈਂਦੀ ਹੈ, (ਤਿਵੇਂ ਮਨ ਮਾਇਆ ਦੀ ਗ਼ੁਲਾਮੀ ਵਿਚ ਆਪਣੇ ਆਪ ਨੂੰ ਫਸਾ ਲੈਂਦਾ ਹੈ) ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Как рыба из жадности к наживке позволяет крючку попасть ей в горло, так ум сам ловит себя в рабство майи. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51040,
          "is_rahao": true,
          "gurmukhi": "ਮਨੁ ਭੂਲਉ ਸਮਝਸਿ ਸਾਚਿ ਨਾਇ ॥",
          "roman": "man bhūlau samjhas sāch nāi.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮਾਇਆ ਦੇ ਮੋਹ ਦੇ ਕਾਰਨ) ਕੁਰਾਹੇ ਪਿਆ ਮਨ ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੇ ਨਾਮ ਵਿਚ (ਜੁੜ ਕੇ ਹੀ) ਆਪਣੀ ਭੁੱਲ ਨੂੰ ਸਮਝਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Сбившийся с пути из-за привязанности к майе ум понимает свою ошибку только соединяясь с Именем вечно устойчивого Господа."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 51041,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰ ਸਬਦੁ ਬੀਚਾਰੇ ਸਹਜ ਭਾਇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur sabad bīchārē sahaj bhāi. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਦੋਂ ਮਨ) ਗੁਰੂ ਦੇ ਸ਼ਬਦ ਨੂੰ ਵਿਚਾਰਦਾ ਹੈ ਤਾਂ ਇਹ ਆਤਮਕ ਅਡੋਲਤਾ ਦੇ ਭਾਵ ਵਿਚ (ਟਿਕਦਾ ਹੈ) ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Когда ум размышляет над Словом Гуру, он утверждается в состоянии духовной невозмутимости. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
