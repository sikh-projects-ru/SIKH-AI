{
  "ang": 1338,
  "shabads": [
    {
      "shabad_id": 4863,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56915,
          "is_rahao": false,
          "gurmukhi": "ਕਿਰਤ ਸੰਜੋਗੀ ਪਾਇਆ ਭਾਲਿ ॥",
          "roman": "kirat sañjogī pāiā bhāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਿਛਲੇ ਕੀਤੇ ਕਰਮਾਂ ਦੇ ਸੰਜੋਗਾਂ ਨਾਲ (ਪਰਮਾਤਮਾ ਨੂੰ ਸਾਧ ਸੰਗਤ ਵਿਚ) ਢੂੰਢ ਕੇ ਲੱਭ ਲਈਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "По сочетанию прежних совершённых дел Бога находят, разыскивая Его в Садх Сангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56916,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਤਿ ਮਹਿ ਬਸੇ ਗੁਪਾਲ ॥",
          "roman": "sādhsangat mah basē gupāl.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸ੍ਰਿਸ਼ਟੀ ਦਾ ਰੱਖਿਅਕ ਪ੍ਰਭੂ ਸਾਧ ਸੰਗਤ ਵਿਚ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь, хранитель творения, пребывает в Садх Сангат."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56917,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਮਿਲਿ ਆਏ ਤੁਮਰੈ ਦੁਆਰ ॥",
          "roman": "gur mil āē tumrē duār.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਮੈਂ ਤੇਰੇ ਦਰ ਤੇ ਆਇਆ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Прабху! Прибегнув к Гуру, я пришёл к Твоим дверям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56918,
          "is_rahao": false,
          "gurmukhi": "ਜਨ ਨਾਨਕ ਦਰਸਨੁ ਦੇਹੁ ਮੁਰਾਰਿ ॥੪॥੧॥",
          "roman": "jan Nānak darsan dēhu murār. 4. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਮੁਰਾਰੀ! (ਆਪਣੇ) ਦਾਸ ਨਾਨਕ ਨੂੰ (ਆਪਣਾ) ਦੀਦਾਰ ਬਖ਼ਸ਼ ॥੪॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Мурари! Даруй Своему слуге Нанаку Своё видение. 4. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4864,
      "rahao_verse_id": 56925,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56919,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56920,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭ ਕੀ ਸੇਵਾ ਜਨ ਕੀ ਸੋਭਾ ॥",
          "roman": "prabh kī sēvā jan kī sobhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੀ ਭਗਤੀ ਨਾਲ ਪਰਮਾਤਮਾ ਦੇ ਭਗਤ ਦੀ ਵਡਿਆਈ (ਲੋਕ ਪਰਲੋਕ ਵਿਚ) ਹੁੰਦੀ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Через преданное служение Богу приходит слава преданного Богу человека — и в этом мире, и в дальнейшем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56921,
          "is_rahao": false,
          "gurmukhi": "ਕਾਮ ਕ੍ਰੋਧ ਮਿਟੇ ਤਿਸੁ ਲੋਭਾ ॥",
          "roman": "kām krodh miṭē tis lobhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰੋਂ ਕਾਮ ਕ੍ਰੋਧ ਲੋਭ (ਆਦਿਕ ਵਿਕਾਰ) ਮਿਟ ਜਾਂਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Изнутри него исчезают похоть, гнев, жадность и другие пороки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56922,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਤੇਰਾ ਜਨ ਕੈ ਭੰਡਾਰਿ ॥",
          "roman": "nām terā jan kē bhaṇḍār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰਾ ਨਾਮ-ਧਨ ਤੇਰੇ ਭਗਤਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਵਿਚ (ਭਰਪੂਰ ਰਹਿੰਦਾ ਹੈ)।"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Богатство Твоего Имени полно пребывает в сокровищнице Твоих преданных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56923,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਹਿ ਪ੍ਰਭ ਦਰਸ ਪਿਆਰਿ ॥੧॥",
          "roman": "gun gāveh prabh daras piār ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਤੇਰੇ ਭਗਤ ਤੇਰੇ ਦੀਦਾਰ ਦੀ ਤਾਂਘ ਵਿਚ ਤੇਰੇ ਗੁਣ ਗਾਂਦੇ ਰਹਿੰਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Твои преданные, в любви и жажде Твоего видения, продолжают воспевать Твои достоинства ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56924,
          "is_rahao": true,
          "gurmukhi": "ਤੁਮਰੀ ਭਗਤਿ ਪ੍ਰਭ ਤੁਮਹਿ ਜਨਾਈ ॥",
          "roman": "tumrī bhagat prabh tumah janāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਭੂ! ਆਪਣੀ ਭਗਤੀ (ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ) ਤੂੰ ਆਪ ਹੀ ਸਮਝਾਈ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь! Свою преданность Ты Сам объяснил Своим служителям."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56925,
          "is_rahao": true,
          "gurmukhi": "ਕਾਟਿ ਜੇਵਰੀ ਜਨ ਲੀਏ ਛਡਾਈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "kāṭ jevrī jan līē chhaḍāī ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੀ ਮੋਹ ਦੀ) ਫਾਹੀ ਕੱਟ ਕੇ ਆਪਣੇ ਸੇਵਕਾਂ ਨੂੰ ਤੂੰ ਆਪ ਹੀ (ਮਾਇਆ ਦੇ ਮੋਹ ਤੋਂ) ਬਚਾਇਆ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Разрезав петлю привязанности, Ты Сам освободил Своих служителей от привязанности к майе ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56926,
          "is_rahao": false,
          "gurmukhi": "ਜੋ ਜਨੁ ਰਾਤਾ ਪ੍ਰਭ ਕੈ ਰੰਗਿ ॥",
          "roman": "jo jan rātā prabh kē raṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਹੜਾ ਜਿਹੜਾ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦੇ ਪ੍ਰੇਮ-ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਗਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который окрашивается цветом любви к Богу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56927,
          "is_rahao": false,
          "gurmukhi": "ਤਿਨਿ ਸੁਖੁ ਪਾਇਆ ਪ੍ਰਭ ਕੈ ਸੰਗਿ ॥",
          "roman": "tin sukh pāiā prabh kē saṅg ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਨੇ ਪਰਮਾਤਮਾ ਦੇ (ਚਰਨਾਂ) ਨਾਲ (ਲੱਗ ਕੇ) ਆਤਮਕ ਆਨੰਦ ਪ੍ਰਾਪਤ ਕੀਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "обретает духовное блаженство, присоединившись к стопам Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56928,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਰਸੁ ਆਇਆ ਸੋਈ ਜਾਨੈ ॥",
          "roman": "jis ras āiā soī jānē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪਰ ਉਸ ਆਨੰਦ ਨੂੰ ਬਿਆਨ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ) ਜਿਸ ਮਨੁੱਖ ਨੂੰ ਉਹ ਆਨੰਦ ਆਉਂਦਾ ਹੈ, ਉਹੀ ਉਸ ਨੂੰ ਜਾਣਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Но это блаженство нельзя выразить; тот, к кому приходит этот вкус, сам его знает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56929,
          "is_rahao": false,
          "gurmukhi": "ਪੇਖਿ ਪੇਖਿ ਮਨ ਮਹਿ ਹੈਰਾਨੈ ॥੨॥",
          "roman": "pēkh pēkh man meh hērānē ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ (ਪਰਮਾਤਮਾ ਦਾ) ਦਰਸਨ ਕਰ ਕਰ ਕੇ (ਆਪਣੇ) ਮਨ ਵਿਚ ਵਾਹ ਵਾਹ ਕਰ ਉੱਠਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Снова и снова видя Бога, этот человек в своём уме восклицает от изумления и восторга ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56930,
          "is_rahao": false,
          "gurmukhi": "ਸੋ ਸੁਖੀਆ ਸਭ ਤੇ ਊਤਮੁ ਸੋਇ ॥",
          "roman": "so sukhīā sabh te ūttam soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸੁਖੀ ਹੋ ਜਾਂਦਾ ਹੈ, ਉਹ ਹੋਰ ਸਭਨਾਂ ਨਾਲੋਂ ਸ੍ਰੇਸ਼ਟ ਜੀਵਨ ਵਾਲਾ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Этот человек становится счастливым; его жизнь становится выше жизни всех остальных."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56931,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਹ੍ਰਿਦੈ ਵਸਿਆ ਪ੍ਰਭੁ ਸੋਇ ॥",
          "roman": "jā kē hirdē vasiā prabh soi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਮਨੁੱਖ) ਦੇ ਹਿਰਦੇ ਵਿਚ ਉਹ ਪਰਮਾਤਮਾ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это тот человек, в сердце которого поселяется тот Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56932,
          "is_rahao": false,
          "gurmukhi": "ਸੋਈ ਨਿਹਚਲੁ ਆਵੈ ਨ ਜਾਇ ॥",
          "roman": "soī nihchal āvē na jāi ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਸਦਾ ਅਡੋਲ ਚਿੱਤ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਕਦੇ ਭਟਕਦਾ ਨਹੀਂ ਫਿਰਦਾ,"
            },
            "sahib_singh_ru": {
              "main": "Этот человек всегда остаётся с устойчивым сознанием; он больше не скитается туда-сюда."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56933,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦਿਨੁ ਪ੍ਰਭ ਕੇ ਹਰਿ ਗੁਣ ਗਾਇ ॥੩॥",
          "roman": "andin prabh ke har gun gāi ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਹਰ ਵੇਲੇ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Этот человек всё время продолжает воспевать достоинства Бога ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56934,
          "is_rahao": false,
          "gurmukhi": "ਤਾ ਕਉ ਕਰਹੁ ਸਗਲ ਨਮਸਕਾਰੁ ॥",
          "roman": "tā kau karah sagal namaskār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਭਾਈ! ਉਸ ਮਨੁੱਖ ਦੇ ਅੱਗੇ ਸਾਰੇ ਆਪਣਾ ਸਿਰ ਨਿਵਾਇਆ ਕਰੋ,"
            },
            "sahib_singh_ru": {
              "main": "О брат! Перед таким человеком всем следует склонять свою голову."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56935,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਮਨਿ ਪੂਰਨੁ ਨਿਰੰਕਾਰੁ ॥",
          "roman": "jā kē man pūran niraṅkār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਦੇ ਮਨ ਵਿਚ ਪਰਮਾਤਮਾ ਆ ਵੱਸਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Это тот, в чьём уме поселяется Бог."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56936,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਮੋਹਿ ਠਾਕੁਰ ਦੇਵਾ ॥",
          "roman": "kar kirpā mohe ṭhākur dēvā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਠਾਕੁਰ ਪ੍ਰਭੂ! ਹੇ ਪ੍ਰਕਾਸ਼-ਰੂਪ ਪ੍ਰਭੂ! ਮੇਰੇ ਉਤੇ ਮਿਹਰ ਕਰ,"
            },
            "sahib_singh_ru": {
              "main": "О Господь-Тхакур! О Господь, форма света! Прояви ко мне милость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56937,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕੁ ਉਧਰੈ ਜਨ ਕੀ ਸੇਵਾ ॥੪॥੨॥",
          "roman": "nānak udhrē jan kī sēvā ॥4॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤੇਰਾ ਸੇਵਕ) ਨਾਨਕ ਤੇਰੇ ਭਗਤ ਦੀ ਸਰਨ ਵਿਚ ਰਹਿ ਕੇ (ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਿਆ ਰਹੇ ॥੪॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Пусть Твой служитель Нанак, оставаясь в прибежище Твоего преданного, будет спасён от пороков ॥4॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4865,
      "rahao_verse_id": 56944,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56938,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56939,
          "is_rahao": false,
          "gurmukhi": "ਗੁਨ ਗਾਵਤ ਮਨਿ ਹੋਇ ਅਨੰਦ ॥",
          "roman": "gun gāvat man hoi anand ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਗਾਂਦਿਆਂ ਮਨ ਵਿਚ ਆਨੰਦ ਪੈਦਾ ਹੁੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Когда воспеваются достоинства Бога, в уме возникает радость."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56940,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਸਿਮਰਉ ਭਗਵੰਤ ॥",
          "roman": "āṭh pahar simrau bhagvant ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਾਹੀਏਂ) ਮੈਂ ਅੱਠੇ ਪਹਰ ਭਗਵਾਨ (ਦਾ ਨਾਮ) ਸਿਮਰਦਾ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "Поэтому я все восемь страж суток вспоминаю Имя Бхагавана."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56941,
          "is_rahao": false,
          "gurmukhi": "ਜਾ ਕੈ ਸਿਮਰਨਿ ਕਲਮਲ ਜਾਹਿ ॥",
          "roman": "jā kē simran kalmal jāh ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਦੀ ਰਾਹੀਂ (ਸਾਰੇ) ਪਾਪ ਦੂਰ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По милости того Гуру, через памятование Имени Бога, все грехи удаляются."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56942,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਗੁਰ ਕੀ ਹਮ ਚਰਨੀ ਪਾਹਿ ॥੧॥",
          "roman": "tis gur kī ham charnī pāh ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਗੁਰੂ ਦੀ (ਸਦਾ) ਚਰਨੀਂ ਲੱਗਾ ਰਹਿੰਦਾ ਹਾਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Я всегда остаюсь припавшим к стопам того Гуру ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56943,
          "is_rahao": true,
          "gurmukhi": "ਸੁਮਤਿ ਦੇਵਹੁ ਸੰਤ ਪਿਆਰੇ ॥",
          "roman": "sumat dēvah sant piārē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪਿਆਰੇ ਸਤਿਗੁਰੂ! (ਮੈਨੂੰ) ਚੰਗੀ ਅਕਲ ਬਖ਼ਸ਼,"
            },
            "sahib_singh_ru": {
              "main": "О любимый Сатгуру! Даруй мне добрый разум."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56944,
          "is_rahao": true,
          "gurmukhi": "ਸਿਮਰਉ ਨਾਮੁ ਮੋਹਿ ਨਿਸਤਾਰੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "simrau nām mohe nistārē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੀ ਰਾਹੀਂ) ਮੈਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਰਹਾਂ (ਜਿਹੜਾ ਨਾਮ) ਮੈਨੂੰ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ) ਪਾਰ ਲੰਘਾ ਲਏ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "С его помощью я продолжал бы вспоминать Имя Бога — то Имя, которое переправит меня через мировой океан ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56945,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਗੁਰਿ ਕਹਿਆ ਮਾਰਗੁ ਸੀਧਾ ॥",
          "roman": "jin gur kahiā mārag sīdhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਨੇ (ਆਤਮਕ ਜੀਵਨ ਦਾ) ਸਿੱਧਾ ਰਸਤਾ ਦੱਸਿਆ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Гуру, который указал прямой путь духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56946,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲ ਤਿਆਗਿ ਨਾਮਿ ਹਰਿ ਗੀਧਾ ॥",
          "roman": "sagal tiāg nām har gīdhā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਦੀ ਬਰਕਤਿ ਨਾਲ ਮਨੁੱਖ) ਹੋਰ ਸਾਰੇ (ਮੋਹ) ਛੱਡ ਕੇ ਪਰਮਾਤਮਾ ਦੇ ਨਾਮ ਵਿਚ ਪਰਚਿਆ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "по чьей благодати человек, оставив все прочие привязанности, остаётся погружённым в Имя Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56947,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਗੁਰ ਕੈ ਸਦਾ ਬਲਿ ਜਾਈਐ ॥",
          "roman": "tis gur kē sadā bal jāīē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਾ ਕੁਰਬਾਨ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "тому Гуру следует всегда приносить себя в жертву."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56948,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਸਿਮਰਨੁ ਜਿਸੁ ਗੁਰ ਤੇ ਪਾਈਐ ॥੨॥",
          "roman": "har simran jis gur te pāīai ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਪਾਸੋਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ (ਦੀ ਦਾਤਿ) ਮਿਲਦੀ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Именно от этого Гуру получают дар памятования Имени Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56949,
          "is_rahao": false,
          "gurmukhi": "ਬੂਡਤ ਪ੍ਰਾਨੀ ਜਿਨਿ ਗੁਰਹਿ ਤਰਾਇਆ ॥",
          "roman": "būḍat prānī jin gureh tarāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਨੇ (ਸੰਸਾਰ-ਸਮੁੰਦਰ ਵਿਚ) ਡੁੱਬ ਰਹੇ ਪ੍ਰਾਣੀਆਂ ਨੂੰ ਪਾਰ ਲੰਘਾਇਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот Гуру переправил существ, тонущих в мировом океане."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56950,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਮੋਹੈ ਨਹੀ ਮਾਇਆ ॥",
          "roman": "jis prasād mohē nahī māiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਦੀ ਮਿਹਰ ਨਾਲ ਮਾਇਆ ਠੱਗ ਨਹੀਂ ਸਕਦੀ,"
            },
            "sahib_singh_ru": {
              "main": "По милости этого Гуру майя не может обмануть."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56951,
          "is_rahao": false,
          "gurmukhi": "ਹਲਤੁ ਪਲਤੁ ਜਿਨਿ ਗੁਰਹਿ ਸਵਾਰਿਆ ॥",
          "roman": "halat palat jin gureh savāriā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ ਗੁਰੂ ਨੇ (ਸਰਨ ਪਏ ਮਨੁੱਖ ਦਾ) ਇਹ ਲੋਕ ਅਤੇ ਪਰਲੋਕ ਸੋਹਣਾ ਬਣਾ ਦਿੱਤਾ,"
            },
            "sahib_singh_ru": {
              "main": "Этот Гуру сделал прекрасными и этот мир, и дальнейший мир человека, пришедшего к его прибежищу."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56952,
          "is_rahao": false,
          "gurmukhi": "ਤਿਸੁ ਗੁਰ ਊਪਰਿ ਸਦਾ ਹਉ ਵਾਰਿਆ ॥੩॥",
          "roman": "tis gur ūpar sadā hau vāriā ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਾ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Я всегда отдаю себя тому Гуру ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56953,
          "is_rahao": false,
          "gurmukhi": "ਮਹਾ ਮੁਗਧ ਤੇ ਕੀਆ ਗਿਆਨੀ ॥",
          "roman": "mahā mugadh te kīā giānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਗੁਰੂ ਨੇ) ਮਹਾ ਮੂਰਖ ਮਨੁੱਖ ਤੋਂ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਵਾਲਾ ਬਣਾ ਦਿੱਤਾ।"
            },
            "sahib_singh_ru": {
              "main": "Этот Гуру сделал великого глупца человеком, обладающим пониманием духовной жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56954,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪੂਰੇ ਕੀ ਅਕਥ ਕਹਾਨੀ ॥",
          "roman": "gur pūrē kī akath kahānī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਪੂਰੇ ਤੌਰ ਤੇ ਬਿਆਨ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"
            },
            "sahib_singh_ru": {
              "main": "Хвалу совершенного Гуру невозможно полностью выразить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56955,
          "is_rahao": false,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮ ਨਾਨਕ ਗੁਰਦੇਵ ॥",
          "roman": "pārbrahm nānak gurdēv ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! (ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ) ਪਾਰਬ੍ਰਹਮ ਗੁਰਦੇਵ-"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Придя к прибежищу Гуру, Парабрахм-Гурдев —"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56956,
          "is_rahao": false,
          "gurmukhi": "ਵਡੈ ਭਾਗਿ ਪਾਈਐ ਹਰਿ ਸੇਵ ॥੪॥੩॥",
          "roman": "vaḍē bhāg pāīē har sēv ॥4॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹਰੀ ਦੀ ਸੇਵਾ-ਭਗਤੀ ਵੱਡੀ ਕਿਸਮਤ ਨਾਲ ਪ੍ਰਾਪਤ ਹੁੰਦੀ ਹੈ ॥੪॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "служение и преданность Хари обретаются великой удачей ॥4॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4866,
      "rahao_verse_id": 56961,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 56957,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5 ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56958,
          "is_rahao": false,
          "gurmukhi": "ਸਗਲੇ ਦੂਖ ਮਿਟੇ ਸੁਖ ਦੀਏ ਅਪਨਾ ਨਾਮੁ ਜਪਾਇਆ ॥",
          "roman": "saglē dūkh miṭē sukh dīē apnā nām japāiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੂੰ ਉਸ (ਪ੍ਰਭੂ) ਨੇ ਆਪਣਾ ਨਾਮ ਜਪਣ ਦੀ ਪ੍ਰੇਰਨਾ ਕੀਤੀ, ਉਹਨਾਂ ਨੂੰ ਉਸ ਨੇ ਸਾਰੇ ਸੁਖ ਬਖ਼ਸ਼ ਦਿੱਤੇ, (ਉਹਨਾਂ ਅੰਦਰੋਂ) ਸਾਰੇ ਦੁੱਖ ਦੂਰ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "Тем, кого Он вдохновил повторять Своё Имя, Он даровал все радости; изнутри них удалились все страдания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56959,
          "is_rahao": false,
          "gurmukhi": "ਕਰਿ ਕਿਰਪਾ ਅਪਨੀ ਸੇਵਾ ਲਾਏ ਸਗਲਾ ਦੁਰਤੁ ਮਿਟਾਇਆ ॥੧॥",
          "roman": "kar kirpā apnī sēvā lāē saglā durat miṭāiā ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਪ੍ਰਭੂ ਨੇ) ਮਿਹਰ ਕਰ ਕੇ (ਜਿਨ੍ਹਾਂ ਨੂੰ) ਆਪਣੀ ਭਗਤੀ ਵਿਚ ਜੋੜਿਆ, (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ ਉਸ ਨੇ) ਸਾਰਾ ਪਾਪ ਦੂਰ ਕਰ ਦਿੱਤਾ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "Проявив милость, Господь соединил их со Своим служением-преданностью и удалил изнутри них весь грех ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56960,
          "is_rahao": true,
          "gurmukhi": "ਹਮ ਬਾਰਿਕ ਸਰਨਿ ਪ੍ਰਭ ਦਇਆਲ ॥",
          "roman": "ham bārik saran prabh daiāl ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਦਇਆ ਦੇ ਸੋਮੇ ਪ੍ਰਭੂ! ਅਸੀਂ (ਜੀਵ ਤੇਰੇ) ਬੱਚੇ (ਤੇਰੀ) ਸਰਨ ਹਾਂ।"
            },
            "sahib_singh_ru": {
              "main": "О Господь, источник милости! Мы, существа, Твои дети и находимся в Твоём прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56961,
          "is_rahao": true,
          "gurmukhi": "ਅਵਗਣ ਕਾਟਿ ਕੀਏ ਪ੍ਰਭਿ ਅਪੁਨੇ ਰਾਖਿ ਲੀਏ ਮੇਰੈ ਗੁਰ ਗੋਪਾਲਿ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "avgaṇ kāṭ kīē prabh apunē rākh līē mērē gur gopāl ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਤੀ ਦੇ ਰੱਖਿਅਕ ਪ੍ਰਭੂ ਨੇ (ਜਿਨ੍ਹਾਂ ਦੀ) ਰੱਖਿਆ ਕੀਤੀ, (ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਔਗੁਣ ਦੂਰ ਕਰ ਕੇ (ਉਹਨਾਂ ਨੂੰ ਉਸ) ਪ੍ਰਭੂ ਨੇ ਆਪਣੇ ਬਣਾ ਲਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "Господь, защитник земли, защитил их; удалив из них недостатки, этот Господь сделал их Своими ॥1॥ рахāу ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56962,
          "is_rahao": false,
          "gurmukhi": "ਤਾਪ ਪਾਪ ਬਿਨਸੇ ਖਿਨ ਭੀਤਰਿ ਭਏ ਕ੍ਰਿਪਾਲ ਗੁਸਾਈ ॥",
          "roman": "tāp pāp binsē khin bhītar bhaē kripāl gusāī ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਧਰਤੀ ਦੇ ਖਸਮ ਪ੍ਰਭੂ ਜੀ (ਜਿਨ੍ਹਾਂ ਉੱਤੇ) ਦਇਆਵਾਨ ਹੋਏ, (ਉਹਨਾਂ ਦੇ) ਸਾਰੇ ਦੁੱਖ-ਕਲੇਸ਼ ਸਾਰੇ ਪਾਪ ਇਕ ਖਿਨ ਵਿਚ ਨਾਸ ਹੋ ਗਏ।"
            },
            "sahib_singh_ru": {
              "main": "Когда Господь, хозяин земли, стал милостив к ним, все их страдания, мучения и все грехи исчезли в одно мгновение."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56963,
          "is_rahao": false,
          "gurmukhi": "ਸਾਸਿ ਸਾਸਿ ਪਾਰਬ੍ਰਹਮੁ ਅਰਾਧੀ ਅਪੁਨੇ ਸਤਿਗੁਰ ਕੈ ਬਲਿ ਜਾਈ ॥੨॥",
          "roman": "sās sās pārbrahm arādhī apunē satigur kē bal jāī ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੇ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, (ਉਸ ਦੀ ਮਿਹਰ ਨਾਲ) ਮੈਂ ਆਪਣੇ ਹਰੇਕ ਸਾਹ ਦੀ ਰਾਹੀਂ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਦਾ ਹਾਂ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Я отдаю себя своему Гуру; по его милости я с каждым своим дыханием вспоминаю Имя Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56964,
          "is_rahao": false,
          "gurmukhi": "ਅਗਮ ਅਗੋਚਰੁ ਬਿਅੰਤੁ ਸੁਆਮੀ ਤਾ ਕਾ ਅੰਤੁ ਨ ਪਾਈਐ ॥",
          "roman": "agam agochar biant suāmī tā kā ant na pāīai ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਾਲਕ-ਪ੍ਰਭੂ ਅਪਹੁੰਚ ਹੈ, ਉਸ ਤਕ (ਜੀਵਾਂ ਦੇ) ਇੰਦ੍ਰਿਆਂ ਦੀ ਪਹੁੰਚ ਨਹੀਂ ਹੋ ਸਕਦੀ, ਉਹ ਬੇਅੰਤ ਹੈ, ਉਸ ਦੇ ਗੁਣਾਂ ਦਾ ਅੰਤ ਨਹੀਂ ਪਾਇਆ ਜਾ ਸਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "Господь-Владыка недостижим; чувства существ не могут достичь Его; Он бесконечен, и предела Его достоинствам нельзя найти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 56965,
          "is_rahao": false,
          "gurmukhi": "ਲਾਹਾ ਖਾਟਿ ਹੋਈਐ ਧਨਵੰਤਾ ਅਪੁਨਾ ਪ੍ਰਭੂ ਧਿਆਈਐ ॥੩॥",
          "roman": "lāhā khāṭ hoīai dhanvantā apunā prabhū dhiāīai ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਆਪਣੇ ਉਸ ਪ੍ਰਭੂ ਦਾ ਸਿਮਰਨ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ, (ਉਸ ਦਾ ਨਾਮ ਹੀ ਅਸਲ ਧਨ ਹੈ, ਇਹ) ਲਾਭ ਖੱਟ ਕੇ ਧਨਵਾਨ ਬਣ ਜਾਈਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Следует вспоминать своего Господа; Его Имя и есть истинное богатство, и, получив эту прибыль, человек становится богатым ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
