{
  "ang": 1340,
  "shabads": [
    {
      "shabad_id": 4870,
      "rahao_verse_id": 57022,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57019,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕਾ ਸਬਦੁ ਸਦਾ ਸਦ ਅਟਲਾ ॥",
          "roman": "gur kā sabad sadā sad aṭlā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦਾ ਸ਼ਬਦ ਸਦਾ ਹੀ ਅਟੱਲ ਰਹਿੰਦਾ ਹੈ (ਕਦੇ ਉਕਾਈ ਵਾਲਾ ਨਹੀਂ)।"
            },
            "sahib_singh_ru": {
              "main": "Шабад Гуру всегда остаётся незыблемым, никогда не содержит ошибки."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57020,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਕੀ ਬਾਣੀ ਜਿਸੁ ਮਨਿ ਵਸੈ ॥ ਦੂਖੁ ਦਰਦੁ ਸਭੁ ਤਾ ਕਾ ਨਸੈ ॥੧॥",
          "roman": "gur kī bāṇī jis man vasē ॥ dūkh darad sabh tā kā nasē ॥1॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਮਨੁੱਖ) ਦੇ ਮਨ ਵਿਚ ਸਤਿਗੁਰੂ ਦੀ ਬਾਣੀ ਟਿਕੀ ਰਹਿੰਦੀ ਹੈ, ਉਸ (ਮਨੁੱਖ) ਦਾ ਹਰੇਕ ਦਰਦ ਨਾਸ ਹੋ ਜਾਂਦਾ ਹੈ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "У того человека, в чьём уме пребывает Бани Сатгуру, всякая боль исчезает ॥1॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57021,
          "is_rahao": true,
          "gurmukhi": "ਹਰਿ ਰੰਗਿ ਰਾਤਾ ਮਨੁ ਰਾਮ ਗੁਨ ਗਾਵੈ ॥",
          "roman": "har raṅg rātā man rām gun gāvē ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦਾ) ਮਨ ਪਰਮਾਤਮਾ ਦੇ (ਪਿਆਰ-) ਰੰਗ ਵਿਚ ਰੰਗਿਆ ਰਹਿੰਦਾ ਹੈ (ਜਿਹੜਾ ਮਨੁੱਖ) ਪ੍ਰਭੂ ਦੇ ਗੁਣ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чей ум окрашен цветом любви к Богу, кто продолжает петь добродетели Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57022,
          "is_rahao": true,
          "gurmukhi": "ਮੁਕਤੋੁ ਸਾਧੂ ਧੂਰੀ ਨਾਵੈ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "mukto sādhū dhūrī nāvē ॥1॥ rahāu ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਹੜਾ ਮਨੁੱਖ) ਗੁਰੂ ਦੀ ਚਰਨ-ਧੂੜ ਵਿਚ ਇਸ਼ਨਾਨ ਕਰਦਾ ਰਹਿੰਦਾ ਹੈ, ਉਹ ਵਿਕਾਰਾਂ ਤੋਂ ਬਚਿਆ ਰਹਿੰਦਾ ਹੈ (ਉਹੀ ਹੈ 'ਮੁਕਤ'); ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "тот человек, кто продолжает купаться в пыли стоп Гуру, остаётся спасённым от пороков; он и есть ‘освобождённый’ ॥1॥ Пауза ॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57023,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰ ਪਰਸਾਦੀ ਉਤਰੇ ਪਾਰਿ ॥",
          "roman": "gur parsādī utre pār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਕਿਰਪਾ ਨਾਲ ਉਹ ਮਨੁੱਖ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "По милости Гуру такие люди переправляются через мирской океан,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57024,
          "is_rahao": false,
          "gurmukhi": "ਭਉ ਭਰਮੁ ਬਿਨਸੇ ਬਿਕਾਰ ॥",
          "roman": "bhau bharam binse bikār ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਅੰਦਰੋਂ) ਡਰ ਭਟਕਣਾ (ਆਦਿਕ ਸਾਰੇ) ਵਿਕਾਰ ਨਾਸ ਹੋ ਜਾਂਦੇ ਹਨ,"
            },
            "sahib_singh_ru": {
              "main": "изнутри у них уничтожаются страх, блуждание и все прочие пороки,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57025,
          "is_rahao": false,
          "gurmukhi": "ਮਨ ਤਨ ਅੰਤਰਿ ਬਸੇ ਗੁਰ ਚਰਨਾ ॥",
          "roman": "man tan antar base gur charnā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਦੇ ਮਨ ਵਿਚ ਤਨ ਵਿਚ ਗੁਰੂ ਦੇ ਚਰਨ ਟਿਕੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "у тех, в чьём уме и теле пребывают стопы Гуру."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57026,
          "is_rahao": false,
          "gurmukhi": "ਨਿਰਭੈ ਸਾਧ ਪਰੇ ਹਰਿ ਸਰਨਾ ॥੨॥",
          "roman": "nirbhē sādh pare har sarnā ॥2॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਸੰਤ ਜਨਾਂ ਨੂੰ ਕੋਈ ਡਰ ਪੋਹ ਨਹੀਂ ਸਕਦਾ, ਉਹ ਸਦਾ ਪਰਮਾਤਮਾ ਦੀ ਸਰਨ ਪਏ ਰਹਿੰਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "Этих святых людей не может коснуться никакой страх; они всегда остаются в прибежище Бога ॥2॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57027,
          "is_rahao": false,
          "gurmukhi": "ਅਨਦ ਸਹਜ ਰਸ ਸੂਖ ਘਨੇਰੇ ॥",
          "roman": "anad sahaj ras sūkh ghanere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹਨਾਂ ਦੇ ਅੰਦਰ) ਆਤਮਕ ਅਡਲੋਤਾ ਦੇ ਅਨੇਕਾਂ ਆਨੰਦ ਤੇ ਸੁਖ ਬਣੇ ਰਹਿੰਦੇ ਹਨ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри них сохраняются многочисленные радости и покои духовной устойчивости."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57028,
          "is_rahao": false,
          "gurmukhi": "ਦੁਸਮਨੁ ਦੂਖੁ ਨ ਆਵੈ ਨੇਰੇ ॥",
          "roman": "dusman dūkh na āvē nere ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕੋਈ ਵੈਰੀ ਦੁੱਖ ਉਹਨਾਂ ਦੇ ਨੇੜੇ ਨਹੀਂ ਢੁਕ ਸਕਦਾ (ਉਹਨਾਂ ਉਤੇ ਆਪਣਾ ਦਬਾਉ ਨਹੀਂ ਪਾ ਸਕਦਾ)।"
            },
            "sahib_singh_ru": {
              "main": "Никакой враг или страдание не может приблизиться к ним и оказать на них своё давление."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57029,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਅਪੁਨੇ ਕਰਿ ਰਾਖੇ ॥",
          "roman": "gur pūrē apune kar rākhe ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪੂਰੇ ਗੁਰੂ ਨੇ ਜਿਨ੍ਹਾਂ ਨੂੰ ਆਪਣੇ ਬਣਾ ਕੇ (ਉਹਨਾਂ ਦੀ) ਰੱਖਿਆ ਕੀਤੀ,"
            },
            "sahib_singh_ru": {
              "main": "Тех, кого полный Гуру сделал своими и защитил,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57030,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਨਾਮੁ ਜਪਤ ਕਿਲਬਿਖ ਸਭਿ ਲਾਥੇ ॥੩॥",
          "roman": "har nām japat kilbikh sabh lāthe ॥3॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਜਪਦਿਆਂ (ਉਹਨਾਂ ਦੇ) ਸਾਰੇ ਪਾਪ ਦੂਰ ਹੋ ਗਏ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "при повторении Имени Бога все их грехи отпали ॥3॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57031,
          "is_rahao": false,
          "gurmukhi": "ਸੰਤ ਸਾਜਨ ਸਿਖ ਭਏ ਸੁਹੇਲੇ ॥",
          "roman": "sant sājan sikh bhae suhele ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਉਹ) ਸੰਤ-ਜਨ ਸੱਜਣ ਸਿੱਖ ਸੁਖੀ ਜੀਵਨ ਵਾਲੇ ਹੋ ਗਏ,"
            },
            "sahib_singh_ru": {
              "main": "Эти святые, друзья, сикхи стали обладателями счастливой жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57032,
          "is_rahao": false,
          "gurmukhi": "ਗੁਰਿ ਪੂਰੈ ਪ੍ਰਭ ਸਿਉ ਲੈ ਮੇਲੇ ॥",
          "roman": "gur pūrē prabh siu lē mele ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਨ੍ਹਾਂ ਨੂੰ ਪੂਰੇ ਗੁਰੂ ਨੇ ਪਰਮਾਤਮਾ ਨਾਲ ਲਿਆ ਜੋੜਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "тех полный Гуру соединил с Богом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57033,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮ ਮਰਨ ਦੁਖ ਫਾਹਾ ਕਾਟਿਆ ॥",
          "roman": "janam maran dukh phāhā kāṭiā ॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹਨਾਂ ਦੇ ਜਨਮ ਮਰਨ ਦੇ ਗੇੜ ਦੇ ਦੁੱਖਾਂ ਦੀ ਫਾਹੀ (ਗੁਰੂ ਨੇ) ਕੱਟ ਦਿੱਤੀ ਹੈ"
            },
            "sahib_singh_ru": {
              "main": "Петлю страданий круга рождения и смерти у них Гуру разрубил."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57034,
          "is_rahao": false,
          "gurmukhi": "ਕਹੁ ਨਾਨਕ ਗੁਰਿ ਪੜਦਾ ਢਾਕਿਆ ॥੪॥੮॥",
          "roman": "kah nānak gur paṛdā ḍhākiā ॥4॥8॥",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਨਾਨਕ ਆਖਦਾ ਹੈ- ਗੁਰੂ ਨੇ ਉਹਨਾਂ ਦੀ ਇੱਜ਼ਤ ਰੱਖ ਲਈ ॥੪॥੮॥"
            },
            "sahib_singh_ru": {
              "main": "Говорит Нанак: Гуру сохранил их честь ॥4॥8॥"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4871,
      "rahao_verse_id": 57037,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57035,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57036,
          "is_rahao": true,
          "gurmukhi": "ਸਤਿਗੁਰਿ ਪੂਰੈ ਨਾਮੁ ਦੀਆ ॥",
          "roman": "satgur pūrē nām dīā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਨੂੰ) ਪੂਰੇ ਗੁਰੂ ਨੇ (ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ (-ਖ਼ਜ਼ਾਨਾ ਬਖ਼ਸ਼ਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тому человеку, которому совершенный Гуру даровал сокровище Имени Бога,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57037,
          "is_rahao": true,
          "gurmukhi": "ਅਨਦ ਮੰਗਲ ਕਲਿਆਣ ਸਦਾ ਸੁਖੁ ਕਾਰਜੁ ਸਗਲਾ ਰਾਸਿ ਥੀਆ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "anad maṅgal kaliāṇ sadā sukh kāraj saglā rās thīā. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਅੰਦਰ ਆਨੰਦ ਖ਼ੁਸ਼ੀ ਸ਼ਾਂਤੀ ਅਤੇ ਸਦਾ ਦਾ ਸੁਖ ਬਣ ਗਿਆ, ਉਸ (ਦੀ ਜ਼ਿੰਦਗੀ) ਦਾ ਸਾਰਾ ਹੀ ਮਨੋਰਥ ਸਫਲ ਹੋ ਗਿਆ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "внутри него утвердились радость, счастье, покой и вечное блаженство; всё назначение его жизни стало успешным. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57038,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਗੁਰ ਕੇ ਮਨਿ ਵੂਠੇ ॥",
          "roman": "charan kamal gur kē man vūṭhē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਜਿਸ ਮਨੁੱਖ ਦੇ) ਮਨ ਵਿਚ ਗੁਰੂ ਦੇ ਸੋਹਣੇ ਚਰਨ ਆ ਵੱਸੇ,"
            },
            "sahib_singh_ru": {
              "main": "В чьём уме поселились прекрасные стопы Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57039,
          "is_rahao": false,
          "gurmukhi": "ਦੂਖ ਦਰਦ ਭ੍ਰਮ ਬਿਨਸੇ ਝੂਠੇ ॥੧॥",
          "roman": "dūkh darad bhram binsē jhūṭhē. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਦੇ ਸਾਰੇ ਦੁੱਖ ਦੂਰ ਹੋ ਗਏ, ਨਾਸਵੰਤ ਪਦਾਰਥਾਂ ਦੀ ਖ਼ਾਤਰ ਸਾਰੀਆਂ ਭਟਕਣਾਂ (ਉਸ ਦੇ ਅੰਦਰੋਂ) ਮੁੱਕ ਗਈਆਂ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "все его страдания ушли, и все блуждания ради преходящих вещей исчезли изнутри него. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57040,
          "is_rahao": false,
          "gurmukhi": "ਨਿਤ ਉਠਿ ਗਾਵਹੁ ਪ੍ਰਭ ਕੀ ਬਾਣੀ ॥",
          "roman": "nit uṭh gāvah prabh kī bāṇī",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਉੱਠ ਕੇ (ਨਿੱਤ ਆਹਰ ਨਾਲ) ਪਰਮਾਤਮਾ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਗਾਵਿਆ ਕਰੋ।"
            },
            "sahib_singh_ru": {
              "main": "Всегда вставая, с постоянным усердием, пойте Бани восхваления Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57041,
          "is_rahao": false,
          "gurmukhi": "ਆਠ ਪਹਰ ਹਰਿ ਸਿਮਰਹੁ ਪ੍ਰਾਣੀ ॥੨॥",
          "roman": "āṭh pahar har simrahu prāṇī. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਪ੍ਰਾਣੀਓ! ਅੱਠੇ ਪਹਰ ਪਰਮਾਤਮਾ ਦਾ ਸਿਮਰਨ ਕਰਿਆ ਕਰੋ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "О живые существа! Все восемь пaharов памятуйте Бога. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57042,
          "is_rahao": false,
          "gurmukhi": "ਘਰਿ ਬਾਹਰਿ ਪ੍ਰਭੁ ਸਭਨੀ ਥਾਈ ॥",
          "roman": "ghar bāhar prabh sabhnī thāīṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਘਰ ਦੇ ਅੰਦਰ ਤੇ ਬਾਹਰ (ਹਰ ਥਾਂ) ਸਭ ਥਾਵਾਂ ਵਿਚ (ਮੈਨੂੰ) ਪ੍ਰਭੂ ਹੀ (ਦਿੱਸਦਾ) ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Внутри дома и снаружи, во всех местах, мне видится только Господь."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57043,
          "is_rahao": false,
          "gurmukhi": "ਸੰਗਿ ਸਹਾਈ ਜਹ ਹਉ ਜਾਈ ॥੩॥",
          "roman": "saṅg sahāī jah hau jāī. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਤਾਂ) ਜਿੱਥੇ (ਭੀ) ਜਾਂਦਾ ਹਾਂ, ਮੈਨੂੰ ਪਰਮਾਤਮਾ (ਤੇਰੇ) ਨਾਲ ਮਦਦਗਾਰ (ਦਿੱਸਦਾ) ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "Куда бы я ни шёл, Бог видится мне помощником вместе с тобой. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57044,
          "is_rahao": false,
          "gurmukhi": "ਦੁਇ ਕਰ ਜੋੜਿ ਕਰੀ ਅਰਦਾਸਿ ॥",
          "roman": "dui kar joṛ karī ardās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ (ਤਾਂ) ਦੋਵੇਂ ਹੱਥ ਜੋੜ ਕੇ ਅਰਜ਼ੋਈ ਕਰਦਾ ਰਹਿੰਦਾ ਹਾਂ,"
            },
            "sahib_singh_ru": {
              "main": "Я, сложив обе руки, продолжаю возносить просьбу,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57045,
          "is_rahao": false,
          "gurmukhi": "ਸਦਾ ਜਪੇ ਨਾਨਕੁ ਗੁਣਤਾਸੁ ॥੪॥੯॥",
          "roman": "sadā japē Nānak guṇtās. 4. 9.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਕਿ (ਉਸ ਪ੍ਰਭੂ ਦਾ ਦਾਸ) ਨਾਨਕ ਸਦਾ ਗੁਣਾਂ ਦੇ ਖ਼ਜ਼ਾਨੇ ਪ੍ਰਭੂ ਦਾ ਨਾਮ ਜਪਦਾ ਰਹੇ ॥੪॥੯॥"
            },
            "sahib_singh_ru": {
              "main": "чтобы Нанак, слуга того Господа, всегда повторял Имя Господа, сокровища добродетелей. 4. 9."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4872,
      "rahao_verse_id": 57048,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57046,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57047,
          "is_rahao": true,
          "gurmukhi": "ਪਾਰਬ੍ਰਹਮੁ ਪ੍ਰਭੁ ਸੁਘੜ ਸੁਜਾਣੁ ॥",
          "roman": "pārbrahm prabh sughaṛ sujāṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸੋਹਣੀ ਆਤਮਕ ਘਾੜਤ ਵਾਲਾ ਸਿਆਣਾ ਪ੍ਰਭੂ ਪਾਰਬ੍ਰਹਮ-"
            },
            "sahib_singh_ru": {
              "main": "Парабрахм, Господь, мудрый и обладающий прекрасной духовной формой,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57048,
          "is_rahao": true,
          "gurmukhi": "ਗੁਰੁ ਪੂਰਾ ਪਾਈਐ ਵਡਭਾਗੀ ਦਰਸਨ ਕਉ ਜਾਈਐ ਕੁਰਬਾਣੁ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "gur pūrā pāīē vaḍbhāgī darsan kau jāīē kurbāṇ. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਤਦੋਂ ਮਿਲਦਾ ਹੈ, ਜਦੋਂ) ਵੱਡੇ ਭਾਗਾਂ ਨਾਲ ਪੂਰਾ ਗੁਰੂ ਮਿਲ ਪੈਂਦਾ ਹੈ। (ਗੁਰੂ ਦਾ) ਦਰਸਨ ਕਰਨ ਦੀ ਖ਼ਾਤਰ ਆਪਣਾ-ਆਪ (ਗੁਰੂ ਦੇ) ਹਵਾਲੇ ਕਰਨ ਦੀ ਲੋੜ ਹੁੰਦੀ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "встречается тогда, когда по великой удаче обретается совершенный Гуру. Ради видения Гуру нужно отдать себя Гуру. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57049,
          "is_rahao": false,
          "gurmukhi": "ਕਿਲਬਿਖ ਮੇਟੇ ਸਬਦਿ ਸੰਤੋਖੁ ॥",
          "roman": "kilbikh mēṭē sabad santokh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਨੇ ਆਪਣੇ) ਸ਼ਬਦ ਦੀ ਰਾਹੀਂ (ਜਿਸ ਮਨੁੱਖ ਦੇ ਸਾਰੇ) ਪਾਪ ਮਿਟਾ ਦਿੱਤੇ (ਅਤੇ ਉਸ ਨੂੰ) ਸੰਤੋਖ ਬਖ਼ਸ਼ਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, чьи грехи Гуру стёр через своё Слово и кому даровал удовлетворённость,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57050,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਅਰਾਧਨ ਹੋਆ ਜੋਗੁ ॥",
          "roman": "nām arādhan hoā jog",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਨਾਮ ਸਿਮਰਨ ਜੋਗਾ ਹੋ ਜਾਂਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "становится способным памятовать Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57051,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗਿ ਹੋਆ ਪਰਗਾਸੁ ॥",
          "roman": "sādhasaṅg hoā pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਦੀ ਸੰਗਤ ਵਿਚ (ਰਹਿ ਕੇ ਉਸ ਮਨੁੱਖ ਦੇ ਅੰਦਰ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "В обществе Гуру внутри того человека возникает свет понимания духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57052,
          "is_rahao": false,
          "gurmukhi": "ਚਰਨ ਕਮਲ ਮਨ ਮਾਹਿ ਨਿਵਾਸੁ ॥੧॥",
          "roman": "charan kamal man māh nivās. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪਰਮਾਤਮਾ ਦੇ ਸੋਹਣੇ ਚਰਨ ਉਸ ਦੇ ਮਨ ਵਿਚ ਟਿਕ ਜਾਂਦੇ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и прекрасные стопы Бога утверждаются в его уме. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57053,
          "is_rahao": false,
          "gurmukhi": "ਜਿਨਿ ਕੀਆ ਤਿਨਿ ਲੀਆ ਰਾਖਿ ॥",
          "roman": "jin kīā tin līā rākh",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਪਰਮਾਤਮਾ) ਨੇ (ਮਨੁੱਖ ਨੂੰ) ਪੈਦਾ ਕੀਤਾ ਹੈ (ਜਦੋਂ ਉਹ ਮਨੁੱਖ ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਗਿਆ ਤਾਂ) ਉਸ (ਪੈਦਾ ਕਰਨ ਵਾਲੇ ਪ੍ਰਭੂ) ਨੇ (ਉਸ ਨੂੰ ਵਿਕਾਰਾਂ ਤੋਂ) ਬਚਾ ਲਿਆ।"
            },
            "sahib_singh_ru": {
              "main": "Тот Бог, который создал человека, когда человек вошёл в прибежище Гуру, тот Создатель-Господь спас его от пороков."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57054,
          "is_rahao": false,
          "gurmukhi": "ਪ੍ਰਭੁ ਪੂਰਾ ਅਨਾਥ ਕਾ ਨਾਥੁ ॥",
          "roman": "prabh pūrā anāth kā nāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਪ੍ਰਭੂ (ਸਾਰੇ ਗੁਣਾਂ ਨਾਲ) ਪੂਰਨ ਹੈ, ਅਤੇ ਨਿਖਸਮਿਆਂ ਦਾ ਖਸਮ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Господь совершенен во всех качествах и является Хозяином тех, у кого нет хозяина."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57055,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸਹਿ ਨਿਵਾਜੇ ਕਿਰਪਾ ਧਾਰਿ ॥",
          "roman": "jisah nivājē kirpā dhār",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮਿਹਰ ਕਰ ਕੇ ਪਰਮਾਤਮਾ ਜਿਸ (ਮਨੁੱਖ) ਨੂੰ ਇੱਜ਼ਤ ਬਖ਼ਸ਼ਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, которому Бог, проявив милость, дарует честь,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57056,
          "is_rahao": false,
          "gurmukhi": "ਪੂਰਨ ਕਰਮ ਤਾ ਕੇ ਆਚਾਰ ॥੨॥",
          "roman": "pūran karam tā kē āchār. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੇ ਸਾਰੇ ਕਰਮ ਸਾਰੇ ਕਰਤੱਬ ਸਫਲ ਹੋ ਜਾਂਦੇ ਹਨ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "у того человека все дела и все поступки становятся успешными. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57057,
          "is_rahao": false,
          "gurmukhi": "ਗੁਣ ਗਾਵੈ ਨਿਤ ਨਿਤ ਨਿਤ ਨਵੇ ॥",
          "roman": "guṇ gāvē nit nit nit navē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਗੁਰੂ ਦੀ ਸਰਨ ਪੈ ਕੇ ਜਿਹੜਾ ਮਨੁੱਖ) ਸਦਾ ਹੀ ਪਰਮਾਤਮਾ ਦੇ ਗੁਣ ਇਉਂ ਗਾਂਦਾ ਰਹਿੰਦਾ ਹੈ (ਜਿਵੇਂ ਉਹ ਗੁਣ ਉਸ ਦੇ ਵਾਸਤੇ ਅਜੇ) ਨਵੇਂ (ਹਨ, ਜਿਵੇਂ ਪਹਿਲਾਂ ਕਦੇ ਨਾਹ ਵੇਖੀ ਹੋਈ ਚੀਜ਼ ਮਨ ਨੂੰ ਖਿੱਚ ਪਾਂਦੀ ਹੈ),"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, который, войдя в прибежище Гуру, постоянно поёт качества Бога так, словно эти качества для него всё ещё новы, словно вещь, прежде никогда не виденная, притягивает ум,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57058,
          "is_rahao": false,
          "gurmukhi": "ਲਖ ਚਉਰਾਸੀਹ ਜੋਨਿ ਨ ਭਵੇ ॥",
          "roman": "lakh chaurāsīh jon na bhavē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਚੌਰਾਸੀ ਲੱਖ ਜੂਨਾਂ ਦੇ ਗੇੜ ਵਿਚ ਨਹੀਂ ਭਟਕਦਾ।"
            },
            "sahib_singh_ru": {
              "main": "не блуждает в круге восьмидесяти четырёх лакхов рождений."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57059,
          "is_rahao": false,
          "gurmukhi": "ਈਹਾਂ ਊਹਾਂ ਚਰਣ ਪੂਜਾਰੇ ॥",
          "roman": "īhāṅ ūhāṅ charaṇ pūjārē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਸ ਮਨੁੱਖ ਦੀ ਇਸ ਲੋਕ ਅਤੇ ਪਰਲੋਕ ਵਿਚ ਇੱਜ਼ਤ ਹੁੰਦੀ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Такой человек получает честь в этом мире и в следующем."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57060,
          "is_rahao": false,
          "gurmukhi": "ਮੁਖੁ ਊਜਲੁ ਸਾਚੇ ਦਰਬਾਰੇ ॥੩॥",
          "roman": "mukh ūjal sāchē darbārē. 3.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਸਦਾ ਕਾਇਮ ਰਹਿਣ ਵਾਲੇ ਪ੍ਰਭੂ ਦੀ ਹਜ਼ੂਰੀ ਵਿਚ ਉਸ ਮਨੁੱਖ ਦਾ ਮੂੰਹ ਰੌਸ਼ਨ ਹੁੰਦਾ ਹੈ ॥੩॥"
            },
            "sahib_singh_ru": {
              "main": "В присутствии вечно пребывающего Господа лицо того человека сияет. 3."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57061,
          "is_rahao": false,
          "gurmukhi": "ਜਿਸੁ ਮਸਤਕਿ ਗੁਰਿ ਧਰਿਆ ਹਾਥੁ ॥",
          "roman": "jis mastak gur dhariā hāth",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਗੁਰੂ ਨੇ ਜਿਸ (ਮਨੁੱਖ) ਦੇ ਮੱਥੇ ਉੱਤੇ ਹੱਥ ਰੱਖਿਆ,"
            },
            "sahib_singh_ru": {
              "main": "Тот человек, на чей лоб Гуру положил руку,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57062,
          "is_rahao": false,
          "gurmukhi": "ਕੋਟਿ ਮਧੇ ਕੋ ਵਿਰਲਾ ਦਾਸੁ ॥",
          "roman": "koṭ madhē ko virlā dās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਉਹ ਮਨੁੱਖ ਪਰਮਾਤਮਾ ਦਾ ਦਾਸ ਬਣ ਜਾਂਦਾ ਹੈ (ਪਰ ਅਜਿਹਾ ਮਨੁੱਖ) ਕ੍ਰੋੜਾਂ ਵਿਚੋਂ ਕੋਈ ਵਿਰਲਾ ਹੀ ਹੁੰਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "становится слугой Бога, но такой человек — редкий среди кроров."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57063,
          "is_rahao": false,
          "gurmukhi": "ਜਲਿ ਥਲਿ ਮਹੀਅਲਿ ਪੇਖੈ ਭਰਪੂਰਿ ॥",
          "roman": "jal thal mahīal pēkhē bharpūr",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਫਿਰ, ਉਹ ਮਨੁੱਖ) ਪਾਣੀ ਵਿਚ ਧਰਤੀ ਵਿਚ ਆਕਾਸ਼ ਵਿਚ (ਹਰ ਥਾਂ) ਪਰਮਾਤਮਾ ਨੂੰ ਵੱਸਦਾ ਵੇਖਦਾ ਹੈ।"
            },
            "sahib_singh_ru": {
              "main": "Затем тот человек видит Бога пребывающим повсюду — в воде, на земле и в небе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57064,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਉਧਰਸਿ ਤਿਸੁ ਜਨ ਕੀ ਧੂਰਿ ॥੪॥੧੦॥",
          "roman": "Nānak udhras tis jan kī dhūr. 4. 10.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਹੇ ਨਾਨਕ! ਅਜਿਹੇ ਮਨੁੱਖ ਦੀ ਚਰਨ-ਧੂੜ ਲੈ ਕੇ ਤੂੰ ਭੀ ਸੰਸਾਰ-ਸਮੁੰਦਰ ਤੋਂ ਪਾਰ ਲੰਘ ਜਾਹਿਂਗਾ ॥੪॥੧੦॥"
            },
            "sahib_singh_ru": {
              "main": "О Нанак! Взяв пыль стоп такого человека, ты тоже переправишься через мировой океан. 4. 10."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4873,
      "rahao_verse_id": 57067,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57065,
          "is_rahao": true,
          "gurmukhi": "ਪ੍ਰਭਾਤੀ ਮਹਲਾ ੫ ॥",
          "roman": "prabhātī mahalā 5",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": ""
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57066,
          "is_rahao": true,
          "gurmukhi": "ਕੁਰਬਾਣੁ ਜਾਈ ਗੁਰ ਪੂਰੇ ਅਪਨੇ ॥",
          "roman": "kurbāṇ jāī gur pūrē apnē",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਮੈਂ ਆਪਣੇ ਉਸ ਪੂਰੇ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ (ਆਪਣੇ ਆਪ ਨੂੰ ਗੁਰੂ ਦੇ ਹਵਾਲੇ ਕਰਦਾ ਹਾਂ)"
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву своему совершенному Гуру, отдаю себя Гуру,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57067,
          "is_rahao": true,
          "gurmukhi": "ਜਿਸੁ ਪ੍ਰਸਾਦਿ ਹਰਿ ਹਰਿ ਜਪੁ ਜਪਨੇ ॥੧॥ ਰਹਾਉ ॥",
          "roman": "jis prasād har har jap japnē. 1. rahāu.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਜਿਸ (ਗੁਰੂ) ਦੀ ਕਿਰਪਾ ਨਾਲ ਸਦਾ ਪਰਮਾਤਮਾ (ਦੇ ਨਾਮ) ਦਾ ਜਾਪ ਜਪਿਆ ਜਾ ਸਕਦਾ ਹੈ ॥੧॥ ਰਹਾਉ ॥"
            },
            "sahib_singh_ru": {
              "main": "по чьей милости можно всегда совершать Джап Имени Бога. 1. Пауза."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57068,
          "is_rahao": false,
          "gurmukhi": "ਅੰਮ੍ਰਿਤ ਬਾਣੀ ਸੁਣਤ ਨਿਹਾਲ ॥",
          "roman": "amrit bāṇī suṇat nihāl",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਆਪਣੇ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, ਜਿਸ ਦੀ) ਆਤਮਕ ਜੀਵਨ ਦੇਣ ਵਾਲੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਦੀ ਬਾਣੀ ਸੁਣਦਿਆਂ ਮਨ ਖਿੜ ਆਉਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву тому Гуру, чью Бани восхваления, дающую духовную жизнь, слушая, ум расцветает,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57069,
          "is_rahao": false,
          "gurmukhi": "ਬਿਨਸਿ ਗਏ ਬਿਖਿਆ ਜੰਜਾਲ ॥੧॥",
          "roman": "binas gaē bikhiā jañjāl. 1.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਮਾਇਆ (ਦੇ ਮੋਹ) ਦੀਆਂ ਫਾਹੀਆਂ ਨਾਸ ਹੋ ਜਾਂਦੀਆਂ ਹਨ ॥੧॥"
            },
            "sahib_singh_ru": {
              "main": "и силки привязанности к майе уничтожаются. 1."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57070,
          "is_rahao": false,
          "gurmukhi": "ਸਾਚ ਸਬਦ ਸਿਉ ਲਾਗੀ ਪ੍ਰੀਤਿ ॥",
          "roman": "sāch sabad siu lāgī prīt",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਆਪਣੇ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, ਜਿਸ ਦੀ ਰਾਹੀਂ) ਸਦਾ-ਥਿਰ ਪ੍ਰਭੂ ਦੀ ਸਿਫ਼ਤ-ਸਾਲਾਹ ਨਾਲ ਪਿਆਰ ਬਣ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву тому Гуру, через которого возникает любовь к восхвалению вечно устойчивого Господа,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57071,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਪ੍ਰਭੁ ਅਪੁਨਾ ਆਇਆ ਚੀਤਿ ॥੨॥",
          "roman": "har prabh apunā āiā chīt. 2.",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "ਅਤੇ ਆਪਣਾ ਹਰੀ-ਪ੍ਰਭੂ ਮਨ ਵਿਚ ਆ ਵੱਸਦਾ ਹੈ ॥੨॥"
            },
            "sahib_singh_ru": {
              "main": "и свой Хари-Господь приходит и поселяется в уме. 2."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57072,
          "is_rahao": false,
          "gurmukhi": "ਨਾਮੁ ਜਪਤ ਹੋਆ ਪਰਗਾਸੁ ॥",
          "roman": "nām japat hoā pargās",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": "(ਮੈਂ ਆਪਣੇ ਉਸ ਗੁਰੂ ਤੋਂ ਸਦਕੇ ਜਾਂਦਾ ਹਾਂ, ਜਿਸ ਦੀ ਕਿਰਪਾ ਨਾਲ ਪਰਮਾਤਮਾ ਦਾ) ਨਾਮ ਜਪਦਿਆਂ (ਮਨ ਵਿਚ ਆਤਮਕ ਜੀਵਨ ਦੀ ਸੂਝ ਦਾ) ਚਾਨਣ ਹੋ ਜਾਂਦਾ ਹੈ,"
            },
            "sahib_singh_ru": {
              "main": "Я иду в жертву тому Гуру, по чьей милости при повторении Имени Бога в уме возникает свет понимания духовной жизни,"
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
