{
  "ang": 1354,
  "shabads": [
    {
      "shabad_id": 4905,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57635,
          "is_rahao": false,
          "gurmukhi": "ਧ੍ਰਿਗੰਤ ਮਾਤ ਪਿਤਾ ਸਨੇਹੰ ਧ੍ਰਿਗ ਸਨੇਹੰ ਭ੍ਰਾਤ ਬਾਂਧਵਹ ॥",
          "roman": "dhrigant māt pitā sanehaṅ dhrig sanehaṅ bhrāt bāṅdhavah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Привязанность к матери и отцу достойна отвержения; привязанность к братьям и родственникам тоже дурна."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57636,
          "is_rahao": false,
          "gurmukhi": "ਧ੍ਰਿਗ ਸ੍ਨੇਹੰ ਬਨਿਤਾ ਬਿਲਾਸ ਸੁਤਹ ॥",
          "roman": "dhrig sanehaṅ banitā bilās sutah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Наслаждение привязанностью к жене и сыну тоже достойно того, чтобы его оставить."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57637,
          "is_rahao": false,
          "gurmukhi": "ਧ੍ਰਿਗ ਸ੍ਨੇਹੰ ਗ੍ਰਿਹਾਰਥ ਕਹ ॥",
          "roman": "dhrig sanehaṅ grihārath kah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Влечение к домашним вещам и имуществу также дурно, потому что всё это преходяще."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57638,
          "is_rahao": false,
          "gurmukhi": "ਸਾਧਸੰਗ ਸ੍ਨੇਹ ਸਤੵਿੰ ਸੁਖਯੰ ਬਸੰਤਿ ਨਾਨਕਹ ॥੨॥",
          "roman": "sādhasaṅg saneh satyiṅ sukhayaṅ basant Nānakah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Любовь к Сатсангу остаётся всегда устойчивой; о Нанак, любящие Сатсанг проводят жизнь в духовном блаженстве."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4906,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57639,
          "is_rahao": false,
          "gurmukhi": "ਮਿਥੵੰਤ ਦੇਹੰ ਖੀਣੰਤ ਬਲਨੰ ॥",
          "roman": "mithyant dehaṅ khīṇant balanaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это тело преходяще, и его сила постоянно уменьшается."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57640,
          "is_rahao": false,
          "gurmukhi": "ਬਰਧੰਤਿ ਜਰੂਆ ਹਿਤੵੰਤ ਮਾਇਆ ॥",
          "roman": "bardhant jarūā hityant māiā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но по мере того как старость усиливается, привязанность к майе тоже возрастает."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57641,
          "is_rahao": false,
          "gurmukhi": "ਅਤੵੰਤ ਆਸਾ ਆਥਿਤੵ ਭਵਨੰ ॥",
          "roman": "atyant āsā āthitya bhavanaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Надежда на вещи становится всё сильнее, хотя живое существо здесь лишь гость в доме."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57642,
          "is_rahao": false,
          "gurmukhi": "ਗਨੰਤ ਸ੍ਵਾਸਾ ਭੈਯਾਨ ਧਰਮੰ ॥",
          "roman": "ganant svāsā bhēyān dharamaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Страшный Дхарам Радж всё время считает его дыхания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57643,
          "is_rahao": false,
          "gurmukhi": "ਪਤੰਤਿ ਮੋਹ ਕੂਪ ਦੁਰਲਭੵ ਦੇਹੰ ਤਤ ਆਸ੍ਰਯੰ ਨਾਨਕ ॥",
          "roman": "patant moh kūp durlabhya dehaṅ tat āsrayaṅ Nānak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это драгоценное человеческое тело падает в колодец привязанности; о Нанак, следует взять опору в Нём."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57644,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਗੋਬਿੰਦ ਗੋਬਿੰਦ ਗੋਪਾਲ ਕ੍ਰਿਪਾ ॥੩॥",
          "roman": "Gobind Gobind Gobind Gopāl kripā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Только милость Гобинда, Гопала может спасти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4907,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57645,
          "is_rahao": false,
          "gurmukhi": "ਕਾਚ ਕੋਟੰ ਰਚੰਤਿ ਤੋਯੰ ਲੇਪਨੰ ਰਕਤ ਚਰਮਣਹ ॥",
          "roman": "kāch koṭaṅ rachant toyaṅ lepanaṅ rakat charmaṇah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Это тело — непрочный крепостной вал, созданный из воды, то есть семени, и обмазанный кровью и кожей."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57646,
          "is_rahao": false,
          "gurmukhi": "ਨਵੰਤ ਦੁਆਰੰ ਭੀਤ ਰਹਿਤੰ ਬਾਇ ਰੂਪੰ ਅਸਥੰਭਨਹ ॥",
          "roman": "navant duāraṅ bhīt rahitaṅ bāi rūpaṅ asthambhanah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У него девять дверей, но нет дверных створок; оно держится на опоре дыхания."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57647,
          "is_rahao": false,
          "gurmukhi": "ਗੋਬਿੰਦ ਨਾਮੰ ਨਹ ਸਿਮਰੰਤਿ ਅਗਿਆਨੀ ਜਾਨੰਤਿ ਅਸਥਿਰੰ ॥",
          "roman": "Gobind nāmaṅ nah simarant agiānī jānant asthiraṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Невежды считают это тело постоянным и не вспоминают Имя Бога."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57648,
          "is_rahao": false,
          "gurmukhi": "ਦੁਰਲਭ ਦੇਹ ਉਧਰੰਤ ਸਾਧ ਸਰਣ ਨਾਨਕ ॥",
          "roman": "durlabh deh udharant sādh saraṇ Nānak",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, те, кто приходит в прибежище Садх Сангат, спасают это редкое тело от пасти постоянной смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57649,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਹਰਿ ਹਰਿ ਹਰਿ ਹਰੇ ਜਪੰਤਿ ॥੪॥",
          "roman": "Har Har Har Har Har hare japant",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Они повторяют Имя Хари, Хари, Хари, Хари, Хари, Харе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4908,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57650,
          "is_rahao": false,
          "gurmukhi": "ਸੁਭੰਤ ਤੁਯੰ ਅਚੁਤ ਗੁਣਗੵੰ ਪੂਰਨੰ ਬਹੁਲੋ ਕ੍ਰਿਪਾਲਾ ॥",
          "roman": "subhant tuyaṅ Achut guṇagyaṅ pūranaṅ bahulo kripālā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Несокрушимый, знающий достоинства, всепроникающий, Ты весьма милостив и сияешь повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57651,
          "is_rahao": false,
          "gurmukhi": "ਗੰਭੀਰੰ ਊਚੈ ਸਰਬਗਿ ਅਪਾਰਾ ॥",
          "roman": "gambhīraṅ ūchē sarbag apārā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты бездонен, высок, знаешь всё и бесконечен."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57652,
          "is_rahao": false,
          "gurmukhi": "ਭ੍ਰਿਤਿਆ ਪ੍ਰਿਅੰ ਬਿਸ੍ਰਾਮ ਚਰਣੰ ॥",
          "roman": "bhritiā priaṅ bisrām charaṇaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Ты дорог Своим слугам, и Твои стопы — их опора и покой."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57653,
          "is_rahao": false,
          "gurmukhi": "ਅਨਾਥ ਨਾਥੇ ਨਾਨਕ ਸਰਣੰ ॥੫॥",
          "roman": "anāth nāthe Nānak saraṇaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: о Владыка беззащитных, мы в Твоём прибежище."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4909,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57654,
          "is_rahao": false,
          "gurmukhi": "ਮ੍ਰਿਗੀ ਪੇਖੰਤ ਬਧਿਕ ਪ੍ਰਹਾਰੇਣ ਲਖੵ ਆਵਧਹ ॥",
          "roman": "mrigī pekhant badhik prahāreṇ lakhya āvadhah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Увидев лань, охотник целится и наносит удар оружием."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57655,
          "is_rahao": false,
          "gurmukhi": "ਅਹੋ ਜਸੵ ਰਖੇਣ ਗੋਪਾਲਹ ਨਾਨਕ ਰੋਮ ਨ ਛੇਦੵਤੇ ॥੬॥",
          "roman": "aho jasya rakheṇ Gopālah Nānak rom na chhedyate",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но дивно: о Нанак, того, кого защищает Гопал, даже волос не может быть повреждён."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57656,
          "is_rahao": false,
          "gurmukhi": "ਬਹੁ ਜਤਨ ਕਰਤਾ ਬਲਵੰਤ ਕਾਰੀ ਸੇਵੰਤ ਸੂਰਾ ਚਤੁਰ ਦਿਸਹ ॥",
          "roman": "bah jatan kartā balavant kārī sevant sūrā chatur disah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек может делать множество усилий, быть очень сильным, и храбрецы со всех четырёх сторон могут служить ему."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57657,
          "is_rahao": false,
          "gurmukhi": "ਬਿਖਮ ਥਾਨ ਬਸੰਤ ਊਚਹ ਨਹ ਸਿਮਰੰਤ ਮਰਣੰ ਕਦਾਂਚਹ ॥",
          "roman": "bikham thān basant ūchah nah simarant maraṇaṅ kadāṅchah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он может жить в труднодоступном высоком месте, где даже никогда не вспоминает о смерти."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57658,
          "is_rahao": false,
          "gurmukhi": "ਹੋਵੰਤਿ ਆਗਿਆ ਭਗਵਾਨ ਪੁਰਖਹ ਨਾਨਕ ਕੀਟੀ ਸਾਸ ਅਕਰਖਤੇ ॥੭॥",
          "roman": "hovant āgiā Bhagavān Purakhah Nānak kīṭī sās akarkhate",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Но, о Нанак, когда есть повеление Благословенного Акал Пуракха, даже муравей вытягивает его дыхание жизни."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4910,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57659,
          "is_rahao": false,
          "gurmukhi": "ਸਬਦੰ ਰਤੰ ਹਿਤੰ ਮਇਆ ਕੀਰਤੰ ਕਲੀ ਕਰਮ ਕ੍ਰਿਤੁਆ ॥",
          "roman": "sabadaṅ rataṅ hitaṅ maiā kīrataṅ kalī karam krituā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Любовь к Гур-шабду, доброжелательная сострадательность к живым существам и восхваление Бога — таковы деяния, совершаемые в этом мире."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57660,
          "is_rahao": false,
          "gurmukhi": "ਮਿਟੰਤਿ ਤਤ੍ਰਾਗਤ ਭਰਮ ਮੋਹੰ ॥",
          "roman": "miṭant tatrāgat bharam mohaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "У такого человека исчезают пришедшие к нему заблуждение и привязанность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57661,
          "is_rahao": false,
          "gurmukhi": "ਭਗਵਾਨ ਰਮਣੰ ਸਰਬਤ੍ਰ ਥਾਨੵਿੰ ॥",
          "roman": "Bhagavān ramaṇaṅ sarbatr thānyiṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Он видит Благословенного Бога пребывающим повсюду."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57662,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿਸਟ ਤੁਯੰ ਅਮੋਘ ਦਰਸਨੰ ਬਸੰਤ ਸਾਧ ਰਸਨਾ ॥",
          "roman": "driṣṭ tuyaṅ amogh darśanaṅ basant sādh rasnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Твоё видение и Твой милостивый взгляд никогда не бывают бесплодными; Ты пребываешь на языке святых."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57663,
          "is_rahao": false,
          "gurmukhi": "ਹਰਿ ਹਰਿ ਹਰਿ ਹਰੇ ਨਾਨਕ ਪ੍ਰਿਅੰ ਜਾਪੁ ਜਪਨਾ ॥੮॥",
          "roman": "Har Har Har hare Nānak priaṅ jāp japnā",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, святым дорог Джап — повторение Имени Хари, Хари, Хари, Харе."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4911,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57664,
          "is_rahao": false,
          "gurmukhi": "ਘਟੰਤ ਰੂਪੰ ਘਟੰਤ ਦੀਪੰ ਘਟੰਤ ਰਵਿ ਸਸੀਅਰ ਨਖੵਤ੍ਰ ਗਗਨੰ ॥",
          "roman": "ghaṭant rūpaṅ ghaṭant dīpaṅ ghaṭant rav sasīar nakhyatr gaganaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Красота преходяща, острова преходящи, солнце, луна, звёзды и небо преходящи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57665,
          "is_rahao": false,
          "gurmukhi": "ਘਟੰਤ ਬਸੁਧਾ ਗਿਰਿ ਤਰ ਸਿਖੰਡੰ ॥",
          "roman": "ghaṭant basudhā gir tar sikhaṇḍaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Земля, высокие горы и деревья преходящи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57666,
          "is_rahao": false,
          "gurmukhi": "ਘਟੰਤ ਲਲਨਾ ਸੁਤ ਭ੍ਰਾਤ ਹੀਤੰ ॥",
          "roman": "ghaṭant lalanā sut bhrāt hītaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Жена, сыновья, братья и близкие родственники преходящи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57667,
          "is_rahao": false,
          "gurmukhi": "ਘਟੰਤ ਕਨਿਕ ਮਾਨਿਕ ਮਾਇਆ ਸ੍ਵਰੂਪੰ ॥",
          "roman": "ghaṭant kanik mānik māiā svarūpaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Золото, драгоценные камни и все формы майи преходящи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57668,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਘਟੰਤ ਕੇਵਲ ਗੋਪਾਲ ਅਚੁਤ ॥",
          "roman": "nah ghaṭant keval Gopāl Achut",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Не преходит только Несокрушимый Гопал."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57669,
          "is_rahao": false,
          "gurmukhi": "ਅਸਥਿਰੰ ਨਾਨਕ ਸਾਧ ਜਨ ॥੯॥",
          "roman": "asthiraṅ Nānak sādh jan",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, Его Садх Сангат и святые люди также пребывают устойчиво."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4912,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57670,
          "is_rahao": false,
          "gurmukhi": "ਨਹ ਬਿਲੰਬ ਧਰਮੰ ਬਿਲੰਬ ਪਾਪੰ ॥",
          "roman": "nah bilaṅb dharamaṅ bilaṅb pāpaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Не медлить в исполнении праведности и медлить перед грехом."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57671,
          "is_rahao": false,
          "gurmukhi": "ਦ੍ਰਿੜੰਤ ਨਾਮੰ ਤਜੰਤ ਲੋਭੰ ॥",
          "roman": "driṛant nāmaṅ tajant lobhaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Утверждать Имя в сердце и оставлять жадность."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57672,
          "is_rahao": false,
          "gurmukhi": "ਸਰਣਿ ਸੰਤੰ ਕਿਲਬਿਖ ਨਾਸੰ ਪ੍ਰਾਪਤੰ ਧਰਮ ਲਖੵਿਣ ॥",
          "roman": "saraṇ santaṅ kilbikh nāsaṅ prāpataṅ dharam lakhyiṇ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Идя в прибежище святых, уничтожать грехи — таковы признаки праведности."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57673,
          "is_rahao": false,
          "gurmukhi": "ਨਾਨਕ ਜਿਹ ਸੁਪ੍ਰਸੰਨ ਮਾਧਵਹ ॥੧੦॥",
          "roman": "Nānak jih suprasann Mādhavah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, эти признаки получает тот человек, на кого милостиво смотрит Мадхав, Господь майи."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4913,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57674,
          "is_rahao": false,
          "gurmukhi": "ਮਿਰਤ ਮੋਹੰ ਅਲਪ ਬੁਧੵੰ ਰਚੰਤਿ ਬਨਿਤਾ ਬਿਨੋਦ ਸਾਹੰ ॥",
          "roman": "mirat mohaṅ alap budhyaṅ rachant banitā binod sāhaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Человек с мелким разумом погружён в привязанность к преходящим вещам и опьянён играми и желаниями женщины."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57675,
          "is_rahao": false,
          "gurmukhi": "ਜੌਬਨ ਬਹਿਕ੍ਰਮ ਕਨਿਕ ਕੁੰਡਲਹ ॥",
          "roman": "jauban bahikram kanik kuṇḍalah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Юность, сила, золотые серьги и подобные украшения — через это майя действует на него."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57676,
          "is_rahao": false,
          "gurmukhi": "ਬਚਿਤ੍ਰ ਮੰਦਿਰ ਸੋਭੰਤਿ ਬਸਤ੍ਰਾ ਇਤੵੰਤ ਮਾਇਆ ਬੵਾਪਿਤੰ ॥",
          "roman": "bachitr mandir sobhant bastrā ityant māiā byāpitaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Разнообразные дворцы и красивые одежды — такими способами майя охватывает его и оказывает своё влияние."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57677,
          "is_rahao": false,
          "gurmukhi": "ਹੇ ਅਚੁਤ ਸਰਣਿ ਸੰਤ ਨਾਨਕ ਭੋ ਭਗਵਾਨਏ ਨਮਹ ॥੧੧॥",
          "roman": "he Achut saraṇ sant Nānak bho Bhagavāne namah",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "О Нанак, скажи: о Несокрушимый, о прибежище святых, о Бхагаван, Тебе наш поклон."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    },
    {
      "shabad_id": 4914,
      "rahao_verse_id": null,
      "rahao_theme": "",
      "shabad_summary": "",
      "lines": [
        {
          "verse_id": 57678,
          "is_rahao": false,
          "gurmukhi": "ਜਨਮੰ ਤ ਮਰਣੰ ਹਰਖੰ ਤ ਸੋਗੰ ਭੋਗੰ ਤ ਰੋਗੰ ॥",
          "roman": "janamaṅ ta maraṇaṅ harakhaṅ ta sogaṅ bhogaṅ ta rogaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Где есть рождение, там есть и смерть; где есть радость, там есть и печаль; где есть наслаждения мирскими вещами, там есть и болезни, рождающиеся от них."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        },
        {
          "verse_id": 57679,
          "is_rahao": false,
          "gurmukhi": "ਊਚੰ ਤ ਨੀਚੰ ਨਾਨੑਾ ਸੁ ਮੂਚੰ ॥",
          "roman": "ūchaṅ ta nīchaṅ nānĥā su mūchaṅ",
          "translations": {
            "ksd_ru": {
              "main": "",
              "artistic": "",
              "context_note": ""
            },
            "sahib_singh_pa": {
              "main": ""
            },
            "sahib_singh_ru": {
              "main": "Где есть возвышение, туда приходит и низость; где есть малость или бедность, там может возникнуть и величие."
            },
            "ipotseluev_ru": {
              "main": ""
            }
          }
        }
      ]
    }
  ]
}
