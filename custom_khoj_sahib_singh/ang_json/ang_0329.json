{
  "ang": 329,
  "line_count": 55,
  "lines": [
    {
      "index": 1,
      "verse_id": 14962,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨਹਿ ਮਾਰਿ ਕਵਨ ਸਿਧਿ ਥਾਪੀ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "manahi mār kavan sidh thāpī. ||1||",
      "translation_ru": "Умертвив ум, какую успешность можно обрести? Это не является настоящим достижением."
    },
    {
      "index": 2,
      "verse_id": 14963,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਵਨੁ ਸੁ ਮੁਨਿ ਜੋ ਮਨੁ ਮਾਰੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kavan so mun jo man mārey.",
      "translation_ru": "Какой это муни, который умерщвляет ум?"
    },
    {
      "index": 3,
      "verse_id": 14964,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਕਉ ਮਾਰਿ ਕਹਹੁ ਕਿਸੁ ਤਾਰੈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man kau mār kahhu kis tārey. ||1|| rahāu.",
      "translation_ru": "Скажите: умертвив ум, кого он спасает? Пауза."
    },
    {
      "index": 4,
      "verse_id": 14965,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਅੰਤਰਿ ਬੋਲੈ ਸਭੁ ਕੋਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man antar boley sabh koī.",
      "translation_ru": "Каждый человек говорит под побуждением ума."
    },
    {
      "index": 5,
      "verse_id": 14966,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨ ਮਾਰੇ ਬਿਨੁ ਭਗਤਿ ਨ ਹੋਈ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man mārey bin bhagat na hoī. ||2||",
      "translation_ru": "Без обуздания ума, то есть без удержания его от пороков, не может быть и бхагти."
    },
    {
      "index": 6,
      "verse_id": 14967,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜੋ ਜਾਨੈ ਭੇਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho Kabīr jo jāney bheu.",
      "translation_ru": "Кабир говорит: кто понимает эту тайну,"
    },
    {
      "index": 7,
      "verse_id": 14968,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮਨੁ ਮਧੁਸੂਦਨੁ ਤ੍ਰਿਭਵਣ ਦੇਉ ॥੩॥੨੮॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "man madhusūdan tribhavaṇ deu. ||3||28||",
      "translation_ru": "его ум становится образом Бога-Мадхусудана, светящего трем мирам."
    },
    {
      "index": 8,
      "verse_id": 14969,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī.",
      "translation_ru": "Гаури, Кабир Джи."
    },
    {
      "index": 9,
      "verse_id": 14970,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਓਇ ਜੁ ਦੀਸਹਿ ਅੰਬਰਿ ਤਾਰੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "oī jo dīseh aṃbar tārey.",
      "translation_ru": "Те звезды, что видны в небе,"
    },
    {
      "index": 10,
      "verse_id": 14971,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਿਨਿ ਓਇ ਚੀਤੇ ਚੀਤਨਹਾਰੇ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kin oī chītey chītanhārey. ||1||",
      "translation_ru": "какой Художник начертал их?"
    },
    {
      "index": 11,
      "verse_id": 14972,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਰੇ ਪੰਡਿਤ ਅੰਬਰੁ ਕਾ ਸਿਉ ਲਾਗਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho re paṇḍit aṃbar kā siu lāgā.",
      "translation_ru": "Скажи, о пандит: на чем держится небо?"
    },
    {
      "index": 12,
      "verse_id": 14973,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੂਝੈ ਬੂਝਨਹਾਰੁ ਸਭਾਗਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "būjhē būjhanhār sabhāgā. ||1|| rahāu.",
      "translation_ru": "Лишь счастливый мудрец понимает эту тайну. Пауза."
    },
    {
      "index": 13,
      "verse_id": 14974,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸੂਰਜ ਚੰਦੁ ਕਰਹਿ ਉਜੀਆਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sūraj chand karah ujīārā.",
      "translation_ru": "Солнце и луна дают свет в мире."
    },
    {
      "index": 14,
      "verse_id": 14975,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਭ ਮਹਿ ਪਸਰਿਆ ਬ੍ਰਹਮ ਪਸਾਰਾ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sabh meh pasriā brahm pasārā. ||2||",
      "translation_ru": "Во всем распространено сияние Божественной Джот, проявление Брахма."
    },
    {
      "index": 15,
      "verse_id": 14976,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਜਾਨੈਗਾ ਸੋਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho Kabīr jānēgā soī.",
      "translation_ru": "Кабир говорит: эту тайну поймет только тот,"
    },
    {
      "index": 16,
      "verse_id": 14977,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਿਰਦੈ ਰਾਮੁ ਮੁਖਿ ਰਾਮੈ ਹੋਇ ॥੩॥੨੯॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "hirdē rām mukh rāmē hoī. ||3||29||",
      "translation_ru": "в чьем сердце пребывает Рам и чьи уста произносят только Рама."
    },
    {
      "index": 17,
      "verse_id": 14978,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī.",
      "translation_ru": "Гаури, Кабир Джи."
    },
    {
      "index": 18,
      "verse_id": 14979,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬੇਦ ਕੀ ਪੁਤ੍ਰੀ ਸਿੰਮ੍ਰਿਤਿ ਭਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bed kī putrī simrit bhāī.",
      "translation_ru": "О брат, эта Симрити, дочь Вед, созданная на их основе,"
    },
    {
      "index": 19,
      "verse_id": 14980,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾਂਕਲ ਜੇਵਰੀ ਲੈ ਹੈ ਆਈ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sāṅkal jevrī lē hē āī. ||1||",
      "translation_ru": "принесла с собой цепи варн-ашрамов и веревки обрядов."
    },
    {
      "index": 20,
      "verse_id": 14981,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਪਨ ਨਗਰੁ ਆਪ ਤੇ ਬਾਧਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āpan nagar āp te bādhiā.",
      "translation_ru": "Она сама связала всех своих последователей."
    },
    {
      "index": 21,
      "verse_id": 14982,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਮੋਹ ਕੈ ਫਾਧਿ ਕਾਲ ਸਰੁ ਸਾਂਧਿਆ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "moh kē phādh kāl sar sāndhiā. ||1|| rahāu.",
      "translation_ru": "Поймав их в петлю привязанности, она натянула над ними стрелу смерти и рождения. Пауза."
    },
    {
      "index": 22,
      "verse_id": 14983,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਟੀ ਨ ਕਟੈ ਤੂਟਿ ਨਹ ਜਾਈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaṭī na kaṭē ṭūṭ nah jāī.",
      "translation_ru": "Эта петля не разрубается разрубанием и сама не рвется."
    },
    {
      "index": 23,
      "verse_id": 14984,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਾ ਸਾਪਨਿ ਹੋਇ ਜਗ ਕਉ ਖਾਈ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sā sāpan hoi jag kau khāī. ||2||",
      "translation_ru": "Она стала змеей и пожирает мир, уничтожая собственных последователей."
    },
    {
      "index": 24,
      "verse_id": 14985,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਮ ਦੇਖਤ ਜਿਨਿ ਸਭੁ ਜਗੁ ਲੂਟਿਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ham dekhat jin sabh jag lūṭiā.",
      "translation_ru": "На наших глазах она обманула весь мир."
    },
    {
      "index": 25,
      "verse_id": 14986,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਮੈ ਰਾਮ ਕਹਿ ਛੂਟਿਆ ॥੩॥੩੦॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho Kabīr mē rām kahi chhūṭiā. ||3||30||",
      "translation_ru": "Кабир говорит: я спасся от нее, повторяя Рам, вспоминая Бога."
    },
    {
      "index": 26,
      "verse_id": 14987,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī.",
      "translation_ru": "Гаури, Кабир Джи."
    },
    {
      "index": 27,
      "verse_id": 14988,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਦੇਇ ਮੁਹਾਰ ਲਗਾਮੁ ਪਹਿਰਾਵਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "dei muhār lagām pahirāvau.",
      "translation_ru": "Я надеваю на коня-ум намордник воздержания от хвалы и хулы и узду любви."
    },
    {
      "index": 28,
      "verse_id": 14989,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਗਲ ਤ ਜੀਨੁ ਗਗਨ ਦਉਰਾਵਉ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sagalat jīn gagan daurāvau. ||1||",
      "translation_ru": "Надев седло знания о всепроникающем Боге, я заставляю ум лететь в страну Нирankar, то есть соединяю его с памятью о Боге."
    },
    {
      "index": 29,
      "verse_id": 14990,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਪਨੈ ਬੀਚਾਰਿ ਅਸਵਾਰੀ ਕੀਜੈ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "apnē bīchār asvārī kījē.",
      "translation_ru": "Сядем верхом на коня знания своего истинного существа."
    },
    {
      "index": 30,
      "verse_id": 14991,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਸਹਜ ਕੈ ਪਾਵੜੈ ਪਗੁ ਧਰਿ ਲੀਜੈ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "sahaj kē pāvṛē pag dhar lījē. ||1|| rahāu.",
      "translation_ru": "Поставим ногу-разум в стремя состояния сахадж, чтобы не упасть. Пауза."
    },
    {
      "index": 31,
      "verse_id": 14992,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਚਲੁ ਰੇ ਬੈਕੁੰਠ ਤੁਝਹਿ ਲੇ ਤਾਰਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "chal re bēkunṭh tujheh le tārau.",
      "translation_ru": "Иди, о конь-ум, я покажу тебе прогулки по Бэкунтху."
    },
    {
      "index": 32,
      "verse_id": 14993,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹਿਚਹਿ ਤ ਪ੍ਰੇਮ ਕੈ ਚਾਬੁਕ ਮਾਰਉ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "hicheh ta prem kē chābuk mārau. ||2||",
      "translation_ru": "Если станешь упрямиться, я ударю тебя кнутом любви."
    },
    {
      "index": 33,
      "verse_id": 14994,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹਤ ਕਬੀਰ ਭਲੇ ਅਸਵਾਰਾ ॥ ਬੇਦ ਕਤੇਬ ਤੇ ਰਹਹਿ ਨਿਰਾਰਾ ॥੩॥੩੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kahat Kabīr bhaley asvārā. bed kateb te raheh nirārā. ||3||31||",
      "translation_ru": "Кабир говорит: такие мудрые всадники, владеющие своим умом, остаются в стороне от споров о Ведах и Катебах."
    },
    {
      "index": 34,
      "verse_id": 14995,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī.",
      "translation_ru": "Гаури, Кабир Джи."
    },
    {
      "index": 35,
      "verse_id": 14996,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਿਹ ਮੁਖਿ ਪਾਂਚਉ ਅੰਮ੍ਰਿਤ ਖਾਏ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jih mukh pāñchau amrit khāe.",
      "translation_ru": "Тем самым ртом, которым ели пять лучших сладких веществ,"
    },
    {
      "index": 36,
      "verse_id": 14997,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਤਿਹ ਮੁਖ ਦੇਖਤ ਲੂਕਟ ਲਾਏ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "tih mukh dekhat lūkaṭ lāe. ||1||",
      "translation_ru": "после смерти перед глазами людей подносят к нему пламя."
    },
    {
      "index": 37,
      "verse_id": 14998,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਇਕੁ ਦੁਖੁ ਰਾਮ ਰਾਇ ਕਾਟਹੁ ਮੇਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ik dukh rām rāi kāṭah merā.",
      "translation_ru": "О мой прекрасный Рам, устрани одну мою боль."
    },
    {
      "index": 38,
      "verse_id": 14999,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਅਗਨਿ ਦਹੈ ਅਰੁ ਗਰਭ ਬਸੇਰਾ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "agan dahē ar garabh baserā. ||1|| rahāu.",
      "translation_ru": "Это огонь жажды, который сжигает, и пребывание в утробе, то есть повторное рождение и смерть. Пауза."
    },
    {
      "index": 39,
      "verse_id": 15000,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾਇਆ ਬਿਗੂਤੀ ਬਹੁ ਬਿਧਿ ਭਾਤੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kāiā bigūtī bah bidh bhātī.",
      "translation_ru": "После смерти это тело портится многими разными способами."
    },
    {
      "index": 40,
      "verse_id": 15001,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੋ ਜਾਰੇ ਕੋ ਗਡਿ ਲੇ ਮਾਟੀ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "ko jārey ko gaḍ le māṭī. ||2||",
      "translation_ru": "Одни сжигают его, другие закапывают в землю."
    },
    {
      "index": 41,
      "verse_id": 15002,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਹਰਿ ਚਰਣ ਦਿਖਾਵਹੁ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho Kabīr har charaṇ dikhāvah.",
      "translation_ru": "Кабир говорит: о Хари, даруй мне видение Твоих стоп."
    },
    {
      "index": 42,
      "verse_id": 15003,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਪਾਛੈ ਤੇ ਜਮੁ ਕਿਉ ਨ ਪਠਾਵਹੁ ॥੩॥੩੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "pāchhē te jam kiu na paṭhāvah. ||3||32||",
      "translation_ru": "После этого, если хочешь, пошли даже Яма забрать мои праны."
    },
    {
      "index": 43,
      "verse_id": 15004,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī.",
      "translation_ru": "Гаури, Кабир Джи."
    },
    {
      "index": 44,
      "verse_id": 15005,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਆਪੇ ਪਾਵਕੁ ਆਪੇ ਪਵਨਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "āpey pāvak āpey pavnā.",
      "translation_ru": "Сам Господин является и огнем, и ветром."
    },
    {
      "index": 45,
      "verse_id": 15006,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਜਾਰੈ ਖਸਮੁ ਤ ਰਾਖੈ ਕਵਨਾ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "jārē khasam ta rākhē kavnā. ||1||",
      "translation_ru": "Если Сам Господин начнет сжигать живое существо, кто сможет его спасти?"
    },
    {
      "index": 46,
      "verse_id": 15007,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮ ਜਪਤ ਤਨੁ ਜਰਿ ਕੀ ਨ ਜਾਇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rām japat tan jar kī na jāe.",
      "translation_ru": "Когда человек вспоминает Рама, пусть даже тело сгорит — он не тревожится."
    },
    {
      "index": 47,
      "verse_id": 15008,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਰਾਮ ਨਾਮ ਚਿਤੁ ਰਹਿਆ ਸਮਾਇ ॥੧॥ ਰਹਾਉ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "rām nām chit rahiā samāe. ||1|| rahāu.",
      "translation_ru": "Его сознание остается погруженным в Имя Рама. Пауза."
    },
    {
      "index": 48,
      "verse_id": 15009,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਾ ਕੋ ਜਰੈ ਕਾਹਿ ਹੋਇ ਹਾਨਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kā ko jarē kāh hoi hān.",
      "translation_ru": "Что и у кого сгорает? Кому бывает ущерб?"
    },
    {
      "index": 49,
      "verse_id": 15010,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਟ ਵਟ ਖੇਲੈ ਸਾਰਿਗਪਾਨਿ ॥੨॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "naṭ vaṭ khelē sārīg pān. ||2||",
      "translation_ru": "Бог, Саригпани, Сам играет в разных обликах, как актеры на сцене."
    },
    {
      "index": 50,
      "verse_id": 15011,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕਹੁ ਕਬੀਰ ਅਖਰ ਦੁਇ ਭਾਖਿ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kaho Kabīr akhar dui bhākh.",
      "translation_ru": "Кабир говорит: запомни эту малую истину."
    },
    {
      "index": 51,
      "verse_id": 15012,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਹੋਇਗਾ ਖਸਮੁ ਤ ਲੇਇਗਾ ਰਾਖਿ ॥੩॥੩੩॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "hoigā khasam ta leigā rākh. ||3||33||",
      "translation_ru": "Если Господину будет угодно, Он Сам спасет, где это потребуется."
    },
    {
      "index": 52,
      "verse_id": 15013,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਗਉੜੀ ਕਬੀਰ ਜੀ ਦੁਪਦੇ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "Gaurī Kabīr jī dupde.",
      "translation_ru": "Гаури, Кабир Джи, двустишия."
    },
    {
      "index": 53,
      "verse_id": 15014,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਨਾ ਮੈ ਜੋਗ ਧਿਆਨ ਚਿਤੁ ਲਾਇਆ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "nā mē jog dhiān chit lāiā.",
      "translation_ru": "Я не сосредоточил сознание на медитации йоги, то есть на самадхи, которые она описывает."
    },
    {
      "index": 54,
      "verse_id": 15015,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਬਿਨੁ ਬੈਰਾਗ ਨ ਛੂਟਸਿ ਮਾਇਆ ॥੧॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "bin bērāg na chhūṭas māiā. ||1||",
      "translation_ru": "Без вайрага, отрешенности от привязанности к миру, не будет освобождения от Майи."
    },
    {
      "index": 55,
      "verse_id": 15016,
      "shabad_num": 0,
      "shabad_id": null,
      "gurmukhi": "ਕੈਸੇ ਜੀਵਨੁ ਹੋਇ ਹਮਾਰਾ ॥",
      "site_roman": "",
      "sahib_singh_pa": "",
      "roman": "kēse jīvan hoe hamārā.",
      "translation_ru": "Как может быть наша истинная жизнь?"
    }
  ]
}
